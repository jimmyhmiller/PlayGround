(module samecode_test)
; ============================================================================
; THE SAME-CODE PROOF, part 2: run every shared function in BOTH phases.
;
; `ct-all` is a METAPROGRAM: at expansion time it calls the eight shared
; functions (samecode.coil) as native code in the metaprogram dylib and splices
; the results into the program as literals. `main` then calls THE SAME EIGHT
; FUNCTIONS at runtime on the SAME inputs and compares every result
; bit-for-bit (f64 via its raw bits, strings byte-wise). Exit 0 = every
; computation — hashing, fnptr sorting, hashmaps, a parser, THE COMPILER'S OWN
; READER, float iteration, libc snprintf, and two POSIX threads — produced the
; identical answer at compile time and at run time.
;
;   coil run metaprog-poc/compile-and-run/samecode_test.coil
; ============================================================================
(import "metaprog-poc/compile-and-run/samecode.coil" :use *)
(import "lib/io.coil" :use *)
(import "lib/fmt.coil" :use *)
(import "lib/str.coil" :use *)
(import "lib/control.coil" :use *)

; the metaprogram: eight computations at EXPANSION TIME, spliced as literals
(defn ct-all [] (-> Code)
  (fmt (stderr) "[samecode] computing all eight at COMPILE TIME (in the metaprogram dylib)\n")
  `(rt-compare ~(sc-fnv SC-TEXT)
               ~(sc-sort-sum 200)
               ~(sc-map-stats 100)
               ~(sc-arith SC-ARITH)
               ~(sc-reader-fold SC-COIL-SRC)
               ~(sc-f64-bits (sc-f64-iter -0.7436 0.1318 64))
               ~(sc-libc-fmt (sc-f64-iter -0.7436 0.1318 64))
               ~(sc-thread-sum 1000000)))

(defn rt-check-i [(name (slice u8)) (ct i64) (rt i64)] (-> i64)
  (fmt (stdout) "  {s}: compile-time={d} run-time={d}  {s}\n" name ct rt (if (icmp-eq ct rt) "OK" "MISMATCH"))
  (if (icmp-eq ct rt) 0 1))
(defn rt-check-s [(name (slice u8)) (ct (slice u8)) (rt (slice u8))] (-> i64)
  (fmt (stdout) "  {s}: compile-time={s} run-time={s}  {s}\n" name ct rt (if (str-eq ct rt) "OK" "MISMATCH"))
  (if (str-eq ct rt) 0 1))

; the runtime: THE SAME eight computations, compared against the spliced values
(defn rt-compare [(fnv i64) (sortsum i64) (mapstats i64) (arith i64)
                  (readerfold i64) (fbits i64) (ffmt (slice u8)) (tsum i64)] (-> i64)
  (fmt (stdout) "same-code proof: eight computations, one definition each, two phases\n")
  (let [(mut bad) 0]
    (store! bad (iadd (load bad) (rt-check-i "fnv-1a hash            " fnv (sc-fnv SC-TEXT))))
    (store! bad (iadd (load bad) (rt-check-i "fnptr insertion sort   " sortsum (sc-sort-sum 200))))
    (store! bad (iadd (load bad) (rt-check-i "string-keyed hashmap   " mapstats (sc-map-stats 100))))
    (store! bad (iadd (load bad) (rt-check-i "recursive-descent parse" arith (sc-arith SC-ARITH))))
    (store! bad (iadd (load bad) (rt-check-i "THE COMPILER'S READER  " readerfold (sc-reader-fold SC-COIL-SRC))))
    (store! bad (iadd (load bad) (rt-check-i "f64 iteration (BITS)   " fbits (sc-f64-bits (sc-f64-iter -0.7436 0.1318 64)))))
    (store! bad (iadd (load bad) (rt-check-s "libc snprintf %.17g    " ffmt (sc-libc-fmt (sc-f64-iter -0.7436 0.1318 64)))))
    (store! bad (iadd (load bad) (rt-check-i "two POSIX threads      " tsum (sc-thread-sum 1000000))))
    (if (icmp-eq (load bad) 0)
        (fmt (stdout) "ALL IDENTICAL: metaprograms and programs run the same code.\n")
      (fmt (stdout) "{d} MISMATCHES\n" (load bad)))
    (load bad)))

(defn main [] (-> :i64)
  (ct-all))
