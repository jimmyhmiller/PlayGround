(module tower_fmt_test)
(import "lib/io.coil" :use *)
(import "lib/fmt.coil" :use *)
(import "lib/control.coil" :use *)
; fmt — a MACRO — used inside a macro body, for expansion-time debug logging.
; The tower expands it at definition time; RUNNING it needs the compiled engine
; (its expansion calls through Writer function pointers).
(defn traced-const [(c Code)] (-> Code)
  (let [v (code-int c)]
    (fmt (stderr) "[traced-const] expanding with {d}\n" v)
    `~(imul v 10)))
(defn main [] (-> :i64) (traced-const 7))
