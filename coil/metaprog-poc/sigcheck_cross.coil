(module app)
(import "sigcheck.coil" :use *)
(import "ptrmod.coil" :use *)
(checker check-sigs)

; `ident` is defined in ANOTHER module (ptrmod) and imported. The checker resolves
; its declaration across the module boundary from the authoritative checked program
; and sees its return type is (ptr i64) → vetoes.
(defn main [] (-> i64)
  (let [p (alloc-stack i64)]
    (store! p 0)
    (load (ident p))))
