(module located)
(defn check-node [(f Code)] (-> Code)
  (if (code-list? f)
      (if (and (icmp-gt (code-count f) 0) (code-eq (code-nth f 0) `banned))
          (report f "banned form used here")
        (check-kids f 0 (code-count f)))
    `0))
(defn check-kids [(f Code) (i i64) (n i64)] (-> Code)
  (if (icmp-ge i n) `0 (do (check-node (code-nth f i)) (check-kids f (iadd i 1) n))))
(defn located-check [(prog Code)] (-> Code) (check-kids prog 0 (code-count prog)))
