; Use the closure library via the module system.
;   coil run examples/closure-lib.coil; echo $?   => 42
(include "lib/closure.coil")

(defclosure adder  [(n :i64)] [(x :i64)] :i64 (iadd n x))
(defclosure scaler [(k :i64)] [(x :i64)] :i64 (imul k x))

(defn main [] (-> :i64)
  (let [a (adder-new 5) s (scaler-new 3)]
    (let [r (iadd (adder-call a 37) (isub (scaler-call s 14) 42))]
      (adder-free a) (scaler-free s)
      r)))
