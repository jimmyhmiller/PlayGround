(defsum Option [T] (None) (Some [(val T)]))

(defn
  unwrap-or
  [T]
  [(o (Option T)) (default T)]
  (-> T)
  (match o (None [] default) (Some [v] v)))

(defsum Shape (Circle [(r :i64)]) (Rect [(w :i64) (h :i64)]))

(defn
  area
  [(s Shape)]
  (-> :i64)
  (match s (Circle [r] (imul 3 (imul r r))) (Rect [w h] (imul w h))))

(defn main [] (-> :i64) (iadd (unwrap-or [i64] (Some [i64] 30) 0) (area (Rect 4 3))))

