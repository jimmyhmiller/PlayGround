; selfhost/src/embedded_stdlib.coil — GENERATED by tools/gen-embedded-stdlib.py.
; The prelude + bundled stdlib as string constants, so the compiler is portable
; (runs outside the repo). Do not edit by hand; regenerate after editing the
; prelude or any bundled lib/*.coil, then rebuild the compiler.
(module embedded_stdlib)

(import "slice.coil" :use *)
(import "str.coil" :use *)

(defn embedded-prelude [] (-> (slice u8))
  "(module coil.core)
; THE CORE NAMESPACE — compiled into the compiler (src/prelude.coil) and auto-loaded
; (auto-referred) into every program, like Clojure's clojure.core. Its names — the
; traits `Eq`/`Hash`/`Add`/… and their operator methods `=`/`+`/`hash`/… — are in
; scope with NO import (every other module must be `:use`/`:as`-imported). Trait
; names are namespaced to `coil.core`; add a type with `(impl Eq YourType …)` or
; `(derive Eq YourType)` (lib/derive.coil).

; RE-EXPORT: `:reexport` re-publishes a module's exported names as part of core, so
; they are auto-referred everywhere (only `:reexport`ed targets, not plain `:use`s).
; This one line gives every program the everyday control flow (while/for/cond/when/
; case/|>/…) with no import. Add another `:reexport` line here to fold more into core.
(import \"control.coil\" :reexport)

; Ambient `print`/`println` over stdout — zero-import everyday output (Clojure's
; `println` in clojure.core). Only those two names are folded into core; the rest of
; the IO/format machinery (Writer, `fmt`, print-*) stays in io/fmt, imported as
; needed. A freestanding program that never prints drags none of it in (the io
; functions are unreferenced → dead-stripped).
(import \"print.coil\" :reexport)

; Option / Result (and Some/None/Ok/Err) are core vocabulary — like Rust's prelude.
; Pure generic sums (no runtime/externs), so this is freestanding-safe, and the
; allocator/IO trait signatures can use Option with no import at the use site.
; `match` recovers the concrete instance from the scrutinee, and bidirectional
; checking pushes the expected type into a bare `(None)`/`(Ok v)`/`(Err e)`, so
; both consuming and constructing them need no `[T …]` annotation in practice.
(defsum Option [T]
  (None)
  (Some [(val T)]))

(defsum Result [T E]
  (Ok  [(val T)])
  (Err [(err E)]))

; structural equality — the method is `=` (so `(= a b)` at runtime).
(deftrait Eq [Self]
  (= [(a Self) (b Self)] (-> bool)))
; inequality for free on any `Eq` type — `(!= a b)` is `(not (= a b))`.
(defn != [(T Eq)] [(a T) (b T)] (-> bool) (not (= a b)))

; a hash of the value (FNV-1a over fields, when derived)
(deftrait Hash [Self]
  (hash [(x Self)] (-> i64)))

; ---- arithmetic + ordering, as traits (Rust-style) -------------------------
; So `+ - * / %` and `< <= > >=` work and dispatch by type — and a generic can be
; bounded `(T Add)` / `(T Ord)`. Each lowers to the core op in the impl, which the
; optimizer inlines, so there's no overhead on primitives.
(deftrait Add [Self] (+ [(a Self) (b Self)] (-> Self)))
(deftrait Sub [Self] (- [(a Self) (b Self)] (-> Self)))
(deftrait Mul [Self] (* [(a Self) (b Self)] (-> Self)))
(deftrait Div [Self] (/ [(a Self) (b Self)] (-> Self)))
(deftrait Rem [Self] (% [(a Self) (b Self)] (-> Self)))
(deftrait Ord [Self]
  (<  [(a Self) (b Self)] (-> bool))
  (<= [(a Self) (b Self)] (-> bool))
  (>  [(a Self) (b Self)] (-> bool))
  (>= [(a Self) (b Self)] (-> bool)))

; standard impls for the common scalar key, i64 (other widths: impl as needed).
(impl Eq i64 (= [(a i64) (b i64)] (-> bool) (icmp-eq a b)))
; bool is Eq (i1 compare). Note: f64 is deliberately NOT Eq — like Rust, because
; NaN != NaN breaks reflexivity; use fcmp-eq / fcmp-ne for floats.
(impl Eq bool (= [(a bool) (b bool)] (-> bool) (if a b (not b))))
(impl Hash i64 (hash [(x i64)] (-> i64) x))
(impl Add i64 (+ [(a i64) (b i64)] (-> i64) (iadd a b)))
(impl Sub i64 (- [(a i64) (b i64)] (-> i64) (isub a b)))
(impl Mul i64 (* [(a i64) (b i64)] (-> i64) (imul a b)))
(impl Div i64 (/ [(a i64) (b i64)] (-> i64) (idiv a b)))
(impl Rem i64 (% [(a i64) (b i64)] (-> i64) (irem a b)))
(impl Ord i64
  (<  [(a i64) (b i64)] (-> bool) (icmp-lt a b))
  (<= [(a i64) (b i64)] (-> bool) (icmp-le a b))
  (>  [(a i64) (b i64)] (-> bool) (icmp-gt a b))
  (>= [(a i64) (b i64)] (-> bool) (icmp-ge a b)))

; f64 arithmetic + ordering
(impl Add f64 (+ [(a f64) (b f64)] (-> f64) (fadd a b)))
(impl Sub f64 (- [(a f64) (b f64)] (-> f64) (fsub a b)))
(impl Mul f64 (* [(a f64) (b f64)] (-> f64) (fmul a b)))
(impl Div f64 (/ [(a f64) (b f64)] (-> f64) (fdiv a b)))
(impl Ord f64
  (<  [(a f64) (b f64)] (-> bool) (fcmp-lt a b))
  (<= [(a f64) (b f64)] (-> bool) (fcmp-le a b))
  (>  [(a f64) (b f64)] (-> bool) (fcmp-gt a b))
  (>= [(a f64) (b f64)] (-> bool) (fcmp-ge a b)))

; ---- bitwise, as traits ----------------------------------------------------
; Rust-style bit operators `& | ^ << >>`, dispatched by type and inlined to the
; core op — so `(& op 0xC7)` reads like C's `op & 0xC7` with no overhead. (Unary
; bitwise-not has no operator: `~` is the reader's unquote; use `(^ a -1)`.)
(deftrait BitAnd [Self] (& [(a Self) (b Self)] (-> Self)))
(deftrait BitOr  [Self] (| [(a Self) (b Self)] (-> Self)))
(deftrait BitXor [Self] (^ [(a Self) (b Self)] (-> Self)))
(deftrait Shl    [Self] (<< [(a Self) (b Self)] (-> Self)))
(deftrait Shr    [Self] (>> [(a Self) (b Self)] (-> Self)))

(impl BitAnd i64 (& [(a i64) (b i64)] (-> i64) (iand a b)))
(impl BitOr  i64 (| [(a i64) (b i64)] (-> i64) (ior a b)))
(impl BitXor i64 (^ [(a i64) (b i64)] (-> i64) (ixor a b)))
(impl Shl    i64 (<< [(a i64) (b i64)] (-> i64) (ishl a b)))
(impl Shr    i64 (>> [(a i64) (b i64)] (-> i64) (ishr a b)))

; ---- collections, as traits -------------------------------------------------
; The everyday collection vocabulary — `(len xs)`, `(get xs k)`, `(push! xs v)`
; — dispatched by the receiver's type, like the operators above. These traits
; are PARAMETERIZED: after `Self`, the extra type parameters (an element type, a
; map's key/value) are DETERMINED by Self — one impl per type, so a call on a
; concrete receiver reads them off that type's impl (associated types with a
; lighter surface). Impls live with their types: lib/arraylist.coil,
; lib/slice.coil ((slice T) covers strings), lib/hashmap.coil, lib/str.coil.
(deftrait Len [Self]
  (len [(xs Self)] (-> i64)))
; K = how you address an element (i64 for lists/slices, the key type for maps);
; E = what you get back (a map returns (Option V) — absence is in the type).
(deftrait Get [Self K E]
  (get [(xs Self) (k K)] (-> E)))
(deftrait Set [Self K E]
  (set! [(xs (mut Self)) (k K) (v E)] (-> i64)))
(deftrait Push [Self E]
  (push! [(xs (mut Self)) (v E)] (-> i64)))
(deftrait Pop [Self E]
  (pop! [(xs (mut Self))] (-> (Option E))))

; Emptiness, generically: any type with a Len impl gets `empty?` for free (a
; bounded generic over a trait — the pattern user code can copy).
(defn empty? [(C Len)] [(xs C)] (-> bool)
  (icmp-eq (len xs) 0))
")

; text of a bundled stdlib module by filename, or an empty slice if not bundled.
(defn embedded-lib [(name (slice u8))] (-> (slice u8))
  (cond
    (str-eq name "alloc.coil")
      "(module alloc)
; Zig-style allocators: an allocator is a VALUE (a vtable struct) threaded
; explicitly. There is no ambient heap -- a function that allocates *takes* an
; Allocator, so allocation is visible in its type. Built entirely in Coil; the
; compiler has no allocator concept.
;
; The vtable is alignment-aware and carries the size+alignment back to `free`
; (so bump/pool allocators can reclaim precisely), mirroring Zig's interface:
;   alloc  (ctx, len, align)            -> (Option bytes)   None = out of memory
;   resize (ctx, ptr, old, new, align)  -> (Option bytes)   None = couldn't grow
;   free   (ctx, ptr, len, align)       -> _
; Failure is a sum type (Option), never a null sentinel.

(import \"result.coil\" :use *)   ; Option/Result/Some/None/Ok/Err, brought in bare

(extern malloc  :cc c [:i64] (-> (ptr i8)))            ; void* malloc(size_t)
(extern realloc :cc c [(ptr i8) :i64] (-> (ptr i8)))   ; void* realloc(void*, size_t)
(extern abort   :cc c [] (-> :i64))                    ; void abort() — unrecoverable hard-fail

; Hard-abort the process on an unrecoverable allocation failure. Exposed as a defn
; (not the bare extern) so callers share ONE `abort` declaration: Coil doesn't dedup
; identical externs across modules, and defns ARE shared via `:use *` while extern
; decls are not — so collections route OOM through `oom` instead of each declaring
; their own `abort` (which would collide when two such libs are imported together).
(defn oom [] (-> :i64) (abort) 0)

(defstruct Allocator
  [(alloc  (fnptr c [(ptr i8) :i64 :i64] (Option (ptr i8))))
   (resize (fnptr c [(ptr i8) (ptr i8) :i64 :i64 :i64] (Option (ptr i8))))
   (free   (fnptr c [(ptr i8) (ptr i8) :i64 :i64] :i64))
   (ctx    (ptr i8))])

; ---- raw, byte-level interface --------------------------------------------
(defn raw-alloc [(a (ptr Allocator)) (size :i64) (align :i64)] (-> (Option (ptr i8)))
  (call-ptr (load (field a alloc)) (load (field a ctx)) size align))
(defn raw-resize [(a (ptr Allocator)) (p (ptr i8)) (old :i64) (new :i64) (align :i64)]
    (-> (Option (ptr i8)))
  (call-ptr (load (field a resize)) (load (field a ctx)) p old new align))
(defn raw-free [(a (ptr Allocator)) (p (ptr i8)) (size :i64) (align :i64)] (-> :i64)
  (call-ptr (load (field a free)) (load (field a ctx)) p size align))

; ---- typed interface (generic; sizes/aligns itself with sizeof/alignof) ----
; `create` and `alloc-slice` take T explicitly (it appears only in the result);
; `destroy` infers T from its pointer argument.
(defn create [T] [(a (ptr Allocator))] (-> (Option (ptr T)))
  (match (raw-alloc a (sizeof T) (alignof T))
    (None []  (None))
    (Some [p] (Some (cast (ptr T) p)))))

(defn alloc-slice [T] [(a (ptr Allocator)) (n :i64)] (-> (Option (ptr T)))
  (match (raw-alloc a (imul n (sizeof T)) (alignof T))
    (None []  (None))
    (Some [p] (Some (cast (ptr T) p)))))

(defn destroy [T] [(a (ptr Allocator)) (p (ptr T))] (-> :i64)
  (raw-free a (cast (ptr i8) p) (sizeof T) (alignof T)))

; `.?`-style escape hatch: take the pointer, or null on failure (Coil doesn't
; promise memory safety, so this is a legitimate, Zig-like convenience).
(defn unwrap-ptr [T] [(o (Option (ptr T)))] (-> (ptr T))
  (match o (None [] (cast (ptr T) 0)) (Some [p] p)))

; `(box A T VAL)` — heap-allocate a T from allocator A, store VAL into it, and
; yield the `(ptr T)`. Removes the create + unwrap-ptr + store! dance for the
; common \"put one value on the heap\" case (e.g. a recursive sum's child node).
; Returns a null pointer on OOM (via unwrap-ptr — descriptive, not safe).
(defn box [(a Code) (ty Code) (val Code)] (-> Code)
  (let [bp (gensym)]
    `(let [~bp (unwrap-ptr [~ty] (create [~ty] ~a))]
       (store! ~bp ~val)
       ~bp)))

; ---- a malloc-backed general-purpose allocator ----
; malloc/realloc guarantee alignment up to max_align_t (16 on x86-64), which
; covers every scalar and pointer; over-aligned requests aren't honored here.
(defn ma-alloc [(ctx (ptr i8)) (size :i64) (align :i64)] (-> (Option (ptr i8)))
  (let [p (malloc size)]
    (if (icmp-eq (cast :i64 p) 0) (None) (Some p))))
(defn ma-resize [(ctx (ptr i8)) (p (ptr i8)) (old :i64) (new :i64) (align :i64)]
    (-> (Option (ptr i8)))
  (let [q (realloc p new)]
    (if (icmp-eq (cast :i64 q) 0) (None) (Some q))))
(defn ma-free [(ctx (ptr i8)) (p (ptr i8)) (size :i64) (align :i64)] (-> :i64) (free p))
(defn malloc-allocator [] (-> (ptr Allocator))
  (let [a (alloc-static Allocator)]
    (store! (field a alloc)  (fnptr-of ma-alloc))
    (store! (field a resize) (fnptr-of ma-resize))
    (store! (field a free)   (fnptr-of ma-free))
    (store! (field a ctx)    (cast (ptr i8) a))
    a))

; ---- an arena (bump) allocator: alloc bumps a pointer (rounded up to the
;      requested alignment), per-alloc free is a no-op, everything is reclaimed
;      at once by freeing the backing block ----
(defstruct Arena [(base (ptr i8)) (off :i64) (cap :i64)])
(defn align-up [(x :i64) (a :i64)] (-> :i64)
  (imul (idiv (iadd x (isub a 1)) a) a))
(defn ar-alloc [(ctx (ptr i8)) (size :i64) (align :i64)] (-> (Option (ptr i8)))
  (let [ar (cast (ptr Arena) ctx)
        o  (align-up (load (field ar off)) align)]
    (if (icmp-gt (iadd o size) (load (field ar cap)))
        (None)                                  ; arena exhausted
        (do (store! (field ar off) (iadd o size))
            (Some (index (load (field ar base)) o))))))     ; base + o
(defn ar-resize [(ctx (ptr i8)) (p (ptr i8)) (old :i64) (new :i64) (align :i64)]
    (-> (Option (ptr i8)))
  (None))                                         ; no in-place resize
(defn ar-free [(ctx (ptr i8)) (p (ptr i8)) (size :i64) (align :i64)] (-> :i64) 0) ; bulk-freed
; Build an arena over a caller-provided buffer — no malloc, so it works
; FREESTANDING (the buffer can be an `alloc-static` array in .bss). The malloc-backed
; `arena-allocator` below is the convenience wrapper; this is the primitive.
(defn arena-over-buffer [(buf (ptr i8)) (cap :i64)] (-> (ptr Allocator))
  (let [ar (alloc-static Arena)
        a  (alloc-static Allocator)]
    (store! (field ar base) buf)
    (store! (field ar off) 0)
    (store! (field ar cap) cap)
    (store! (field a alloc)  (fnptr-of ar-alloc))
    (store! (field a resize) (fnptr-of ar-resize))
    (store! (field a free)   (fnptr-of ar-free))
    (store! (field a ctx)    (cast (ptr i8) ar))
    a))
(defn arena-allocator [(cap :i64)] (-> (ptr Allocator))
  (arena-over-buffer (malloc cap) cap))      ; convenience: malloc the backing buffer
"
    (str-eq name "arraylist.coil")
      "(module arraylist)
; A growable array — `ArrayList T` — built on slices + the allocator-as-value
; interface (lib/alloc.coil). Like everything else, an ORDINARY generic struct +
; functions/macros; the compiler has no notion of it, and there is no ambient
; heap: an ArrayList carries the `(ptr Allocator)` it grows with.
;
;   (import \"lib/arraylist.coil\" :use *)
;   (let [a (malloc-allocator) (mut xs) (al-new [i64] a)]
;     (al-push! (mut xs) 10) (al-for [v xs] …) (al-free! (mut xs)))
;
; Mutating ops take `(mut (ArrayList T))` — pass `(mut xs)`. Reads take it by
; value. `al-push!` grows by doubling (initial cap 4); it tries the allocator's
; in-place `resize`, else allocates-copies-frees (so arena allocators work too),
; and HARD-ABORTS on genuine OOM (never a silent-wrong value). Bounds are not
; checked (debug bounds-checks are Phase-2 safety work).

(import \"alloc.coil\"  :use *)   ; Allocator, raw-*, alloc-slice, malloc-allocator
(import \"result.coil\" :use *)   ; Option/Some/None for the allocator's results
(import \"slice.coil\"  :use *)   ; (slice T) / slice-new, for al-slice + al-for
; OOM hard-fail routes through alloc's `oom` (a shared defn) rather than a local
; `abort` extern, so ArrayList + HashMap can be imported together (Coil doesn't
; dedup identical extern decls across modules).

(defstruct ArrayList [T]
  [(data (ptr T)) (len i64) (cap i64) (alc (ptr Allocator))])

; An empty list that will grow with allocator `a` (no allocation until first push).
(defn al-new [T] [(a (ptr Allocator))] (-> (ArrayList T))
  (let [(mut l) (zeroed (ArrayList T))]
    (store! (field l alc) a)
    (load l)))

(defn al-len [T] [(l (ArrayList T))] (-> i64) (load (field l len)))
(defn al-cap [T] [(l (ArrayList T))] (-> i64) (load (field l cap)))
(defn al-empty? [T] [(l (ArrayList T))] (-> bool) (icmp-eq (load (field l len)) 0))

(defn al-get [T] [(l (ArrayList T)) (i i64)] (-> T)
  (load (index (load (field l data)) i)))
(defn al-set! [T] [(l (mut (ArrayList T))) (i i64) (v T)] (-> i64)
  (store! (index (load (field l data)) i) v)
  0)

; Grow capacity to at least `newcap`. Tries in-place resize; on failure (e.g. an
; arena, which never resizes) allocates fresh, copies, frees the old block; a
; genuine allocation failure aborts.
(defn al-reserve! [T] [(l (mut (ArrayList T))) (newcap i64)] (-> i64)
  (let [oldcap (load (field l cap))
        a      (load (field l alc))]
    (if (icmp-le newcap oldcap)
        0
        (match (raw-resize a (cast (ptr i8) (load (field l data)))
                           (imul oldcap (sizeof T)) (imul newcap (sizeof T)) (alignof T))
          (Some [p] (do (store! (field l data) (cast (ptr T) p))
                        (store! (field l cap) newcap)
                        0))
          (None []
            (match (alloc-slice [T] a newcap)
              (None [] (do (oom) -1))   ; out of memory — hard fail, no silent wrong
              (Some [np]
                (do
                  (let [(mut i) 0]
                    (loop
                      (if (icmp-ge (load i) (load (field l len)))
                          (break)
                          (do (store! (index np (load i))
                                      (load (index (load (field l data)) (load i))))
                              (store! i (iadd (load i) 1))))))
                  (if (icmp-gt oldcap 0)
                      (raw-free a (cast (ptr i8) (load (field l data)))
                                (imul oldcap (sizeof T)) (alignof T))
                      0)
                  (store! (field l data) np)
                  (store! (field l cap) newcap)
                  0))))))))

; Append v; grows (doubling, min 4) if full. Returns the new length.
(defn al-push! [T] [(l (mut (ArrayList T))) (v T)] (-> i64)
  (let [n (load (field l len))]
    (if (icmp-ge n (load (field l cap)))
        (al-reserve! (mut l)
                     (if (icmp-eq (load (field l cap)) 0) 4 (imul (load (field l cap)) 2)))
        0)
    (store! (index (load (field l data)) n) v)
    (store! (field l len) (iadd n 1))
    (iadd n 1)))

; Remove and return the last element as (Some v); (None) if empty.
(defn al-pop! [T] [(l (mut (ArrayList T)))] (-> (Option T))
  (let [n (load (field l len))]
    (if (icmp-eq n 0)
        (None)
        (let [v (load (index (load (field l data)) (isub n 1)))]
          (store! (field l len) (isub n 1))
          (Some v)))))

; A slice view over the current elements (shares storage; invalidated by a later
; grow that moves the buffer).
(defn al-slice [T] [(l (ArrayList T))] (-> (slice T))
  (slice-new (load (field l data)) (load (field l len))))

; Free the backing buffer and reset to empty (the allocator itself is untouched).
(defn al-free! [T] [(l (mut (ArrayList T)))] (-> i64)
  (if (icmp-gt (load (field l cap)) 0)
      (raw-free (load (field l alc)) (cast (ptr i8) (load (field l data)))
                (imul (load (field l cap)) (sizeof T)) (alignof T))
      0)
  (store! (field l data) (cast (ptr T) 0))
  (store! (field l len) 0)
  (store! (field l cap) 0)
  0)

; `(al-for [x xs] body...)` — iterate the list's elements (over its slice view).
(defn al-for [(binding Code) & (body Code)] (-> Code)
  (if (not (icmp-eq (code-count binding) 2))
      (error \"al-for: binding must be [x arraylist]\")
      `(slice-for [~(code-nth binding 0) (al-slice ~(code-nth binding 1))] ~@body)))

; ---- the core collection traits (coil.core) ---------------------------------
; `(len xs)` / `(get xs i)` / `(set! (mut xs) i v)` / `(push! (mut xs) v)` /
; `(pop! (mut xs))` on any (ArrayList T) — the al-* functions remain the named
; API these delegate to.
(impl [T] Len (ArrayList T)
  (len [(xs (ArrayList T))] (-> i64) (al-len xs)))
(impl [T] Get (ArrayList T)
  (get [(xs (ArrayList T)) (i i64)] (-> T) (al-get xs i)))
(impl [T] Set (ArrayList T)
  (set! [(xs (mut (ArrayList T))) (i i64) (v T)] (-> i64) (al-set! (mut xs) i v)))
(impl [T] Push (ArrayList T)
  (push! [(xs (mut (ArrayList T))) (v T)] (-> i64) (al-push! (mut xs) v)))
(impl [T] Pop (ArrayList T)
  (pop! [(xs (mut (ArrayList T)))] (-> (Option T)) (al-pop! (mut xs))))
"
    (str-eq name "atomic.coil")
      "; Atomic operations on `(ptr i64)` — a PURE LIBRARY over the `llvm-ir` escape hatch
; (atomicrmw / cmpxchg / atomic load+store), sequentially consistent. ZERO core
; feature, like lib/mmio.coil: the concurrency axis grows by library, not a core hack.
; (seq_cst to start; weaker orderings — relaxed/acquire/release — are a friction-driven
; follow-up, only if a real program needs the perf.)
(module atomic)

; fetch-and-add: atomically `*p += v`, returns the PREVIOUS value.
(defn atomic-add [(p (ptr i64)) (v i64)] (-> i64)
  (llvm-ir i64 [p v]
\"%old = atomicrmw add ptr $0, i64 $1 seq_cst
ret i64 %old\"))

; fetch-and-sub: atomically `*p -= v`, returns the PREVIOUS value.
(defn atomic-sub [(p (ptr i64)) (v i64)] (-> i64)
  (llvm-ir i64 [p v]
\"%old = atomicrmw sub ptr $0, i64 $1 seq_cst
ret i64 %old\"))

; atomic load.
(defn atomic-load [(p (ptr i64))] (-> i64)
  (llvm-ir i64 [p]
\"%v = load atomic i64, ptr $0 seq_cst, align 8
ret i64 %v\"))

; atomic store.
(defn atomic-store [(p (ptr i64)) (v i64)] (-> i64)
  (llvm-ir i64 [p v]
\"store atomic i64 $1, ptr $0 seq_cst, align 8
ret i64 0\"))

; atomic exchange: set `*p = v`, returns the PREVIOUS value.
(defn atomic-xchg [(p (ptr i64)) (v i64)] (-> i64)
  (llvm-ir i64 [p v]
\"%old = atomicrmw xchg ptr $0, i64 $1 seq_cst
ret i64 %old\"))

; compare-and-swap: if `*p == expected`, set `*p = desired`. Returns the OBSERVED value
; (== expected exactly when the swap happened — the caller compares to detect success).
(defn atomic-cas [(p (ptr i64)) (expected i64) (desired i64)] (-> i64)
  (llvm-ir i64 [p expected desired]
\"%r = cmpxchg ptr $0, i64 $1, i64 $2 seq_cst seq_cst
%v = extractvalue { i64, i1 } %r, 0
ret i64 %v\"))

; ---- pointer atomics: generic over T (one llvm-ir each, type-agnostic thanks to LLVM
; opaque pointers). These are the atomics lock-free POINTER structures actually want —
; no int<->ptr round-trip — closing the (ptr i64)-only + pointer-CAS friction.
(defn atomic-load-ptr [T] [(p (ptr (ptr T)))] (-> (ptr T))
  (llvm-ir (ptr T) [p]
\"%v = load atomic ptr, ptr $0 seq_cst, align 8
ret ptr %v\"))
(defn atomic-store-ptr [T] [(p (ptr (ptr T))) (v (ptr T))] (-> i64)
  (llvm-ir i64 [p v]
\"store atomic ptr $1, ptr $0 seq_cst, align 8
ret i64 0\"))
(defn atomic-cas-ptr [T] [(p (ptr (ptr T))) (expected (ptr T)) (desired (ptr T))] (-> (ptr T))
  (llvm-ir (ptr T) [p expected desired]
\"%r = cmpxchg ptr $0, ptr $1, ptr $2 seq_cst seq_cst
%v = extractvalue { ptr, i1 } %r, 0
ret ptr %v\"))
"
    (str-eq name "closure.coil")
      "(module closure)
; Closure library — written entirely in Coil macros. `(import \"lib/closure.coil\")`
; then `(defclosure NAME [captures] [params] RET body...)` to get a heap closure
; with NAME-new / NAME-call / NAME-free. Nothing in the compiler knows about it.

; Stage-3 comptime helpers (recurse by index over Code vectors of (name type) pairs).
(defn cl--param-types [(ps Code) (i i64)] (-> Code)
  (if (icmp-eq i (code-count ps)) `()
    `(~(code-nth (code-nth ps i) 1) ~@(cl--param-types ps (iadd i 1)))))
(defn cl--param-names [(ps Code) (i i64)] (-> Code)
  (if (icmp-eq i (code-count ps)) `()
    `(~(code-nth (code-nth ps i) 0) ~@(cl--param-names ps (iadd i 1)))))
; let-bindings that load each capture out of the env: name (load (field __self name)) …
(defn cl--cap-loads [(caps Code) (i i64)] (-> Code)
  (if (icmp-eq i (code-count caps)) `()
    (let [nm (code-nth (code-nth caps i) 0)]
      `(~nm (load (field __self ~nm)) ~@(cl--cap-loads caps (iadd i 1))))))
(defn cl--cap-stores [(caps Code) (i i64)] (-> Code)
  (if (icmp-eq i (code-count caps)) `()
    (let [nm (code-nth (code-nth caps i) 0)]
      `((store! (field __e ~nm) ~nm) ~@(cl--cap-stores caps (iadd i 1))))))

(defn defclosure [(name Code) (caps Code) (params Code) (ret Code) & (body Code)] (-> Code)
  (let [env-name  (code-symbol name \"-env\")
        code-name (code-symbol name \"-code\")
        new-name  (code-symbol name \"-new\")
        call-name (code-symbol name \"-call\")
        free-name (code-symbol name \"-free\")]
    `(do
       (defstruct ~env-name [~@caps])
       (defn ~code-name [(__self (ptr ~env-name)) ~@params] (-> ~ret)
         (let [~@(cl--cap-loads caps 0)] ~@body))
       (defstruct ~name
         [(code (fnptr c [(ptr ~env-name) ~@(cl--param-types params 0)] ~ret))
          (env (ptr ~env-name))])
       (defn ~new-name [~@caps] (-> (ptr ~name))
         (let [__e (alloc-heap ~env-name)
               __c (alloc-heap ~name)]
           ~@(cl--cap-stores caps 0)
           (store! (field __c code) (fnptr-of ~code-name))
           (store! (field __c env) __e)
           __c))
       (defn ~call-name [(__c (ptr ~name)) ~@params] (-> ~ret)
         (call-ptr (load (field __c code)) (load (field __c env)) ~@(cl--param-names params 0)))
       (defn ~free-name [(__c (ptr ~name))] (-> i64)
         (do (free (load (field __c env))) (free __c))))))
"
    (str-eq name "control.coil")
      "(module control)
; `Option` (None | Some) is the iterator protocol's `next` return type; importing
; it here means `for-in (iter …)` works without the user importing result too —
; macro hygiene qualifies the None/Some in the template to result's namespace.
(import \"result.coil\" :use *)
; `case` defaults to the `Eq` trait, which lives in the auto-loaded prelude — no
; import needed for it.
; Control-flow sugar — written entirely in Coil macros. `(import \"lib/control.coil\")`
; then use `when`/`unless`/`cond`/`|>`/`inline-for`/`for-in`. Nothing in the compiler
; knows about any of these; they expand to `if`/`do`/`let` over the core.
;
; `while` and `for` are MACROS over the core `loop`/`break`/`continue` primitive
; (the 3 structured-control-flow forms in the compiler) — proof that the loop
; *features* live in userland, not the compiler. `inline-for` is the separate
; comptime-UNROLLED loop (bounds known at expand time), a pure macro needing no
; primitive at all.

; ---- conditionals ---------------------------------------------------------
; `(when c body...)` — evaluate body (yielding its last form) iff c is true,
; else 0. `(unless c body...)` is the negation.
; Stage-3 macros: ordinary `[Code…] -> Code` functions, expanded inline.
(defn when [(c Code) & (body Code)] (-> Code) `(if ~c (do ~@body) 0))
(defn unless [(c Code) & (body Code)] (-> Code) `(if ~c 0 (do ~@body)))

; `(cond t1 e1 t2 e2 ... [else])` — expands to nested ifs. A lone trailing
; clause is the else branch; an empty cond is 0.
(defn cond-arms [(cs Code)] (-> Code)
  (if (icmp-eq (code-count cs) 0) `0
    (if (icmp-eq (code-count cs) 1) (code-nth cs 0)
      `(if ~(code-nth cs 0)
           ~(code-nth cs 1)
           ~(cond-arms (code-rest (code-rest cs)))))))
(defn cond [& (cs Code)] (-> Code) (cond-arms cs))

; `(case x k1 e1 k2 e2 … [default])` — evaluate `x` ONCE, then pick the first `ei`
; whose `(= x ki)` holds, using the `Eq` trait (auto-loaded prelude); a lone trailing
; clause is the default (0 if none). Flat `key body` pairs, Clojure-style. The keys'
; type must implement `Eq` — pass a non-`Eq` value and you get
; \"'T' does not implement 'Eq'\". Primitives (i64/bool) and any `(derive Eq …)`
; struct work out of the box; for a custom comparison (e.g. `sexp-sym-is` on a
; non-`Eq` type) use `case-by`.
(defn case-arms [(v Code) (eq Code) (clauses Code)] (-> Code)
  (if (icmp-eq (code-count clauses) 0) `0
    (if (icmp-eq (code-count clauses) 1) (code-nth clauses 0)  ; lone trailing = default
      `(if (~eq ~v ~(code-nth clauses 0))
           ~(code-nth clauses 1)
           ~(case-arms v eq (code-rest (code-rest clauses)))))))
(defn case [(x Code) & (clauses Code)] (-> Code)
  (let [v (gensym)] `(let [~v ~x] ~(case-arms v `= clauses))))

; `(case-by x eq? k1 e1 … [default])` — like `case`, but with an explicit 2-arg
; equality `eq?` instead of the `Eq` trait. For keys whose type isn't `Eq`, or a
; domain predicate: e.g. `(case-by head sexp-sym-is \"if\" … default)`.
(defn case-by [(x Code) (eq Code) & (clauses Code)] (-> Code)
  (let [v (gensym)] `(let [~v ~x] ~(case-arms v eq clauses))))

; NOTE on `->`/`->>` (thread macros): deliberately NOT provided. `->` collides
; with Coil's reserved `(-> :type)` return-type marker — the macro expander runs
; before parsing and is position-insensitive, so a `->` macro would clobber every
; defn/extern return type. A threading macro would need a non-reserved name.

; ---- runtime loops (macros over the loop/break/continue primitive) --------
; `(while cond body...)` — repeat body while cond is true. Desugars to a `loop`
; that `break`s when cond goes false. `continue` re-checks cond (correct).
(defn while [(c Code) & (body Code)] (-> Code)
  `(loop (if ~c (do ~@body) (break))))

; `(for [i LO HI] body...)` — count i from LO to HI-1 (runtime bounds), binding i
; as an immutable value in body each iteration. The hidden counter is incremented
; at the TOP of the loop (starting LO-1), so a `continue` in body still advances
; the counter — matching C `for` semantics, no skipped increment.
(defn for [(binding Code) & (body Code)] (-> Code)
  (if (not (icmp-eq (code-count binding) 3)) (error \"for: binding must be [i LO HI]\")
  (let [i   (code-nth binding 0)
        lo  (code-nth binding 1)
        hi  (code-nth binding 2)
        idx (gensym)]
    `(let [(mut ~idx) (isub ~lo 1)]
       (loop
         (store! ~idx (iadd (load ~idx) 1))
         (if (icmp-lt (load ~idx) ~hi)
             (let [~i (load ~idx)] ~@body)
             (break)))))))

; `(for-in [x COLL] body...)` — iterate a collection, binding x to each element.
; A macro over `for`, dispatching on the collection FORM (the expander has no
; types): `(range LO HI)` yields the ints LO..HI-1; `(over ARR LEN)` yields the
; elements of a fixed array ARR of length LEN; `(in COLL)` yields the elements
; of ANY type with Len + Get impls (ArrayList, slice — including strings, …) via
; the coil.core collection traits. User collection types ride the
; iterator-value protocol (`for-each`, below) instead. No core support.
(defn for-in [(binding Code) & (body Code)] (-> Code)
  (if (not (icmp-eq (code-count binding) 2)) (error \"for-in: binding must be [x COLL]\")
  (let [x    (code-nth binding 0)
        coll (code-nth binding 1)]
    (if (not (code-list? coll)) (error \"for-in: COLL must be a form, e.g. (range lo hi), (in coll), or (over arr len)\")
    (let [h (code-nth coll 0)]
      (if (code-eq h `range)
          `(for [~x ~(code-nth coll 1) ~(code-nth coll 2)] ~@body)
          (if (code-eq h `in)
              (let [c (gensym)
                    i (gensym)]
                `(let [~c ~(code-nth coll 1)]
                   (for [~i 0 (len ~c)]
                     (let [~x (get ~c ~i)] ~@body))))
          (if (code-eq h `over)
              (let [arr (code-nth coll 1)
                    len (code-nth coll 2)
                    i   (gensym)]
                `(for [~i 0 ~len]
                   (let [~x (load (index ~arr ~i))] ~@body)))
              ; The extensible protocol: (iter NEXT STATE) where NEXT is a fnptr
              ; (ptr S) -> (Option T) advancing STATE (a (ptr S)).
              (if (code-eq h `iter)
                  (let [nf  (code-nth coll 1)
                        st  (code-nth coll 2)
                        nfv (gensym)
                        stv (gensym)]
                    `(let [~nfv ~nf ~stv ~st]
                       (loop
                         (match (call-ptr ~nfv ~stv)
                           (None [] (break))
                           (Some [~x] ~@body)))))
                  (error \"for-in: unsupported collection; use (range lo hi), (in coll), (over arr len), or (iter next state)\"))))))))))

; ---- threading ------------------------------------------------------------
; Spelled `|>`/`|>>` (F#/Elixir/OCaml) rather than Clojure's `->`/`->>`: `->`
; collides with Coil's reserved `(-> :type)` return marker (the pre-parse,
; position-blind expander would otherwise clobber every defn/extern return type).
; `|>` is unreserved, so it's a clean macro.
;
; `(|> x (f a) g)` => `(g (f x a))` — thread x as the FIRST argument.
(defn thread-first [(x Code) (forms Code)] (-> Code)
  (if (icmp-eq (code-count forms) 0) x
    (thread-first
      (let [form (code-nth forms 0)]
        (if (code-list? form)
            `(~(code-nth form 0) ~x ~@(code-rest form))   ; (f a) → (f x a)
            `(~form ~x)))                                  ; g → (g x)
      (code-rest forms))))
(defn |> [(x Code) & (forms Code)] (-> Code) (thread-first x forms))

; `(|>> x (f a) g)` => `(g (f a x))` — thread x as the LAST argument.
(defn thread-last [(x Code) (forms Code)] (-> Code)
  (if (icmp-eq (code-count forms) 0) x
    (thread-last
      (let [form (code-nth forms 0)]
        (if (code-list? form)
            `(~@form ~x)                                   ; (f a) → (f a x)
            `(~form ~x)))
      (code-rest forms))))
(defn |>> [(x Code) & (forms Code)] (-> Code) (thread-last x forms))

; ---- labeled block + early return (macros over loop/break) ----------------
; `(block :b body...)` evaluates body and yields its value; `(return-from :b v)`
; anywhere inside exits the block early with v. Implemented as a single-iteration
; `loop` whose value is delivered by `break` — so EARLY RETURN is itself a macro,
; needing no core support. This is the substrate `defer`/scope guards build on.
;
; `(block :b e...)` => `(loop :b (break :b (do e...)))`: the inner `do` runs to a
; value then breaks; an early `(return-from :b v)` => `(break :b v)` short-circuits.
(defn block [(label Code) & (body Code)] (-> Code)
  `(loop ~label (break ~label (do ~@body))))

(defn return-from [(label Code) (v Code)] (-> Code)
  `(break ~label ~v))

; ---- defer / scope guards (macros over block + break) ----------------------
; `(scope :s body...)` runs body, then runs every `(defer cleanup)` form found
; as a DIRECT child of the scope, in REVERSE (LIFO) order — on BOTH normal exit
; and `(return-from :s v)` early exit (both route through the scope's `block :s`).
; Cleanups are emitted inline (they see the scope's lexical bindings).
;
; NO-SILENT-SKIP guarantee: a `break`/`continue` in the body that would escape the
; scope PAST its cleanups is a COMPILE ERROR, never a skipped cleanup. Allowed
; control: break/continue targeting a loop nested *within* the body, and
; `(return-from :s v)` / `(break :s v)` to exit the scope itself. Disallowed
; (hard error): an unlabeled break/continue at scope level, or a labeled one
; targeting an enclosing loop outside the scope.
;
; LIMITATIONS (documented, not hidden): defers are LEXICAL/static (Zig-style, not
; Go's runtime list) and must be DIRECT forms of the scope body (a `(defer …)`
; nested inside an `if`/loop hard-errors). `(continue :s)` is rejected.

; All Stage-3 comptime helpers over Code. `scope-escape` aborts via `(error …)` at
; the point it finds an escaping transfer (rather than returning a string), since a
; statically-typed helper can't return \"string-or-false\".
(defn is-control? [(h Code)] (-> bool)
  (if (code-eq h `break) true (if (code-eq h `continue) true (code-eq h `return-from))))

(defn loop-introducer? [(h Code)] (-> bool)
  (if (code-eq h `loop) true (if (code-eq h `while) true (if (code-eq h `for) true
    (if (code-eq h `block) true (code-eq h `scope))))))

; the :label of a (break …)/(continue …)/(return-from …) form, or `no-label
(defn control-label [(form Code)] (-> Code)
  (if (icmp-lt 1 (code-count form))
      (let [a (code-nth form 1)] (if (code-keyword? a) a `no-label))
      `no-label))

(defn label-member? [(x Code) (xs Code) (i i64)] (-> bool)
  (if (not (icmp-lt i (code-count xs))) false
    (if (code-eq x (code-nth xs i)) true (label-member? x xs (iadd i 1)))))

; prepend a loop form's own label (if any) to the in-scope label list
(defn escape-labels [(form Code) (labels Code)] (-> Code)
  (if (icmp-lt 1 (code-count form))
      (let [a (code-nth form 1)] (if (code-keyword? a) `(~a ~@labels) labels))
      labels))

(defn is-defer? [(f Code)] (-> bool)
  (if (code-list? f)
      (if (icmp-lt 0 (code-count f)) (code-eq (code-nth f 0) `defer) false)
      false))

; Walk a form; (error …) if it has a scope-escaping break/continue, else return 0.
; `depth` = enclosing in-body loops; `labels` = their labels; `slabel` = the scope's.
(defn scope-escape [(form Code) (depth i64) (labels Code) (slabel Code)] (-> i64)
  (if (not (code-list? form)) 0
    (if (not (icmp-lt 0 (code-count form))) 0
      (let [h (code-nth form 0)]
        (if (is-control? h)
            (let [lab (control-label form)]
              (if (not (code-eq lab `no-label))
                  (if (label-member? lab labels 0) 0
                    (if (code-eq lab slabel)
                        (if (code-eq h `continue)
                            (error \"scope: (continue) cannot target the scope label; use return-from to exit\")
                            0)
                        (error \"scope: a labeled break/continue escapes the (scope ...) past its defers\")))
                  (if (icmp-lt 0 depth) 0
                      (error \"scope: an unlabeled break/continue cannot exit a (scope ...); use (return-from :label v)\"))))
            (if (loop-introducer? h)
                (scope-escape-list (code-rest form) (iadd depth 1) (escape-labels form labels) slabel)
                (scope-escape-list (code-rest form) depth labels slabel)))))))

(defn scope-escape-list [(forms Code) (depth i64) (labels Code) (slabel Code)] (-> i64)
  (if (not (icmp-lt 0 (code-count forms))) 0
    (let [chk (scope-escape (code-nth forms 0) depth labels slabel)]
      (scope-escape-list (code-rest forms) depth labels slabel))))

; cleanup exprs (defer bodies) in REVERSE (LIFO) order
(defn scope-cleanups [(body Code) (i i64) (acc Code)] (-> Code)
  (if (not (icmp-lt i (code-count body))) acc
    (let [f (code-nth body i)]
      (scope-cleanups body (iadd i 1)
        (if (is-defer? f) `(~(code-nth f 1) ~@acc) acc)))))

; the non-defer forms, in order
(defn scope-mains [(body Code) (i i64) (acc Code)] (-> Code)
  (if (not (icmp-lt i (code-count body))) acc
    (let [f (code-nth body i)]
      (scope-mains body (iadd i 1)
        (if (is-defer? f) acc `(~@acc ~f))))))

(defn scope [(label Code) & (body Code)] (-> Code)
  (if (not (code-keyword? label))
      (error \"scope: first argument must be a :label, e.g. (scope :s body...)\")
      (let [chk      (scope-escape-list body 0 `() label)
            cleanups (scope-cleanups body 0 `())
            mains    (scope-mains body 0 `())
            r        (gensym)]
        `(let [~r (block ~label ~@mains)]
           ~@cleanups
           ~r))))

; A bare `(defer …)` is only meaningful as a direct child of `(scope …)`, where
; `scope` extracts it before this macro runs. Reaching this expansion means it
; was used outside a scope (or nested too deep) — hard-error, never a no-op.
(defn defer [& (_ Code)] (-> Code)
  (error \"defer: (defer expr) is only valid as a DIRECT form inside (scope :s ...)\"))

; ---- comptime-unrolled loop ----------------------------------------------
; `(inline-for [i LO HI] body...)` — fully unrolls `body` for i = LO..HI-1,
; with i a compile-time literal each iteration (zero runtime loop overhead).
; LO/HI MUST be literal integers (known at expansion); for runtime bounds use
; `for`.
(defn inline-for-iters [(i Code) (lo i64) (hi i64) (body Code)] (-> Code)
  (if (icmp-lt lo hi)
      `((let [~i ~lo] ~@body) ~@(inline-for-iters i (iadd lo 1) hi body))
      `()))
(defn inline-for [(binding Code) & (body Code)] (-> Code)
  (if (not (icmp-eq (code-count binding) 3))
      (error \"inline-for: binding must be [i LO HI] with literal integer bounds\")
      (let [i  (code-nth binding 0)
            lo (code-int (code-nth binding 1))
            hi (code-int (code-nth binding 2))]
        `(do ~@(inline-for-iters i lo hi body)))))

; `(all a b c …)` / `(any a b c …)` — variadic boolean AND / OR, folding to the
; 2-ary core `and`/`or` (short-circuit). `(all)` = true, `(any)` = false; a single
; argument is returned as-is. (The core `and`/`or` stay 2-ary; these are the
; n-ary convenience over them.)
(defn all [& (xs Code)] (-> Code)
  (if (icmp-eq (code-count xs) 0) `true        ; emit the `true` FORM, not a macro bool
    (if (icmp-eq (code-count xs) 1) (code-nth xs 0)
      `(and ~(code-nth xs 0) (all ~@(code-rest xs))))))
(defn any [& (xs Code)] (-> Code)
  (if (icmp-eq (code-count xs) 0) `false
    (if (icmp-eq (code-count xs) 1) (code-nth xs 0)
      `(or ~(code-nth xs 0) (any ~@(code-rest xs))))))
"
    (str-eq name "derive.coil")
      "(module derive)
; Type-directed code as a LIBRARY — `(derive-eq T)` / `(derive-hash T)` /
; `(derive-keyops T)` generate a structural `T-eq` / `T-hash` and a HashMap
; `T-keyops` for a struct by reflecting its fields at macro expansion
; (struct-fields / type-kind). This is the prime directive made true for the
; type-directed half of the language: NO compiler `derive` keyword, NO
; hand-written per-type boilerplate — just macros over the reflection builtins.
;
;   (import \"lib/derive.coil\" :use *)
;   (defstruct Point [(x i64) (y i64)])
;   (derive-eq Point) (derive-hash Point) (derive-keyops Point)
;   ; => Point-eq / Point-hash / Point-keyops, usable as a real HashMap key
;

(import \"hashmap.coil\" :use *)   ; KeyOps — for (derive-keyops T)
; v1 field-type support (a HARD ERROR otherwise — never silently wrong):
;   derive-eq:   integers/bools/floats + nested structs (recurse — derive first).
;   derive-hash: integers/bools + nested structs (floats rejected — bit-hashing is
;                lossy; write hash by hand).
; sum/slice/pointer/compound fields are rejected by both — write the op by hand.

; ---- shared field reflection helpers (Stage-3, over a type given as Code) ----
; kind tags: 0=int 1=float 2=bool 3=struct 4=sum 5=ptr 6=array 7=slice 8=other

; ---- derive-eq (standalone T-eq function) ----------------------------------
(defn derive--field-eq [(T Code) (a Code) (b Code) (i i64)] (-> Code)
  (let [fname (code-field-name T i)
        kind  (code-field-kind T i)
        pa    `(field ~a ~fname)
        pb    `(field ~b ~fname)]
    (if (icmp-eq kind 3) `(~(code-symbol (code-field-type T i) \"-eq\") ~pa ~pb)  ; nested struct: recurse
      (if (icmp-eq kind 4) (error \"derive-eq: sum fields unsupported in v1; write eq by hand\")
        (if (icmp-eq kind 1) `(fcmp-eq (load ~pa) (load ~pb))                   ; float
          `(icmp-eq (load ~pa) (load ~pb)))))))                                 ; int/bool

(defn derive--eq-and [(T Code) (a Code) (b Code) (i i64) (n i64)] (-> Code)
  (if (icmp-eq i n) `true
    (let [this (derive--field-eq T a b i)]
      (if (icmp-eq (iadd i 1) n) this
        `(and ~this ~(derive--eq-and T a b (iadd i 1) n))))))

(defn derive-eq [(tname Code)] (-> Code)
  `(defn ~(code-symbol tname \"-eq\") [(a ~tname) (b ~tname)] (-> bool)
     ~(derive--eq-and tname `a `b 0 (code-field-count tname))))

; ---- derive-hash (FNV-1a over the fields) ----------------------------------
(defn derive--field-hash [(T Code) (x Code) (i i64)] (-> Code)
  (let [fname (code-field-name T i)
        kind  (code-field-kind T i)
        p     `(field ~x ~fname)]
    (if (icmp-eq kind 3) `(~(code-symbol (code-field-type T i) \"-hash\") ~p)     ; nested struct: recurse
      (if (icmp-eq kind 4) (error \"derive-hash: sum fields unsupported in v1; write hash by hand\")
        (if (icmp-eq kind 1) (error \"derive-hash: float fields unsupported (bit-hashing is lossy); write hash by hand\")
          `(load ~p))))))                                                       ; int/bool

(defn derive--hash-steps [(T Code) (x Code) (h Code) (i i64) (n i64)] (-> Code)
  (if (icmp-eq i n) `()
    (let [fh (derive--field-hash T x i)]
      `((store! ~h (imul (ixor (load ~h) ~fh) 1099511628211)) ~@(derive--hash-steps T x h (iadd i 1) n)))))

(defn derive-hash [(tname Code)] (-> Code)
  `(defn ~(code-symbol tname \"-hash\") [(x ~tname)] (-> i64)
     (let [(mut h) -3750763034362895579]
       ~@(derive--hash-steps tname `x `h 0 (code-field-count tname))
       (load h))))

; ---- derive (generate a TRAIT impl) ----------------------------------------
(defn derive--teq-field [(T Code) (a Code) (b Code) (i i64)] (-> Code)
  (let [fname (code-field-name T i)
        kind  (code-field-kind T i)
        pa    `(field ~a ~fname)
        pb    `(field ~b ~fname)]
    (if (icmp-eq kind 3) `(= ~pa ~pb)                                           ; nested: trait =
      (if (icmp-eq kind 4) (error \"derive Eq: sum fields unsupported; impl by hand\")
        (if (icmp-eq kind 1) `(fcmp-eq (load ~pa) (load ~pb))
          `(icmp-eq (load ~pa) (load ~pb)))))))

(defn derive--teq-and [(T Code) (a Code) (b Code) (i i64) (n i64)] (-> Code)
  (if (icmp-eq i n) `true
    (let [this (derive--teq-field T a b i)]
      (if (icmp-eq (iadd i 1) n) this
        `(and ~this ~(derive--teq-and T a b (iadd i 1) n))))))

(defn derive--thash-field [(T Code) (x Code) (i i64)] (-> Code)
  (let [fname (code-field-name T i)
        kind  (code-field-kind T i)
        p     `(field ~x ~fname)]
    (if (icmp-eq kind 3) `(hash ~p)                                             ; nested: trait hash
      (if (icmp-eq kind 4) (error \"derive Hash: sum fields unsupported; impl by hand\")
        (if (icmp-eq kind 1) (error \"derive Hash: float fields unsupported (bit-hashing is lossy); impl by hand\")
          `(load ~p))))))

(defn derive--thash-steps [(T Code) (x Code) (h Code) (i i64) (n i64)] (-> Code)
  (if (icmp-eq i n) `()
    (let [fh (derive--thash-field T x i)]
      `((store! ~h (imul (ixor (load ~h) ~fh) 1099511628211)) ~@(derive--thash-steps T x h (iadd i 1) n)))))

(defn derive [(trait-name Code) (tname Code)] (-> Code)
  (if (code-eq trait-name `Eq)
      `(impl Eq ~tname
         (= [(a ~tname) (b ~tname)] (-> bool)
           ~(derive--teq-and tname `a `b 0 (code-field-count tname))))
    (if (code-eq trait-name `Hash)
        `(impl Hash ~tname
           (hash [(x ~tname)] (-> i64)
             (let [(mut h) -3750763034362895579]
               ~@(derive--thash-steps tname `x `h 0 (code-field-count tname))
               (load h))))
      (error \"derive: only Eq and Hash are supported (impl other traits by hand)\"))))

; ---- derive-keyops (a HashMap key from derived eq + hash) -------------------
(defn derive-keyops [(tname Code)] (-> Code)
  `(do
     (defn ~(code-symbol tname \"-keyhash\") [(slot (ptr i8)) (n i64)] (-> i64)
       (~(code-symbol tname \"-hash\") (cast (ptr ~tname) slot)))
     (defn ~(code-symbol tname \"-keyeq\") [(ka (ptr i8)) (kb (ptr i8)) (n i64)] (-> bool)
       (~(code-symbol tname \"-eq\") (cast (ptr ~tname) ka) (cast (ptr ~tname) kb)))
     (defn ~(code-symbol tname \"-keyops\") [] (-> (ptr KeyOps))
       (let [o (alloc-static KeyOps)]
         (store! (field o hash) (fnptr-of ~(code-symbol tname \"-keyhash\")))
         (store! (field o eq)   (fnptr-of ~(code-symbol tname \"-keyeq\")))
         (store! (field o size) (sizeof ~tname))
         o))))
"
    (str-eq name "fmt.coil")
      "(module fmt)
; Formatting helpers over the IO Writer capability (lib/io.coil) — all explicit:
; every printer TAKES a `(ptr Writer)`, there is no ambient stdout. Builds on io's
; print-str / print-int (non-negative) / write-byte, adding the everyday pieces:
; signed decimal, hex, bool, char, and newline/line convenience.
;
; The positional FORMAT-STRING front end (`(fmt w \"x={d} y={s}\" a b)`) needs
; compile-time string access in the macro evaluator and is a separate increment.
;
;   (import \"lib/fmt.coil\" :use *) (import \"lib/io.coil\" :use *) (import \"lib/result.coil\" :use *)

(import \"io.coil\"     :use *)
(import \"result.coil\" :use *)

; Signed decimal (io's print-int is non-negative only). NOTE: i64 MIN's magnitude
; isn't representable, so it prints as its wrapped value — documented edge case.
(defn print-i [(w (ptr Writer)) (n :i64)] (-> (Result :i64 IoError))
  (if (icmp-lt n 0)
      (match (write-byte w (cast :u8 45))     ; '-'
        (Err [e] (Err e))
        (Ok [_] (print-int w (isub 0 n))))
      (print-int w n)))

; Lowercase hexadecimal (non-negative), no \"0x\" prefix.
(defn print-hex [(w (ptr Writer)) (n :i64)] (-> (Result :i64 IoError))
  (if (icmp-lt n 16)
      (write-byte w (cast :u8 (if (icmp-lt n 10) (iadd n 48) (iadd n 87))))   ; 87 = 'a'-10
      (match (print-hex w (idiv n 16))
        (Err [e] (Err e))
        (Ok [_]
          (let [d (irem n 16)]
            (write-byte w (cast :u8 (if (icmp-lt d 10) (iadd d 48) (iadd d 87)))))))))

; UNSIGNED lowercase hex over the FULL range (udiv/urem interpret the bits as
; unsigned, so a \"negative\" i64 / a u64 with the high bit set prints correctly —
; unlike print-hex, which assumes non-negative). Recurses MSB-first.
(defn uhex-digits [(w (ptr Writer)) (n :i64)] (-> (Result :i64 IoError))
  (if (icmp-eq n 0)
      (Ok 0)
      (match (uhex-digits w (udiv n 16))
        (Err [e] (Err e))
        (Ok [_]
          (let [d (urem n 16)]
            (write-byte w (cast :u8 (if (icmp-lt d 10) (iadd d 48) (iadd d 87)))))))))
(defn print-uhex [(w (ptr Writer)) (n :i64)] (-> (Result :i64 IoError))
  (if (icmp-eq n 0)
      (write-byte w (cast :u8 48))   ; \"0\"
      (uhex-digits w n)))

; UNSIGNED decimal over the FULL range (udiv/urem interpret the bits as unsigned),
; so a u64 with the high bit set prints its true magnitude — print-i would show
; the wrapped negative value. Recurses MSB-first, like uhex-digits.
(defn udec-digits [(w (ptr Writer)) (n :i64)] (-> (Result :i64 IoError))
  (if (icmp-eq n 0)
      (Ok 0)
      (match (udec-digits w (udiv n 10))
        (Err [e] (Err e))
        (Ok [_] (write-byte w (cast :u8 (iadd (urem n 10) 48)))))))
(defn print-u [(w (ptr Writer)) (n :i64)] (-> (Result :i64 IoError))
  (if (icmp-eq n 0)
      (write-byte w (cast :u8 48))   ; \"0\"
      (udec-digits w n)))

; ---- floats ------------------------------------------------------------------
; `print-f` writes an f64 in plain decimal: integer part, '.', then the fraction
; rounded to six digits (half-up) with trailing zeros trimmed but at least one
; digit kept — 1.5 -> \"1.5\", 42.0 -> \"42.0\", pi -> \"3.141593\". NaN -> \"NaN\", the
; infinities -> \"inf\" / \"-inf\". A magnitude whose integer part doesn't fit i64
; falls back to approximate scientific notation (\"1.797693e+308\"). This is a
; DISPLAY convenience (fixed six-digit precision), NOT a shortest-roundtrip
; serializer. Byte writes along the way are best-effort (an error on one digit
; doesn't abort the rest); the final write's result is returned.

; write `n` '0' bytes (returns the last write's result)
(defn f--zeros [(w (ptr Writer)) (n :i64)] (-> (Result :i64 IoError))
  (if (icmp-le n 0)
      (Ok 0)
      (do (write-byte w (cast :u8 48)) (f--zeros w (isub n 1)))))

(defn f--ndigits [(n :i64)] (-> :i64)
  (if (icmp-lt n 10) 1 (iadd 1 (f--ndigits (idiv n 10)))))

; the fraction part: '.', then fr6 (0..999999 — the fraction scaled by 1e6 and
; rounded) with its leading zeros restored and trailing zeros trimmed (min one).
(defn f--frac [(w (ptr Writer)) (fr6 :i64)] (-> (Result :i64 IoError))
  (let [(mut v) fr6 (mut width) 6]
    (while (and (icmp-gt (load width) 1) (icmp-eq (irem (load v) 10) 0))
      (store! v (idiv (load v) 10))
      (store! width (isub (load width) 1)))
    (write-byte w (cast :u8 46))   ; '.'
    (f--zeros w (isub (load width) (f--ndigits (load v))))
    (print-int w (load v))))

; x is finite and 0 <= x < 2^63: \"<int>.<frac>\" (watch the round-up carry:
; 0.9999999 scales to 1000000, which is really \"1.0\")
(defn f--fixed [(w (ptr Writer)) (x :f64)] (-> (Result :i64 IoError))
  (let [ip0   (cast :i64 x)
        fr6-r (cast :i64 (fadd (fmul (fsub x (cast :f64 ip0)) 1000000.0) 0.5))
        carry (icmp-eq fr6-r 1000000)
        ip    (if carry (iadd ip0 1) ip0)
        fr6   (if carry 0 fr6-r)]
    (print-int w ip)
    (f--frac w fr6)))

; x >= 2^63 (huge finite): approximate scientific notation \"m.mmmmmm\" 'e' '+' NN
(defn f--sci [(w (ptr Writer)) (x :f64)] (-> (Result :i64 IoError))
  (let [(mut m) x (mut e) 0]
    (while (fcmp-ge (load m) 10.0)
      (store! m (fdiv (load m) 10.0))
      (store! e (iadd (load e) 1)))
    (f--fixed w (load m))
    (write-byte w (cast :u8 101))   ; 'e'
    (write-byte w (cast :u8 43))    ; '+'
    (print-int w (load e))))

; x >= 0 (sign and NaN handled by print-f); inf iff x > 0 and 1/x == 0 — the
; test needs no max-double literal
(defn f--abs [(w (ptr Writer)) (x :f64)] (-> (Result :i64 IoError))
  (if (if (fcmp-gt x 0.0) (fcmp-eq (fdiv 1.0 x) 0.0) false)
      (print-str w \"inf\")
      (if (fcmp-lt x 9223372036854775808.0)   ; 2^63, exact as f64
          (f--fixed w x)
          (f--sci w x))))

(defn print-f [(w (ptr Writer)) (x :f64)] (-> (Result :i64 IoError))
  (if (not (fcmp-eq x x))   ; only NaN differs from itself
      (print-str w \"NaN\")
      (if (fcmp-lt x 0.0)
          (do (write-byte w (cast :u8 45))   ; '-'
              (f--abs w (fsub 0.0 x)))
          (f--abs w x))))

(defn print-bool [(w (ptr Writer)) (b bool)] (-> (Result :i64 IoError))
  (print-str w (if b \"true\" \"false\")))

(defn print-char [(w (ptr Writer)) (c :i64)] (-> (Result :i64 IoError))
  (write-byte w (cast :u8 c)))

(defn print-nl [(w (ptr Writer))] (-> (Result :i64 IoError))
  (write-byte w (cast :u8 10)))   ; '\\n'

; Print a `(slice u8)` string followed by a newline.
(defn print-line [(w (ptr Writer)) (s (slice u8))] (-> (Result :i64 IoError))
  (match (print-str w s)
    (Err [e] (Err e))
    (Ok [_] (print-nl w))))

; ---- positional format strings (a MACRO over the printers + the str-bytes /
;      bytes->str compile-time builtins; the compiler knows nothing of formats) ----
; `(fmt w \"n={d} s={s}\" a b)` — specs: {d} signed int, {s} string, {x} hex (>=0),
; {c} char, {b} bool, {u} unsigned decimal (full range), {f} float (print-f);
; `{{`/`}}` are literal braces. Expands to a sequence of print-* calls. Too few
; args for the specs is a compile error (no silent wrong).

; The printer for a spec, as a FULLY-QUALIFIED head (`io.print-str`/`fmt.print-i`/…).
; The name is spliced into call-head position via `~unquote`, which bypasses the
; macro's call-head hygiene — so qualify it here, otherwise it resolves at the use
; site and breaks wherever the caller didn't import io/fmt (e.g. the ambient
; `print`/`println`, which import nothing).
(defn fmt--printer [(spec i64)] (-> Code)
  (if (icmp-eq spec 100) `fmt.print-i
  (if (icmp-eq spec 115) `io.print-str
  (if (icmp-eq spec 120) `fmt.print-hex
  (if (icmp-eq spec 99)  `fmt.print-char
  (if (icmp-eq spec 98)  `fmt.print-bool
  (if (icmp-eq spec 117) `fmt.print-u
  (if (icmp-eq spec 102) `fmt.print-f
    (error \"fmt: unknown spec; use {d} {s} {x} {c} {b} {u} {f}\")))))))))

; flush the accumulated literal bytes as a single print-str (or nothing if empty)
(defn fmt--flush [(w Code) (lit Code)] (-> Code)
  (if (icmp-eq (code-count lit) 0) `()
    `((io.print-str ~w ~(bytes->str lit)))))

; single pass over the format bytes (index i), accumulating literal bytes in `lit`
; and consuming `args` (index ai). Returns a Code list of print-* call forms.
(defn fmt--go [(w Code) (bs Code) (i i64) (lit Code) (args Code) (ai i64)] (-> Code)
  (if (icmp-eq i (code-count bs))
      (fmt--flush w lit)
    (let [b (code-int (code-nth bs i))]
      (if (icmp-eq b 123)                                              ; '{'
          (if (if (icmp-lt (iadd i 1) (code-count bs)) (icmp-eq (code-int (code-nth bs (iadd i 1))) 123) false)
              (fmt--go w bs (iadd i 2) `(~@lit 123) args ai)           ; '{{' -> literal '{'
            (if (if (icmp-lt (iadd i 2) (code-count bs)) (icmp-eq (code-int (code-nth bs (iadd i 2))) 125) false)
                (if (icmp-eq ai (code-count args))
                    (error \"fmt: not enough arguments for the format string\")
                  `(~@(fmt--flush w lit)
                    (~(fmt--printer (code-int (code-nth bs (iadd i 1)))) ~w ~(code-nth args ai))
                    ~@(fmt--go w bs (iadd i 3) `() args (iadd ai 1))))
              (error \"fmt: malformed spec, expected {X}\")))
        (if (icmp-eq b 125)                                            ; '}'
            (if (if (icmp-lt (iadd i 1) (code-count bs)) (icmp-eq (code-int (code-nth bs (iadd i 1))) 125) false)
                (fmt--go w bs (iadd i 2) `(~@lit 125) args ai)         ; '}}' -> literal '}'
              (error \"fmt: unmatched '}' (use '}}')\"))
          (fmt--go w bs (iadd i 1) `(~@lit ~(code-nth bs i)) args ai))))))

(defn fmt [(w Code) (fmt-str Code) & (args Code)] (-> Code)
  `(do ~@(fmt--go w (str-bytes fmt-str) 0 `() args 0)))
"
    (str-eq name "hashmap.coil")
      "(module hashmap)
; An open-addressing hash map `HashMap[K V]` — a generic-struct LIBRARY over the
; allocator interface + lib/mem; no compiler support, no ambient heap (the map
; carries its `(ptr Allocator)`).
;
; HASHING & EQUALITY ARE EXPLICIT CAPABILITY VALUES — a `KeyOps` vtable (hash + eq
; fn pointers + the key size), threaded like the allocator and IO. This is correct
; for EVERY key type and avoids the silent footgun of a byte-wise default (two
; \"equal\" struct values with different uninitialized padding would silently fail
; to match). It also handles content-keyed strings today (supply a content hash).
;
; Convenience: `scalar-keyops [K]` supplies the byte-wise hash/eq SAFELY — but only
; for SCALAR/POINTER keys, where byte-equality provably IS value-equality (no
; padding). A struct/string key MUST supply its own KeyOps (so correctness can't
; be gotten silently wrong). `hm-new-scalar` wires the scalar ops in for you.
;
;   (import \"lib/hashmap.coil\" :use *) (import \"lib/alloc.coil\" :use *)
;   (import \"lib/result.coil\" :use *)   ; for the (Option V) hm-get returns

(import \"alloc.coil\"   :use *)
(import \"result.coil\"  :use *)
(import \"mem.coil\"     :use *)
(import \"control.coil\" :use *)   ; `for` — used by the hm-for iteration macro

; The key capability: hash a key, compare two keys; `size` is sizeof K (handed to
; the byte-wise helpers; a custom hash/eq may ignore it). Type-erased over (ptr i8)
; so one KeyOps shape serves any K. NOT generic — the map stores it by value.
(defstruct KeyOps
  [(hash (fnptr c [(ptr i8) :i64] :i64))
   (eq   (fnptr c [(ptr i8) (ptr i8) :i64] bool))
   (size :i64)])

; Safe byte-wise ops — sound ONLY where byte-equality == value-equality.
(defn bytewise-hash [(p (ptr i8)) (n :i64)] (-> :i64)
  (let [(mut h) -3750763034362895579   ; FNV-1a offset basis
        (mut i) 0]
    (loop
      (if (icmp-ge (load i) n)
          (break)
          (do (store! h (imul (ixor (load h) (cast :i64 (load (index p (load i)))))
                              1099511628211))
              (store! i (iadd (load i) 1)))))
    (load h)))
(defn bytewise-eq [(a (ptr i8)) (b (ptr i8)) (n :i64)] (-> bool)
  (mem-eql a b n))   ; mem-eql [i8] compares n bytes

; Build the safe scalar/pointer-key ops for K (uses sizeof K). The vtable lives in
; static storage and is handed around by pointer (like the allocator). Do NOT use
; for struct keys with padding — define an explicit KeyOps instead.
(defn scalar-keyops [K] [] (-> (ptr KeyOps))
  (let [o (alloc-static KeyOps)]
    (store! (field o hash) (fnptr-of bytewise-hash))
    (store! (field o eq)   (fnptr-of bytewise-eq))
    (store! (field o size) (sizeof K))
    o))

; state: 0 empty, 1 occupied, 2 tombstone
(defstruct Entry [K V] [(state :i64) (key K) (val V)])
(defstruct HashMap [K V]
  [(slots (ptr (Entry K V))) (cap :i64) (len :i64) (tombs :i64)
   (alc (ptr Allocator)) (ops (ptr KeyOps))])

; Call the key vtable.
(defn ko-hash [(opsp (ptr KeyOps)) (kp (ptr i8))] (-> :i64)
  (call-ptr (load (field opsp hash)) kp (load (field opsp size))))
(defn ko-eq [(opsp (ptr KeyOps)) (a (ptr i8)) (b (ptr i8))] (-> bool)
  (call-ptr (load (field opsp eq)) a b (load (field opsp size))))

(defn hm-new [K V] [(a (ptr Allocator)) (ops (ptr KeyOps))] (-> (HashMap K V))
  (let [(mut m) (zeroed (HashMap K V))]
    (store! (field m alc) a)
    (store! (field m ops) ops)   ; both vtables held by pointer (scalar stores)
    (load m)))

; Convenience for scalar/pointer keys: wires in the safe byte-wise ops.
(defn hm-new-scalar [K V] [(a (ptr Allocator))] (-> (HashMap K V))
  (hm-new [K V] a (scalar-keyops [K])))

(defn hm-len [K V] [(m (HashMap K V))] (-> :i64) (load (field m len)))
(defn hm-cap [K V] [(m (HashMap K V))] (-> :i64) (load (field m cap)))

; Insert (key-at kp, v) into raw slots (power-of-two cap), linear probing via the
; key vtable `opsp`. Probes THROUGH tombstones to find an existing key (so an
; update lands on the real entry, never duplicating it), remembering the first
; tombstone to reuse on a confirmed-absent insert. Returns:
;   0 = updated an existing key   1 = filled an empty slot   2 = reused a tombstone
; (1 and 2 both add a key; 2 additionally consumes a tombstone). Terminates because
; the caller keeps at least one empty slot (tombstones counted toward resize).
(defn hm-insert-raw [K V]
    [(opsp (ptr KeyOps)) (slots (ptr (Entry K V))) (cap :i64) (kp (ptr K)) (v V)] (-> :i64)
  (let [kpi (cast (ptr i8) kp)
        (mut i) (iand (ko-hash opsp kpi) (isub cap 1))
        (mut tomb) -1        ; index of the first tombstone seen, -1 = none yet
        (mut result) 0
        (mut done) 0]
    (loop
      (if (icmp-eq (load done) 1)
          (break)
          (let [e  (index slots (load i))
                st (load (field e state))]
            (if (icmp-eq st 0)
                ; empty ⇒ key is absent. Insert at the first tombstone if we saw
                ; one, else here.
                (let [target (if (icmp-ge (load tomb) 0) (load tomb) (load i))
                      te     (index slots target)]
                  (store! (field te state) 1)
                  (store! (field te key) (load kp))
                  (store! (field te val) v)
                  (store! result (if (icmp-ge (load tomb) 0) 2 1))
                  (store! done 1))
                (if (icmp-eq st 1)
                    (if (ko-eq opsp (cast (ptr i8) (field e key)) kpi)
                        (do (store! (field e val) v) (store! result 0) (store! done 1))  ; update
                        (store! i (iand (iadd (load i) 1) (isub cap 1))))                ; probe on
                    (do                                                                  ; tombstone
                      (if (icmp-lt (load tomb) 0) (store! tomb (load i)) 0)
                      (store! i (iand (iadd (load i) 1) (isub cap 1)))))))))
    (load result)))

(defn hm-grow! [K V] [(m (mut (HashMap K V))) (newcap :i64)] (-> :i64)
  (let [a        (load (field m alc))
        oldslots (load (field m slots))
        oldcap   (load (field m cap))]
    (match (alloc-slice [(Entry K V)] a newcap)
      (None [] (do (oom) -1))
      (Some [ns]
        (do
          (mem-zero ns newcap)
          (let [(mut j) 0]
            (loop
              (if (icmp-ge (load j) oldcap)
                  (break)
                  (do
                    (let [e (index oldslots (load j))]
                      (if (icmp-eq (load (field e state)) 1)
                          (hm-insert-raw [K V] (load (field m ops)) ns newcap
                                         (field e key) (load (field e val)))
                          0))
                    (store! j (iadd (load j) 1))))))
          (if (icmp-gt oldcap 0)
              (raw-free a (cast (ptr i8) oldslots)
                        (imul oldcap (sizeof (Entry K V))) (alignof (Entry K V)))
              0)
          (store! (field m slots) ns)
          (store! (field m cap) newcap)
          (store! (field m tombs) 0)   ; rehash dropped all tombstones
          0)))))

(defn hm-put! [K V] [(m (mut (HashMap K V))) (k K) (v V)] (-> :i64)
  ; Resize when occupied + tombstones would pass 0.75 — counting tombstones keeps a
  ; free slot (probe termination). Grow only if genuinely >half full; otherwise
  ; rehash same-size to clear tombstones (so delete/insert churn can't grow forever).
  (let [cap (load (field m cap))]
    (if (icmp-ge (imul (iadd (iadd (load (field m len)) (load (field m tombs))) 1) 4) (imul cap 3))
        (hm-grow! (mut m)
                  (if (icmp-eq cap 0) 8
                      (if (icmp-ge (imul (load (field m len)) 2) cap) (imul cap 2) cap)))
        0))
  (let [kp (alloc-stack K)]
    (store! kp k)
    (let [r (hm-insert-raw [K V] (load (field m ops)) (load (field m slots)) (load (field m cap)) kp v)]
      (if (icmp-ge r 1)                                            ; added a new key
          (do (store! (field m len) (iadd (load (field m len)) 1))
              (if (icmp-eq r 2)                                    ; ...reusing a tombstone
                  (store! (field m tombs) (isub (load (field m tombs)) 1))
                  0))
          0)))
  0)

(defn hm-get [K V] [(m (HashMap K V)) (k K)] (-> (Option V))
  (let [cap (load (field m cap))]
    (if (icmp-eq cap 0)
        (None)
        (let [slots (load (field m slots))
              opsp  (load (field m ops))
              kp    (alloc-stack K)]
          (store! kp k)
          (let [kpi (cast (ptr i8) kp)
                (mut i) (iand (ko-hash opsp kpi) (isub cap 1))]
            (loop
              (let [e  (index slots (load i))
                    st (load (field e state))]
                (if (icmp-eq st 0)
                    (break)
                    (if (and (icmp-eq st 1) (ko-eq opsp (cast (ptr i8) (field e key)) kpi))
                        (break)
                        (store! i (iand (iadd (load i) 1) (isub cap 1)))))))
            (let [e (index slots (load i))]
              (if (icmp-eq (load (field e state)) 1)
                  (Some (load (field e val)))
                  (None))))))))

(defn hm-contains? [K V] [(m (HashMap K V)) (k K)] (-> bool)
  (match (hm-get [K V] m k) (None [] false) (Some [_] true)))

(defn hm-remove! [K V] [(m (mut (HashMap K V))) (k K)] (-> :i64)
  (let [cap (load (field m cap))]
    (if (icmp-eq cap 0)
        0
        (let [slots (load (field m slots))
              opsp  (load (field m ops))
              kp    (alloc-stack K)
              (mut res) 0]
          (store! kp k)
          (let [kpi (cast (ptr i8) kp)
                (mut i) (iand (ko-hash opsp kpi) (isub cap 1))]
            (loop
              (let [e  (index slots (load i))
                    st (load (field e state))]
                (if (icmp-eq st 0)
                    (break)
                    (if (and (icmp-eq st 1) (ko-eq opsp (cast (ptr i8) (field e key)) kpi))
                        (do (store! (field e state) 2)                        ; tombstone
                            (store! (field m len) (isub (load (field m len)) 1))
                            (store! (field m tombs) (iadd (load (field m tombs)) 1))
                            (store! res 1)
                            (break))
                        (store! i (iand (iadd (load i) 1) (isub cap 1))))))))
          (load res)))))

(defn hm-free! [K V] [(m (mut (HashMap K V)))] (-> :i64)
  (if (icmp-gt (load (field m cap)) 0)
      (raw-free (load (field m alc)) (cast (ptr i8) (load (field m slots)))
                (imul (load (field m cap)) (sizeof (Entry K V))) (alignof (Entry K V)))
      0)
  (store! (field m slots) (cast (ptr (Entry K V)) 0))
  (store! (field m cap) 0)
  (store! (field m len) 0)
  (store! (field m tombs) 0)
  0)

; `(hm-for [k v map-ptr] body…)` — iterate the OCCUPIED entries of a map, binding
; `k`/`v` to each key/value. `map-ptr` is a `(ptr (HashMap K V))` (K V inferred);
; order is unspecified (slot order). A macro over `for` + the slot array — the map
; iteration the JSON dogfood wanted (you could query a map but not walk it).
(defn hm-for [(binding Code) & (body Code)] (-> Code)
  (if (not (icmp-eq (code-count binding) 3))
      (error \"hm-for: binding must be [key val map-ptr]\")
      (let [k  (code-nth binding 0)
            v  (code-nth binding 1)
            mp (code-nth binding 2)
            m  (gensym) i (gensym) e (gensym)]
        `(let [~m ~mp]
           (for [~i 0 (hm-cap (load ~m))]
             (let [~e (index (load (field ~m slots)) ~i)]
               (if (icmp-eq (load (field ~e state)) 1)
                   (let [~k (load (field ~e key)) ~v (load (field ~e val))] ~@body)
                   0)))))))

; ---- the core collection traits (coil.core) ---------------------------------
; `(len m)` / `(get m k)` / `(set! (mut m) k v)` on any (HashMap K V). `get`
; returns (Option V) — a map's E is optional by nature; `set!` is hm-put!
; (insert-or-update).
(impl [K V] Len (HashMap K V)
  (len [(m (HashMap K V))] (-> i64) (hm-len m)))
(impl [K V] Get (HashMap K V)
  (get [(m (HashMap K V)) (k K)] (-> (Option V)) (hm-get m k)))
(impl [K V] Set (HashMap K V)
  (set! [(m (mut (HashMap K V))) (k K) (v V)] (-> i64) (hm-put! (mut m) k v)))
"
    (str-eq name "io.coil")
      "(module io)
; Zig-style IO: a capability is a VALUE (a vtable struct) threaded explicitly,
; exactly like the allocator. A `Writer` is `{ write-fn, ctx }`; a function that
; does output *takes* a Writer, so IO shows up in its type. There is no ambient
; stdout -- you pass `(stdout)` (or a buffer, or a null sink) in.
;
;   write-fn (ctx, bytes, len) -> (Result n IoError)   ; n = bytes written
;   read-fn  (ctx, buf,   len) -> (Result n IoError)   ; n = bytes read, 0 = EOF
;
; Errors are a sum type (Result), never a -1 sentinel. Constructors like `(Ok n)`
; / `(Err e)` carry no type annotations: the checker pushes the expected
; `(Result :i64 IoError)` in from each function's return type (bidirectional
; checking), filling even the error type that `Ok` mentions in no field.

(import \"result.coil\" :use *)
(import \"slice.coil\"  :use *)   ; (slice u8) strings: slice-data / slice-len

(extern write  :cc c [:i64 (ptr i8) :i64] (-> :i64))   ; ssize_t write(fd, buf, n)
(extern read   :cc c [:i64 (ptr i8) :i64] (-> :i64))   ; ssize_t read(fd, buf, n)
(extern strlen :cc c [(ptr i8)] (-> :i64))             ; size_t strlen(const char*)
(extern memcpy :cc c [(ptr i8) (ptr i8) :i64] (-> (ptr i8)))

(defsum IoError
  (Eof)
  (Errno [(code :i64)]))

; ============================ Writer ========================================
(defstruct Writer
  [(write-fn (fnptr c [(ptr i8) (ptr i8) :i64] (Result :i64 IoError)))
   (ctx      (ptr i8))])

; One underlying write; may be short (writes fewer than `len` bytes).
(defn write-some [(w (ptr Writer)) (buf (ptr i8)) (len :i64)] (-> (Result :i64 IoError))
  (call-ptr (load (field w write-fn)) (load (field w ctx)) buf len))

; Write the whole buffer, looping over short writes; returns the total or errors.
(defn write-all [(w (ptr Writer)) (buf (ptr i8)) (len :i64)] (-> (Result :i64 IoError))
  (if (icmp-le len 0)
      (Ok 0)
      (match (write-some w buf len)
        (Err [e] (Err e))
        (Ok [n]
          (if (icmp-le n 0)
              (Err (Errno 0))                           ; made no progress
              (match (write-all w (index buf n) (isub len n))
                (Err [e] (Err e))
                (Ok [m] (Ok (iadd n m)))))))))

(defn write-byte [(w (ptr Writer)) (b :u8)] (-> (Result :i64 IoError))
  (let [p (alloc-stack :u8)]
    (store! p b)
    (write-all w (cast (ptr i8) p) 1)))

; Write a `(slice u8)` string — its length is carried, so no `strlen` scan and
; embedded NULs are fine. This is the everyday string printer.
(defn print-str [(w (ptr Writer)) (s (slice u8))] (-> (Result :i64 IoError))
  (write-all w (cast (ptr i8) (slice-data s)) (slice-len s)))

; Write a NUL-terminated C string (`c\"…\"` / a `(ptr i8)` from FFI).
(defn print-cstr [(w (ptr Writer)) (s (ptr i8))] (-> (Result :i64 IoError))
  (write-all w s (strlen s)))

; Write a non-negative integer in decimal, most-significant digit first.
(defn print-int [(w (ptr Writer)) (n :i64)] (-> (Result :i64 IoError))
  (if (icmp-lt n 10)
      (write-byte w (cast :u8 (iadd n 48)))
      (do (print-int w (idiv n 10))
          (write-byte w (cast :u8 (iadd (irem n 10) 48))))))

; ---- backends ----
; fd-backed: the ctx pointer *is* the file descriptor (int<->ptr cast).
(defn fd-write [(ctx (ptr i8)) (buf (ptr i8)) (len :i64)] (-> (Result :i64 IoError))
  (let [n (write (cast :i64 ctx) buf len)]
    (if (icmp-lt n 0) (Err (Errno n)) (Ok n))))
(defn fd-writer [(fd :i64)] (-> (ptr Writer))
  (let [w (alloc-static Writer)]
    (store! (field w write-fn) (fnptr-of fd-write))
    (store! (field w ctx) (cast (ptr i8) fd))
    w))
(defn stdout [] (-> (ptr Writer)) (fd-writer 1))
(defn stderr [] (-> (ptr Writer)) (fd-writer 2))

; null sink: discards everything, always succeeds.
(defn null-write [(ctx (ptr i8)) (buf (ptr i8)) (len :i64)] (-> (Result :i64 IoError))
  (Ok len))
(defn null-writer [] (-> (ptr Writer))
  (let [w (alloc-static Writer)]
    (store! (field w write-fn) (fnptr-of null-write))
    (store! (field w ctx) (cast (ptr i8) 0))
    w))

; fixed-buffer sink: writes into a caller-provided byte buffer, tracking how
; much is used (Zig's fixedBufferStream). Errors with Errno 0 when full.
(defstruct FixBuf [(data (ptr i8)) (len :i64) (cap :i64)])
(defn fb-write [(ctx (ptr i8)) (buf (ptr i8)) (len :i64)] (-> (Result :i64 IoError))
  (let [fb   (cast (ptr FixBuf) ctx)
        cur  (load (field fb len))
        room (isub (load (field fb cap)) cur)
        n    (if (icmp-lt len room) len room)]
    (memcpy (index (load (field fb data)) cur) buf n)
    (store! (field fb len) (iadd cur n))
    (if (icmp-lt n len) (Err (Errno 0)) (Ok n))))
; Initialize a Writer over an existing FixBuf (data/cap already set, len 0).
(defn fixed-buffer-writer [(fb (ptr FixBuf))] (-> (ptr Writer))
  (let [w (alloc-static Writer)]
    (store! (field fb len) 0)
    (store! (field w write-fn) (fnptr-of fb-write))
    (store! (field w ctx) (cast (ptr i8) fb))
    w))

; ============================ Reader ========================================
(defstruct Reader
  [(read-fn (fnptr c [(ptr i8) (ptr i8) :i64] (Result :i64 IoError)))
   (ctx     (ptr i8))])

(defn read-some [(r (ptr Reader)) (buf (ptr i8)) (len :i64)] (-> (Result :i64 IoError))
  (call-ptr (load (field r read-fn)) (load (field r ctx)) buf len))

(defn fd-read [(ctx (ptr i8)) (buf (ptr i8)) (len :i64)] (-> (Result :i64 IoError))
  (let [n (read (cast :i64 ctx) buf len)]
    (if (icmp-lt n 0) (Err (Errno n)) (Ok n))))
(defn fd-reader [(fd :i64)] (-> (ptr Reader))
  (let [r (alloc-static Reader)]
    (store! (field r read-fn) (fnptr-of fd-read))
    (store! (field r ctx) (cast (ptr i8) fd))
    r))
(defn stdin [] (-> (ptr Reader)) (fd-reader 0))
"
    (str-eq name "match.coil")
      "(module match)
; `(match-else scrut (V1 [..] body) … (_ default))` — a `match` with a CATCH-ALL
; arm, as a pure-LIBRARY MACRO over the comptime reflection bridge (no compiler
; `_` support). It infers the sum from the first explicit arm's variant name
; (code-variant-sum), enumerates the sum's variants (code-variant-*), and expands
; `_` into an explicit arm for each NOT-yet-covered variant (with gensym'd field
; binds the default ignores). Stage-3: macros are ordinary [Code…] -> Code fns.
;
;   (match-else j (JNum [n] n) (_ 0))   ; the other Json variants -> 0

; all but the last element of a list
(defn me--butlast [(xs Code) (i i64)] (-> Code)
  (if (icmp-eq i (isub (code-count xs) 1)) `()
    `(~(code-nth xs i) ~@(me--butlast xs (iadd i 1)))))

; the `_` arm's body: (_ b) -> b ; (_ b1 b2 …) -> (do b1 b2 …)
(defn me--wild-body [(wild Code)] (-> Code)
  (let [b (code-rest wild)]
    (if (icmp-eq (code-count b) 1) (code-nth b 0) `(do ~@b))))

; is `vname` the variant of one of the explicit arms?
(defn me--covered? [(explicit Code) (vname Code) (i i64)] (-> bool)
  (if (icmp-eq i (code-count explicit)) false
    (if (code-eq (code-nth (code-nth explicit i) 0) vname) true
      (me--covered? explicit vname (iadd i 1)))))

; n fresh bind names as a list (the default ignores them)
(defn me--genbinds [(n i64)] (-> Code)
  (if (icmp-eq n 0) `() `(~(gensym) ~@(me--genbinds (isub n 1)))))

; an arm `(Vname [binds] default)` for each variant of `sum` not already covered
(defn me--uncovered [(sum Code) (explicit Code) (default Code) (i i64)] (-> Code)
  (if (icmp-eq i (code-variant-count sum)) `()
    (let [vname (code-variant-name sum i)]
      (if (me--covered? explicit vname 0)
          (me--uncovered sum explicit default (iadd i 1))
          `((~vname [~@(me--genbinds (code-variant-fields sum i))] ~default)
            ~@(me--uncovered sum explicit default (iadd i 1)))))))

(defn match-else [(scrut Code) & (arms Code)] (-> Code)
  (let [n        (code-count arms)
        wild     (code-nth arms (isub n 1))
        explicit (me--butlast arms 0)]
    (if (not (code-eq (code-nth wild 0) `_))
        (error \"match-else: the last arm must be (_ default)\")
      (if (icmp-eq (code-count explicit) 0)
          (error \"match-else: needs at least one explicit variant arm (to infer the sum)\")
        (let [default (me--wild-body wild)
              sum     (code-variant-sum (code-nth (code-nth explicit 0) 0))]
          `(match ~scrut ~@explicit ~@(me--uncovered sum explicit default 0)))))))
"
    (str-eq name "mem.coil")
      "(module mem)
; Low-level memory operations — typed, generic wrappers over libc, each sizing
; itself with `sizeof T`. They operate on raw `(ptr T)` regions and need no
; allocator. Foundational: depends only on libc (no other Coil module), so any
; layer (collections, fmt, …) can use it.
;
; mem-copy/move : copy n elements (move is overlap-safe)
; mem-zero      : zero n elements
; mem-fill      : set n elements to a value (element-wise, any T)
; mem-eql       : byte-compare n elements

(extern memcpy  :cc c [(ptr i8) (ptr i8) :i64] (-> (ptr i8)))
(extern memmove :cc c [(ptr i8) (ptr i8) :i64] (-> (ptr i8)))
(extern memset  :cc c [(ptr i8) :i64 :i64]     (-> (ptr i8)))
(extern memcmp  :cc c [(ptr i8) (ptr i8) :i64] (-> :i64))

; Copy n elements src -> dst (regions must NOT overlap).
(defn mem-copy [T] [(dst (ptr T)) (src (ptr T)) (n :i64)] (-> :i64)
  (memcpy (cast (ptr i8) dst) (cast (ptr i8) src) (imul n (sizeof T)))
  0)

; Copy n elements src -> dst, safe when the regions overlap.
(defn mem-move [T] [(dst (ptr T)) (src (ptr T)) (n :i64)] (-> :i64)
  (memmove (cast (ptr i8) dst) (cast (ptr i8) src) (imul n (sizeof T)))
  0)

; Zero the first n elements.
(defn mem-zero [T] [(dst (ptr T)) (n :i64)] (-> :i64)
  (memset (cast (ptr i8) dst) 0 (imul n (sizeof T)))
  0)

; Set each of the first n elements to v (element-wise — works for any T, unlike
; memset's single-byte pattern). Built on the loop primitive; no imports needed.
(defn mem-fill [T] [(dst (ptr T)) (v T) (n :i64)] (-> :i64)
  (let [(mut i) 0]
    (loop
      (if (icmp-ge (load i) n)
          (break)
          (do (store! (index dst (load i)) v)
              (store! i (iadd (load i) 1))))))
  0)

; True if the first n elements of a and b are byte-identical.
(defn mem-eql [T] [(a (ptr T)) (b (ptr T)) (n :i64)] (-> bool)
  (icmp-eq (memcmp (cast (ptr i8) a) (cast (ptr i8) b) (imul n (sizeof T))) 0))
"
    (str-eq name "mmio.coil")
      "; Memory-mapped I/O device registers as a typed bitfield — a PURE MACRO. The §7
; capstone: \"expressiveness through macros\" at its hardest domain (hardware device
; registers), with ZERO core feature. `defmmio-reg` takes a register spec (name,
; MMIO address, and named bit-fields) and GENERATES — entirely via the macro system —
; a volatile-load reader, a volatile-store writer, and a shift+mask getter per field,
; over the existing `llvm-ir` (volatile load/store) + `iand`/`ishr`/`ishl` primitives.
; No core MMIO/register/bitfield support exists; it's all library.
;
;   (defmmio-reg UARTFR 150994968        ; 0x09000018 — PL011 flag register
;     [(rxfe 4 1) (txff 5 1)])           ; (field, bit-offset, width)
; expands to:
;   UARTFR-read  []        -> i32        ; volatile load the 32-bit register
;   UARTFR-write [(v i32)] -> i64        ; volatile store
;   UARTFR-rxfe  []        -> i32        ; (read >> 4) & 1
;   UARTFR-txff  []        -> i32        ; (read >> 5) & 1
(module mmio)

; one shift+mask getter per field (recurse by index). The mask `(1 << width) - 1`
; is emitted as ordinary code (LLVM const-folds it), so no macro-time bit ops.
(defn defmmio--fields [(name Code) (fields Code) (i i64)] (-> Code)
  (if (icmp-eq i (code-count fields)) `()
    (let [f      (code-nth fields i)
          fname  (code-nth f 0)
          offset (code-nth f 1)
          width  (code-nth f 2)]
      `((defn ~(code-symbol name \"-\" fname) [] (-> u32)
          (iand (ishr (~(code-symbol name \"-read\")) ~offset)
                (isub (ishl 1 ~width) 1)))
        ~@(defmmio--fields name fields (iadd i 1))))))

(defn defmmio-reg [(name Code) (addr Code) (fields Code)] (-> Code)
  `(do
     ; volatile 32-bit load from the fixed MMIO address (address spliced into the IR).
     ; Registers are UNSIGNED (u32) — so field extraction uses a LOGICAL shift (lshr),
     ; the conventional + correct choice for register fields. (LLVM i32 == u32's repr.)
     (defn ~(code-symbol name \"-read\") [] (-> u32)
       (llvm-ir u32 []
         ~(code-str \"%p = inttoptr i64 \" addr \" to ptr\\n\"
                    \"%v = load volatile i32, ptr %p\\n\"
                    \"ret i32 %v\")))
     ; volatile 32-bit store.
     (defn ~(code-symbol name \"-write\") [(v u32)] (-> i64)
       (llvm-ir i64 [v]
         ~(code-str \"%p = inttoptr i64 \" addr \" to ptr\\n\"
                    \"store volatile i32 $0, ptr %p\\n\"
                    \"ret i64 0\")))
     ~@(defmmio--fields name fields 0)))
"
    (str-eq name "print.coil")
      "(module print)
; Ambient print/println over stdout — the convenience layer you can call with ZERO
; imports (coil.core `:reexport`s this module, so `print`/`println` are auto-referred
; everywhere, like Clojure's `println` in clojure.core).
;
; Format strings are `fmt`'s: {d} signed int, {s} string, {x} hex (>=0), {c} char,
; {b} bool, {u} unsigned decimal, {f} float; `{{`/`}}` are literal braces. Too few
; args is a COMPILE error.
;
;   (println \"x={d} ok={b}\" 42 true)     ; -> stdout, with a trailing newline
;   (print   \"loading {s}\" name)         ; -> stdout, no newline
;
; Both yield a `(Result i64 IoError)` (the underlying write result), so discard it in
; a `(do … 0)` like any effectful call. The explicit-Writer forms remain in fmt/io
; (`(fmt w …)`, `print-*`) for when you need a specific sink (a buffer, stderr, …);
; this is just the everyday stdout shortcut.
(export print println)
(import \"fmt.coil\" :use *)   ; the `fmt` format-string macro + the print-* printers
(import \"io.coil\"  :use *)   ; stdout

; (print \"fmt\" args…) — format to stdout, no trailing newline. The writer is bound
; once (a gensym) so a multi-spec format doesn't re-create the stdout writer per piece.
(defn print [(f Code) & (args Code)] (-> Code)
  (let [w (gensym)]
    `(let [~w (stdout)] (fmt ~w ~f ~@args))))

; (println \"fmt\" args…) — like `print`, plus a trailing newline.
(defn println [(f Code) & (args Code)] (-> Code)
  (let [w (gensym)]
    `(let [~w (stdout)] (do (fmt ~w ~f ~@args) (print-nl ~w)))))
"
    (str-eq name "result.coil")
      "(module result)
"
    (str-eq name "sexp.coil")
      "; A runtime s-expression reader: parse `(slice u8)` text into a tree of `Sexp`
; (numbers, symbols, and lists). The thing every Lisp/config/serialization format
; rewrites by hand — here once, as a library over the allocator, `(slice u8)`, and
; ArrayList. Nothing compiler-magic; `read-all` is the one-call entry, with
; accessors so a consumer never touches the representation.
;
;   (let [forms (read-all a \"(define x 10) (+ x 1)\")]   ; -> ArrayList<(ptr Sexp)>
;     (sexp-count (al-get [(ptr Sexp)] (load forms) 1)))   ; => 3
(module sexp)
(import \"alloc.coil\"     :use *)
(import \"slice.coil\"     :use *)
(import \"str.coil\"       :use *)
(import \"arraylist.coil\" :use *)

(defsum Sexp
  (SNum  [(v i64)])
  (SSym  [(s (slice u8))])
  (SList [(items (ptr (ArrayList (ptr Sexp))))]))

(defn sx [(a (ptr Allocator)) (x Sexp)] (-> (ptr Sexp))
  (let [p (unwrap-ptr [Sexp] (create [Sexp] a))] (store! p x) p))

; ---- reader cursor ---------------------------------------------------------
(defstruct Reader [(src (slice u8)) (pos i64) (a (ptr Allocator))])

(defn r-end? [(r (ptr Reader))] (-> bool) (icmp-ge (load (field r pos)) (slice-len (load (field r src)))))
(defn r-peek [(r (ptr Reader))] (-> i64)
  (if (r-end? r) -1 (cast i64 (slice-get (load (field r src)) (load (field r pos))))))
(defn r-adv [(r (ptr Reader))] (-> i64) (store! (field r pos) (iadd (load (field r pos)) 1)) 0)

(defn ws? [(c i64)] (-> bool)
  (or (icmp-eq c 32) (or (icmp-eq c 10) (or (icmp-eq c 9) (icmp-eq c 13)))))
(defn digit? [(c i64)] (-> bool) (and (icmp-ge c 48) (icmp-le c 57)))
(defn delim? [(c i64)] (-> bool)
  (or (icmp-eq c -1) (or (ws? c) (or (icmp-eq c 40) (icmp-eq c 41)))))

(defn r-skip-ws [(r (ptr Reader))] (-> i64) (loop (if (ws? (r-peek r)) (r-adv r) (break))) 0)

; a run of non-delimiter bytes as a (slice u8) view into the source
(defn r-token [(r (ptr Reader))] (-> (slice u8))
  (let [start (load (field r pos))]
    (loop (if (delim? (r-peek r)) (break) (r-adv r)))
    (subslice (load (field r src)) start (load (field r pos)))))

(defn sexp-parse-int [(s (slice u8))] (-> i64)
  (let [(mut i) 0 n (slice-len s) (mut acc) 0 (mut sign) 1]
    (if (and (icmp-gt n 0) (icmp-eq (cast i64 (slice-get s 0)) 45))   ; '-'
        (do (store! sign -1) (store! i 1)) 0)
    (loop (if (icmp-ge (load i) n) (break)
            (do (store! acc (iadd (imul (load acc) 10) (isub (cast i64 (slice-get s (load i))) 48)))
                (store! i (iadd (load i) 1)))))
    (imul (load sign) (load acc))))

(defn numeric-token? [(tok (slice u8))] (-> bool)
  (and (icmp-gt (slice-len tok) 0)
       (or (digit? (cast i64 (slice-get tok 0)))
           (and (icmp-eq (cast i64 (slice-get tok 0)) 45) (icmp-gt (slice-len tok) 1)))))

; ---- read one form (returns a null (ptr Sexp) at end of input) -------------
(defn read-form [(r (ptr Reader))] (-> (ptr Sexp))
  (r-skip-ws r)
  (let [c (r-peek r)]
    (if (icmp-eq c -1) (cast (ptr Sexp) 0)
      (if (icmp-eq c 40)                                ; '(' -> list
          (do (r-adv r)
              (let [(mut items) (al-new [(ptr Sexp)] (load (field r a)))]
                (loop
                  (do (r-skip-ws r)
                      (if (icmp-eq (r-peek r) 41) (do (r-adv r) (break))
                        (if (icmp-eq (r-peek r) -1) (break)
                          (al-push! (mut items) (read-form r))))))
                (let [boxed (unwrap-ptr [(ArrayList (ptr Sexp))]
                                        (create [(ArrayList (ptr Sexp))] (load (field r a))))]
                  (store! boxed (load items))
                  (sx (load (field r a)) (SList boxed)))))
          (let [tok (r-token r)]
            (if (numeric-token? tok)
                (sx (load (field r a)) (SNum (sexp-parse-int tok)))
                (sx (load (field r a)) (SSym tok))))))))

; ---- entry points ----------------------------------------------------------
; read EVERY top-level form into an ArrayList<(ptr Sexp)>.
(defn read-all [(a (ptr Allocator)) (src (slice u8))] (-> (ptr (ArrayList (ptr Sexp))))
  (let [rstate (alloc-stack Reader)
        (mut forms) (al-new [(ptr Sexp)] a)]
    (store! (field rstate src) src)
    (store! (field rstate pos) 0)
    (store! (field rstate a) a)
    (loop
      (let [f (read-form rstate)]
        (if (icmp-eq (cast i64 f) 0) (break) (al-push! (mut forms) f))))
    (let [boxed (unwrap-ptr [(ArrayList (ptr Sexp))] (create [(ArrayList (ptr Sexp))] a))]
      (store! boxed (load forms))
      boxed)))

; ---- accessors (a consumer never matches the representation directly) -------
(defn sexp-num?  [(x (ptr Sexp))] (-> bool) (match (load x) (SNum [_] true)  (SSym [_] false) (SList [_] false)))
(defn sexp-sym?  [(x (ptr Sexp))] (-> bool) (match (load x) (SSym [_] true)  (SNum [_] false) (SList [_] false)))
(defn sexp-list? [(x (ptr Sexp))] (-> bool) (match (load x) (SList [_] true) (SNum [_] false) (SSym [_] false)))

(defn sexp-num [(x (ptr Sexp))] (-> i64)
  (match (load x) (SNum [v] v) (SSym [_] 0) (SList [_] 0)))
(defn sexp-sym [(x (ptr Sexp))] (-> (slice u8))
  (match (load x) (SSym [s] s) (SNum [_] \"\") (SList [_] \"\")))
(defn sexp-items [(x (ptr Sexp))] (-> (ptr (ArrayList (ptr Sexp))))
  (match (load x) (SList [items] items) (SNum [_] (cast (ptr (ArrayList (ptr Sexp))) 0)) (SSym [_] (cast (ptr (ArrayList (ptr Sexp))) 0))))

(defn sexp-count [(x (ptr Sexp))] (-> i64)
  (if (sexp-list? x) (al-len [(ptr Sexp)] (load (sexp-items x))) 0))
(defn sexp-nth [(x (ptr Sexp)) (i i64)] (-> (ptr Sexp))
  (al-get [(ptr Sexp)] (load (sexp-items x)) i))

; symbol equals a literal — the common dispatch test
(defn sexp-sym-is [(x (ptr Sexp)) (lit (slice u8))] (-> bool)
  (and (sexp-sym? x) (str-eq (sexp-sym x) lit)))
"
    (str-eq name "simd.coil")
      "(module simd)
; SIMD as a *library* -- every operation is a macro over the `(llvm-ir ...)`
; primitive, so nothing here is in the compiler. Each op is a raw-IR template;
; `$ret`/`$tN` expand to the result/operand LLVM type strings and `$N` to the
; operand SSA names, so one template serves every lane type and width. The LLVM
; verifier checks the bodies, and `-O3` inlines them away to bare NEON/SSE.
;
; This file targets <4 x float> (NEON / 128-bit). Widen by editing the lane
; count and intrinsic suffix, or generate per-target with a `target-arch` macro.

; ---- construct a <4 x float> from four scalars (cast to f32) ----------------
(defn vec4f [(x0 Code) (x1 Code) (x2 Code) (x3 Code)] (-> Code)
  `(llvm-ir (vec f32 4) [(cast :f32 ~x0) (cast :f32 ~x1) (cast :f32 ~x2) (cast :f32 ~x3)]
     \"%v0 = insertelement <4 x float> undef, $t0 $0, i32 0
%v1 = insertelement <4 x float> %v0, $t1 $1, i32 1
%v2 = insertelement <4 x float> %v1, $t2 $2, i32 2
%r  = insertelement <4 x float> %v2, $t3 $3, i32 3
ret $ret %r\"))

; ---- broadcast one scalar across all four lanes ----------------------------
(defn splat4f [(x Code)] (-> Code)
  `(llvm-ir (vec f32 4) [(cast :f32 ~x)]
     \"%v = insertelement <4 x float> undef, $t0 $0, i32 0
%r = shufflevector <4 x float> %v, <4 x float> undef, <4 x i32> zeroinitializer
ret $ret %r\"))

; ---- elementwise arithmetic (one template per op; any lane type via $ret) ---
(defn vadd4f [(a Code) (b Code)] (-> Code)
  `(llvm-ir (vec f32 4) [~a ~b] \"%r = fadd $ret $0, $1
ret $ret %r\"))
(defn vsub4f [(a Code) (b Code)] (-> Code)
  `(llvm-ir (vec f32 4) [~a ~b] \"%r = fsub $ret $0, $1
ret $ret %r\"))
(defn vmul4f [(a Code) (b Code)] (-> Code)
  `(llvm-ir (vec f32 4) [~a ~b] \"%r = fmul $ret $0, $1
ret $ret %r\"))

; ---- fused multiply-add via the @llvm.fma intrinsic (declare is hoisted) ----
(defn vfma4f [(a Code) (b Code) (c Code)] (-> Code)
  `(llvm-ir (vec f32 4) [~a ~b ~c]
     \"declare <4 x float> @llvm.fma.v4f32(<4 x float>, <4 x float>, <4 x float>)
%r = call $ret @llvm.fma.v4f32($t0 $0, $t1 $1, $t2 $2)
ret $ret %r\"))

; ---- horizontal sum of the four lanes -> scalar f32 ------------------------
(defn reduce-add4f [(v Code)] (-> Code)
  `(llvm-ir f32 [~v]
     \"declare float @llvm.vector.reduce.fadd.v4f32(float, <4 x float>)
%r = call $ret @llvm.vector.reduce.fadd.v4f32(float 0.0, $t0 $0)
ret $ret %r\"))

; ---- a 4-wide dot product, built from the pieces above ---------------------
(defn dot4f [(a (vec f32 4)) (b (vec f32 4))] (-> f32)
  (reduce-add4f (vmul4f a b)))
"
    (str-eq name "slice.coil")
      "(module slice)
; A `(slice T)` is a fat pointer `{ data: (ptr T), len: i64 }` over contiguous
; elements — the everyday view into an array/buffer, and the representation of a
; string (`(slice u8)`). The fat-pointer TYPE is the one piece of core support
; slices need; every operation here is a LIBRARY over `(llvm-ir …)`, exactly as
; lib/simd.coil builds SIMD over the core `(vec T N)` type.
;
;   (import \"lib/slice.coil\")
;   (let [arr (alloc-stack (array i64 3))] … (let [s (slice-of arr 3)] (slice-for [x s] …)))
;
; Slices ALIAS their backing storage: `slice-set!` writes through to the original,
; and a `subslice` shares the same memory. A slice is a small value (two words),
; so it is passed/returned BY VALUE (like Rust's `&str`). Bounds are NOT checked
; here (debug-mode bounds checking is Phase-2 safety work).

(import \"control.coil\" :use *)   ; `for` (and its loop/break lowering) for slice-for

; Construct a slice from a base element pointer and a length — `{data, len}` built
; with two `insertvalue`s. T is inferred from `data` at the call site.
(defn slice-new [T] [(data (ptr T)) (len i64)] (-> (slice T))
  (llvm-ir (slice T) [data len]
    \"%s0 = insertvalue $ret undef, $t0 $0, 0
%s1 = insertvalue $ret %s0, $t1 $1, 1
ret $ret %s1\"))

; The element count (field 1).
(defn slice-len [T] [(s (slice T))] (-> i64)
  (llvm-ir i64 [s] \"%l = extractvalue $t0 $0, 1
ret $ret %l\"))

; The base element pointer (field 0) — for interop / building sub-views.
(defn slice-data [T] [(s (slice T))] (-> (ptr T))
  (llvm-ir (ptr T) [s] \"%d = extractvalue $t0 $0, 0
ret $ret %d\"))

(defn slice-empty? [T] [(s (slice T))] (-> bool) (icmp-eq (slice-len s) 0))

; Read / write element i (no bounds check — Phase-2 adds debug checks).
(defn slice-get [T] [(s (slice T)) (i i64)] (-> T)
  (load (index (slice-data s) i)))

(defn slice-set! [T] [(s (slice T)) (i i64) (v T)] (-> i64)
  (store! (index (slice-data s) i) v)
  0)

; `subslice s lo hi` → the half-open view `[lo, hi)`, sharing storage.
(defn subslice [T] [(s (slice T)) (lo i64) (hi i64)] (-> (slice T))
  (slice-new (index (slice-data s) lo) (isub hi lo)))

; `(slice-of ARR LEN)` — a slice over a fixed array `ARR` (a `(ptr (array T N))`
; or element pointer) of length LEN. T is inferred.
(defn slice-of [(arr Code) (len Code)] (-> Code)
  `(slice-new (index ~arr 0) ~len))

; `(slice-for [x s] body...)` — iterate a slice's elements, binding x to each.
; A macro over `for` (hence over the loop primitive); break/continue work inside.
(defn slice-for [(binding Code) & (body Code)] (-> Code)
  (if (not (icmp-eq (code-count binding) 2))
      (error \"slice-for: binding must be [x slice]\")
      (let [x  (code-nth binding 0)
            s  (code-nth binding 1)
            sv (gensym)
            i  (gensym)]
        `(let [~sv ~s]
           (for [~i 0 (slice-len ~sv)]
             (let [~x (slice-get ~sv ~i)] ~@body))))))

; ---- the core collection traits (coil.core) ---------------------------------
; `(len s)` / `(get s i)` on any (slice T) — including strings, which are
; (slice u8). `set!` writes through the view (a slice borrows its elements);
; the (mut Self) receiver is the trait's shape, so rebind a slice as
; (mut s) to write. No Push/Pop: a slice can't grow.
(impl [T] Len (slice T)
  (len [(s (slice T))] (-> i64) (slice-len s)))
(impl [T] Get (slice T)
  (get [(s (slice T)) (i i64)] (-> T) (slice-get s i)))
(impl [T] Set (slice T)
  (set! [(s (mut (slice T))) (i i64) (v T)] (-> i64) (slice-set! (load s) i v)))
"
    (str-eq name "str.coil")
      "(module str)
; Strings are `(slice u8)` VIEWS (UTF-8 bytes) — see lib/slice.coil. A `\"…\"`
; literal is one, borrowing static bytes. These are the content operations over
; that view: equality, hashing, search, and an allocator-aware concatenation.
; Owned, growable strings are `StrBuf` (a library over ArrayList<u8>) at the
; bottom of this file. Nothing here is compiler magic — it is all library over
; the core `(slice u8)` type, the allocator value, and lib/mem.
;
;   (import \"lib/str.coil\" :use *) (import \"lib/slice.coil\" :use *)

(import \"slice.coil\"     :use *)   ; slice-len/data/get, subslice, slice-new
(import \"mem.coil\"       :use *)   ; mem-eql, mem-copy
(import \"result.coil\"    :use *)   ; Option/Some/None for find / fallible alloc
(import \"alloc.coil\"     :use *)   ; Allocator, raw-alloc — for concat / StrBuf
(import \"arraylist.coil\" :use *)   ; ArrayList — owned StrBuf is a library over it
(import \"hashmap.coil\"   :use *)   ; KeyOps — for str-keyops (string-keyed maps)

; ---- the everyday view operations -----------------------------------------
(defn str-len [(s (slice u8))] (-> i64) (slice-len s))
(defn char-at [(s (slice u8)) (i :i64)] (-> :u8) (slice-get s i))
(defn substr  [(s (slice u8)) (lo :i64) (hi :i64)] (-> (slice u8)) (subslice s lo hi))

; Content equality: same length and same bytes.
(defn str-eq [(a (slice u8)) (b (slice u8))] (-> bool)
  (let [la (slice-len a)]
    (if (icmp-ne la (slice-len b))
        false
        (mem-eql [u8] (slice-data a) (slice-data b) la))))

; FNV-1a over the bytes (matches lib/hashmap's bytewise-hash, so a content hash).
(defn str-hash [(s (slice u8))] (-> :i64)
  (let [(mut h) -3750763034362895579    ; FNV-1a offset basis
        (mut i) 0
        n (slice-len s)]
    (loop
      (if (icmp-ge (load i) n)
          (break)
          (do (store! h (imul (ixor (load h) (cast :i64 (slice-get s (load i))))
                              1099511628211))
              (store! i (iadd (load i) 1)))))
    (load h)))

(defn starts-with [(s (slice u8)) (prefix (slice u8))] (-> bool)
  (let [lp (slice-len prefix)]
    (if (icmp-gt lp (slice-len s))
        false
        (str-eq (subslice s 0 lp) prefix))))

; First index of `needle` in `hay`, or `(None)` — tail-recursive (TCO'd to a loop).
(defn str-find-from [(hay (slice u8)) (needle (slice u8)) (i :i64)] (-> (Option :i64))
  (if (icmp-gt (iadd i (slice-len needle)) (slice-len hay))
      (None)
      (if (str-eq (subslice hay i (iadd i (slice-len needle))) needle)
          (Some i)
          (str-find-from hay needle (iadd i 1)))))
(defn str-find [(hay (slice u8)) (needle (slice u8))] (-> (Option :i64))
  (str-find-from hay needle 0))

; Concatenate into freshly-allocated bytes; `(None)` on OOM. The result owns its
; buffer (allocated from `a`); free it with the same allocator when done.
(defn str-concat [(a (ptr Allocator)) (x (slice u8)) (y (slice u8))] (-> (Option (slice u8)))
  (let [lx (slice-len x) ly (slice-len y)]
    (match (raw-alloc a (iadd lx ly) 1)
      (None [] (None))
      (Some [buf]
        (let [p (cast (ptr u8) buf)]
          (mem-copy [u8] p (slice-data x) lx)
          (mem-copy [u8] (index p lx) (slice-data y) ly)
          (Some (slice-new p (iadd lx ly))))))))

; ---- string-keyed HashMap: a KeyOps whose hash/eq read the slice's bytes ----
; The map stores the (slice u8) key value in its slot; these deref that slot to
; the fat pointer, then hash/compare the pointed-to CONTENT (not the 16 raw bytes
; of the fat pointer, which would compare addresses).
(defn str-key-hash [(slot (ptr i8)) (n :i64)] (-> :i64)
  (str-hash (load (cast (ptr (slice u8)) slot))))
(defn str-key-eq [(a (ptr i8)) (b (ptr i8)) (n :i64)] (-> bool)
  (str-eq (load (cast (ptr (slice u8)) a)) (load (cast (ptr (slice u8)) b))))
(defn str-keyops [] (-> (ptr KeyOps))
  (let [o (alloc-static KeyOps)]
    (store! (field o hash) (fnptr-of str-key-hash))
    (store! (field o eq)   (fnptr-of str-key-eq))
    (store! (field o size) (sizeof (slice u8)))
    o))

; ---- owned, growable string: a LIBRARY over ArrayList<u8> ------------------
; `StrBuf` is just an `(ArrayList u8)`; appending pushes bytes, and `sb-str` hands
; back a `(slice u8)` VIEW over the current contents (no copy, invalidated by a
; later growth that moves the buffer — same contract as al-slice).
(defstruct StrBuf [(bytes (ArrayList u8))])

(defn sb-new [(a (ptr Allocator))] (-> StrBuf)
  (let [(mut sb) (zeroed StrBuf)]
    (store! (field sb bytes) (al-new [u8] a))
    (load sb)))

; Append a (slice u8); returns the new length.
(defn sb-push-str! [(sb (mut StrBuf)) (s (slice u8))] (-> :i64)
  (let [(mut i) 0 n (slice-len s)]
    (loop
      (if (icmp-ge (load i) n)
          (break)
          (do (al-push! (mut (field sb bytes)) (slice-get s (load i)))
              (store! i (iadd (load i) 1)))))
    (al-len (field sb bytes))))

(defn sb-push-byte! [(sb (mut StrBuf)) (b :u8)] (-> :i64)
  (al-push! (mut (field sb bytes)) b))

; A (slice u8) view over the current contents (shares storage with the StrBuf).
(defn sb-str [(sb StrBuf)] (-> (slice u8))
  (al-slice (field sb bytes)))

(defn sb-free! [(sb (mut StrBuf))] (-> :i64)
  (al-free! (mut (field sb bytes))))

; ---- the core collection traits (coil.core) ---------------------------------
; A StrBuf is a byte collection: `(len sb)` / `(get sb i)` / `(push! (mut sb) b)`.
; (Strings themselves are (slice u8) — their Len/Get impls are lib/slice.coil's.)
(impl Len StrBuf
  (len [(sb StrBuf)] (-> i64) (al-len (load (field sb bytes)))))
(impl Get StrBuf
  (get [(sb StrBuf) (i i64)] (-> :u8) (al-get (load (field sb bytes)) i)))
(impl Push StrBuf
  (push! [(sb (mut StrBuf)) (b :u8)] (-> i64) (sb-push-byte! (mut sb) b)))
"
    (str-eq name "thread.coil")
      "; Threads — a thin capability-as-value wrapper over the POSIX `pthread` externs (the
; same C-interop callback pattern cinterop proved with qsort: a Coil function handed to
; C as a function pointer). PURE LIBRARY, no core feature. Hosted (links libpthread/
; libc) — concurrency is a hosted concern; bare-metal concurrency is a separate axis.
(module thread)

; int pthread_create(pthread_t*, const pthread_attr_t*, void*(*)(void*), void*)
(extern pthread_create :cc c [(ptr i8) (ptr i8) (fnptr c [(ptr i8)] (ptr i8)) (ptr i8)] (-> i32))
; int pthread_join(pthread_t, void**)
(extern pthread_join   :cc c [(ptr i8) (ptr i8)] (-> i32))

; A handle to a spawned thread. `pthread_t` is an opaque pointer-sized value; we keep it
; in a struct so a thread is an ordinary value you pass around.
(defstruct Thread [(handle (ptr i8))])

; spawn: run `body(arg)` on a new thread, recording the handle into `th`. Returns the
; pthread_create status (0 = ok).
(defn thread-spawn [(th (ptr Thread)) (body (fnptr c [(ptr i8)] (ptr i8))) (arg (ptr i8))] (-> i32)
  (pthread_create (cast (ptr i8) (field th handle)) (cast (ptr i8) 0) body arg))

; join: block until the thread finishes (discarding its return value). Returns status.
(defn thread-join [(th (ptr Thread))] (-> i32)
  (pthread_join (load (field th handle)) (cast (ptr i8) 0)))
"
    (str-eq name "try.coil")
      "(module try)
; `?`/try-style early exit for Result/Option — a PURE LIBRARY MACRO over
; block/return-from (themselves macros over loop/break). No core support: this is
; the macros-first thesis continuing into Phase-2, killing the Result/Option
; match-pyramids.
;
; Wrap a function body in `(try …)` (a `block :try`), then `(try! e)` unwraps an
; `(Ok v)` to v or short-circuits the whole `try` with `(Err e)`; `(try? e)` does
; the same for `(Some v)` / `(None)`. The function's return type is the Result/
; Option, and the try body's normal tail must produce one (e.g. end in `(Ok …)`).
;
;   (import \"lib/try.coil\" :use *) (import \"lib/result.coil\" :use *)
;   (defn f [...] (-> (Result i64 E))
;     (try (let [a (try! (g ...)) b (try! (h ...))] (Ok (iadd a b)))))
;
; NOTE: the block label is the fixed `:try`, so nesting two `(try …)` blocks in ONE
; function shadows (a compile error) — use one try-block per function (the common
; case; functions compose via their Result returns).

(import \"result.coil\"  :use *)   ; Ok / Err / Some / None
(import \"control.coil\" :use *)   ; block / return-from / loop / break

(defn try [& (body Code)] (-> Code)
  `(block :try ~@body))

; Result: (Ok v) -> v ; (Err e) -> short-circuit the enclosing (try) with (Err e).
(defn try! [(e Code)] (-> Code)
  (let [v (gensym) er (gensym)]
    `(match ~e
       (Ok  [~v] ~v)
       (Err [~er] (return-from :try (Err ~er))))))

; Option: (Some v) -> v ; (None) -> short-circuit the enclosing (try) with (None).
(defn try? [(e Code)] (-> Code)
  (let [v (gensym)]
    `(match ~e
       (Some [~v] ~v)
       (None []   (return-from :try (None))))))
"
    ""))
