; selfhost/src/comptime_eval.coil — the COMPILED comptime fold (interp deletion step 1,
; mac-8). The tree-walk interpreter (comptime.coil) is a strictly WEAKER sublanguage than
; a macro body: it rejects generic calls, sizeof/alignof/offsetof, and strings. When
; `fold-expr` (the check-finish comptime/const fold) hits a `(comptime E)` / non-literal
; `(const …)` site the interpreter cannot evaluate, it calls the hook registered here,
; which compiles E through the SAME compiled metaprogram engine macros already use:
;
;   1. recover E's checked static type (only scalars — int/bool/f64 — are read back);
;   2. build a MINIMAL closure sub-program of what E transitively calls, plus a synthetic
;      `(defn coil.ct.thunk [] (-> T) E)` exported under the C symbol `coil_ct_thunk`;
;   3. monomorphize + build + dlopen it (meta-build-dylib), dlsym the entry, run it, and
;      read the scalar result back out of the return register;
;   4. rebuild a literal from the value (comptime.coil::build-value) and hand it back.
;
; The hook DECLINES (returns null) for anything it can't read back — an aggregate/string/
; f32 result, or a closure it can't clear — so the interpreter's own error stands (no
; regression: aggregate comptime still folds on the interpreter). The LLVM-free seed,
; which never registers the hook, is byte-identical.
(module comptime_eval)

(import "alloc.coil" :use *)
(import "result.coil" :use *)
(import "slice.coil" :use *)
(import "str.coil" :use *)
(import "arraylist.coil" :use *)
(import "match.coil" :use *)        ; match-else
(import "control.coil" :use *)
(import "try.coil" :use *)
(import "ast.coil" :use *)
(import "ctval.coil" :use *)   ; CtVal / EnvBind / CtCtx (was reached via comptime.coil)
(import "parser.coil" :use *)       ; box-al
(import "resolve.coil" :use *)      ; SBox, set-contains
(import "check.coil" :use *)        ; type-map-lookup, Diag, derr
(import "comptime.coil" :use *)     ; CtCtx, fold-expr(-list), build-value, closure-*, CtVal, trunc, diag-some?, set-comptime-fold-hook!
(import "mono.coil" :use *)         ; monomorphize, sort-mono-program, drop-code-funcs
(import "metaengine.coil" :use *)   ; meta-build-box/meta-mobj-box, me-unique, me-link-flags-str
(import "macho.coil" :use *)        ; MObj
(import "jit.coil" :use *)          ; jit-load / jit-lookup — the in-memory path

(extern dlopen :cc c [(ptr i8) i64] (-> (ptr i8)))
(extern dlsym  :cc c [(ptr i8) (ptr i8)] (-> (ptr i8)))
(extern system :cc c [(ptr i8)] (-> i32))
(extern unlink :cc c [(ptr i8)] (-> i32))

; box a (Result Expr Diag) on the heap so the hook can hand it back through (ptr i8).
(defn cte-box [(a (ptr Allocator)) (r (Result Expr Diag))] (-> (ptr i8))
  (let [p (unwrap-ptr [(Result Expr Diag)] (create [(Result Expr Diag)] a))] (store! p r) (cast (ptr i8) p)))

; classify the comptime result type: 1=int, 2=bool, 3=f64, 0=not-readable (decline).
(defn cte-kind [(t (ptr Type))] (-> i64)
  (match-else (load t)
    (TInt   [b s] 1)
    (TBool  []    2)
    (TFloat [b]   (if (icmp-eq b 64) 3 (if (icmp-eq b 32) 4 0)))
    (_ 0)))

; the checked static type of the comptime inner expression: the type map by nid, with a
; structural fallback for the intrinsic-typed leaves (sizeof/alignof/offsetof are i64).
(defn cte-node-type [(e (ptr Expr))] (-> (Option Type))
  (match (type-map-lookup (load (field e nid)))
    (Some [t] (Some t))
    (None []
      (match-else (load (field e kind))
        (EInt      [v]     (Some (TInt 64 true)))
        (EBool     [b]     (Some (TBool)))
        (EFloat    [bits]  (Some (TFloat 64)))
        (ESizeOf   [ty]    (Some (TInt 64 true)))
        (EAlignOf  [ty]    (Some (TInt 64 true)))
        (EOffsetOf [ty f]  (Some (TInt 64 true)))
        (_ (None [Type]))))))

; fold every comptime site in the closure funcs' bodies (rare — a helper reached by E
; that itself has a comptime), reusing the interp/hook fold. On failure the whole
; compiled fold declines so the interpreter's original error stands.
(defn cte-fold-closure [(sub (ptr Program)) (cx (ptr CtCtx))] (-> (Result i64 Diag))
  (let [fs (load (field sub funcs)) n (al-len [Func] (load fs)) (mut i) 0 (mut err) (None [Diag])]
    (loop (if (or (diag-some? (load err)) (icmp-ge (load i) n)) (break)
      (do (match (fold-expr-list (load (field (al-elem [Func] fs (load i)) body)) cx)
            (Err [d] (store! err (Some d)))
            (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (match (load err) (Some [d] (Err [i64 Diag] d)) (None [] (Ok [i64 Diag] 0)))))

; append (defn coil.ct.thunk [] (-> T) E) to the sub-program's funcs and export it as
; the C symbol `coil_ct_thunk` (a zero-param scalar return needs no C-ABI thunk).
(defn cte-add-entry [(a (ptr Allocator)) (sub (ptr Program)) (inner (ptr Expr)) (rty Type)] (-> i64)
  (let [f (alloc-stack Func) (mut body) (al-new [Expr] a)]
    (al-push! (mut body) (load inner))
    (store! (field f name) "coil.ct.thunk")
    (store! (field f type_params) (box-al [(slice u8)] a (al-new [(slice u8)] a)))
    (store! (field f bounds) (box-al [Bound] a (al-new [Bound] a)))
    (store! (field f cc) "c")
    (store! (field f params) (box-al [Param] a (al-new [Param] a)))
    (store! (field f ret) rty)
    (store! (field f body) (box-al [Expr] a (load body)))
    (store! (field f macro_variadic) false)
    (store! (field f lo) -1) (store! (field f hi) -1) (store! (field f source) -1) (store! (field f ctxt) 0)
    (al-push! [Func] (load (field sub funcs)) (load f)))
  (let [e (alloc-stack ExportC)]
    (store! (field e name) "coil.ct.thunk")
    (store! (field e symbol) (Some "coil_ct_thunk"))
    (store! (field e params) (box-al [Type] a (al-new [Type] a)))
    (store! (field e lo) -1) (store! (field e hi) -1) (store! (field e source) -1) (store! (field e ctxt) 0)
    (al-push! [ExportC] (load (field sub exports)) (load e)))
  0)

; run the compiled entry and read the scalar out of the return register.
(defn cte-invoke [(fp (ptr i8)) (kind i64) (tp (ptr Type))] (-> CtVal)
  (if (icmp-eq kind 4)
      ; f32 comes back in the low half of the FP return register. Widening to f64 is
      ; exact, and the literal is re-typed f32 by the site's own checked type.
      (CFloat (cast f64 (call-ptr (cast (fnptr c [] f32) fp))))
  (if (icmp-eq kind 3)
      (CFloat (call-ptr (cast (fnptr c [] f64) fp)))
    (let [n (call-ptr (cast (fnptr c [] i64) fp))]
      (if (icmp-eq kind 2) (CBool (icmp-ne n 0))
        (match-else (load tp)
          (TInt [b s] (CInt (trunc n b s)))
          (_ (CInt n))))))))

; mono + build-obj + link + dlopen a self-contained comptime dylib. Unlike the macro
; engine's meta-build-dylib, a comptime program has NO code ops, so there is no metashim
; vtable handshake (coil_mp_init) — a plain dlopen suffices.
(defn cte-build-dylib [(a (ptr Allocator)) (sub (ptr Program))] (-> (Result (ptr i8) Diag))
  (try (do
    (let [bb (meta-build-box)]
      (if (icmp-eq (load (field bb isset)) 0)
          (return-from :try (Err [(ptr i8) Diag] (derr "comptime: this compiler build has no backend object builder to compile comptime expressions"))) 0)
      (let [mp (try! (monomorphize a sub))]
        (sort-mono-program a mp)
        (let [id (me-unique a)
              obj-s (sconcat3 a "/tmp/coil-ct-" id ".o")
              tmp-s (sconcat3 a "/tmp/coil-ct-" id ".dylib")]
          (call-ptr (load (field bb fp)) a mp (slice->cstr a obj-s))
          (let [cmd (sconcat a (sconcat a (sconcat3 a "cc -dynamiclib " obj-s " -o ")
                                        (sconcat a tmp-s " -Wl,-undefined,dynamic_lookup"))
                               (me-link-flags-str a))]
            (if (icmp-ne (cast i64 (system (slice->cstr a cmd))) 0)
                (Err [(ptr i8) Diag] (derr "comptime: linking the compiled comptime dylib failed"))
              (do (unlink (slice->cstr a obj-s))
                  (let [h (dlopen (slice->cstr a tmp-s) 2)]
                    (if (icmp-eq (cast i64 h) 0)
                        (Err [(ptr i8) Diag] (derr "comptime: dlopen of the compiled comptime dylib failed"))
                      ; the image stays mapped for the life of the process, so the file
                      ; itself is dead weight — drop it rather than litter /tmp with one
                      ; dylib per comptime site. (Unlike the METAPROGRAM dylibs, which are
                      ; deliberately kept: they are content-hashed into ~/.cache/coil.)
                      (do (unlink (slice->cstr a tmp-s))
                          (Ok [(ptr i8) Diag] h)))))))))))))

; ---- reaching the compiled entry ------------------------------------------------
; When the backend can hand the object back IN MEMORY (the arm64 backend registers
; meta-build-mobj), monomorphize and load it straight into executable pages — no
; temp .o, no fork of `cc -dynamiclib`, no dlopen. The LLVM backend emits only via
; LLVMTargetMachineEmitToFile and has no MObj to give, so under LLVM this falls back
; to building a real dylib. The CODEGEN is the same either way; only the route into
; memory differs.
;
; The image (or dylib) is deliberately left mapped. An aggregate readback can point
; at bytes inside it — a string literal lives in the image's own data — so unmapping
; here would dangle the value just folded.
(defn cte-entry [(a (ptr Allocator)) (sub (ptr Program))] (-> (Result (ptr i8) Diag))
  (if (meta-mobj-available?)
      (try (do
        (let [mp (try! (monomorphize a sub))]
          (sort-mono-program a mp)
          (let [(mut o) (call-ptr (load (field (meta-mobj-box) fp)) a mp)]
            (match (jit-load a (mut o))
              (Err [m] (Err [(ptr i8) Diag] (derr m)))
              (Ok [img0]
                (let [img (alloc-stack JitImage)]
                  (store! img img0)
                  (let [fp (jit-lookup img "coil_ct_thunk")]
                    (if (icmp-eq (cast i64 fp) 0)
                        (Err [(ptr i8) Diag] (derr "comptime: compiled entry missing from the in-memory image (compiler bug)"))
                      (Ok [(ptr i8) Diag] fp))))))))))
    (match (cte-build-dylib a sub)
      (Err [d] (Err [(ptr i8) Diag] d))
      (Ok [h]
        (let [fp (dlsym h (slice->cstr a "coil_ct_thunk"))]
          (if (icmp-eq (cast i64 fp) 0)
              (Err [(ptr i8) Diag] (derr "comptime: compiled entry missing from the metaprogram dylib (compiler bug)"))
            (Ok [(ptr i8) Diag] fp)))))))

; run the entry, reconstruct a literal from the scalar it returns.
(defn cte-run [(a (ptr Allocator)) (sub (ptr Program)) (cx (ptr CtCtx)) (inner (ptr Expr)) (kind i64) (tp (ptr Type))] (-> (ptr i8))
  (match (cte-entry a sub)
    (Err [d] (cte-box a (Err [Expr Diag] d)))
    (Ok [fp]
      (let [lo (load (field inner lo)) hi (load (field inner hi)) src (load (field inner source)) ctxt (load (field inner ctxt))
            cv (cte-invoke fp kind tp)]
        (match (build-value a (new-cell cv) lo hi src ctxt cx)
          (Err [d] (cte-box a (Err [Expr Diag] d)))
          (Ok [lit] (cte-box a (Ok [Expr Diag] lit))))))))

; ============================ AGGREGATE readback (interp deletion step 3a) =========
; The scalar path above reads int/bool/f64 out of the return register. An AGGREGATE
; comptime — a struct/array/string built with a capability the interpreter lacks
; (sizeof, a generic call, a string op) — needs a NATIVE-MEMORY readback instead: a
; write-through `(ptr T)` thunk stores E's result into a heap buffer, and we walk the
; C layout by field offset to rebuild a CtVal (which build-value turns into a literal,
; exactly like the interpreter's own aggregate fold). The layout walked here is the
; NATURAL C ABI both backends emit (codegen_a64.coil::g-natural-layout! and codegen.coil
; via LLVMOffsetOfElement); it is NOT a third private layout, it is that one contract.
; Sums, raw pointers, f32, vecs, non-u8 slices and non-default struct layouts are
; DECLINED (the reader returns None → the hook returns null → the interpreter's own
; "isn't supported yet" error stands, so nothing that folds today regresses).

(defn cte-align8 [(x i64)] (-> i64) (imul (idiv (iadd x 7) 8) 8))

; CONSERVATIVE payload sizing, mirroring codegen.coil::type-bytes and
; codegen_a64.coil::g-type-bytes exactly. This is deliberately NOT cte-ty-size.
; A sum's payload word count comes from the conservative per-field align8
; accumulation, while the offsets of the fields INSIDE that payload are natural.
; The two disagree the moment a variant carries a struct, so the reader needs both.
(defn cte-tb [(cx (ptr CtCtx)) (t (ptr Type))] (-> i64)
  (match-else (load t)
    (TInt   [b s]  (idiv (iadd b 7) 8))
    (TFloat [b]    (idiv b 8))
    (TBool  []     1)
    (TPtr   [i]    8) (TRef [m i] 8) (TFn [c p r] 8)
    (TSlice [el]   16)
    (TArray [el n] (imul (cte-tb cx el) n))
    (TStruct [nm]
      (let [sd (ct-struct-find cx nm)]
        (if (icmp-ne (cast i64 sd) 0)
            (let [fs (load (field sd fields)) n (al-len [Field] (load fs)) (mut i) 0 (mut tot) 0]
              (loop (if (icmp-ge (load i) n) (break)
                (do (store! tot (iadd (load tot) (cte-align8 (cte-tb cx (field (al-elem [Field] fs (load i)) ty)))))
                    (store! i (iadd (load i) 1)))))
              (load tot))
          (let [ud (ct-sum-find cx nm)]
            (if (icmp-eq (cast i64 ud) 0) 8
              (iadd 8 (imul 8 (cte-sum-words cx ud))))))))
    (_ 8)))
; payload words: max over variants of the conservative per-field accumulation.
(defn cte-sum-words [(cx (ptr CtCtx)) (ud (ptr SumDef))] (-> i64)
  (let [vs (load (field ud variants)) nv (al-len [Variant] (load vs)) (mut i) 0 (mut maxb) 0]
    (loop (if (icmp-ge (load i) nv) (break)
      (do (let [vp (al-elem [Variant] vs (load i))
                fs (load (field vp fields)) nf (al-len [Field] (load fs)) (mut j) 0 (mut acc) 0]
            (loop (if (icmp-ge (load j) nf) (break)
              (do (store! acc (iadd (load acc) (cte-align8 (cte-tb cx (field (al-elem [Field] fs (load j)) ty)))))
                  (store! j (iadd (load j) 1)))))
            (if (icmp-gt (load acc) (load maxb)) (store! maxb (load acc)) 0))
          (store! i (iadd (load i) 1)))))
    (idiv (load maxb) 8)))

; natural alignment of `t` (the C ABI: TInt 1/2/4/8, everything pointer-shaped 8, a
; struct = its widest field). Only ever reached for a cte-readable? type.
(defn cte-ty-align [(cx (ptr CtCtx)) (t (ptr Type))] (-> i64)
  (match-else (load t)
    (TInt   [b s]  (if (icmp-le b 8) 1 (if (icmp-le b 16) 2 (if (icmp-le b 32) 4 8))))
    (TFloat [b]    (idiv b 8))
    (TBool  []     1)
    (TPtr   [i]    8) (TRef [m i] 8) (TFn [c p r] 8)
    (TArray [el n] (cte-ty-align cx el))
    (TSlice [el]   8)
    (TStruct [nm]
      (let [sd (ct-struct-find cx nm)]
        (if (icmp-eq (cast i64 sd) 0) 8        ; a sum (or unknown) is 8-aligned
          (let [fs (load (field sd fields)) n (al-len [Field] (load fs)) (mut i) 0 (mut mx) 1]
            (loop (if (icmp-ge (load i) n) (break)
              (do (let [al (cte-ty-align cx (field (al-elem [Field] fs (load i)) ty))]
                    (if (icmp-gt al (load mx)) (store! mx al) 0))
                  (store! i (iadd (load i) 1)))))
            (load mx)))))
    (_ 8)))
; natural byte size of `t`, and the struct-size rounding (align8-of-widest). Mirrors
; g-natural-layout! / ty-size exactly.
(defn cte-struct-size [(cx (ptr CtCtx)) (sd (ptr StructDef))] (-> i64)
  (let [fs (load (field sd fields)) n (al-len [Field] (load fs)) (mut off) 0 (mut maxal) 1 (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [fty (field (al-elem [Field] fs (load i)) ty) al (cte-ty-align cx fty)]
            (if (icmp-gt al (load maxal)) (store! maxal al) 0)
            (store! off (imul (idiv (iadd (load off) (isub al 1)) al) al))
            (store! off (iadd (load off) (cte-ty-size cx fty))))
          (store! i (iadd (load i) 1)))))
    (imul (idiv (iadd (load off) (isub (load maxal) 1)) (load maxal)) (load maxal))))
(defn cte-ty-size [(cx (ptr CtCtx)) (t (ptr Type))] (-> i64)
  (match-else (load t)
    (TInt   [b s]  (if (icmp-le b 8) 1 (if (icmp-le b 16) 2 (if (icmp-le b 32) 4 8))))
    (TFloat [b]    (idiv b 8))
    (TBool  []     1)
    (TPtr   [i]    8) (TRef [m i] 8) (TFn [c p r] 8)
    (TArray [el n] (imul (cte-ty-size cx el) n))
    (TSlice [el]   16)
    (TStruct [nm]
      (let [sd (ct-struct-find cx nm)]
        (if (icmp-ne (cast i64 sd) 0) (cte-struct-size cx sd)
          (let [ud (ct-sum-find cx nm)]
            ; {tag, [words x i64]} — the tag occupies a whole 8-byte slot
            (if (icmp-eq (cast i64 ud) 0) 8 (iadd 8 (imul 8 (cte-sum-words cx ud))))))))
    (_ 8)))
; byte offset of field `fi` within struct `sd`, honouring the declared layout.
; LC/LAligned mirror g-natural-off; LPacked is the same walk with the alignment
; step removed; LExplicit reads the offsets it was given.
(defn cte-field-off [(cx (ptr CtCtx)) (sd (ptr StructDef)) (fi i64)] (-> i64)
  (match-else (load (field sd layout))
    (LExplicit [offs size align] (al-get [i64] (load offs) fi))
    (LPacked []
      (let [fs (load (field sd fields)) (mut off) 0 (mut i) 0 (mut res) 0]
        (loop (if (icmp-gt (load i) fi) (break)
          (do (if (icmp-eq (load i) fi) (store! res (load off)) 0)
              (store! off (iadd (load off) (cte-ty-size cx (field (al-elem [Field] fs (load i)) ty))))
              (store! i (iadd (load i) 1)))))
        (load res)))
    (_
      (let [fs (load (field sd fields)) (mut off) 0 (mut i) 0 (mut res) 0]
        (loop (if (icmp-gt (load i) fi) (break)
          (do (let [fty (field (al-elem [Field] fs (load i)) ty) al (cte-ty-align cx fty)]
                (store! off (imul (idiv (iadd (load off) (isub al 1)) al) al))
                (if (icmp-eq (load i) fi) (store! res (load off)) 0)
                (store! off (iadd (load off) (cte-ty-size cx fty))))
              (store! i (iadd (load i) 1)))))
        (load res)))))
; Can this struct's fields be located by BYTE offset? Everything except LBits can:
; LC and LAligned lay fields out naturally, LPacked drops the padding, LExplicit
; states the offsets outright. LBits packs fields into a backing integer at BIT
; positions, so there is no byte offset to read from — that one stays declined.
(defn cte-walkable-layout? [(sd (ptr StructDef))] (-> bool)
  (match-else (load (field sd layout)) (LBits [b o] false) (_ true)))
; can a value of `t` be read back into a CtVal? (int/bool/f64/array-of/string/LC-struct-of).
(defn cte-struct-readable? [(cx (ptr CtCtx)) (sd (ptr StructDef))] (-> bool)
  (let [fs (load (field sd fields)) n (al-len [Field] (load fs)) (mut i) 0 (mut ok) true]
    (loop (if (or (not (load ok)) (icmp-ge (load i) n)) (break)
      (do (if (not (cte-readable? cx (field (al-elem [Field] fs (load i)) ty))) (store! ok false) 0)
          (store! i (iadd (load i) 1)))))
    (load ok)))
(defn cte-readable? [(cx (ptr CtCtx)) (t (ptr Type))] (-> bool)
  (match-else (load t)
    (TInt   [b s]  true)
    (TBool  []     true)
    (TFloat [b]    (or (icmp-eq b 64) (icmp-eq b 32)))
    (TArray [el n] (cte-readable? cx el))
    (TSlice [el]   (match-else (load el) (TInt [b s] (icmp-eq b 8)) (_ false)))
    (TStruct [nm]
      (let [sd (ct-struct-find cx nm)]
        (if (icmp-ne (cast i64 sd) 0)
            (if (not (cte-walkable-layout? sd)) false (cte-struct-readable? cx sd))
          (let [ud (ct-sum-find cx nm)]
            (if (icmp-eq (cast i64 ud) 0) false (cte-sum-readable? cx ud))))))
    (_ false)))

; every field of every variant must be readable — the tag selects one at run time,
; so a sum is only foldable if the reader could handle whichever came back.
(defn cte-sum-readable? [(cx (ptr CtCtx)) (ud (ptr SumDef))] (-> bool)
  (let [vs (load (field ud variants)) nv (al-len [Variant] (load vs)) (mut i) 0 (mut ok) true]
    (loop (if (or (not (load ok)) (icmp-ge (load i) nv)) (break)
      (do (let [fs (load (field (al-elem [Variant] vs (load i)) fields))
                nf (al-len [Field] (load fs)) (mut j) 0]
            (loop (if (icmp-ge (load j) nf) (break)
              (do (if (not (cte-readable? cx (field (al-elem [Field] fs (load j)) ty))) (store! ok false) 0)
                  (store! j (iadd (load j) 1))))))
          (store! i (iadd (load i) 1)))))
    (load ok)))

; ---- native-memory readers -------------------------------------------------------
; assemble `nbytes` little-endian bytes at buf+off into a zero-extended i64.
(defn cte-load-raw [(buf (ptr i8)) (off i64) (nbytes i64)] (-> i64)
  (let [(mut i) 0 (mut acc) 0]
    (loop (if (icmp-ge (load i) nbytes) (break)
      (do (let [byte (iand (cast i64 (load (cast (ptr i8) (iadd (cast i64 buf) (iadd off (load i)))))) 255)]
            (store! acc (ior (load acc) (ishl byte (imul (load i) 8)))))
          (store! i (iadd (load i) 1)))))
    (load acc)))
(defn cte-load-f64 [(buf (ptr i8)) (off i64)] (-> f64)
  (load (cast (ptr f64) (iadd (cast i64 buf) off))))
(defn cte-load-f32 [(buf (ptr i8)) (off i64)] (-> f64)
  (cast f64 (load (cast (ptr f32) (iadd (cast i64 buf) off)))))
(defn cte-copy-bytes [(dst (ptr i8)) (src (ptr i8)) (n i64)] (-> i64)
  (let [(mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (store! (cast (ptr i8) (iadd (cast i64 dst) (load i)))
                  (load (cast (ptr i8) (iadd (cast i64 src) (load i)))))
          (store! i (iadd (load i) 1))))))
  0)
; read a (slice u8) {ptr@off, len@off+8}: copy len bytes out of the still-mapped dylib.
(defn cte-read-str [(buf (ptr i8)) (off i64) (a (ptr Allocator))] (-> (Option CtVal))
  (let [p   (cast (ptr i8) (cte-load-raw buf off 8))
        len (cte-load-raw buf (iadd off 8) 8)]
    (if (or (icmp-eq (cast i64 p) 0) (icmp-le len 0))
        (Some (CStr (slice-new [u8] (cast (ptr u8) 0) 0)))
      (match (raw-alloc a len 1)
        (None [] (None [CtVal]))
        (Some [dst]
          (do (cte-copy-bytes dst p len)
              (Some (CStr (slice-new [u8] (cast (ptr u8) dst) len)))))))))
(defn cte-read-struct [(cx (ptr CtCtx)) (sd (ptr StructDef)) (nm (slice u8)) (buf (ptr i8)) (off i64) (a (ptr Allocator))] (-> (Option CtVal))
  (let [fs (load (field sd fields)) n (al-len [Field] (load fs))
        (mut cells) (al-new [(ptr CtVal)] a) (mut i) 0 (mut bad) false]
    (loop (if (or (load bad) (icmp-ge (load i) n)) (break)
      (do (let [foff (iadd off (cte-field-off cx sd (load i)))
                fty (field (al-elem [Field] fs (load i)) ty)]
            (match (cte-read cx fty buf foff a)
              (None [] (store! bad true))
              (Some [cv] (al-push! (mut cells) (new-cell cv)))))
          (store! i (iadd (load i) 1)))))
    (if (load bad) (None [CtVal]) (Some (CStruct nm (box-al [(ptr CtVal)] a (load cells)))))))
; Read a sum at buf+off.
;
; Layout, verified against BOTH backends by dumping the bytes of a live value:
;
;   0..3   tag (i32) — the variant's declaration index
;   4..7   padding   — NOT zeroed by the arm64 backend, so the tag must be read as
;                      4 bytes; reading 8 picks up whatever was on the stack
;   8..    payload   — the selected variant's fields at NATURAL offsets, exactly
;                      the g-natural-off walk, independent of the conservative
;                      per-field align8 that decides how many words the payload has
(defn cte-read-sum [(cx (ptr CtCtx)) (ud (ptr SumDef)) (buf (ptr i8)) (off i64) (a (ptr Allocator))] (-> (Option CtVal))
  (let [vs (load (field ud variants)) nv (al-len [Variant] (load vs))
        tag (cte-load-raw buf off 4)]
    (if (or (icmp-lt tag 0) (icmp-ge tag nv)) (None [CtVal])
      (let [vp (al-elem [Variant] vs tag)
            fs (load (field vp fields)) nf (al-len [Field] (load fs))
            (mut cells) (al-new [(ptr CtVal)] a) (mut i) 0 (mut foff) 0 (mut bad) false]
        (loop (if (or (load bad) (icmp-ge (load i) nf)) (break)
          (do (let [fty (field (al-elem [Field] fs (load i)) ty)
                    al (cte-ty-align cx fty)]
                (store! foff (imul (idiv (iadd (load foff) (isub al 1)) al) al))
                (match (cte-read cx fty buf (iadd (iadd off 8) (load foff)) a)
                  (None [] (store! bad true))
                  (Some [cv] (al-push! (mut cells) (new-cell cv))))
                (store! foff (iadd (load foff) (cte-ty-size cx fty))))
              (store! i (iadd (load i) 1)))))
        (if (load bad) (None [CtVal])
          (Some (CSum (load (field vp name)) (box-al [(ptr CtVal)] a (load cells)))))))))

; read a value of type `t` at buf+off. None = a leaf this reader declines (no regression).
(defn cte-read [(cx (ptr CtCtx)) (t (ptr Type)) (buf (ptr i8)) (off i64) (a (ptr Allocator))] (-> (Option CtVal))
  (match-else (load t)
    (TInt   [b s] (Some (CInt (trunc (cte-load-raw buf off (cte-ty-size cx t)) b s))))
    (TBool  []    (Some (CBool (icmp-ne (cte-load-raw buf off 1) 0))))
    (TFloat [b]   (if (icmp-eq b 64) (Some (CFloat (cte-load-f64 buf off)))
                    (if (icmp-eq b 32) (Some (CFloat (cte-load-f32 buf off))) (None [CtVal]))))
    (TArray [el n]
      (let [es (cte-ty-size cx el) (mut cells) (al-new [(ptr CtVal)] a) (mut i) 0 (mut bad) false]
        (loop (if (or (load bad) (icmp-ge (load i) n)) (break)
          (do (match (cte-read cx el buf (iadd off (imul (load i) es)) a)
                (None [] (store! bad true))
                (Some [cv] (al-push! (mut cells) (new-cell cv))))
              (store! i (iadd (load i) 1)))))
        (if (load bad) (None [CtVal]) (Some (CArray (load el) (box-al [(ptr CtVal)] a (load cells)))))))
    (TSlice [el]
      (match-else (load el) (TInt [b s] (if (icmp-eq b 8) (cte-read-str buf off a) (None [CtVal]))) (_ (None [CtVal]))))
    (TStruct [nm]
      (let [sd (ct-struct-find cx nm)]
        (if (icmp-ne (cast i64 sd) 0)
            (if (not (cte-walkable-layout? sd)) (None [CtVal]) (cte-read-struct cx sd nm buf off a))
          ; the nominal may name a SUM rather than a struct
          (let [ud (ct-sum-find cx nm)]
            (if (icmp-eq (cast i64 ud) 0) (None [CtVal]) (cte-read-sum cx ud buf off a))))))
    (_ (None [CtVal]))))

; append (defn coil.ct.thunk [($ct$out (ptr T))] (-> i64) (do (store! $ct$out E) 0)) —
; a write-through entry (a pointer param needs no C-ABI thunk on either backend).
(defn cte-add-entry-agg [(a (ptr Allocator)) (sub (ptr Program)) (inner (ptr Expr)) (rty Type)] (-> i64)
  (let [f (alloc-stack Func) (mut params) (al-new [Param] a) pp (alloc-stack Param)]
    (store! (field pp name) "$ct$out")
    (store! (field pp ty) (TPtr (box-type a rty)))
    (al-push! (mut params) (load pp))
    (let [lo (load (field inner lo)) hi (load (field inner hi)) src (load (field inner source)) ctxt (load (field inner ctxt))
          (mut body) (al-new [Expr] a)]
      (al-push! (mut body) (mk-expr (EStore (box-expr a (mk-expr (EVar "$ct$out") lo hi src ctxt)) (box-expr a (load inner))) lo hi src ctxt))
      (al-push! (mut body) (mk-expr (EInt 0) lo hi src ctxt))
      (store! (field f name) "coil.ct.thunk")
      (store! (field f type_params) (box-al [(slice u8)] a (al-new [(slice u8)] a)))
      (store! (field f bounds) (box-al [Bound] a (al-new [Bound] a)))
      (store! (field f cc) "c")
      (store! (field f params) (box-al [Param] a (load params)))
      (store! (field f ret) (TInt 64 true))
      (store! (field f body) (box-al [Expr] a (load body)))
      (store! (field f macro_variadic) false)
      (store! (field f lo) -1) (store! (field f hi) -1) (store! (field f source) -1) (store! (field f ctxt) 0)
      (al-push! [Func] (load (field sub funcs)) (load f))))
  (let [e (alloc-stack ExportC) (mut eparams) (al-new [Type] a)]
    (al-push! (mut eparams) (TPtr (box-type a rty)))
    (store! (field e name) "coil.ct.thunk")
    (store! (field e symbol) (Some "coil_ct_thunk"))
    (store! (field e params) (box-al [Type] a (load eparams)))
    (store! (field e lo) -1) (store! (field e hi) -1) (store! (field e source) -1) (store! (field e ctxt) 0)
    (al-push! [ExportC] (load (field sub exports)) (load e)))
  0)
; run the entry write-through into a heap buffer, then read the aggregate back.
(defn cte-run-agg [(a (ptr Allocator)) (sub (ptr Program)) (cx (ptr CtCtx)) (inner (ptr Expr)) (t0 Type)] (-> (ptr i8))
  (match (cte-entry a sub)
    (Err [d] (cte-box a (Err [Expr Diag] d)))
    (Ok [fp]
      (let [tp (alloc-stack Type)] (store! tp t0)
        (match (raw-alloc a (iadd (cte-ty-size cx tp) 64) 16)
          (None [] (cte-box a (Err [Expr Diag] (derr "comptime: out of memory allocating the comptime readback buffer"))))
          (Some [buf]
            (do
              (call-ptr (cast (fnptr c [(ptr i8)] i64) fp) buf)
              (match (cte-read cx tp buf 0 a)
                (None [] (cast (ptr i8) 0))
                (Some [cv]
                  (let [lo (load (field inner lo)) hi (load (field inner hi)) src (load (field inner source)) ctxt (load (field inner ctxt))]
                    (match (build-value a (new-cell cv) lo hi src ctxt cx)
                      (Err [d] (cte-box a (Err [Expr Diag] d)))
                      (Ok [lit] (cte-box a (Ok [Expr Diag] lit))))))))))))))

; the registered hook (comptime.coil::ct-fold-hook). null = declined.
(defn comptime-fold-one [(a (ptr Allocator)) (inner (ptr Expr)) (cx (ptr CtCtx))] (-> (ptr i8))
  (let [prog (load (field cx prog))]
    (if (icmp-eq (cast i64 prog) 0) (cast (ptr i8) 0)
      (match (cte-node-type inner)
        (None [] (cast (ptr i8) 0))
        (Some [t0]
          (let [tp (alloc-stack Type)] (store! tp t0)
            (let [kind (cte-kind tp)]
              ; scalar (kind 1/2/3) → return-register path; else a readable aggregate
              ; → write-through path; anything else declines (interp error stands).
              (if (and (icmp-eq kind 0) (not (cte-readable? cx tp))) (cast (ptr i8) 0)
                ; clear any nested comptime in E itself first (via interp/hook)
                (match (fold-expr inner cx)
                  (Err [_] (cast (ptr i8) 0))
                  (Ok [_]
                    (let [names (prog-fn-names prog a)
                          stackb (unwrap-ptr [SBox] (create [SBox] a))]
                      (store! (field stackb items) (al-new [(slice u8)] a))
                      (collect-calls inner names stackb)
                      (let [wanted (closure-funcs prog (field stackb items) a)
                            sub (closure-subprogram prog wanted a)]
                        (match (cte-fold-closure sub cx)
                          (Err [_] (cast (ptr i8) 0))
                          (Ok [_]
                            (if (icmp-eq kind 0)
                                (do (cte-add-entry-agg a sub inner t0)
                                    (drop-code-funcs a sub)
                                    (cte-run-agg a sub cx inner t0))
                              (do (cte-add-entry a sub inner t0)
                                  (drop-code-funcs a sub)
                                  (cte-run a sub cx inner kind tp)))))))))))))))))

; wire the hook into the interpreter's fold pass (called by main / main_a64 at startup).
(defn register-comptime-fold! [] (-> i64)
  (set-comptime-fold-hook! (fnptr-of comptime-fold-one)))
