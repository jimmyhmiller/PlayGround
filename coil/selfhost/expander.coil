; selfhost/resolver.coil — the Coil port of src/resolve.rs (the name-resolution /
; "qualify" pass), composed over the already-completed reader + parser + loader.
;
; THE CONTRACT (see selfhost/oracle/resolved/): build this with the Rust `coil`,
;   selfhost/oracle/gate-resolved.sh <this-binary>
; must be byte-identical to the reference `coil dump-resolved` across the whole
; corpus. A shortcut (dropped qualification, skipped reference) makes the corpus
; diff non-empty and the gate FAILS.
;
; PIPELINE: selfread (reader) -> selfload (loader = src/macros.rs::load_program,
; producing module-tagged forms + import/export tables) -> resolve (parse each
; tagged form via parse-program, qualify it under its module, merge) -> the
; canonical Program dump (d-program, REUSED from the parser pass).
;
; WHAT IS ALREADY WRITTEN (do not touch): the reader/AST representation, the
; reused reader, parse-program + its helpers, the canonical Program dumper, and
; file IO — copied verbatim from the COMPLETED parser pass. The loader port (LS /
; process-forms / load-program …) is copied from the completed loader pass. WHAT
; YOU IMPLEMENT: the resolve/qualify logic, ported FAITHFULLY from src/resolve.rs.
(module selfhost.checker)

(import "lib/alloc.coil"     :use *)
(import "lib/result.coil"    :use *)
(import "lib/slice.coil"     :use *)
(import "lib/str.coil"       :use *)
(import "lib/arraylist.coil" :use *)
(import "lib/io.coil"        :use *)
(import "lib/control.coil"   :use *)
(import "lib/try.coil"       :use *)
(import "lib/match.coil"     :use *)

; ---- libc the self-host tool needs ------------------------------------------
(extern open     :cc c [(ptr i8) i32] (-> i32))
(extern close    :cc c [i32] (-> i32))
(extern strtod   :cc c [(ptr i8) (ptr (ptr i8))] (-> f64))
(extern realpath :cc c [(ptr i8) (ptr i8)] (-> (ptr i8)))   ; NULL on failure
(extern getcwd   :cc c [(ptr i8) i64] (-> (ptr i8)))

; ============================ reader representation ==========================
; Copied verbatim from selfhost/reader.coil (the reader is a completed pass; the
; parser reuses it to turn source text into Sexp before parsing).
(defsum SexpKind
  (KInt   [(v i64)])
  (KFloat [(bits i64)])
  (KSym   [(s (slice u8))])
  (KKw    [(s (slice u8))])
  (KStr   [(s (slice u8))])
  (KCStr  [(s (slice u8))])
  (KList  [(items (ptr (ArrayList Sexp)))])
  (KVec   [(items (ptr (ArrayList Sexp)))]))

; source = the SourceMap id of the file this node was read from (0 = main file,
; 1 = <prelude>, then each import in load order). ctxt = expansion context (0 =
; user-written; nonzero only after the macro expander stamps it). Stamped by
; read-all (per file) and by stamp-expansion (per macro expansion).
(defstruct Sexp [(kind SexpKind) (lo i64) (hi i64) (source i64) (ctxt i64)])

(defsum TokKind
  (TOpen   [(c i64)])
  (TClose  [(c i64)])
  (TPrefix [(s (slice u8))])
  (TStr    [(s (slice u8))])
  (TCStr   [(s (slice u8))])
  (TAtom   [(s (slice u8))]))

(defstruct Tok [(kind TokKind) (lo i64) (hi i64)])
(defstruct Parser [(toks (ptr (ArrayList Tok))) (pos i64)])
(defstruct StrRead [(s (slice u8)) (end i64)])

; ============================ AST representation =============================
; Mirrors src/ast.rs. Recursion goes through (ptr Expr) / (ptr Type) (single
; box) and (ptr (ArrayList X)) (a sequence), like reader.coil/Sexp. Spans live as
; raw i64 lo/hi (dummy = -1), exactly as the reader stores them.

; Type — 14 constructable variants (src/ast.rs Type).
(defsum Type
  (TInt    [(bits i64) (signed bool)])
  (TFloat  [(bits i64)])
  (TBool   [])
  (TVoid   [])
  (TPtr    [(inner (ptr Type))])
  (TRef    [(mutable bool) (inner (ptr Type))])
  (TStruct [(name (slice u8))])
  (TArray  [(elem (ptr Type)) (n i64)])
  (TSlice  [(elem (ptr Type))])
  (TVec    [(elem (ptr Type)) (n i64)])
  (TFn     [(cc (slice u8)) (params (ptr (ArrayList Type))) (ret (ptr Type))])
  (TApp    [(name (slice u8)) (args (ptr (ArrayList Type)))])
  (TNever  [])
  (TCode   []))

; A function parameter (name + type).
(defstruct Param [(name (slice u8)) (ty Type)])
; A struct/variant field (name + type).
(defstruct Field [(name (slice u8)) (ty Type)])

; ExprKind — the 42 variants `parse_program` can PRODUCE (the 6 checker/mono-only
; variants — SpillRef, DynDispatch, MakeDyn, Construct, StaticRef, TraitCall —
; are never produced by the parser, so they are intentionally absent here).
; Numeric op tags: BinOp/CmpOp/Storage/TypeQuery/FieldMeta/CodeOp are stored as
; i64 codes (see the d-*-tag dumpers for the code->string mapping).
(defsum ExprKind
  (EInt       [(v i64)])
  (EStr       [(s (slice u8))])
  (ECStr      [(s (slice u8))])
  (EVar       [(name (slice u8))])
  (EZeroed    [(ty Type)])
  (EBorrow    [(mutable bool) (place (ptr Expr))])
  (ELet       [(binds (ptr (ArrayList Bind))) (body (ptr (ArrayList Expr)))])
  (EBin       [(op i64) (lhs (ptr Expr)) (rhs (ptr Expr))])
  (ENot       [(inner (ptr Expr))])
  (EFloat     [(bits i64)])
  (EBool      [(b bool)])
  (ECmp       [(op i64) (lhs (ptr Expr)) (rhs (ptr Expr))])
  (EIf        [(cnd (ptr Expr)) (thn (ptr Expr)) (els (ptr Expr))])
  (EDo        [(body (ptr (ArrayList Expr)))])
  (ECall      [(func (slice u8)) (type_args (ptr (ArrayList Type))) (args (ptr (ArrayList Expr)))])
  (EAlloc     [(storage i64) (ty Type)])
  (EField     [(p (ptr Expr)) (fname (slice u8))])
  (ELoad      [(inner (ptr Expr))])
  (EStore     [(p (ptr Expr)) (val (ptr Expr))])
  (EIndex     [(p (ptr Expr)) (idx (ptr Expr))])
  (ECast      [(ty Type) (inner (ptr Expr))])
  (ESizeOf    [(ty Type)])
  (EAlignOf   [(ty Type)])
  (EOffsetOf  [(ty Type) (fname (slice u8))])
  (EBitGet    [(p (ptr Expr)) (fname (slice u8))])
  (EBitSet    [(p (ptr Expr)) (fname (slice u8)) (val (ptr Expr))])
  (EFree      [(inner (ptr Expr))])
  (EErase     [(trait_name (slice u8)) (inner (ptr Expr))])
  (EMatch     [(scrut (ptr Expr)) (arms (ptr (ArrayList Arm)))])
  (EFnPtrOf   [(name (slice u8))])
  (ECallPtr   [(fp (ptr Expr)) (args (ptr (ArrayList Expr)))])
  (ELoop      [(label (Option (slice u8))) (body (ptr (ArrayList Expr)))])
  (EBreak     [(label (Option (slice u8))) (value (Option (ptr Expr)))])
  (EContinue  [(label (Option (slice u8)))])
  (ELlvmIr    [(result Type) (args (ptr (ArrayList Expr))) (body (slice u8))])
  (ETypeQuery [(q i64) (ty Type)])
  (EFieldMeta [(meta i64) (ty Type) (idx (ptr Expr))])
  (EFieldIndex[(ty Type) (name (ptr Expr))])
  (EQuote     [(form (ptr Sexp))])
  (ECodeOp    [(op i64) (args (ptr (ArrayList Expr)))])
  (EQuasi     [(q Quasi)])
  (EComptime  [(inner (ptr Expr))])
  ; ---- the 6 check-introduced variants (parser/resolver never emit these;
  ; the type-checker LOWERS calls/borrows/etc. into them). Mirror src/ast.rs.
  (ESpillRef  [(inner (ptr Expr))])
  (EConstruct [(sum (slice u8)) (variant (slice u8)) (args (ptr (ArrayList Expr)))])
  (ETraitCall [(trait_name (slice u8)) (method (slice u8)) (self_tp (slice u8)) (args (ptr (ArrayList Expr)))])
  (EDynDispatch [(dyn_struct (slice u8)) (vtable_struct (slice u8)) (method_index i64) (cc (slice u8)) (params (ptr (ArrayList Type))) (ret Type) (recv (ptr Expr)) (args (ptr (ArrayList Expr)))])
  (EMakeDyn   [(dyn_struct (slice u8)) (vtable_struct (slice u8)) (methods (ptr (ArrayList (slice u8)))) (inner (ptr Expr))])
  (EStaticRef [(name (slice u8))]))

(defstruct Expr [(kind ExprKind) (lo i64) (hi i64)])

; A let binding (name, mutable, value).
(defstruct Bind [(name (slice u8)) (mutable bool) (value Expr)])
; A match arm (variant, bound names, body).
(defstruct Arm [(variant (slice u8)) (binds (ptr (ArrayList (slice u8)))) (body Expr)])

; A quasiquote template node (src/ast.rs Quasi).
(defsum Quasi
  (QLit     [(form (ptr Sexp))])
  (QUnquote [(e (ptr Expr))])
  (QSplice  [(e (ptr Expr))])
  (QList    [(items (ptr (ArrayList Quasi)))])
  (QVector  [(items (ptr (ArrayList Quasi)))]))

; Calling-convention lowering (src/convention.rs).
(defsum Lowering
  (LNative [(cc i64)])   ; cc: 0=c 1=fast 2=cold
  (LShim   []))

(defstruct Convention
  [(name (slice u8))
   (params (ptr (ArrayList (slice u8))))
   (ret (Option (slice u8)))
   (clobber (ptr (ArrayList (slice u8))))
   (preserve (ptr (ArrayList (slice u8))))
   (lowering Lowering)])

; Struct memory layout (src/ast.rs Layout).
(defsum Layout
  (LC       [])
  (LPacked  [])
  (LAligned [(n i64)])
  (LExplicit[(offsets (ptr (ArrayList i64))) (size (Option i64)) (align i64)])
  (LBits    [(backing i64) (offsets (ptr (ArrayList i64)))]))

(defstruct StructDef
  [(name (slice u8))
   (type_params (ptr (ArrayList (slice u8))))
   (layout Layout)
   (fields (ptr (ArrayList Field)))])

(defstruct Variant [(name (slice u8)) (fields (ptr (ArrayList Field)))])
(defstruct SumDef
  [(name (slice u8))
   (type_params (ptr (ArrayList (slice u8))))
   (variants (ptr (ArrayList Variant)))])

(defstruct Extern
  [(name (slice u8)) (cc (slice u8)) (params (ptr (ArrayList Type)))
   (variadic bool) (ret Type)])

; A trait bound on a type parameter (name + required trait names).
(defstruct Bound [(name (slice u8)) (traits (ptr (ArrayList (slice u8))))])

(defstruct Func
  [(name (slice u8))
   (type_params (ptr (ArrayList (slice u8))))
   (bounds (ptr (ArrayList Bound)))
   (cc (slice u8))
   (params (ptr (ArrayList Param)))
   (ret Type)
   (body (ptr (ArrayList Expr)))
   (macro_variadic bool)
   (lo i64) (hi i64)])

(defstruct StaticAssert [(cnd Expr) (msg (slice u8))])
(defstruct Const [(name (slice u8)) (ty (Option Type)) (value Expr)])

(defstruct TraitMethod [(name (slice u8)) (params (ptr (ArrayList Param))) (ret Type)])
(defstruct TraitDef
  [(name (slice u8)) (self_param (slice u8)) (methods (ptr (ArrayList TraitMethod)))])
(defstruct ImplDef
  [(trait_name (slice u8)) (for_type (slice u8)) (methods (ptr (ArrayList Func)))])

(defstruct ExportC
  [(name (slice u8)) (symbol (Option (slice u8))) (params (ptr (ArrayList Type)))
   (lo i64) (hi i64)])

; The whole program (src/ast.rs Program). `statics` is omitted: parsing never
; produces statics (they come from checking), so the dump always emits an empty
; `(statics)` section.
(defstruct Program
  [(conventions (ptr (ArrayList Convention)))
   (structs (ptr (ArrayList StructDef)))
   (sums (ptr (ArrayList SumDef)))
   (externs (ptr (ArrayList Extern)))
   (funcs (ptr (ArrayList Func)))
   (asserts (ptr (ArrayList StaticAssert)))
   (consts (ptr (ArrayList Const)))
   (traits (ptr (ArrayList TraitDef)))
   (impls (ptr (ArrayList ImplDef)))
   (metas (ptr (ArrayList Expr)))
   (exports (ptr (ArrayList ExportC)))])

; A parse/read diagnostic (src/span.rs Diag); dummy span = -1.
(defstruct Diag [(lo i64) (hi i64) (msg (slice u8)) (source i64) (ctxt i64)])

; ============================ small constructors =============================
(defn mk-sexp [(kind SexpKind) (lo i64) (hi i64)] (-> Sexp)
  (let [p (alloc-stack Sexp)]
    (store! (field p kind) kind) (store! (field p lo) lo) (store! (field p hi) hi)
    (store! (field p source) (if (icmp-lt lo 0) -1 0)) (store! (field p ctxt) 0)
    (load p)))
(defn mk-tok [(kind TokKind) (lo i64) (hi i64)] (-> Tok)
  (let [p (alloc-stack Tok)]
    (store! (field p kind) kind) (store! (field p lo) lo) (store! (field p hi) hi)
    (load p)))
(defn mk-diag [(lo i64) (hi i64) (msg (slice u8))] (-> Diag)
  (let [p (alloc-stack Diag)]
    (store! (field p lo) lo) (store! (field p hi) hi) (store! (field p msg) msg)
    (store! (field p source) (if (icmp-lt lo 0) -1 0)) (store! (field p ctxt) 0)
    (load p)))
(defn mk-strread [(s (slice u8)) (end i64)] (-> StrRead)
  (let [p (alloc-stack StrRead)]
    (store! (field p s) s) (store! (field p end) end)
    (load p)))

; Rebuild a Sexp of the given kind carrying the FULL span (source+lo+hi+ctxt) of an
; existing node — mirrors Rust `Sexp::new(kind, s.span)`. Used by expand-calls when it
; reconstructs a List/Vector so a source-N / macro-stamped-ctxt wrapper keeps its span
; (mk-sexp would reset source to 0 / ctxt to 0 from lo alone).
(defn mk-sexp-like [(kind SexpKind) (s (ptr Sexp))] (-> Sexp)
  (let [p (alloc-stack Sexp)]
    (store! (field p kind) kind)
    (store! (field p lo) (load (field s lo))) (store! (field p hi) (load (field s hi)))
    (store! (field p source) (load (field s source))) (store! (field p ctxt) (load (field s ctxt)))
    (load p)))

(defn box-items [(a (ptr Allocator)) (items (ArrayList Sexp))] (-> (ptr (ArrayList Sexp)))
  (let [p (unwrap-ptr [(ArrayList Sexp)] (create [(ArrayList Sexp)] a))]
    (store! p items) p))
(defn box-sexp [(a (ptr Allocator)) (s Sexp)] (-> (ptr Sexp))
  (let [p (unwrap-ptr [Sexp] (create [Sexp] a))] (store! p s) p))
(defn box-expr [(a (ptr Allocator)) (e Expr)] (-> (ptr Expr))
  (let [p (unwrap-ptr [Expr] (create [Expr] a))] (store! p e) p))
(defn box-type [(a (ptr Allocator)) (t Type)] (-> (ptr Type))
  (let [p (unwrap-ptr [Type] (create [Type] a))] (store! p t) p))

(defn mk-expr [(kind ExprKind) (lo i64) (hi i64)] (-> Expr)
  (let [p (alloc-stack Expr)]
    (store! (field p kind) kind) (store! (field p lo) lo) (store! (field p hi) hi)
    (load p)))

; ============================ numeric/string utils ===========================
(defn f64-bits [(x f64)] (-> i64)
  (let [p (alloc-stack f64)] (store! p x) (load (cast (ptr i64) p))))

(defn slice->cstr [(a (ptr Allocator)) (s (slice u8))] (-> (ptr i8))
  (let [n (slice-len s)
        buf (unwrap-ptr [i8] (raw-alloc a (iadd n 1) 1))
        (mut i) 0]
    (loop
      (if (icmp-ge (load i) n) (break)
        (do (store! (index buf (load i)) (cast i8 (slice-get s (load i))))
            (store! i (iadd (load i) 1)))))
    (store! (index buf n) (cast i8 0))
    buf))

; ============================ output primitives ==============================
(defn wb [(w (ptr Writer)) (b i64)] (-> i64) (write-byte w (cast u8 b)) 0)
(defn ps [(w (ptr Writer)) (s (slice u8))] (-> i64) (print-str w s) 0)
(defn hexd [(d i64)] (-> i64) (if (icmp-lt d 10) (iadd d 48) (iadd d 87)))

(defn dump-dec-mag [(w (ptr Writer)) (n i64)] (-> i64)
  (if (icmp-lt n 10)
      (wb w (iadd n 48))
      (do (dump-dec-mag w (udiv n 10)) (wb w (iadd (urem n 10) 48)))))
(defn dump-dec [(w (ptr Writer)) (n i64)] (-> i64)
  (if (icmp-lt n 0)
      (do (wb w 45) (dump-dec-mag w (isub 0 n)))
      (dump-dec-mag w n)))

(defn u-hex16 [(w (ptr Writer)) (n i64)] (-> i64)
  (let [(mut k) 60]
    (loop
      (if (icmp-lt (load k) 0) (break)
        (do (wb w (hexd (iand (ishr n (load k)) 15))) (store! k (isub (load k) 4))))))
  0)

; A span `@lo:hi`, dummy (lo/hi = -1) prints as `@D:…`/`…:D` (mirrors dump_span).
; Emit one span field: 'D' for a dummy value (< 0 = u32::MAX in Rust) else decimal.
(defn dump-span-field [(w (ptr Writer)) (v i64)] (-> i64)
  (if (icmp-lt v 0) (wb w 68) (dump-dec w v)))
(defn dump-span4 [(w (ptr Writer)) (source i64) (lo i64) (hi i64) (ctxt i64)] (-> i64)
  (wb w 64)                                        ; '@'
  (dump-span-field w source) (wb w 58)             ; source ':'
  (dump-span-field w lo)     (wb w 58)             ; lo ':'
  (dump-span-field w hi)     (wb w 58)             ; hi ':'
  (dump-span-field w ctxt))                        ; ctxt
; Compat wrapper for the Expr dumper (d-expr): Exprs carry only lo/hi, so the
; source mirrors lo's dummy-ness and ctxt is 0 (d-expr is NOT on the expand path).
(defn dump-span [(w (ptr Writer)) (lo i64) (hi i64)] (-> i64)
  (dump-span4 w (if (icmp-lt lo 0) -1 0) lo hi 0))

(defn hex2 [(w (ptr Writer)) (b i64)] (-> i64)
  (wb w (hexd (iand (ishr b 4) 15))) (wb w (hexd (iand b 15))))
(defn esc-write [(w (ptr Writer)) (s (slice u8))] (-> i64)
  (let [(mut i) 0 n (slice-len s)]
    (loop
      (if (icmp-ge (load i) n) (break)
        (do (let [b (cast i64 (slice-get s (load i)))]
              (if (icmp-eq b 92) (ps w "\\\\")
              (if (icmp-eq b 34) (ps w "\\\"")
              (if (icmp-eq b 10) (ps w "\\n")
              (if (icmp-eq b 9)  (ps w "\\t")
              (if (icmp-eq b 13) (ps w "\\r")
              (if (and (icmp-ge b 32) (icmp-le b 126)) (wb w b)
              (do (ps w "\\x") (hex2 w b)))))))))
            (store! i (iadd (load i) 1))))))
  0)
; A quoted string `"<escaped>"`.
(defn dstr [(w (ptr Writer)) (s (slice u8))] (-> i64)
  (wb w 34) (esc-write w s) (wb w 34))
; A bool as '1'/'0'.
(defn dbool [(w (ptr Writer)) (b bool)] (-> i64) (if b (wb w 49) (wb w 48)))

; ============================ Sexp canonical dump (for quote) =================
; Mirrors src/reader.rs dump_node (reused by EQuote / QLit). Identical to
; selfhost/reader.coil's dumper.
(defn sx-atom [(w (ptr Writer)) (tag (slice u8)) (s (slice u8)) (source i64) (lo i64) (hi i64) (ctxt i64)] (-> i64)
  (wb w 40) (ps w tag) (dump-span4 w source lo hi ctxt) (ps w " \"") (esc-write w s) (ps w "\")"))
(defn sx-seq [(w (ptr Writer)) (tag (slice u8)) (items (ptr (ArrayList Sexp))) (source i64) (lo i64) (hi i64) (ctxt i64)] (-> i64)
  (wb w 40) (ps w tag) (dump-span4 w source lo hi ctxt)
  (let [(mut i) 0 n (al-len [Sexp] (load items))]
    (loop
      (if (icmp-ge (load i) n) (break)
        (do (wb w 32)
            (let [child (alloc-stack Sexp)]
              (store! child (al-get [Sexp] (load items) (load i)))
              (sx-node w child))
            (store! i (iadd (load i) 1))))))
  (wb w 41))
(defn sx-node [(w (ptr Writer)) (x (ptr Sexp))] (-> i64)
  (let [lo (load (field x lo)) hi (load (field x hi))
        src (load (field x source)) ctxt (load (field x ctxt))]
    (match (load (field x kind))
      (KInt   [v]     (do (ps w "(int") (dump-span4 w src lo hi ctxt) (wb w 32) (dump-dec w v) (wb w 41)))
      (KFloat [bits]  (do (ps w "(float") (dump-span4 w src lo hi ctxt) (ps w " 0x") (u-hex16 w bits) (wb w 41)))
      (KSym   [s]     (sx-atom w "sym" s src lo hi ctxt))
      (KKw    [s]     (sx-atom w "kw" s src lo hi ctxt))
      (KStr   [s]     (sx-atom w "str" s src lo hi ctxt))
      (KCStr  [s]     (sx-atom w "cstr" s src lo hi ctxt))
      (KList  [items] (sx-seq w "list" items src lo hi ctxt))
      (KVec   [items] (sx-seq w "vec" items src lo hi ctxt)))))

; ============================ AST canonical dump =============================
; Mirrors src/dump_ast.rs EXACTLY. Every helper corresponds to a Rust dumper.

; `["a" "b"]` — a vector of strings.
(defn d-strs [(w (ptr Writer)) (v (ptr (ArrayList (slice u8))))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [(slice u8)] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (dstr w (al-get [(slice u8)] (load v) (load i)))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

; `(some "x")` / `(none)` — an optional string.
(defn d-opt-str [(w (ptr Writer)) (v (Option (slice u8)))] (-> i64)
  (match v
    (Some [s] (do (ps w "(some ") (dstr w s) (wb w 41)))
    (None []  (ps w "(none)"))))

; ---- types ----
(defn d-types [(w (ptr Writer)) (v (ptr (ArrayList Type)))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Type] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [t (alloc-stack Type)] (store! t (al-get [Type] (load v) (load i))) (d-type w t))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

(defn d-type [(w (ptr Writer)) (t (ptr Type))] (-> i64)
  (match (load t)
    (TInt   [bits signed] (do (ps w "(int ") (dump-dec w bits) (wb w 32) (dbool w signed) (wb w 41)))
    (TFloat [bits]        (do (ps w "(float ") (dump-dec w bits) (wb w 41)))
    (TBool  []            (ps w "bool"))
    (TVoid  []            (ps w "void"))
    (TPtr   [inner]       (do (ps w "(ptr ") (d-type w inner) (wb w 41)))
    (TRef   [m inner]     (do (ps w "(ref ") (dbool w m) (wb w 32) (d-type w inner) (wb w 41)))
    (TStruct[name]        (do (ps w "(struct ") (dstr w name) (wb w 41)))
    (TArray [elem n]      (do (ps w "(array ") (d-type w elem) (wb w 32) (dump-dec w n) (wb w 41)))
    (TSlice [elem]        (do (ps w "(slice ") (d-type w elem) (wb w 41)))
    (TVec   [elem n]      (do (ps w "(vec ") (d-type w elem) (wb w 32) (dump-dec w n) (wb w 41)))
    (TFn    [cc params ret] (do (ps w "(fn ") (dstr w cc) (wb w 32) (d-types w params) (wb w 32) (d-type w ret) (wb w 41)))
    (TApp   [name args]   (do (ps w "(app ") (dstr w name) (wb w 32) (d-types w args) (wb w 41)))
    (TNever []            (ps w "never"))
    (TCode  []            (ps w "code"))))

; ---- enum-tag dumpers (i64 code -> string, mirrors *_tag in dump_ast.rs) ----
(defn d-binop [(w (ptr Writer)) (op i64)] (-> i64)
  (ps w (if (icmp-eq op 0) "add" (if (icmp-eq op 1) "sub" (if (icmp-eq op 2) "mul"
        (if (icmp-eq op 3) "div" (if (icmp-eq op 4) "rem" (if (icmp-eq op 5) "udiv"
        (if (icmp-eq op 6) "urem" (if (icmp-eq op 7) "and" (if (icmp-eq op 8) "or"
        (if (icmp-eq op 9) "xor" (if (icmp-eq op 10) "shl" "shr")))))))))))))
(defn d-cmpop [(w (ptr Writer)) (op i64)] (-> i64)
  (ps w (if (icmp-eq op 0) "lt" (if (icmp-eq op 1) "le" (if (icmp-eq op 2) "gt"
        (if (icmp-eq op 3) "ge" (if (icmp-eq op 4) "eq" "ne")))))))
(defn d-storage [(w (ptr Writer)) (s i64)] (-> i64)
  (ps w (if (icmp-eq s 0) "stack" (if (icmp-eq s 1) "static" "heap"))))
(defn d-typequery [(w (ptr Writer)) (q i64)] (-> i64)
  (ps w (if (icmp-eq q 0) "fieldcount" (if (icmp-eq q 1) "variantcount"
        (if (icmp-eq q 2) "isstruct" (if (icmp-eq q 3) "issum" (if (icmp-eq q 4) "isint"
        (if (icmp-eq q 5) "isfloat" (if (icmp-eq q 6) "isptr" "isarray")))))))))
(defn d-fieldmeta [(w (ptr Writer)) (m i64)] (-> i64)
  (ps w (if (icmp-eq m 0) "name" (if (icmp-eq m 1) "typekind" "typename"))))
(defn d-codeop [(w (ptr Writer)) (op i64)] (-> i64)
  (ps w (if (icmp-eq op 0) "islist" (if (icmp-eq op 1) "issym" (if (icmp-eq op 2) "isint"
        (if (icmp-eq op 3) "count" (if (icmp-eq op 4) "nth" (if (icmp-eq op 5) "sym"
        (if (icmp-eq op 6) "int" (if (icmp-eq op 7) "rest" (if (icmp-eq op 8) "gensym"
        (if (icmp-eq op 9) "error" (if (icmp-eq op 10) "eq" (if (icmp-eq op 11) "iskeyword"
        (if (icmp-eq op 12) "symbol" (if (icmp-eq op 13) "str" (if (icmp-eq op 14) "cfieldcount"
        (if (icmp-eq op 15) "cfieldname" (if (icmp-eq op 16) "cfieldkind" (if (icmp-eq op 17) "cfieldtype"
        (if (icmp-eq op 18) "cvariantsum" (if (icmp-eq op 19) "cvariantcount" (if (icmp-eq op 20) "cvariantname"
        (if (icmp-eq op 21) "cvariantfields" (if (icmp-eq op 22) "ctraitmethodcount" (if (icmp-eq op 23) "ctraitmethodname"
        (if (icmp-eq op 24) "ctraitarity" (if (icmp-eq op 25) "ctraitparamname" (if (icmp-eq op 26) "ctraitparamtype"
        (if (icmp-eq op 27) "ctraitrettype" (if (icmp-eq op 28) "strbytes" (if (icmp-eq op 29) "bytestostr"
        "targetarch"))))))))))))))))))))))))))))))))

; ---- exprs ----
(defn d-exprs [(w (ptr Writer)) (v (ptr (ArrayList Expr)))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Expr] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [e (alloc-stack Expr)] (store! e (al-get [Expr] (load v) (load i))) (d-expr w e))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

(defn d-opt-expr [(w (ptr Writer)) (v (Option (ptr Expr)))] (-> i64)
  (match v
    (Some [e] (do (ps w "(some ") (d-expr w e) (wb w 41)))
    (None []  (ps w "(none)"))))

(defn d-binds [(w (ptr Writer)) (v (ptr (ArrayList Bind)))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Bind] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [b (alloc-stack Bind)]
            (store! b (al-get [Bind] (load v) (load i)))
            (ps w "(bind ") (dstr w (load (field b name))) (wb w 32)
            (dbool w (load (field b mutable))) (wb w 32)
            (let [ve (alloc-stack Expr)] (store! ve (load (field b value))) (d-expr w ve))
            (wb w 41))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

(defn d-arms [(w (ptr Writer)) (v (ptr (ArrayList Arm)))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Arm] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [a (alloc-stack Arm)]
            (store! a (al-get [Arm] (load v) (load i)))
            (ps w "(arm ") (dstr w (load (field a variant))) (wb w 32)
            (d-strs w (load (field a binds))) (wb w 32)
            (let [be (alloc-stack Expr)] (store! be (load (field a body))) (d-expr w be))
            (wb w 41))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

(defn d-quasi [(w (ptr Writer)) (q (ptr Quasi))] (-> i64)
  (match (load q)
    (QLit     [form] (do (ps w "(qlit ") (sx-node w form) (wb w 41)))
    (QUnquote [e]    (do (ps w "(qunq ") (d-expr w e) (wb w 41)))
    (QSplice  [e]    (do (ps w "(qspl ") (d-expr w e) (wb w 41)))
    (QList    [items] (do (ps w "(qlist")
                          (let [(mut i) 0 n (al-len [Quasi] (load items))]
                            (loop (if (icmp-ge (load i) n) (break)
                              (do (wb w 32)
                                  (let [c (alloc-stack Quasi)] (store! c (al-get [Quasi] (load items) (load i))) (d-quasi w c))
                                  (store! i (iadd (load i) 1))))))
                          (wb w 41)))
    (QVector  [items] (do (ps w "(qvec")
                          (let [(mut i) 0 n (al-len [Quasi] (load items))]
                            (loop (if (icmp-ge (load i) n) (break)
                              (do (wb w 32)
                                  (let [c (alloc-stack Quasi)] (store! c (al-get [Quasi] (load items) (load i))) (d-quasi w c))
                                  (store! i (iadd (load i) 1))))))
                          (wb w 41)))))

(defn d-expr [(w (ptr Writer)) (e (ptr Expr))] (-> i64)
  (let [lo (load (field e lo)) hi (load (field e hi))]
    (wb w 40)
    (match (load (field e kind))
      (EInt   [v]    (do (ps w "eint") (dump-span w lo hi) (wb w 32) (dump-dec w v)))
      (EFloat [bits] (do (ps w "efloat") (dump-span w lo hi) (ps w " 0x") (u-hex16 w bits)))
      (EBool  [b]    (do (ps w "ebool") (dump-span w lo hi) (wb w 32) (dbool w b)))
      (EStr   [s]    (do (ps w "estr") (dump-span w lo hi) (wb w 32) (dstr w s)))
      (ECStr  [s]    (do (ps w "ecstr") (dump-span w lo hi) (wb w 32) (dstr w s)))
      (EVar   [name] (do (ps w "var") (dump-span w lo hi) (wb w 32) (dstr w name)))
      (EZeroed[ty]   (do (ps w "zeroed") (dump-span w lo hi) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t))))
      (EBorrow[m place] (do (ps w "borrow") (dump-span w lo hi) (wb w 32) (dbool w m) (wb w 32) (d-expr w place)))
      (ELet   [binds body] (do (ps w "let") (dump-span w lo hi) (wb w 32) (d-binds w binds) (wb w 32) (d-exprs w body)))
      (EBin   [op lhs rhs] (do (ps w "bin") (dump-span w lo hi) (wb w 32) (d-binop w op) (wb w 32) (d-expr w lhs) (wb w 32) (d-expr w rhs)))
      (ENot   [inner] (do (ps w "inot") (dump-span w lo hi) (wb w 32) (d-expr w inner)))
      (ECmp   [op lhs rhs] (do (ps w "cmp") (dump-span w lo hi) (wb w 32) (d-cmpop w op) (wb w 32) (d-expr w lhs) (wb w 32) (d-expr w rhs)))
      (EIf    [cnd thn els] (do (ps w "if") (dump-span w lo hi) (wb w 32) (d-expr w cnd) (wb w 32) (d-expr w thn) (wb w 32) (d-expr w els)))
      (EDo    [body] (do (ps w "do") (dump-span w lo hi) (wb w 32) (d-exprs w body)))
      (ECall  [func type_args args] (do (ps w "call") (dump-span w lo hi) (wb w 32) (dstr w func) (wb w 32) (d-types w type_args) (wb w 32) (d-exprs w args)))
      (EAlloc [storage ty] (do (ps w "alloc") (dump-span w lo hi) (wb w 32) (d-storage w storage) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t))))
      (EField [p fname] (do (ps w "field") (dump-span w lo hi) (wb w 32) (d-expr w p) (wb w 32) (dstr w fname)))
      (ELoad  [inner] (do (ps w "load") (dump-span w lo hi) (wb w 32) (d-expr w inner)))
      (EStore [p val] (do (ps w "store") (dump-span w lo hi) (wb w 32) (d-expr w p) (wb w 32) (d-expr w val)))
      (EIndex [p idx] (do (ps w "index") (dump-span w lo hi) (wb w 32) (d-expr w p) (wb w 32) (d-expr w idx)))
      (ECast  [ty inner] (do (ps w "cast") (dump-span w lo hi) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t)) (wb w 32) (d-expr w inner)))
      (ESizeOf[ty] (do (ps w "sizeof") (dump-span w lo hi) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t))))
      (EAlignOf[ty] (do (ps w "alignof") (dump-span w lo hi) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t))))
      (EOffsetOf[ty fname] (do (ps w "offsetof") (dump-span w lo hi) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t)) (wb w 32) (dstr w fname)))
      (EBitGet[p fname] (do (ps w "bitget") (dump-span w lo hi) (wb w 32) (d-expr w p) (wb w 32) (dstr w fname)))
      (EBitSet[p fname val] (do (ps w "bitset") (dump-span w lo hi) (wb w 32) (d-expr w p) (wb w 32) (dstr w fname) (wb w 32) (d-expr w val)))
      (EFree  [inner] (do (ps w "free") (dump-span w lo hi) (wb w 32) (d-expr w inner)))
      (EErase [trait_name inner] (do (ps w "erase") (dump-span w lo hi) (wb w 32) (dstr w trait_name) (wb w 32) (d-expr w inner)))
      (EMatch [scrut arms] (do (ps w "match") (dump-span w lo hi) (wb w 32) (d-expr w scrut) (wb w 32) (d-arms w arms)))
      (EFnPtrOf[name] (do (ps w "fnptrof") (dump-span w lo hi) (wb w 32) (dstr w name)))
      (ECallPtr[fp args] (do (ps w "callptr") (dump-span w lo hi) (wb w 32) (d-expr w fp) (wb w 32) (d-exprs w args)))
      (ELoop  [label body] (do (ps w "loop") (dump-span w lo hi) (wb w 32) (d-opt-str w label) (wb w 32) (d-exprs w body)))
      (EBreak [label value] (do (ps w "break") (dump-span w lo hi) (wb w 32) (d-opt-str w label) (wb w 32) (d-opt-expr w value)))
      (EContinue[label] (do (ps w "continue") (dump-span w lo hi) (wb w 32) (d-opt-str w label)))
      (ELlvmIr[result args body] (do (ps w "llvmir") (dump-span w lo hi) (wb w 32) (let [t (alloc-stack Type)] (store! t result) (d-type w t)) (wb w 32) (d-exprs w args) (wb w 32) (dstr w body)))
      (ETypeQuery[q ty] (do (ps w "typequery") (dump-span w lo hi) (wb w 32) (d-typequery w q) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t))))
      (EFieldMeta[meta ty idx] (do (ps w "fieldmeta") (dump-span w lo hi) (wb w 32) (d-fieldmeta w meta) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t)) (wb w 32) (d-expr w idx)))
      (EFieldIndex[ty name] (do (ps w "fieldindex") (dump-span w lo hi) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t)) (wb w 32) (d-expr w name)))
      (EQuote [form] (do (ps w "quote") (dump-span w lo hi) (wb w 32) (sx-node w form)))
      (ECodeOp[op args] (do (ps w "codeop") (dump-span w lo hi) (wb w 32) (d-codeop w op) (wb w 32) (d-exprs w args)))
      (EQuasi [q] (do (ps w "quasi") (dump-span w lo hi) (wb w 32) (let [qp (alloc-stack Quasi)] (store! qp q) (d-quasi w qp))))
      (EComptime[inner] (do (ps w "comptime") (dump-span w lo hi) (wb w 32) (d-expr w inner)))
      ; ---- the 6 check-introduced variants (mirror src/dump_ast.rs) ----
      (ESpillRef[inner] (do (ps w "spillref") (dump-span w lo hi) (wb w 32) (d-expr w inner)))
      (EConstruct[sum variant args] (do (ps w "construct") (dump-span w lo hi) (wb w 32) (dstr w sum) (wb w 32) (dstr w variant) (wb w 32) (d-exprs w args)))
      (ETraitCall[trait_name method self_tp args] (do (ps w "traitcall") (dump-span w lo hi) (wb w 32) (dstr w trait_name) (wb w 32) (dstr w method) (wb w 32) (dstr w self_tp) (wb w 32) (d-exprs w args)))
      (EDynDispatch[dyn_struct vtable_struct method_index cc params ret recv args]
        (do (ps w "dyndispatch") (dump-span w lo hi) (wb w 32) (dstr w dyn_struct) (wb w 32) (dstr w vtable_struct) (wb w 32) (dump-dec w method_index) (wb w 32) (dstr w cc) (wb w 32) (d-types w params) (wb w 32) (let [t (alloc-stack Type)] (store! t ret) (d-type w t)) (wb w 32) (d-expr w recv) (wb w 32) (d-exprs w args)))
      (EMakeDyn[dyn_struct vtable_struct methods inner]
        (do (ps w "makedyn") (dump-span w lo hi) (wb w 32) (dstr w dyn_struct) (wb w 32) (dstr w vtable_struct) (wb w 32) (d-strs w methods) (wb w 32) (d-expr w inner)))
      (EStaticRef[name] (do (ps w "staticref") (dump-span w lo hi) (wb w 32) (dstr w name))))
    (wb w 41)))

; ---- declarations ----
(defn d-param [(w (ptr Writer)) (p (ptr Param))] (-> i64)
  (ps w "(param ") (dstr w (load (field p name))) (wb w 32)
  (let [t (alloc-stack Type)] (store! t (load (field p ty))) (d-type w t)) (wb w 41))
(defn d-params [(w (ptr Writer)) (v (ptr (ArrayList Param)))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Param] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [p (alloc-stack Param)] (store! p (al-get [Param] (load v) (load i))) (d-param w p))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

(defn d-field [(w (ptr Writer)) (f (ptr Field))] (-> i64)
  (ps w "(fld ") (dstr w (load (field f name))) (wb w 32)
  (let [t (alloc-stack Type)] (store! t (load (field f ty))) (d-type w t)) (wb w 41))
(defn d-fields [(w (ptr Writer)) (v (ptr (ArrayList Field)))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Field] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [f (alloc-stack Field)] (store! f (al-get [Field] (load v) (load i))) (d-field w f))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

(defn d-i64s [(w (ptr Writer)) (v (ptr (ArrayList i64)))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [i64] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (dump-dec w (al-get [i64] (load v) (load i)))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

(defn d-bounds [(w (ptr Writer)) (v (ptr (ArrayList Bound)))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Bound] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [b (alloc-stack Bound)]
            (store! b (al-get [Bound] (load v) (load i)))
            (ps w "(bound ") (dstr w (load (field b name))) (wb w 32)
            (d-strs w (load (field b traits))) (wb w 41))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

(defn d-func [(w (ptr Writer)) (f (ptr Func))] (-> i64)
  (ps w "(func ") (dstr w (load (field f name))) (wb w 32)
  (d-strs w (load (field f type_params))) (wb w 32)
  (d-bounds w (load (field f bounds))) (wb w 32)
  (dstr w (load (field f cc))) (wb w 32)
  (d-params w (load (field f params))) (wb w 32)
  (let [t (alloc-stack Type)] (store! t (load (field f ret))) (d-type w t)) (wb w 32)
  (d-exprs w (load (field f body))) (wb w 32)
  (dbool w (load (field f macro_variadic))) (wb w 32)
  (dump-span w (load (field f lo)) (load (field f hi))) (wb w 41))

(defn d-convention [(w (ptr Writer)) (c (ptr Convention))] (-> i64)
  (ps w "(cc ") (dstr w (load (field c name))) (wb w 32)
  (d-strs w (load (field c params))) (wb w 32)
  (d-opt-str w (load (field c ret))) (wb w 32)
  (d-strs w (load (field c clobber))) (wb w 32)
  (d-strs w (load (field c preserve))) (wb w 32)
  (match (load (field c lowering))
    (LNative [cc] (do (ps w "(native ") (ps w (if (icmp-eq cc 0) "c" (if (icmp-eq cc 1) "fast" "cold"))) (wb w 41)))
    (LShim   []   (ps w "(shim)")))
  (wb w 41))

(defn d-layout [(w (ptr Writer)) (l (ptr Layout))] (-> i64)
  (match (load l)
    (LC       []   (ps w "(c)"))
    (LPacked  []   (ps w "(packed)"))
    (LAligned [n]  (do (ps w "(aligned ") (dump-dec w n) (wb w 41)))
    (LExplicit[offsets size align]
      (do (ps w "(explicit ") (d-i64s w offsets) (wb w 32)
          (match size (Some [n] (do (ps w "(some ") (dump-dec w n) (wb w 41))) (None [] (ps w "(none)")))
          (wb w 32) (dump-dec w align) (wb w 41)))
    (LBits    [backing offsets]
      (do (ps w "(bits ") (dump-dec w backing) (wb w 32) (d-i64s w offsets) (wb w 41)))))

(defn d-struct [(w (ptr Writer)) (s (ptr StructDef))] (-> i64)
  (ps w "(struct ") (dstr w (load (field s name))) (wb w 32)
  (d-strs w (load (field s type_params))) (wb w 32)
  (let [lp (alloc-stack Layout)] (store! lp (load (field s layout))) (d-layout w lp)) (wb w 32)
  (d-fields w (load (field s fields))) (wb w 41))

(defn d-variant [(w (ptr Writer)) (vr (ptr Variant))] (-> i64)
  (ps w "(variant ") (dstr w (load (field vr name))) (wb w 32)
  (d-fields w (load (field vr fields))) (wb w 41))
(defn d-sum [(w (ptr Writer)) (s (ptr SumDef))] (-> i64)
  (ps w "(sum ") (dstr w (load (field s name))) (wb w 32)
  (d-strs w (load (field s type_params))) (wb w 32)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Variant] (load (field s variants)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [vr (alloc-stack Variant)] (store! vr (al-get [Variant] (load (field s variants)) (load i))) (d-variant w vr))
          (store! i (iadd (load i) 1))))))
  (wb w 93) (wb w 41))

(defn d-extern [(w (ptr Writer)) (e (ptr Extern))] (-> i64)
  (ps w "(extern ") (dstr w (load (field e name))) (wb w 32)
  (dstr w (load (field e cc))) (wb w 32)
  (d-types w (load (field e params))) (wb w 32)
  (dbool w (load (field e variadic))) (wb w 32)
  (let [t (alloc-stack Type)] (store! t (load (field e ret))) (d-type w t)) (wb w 41))

(defn d-assert [(w (ptr Writer)) (a (ptr StaticAssert))] (-> i64)
  (ps w "(assert ")
  (let [ce (alloc-stack Expr)] (store! ce (load (field a cnd))) (d-expr w ce)) (wb w 32)
  (dstr w (load (field a msg))) (wb w 41))

(defn d-const [(w (ptr Writer)) (c (ptr Const))] (-> i64)
  (ps w "(const ") (dstr w (load (field c name))) (wb w 32)
  (match (load (field c ty))
    (Some [t] (do (ps w "(some ") (let [tp (alloc-stack Type)] (store! tp t) (d-type w tp)) (wb w 41)))
    (None []  (ps w "(none)")))
  (wb w 32)
  (let [ve (alloc-stack Expr)] (store! ve (load (field c value))) (d-expr w ve)) (wb w 41))

(defn d-trait [(w (ptr Writer)) (t (ptr TraitDef))] (-> i64)
  (ps w "(trait ") (dstr w (load (field t name))) (wb w 32)
  (dstr w (load (field t self_param))) (wb w 32)
  (wb w 91)
  (let [(mut i) 0 n (al-len [TraitMethod] (load (field t methods)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [m (alloc-stack TraitMethod)]
            (store! m (al-get [TraitMethod] (load (field t methods)) (load i)))
            (ps w "(method ") (dstr w (load (field m name))) (wb w 32)
            (d-params w (load (field m params))) (wb w 32)
            (let [rt (alloc-stack Type)] (store! rt (load (field m ret))) (d-type w rt)) (wb w 41))
          (store! i (iadd (load i) 1))))))
  (wb w 93) (wb w 41))

(defn d-impl [(w (ptr Writer)) (im (ptr ImplDef))] (-> i64)
  (ps w "(impl ") (dstr w (load (field im trait_name))) (wb w 32)
  (dstr w (load (field im for_type))) (wb w 32)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Func] (load (field im methods)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [f (alloc-stack Func)] (store! f (al-get [Func] (load (field im methods)) (load i))) (d-func w f))
          (store! i (iadd (load i) 1))))))
  (wb w 93) (wb w 41))

(defn d-export [(w (ptr Writer)) (e (ptr ExportC))] (-> i64)
  (ps w "(export ") (dstr w (load (field e name))) (wb w 32)
  (d-opt-str w (load (field e symbol))) (wb w 32)
  (d-types w (load (field e params))) (wb w 32)
  (dump-span w (load (field e lo)) (load (field e hi))) (wb w 41))

; Byte-lexicographic `<` on strings (Rust String Ord over ASCII conv names):
; a proper prefix is less than the longer string.
(defn str-lt [(x (slice u8)) (y (slice u8))] (-> bool)
  (let [nx (slice-len x) ny (slice-len y) (mut i) 0 (mut res) 0]
    (loop (if (or (icmp-ge (load i) nx) (icmp-ge (load i) ny)) (break)
      (let [cx (cast i64 (slice-get x (load i))) cy (cast i64 (slice-get y (load i)))]
        (if (icmp-lt cx cy) (do (store! res 1) (break))
          (if (icmp-gt cx cy) (do (store! res 2) (break))
            (store! i (iadd (load i) 1)))))))
    (if (icmp-eq (load res) 1) true (if (icmp-eq (load res) 2) false (icmp-lt nx ny)))))
(defn conv-name [(c Convention)] (-> (slice u8))
  (let [p (alloc-stack Convention)] (store! p c) (load (field p name))))

; A whole-section dumper: `(<tag>` then a space+item per element, then `)`.
; Mirrors dump_program's per-section loops.
(defn d-program [(w (ptr Writer)) (p (ptr Program)) (a (ptr Allocator))] (-> i64)
  ; conventions — sorted by name (mirrors dump_program's keys().sort()).
  (ps w "(conventions")
  (let [convs (load (field p conventions)) n (al-len [Convention] convs) (mut used) (al-new [bool] a) (mut k) 0]
    (loop (if (icmp-ge (load k) n) (break) (do (al-push! (mut used) false) (store! k (iadd (load k) 1)))))
    (let [(mut c) 0]
      (loop (if (icmp-ge (load c) n) (break)
        (do (let [(mut best) -1 (mut bi) 0]
              (loop (if (icmp-ge (load bi) n) (break)
                (do (if (not (al-get [bool] (load used) (load bi)))
                        (if (or (icmp-lt (load best) 0)
                                (str-lt (conv-name (al-get [Convention] convs (load bi))) (conv-name (al-get [Convention] convs (load best)))))
                            (store! best (load bi)) 0) 0)
                    (store! bi (iadd (load bi) 1)))))
              (al-set! [bool] (mut used) (load best) true)
              (wb w 32)
              (let [cc (alloc-stack Convention)] (store! cc (al-get [Convention] convs (load best))) (d-convention w cc)))
            (store! c (iadd (load c) 1)))))))
  (wb w 41)
  (ps w "\n(structs")
  (let [(mut i) 0 n (al-len [StructDef] (load (field p structs)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [s (alloc-stack StructDef)] (store! s (al-get [StructDef] (load (field p structs)) (load i))) (d-struct w s))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(sums")
  (let [(mut i) 0 n (al-len [SumDef] (load (field p sums)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [s (alloc-stack SumDef)] (store! s (al-get [SumDef] (load (field p sums)) (load i))) (d-sum w s))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(externs")
  (let [(mut i) 0 n (al-len [Extern] (load (field p externs)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [e (alloc-stack Extern)] (store! e (al-get [Extern] (load (field p externs)) (load i))) (d-extern w e))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(funcs")
  (let [(mut i) 0 n (al-len [Func] (load (field p funcs)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [f (alloc-stack Func)] (store! f (al-get [Func] (load (field p funcs)) (load i))) (d-func w f))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(asserts")
  (let [(mut i) 0 n (al-len [StaticAssert] (load (field p asserts)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [a (alloc-stack StaticAssert)] (store! a (al-get [StaticAssert] (load (field p asserts)) (load i))) (d-assert w a))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(consts")
  (let [(mut i) 0 n (al-len [Const] (load (field p consts)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [c (alloc-stack Const)] (store! c (al-get [Const] (load (field p consts)) (load i))) (d-const w c))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(traits")
  (let [(mut i) 0 n (al-len [TraitDef] (load (field p traits)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [t (alloc-stack TraitDef)] (store! t (al-get [TraitDef] (load (field p traits)) (load i))) (d-trait w t))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(impls")
  (let [(mut i) 0 n (al-len [ImplDef] (load (field p impls)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [im (alloc-stack ImplDef)] (store! im (al-get [ImplDef] (load (field p impls)) (load i))) (d-impl w im))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(statics)")
  (ps w "\n(metas")
  (let [(mut i) 0 n (al-len [Expr] (load (field p metas)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [m (alloc-stack Expr)] (store! m (al-get [Expr] (load (field p metas)) (load i))) (d-expr w m))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(exports")
  (let [(mut i) 0 n (al-len [ExportC] (load (field p exports)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [e (alloc-stack ExportC)] (store! e (al-get [ExportC] (load (field p exports)) (load i))) (d-export w e))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  0)

; ============================ the PORT (implement these) =====================
; Each stub HARD-ABORTS (never a silent wrong value). Replace the body with a
; faithful port of the same-named function in src/parse.rs.
(defn unimplemented [(who (slice u8))] (-> i64)
  (let [w (stderr)] (ps w "UNIMPLEMENTED: ") (ps w who) (wb w 10))
  (abort) 0)

; ---- generic boxing + string helpers ----
(defn box-al [T] [(a (ptr Allocator)) (l (ArrayList T))] (-> (ptr (ArrayList T)))
  (let [p (unwrap-ptr [(ArrayList T)] (create [(ArrayList T)] a))] (store! p l) p))
(defn sconcat [(a (ptr Allocator)) (x (slice u8)) (y (slice u8))] (-> (slice u8))
  (match (str-concat a x y) (Some [v] v) (None [] "")))
(defn sconcat3 [(a (ptr Allocator)) (x (slice u8)) (y (slice u8)) (z (slice u8))] (-> (slice u8))
  (sconcat a (sconcat a x y) z))
(defn push-mag [(buf (mut (ArrayList u8))) (n i64)] (-> i64)
  (if (icmp-lt n 10) (al-push! (mut buf) (cast u8 (iadd n 48)))
      (do (push-mag (mut buf) (udiv n 10)) (al-push! (mut buf) (cast u8 (iadd (urem n 10) 48))))))
(defn i64->str [(a (ptr Allocator)) (n i64)] (-> (slice u8))
  (let [(mut buf) (al-new [u8] a)]
    (if (icmp-lt n 0) (do (al-push! (mut buf) (cast u8 45)) (push-mag (mut buf) (isub 0 n))) (push-mag (mut buf) n))
    (al-slice [u8] (load buf))))
(defn char1 [(a (ptr Allocator)) (c i64)] (-> (slice u8))
  (slice-new [u8] (let [cb (cast (ptr u8) (unwrap-ptr [i8] (raw-alloc a 1 1)))] (store! (index cb 0) (cast u8 c)) cb) 1))

; ---- Sexp inspection (one match -> a flat info struct) ----
(defstruct SxInfo [(tag i64) (ival i64) (sval (slice u8)) (items (ptr (ArrayList Sexp)))])
(defn sx-info [(s Sexp)] (-> SxInfo)
  (let [sp (alloc-stack Sexp) p (alloc-stack SxInfo)]
    (store! sp s)
    (store! (field p ival) 0) (store! (field p sval) "") (store! (field p items) (zeroed (ptr (ArrayList Sexp))))
    (match (load (field sp kind))
      (KInt   [v]  (do (store! (field p tag) 0) (store! (field p ival) v) 0))
      (KFloat [b]  (do (store! (field p tag) 1) (store! (field p ival) b) 0))
      (KSym   [x]  (do (store! (field p tag) 2) (store! (field p sval) x) 0))
      (KKw    [x]  (do (store! (field p tag) 3) (store! (field p sval) x) 0))
      (KStr   [x]  (do (store! (field p tag) 4) (store! (field p sval) x) 0))
      (KCStr  [x]  (do (store! (field p tag) 5) (store! (field p sval) x) 0))
      (KList  [it] (do (store! (field p tag) 6) (store! (field p items) it) 0))
      (KVec   [it] (do (store! (field p tag) 7) (store! (field p items) it) 0)))
    (load p)))
(defn sx-tag   [(s Sexp)] (-> i64) (let [p (alloc-stack SxInfo)] (store! p (sx-info s)) (load (field p tag))))
(defn sx-ival  [(s Sexp)] (-> i64) (let [p (alloc-stack SxInfo)] (store! p (sx-info s)) (load (field p ival))))
(defn sx-sval  [(s Sexp)] (-> (slice u8)) (let [p (alloc-stack SxInfo)] (store! p (sx-info s)) (load (field p sval))))
(defn sx-items [(s Sexp)] (-> (ptr (ArrayList Sexp))) (let [p (alloc-stack SxInfo)] (store! p (sx-info s)) (load (field p items))))
(defn sx-lo [(s Sexp)] (-> i64) (let [p (alloc-stack Sexp)] (store! p s) (load (field p lo))))
(defn sx-hi [(s Sexp)] (-> i64) (let [p (alloc-stack Sexp)] (store! p s) (load (field p hi))))
(defn sx-len [(l (ptr (ArrayList Sexp)))] (-> i64) (al-len [Sexp] (load l)))
(defn sx-at  [(l (ptr (ArrayList Sexp))) (i i64)] (-> Sexp) (al-get [Sexp] (load l) i))
(defn sx-get [(l (ptr (ArrayList Sexp))) (i i64)] (-> (Option Sexp))
  (if (or (icmp-lt i 0) (icmp-ge i (sx-len l))) (None [Sexp]) (Some (sx-at l i))))
(defn rest-from [(a (ptr Allocator)) (l (ptr (ArrayList Sexp))) (start i64)] (-> (ptr (ArrayList Sexp)))
  (let [(mut out) (al-new [Sexp] a) n (sx-len l) (mut i) start]
    (loop (if (icmp-ge (load i) n) (break) (do (al-push! (mut out) (sx-at l (load i))) (store! i (iadd (load i) 1)))))
    (box-al [Sexp] a (load out))))

; small Option<Sexp> predicates
(defn opt-is-vec [(o (Option Sexp))] (-> bool) (match o (Some [s] (icmp-eq (sx-tag s) 7)) (None [] false)))
(defn opt-get [(o (Option Sexp))] (-> Sexp) (match o (Some [s] s) (None [] (zeroed Sexp))))
(defn opt-is-kw [(o (Option Sexp)) (name (slice u8))] (-> bool) (match o (Some [s] (and (icmp-eq (sx-tag s) 3) (str-eq (sx-sval s) name))) (None [] false)))
(defn opt-is-pos-int [(o (Option Sexp))] (-> bool) (match o (Some [s] (and (icmp-eq (sx-tag s) 0) (icmp-gt (sx-ival s) 0))) (None [] false)))
(defn opt-int [(o (Option Sexp))] (-> i64) (match o (Some [s] (sx-ival s)) (None [] 0)))
(defn opt-is-str [(o (Option Sexp))] (-> bool) (match o (Some [s] (icmp-eq (sx-tag s) 4)) (None [] false)))
(defn opt-str-val [(o (Option Sexp))] (-> (slice u8)) (match o (Some [s] (sx-sval s)) (None [] "")))

; ---- Sexp Display (src/reader.rs Display), for error interpolation ----
(defn sexp-display [(a (ptr Allocator)) (s Sexp)] (-> (slice u8))
  (let [tg (sx-tag s)]
    (if (icmp-eq tg 0) (i64->str a (sx-ival s))
    (if (icmp-eq tg 2) (sx-sval s)
    (if (icmp-eq tg 3) (sconcat a ":" (sx-sval s))
    (if (icmp-eq tg 6) (seq-display a (sx-items s) 40 41)
    (if (icmp-eq tg 7) (seq-display a (sx-items s) 91 93)
      (do (unimplemented "sexp-display/float-str-cstr") ""))))))))
(defn seq-display [(a (ptr Allocator)) (items (ptr (ArrayList Sexp))) (open i64) (close i64)] (-> (slice u8))
  (let [(mut acc) (char1 a open) n (sx-len items) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (do (store! acc (sconcat a (load acc) " ")) 0) 0)
          (store! acc (sconcat a (load acc) (sexp-display a (sx-at items (load i)))))
          (store! i (iadd (load i) 1)))))
    (sconcat a (load acc) (char1 a close))))

; ---- diagnostics ----
(defn derr    [(msg (slice u8))] (-> Diag) (mk-diag -1 -1 msg))
(defn derr-at [(lo i64) (hi i64) (msg (slice u8))] (-> Diag) (mk-diag lo hi msg))
(defn dwspan  [(d Diag) (lo i64) (hi i64)] (-> Diag)
  (let [p (alloc-stack Diag)] (store! p d)
    (if (icmp-lt (load (field p lo)) 0) (do (store! (field p lo) lo) (store! (field p hi) hi)) 0)
    (load p)))

; ---- Option -> Result with a message (mirrors `.ok_or(msg)?`) ----
(defn need [T] [(o (Option T)) (msg (slice u8))] (-> (Result T Diag))
  (match o (Some [v] (Ok v)) (None [] (Err (derr msg)))))

; ---- matchers (src/parse.rs small helpers) ----
(defn as-list [(s Sexp) (msg (slice u8))] (-> (Result (ptr (ArrayList Sexp)) Diag))
  (if (icmp-eq (sx-tag s) 6) (Ok (sx-items s)) (Err (derr-at (sx-lo s) (sx-hi s) msg))))
(defn head-sym [(a (ptr Allocator)) (items (ptr (ArrayList Sexp)))] (-> (Result (slice u8) Diag))
  (if (icmp-eq (sx-len items) 0) (Err (derr "empty list"))
      (let [h (sx-at items 0)]
        (if (icmp-eq (sx-tag h) 2) (Ok (sx-sval h))
            (Err (derr-at (sx-lo h) (sx-hi h) (sconcat a "expected a symbol head, got " (sexp-display a h))))))))
(defn sym-of [(a (ptr Allocator)) (s Sexp) (what (slice u8))] (-> (Result (slice u8) Diag))
  (if (icmp-eq (sx-tag s) 2) (Ok (sx-sval s))
      (Err (derr-at (sx-lo s) (sx-hi s) (sconcat a what (sconcat a ": expected symbol, got " (sexp-display a s)))))))
(defn kw-of [(a (ptr Allocator)) (s Sexp) (what (slice u8))] (-> (Result (slice u8) Diag))
  (if (icmp-eq (sx-tag s) 3) (Ok (sx-sval s))
      (Err (derr-at (sx-lo s) (sx-hi s) (sconcat a what (sconcat a ": expected keyword, got " (sexp-display a s)))))))
(defn int-val [(a (ptr Allocator)) (s Sexp) (what (slice u8))] (-> (Result i64 Diag))
  (if (icmp-eq (sx-tag s) 0) (Ok (sx-ival s))
      (Err (derr-at (sx-lo s) (sx-hi s) (sconcat a what (sconcat a ": expected an integer, got " (sexp-display a s)))))))
(defn pow2 [(s (Option Sexp))] (-> (Result i64 Diag))
  (match s
    (Some [x] (if (and (icmp-eq (sx-tag x) 0) (let [n (sx-ival x)] (and (icmp-gt n 0) (icmp-eq (iand n (isub n 1)) 0)))) (Ok (sx-ival x)) (Err (derr "alignment must be a positive power of two"))))
    (None [] (Err (derr "alignment must be a positive power of two")))))
(defn sym-vec [(a (ptr Allocator)) (s Sexp) (what (slice u8))] (-> (Result (ptr (ArrayList (slice u8))) Diag))
  (if (icmp-eq (sx-tag s) 7)
      (try (let [items (sx-items s) (mut out) (al-new [(slice u8)] a) n (sx-len items) (mut i) 0]
        (loop (if (icmp-ge (load i) n) (break) (do (al-push! (mut out) (try! (sym-of a (sx-at items (load i)) what))) (store! i (iadd (load i) 1)))))
        (Ok (box-al [(slice u8)] a (load out)))))
      (Err [(ptr (ArrayList (slice u8))) Diag] (derr-at (sx-lo s) (sx-hi s) (sconcat a what (sconcat a ": expected vector, got " (sexp-display a s)))))))
(defn need-vec [(o (Option Sexp)) (msg (slice u8))] (-> (Result (ptr (ArrayList Sexp)) Diag))
  (match o (Some [s] (if (icmp-eq (sx-tag s) 7) (Ok (sx-items s)) (Err (derr msg)))) (None [] (Err (derr msg)))))
(defstruct Two [(x Sexp) (y Sexp)])
(defn need-two [(a (ptr Allocator)) (args (ptr (ArrayList Sexp))) (head (slice u8))] (-> (Result Two Diag))
  (if (icmp-ne (sx-len args) 2) (Err (derr (sconcat a head ": expects exactly 2 arguments")))
      (Ok (let [p (alloc-stack Two)] (store! (field p x) (sx-at args 0)) (store! (field p y) (sx-at args 1)) (load p)))))

; ---- types (src/parse.rs prim_type / int_type / parse_type) ----
(defn type-int-bits [(t Type)] (-> i64)
  (match t (TInt [b s] b) (TFloat [_] -1) (TBool [] -1) (TVoid [] -1) (TPtr [_] -1) (TRef [_ _] -1)
    (TStruct [_] -1) (TArray [_ _] -1) (TSlice [_] -1) (TVec [_ _] -1) (TFn [_ _ _] -1) (TApp [_ _] -1) (TNever [] -1) (TCode [] -1)))
(defn not-int-diag [(a (ptr Allocator)) (name (slice u8))] (-> Diag) (derr (sconcat3 a "not an int type '" name "'")))
(defn int-type [(a (ptr Allocator)) (name (slice u8))] (-> (Result Type Diag))
  (let [n (slice-len name)]
    (if (icmp-eq n 0) (Err (not-int-diag a name))
      (let [c0 (cast i64 (slice-get name 0)) signed (if (icmp-eq c0 105) 1 (if (icmp-eq c0 117) 0 -1))]
        (if (icmp-lt signed 0) (Err (not-int-diag a name))
          (if (icmp-eq n 1) (Err (not-int-diag a name))
            (let [(mut bits) 0 (mut bad) false (mut over) false (mut i) 1]
              (loop (if (icmp-ge (load i) n) (break)
                (let [c (cast i64 (slice-get name (load i)))]
                  (if (and (icmp-ge c 48) (icmp-le c 57))
                      (do (store! bits (iadd (imul (load bits) 10) (isub c 48)))
                          (if (icmp-gt (load bits) 4294967295) (do (store! over true) 0) 0)
                          (store! i (iadd (load i) 1)))
                      (do (store! bad true) (break))))))
              (if (load bad) (Err (not-int-diag a name))
                (if (load over) (Err (derr (sconcat3 a "int width too large in '" name "'")))
                  (if (or (icmp-eq (load bits) 0) (icmp-gt (load bits) 65535))
                      (Err (derr (sconcat3 a "int width out of range in '" name "' (1..=65535)")))
                      (Ok (TInt (load bits) (icmp-eq signed 1)))))))))))))
(defn prim-type [(a (ptr Allocator)) (name (slice u8))] (-> (Result Type Diag))
  (if (str-eq name "f32") (Ok (TFloat 32))
  (if (str-eq name "f64") (Ok (TFloat 64))
  (if (str-eq name "bool") (Ok (TBool))
  (if (str-eq name "void") (Ok (TVoid))
    (int-type a name))))))
(defn parse-types [(a (ptr Allocator)) (items (ptr (ArrayList Sexp)))] (-> (Result (ptr (ArrayList Type)) Diag))
  (try (let [(mut out) (al-new [Type] a) n (sx-len items) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break) (do (al-push! (mut out) (try! (parse-type a (sx-at items (load i))))) (store! i (iadd (load i) 1)))))
    (Ok (box-al [Type] a (load out))))))
(defn parse-type [(a (ptr Allocator)) (s Sexp)] (-> (Result Type Diag))
  (match (parse-type-inner a s)
    (Err [d] (Err (dwspan d (sx-lo s) (sx-hi s))))
    (Ok [t] (Ok t))))
(defn parse-type-inner [(a (ptr Allocator)) (s Sexp)] (-> (Result Type Diag))
  (let [tg (sx-tag s) slo (sx-lo s) shi (sx-hi s)]
    (if (icmp-eq tg 3) (prim-type a (sx-sval s))
    (if (icmp-eq tg 2) (let [k (sx-sval s)] (if (str-eq k "Code") (Ok (TCode)) (match (prim-type a k) (Ok [t] (Ok t)) (Err [_] (Ok (TStruct k))))))
    (if (icmp-eq tg 6) (parse-type-list a (sx-items s))
      (Err (derr-at slo shi (sconcat a "unsupported type: " (sexp-display a s)))))))))
(defn parse-type-list [(a (ptr Allocator)) (items (ptr (ArrayList Sexp)))] (-> (Result Type Diag))
  (try (let [head (try! (head-sym a items))]
    (if (str-eq head "mut")
        (Ok (TRef true (box-type a (try! (parse-type a (try! (need [Sexp] (sx-get items 1) "mut: expects (mut TYPE)")))))))
    (if (str-eq head "ref")
        (Ok (TRef false (box-type a (try! (parse-type a (try! (need [Sexp] (sx-get items 1) "ref: expects (ref TYPE)")))))))
    (if (str-eq head "ptr")
        (Ok (TPtr (box-type a (match (sx-get items 1) (Some [t] (try! (parse-type a t))) (None [] (TInt 64 true))))))
    (if (str-eq head "array")
        (let [elem (box-type a (try! (parse-type a (try! (need [Sexp] (sx-get items 1) "array type: missing element type")))))
              nn (if (opt-is-pos-int (sx-get items 2)) (opt-int (sx-get items 2)) -1)]
          (if (icmp-lt nn 0) (Err [Type Diag] (derr "array type: expected a positive length")) (Ok (TArray elem nn))))
    (if (str-eq head "slice")
        (Ok (TSlice (box-type a (try! (parse-type a (try! (need [Sexp] (sx-get items 1) "slice type: missing element type")))))))
    (if (str-eq head "vec")
        (let [elem (box-type a (try! (parse-type a (try! (need [Sexp] (sx-get items 1) "vec type: missing element type")))))
              nn (if (opt-is-pos-int (sx-get items 2)) (opt-int (sx-get items 2)) -1)]
          (if (icmp-lt nn 0) (Err [Type Diag] (derr "vec type: expected a positive lane count")) (Ok (TVec elem nn))))
    (if (str-eq head "struct")
        (Ok (TStruct (try! (sym-of a (try! (need [Sexp] (sx-get items 1) "struct type: missing name")) "struct name"))))
    (if (str-eq head "dyn")
        (Ok (TStruct (sconcat a (try! (sym-of a (try! (need [Sexp] (sx-get items 1) "dyn type: expected (dyn Trait)")) "dyn trait name")) "-dyn")))
    (if (str-eq head "fnptr")
        (let [cc (try! (sym-of a (try! (need [Sexp] (sx-get items 1) "fnptr type: missing convention")) "fnptr cc"))
              pv (try! (need-vec (sx-get items 2) "fnptr type: expected a vector of parameter types"))
              params (try! (parse-types a pv))
              ret (box-type a (try! (parse-type a (try! (need [Sexp] (sx-get items 3) "fnptr type: missing return type")))))]
          (Ok (TFn cc params ret)))
      (Ok (TApp head (try! (parse-types a (rest-from a items 1)))))))))))))))))

; ---- type parameters (src/parse.rs parse_type_params) ----
(defstruct TPResult [(params (ptr (ArrayList (slice u8)))) (bounds (ptr (ArrayList Bound))) (consumed bool)])
(defn parse-type-params [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp))) (i i64)] (-> (Result TPResult Diag))
  (try (let [a0 (sx-get rest i) a1 (sx-get rest (iadd i 1))]
    (if (not (and (opt-is-vec a0) (opt-is-vec a1)))
        (Ok (let [r (alloc-stack TPResult)]
              (store! (field r params) (box-al [(slice u8)] a (al-new [(slice u8)] a)))
              (store! (field r bounds) (box-al [Bound] a (al-new [Bound] a)))
              (store! (field r consumed) false) (load r)))
        (let [tp (sx-items (opt-get a0)) (mut params) (al-new [(slice u8)] a) (mut bounds) (al-new [Bound] a) n (sx-len tp) (mut k) 0]
          (loop (if (icmp-ge (load k) n) (break)
            (let [entry (sx-at tp (load k))]
              (store! k (iadd (load k) 1))
              (if (icmp-eq (sx-tag entry) 2) (al-push! (mut params) (sx-sval entry))
                (if (icmp-eq (sx-tag entry) 6)
                    (let [eitems (sx-items entry)
                          pname (try! (sym-of a (try! (need [Sexp] (sx-get eitems 0) "type parameter: empty () bound")) "type parameter"))
                          (mut traits) (al-new [(slice u8)] a) tn (sx-len eitems) (mut ti) 1]
                      (loop (if (icmp-ge (load ti) tn) (break) (do (al-push! (mut traits) (try! (sym-of a (sx-at eitems (load ti)) "bound trait"))) (store! ti (iadd (load ti) 1)))))
                      (if (icmp-gt (al-len [(slice u8)] (load traits)) 0)
                          (let [bp (alloc-stack Bound)] (store! (field bp name) pname) (store! (field bp traits) (box-al [(slice u8)] a (load traits))) (al-push! (mut bounds) (load bp))) 0)
                      (al-push! (mut params) pname))
                  (return-from :try (Err [TPResult Diag] (derr-at (sx-lo entry) (sx-hi entry) "type parameter must be a name or (name Trait…)"))))))))
          (Ok (let [r (alloc-stack TPResult)]
                (store! (field r params) (box-al [(slice u8)] a (load params)))
                (store! (field r bounds) (box-al [Bound] a (load bounds)))
                (store! (field r consumed) true) (load r))))))))

; ---- quasiquote (src/parse.rs build_quasi) ----
(defn build-quasi-seq [(a (ptr Allocator)) (items (ptr (ArrayList Sexp))) (isvec bool)] (-> (Result Quasi Diag))
  (try (let [(mut out) (al-new [Quasi] a) n (sx-len items) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break) (do (al-push! (mut out) (try! (build-quasi a (sx-at items (load i))))) (store! i (iadd (load i) 1)))))
    (Ok (if isvec (QVector (box-al [Quasi] a (load out))) (QList (box-al [Quasi] a (load out))))))))
(defn build-quasi [(a (ptr Allocator)) (s Sexp)] (-> (Result Quasi Diag))
  (let [tg (sx-tag s)]
    (if (icmp-eq tg 6)
        (let [items (sx-items s)]
          (if (icmp-eq (sx-len items) 2)
              (let [h (sx-at items 0)]
                (if (icmp-eq (sx-tag h) 2)
                    (let [hs (sx-sval h)]
                      (if (str-eq hs "unquote")
                          (match (parse-expr a (sx-at items 1)) (Err [d] (Err d)) (Ok [e] (Ok (QUnquote (box-expr a e)))))
                        (if (str-eq hs "unquote-splicing")
                          (match (parse-expr a (sx-at items 1)) (Err [d] (Err d)) (Ok [e] (Ok (QSplice (box-expr a e)))))
                          (build-quasi-seq a items false))))
                    (build-quasi-seq a items false)))
              (build-quasi-seq a items false)))
      (if (icmp-eq tg 7) (build-quasi-seq a (sx-items s) true)
          (Ok (QLit (box-sexp a s)))))))

; ---- expressions (src/parse.rs parse_expr / parse_list_expr) ----
(defn mk-bin [(a (ptr Allocator)) (args (ptr (ArrayList Sexp))) (head (slice u8)) (op i64)] (-> (Result ExprKind Diag))
  (try (let [tp (alloc-stack Two)] (store! tp (try! (need-two a args head)))
    (Ok (EBin op (box-expr a (try! (parse-expr a (load (field tp x))))) (box-expr a (try! (parse-expr a (load (field tp y))))))))))
(defn mk-cmp [(a (ptr Allocator)) (args (ptr (ArrayList Sexp))) (head (slice u8)) (op i64)] (-> (Result ExprKind Diag))
  (try (let [tp (alloc-stack Two)] (store! tp (try! (need-two a args head)))
    (Ok (ECmp op (box-expr a (try! (parse-expr a (load (field tp x))))) (box-expr a (try! (parse-expr a (load (field tp y))))))))))
(defn binop-of [(h (slice u8))] (-> i64)
  (if (str-eq h "iadd") 0 (if (str-eq h "isub") 1 (if (str-eq h "imul") 2 (if (str-eq h "idiv") 3 (if (str-eq h "irem") 4 (if (str-eq h "udiv") 5 (if (str-eq h "urem") 6 (if (str-eq h "iand") 7 (if (str-eq h "ior") 8 (if (str-eq h "ixor") 9 (if (str-eq h "ishl") 10 (if (str-eq h "ishr") 11 (if (str-eq h "fadd") 0 (if (str-eq h "fsub") 1 (if (str-eq h "fmul") 2 (if (str-eq h "fdiv") 3 (if (str-eq h "frem") 4 -1))))))))))))))))))
(defn cmpop-of [(h (slice u8))] (-> i64)
  (if (str-eq h "fcmp-lt") 0 (if (str-eq h "fcmp-le") 1 (if (str-eq h "fcmp-gt") 2 (if (str-eq h "fcmp-ge") 3 (if (str-eq h "fcmp-eq") 4 (if (str-eq h "fcmp-ne") 5 (if (str-eq h "icmp-lt") 0 (if (str-eq h "icmp-le") 1 (if (str-eq h "icmp-gt") 2 (if (str-eq h "icmp-ge") 3 (if (str-eq h "icmp-eq") 4 (if (str-eq h "icmp-ne") 5 -1)))))))))))))
(defn codeop-of [(h (slice u8))] (-> i64)
  (if (str-eq h "code-list?") 0 (if (str-eq h "code-sym?") 1 (if (str-eq h "code-int?") 2 (if (str-eq h "code-count") 3 (if (str-eq h "code-nth") 4 (if (str-eq h "code-sym") 5 (if (str-eq h "code-int") 6 (if (str-eq h "code-rest") 7 (if (str-eq h "code-eq") 10 (if (str-eq h "code-keyword?") 11 (if (str-eq h "code-symbol") 12 (if (str-eq h "code-str") 13 (if (str-eq h "code-field-count") 14 (if (str-eq h "code-field-name") 15 (if (str-eq h "code-field-kind") 16 (if (str-eq h "code-field-type") 17 (if (str-eq h "code-variant-sum") 18 (if (str-eq h "code-variant-count") 19 (if (str-eq h "code-variant-name") 20 (if (str-eq h "code-variant-fields") 21 (if (str-eq h "code-trait-method-count") 22 (if (str-eq h "code-trait-method-name") 23 (if (str-eq h "code-trait-arity") 24 (if (str-eq h "code-trait-param-name") 25 (if (str-eq h "code-trait-param-type") 26 (if (str-eq h "code-trait-ret-type") 27 (if (str-eq h "str-bytes") 28 (if (str-eq h "bytes->str") 29 -1)))))))))))))))))))))))))))))
(defn typequery-of [(h (slice u8))] (-> i64)
  (if (str-eq h "field-count") 0 (if (str-eq h "variant-count") 1 (if (str-eq h "struct?") 2 (if (str-eq h "sum?") 3 (if (str-eq h "int?") 4 (if (str-eq h "float?") 5 (if (str-eq h "ptr?") 6 (if (str-eq h "array?") 7 -1)))))))))
(defn fieldmeta-of [(h (slice u8))] (-> i64)
  (if (str-eq h "field-name") 0 (if (str-eq h "field-type-kind") 1 (if (str-eq h "field-type-name") 2 -1))))
(defn alloc-form [(a (ptr Allocator)) (args (ptr (ArrayList Sexp))) (storage i64)] (-> (Result ExprKind Diag))
  (try (let [ty (match (sx-get args 0) (Some [t] (try! (parse-type a t))) (None [] (TInt 64 true)))] (Ok (EAlloc storage ty)))))
(defn parse-exprs [(a (ptr Allocator)) (items (ptr (ArrayList Sexp)))] (-> (Result (ptr (ArrayList Expr)) Diag))
  (try (let [(mut out) (al-new [Expr] a) n (sx-len items) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break) (do (al-push! (mut out) (try! (parse-expr a (sx-at items (load i))))) (store! i (iadd (load i) 1)))))
    (Ok (box-al [Expr] a (load out))))))
(defn parse-expr [(a (ptr Allocator)) (s Sexp)] (-> (Result Expr Diag))
  (match (parse-expr-inner a s)
    (Err [d] (Err (dwspan d (sx-lo s) (sx-hi s))))
    (Ok [kind] (Ok (mk-expr kind (sx-lo s) (sx-hi s))))))
(defn parse-expr-inner [(a (ptr Allocator)) (s Sexp)] (-> (Result ExprKind Diag))
  (let [tg (sx-tag s) slo (sx-lo s) shi (sx-hi s)]
    (if (icmp-eq tg 0) (Ok (EInt (sx-ival s)))
    (if (icmp-eq tg 1) (Ok (EFloat (sx-ival s)))
    (if (icmp-eq tg 2) (let [nm (sx-sval s)] (if (str-eq nm "true") (Ok (EBool true)) (if (str-eq nm "false") (Ok (EBool false)) (Ok (EVar nm)))))
    (if (icmp-eq tg 3) (Err (derr-at slo shi (sconcat a "unexpected keyword :" (sconcat a (sx-sval s) " in expression"))))
    (if (icmp-eq tg 4) (Ok (EStr (sx-sval s)))
    (if (icmp-eq tg 5) (Ok (ECStr (sx-sval s)))
    (if (icmp-eq tg 7) (Err (derr-at slo shi "unexpected vector in expression"))
      (parse-list-expr a (sx-items s) slo shi))))))))))

; A leading :label keyword (src/parse.rs parse_label).
(defstruct LabelSplit [(label (Option (slice u8))) (rest (ptr (ArrayList Sexp)))])
(defn split-label [(a (ptr Allocator)) (args (ptr (ArrayList Sexp)))] (-> LabelSplit)
  (let [r (alloc-stack LabelSplit)]
    (if (and (icmp-gt (sx-len args) 0) (icmp-eq (sx-tag (sx-at args 0)) 3))
        (do (store! (field r label) (Some (sx-sval (sx-at args 0)))) (store! (field r rest) (rest-from a args 1)))
        (do (store! (field r label) (None [(slice u8)])) (store! (field r rest) args)))
    (load r)))

; (let [binds...] body...) — src/parse.rs `let` arm.
(defn parse-let [(a (ptr Allocator)) (args (ptr (ArrayList Sexp))) (slo i64) (shi i64)] (-> (Result ExprKind Diag))
  (try (let [bvo (sx-get args 0)]
    (if (not (opt-is-vec bvo)) (return-from :try (Err [ExprKind Diag] (derr-at slo shi "let: expected binding vector"))) 0)
    (let [bv (sx-items (opt-get bvo)) nb (sx-len bv)]
      (if (not (icmp-eq (urem nb 2) 0)) (return-from :try (Err [ExprKind Diag] (derr-at slo shi "let: bindings must be name/value pairs"))) 0)
      (let [(mut binds) (al-new [Bind] a) (mut k) 0]
        (loop (if (icmp-ge (load k) nb) (break)
          (let [nmf (sx-at bv (load k)) vf (sx-at bv (iadd (load k) 1))]
            (let [bp (alloc-stack Bind)]
              (if (icmp-eq (sx-tag nmf) 2)
                  (do (store! (field bp name) (sx-sval nmf)) (store! (field bp mutable) false))
                (if (and (icmp-eq (sx-tag nmf) 6) (and (icmp-eq (sx-len (sx-items nmf)) 2) (str-eq (try! (head-sym a (sx-items nmf))) "mut")))
                    (do (store! (field bp name) (try! (sym-of a (sx-at (sx-items nmf) 1) "let binding name"))) (store! (field bp mutable) true))
                  (return-from :try (Err [ExprKind Diag] (derr-at (sx-lo nmf) (sx-hi nmf) (sconcat3 a "let binding name must be `name` or `(mut name)`, got " (sexp-display a nmf) ""))))))
              (store! (field bp value) (try! (parse-expr a vf)))
              (al-push! (mut binds) (load bp)))
            (store! k (iadd (load k) 2)))))
        (let [body (try! (parse-exprs a (rest-from a args 1)))]
          (if (icmp-eq (al-len [Expr] (load body)) 0) (return-from :try (Err [ExprKind Diag] (derr-at slo shi "let: empty body"))) 0)
          (Ok (ELet (box-al [Bind] a (load binds)) body))))))))

; (match scrut arms...) — src/parse.rs `match` arm.
(defn parse-match [(a (ptr Allocator)) (args (ptr (ArrayList Sexp))) (slo i64) (shi i64)] (-> (Result ExprKind Diag))
  (try (let [scrut (box-expr a (try! (parse-expr a (try! (need [Sexp] (sx-get args 0) "match: missing scrutinee")))))
             (mut arms) (al-new [Arm] a) n (sx-len args) (mut i) 1]
    (loop (if (icmp-ge (load i) n) (break)
      (let [arm-s (sx-at args (load i))]
        (store! i (iadd (load i) 1))
        (let [al (try! (as-list arm-s "match arm must be (Variant [binds] body)"))
              variant (try! (sym-of a (try! (need [Sexp] (sx-get al 0) "arm: missing variant")) "variant"))
              bvo (sx-get al 1)]
          (if (not (opt-is-vec bvo)) (return-from :try (Err [ExprKind Diag] (derr-at (sx-lo arm-s) (sx-hi arm-s) (sconcat3 a "arm '" variant "': expected a bind vector")))) 0)
          (let [bv (sx-items (opt-get bvo)) (mut binds) (al-new [(slice u8)] a) nb (sx-len bv) (mut bi) 0]
            (loop (if (icmp-ge (load bi) nb) (break) (do (al-push! (mut binds) (try! (sym-of a (sx-at bv (load bi)) "bind"))) (store! bi (iadd (load bi) 1)))))
            (let [bodyf (try! (parse-exprs a (rest-from a al 2))) nbody (al-len [Expr] (load bodyf))]
              (let [body (if (icmp-eq nbody 0) (return-from :try (Err [ExprKind Diag] (derr-at (sx-lo arm-s) (sx-hi arm-s) (sconcat3 a "arm '" variant "': missing body"))))
                           (if (icmp-eq nbody 1) (al-get [Expr] (load bodyf) 0) (mk-expr (EDo bodyf) (sx-lo arm-s) (sx-hi arm-s))))]
                (let [ap (alloc-stack Arm)] (store! (field ap variant) variant) (store! (field ap binds) (box-al [(slice u8)] a (load binds))) (store! (field ap body) body) (al-push! (mut arms) (load ap))))))))))
    (Ok (EMatch scrut (box-al [Arm] a (load arms)))))))

; (llvm-ir RESULT [operands] "BODY") — src/parse.rs `llvm-ir` arm.
(defn parse-llvm-ir [(a (ptr Allocator)) (args (ptr (ArrayList Sexp))) (slo i64) (shi i64)] (-> (Result ExprKind Diag))
  (try (if (icmp-ne (sx-len args) 3) (Err [ExprKind Diag] (derr-at slo shi "llvm-ir: expects (llvm-ir RESULT-TYPE [operands...] \"BODY\")"))
    (let [result (try! (parse-type a (sx-at args 0)))
          ov (sx-at args 1)]
      (if (not (icmp-eq (sx-tag ov) 7)) (return-from :try (Err [ExprKind Diag] (derr-at (sx-lo ov) (sx-hi ov) "llvm-ir: expected a [operand...] vector"))) 0)
      (let [operands (try! (parse-exprs a (sx-items ov))) bv (sx-at args 2)]
        (if (not (icmp-eq (sx-tag bv) 4)) (return-from :try (Err [ExprKind Diag] (derr-at (sx-lo bv) (sx-hi bv) "llvm-ir: body must be a string literal"))) 0)
        (Ok (ELlvmIr result operands (sx-sval bv))))))))

; the big head dispatch (src/parse.rs parse_list_expr).
(defn parse-list-expr [(a (ptr Allocator)) (items (ptr (ArrayList Sexp))) (slo i64) (shi i64)] (-> (Result ExprKind Diag))
  (try (let [head (try! (head-sym a items)) args (rest-from a items 1) nargs (sx-len args)]
    (let [bop (binop-of head)]
    (if (icmp-ge bop 0) (mk-bin a args head bop)
    (let [cop (cmpop-of head)]
    (if (icmp-ge cop 0) (mk-cmp a args head cop)
    (if (str-eq head "inot") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "inot: expects (inot x)")) (Ok (ENot (box-expr a (try! (parse-expr a (sx-at args 0)))))))
    (if (str-eq head "and")
        (let [tp (alloc-stack Two)] (store! tp (try! (need-two a args "and")))
          (Ok (EIf (box-expr a (try! (parse-expr a (load (field tp x))))) (box-expr a (try! (parse-expr a (load (field tp y))))) (box-expr a (mk-expr (EBool false) slo shi)))))
    (if (str-eq head "or")
        (let [tp (alloc-stack Two)] (store! tp (try! (need-two a args "or")))
          (Ok (EIf (box-expr a (try! (parse-expr a (load (field tp x))))) (box-expr a (mk-expr (EBool true) slo shi)) (box-expr a (try! (parse-expr a (load (field tp y))))))))
    (if (str-eq head "not") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "not: expects (not x)"))
        (Ok (EIf (box-expr a (try! (parse-expr a (sx-at args 0)))) (box-expr a (mk-expr (EBool false) slo shi)) (box-expr a (mk-expr (EBool true) slo shi)))))
    (if (str-eq head "if") (if (icmp-ne nargs 3) (Err [ExprKind Diag] (derr-at slo shi "if: expects (if cond then else)"))
        (Ok (EIf (box-expr a (try! (parse-expr a (sx-at args 0)))) (box-expr a (try! (parse-expr a (sx-at args 1)))) (box-expr a (try! (parse-expr a (sx-at args 2)))))))
    (if (str-eq head "do") (Ok (EDo (try! (parse-exprs a args))))
    (if (str-eq head "comptime") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "comptime: expects (comptime expr)")) (Ok (EComptime (box-expr a (try! (parse-expr a (sx-at args 0)))))))
    (if (str-eq head "let") (parse-let a args slo shi)
    (if (str-eq head "call")
        (let [f (try! (sym-of a (try! (need [Sexp] (sx-get args 0) "call: missing function")) "call target"))]
          (Ok (ECall f (box-al [Type] a (al-new [Type] a)) (try! (parse-exprs a (rest-from a args 1))))))
    (if (str-eq head "zeroed") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "zeroed: expects (zeroed TYPE)")) (Ok (EZeroed (try! (parse-type a (sx-at args 0))))))
    (if (str-eq head "mut") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "mut: expects (mut PLACE)")) (Ok (EBorrow true (box-expr a (try! (parse-expr a (sx-at args 0)))))))
    (if (str-eq head "alloc-stack") (alloc-form a args 0)
    (if (str-eq head "alloc-static") (alloc-form a args 1)
    (if (str-eq head "alloc-heap") (alloc-form a args 2)
    (if (str-eq head "field")
        (Ok (EField (box-expr a (try! (parse-expr a (try! (need [Sexp] (sx-get args 0) "field: missing pointer"))))) (try! (sym-of a (try! (need [Sexp] (sx-get args 1) "field: missing field name")) "field name"))))
    (if (str-eq head "get")
        (Ok (EBitGet (box-expr a (try! (parse-expr a (try! (need [Sexp] (sx-get args 0) "get: missing pointer"))))) (try! (sym-of a (try! (need [Sexp] (sx-get args 1) "get: missing field name")) "field name"))))
    (if (str-eq head "set!")
        (Ok (EBitSet (box-expr a (try! (parse-expr a (try! (need [Sexp] (sx-get args 0) "set!: missing pointer"))))) (try! (sym-of a (try! (need [Sexp] (sx-get args 1) "set!: missing field name")) "field name")) (box-expr a (try! (parse-expr a (try! (need [Sexp] (sx-get args 2) "set!: missing value")))))))
    (if (str-eq head "fnptr-of") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "fnptr-of: expects (fnptr-of name)")) (Ok (EFnPtrOf (try! (sym-of a (sx-at args 0) "function name")))))
    (if (str-eq head "call-ptr")
        (Ok (ECallPtr (box-expr a (try! (parse-expr a (try! (need [Sexp] (sx-get args 0) "call-ptr: missing function pointer"))))) (try! (parse-exprs a (rest-from a args 1)))))
    (if (str-eq head "load") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "load: expects (load ptr)")) (Ok (ELoad (box-expr a (try! (parse-expr a (sx-at args 0)))))))
    (if (str-eq head "store!")
        (let [tp (alloc-stack Two)] (store! tp (try! (need-two a args "store!"))) (Ok (EStore (box-expr a (try! (parse-expr a (load (field tp x))))) (box-expr a (try! (parse-expr a (load (field tp y))))))))
    (if (str-eq head "free") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "free: expects (free ptr)")) (Ok (EFree (box-expr a (try! (parse-expr a (sx-at args 0)))))))
    (if (str-eq head "make-dyn") (if (icmp-ne nargs 2) (Err [ExprKind Diag] (derr-at slo shi "make-dyn: expects (make-dyn Trait expr)"))
        (Ok (EErase (try! (sym-of a (sx-at args 0) "make-dyn trait name")) (box-expr a (try! (parse-expr a (sx-at args 1)))))))
    (if (str-eq head "index")
        (let [tp (alloc-stack Two)] (store! tp (try! (need-two a args "index"))) (Ok (EIndex (box-expr a (try! (parse-expr a (load (field tp x))))) (box-expr a (try! (parse-expr a (load (field tp y))))))))
    (if (str-eq head "cast") (if (icmp-ne nargs 2) (Err [ExprKind Diag] (derr-at slo shi "cast: expects (cast :type expr)"))
        (Ok (ECast (try! (parse-type a (sx-at args 0))) (box-expr a (try! (parse-expr a (sx-at args 1)))))))
    (if (str-eq head "match") (parse-match a args slo shi)
    (if (str-eq head "sizeof") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "sizeof: expects (sizeof TYPE)")) (Ok (ESizeOf (try! (parse-type a (sx-at args 0))))))
    (if (str-eq head "alignof") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "alignof: expects (alignof TYPE)")) (Ok (EAlignOf (try! (parse-type a (sx-at args 0))))))
    (if (str-eq head "offsetof") (if (icmp-ne nargs 2) (Err [ExprKind Diag] (derr-at slo shi "offsetof: expects (offsetof TYPE field)")) (Ok (EOffsetOf (try! (parse-type a (sx-at args 0))) (try! (sym-of a (sx-at args 1) "field")))))
    (if (icmp-ge (typequery-of head) 0)
        (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi (sconcat a head (sconcat a ": expects (" (sconcat a head " TYPE)"))))) (Ok (ETypeQuery (typequery-of head) (try! (parse-type a (sx-at args 0))))))
    (if (icmp-ge (fieldmeta-of head) 0)
        (if (icmp-ne nargs 2) (Err [ExprKind Diag] (derr-at slo shi (sconcat a head (sconcat a ": expects (" (sconcat a head " TYPE index)"))))) (Ok (EFieldMeta (fieldmeta-of head) (try! (parse-type a (sx-at args 0))) (box-expr a (try! (parse-expr a (sx-at args 1)))))))
    (if (str-eq head "field-index") (if (icmp-ne nargs 2) (Err [ExprKind Diag] (derr-at slo shi "field-index: expects (field-index TYPE name)")) (Ok (EFieldIndex (try! (parse-type a (sx-at args 0))) (box-expr a (try! (parse-expr a (sx-at args 1)))))))
    (if (str-eq head "quote") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "quote: expects (quote FORM)")) (Ok (EQuote (box-sexp a (sx-at args 0)))))
    (if (str-eq head "quasiquote") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "quasiquote: expects one template")) (Ok (EQuasi (try! (build-quasi a (sx-at args 0))))))
    (if (str-eq head "unquote") (Err [ExprKind Diag] (derr-at slo shi "unquote (~) is only valid inside a quasiquote (`)"))
    (if (str-eq head "gensym") (if (not (icmp-eq nargs 0)) (Err [ExprKind Diag] (derr-at slo shi "gensym: expects (gensym)")) (Ok (ECodeOp 8 (box-al [Expr] a (al-new [Expr] a)))))
    (if (str-eq head "target-arch") (if (not (icmp-eq nargs 0)) (Err [ExprKind Diag] (derr-at slo shi "target-arch: expects (target-arch)")) (Ok (ECodeOp 30 (box-al [Expr] a (al-new [Expr] a)))))
    (if (str-eq head "error") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "error: expects (error MSG)")) (Ok (ECodeOp 9 (try! (parse-exprs a args)))))
    (if (icmp-ge (codeop-of head) 0) (Ok (ECodeOp (codeop-of head) (try! (parse-exprs a args))))
    (if (str-eq head "loop")
        (let [lr (alloc-stack LabelSplit)] (store! lr (split-label a args))
          (let [body (try! (parse-exprs a (load (field lr rest))))]
            (if (icmp-eq (al-len [Expr] (load body)) 0) (Err [ExprKind Diag] (derr-at slo shi "loop: expects (loop [:label] body...)")) (Ok (ELoop (load (field lr label)) body)))))
    (if (str-eq head "break")
        (let [lr (alloc-stack LabelSplit)] (store! lr (split-label a args))
          (let [r (load (field lr rest))]
            (if (icmp-gt (sx-len r) 1) (Err [ExprKind Diag] (derr-at slo shi "break: expects (break [:label] [value])"))
                (Ok (EBreak (load (field lr label)) (match (sx-get r 0) (Some [e] (Some (box-expr a (try! (parse-expr a e))))) (None [] (None [(ptr Expr)]))))))))
    (if (str-eq head "continue")
        (let [lr (alloc-stack LabelSplit)] (store! lr (split-label a args))
          (if (icmp-gt (sx-len (load (field lr rest))) 0) (Err [ExprKind Diag] (derr-at slo shi "continue: expects (continue [:label])")) (Ok (EContinue (load (field lr label))))))
    (if (str-eq head "llvm-ir") (parse-llvm-ir a args slo shi)
      (let [fv (sx-get args 0)]
        (if (opt-is-vec fv)
            (Ok (ECall head (try! (parse-types a (sx-items (opt-get fv)))) (try! (parse-exprs a (rest-from a args 1)))))
            (Ok (ECall head (box-al [Type] a (al-new [Type] a)) (try! (parse-exprs a args))))))))))))))))))))))))))))))))))))))))))))))))))))))))

; ---- declaration parsers (src/parse.rs) ----
(defn func-name [(f Func)] (-> (slice u8)) (let [p (alloc-stack Func)] (store! p f) (load (field p name))))

; variant/struct fields: (name :type) -> Field.
(defn parse-fields [(a (ptr Allocator)) (fv (ptr (ArrayList Sexp)))] (-> (Result (ptr (ArrayList Field)) Diag))
  (try (let [(mut fs) (al-new [Field] a) n (sx-len fv) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (let [f (sx-at fv (load i))]
        (store! i (iadd (load i) 1))
        (let [fl (try! (as-list f "field must be (name :type)"))
              fn0 (try! (sym-of a (sx-at fl 0) "field name"))
              ft (try! (parse-type a (try! (need [Sexp] (sx-get fl 1) "field type"))))]
          (let [fp (alloc-stack Field)] (store! (field fp name) fn0) (store! (field fp ty) ft) (al-push! (mut fs) (load fp)))))))
    (Ok (box-al [Field] a (load fs))))))

(defn parse-const [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp)))] (-> (Result Const Diag))
  (try (let [name (try! (sym-of a (try! (need [Sexp] (sx-get rest 0) "const: missing name")) "const name")) nr (sx-len rest)]
    (if (icmp-eq nr 2)
        (let [value (try! (parse-expr a (sx-at rest 1)))]
          (Ok (let [c (alloc-stack Const)] (store! (field c name) name) (store! (field c ty) (None [Type])) (store! (field c value) value) (load c))))
      (if (icmp-eq nr 3)
          (let [ty (try! (parse-type a (sx-at rest 1))) value (try! (parse-expr a (sx-at rest 2)))]
            (Ok (let [c (alloc-stack Const)] (store! (field c name) name) (store! (field c ty) (Some ty)) (store! (field c value) value) (load c))))
          (Err [Const Diag] (derr "const: expected (const NAME VALUE) or (const NAME TYPE VALUE)")))))))

(defn parse-defsum [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp)))] (-> (Result SumDef Diag))
  (try (let [name (try! (sym-of a (try! (need [Sexp] (sx-get rest 0) "defsum: missing name")) "sum name"))
             (mut i) 1 (mut tps) (al-new [(slice u8)] a)]
    (if (opt-is-vec (sx-get rest (load i)))
        (do (let [it (sx-items (opt-get (sx-get rest (load i)))) n (sx-len it) (mut k) 0]
              (loop (if (icmp-ge (load k) n) (break) (do (al-push! (mut tps) (try! (sym-of a (sx-at it (load k)) "type parameter"))) (store! k (iadd (load k) 1))))))
            (store! i (iadd (load i) 1))) 0)
    (let [(mut variants) (al-new [Variant] a) nr (sx-len rest) (mut vi) (load i)]
      (loop (if (icmp-ge (load vi) nr) (break)
        (let [v (sx-at rest (load vi))]
          (store! vi (iadd (load vi) 1))
          (let [vl (try! (as-list v "variant must be (Name [fields])"))
                vname (try! (sym-of a (try! (need [Sexp] (sx-get vl 0) "variant: missing name")) "variant name"))
                fields (if (opt-is-vec (sx-get vl 1)) (try! (parse-fields a (sx-items (opt-get (sx-get vl 1)))))
                         (match (sx-get vl 1)
                           (Some [_] (return-from :try (Err [SumDef Diag] (derr-at (sx-lo v) (sx-hi v) (sconcat3 a "variant '" vname "': fields must be a vector")))))
                           (None [] (box-al [Field] a (al-new [Field] a)))))]
            (let [vp (alloc-stack Variant)] (store! (field vp name) vname) (store! (field vp fields) fields) (al-push! (mut variants) (load vp)))))))
      (Ok (let [sd (alloc-stack SumDef)] (store! (field sd name) name) (store! (field sd type_params) (box-al [(slice u8)] a (load tps))) (store! (field sd variants) (box-al [Variant] a (load variants))) (load sd)))))))

(defn compute-backing [(a (ptr Allocator)) (name (slice u8)) (acc i64) (backing i64)] (-> (Result i64 Diag))
  (if (icmp-ge backing 0)
      (if (icmp-ge backing acc) (Ok backing)
          (Err [i64 Diag] (derr (sconcat a (sconcat3 a "defstruct '" name "': :backing i") (sconcat a (i64->str a backing) (sconcat a " too small for " (sconcat a (i64->str a acc) " bits")))))))
      (if (icmp-le acc 8) (Ok 8) (if (icmp-le acc 16) (Ok 16) (if (icmp-le acc 32) (Ok 32) (if (icmp-le acc 64) (Ok 64)
          (Err [i64 Diag] (derr (sconcat a (sconcat3 a "defstruct '" name "': ") (sconcat a (i64->str a acc) " bits needs an explicit :backing"))))))))))

(defstruct BitField [(fname (slice u8)) (width i64)])
(defn parse-bitfield [(a (ptr Allocator)) (f Sexp)] (-> (Result BitField Diag))
  (try (let [fl (try! (as-list f "bitfield must be (name :bits N)"))
             fname (try! (sym-of a (sx-at fl 0) "field name"))
             width (if (and (opt-is-kw (sx-get fl 1) "bits") (opt-is-pos-int (sx-get fl 2))) (opt-int (sx-get fl 2)) -1)]
    (if (icmp-lt width 0) (Err [BitField Diag] (derr-at (sx-lo f) (sx-hi f) (sconcat3 a "field '" fname "' must be (name :bits N)")))
        (Ok (let [b (alloc-stack BitField)] (store! (field b fname) fname) (store! (field b width) width) (load b)))))))

(defn finish-bits [(a (ptr Allocator)) (name (slice u8)) (tparams (ptr (ArrayList (slice u8)))) (backing i64) (fields-items (ptr (ArrayList Sexp)))] (-> (Result StructDef Diag))
  (let [(mut fields) (al-new [Field] a) (mut offsets) (al-new [i64] a) (mut acc) 0 n (sx-len fields-items) (mut fi) 0
        (mut out) (zeroed (Result StructDef Diag)) (mut failed) false]
    (loop (if (icmp-ge (load fi) n) (break)
      (let [f (sx-at fields-items (load fi))]
        (store! fi (iadd (load fi) 1))
        (match (parse-bitfield a f)
          (Err [d] (do (store! out (Err d)) (store! failed true) (break)))
          (Ok [fld]
            (let [bp (alloc-stack BitField)] (store! bp fld)
              (let [fr (alloc-stack Field)] (store! (field fr name) (load (field bp fname))) (store! (field fr ty) (TInt (load (field bp width)) false)) (al-push! (mut fields) (load fr)))
              (al-push! (mut offsets) (load acc))
              (store! acc (iadd (load acc) (load (field bp width))))))))))
    (if (load failed) (load out)
        (match (compute-backing a name (load acc) backing)
          (Err [d] (Err d))
          (Ok [bk] (Ok (let [sd (alloc-stack StructDef)] (store! (field sd name) name) (store! (field sd type_params) tparams) (store! (field sd layout) (LBits bk (box-al [i64] a (load offsets)))) (store! (field sd fields) (box-al [Field] a (load fields))) (load sd))))))))

(defstruct NField [(fname (slice u8)) (fty Type) (at (Option i64))])
(defn parse-normal-field [(a (ptr Allocator)) (f Sexp)] (-> (Result NField Diag))
  (try (let [fl (try! (as-list f "field must be (name :type [:at N])"))
             fname (try! (sym-of a (sx-at fl 0) "field name"))
             fty (try! (parse-type a (try! (need [Sexp] (sx-get fl 1) "field missing type"))))
             (mut at) (None [i64]) (mut j) 2 fln (sx-len fl) (mut out) (zeroed (Result NField Diag)) (mut bad) false]
    (loop (if (icmp-ge (load j) fln) (break)
      (let [fj (sx-at fl (load j))]
        (if (and (icmp-eq (sx-tag fj) 3) (str-eq (sx-sval fj) "at"))
            (do (store! at (Some (try! (int-val a (try! (need [Sexp] (sx-get fl (iadd (load j) 1)) ":at missing value")) "at")))) (store! j (iadd (load j) 2)))
            (do (store! out (Err (derr-at (sx-lo fj) (sx-hi fj) (sconcat a "unknown field option " (sexp-display a fj))))) (store! bad true) (break))))))
    (if (load bad) (load out)
        (Ok (let [nf (alloc-stack NField)] (store! (field nf fname) fname) (store! (field nf fty) fty) (store! (field nf at) (load at)) (load nf)))))))

(defn compute-layout [(a (ptr Allocator)) (name (slice u8)) (packed bool) (explicit bool) (aligned i64) (exp-size i64) (has-size bool) (exp-align i64) (anyat bool) (ats (ptr (ArrayList (Option i64))))] (-> (Result Layout Diag))
  (if (icmp-ge aligned 0) (Ok (LAligned aligned))
    (if (or explicit anyat)
        (let [(mut offs) (al-new [i64] a) na (al-len [(Option i64)] (load ats)) (mut oi) 0 (mut bad) false]
          (loop (if (icmp-ge (load oi) na) (break)
            (match (al-get [(Option i64)] (load ats) (load oi))
              (Some [o] (do (al-push! (mut offs) o) (store! oi (iadd (load oi) 1))))
              (None [] (do (store! bad true) (break))))))
          (if (load bad) (Err (derr (sconcat3 a "defstruct '" name "': explicit layout needs :at on every field")))
              (Ok (LExplicit (box-al [i64] a (load offs)) (if has-size (Some exp-size) (None [i64])) exp-align))))
      (if packed (Ok (LPacked)) (Ok (LC))))))

(defn finish-normal [(a (ptr Allocator)) (name (slice u8)) (tparams (ptr (ArrayList (slice u8)))) (packed bool) (explicit bool) (aligned i64) (exp-size i64) (has-size bool) (exp-align i64) (fields-items (ptr (ArrayList Sexp)))] (-> (Result StructDef Diag))
  (let [(mut fields) (al-new [Field] a) (mut ats) (al-new [(Option i64)] a) (mut anyat) false n (sx-len fields-items) (mut fi) 0
        (mut out) (zeroed (Result StructDef Diag)) (mut failed) false]
    (loop (if (icmp-ge (load fi) n) (break)
      (let [f (sx-at fields-items (load fi))]
        (store! fi (iadd (load fi) 1))
        (match (parse-normal-field a f)
          (Err [d] (do (store! out (Err d)) (store! failed true) (break)))
          (Ok [nf]
            (let [np (alloc-stack NField)] (store! np nf)
              (let [fr (alloc-stack Field)] (store! (field fr name) (load (field np fname))) (store! (field fr ty) (load (field np fty))) (al-push! (mut fields) (load fr)))
              (match (load (field np at)) (Some [_] (store! anyat true)) (None [] false))
              (al-push! (mut ats) (load (field np at)))))))))
    (if (load failed) (load out)
        (match (compute-layout a name packed explicit aligned exp-size has-size exp-align (load anyat) (box-al [(Option i64)] a (load ats)))
          (Err [d] (Err d))
          (Ok [layout] (Ok (let [sd (alloc-stack StructDef)] (store! (field sd name) name) (store! (field sd type_params) tparams) (store! (field sd layout) layout) (store! (field sd fields) (box-al [Field] a (load fields))) (load sd))))))))

(defstruct StructOpts [(packed bool) (explicit bool) (bits bool) (aligned i64) (exp-size i64) (has-size bool) (exp-align i64) (backing i64) (next i64)])
(defn parse-struct-opts [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp))) (start i64)] (-> (Result StructOpts Diag))
  (let [(mut packed) false (mut explicit) false (mut bits) false (mut aligned) -1 (mut exp-size) -1 (mut has-size) false (mut exp-align) 0 (mut backing) -1
        (mut i) start (mut out) (zeroed (Result StructOpts Diag)) (mut failed) false]
    (loop
      (match (sx-get rest (load i))
        (None [] (break))
        (Some [kw]
          (if (not (icmp-eq (sx-tag kw) 3)) (break)
            (match (need [Sexp] (sx-get rest (iadd (load i) 1)) (sconcat3 a "defstruct: ':" (sx-sval kw) "' missing value"))
              (Err [d] (do (store! out (Err d)) (store! failed true) (break)))
              (Ok [val]
                (let [k (sx-sval kw) (mut stop) false]
                  (if (str-eq k "layout")
                      (if (icmp-eq (sx-tag val) 2)
                          (let [vs (sx-sval val)]
                            (if (str-eq vs "c") 0
                              (if (str-eq vs "packed") (do (store! packed true) 0)
                                (if (str-eq vs "explicit") (do (store! explicit true) 0)
                                  (if (str-eq vs "bits") (do (store! bits true) 0)
                                    (do (store! out (Err [StructOpts Diag] (derr-at (sx-lo val) (sx-hi val) "layout must be c, packed, explicit, bits, or (align N)"))) (store! failed true) (store! stop true) 0))))))
                        (if (and (icmp-eq (sx-tag val) 6) (icmp-gt (sx-len (sx-items val)) 0))
                            (let [vit (sx-items val)]
                              (if (and (icmp-eq (sx-tag (sx-at vit 0)) 2) (str-eq (sx-sval (sx-at vit 0)) "align"))
                                  (match (pow2 (sx-get vit 1)) (Ok [v] (store! aligned v)) (Err [d] (do (store! out (Err d)) (store! failed true) (store! stop true) 0)))
                                  (do (store! out (Err [StructOpts Diag] (derr-at (sx-lo val) (sx-hi val) "layout must be c, packed, explicit, bits, or (align N)"))) (store! failed true) (store! stop true) 0)))
                            (do (store! out (Err [StructOpts Diag] (derr-at (sx-lo val) (sx-hi val) "layout must be c, packed, explicit, bits, or (align N)"))) (store! failed true) (store! stop true) 0)))
                    (if (str-eq k "size")
                        (match (int-val a val "size") (Ok [v] (do (store! exp-size v) (store! has-size true) 0)) (Err [d] (do (store! out (Err d)) (store! failed true) (store! stop true) 0)))
                      (if (str-eq k "align")
                          (match (pow2 (sx-get rest (iadd (load i) 1))) (Ok [v] (store! exp-align v)) (Err [d] (do (store! out (Err d)) (store! failed true) (store! stop true) 0)))
                        (if (str-eq k "backing")
                            (match (parse-type a val) (Err [d] (do (store! out (Err d)) (store! failed true) (store! stop true) 0))
                              (Ok [bt] (let [bb (type-int-bits bt)] (if (icmp-lt bb 0) (do (store! out (Err [StructOpts Diag] (derr-at (sx-lo val) (sx-hi val) ":backing must be an integer type"))) (store! failed true) (store! stop true) 0) (store! backing bb)))))
                          (do (store! stop true) 0)))))
                  (if (load stop) (break) (store! i (iadd (load i) 2))))))))))
    (if (load failed) (load out)
        (Ok (let [o (alloc-stack StructOpts)]
              (store! (field o packed) (load packed)) (store! (field o explicit) (load explicit)) (store! (field o bits) (load bits))
              (store! (field o aligned) (load aligned)) (store! (field o exp-size) (load exp-size)) (store! (field o has-size) (load has-size))
              (store! (field o exp-align) (load exp-align)) (store! (field o backing) (load backing)) (store! (field o next) (load i)) (load o))))))

(defn parse-defstruct [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp)))] (-> (Result StructDef Diag))
  (try (let [name (try! (sym-of a (try! (need [Sexp] (sx-get rest 0) "defstruct: missing name")) "struct name"))
             opts (alloc-stack StructOpts)]
    (store! opts (try! (parse-struct-opts a rest 1)))
    (let [tpr (alloc-stack TPResult)] (store! tpr (try! (parse-type-params a rest (load (field opts next)))))
      (let [i (if (load (field tpr consumed)) (iadd (load (field opts next)) 1) (load (field opts next)))
            fields-items (if (opt-is-vec (sx-get rest i)) (sx-items (opt-get (sx-get rest i))) (zeroed (ptr (ArrayList Sexp))))]
        (if (icmp-eq (cast i64 fields-items) 0) (Err [StructDef Diag] (derr (sconcat3 a "defstruct '" name "': expected a field vector")))
          (if (load (field opts bits))
              (finish-bits a name (load (field tpr params)) (load (field opts backing)) fields-items)
              (finish-normal a name (load (field tpr params)) (load (field opts packed)) (load (field opts explicit)) (load (field opts aligned)) (load (field opts exp-size)) (load (field opts has-size)) (load (field opts exp-align)) fields-items))))))))
(defn parse-extern [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp)))] (-> (Result Extern Diag))
  (try (let [name (try! (sym-of a (try! (need [Sexp] (sx-get rest 0) "extern: missing name")) "extern name")) (mut i) 1 (mut cc) "c"]
    (match (sx-get rest (load i))
      (Some [k] (if (and (icmp-eq (sx-tag k) 3) (str-eq (sx-sval k) "cc"))
                    (do (store! cc (try! (sym-of a (try! (need [Sexp] (sx-get rest (iadd (load i) 1)) "extern: ':cc' missing convention")) "cc name"))) (store! i (iadd (load i) 2)) 0) 0))
      (None [] 0))
    (let [params-items (try! (need-vec (sx-get rest (load i)) (sconcat3 a "extern '" name "': expected a vector of parameter types")))]
      (store! i (iadd (load i) 1))
      (let [pn (sx-len params-items)
            variadic (if (icmp-gt pn 0) (let [last (sx-at params-items (isub pn 1))] (and (icmp-eq (sx-tag last) 2) (str-eq (sx-sval last) "..."))) false)
            fixed-n (if variadic (isub pn 1) pn) (mut params) (al-new [Type] a) (mut pi) 0]
        (loop (if (icmp-ge (load pi) fixed-n) (break) (do (al-push! (mut params) (try! (parse-type a (sx-at params-items (load pi))))) (store! pi (iadd (load pi) 1)))))
        (let [ret-l (try! (as-list (try! (need [Sexp] (sx-get rest (load i)) "extern: missing (-> :type)")) "expected (-> :type)"))]
          (if (not (str-eq (try! (head-sym a ret-l)) "->")) (return-from :try (Err [Extern Diag] (derr (sconcat3 a "extern '" name "': expected (-> :type)")))) 0)
          (let [ret (try! (parse-type a (try! (need [Sexp] (sx-get ret-l 1) "(-> ) missing type"))))]
            (Ok (let [e (alloc-stack Extern)] (store! (field e name) name) (store! (field e cc) (load cc)) (store! (field e params) (box-al [Type] a (load params))) (store! (field e variadic) variadic) (store! (field e ret) ret) (load e))))))))))

(defn native-cc-parse [(s (slice u8))] (-> i64)
  (if (or (str-eq s "c") (str-eq s "ccc")) 0 (if (or (str-eq s "fast") (str-eq s "fastcc")) 1 (if (or (str-eq s "cold") (str-eq s "coldcc")) 2 -1))))

(defn parse-defcc [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp)))] (-> (Result Convention Diag))
  (try (let [name (try! (sym-of a (try! (need [Sexp] (sx-get rest 0) "defcc: missing name")) "defcc name"))
             (mut params) (box-al [(slice u8)] a (al-new [(slice u8)] a)) (mut ret) (None [(slice u8)])
             (mut clobber) (box-al [(slice u8)] a (al-new [(slice u8)] a)) (mut preserve) (box-al [(slice u8)] a (al-new [(slice u8)] a))
             (mut native) -1 (mut shim) false (mut i) 1 nr (sx-len rest)]
    (loop (if (icmp-ge (load i) nr) (break)
      (let [kw (try! (kw-of a (sx-at rest (load i)) "defcc option"))
            val (try! (need [Sexp] (sx-get rest (iadd (load i) 1)) (sconcat3 a "defcc: option ':" kw "' missing value")))]
        (if (str-eq kw "params") (do (store! params (try! (sym-vec a val "params"))) 0)
          (if (str-eq kw "ret") (do (store! ret (Some (try! (sym-of a val "ret")))) 0)
            (if (str-eq kw "clobber") (do (store! clobber (try! (sym-vec a val "clobber"))) 0)
              (if (str-eq kw "preserve") (do (store! preserve (try! (sym-vec a val "preserve"))) 0)
                (if (str-eq kw "native")
                    (let [nn (try! (sym-of a val "native")) code (native-cc-parse nn)]
                      (if (icmp-lt code 0) (return-from :try (Err [Convention Diag] (derr-at (sx-lo val) (sx-hi val) (sconcat3 a "defcc: unknown native cc '" nn "'")))) (do (store! native code) 0)))
                  (if (str-eq kw "lower")
                      (if (str-eq (try! (sym-of a val "lower")) "shim") (do (store! shim true) 0) 0)
                    (return-from :try (Err [Convention Diag] (derr-at (sx-lo (sx-at rest (load i))) (sx-hi (sx-at rest (load i))) (sconcat3 a "defcc: unknown option ':" kw "'"))))))))))
        (store! i (iadd (load i) 2)))))
    (let [lowering (if (icmp-ge (load native) 0) (LNative (load native)) (if (load shim) (LShim) (return-from :try (Err [Convention Diag] (derr (sconcat3 a "defcc '" name "': needs a lowering (:native <c|fast|cold> or :lower shim)"))))))]
      (Ok (let [c (alloc-stack Convention)] (store! (field c name) name) (store! (field c params) (load params)) (store! (field c ret) (load ret)) (store! (field c clobber) (load clobber)) (store! (field c preserve) (load preserve)) (store! (field c lowering) lowering) (load c)))))))

(defn parse-defn [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp)))] (-> (Result Func Diag))
  (try (let [name (try! (sym-of a (try! (need [Sexp] (sx-get rest 0) "defn: missing name")) "defn name")) (mut i) 1 (mut cc) "c"]
    (match (sx-get rest (load i))
      (Some [k] (if (and (icmp-eq (sx-tag k) 3) (str-eq (sx-sval k) "cc"))
                    (do (store! cc (try! (sym-of a (try! (need [Sexp] (sx-get rest (iadd (load i) 1)) "defn: ':cc' missing convention name")) "cc name"))) (store! i (iadd (load i) 2)) 0) 0))
      (None [] 0))
    (let [tpr (alloc-stack TPResult)] (store! tpr (try! (parse-type-params a rest (load i))))
      (if (load (field tpr consumed)) (do (store! i (iadd (load i) 1)) 0) 0)
      (let [params-items (try! (need-vec (sx-get rest (load i)) (sconcat3 a "defn '" name "': expected parameter vector")))]
        (store! i (iadd (load i) 1))
        (let [(mut params) (al-new [Param] a) (mut macrov) false np (sx-len params-items) (mut pi) 0]
          (loop (if (icmp-ge (load pi) np) (break)
            (let [p (sx-at params-items (load pi))]
              (store! pi (iadd (load pi) 1))
              (if (and (icmp-eq (sx-tag p) 2) (str-eq (sx-sval p) "&")) (do (store! macrov true) 0)
                (let [pl (try! (as-list p "parameter must be (name :type)"))
                      pn (try! (sym-of a (sx-at pl 0) "param name"))
                      pt (try! (parse-type a (try! (need [Sexp] (sx-get pl 1) "param missing type"))))]
                  (let [pp (alloc-stack Param)] (store! (field pp name) pn) (store! (field pp ty) pt) (al-push! (mut params) (load pp))))))))
          (let [ret-l (try! (as-list (try! (need [Sexp] (sx-get rest (load i)) "defn: missing (-> :type)")) "expected (-> :type)"))]
            (if (not (str-eq (try! (head-sym a ret-l)) "->")) (return-from :try (Err [Func Diag] (derr "defn: expected (-> :type) after params"))) 0)
            (let [ret (try! (parse-type a (try! (need [Sexp] (sx-get ret-l 1) "(-> ) missing type"))))]
              (store! i (iadd (load i) 1))
              (let [body (try! (parse-exprs a (rest-from a rest (load i))))]
                (if (icmp-eq (al-len [Expr] (load body)) 0) (return-from :try (Err [Func Diag] (derr (sconcat3 a "defn '" name "': empty body")))) 0)
                (Ok (let [f (alloc-stack Func)]
                      (store! (field f name) name) (store! (field f type_params) (load (field tpr params))) (store! (field f bounds) (load (field tpr bounds)))
                      (store! (field f cc) (load cc)) (store! (field f params) (box-al [Param] a (load params))) (store! (field f ret) ret)
                      (store! (field f body) body) (store! (field f macro_variadic) (load macrov)) (store! (field f lo) -1) (store! (field f hi) -1) (load f))))))))))))

(defn parse-deftrait [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp)))] (-> (Result TraitDef Diag))
  (try (let [name (try! (sym-of a (try! (need [Sexp] (sx-get rest 0) "deftrait: missing name")) "trait name"))
             self-param (if (and (opt-is-vec (sx-get rest 1)) (icmp-eq (sx-len (sx-items (opt-get (sx-get rest 1)))) 1))
                            (try! (sym-of a (sx-at (sx-items (opt-get (sx-get rest 1))) 0) "Self parameter"))
                            (return-from :try (Err [TraitDef Diag] (derr "deftrait: expected [Self] after the name"))))
             (mut methods) (al-new [TraitMethod] a) nr (sx-len rest) (mut mi) 2]
    (loop (if (icmp-ge (load mi) nr) (break)
      (let [m (sx-at rest (load mi))]
        (store! mi (iadd (load mi) 1))
        (let [ml (try! (as-list m "trait method must be (name [params] (-> ret))"))
              mname (try! (sym-of a (try! (need [Sexp] (sx-get ml 0) "trait method: missing name")) "method name"))
              params-items (if (opt-is-vec (sx-get ml 1)) (sx-items (opt-get (sx-get ml 1))) (return-from :try (Err [TraitDef Diag] (derr-at (sx-lo m) (sx-hi m) (sconcat3 a "trait method '" mname "': expected a param vector")))))
              (mut params) (al-new [Param] a) pnn (sx-len params-items) (mut pi) 0]
          (loop (if (icmp-ge (load pi) pnn) (break)
            (let [p (sx-at params-items (load pi))]
              (store! pi (iadd (load pi) 1))
              (let [pl (try! (as-list p "method param must be (name :type)"))
                    pnm (try! (sym-of a (sx-at pl 0) "param name"))
                    pty (try! (parse-type a (try! (need [Sexp] (sx-get pl 1) "method param missing type"))))]
                (let [pp (alloc-stack Param)] (store! (field pp name) pnm) (store! (field pp ty) pty) (al-push! (mut params) (load pp)))))))
          (let [ret-l (try! (as-list (try! (need [Sexp] (sx-get ml 2) "trait method: missing (-> ret)")) "expected (-> ret)"))]
            (if (not (str-eq (try! (head-sym a ret-l)) "->")) (return-from :try (Err [TraitDef Diag] (derr-at (sx-lo m) (sx-hi m) (sconcat3 a "trait method '" mname "': expected (-> ret)")))) 0)
            (let [ret (try! (parse-type a (try! (need [Sexp] (sx-get ret-l 1) "(-> ) missing type"))))]
              (let [mp (alloc-stack TraitMethod)] (store! (field mp name) mname) (store! (field mp params) (box-al [Param] a (load params))) (store! (field mp ret) ret) (al-push! (mut methods) (load mp)))))))))
    (Ok (let [t (alloc-stack TraitDef)] (store! (field t name) name) (store! (field t self_param) self-param) (store! (field t methods) (box-al [TraitMethod] a (load methods))) (load t))))))

(defn parse-impl [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp))) (slo i64) (shi i64)] (-> (Result ImplDef Diag))
  (try (let [trait-name (try! (sym-of a (try! (need [Sexp] (sx-get rest 0) "impl: missing trait name")) "trait name"))
             for-type (try! (sym-of a (try! (need [Sexp] (sx-get rest 1) "impl: missing type name")) "impl type"))
             (mut methods) (al-new [Func] a) nr (sx-len rest) (mut mi) 2]
    (loop (if (icmp-ge (load mi) nr) (break)
      (let [m (sx-at rest (load mi))]
        (store! mi (iadd (load mi) 1))
        (let [ml (try! (as-list m "impl method must be (name [params] (-> ret) body…)"))
              f0 (try! (parse-defn a ml))]
          (let [fp (alloc-stack Func)] (store! fp f0) (store! (field fp lo) slo) (store! (field fp hi) shi) (al-push! (mut methods) (load fp)))))))
    (Ok (let [im (alloc-stack ImplDef)] (store! (field im trait_name) trait-name) (store! (field im for_type) for-type) (store! (field im methods) (box-al [Func] a (load methods))) (load im))))))

(defn parse-export-c [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp)))] (-> (Result (ptr (ArrayList ExportC)) Diag))
  (try (let [(mut out) (al-new [ExportC] a) n (sx-len rest) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (let [item (sx-at rest (load i))]
        (store! i (iadd (load i) 1))
        (let [tg (sx-tag item)]
          (if (icmp-eq tg 2)
              (let [ep (alloc-stack ExportC)] (store! (field ep name) (sx-sval item)) (store! (field ep symbol) (None [(slice u8)])) (store! (field ep params) (box-al [Type] a (al-new [Type] a))) (store! (field ep lo) (sx-lo item)) (store! (field ep hi) (sx-hi item)) (al-push! (mut out) (load ep)))
            (if (icmp-eq tg 7)
                (let [v (sx-items item)
                      nm (if (and (icmp-gt (sx-len v) 0) (icmp-eq (sx-tag (sx-at v 0)) 2)) (sx-sval (sx-at v 0)) (return-from :try (Err [(ptr (ArrayList ExportC)) Diag] (derr-at (sx-lo item) (sx-hi item) "export-c: expected [name :as \"symbol\"]"))))
                      sym0 (if (and (opt-is-kw (sx-get v 1) "as") (opt-is-str (sx-get v 2))) (opt-str-val (sx-get v 2)) (return-from :try (Err [(ptr (ArrayList ExportC)) Diag] (derr-at (sx-lo item) (sx-hi item) "export-c: expected [name :as \"symbol\"]"))))]
                  (let [ep (alloc-stack ExportC)] (store! (field ep name) nm) (store! (field ep symbol) (Some sym0)) (store! (field ep params) (box-al [Type] a (al-new [Type] a))) (store! (field ep lo) (sx-lo item)) (store! (field ep hi) (sx-hi item)) (al-push! (mut out) (load ep))))
              (return-from :try (Err [(ptr (ArrayList ExportC)) Diag] (derr-at (sx-lo item) (sx-hi item) "export-c: each entry is a function name or [name :as \"symbol\"]")))))))))
    (Ok (box-al [ExportC] a (load out))))))

(defn default-c-convention [(a (ptr Allocator))] (-> Convention)
  (let [c (alloc-stack Convention)]
    (store! (field c name) "c") (store! (field c params) (box-al [(slice u8)] a (al-new [(slice u8)] a))) (store! (field c ret) (None [(slice u8)]))
    (store! (field c clobber) (box-al [(slice u8)] a (al-new [(slice u8)] a))) (store! (field c preserve) (box-al [(slice u8)] a (al-new [(slice u8)] a)))
    (store! (field c lowering) (LNative 0)) (load c)))

; `parse_program` in src/parse.rs: fold the top-level forms into a Program.
(defn parse-program [(a (ptr Allocator)) (forms (ptr (ArrayList Sexp)))] (-> (Result Program Diag))
  (let [(mut convs) (al-new [Convention] a) (mut structs) (al-new [StructDef] a) (mut sums) (al-new [SumDef] a)
        (mut externs) (al-new [Extern] a) (mut funcs) (al-new [Func] a) (mut asserts) (al-new [StaticAssert] a)
        (mut consts) (al-new [Const] a) (mut traits) (al-new [TraitDef] a) (mut impls) (al-new [ImplDef] a)
        (mut metas) (al-new [Expr] a) (mut exports) (al-new [ExportC] a)
        (mut err) (zeroed Diag) (mut failed) false]
    (al-push! (mut convs) (default-c-convention a))
    (let [nf (sx-len forms) (mut fi) 0]
      (loop (if (icmp-ge (load fi) nf) (break)
        (let [form (sx-at forms (load fi)) flo (sx-lo form) fhi (sx-hi form)]
          (store! fi (iadd (load fi) 1))
          (let [res
                (match (as-list form "top-level form must be a list")
                  (Err [d] (Err [i64 Diag] d))
                  (Ok [items]
                    (match (head-sym a items)
                      (Err [d] (Err [i64 Diag] d))
                      (Ok [head]
                        (let [rest (rest-from a items 1)]
                          (if (str-eq head "defcc")
                              (match (parse-defcc a rest) (Err [d] (Err [i64 Diag] d))
                                (Ok [c]
                                  (let [cp (alloc-stack Convention)] (store! cp c)
                                    (let [nm (load (field cp name)) (mut found) -1 (mut ci) 0 cn (al-len [Convention] (load convs))]
                                      (loop (if (icmp-ge (load ci) cn) (break) (do (if (str-eq (conv-name (al-get [Convention] (load convs) (load ci))) nm) (do (store! found (load ci)) 0) 0) (store! ci (iadd (load ci) 1)))))
                                      (if (icmp-ge (load found) 0)
                                          (if (str-eq nm "c") (do (al-set! [Convention] (mut convs) (load found) (load cp)) (Ok [i64 Diag] 0)) (Err [i64 Diag] (derr (sconcat3 a "convention '" nm "' defined twice"))))
                                          (do (al-push! (mut convs) (load cp)) (Ok [i64 Diag] 0)))))))
                          (if (str-eq head "defstruct") (match (parse-defstruct a rest) (Ok [sd] (do (al-push! (mut structs) sd) (Ok [i64 Diag] 0))) (Err [d] (Err [i64 Diag] d)))
                          (if (str-eq head "defsum") (match (parse-defsum a rest) (Ok [sd] (do (al-push! (mut sums) sd) (Ok [i64 Diag] 0))) (Err [d] (Err [i64 Diag] d)))
                          (if (str-eq head "defn")
                              (match (parse-defn a rest) (Err [d] (Err [i64 Diag] d))
                                (Ok [f0]
                                  (let [fp (alloc-stack Func)] (store! fp f0) (store! (field fp lo) flo) (store! (field fp hi) fhi)
                                    (let [nm (load (field fp name)) (mut dup) false (mut ci) 0 cn (al-len [Func] (load funcs))]
                                      (loop (if (icmp-ge (load ci) cn) (break) (do (if (str-eq (func-name (al-get [Func] (load funcs) (load ci))) nm) (do (store! dup true) 0) 0) (store! ci (iadd (load ci) 1)))))
                                      (if (load dup) (Err [i64 Diag] (derr (sconcat3 a "function '" nm "' defined twice"))) (do (al-push! (mut funcs) (load fp)) (Ok [i64 Diag] 0)))))))
                          (if (str-eq head "extern") (match (parse-extern a rest) (Ok [e] (do (al-push! (mut externs) e) (Ok [i64 Diag] 0))) (Err [d] (Err [i64 Diag] d)))
                          (if (str-eq head "export-c")
                              (match (parse-export-c a rest) (Err [d] (Err [i64 Diag] d))
                                (Ok [es] (do (let [en (al-len [ExportC] (load es)) (mut ei) 0] (loop (if (icmp-ge (load ei) en) (break) (do (al-push! (mut exports) (al-get [ExportC] (load es) (load ei))) (store! ei (iadd (load ei) 1)))))) (Ok [i64 Diag] 0))))
                          (if (str-eq head "static-assert")
                              (match (parse-static-assert a items) (Ok [sa] (do (al-push! (mut asserts) sa) (Ok [i64 Diag] 0))) (Err [d] (Err [i64 Diag] d)))
                          (if (str-eq head "const") (match (parse-const a rest) (Ok [c] (do (al-push! (mut consts) c) (Ok [i64 Diag] 0))) (Err [d] (Err [i64 Diag] d)))
                          (if (str-eq head "deftrait") (match (parse-deftrait a rest) (Ok [t] (do (al-push! (mut traits) t) (Ok [i64 Diag] 0))) (Err [d] (Err [i64 Diag] d)))
                          (if (str-eq head "impl") (match (parse-impl a rest flo fhi) (Ok [im] (do (al-push! (mut impls) im) (Ok [i64 Diag] 0))) (Err [d] (Err [i64 Diag] d)))
                          (if (str-eq head "meta")
                              (if (not (icmp-eq (sx-len items) 2)) (Err [i64 Diag] (derr "meta: expected (meta EXPR)"))
                                  (match (parse-expr a (sx-at items 1)) (Ok [e] (do (al-push! (mut metas) e) (Ok [i64 Diag] 0))) (Err [d] (Err [i64 Diag] d))))
                            (Err [i64 Diag] (derr (sconcat3 a "unknown top-level form '" head "'")))))))))))))))))))]
            (match res (Ok [_] 0) (Err [d] (do (store! err (dwspan d flo fhi)) (store! failed true) (break)))))))))
    (if (load failed) (Err (load err))
        (Ok (let [pp (alloc-stack Program)]
              (store! (field pp conventions) (box-al [Convention] a (load convs)))
              (store! (field pp structs) (box-al [StructDef] a (load structs)))
              (store! (field pp sums) (box-al [SumDef] a (load sums)))
              (store! (field pp externs) (box-al [Extern] a (load externs)))
              (store! (field pp funcs) (box-al [Func] a (load funcs)))
              (store! (field pp asserts) (box-al [StaticAssert] a (load asserts)))
              (store! (field pp consts) (box-al [Const] a (load consts)))
              (store! (field pp traits) (box-al [TraitDef] a (load traits)))
              (store! (field pp impls) (box-al [ImplDef] a (load impls)))
              (store! (field pp metas) (box-al [Expr] a (load metas)))
              (store! (field pp exports) (box-al [ExportC] a (load exports)))
              (load pp))))))

; static-assert (src/parse.rs): condition presence + message rule.
(defn assert-msg [(a (ptr Allocator)) (items (ptr (ArrayList Sexp)))] (-> (Result (slice u8) Diag))
  (match (sx-get items 2)
    (None [] (Ok "static assertion failed"))
    (Some [s] (if (icmp-eq (sx-tag s) 4) (Ok (sx-sval s)) (Err (derr "static-assert: message must be a string"))))))
(defn parse-static-assert [(a (ptr Allocator)) (items (ptr (ArrayList Sexp)))] (-> (Result StaticAssert Diag))
  (try (let [cond (try! (parse-expr a (try! (need [Sexp] (sx-get items 1) "static-assert: missing condition"))))
             msg (try! (assert-msg a items))]
    (Ok (let [ap (alloc-stack StaticAssert)] (store! (field ap cnd) cond) (store! (field ap msg) msg) (load ap))))))

; ============================ reused reader =================================
; Ported (and verified) in selfhost/reader.coil — copied here so the parser can
; turn source into Sexp. Treat as already-correct.
(defn looks-numeric [(s (slice u8))] (-> bool)
  (let [n (slice-len s)]
    (if (icmp-eq n 0) false
        (let [c0 (cast i64 (slice-get s 0))]
          (if (and (icmp-ge c0 48) (icmp-le c0 57)) true
              (if (or (icmp-eq c0 45) (or (icmp-eq c0 43) (icmp-eq c0 46)))
                  (if (icmp-ge n 2)
                      (let [c1 (cast i64 (slice-get s 1))] (and (icmp-ge c1 48) (icmp-le c1 57)))
                      false)
                  false))))))

(defn parse-int [(s (slice u8))] (-> (Option i64))
  (let [n (slice-len s)]
    (let [dec
          (if (icmp-eq n 0) (None [i64])
              (let [(mut i) 0 (mut neg) false]
                (let [c0 (cast i64 (slice-get s 0))]
                  (if (icmp-eq c0 45) (do (store! neg true) (store! i 1))
                    (if (icmp-eq c0 43) (store! i 1) 0)))
                (if (icmp-ge (load i) n) (None [i64])
                    (let [(mut mag) 0 (mut ok) true (mut overflow) false
                          maxrem (if (load neg) 8 7)]
                      (loop
                        (if (icmp-ge (load i) n) (break)
                          (let [c (cast i64 (slice-get s (load i)))]
                            (if (and (icmp-ge c 48) (icmp-le c 57))
                                (let [d (isub c 48)]
                                  (if (or (icmp-gt (load mag) 922337203685477580)
                                          (and (icmp-eq (load mag) 922337203685477580) (icmp-gt d maxrem)))
                                      (do (store! overflow true) (break))
                                      (do (store! mag (iadd (imul (load mag) 10) d)) (store! i (iadd (load i) 1)))))
                                (do (store! ok false) (break))))))
                      (if (or (not (load ok)) (load overflow)) (None [i64])
                          (Some (if (load neg) (isub 0 (load mag)) (load mag))))))))]
      (match dec
        (Some [v] (Some v))
        (None []
          (if (icmp-eq n 0) (None [i64])
              (let [(mut neg2) false (mut bstart) 0]
                (let [c0 (cast i64 (slice-get s 0))]
                  (if (icmp-eq c0 45) (do (store! neg2 true) (store! bstart 1))
                    (if (icmp-eq c0 43) (store! bstart 1) 0)))
                (let [blen (isub n (load bstart)) (mut radix) 0 (mut dstart) (load bstart)]
                  (if (and (icmp-ge blen 2) (icmp-eq (cast i64 (slice-get s (load bstart))) 48))
                      (let [c1 (cast i64 (slice-get s (iadd (load bstart) 1)))]
                        (if (or (icmp-eq c1 120) (icmp-eq c1 88)) (do (store! radix 16) (store! dstart (iadd (load bstart) 2)))
                          (if (or (icmp-eq c1 98) (icmp-eq c1 66)) (do (store! radix 2) (store! dstart (iadd (load bstart) 2)))
                            (if (or (icmp-eq c1 111) (icmp-eq c1 79)) (do (store! radix 8) (store! dstart (iadd (load bstart) 2)))
                              0))))
                      0)
                  (if (icmp-eq (load radix) 0)
                      (let [body (subslice s (load bstart) n)
                            has-us (do (let [(mut f) false (mut j) (load bstart)]
                                         (loop (if (icmp-ge (load j) n) (break)
                                             (do (if (icmp-eq (cast i64 (slice-get s (load j))) 95) (store! f true) false)
                                                 (store! j (iadd (load j) 1)))))
                                         (load f)))]
                        (if (and has-us (looks-numeric body)) (do (store! radix 10) (store! dstart (load bstart))) 0))
                      0)
                  (if (icmp-eq (load radix) 0) (None [i64])
                      (let [(mut mag) 0 (mut count) 0 (mut bad) false (mut ovf) false
                            (mut j) (load dstart) rr (load radix)]
                        (loop
                          (if (icmp-ge (load j) n) (break)
                            (let [c (cast i64 (slice-get s (load j)))]
                              (store! j (iadd (load j) 1))
                              (if (icmp-eq c 95) 0
                                (let [dv (let [v0 (if (and (icmp-ge c 48) (icmp-le c 57)) (isub c 48)
                                                    (if (and (icmp-ge c 97) (icmp-le c 122)) (iadd (isub c 97) 10)
                                                      (if (and (icmp-ge c 65) (icmp-le c 90)) (iadd (isub c 65) 10) -1)))]
                                           (if (icmp-lt v0 0) -1 (if (icmp-ge v0 rr) -1 v0)))]
                                  (if (icmp-lt dv 0) (do (store! bad true) (break))
                                      (let [maxdiv (udiv -1 rr) maxrem (urem -1 rr)]
                                        (if (or (icmp-gt (cast u64 (load mag)) (cast u64 maxdiv))
                                                (and (icmp-eq (load mag) maxdiv) (icmp-gt (cast u64 dv) (cast u64 maxrem))))
                                            (do (store! ovf true) (break))
                                            (do (store! mag (iadd (imul (load mag) rr) dv)) (store! count (iadd (load count) 1)))))))))))
                        (if (or (load bad) (or (load ovf) (icmp-eq (load count) 0))) (None [i64])
                            (Some (if (load neg2) (isub 0 (load mag)) (load mag))))))))))))))

(defn atom [(s (slice u8))] (-> SexpKind)
  (let [n (slice-len s)]
    (if (and (icmp-gt n 0) (icmp-eq (cast i64 (slice-get s 0)) 58)) (KKw (subslice s 1 n))
        (match (parse-int s)
          (Some [v] (KInt v))
          (None []
            (if (and (looks-numeric s)
                     (do (let [(mut f) false (mut j) 0]
                           (loop (if (icmp-ge (load j) n) (break)
                               (do (let [c (cast i64 (slice-get s (load j)))]
                                     (if (or (icmp-eq c 46) (or (icmp-eq c 101) (icmp-eq c 69))) (store! f true) false))
                                   (store! j (iadd (load j) 1)))))
                           (load f))))
                (let [a (malloc-allocator) buf (slice->cstr a s) ep (alloc-stack (ptr i8))
                      x (strtod buf ep) consumed (isub (cast i64 (load ep)) (cast i64 buf))]
                  (if (and (icmp-gt n 0) (icmp-eq consumed n)) (KFloat (f64-bits x)) (KSym s)))
                (KSym s)))))))

(defn read-string-body [(a (ptr Allocator)) (src (slice u8)) (open-off i64) (i i64)] (-> (Result StrRead Diag))
  (let [n (slice-len src) (mut buf) (al-new [u8] a) (mut k) i (mut out) (zeroed (Result StrRead Diag))]
    (loop
      (if (icmp-ge (load k) n)
          (do (store! out (Err (mk-diag open-off n "unterminated string literal"))) (break))
          (let [c (cast i64 (slice-get src (load k)))]
            (store! k (iadd (load k) 1))
            (if (icmp-eq c 34)
                (do (store! out (Ok (mk-strread (al-slice [u8] (load buf)) (load k)))) (break))
              (if (icmp-eq c 92)
                  (if (icmp-ge (load k) n)
                      (do (store! out (Err (mk-diag open-off n "unterminated string escape"))) (break))
                      (let [e (cast i64 (slice-get src (load k)))]
                        (store! k (iadd (load k) 1))
                        (al-push! (mut buf)
                          (cast u8 (if (icmp-eq e 110) 10 (if (icmp-eq e 116) 9 (if (icmp-eq e 34) 34 (if (icmp-eq e 92) 92 e))))))))
                  (al-push! (mut buf) (cast u8 c)))))))
    (load out)))

(defn tokenize [(a (ptr Allocator)) (src (slice u8))] (-> (Result (ptr (ArrayList Tok)) Diag))
  (let [n (slice-len src) (mut toks) (al-new [Tok] a) (mut i) 0
        (mut out) (zeroed (Result (ptr (ArrayList Tok)) Diag)) (mut done) false]
    (loop
      (if (icmp-ge (load i) n) (break)
        (let [c (cast i64 (slice-get src (load i)))]
          (if (or (icmp-eq c 32) (or (icmp-eq c 9) (or (icmp-eq c 10) (or (icmp-eq c 13) (or (icmp-eq c 11) (icmp-eq c 12))))))
              (store! i (iadd (load i) 1))
            (if (icmp-eq c 59)
                (loop (if (icmp-ge (load i) n) (break)
                    (let [ch (cast i64 (slice-get src (load i)))]
                      (store! i (iadd (load i) 1)) (if (icmp-eq ch 10) (break) 0))))
              (if (or (icmp-eq c 40) (icmp-eq c 91))
                  (do (al-push! (mut toks) (mk-tok (TOpen c) (load i) (iadd (load i) 1))) (store! i (iadd (load i) 1)))
                (if (or (icmp-eq c 41) (icmp-eq c 93))
                    (do (al-push! (mut toks) (mk-tok (TClose c) (load i) (iadd (load i) 1))) (store! i (iadd (load i) 1)))
                  (if (icmp-eq c 39)
                      (do (al-push! (mut toks) (mk-tok (TPrefix "quote") (load i) (iadd (load i) 1))) (store! i (iadd (load i) 1)))
                    (if (icmp-eq c 96)
                        (do (al-push! (mut toks) (mk-tok (TPrefix "quasiquote") (load i) (iadd (load i) 1))) (store! i (iadd (load i) 1)))
                      (if (icmp-eq c 126)
                          (let [istart (load i)]
                            (store! i (iadd (load i) 1))
                            (if (and (icmp-lt (load i) n) (icmp-eq (cast i64 (slice-get src (load i))) 64))
                                (do (al-push! (mut toks) (mk-tok (TPrefix "unquote-splicing") istart (iadd (load i) 1))) (store! i (iadd (load i) 1)))
                                (al-push! (mut toks) (mk-tok (TPrefix "unquote") istart (iadd istart 1)))))
                        (if (icmp-eq c 34)
                            (let [istart (load i)]
                              (store! i (iadd (load i) 1))
                              (match (read-string-body a src istart (load i))
                                (Err [d] (do (store! out (Err d)) (store! done true) (break)))
                                (Ok [sr]
                                  (let [srp (alloc-stack StrRead)]
                                    (store! srp sr)
                                    (al-push! (mut toks) (mk-tok (TStr (load (field srp s))) istart (load (field srp end))))
                                    (store! i (load (field srp end)))))))
                            (let [start (load i) (mut end) (load i)]
                              (loop
                                (if (icmp-ge (load i) n) (break)
                                  (let [cc (cast i64 (slice-get src (load i)))]
                                    (if (or (or (icmp-eq cc 32) (or (icmp-eq cc 9) (or (icmp-eq cc 10) (or (icmp-eq cc 13) (or (icmp-eq cc 11) (icmp-eq cc 12))))))
                                            (or (icmp-eq cc 40) (or (icmp-eq cc 41) (or (icmp-eq cc 91) (or (icmp-eq cc 93) (or (icmp-eq cc 59) (or (icmp-eq cc 39) (or (icmp-eq cc 96) (or (icmp-eq cc 126) (icmp-eq cc 34))))))))))
                                        (break)
                                        (do (store! i (iadd (load i) 1)) (store! end (load i)))))))
                              (let [stok (subslice src start (load end))]
                                (if (and (and (icmp-eq (isub (load end) start) 1) (icmp-eq (cast i64 (slice-get src start)) 99))
                                         (and (icmp-lt (load i) n) (icmp-eq (cast i64 (slice-get src (load i))) 34)))
                                    (do (store! i (iadd (load i) 1))
                                        (match (read-string-body a src start (load i))
                                          (Err [d] (do (store! out (Err d)) (store! done true) (break)))
                                          (Ok [sr]
                                            (let [srp (alloc-stack StrRead)]
                                              (store! srp sr)
                                              (al-push! (mut toks) (mk-tok (TCStr (load (field srp s))) start (load (field srp end))))
                                              (store! i (load (field srp end)))))))
                                    (al-push! (mut toks) (mk-tok (TAtom stok) start (load end)))))))))))))))))
    (if (load done) (load out)
        (Ok (let [bp (unwrap-ptr [(ArrayList Tok)] (create [(ArrayList Tok)] a))] (store! bp (load toks)) bp)))))

(defn parse-one [(p (ptr Parser)) (a (ptr Allocator))] (-> (Result Sexp Diag))
  (let [toks (load (field p toks)) ntok (al-len [Tok] (load toks)) pos (load (field p pos))]
    (if (icmp-ge pos ntok) (Err (mk-diag -1 -1 "unexpected end of input"))
        (let [tok (alloc-stack Tok)]
          (store! tok (al-get [Tok] (load toks) pos))
          (store! (field p pos) (iadd pos 1))
          (let [tlo (load (field tok lo)) thi (load (field tok hi))]
            (match (load (field tok kind))
              (TStr  [s] (Ok (mk-sexp (KStr s) tlo thi)))
              (TCStr [s] (Ok (mk-sexp (KCStr s) tlo thi)))
              (TAtom [s] (Ok (mk-sexp (atom s) tlo thi)))
              (TClose [c]
                (let [cs (slice-new [u8] (let [cb (cast (ptr u8) (unwrap-ptr [i8] (raw-alloc a 1 1)))] (store! (index cb 0) (cast u8 c)) cb) 1)
                      m1 (match (str-concat a "unexpected '" cs) (Some [v] v) (None [] ""))
                      m2 (match (str-concat a m1 "'") (Some [v] v) (None [] ""))]
                  (Err (mk-diag tlo thi m2))))
              (TPrefix [sym]
                (match (parse-one p a)
                  (Err [d] (Err d))
                  (Ok [inner]
                    (let [ip (alloc-stack Sexp)]
                      (store! ip inner)
                      (let [ihi (load (field ip hi)) (mut kids) (al-new [Sexp] a)]
                        (al-push! (mut kids) (mk-sexp (KSym sym) tlo thi))
                        (al-push! (mut kids) (load ip))
                        (Ok (mk-sexp (KList (box-items a (load kids))) tlo ihi)))))))
              (TOpen [open]
                (let [close (if (icmp-eq open 40) 41 93) (mut items) (al-new [Sexp] a) (mut out) (zeroed (Result Sexp Diag))]
                  (loop
                    (let [cpos (load (field p pos))]
                      (if (icmp-ge cpos ntok)
                          (do (let [cs (slice-new [u8] (let [cb (cast (ptr u8) (unwrap-ptr [i8] (raw-alloc a 1 1)))] (store! (index cb 0) (cast u8 open)) cb) 1)
                                    m1 (match (str-concat a "unclosed '" cs) (Some [v] v) (None [] ""))
                                    m2 (match (str-concat a m1 "'") (Some [v] v) (None [] ""))]
                                (store! out (Err (mk-diag tlo thi m2))))
                              (break))
                          (let [nt (alloc-stack Tok)]
                            (store! nt (al-get [Tok] (load toks) cpos))
                            (let [cdelim (match (load (field nt kind))
                                           (TClose [cc] cc) (TOpen [_] -1) (TPrefix [_] -1)
                                           (TStr [_] -1) (TCStr [_] -1) (TAtom [_] -1))]
                              (if (icmp-ge cdelim 0)
                                  (if (icmp-ne cdelim close)
                                      (do (let [os (slice-new [u8] (let [cb (cast (ptr u8) (unwrap-ptr [i8] (raw-alloc a 1 1)))] (store! (index cb 0) (cast u8 open)) cb) 1)
                                                ds (slice-new [u8] (let [cb (cast (ptr u8) (unwrap-ptr [i8] (raw-alloc a 1 1)))] (store! (index cb 0) (cast u8 cdelim)) cb) 1)
                                                m1 (match (str-concat a "mismatched delimiters: '" os) (Some [v] v) (None [] ""))
                                                m2 (match (str-concat a m1 "' .. '") (Some [v] v) (None [] ""))
                                                m3 (match (str-concat a m2 ds) (Some [v] v) (None [] ""))
                                                m4 (match (str-concat a m3 "'") (Some [v] v) (None [] ""))]
                                            (store! out (Err (mk-diag (load (field nt lo)) (load (field nt hi)) m4))))
                                          (break))
                                      (do (store! (field p pos) (iadd cpos 1))
                                          (store! out (Ok (mk-sexp (if (icmp-eq open 40)
                                                                       (KList (box-items a (load items)))
                                                                       (KVec (box-items a (load items))))
                                                                   tlo (load (field nt hi)))))
                                          (break)))
                                  (match (parse-one p a)
                                    (Ok [child] (do (al-push! (mut items) child) 0))
                                    (Err [d] (do (store! out (Err d)) (break))))))))))
                  (load out)))))))))

; Recursively stamp `source` onto a node and all its descendants (in place),
; mirroring the Rust reader stamping each Sexp's span with its file's source id.
; ctxt is left untouched (0 from the constructor; the macro expander sets it).
(defn stamp-source-list [(items (ptr (ArrayList Sexp))) (source i64)] (-> i64)
  (let [n (al-len [Sexp] (load items)) (mut i) 0 data (load (field items data))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (stamp-source-node (index data (load i)) source)
          (store! i (iadd (load i) 1))))))
  0)
(defn stamp-source-node [(x (ptr Sexp)) (source i64)] (-> i64)
  (store! (field x source) source)
  (match (load (field x kind))
    (KList  [items] (stamp-source-list items source))
    (KVec   [items] (stamp-source-list items source))
    (KInt   [v] 0) (KFloat [b] 0) (KSym  [s] 0)
    (KKw    [s] 0) (KStr   [s] 0) (KCStr [s] 0))
  0)
; Attach a non-dummy diagnostic to `source` (a dummy diag — lo<0 — keeps its D span).
(defn diag-with-source [(d Diag) (source i64)] (-> Diag)
  (let [p (alloc-stack Diag)] (store! p d)
    (if (icmp-ge (load (field p lo)) 0) (store! (field p source) source) 0)
    (load p)))

(defn read-all [(a (ptr Allocator)) (src (slice u8)) (source i64)] (-> (Result (ptr (ArrayList Sexp)) Diag))
  (match (tokenize a src)
    (Err [d] (Err (diag-with-source d source)))
    (Ok [toks]
      (let [p (alloc-stack Parser) (mut out) (al-new [Sexp] a) (mut err) (zeroed Diag) (mut failed) false]
        (store! (field p toks) toks) (store! (field p pos) 0)
        (loop
          (if (icmp-ge (load (field p pos)) (al-len [Tok] (load toks))) (break)
            (match (parse-one p a)
              (Ok [s] (do (al-push! (mut out) s) 0))
              (Err [d] (do (store! err d) (store! failed true) (break))))))
        (if (load failed)
            (Err (diag-with-source (load err) source))
            (let [forms (box-items a (load out))]
              (stamp-source-list forms source)
              (Ok forms)))))))

; ============================ canonical dump entry ==========================
; Emits the `(error@lo:hi "msg")` shape on a read/parse error (mirrors dump_ast
; in src/lib.rs). A dummy span (lo/hi = -1) prints `D`.
(defn dump-error [(w (ptr Writer)) (d (ptr Diag))] (-> i64)
  (ps w "(error") (dump-span4 w (load (field d source)) (load (field d lo)) (load (field d hi)) (load (field d ctxt)))
  (ps w " \"") (esc-write w (load (field d msg))) (ps w "\")"))

(defn dump-ast-program [(a (ptr Allocator)) (src (slice u8))] (-> i64)
  (let [w (stdout)]
    (match (read-all a src 0)
      (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
      (Ok [forms]
        (match (parse-program a forms)
          (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
          (Ok [prog] (let [pp (alloc-stack Program)] (store! pp prog) (d-program w pp a)))))))
  0)

; ============================ file IO + entry ===============================
(defn read-file [(a (ptr Allocator)) (path (ptr i8))] (-> (slice u8))
  (let [fd (open path 0) buf (unwrap-ptr [i8] (raw-alloc a 65536 1)) (mut bytes) (al-new [u8] a)]
    (loop
      (let [n (read (cast i64 fd) buf 65536)]
        (if (icmp-le n 0) (break)
          (let [(mut i) 0]
            (loop (if (icmp-ge (load i) n) (break)
                (do (al-push! (mut bytes) (cast u8 (load (index buf (load i))))) (store! i (iadd (load i) 1)))))))))
    (close fd)
    (al-slice [u8] (load bytes))))

; A hand-built Program smoke test (no spans → byte-exact against `coil dump-ast`
; of the equivalent source). Validates the dumper before the parser is filled.
(defn smoke [(a (ptr Allocator))] (-> i64)
  (let [w (stdout) p (alloc-stack Program)]
    ; conventions: [c]
    (let [(mut cs) (al-new [Convention] a) cv (alloc-stack Convention)]
      (store! (field cv name) "c")
      (store! (field cv params) (let [bp (unwrap-ptr [(ArrayList (slice u8))] (create [(ArrayList (slice u8))] a))] (store! bp (al-new [(slice u8)] a)) bp))
      (store! (field cv ret) (None [(slice u8)]))
      (store! (field cv clobber) (let [bp (unwrap-ptr [(ArrayList (slice u8))] (create [(ArrayList (slice u8))] a))] (store! bp (al-new [(slice u8)] a)) bp))
      (store! (field cv preserve) (let [bp (unwrap-ptr [(ArrayList (slice u8))] (create [(ArrayList (slice u8))] a))] (store! bp (al-new [(slice u8)] a)) bp))
      (store! (field cv lowering) (LNative 0))
      (al-push! (mut cs) (load cv))
      (store! (field p conventions) (let [bp (unwrap-ptr [(ArrayList Convention)] (create [(ArrayList Convention)] a))] (store! bp (load cs)) bp)))
    ; structs: [Point {x:i64,y:i64}]
    (let [(mut ss) (al-new [StructDef] a) sd (alloc-stack StructDef)
          (mut fs) (al-new [Field] a) fx (alloc-stack Field) fy (alloc-stack Field)]
      (store! (field fx name) "x") (store! (field fx ty) (TInt 64 true)) (al-push! (mut fs) (load fx))
      (store! (field fy name) "y") (store! (field fy ty) (TInt 64 true)) (al-push! (mut fs) (load fy))
      (store! (field sd name) "Point")
      (store! (field sd type_params) (let [bp (unwrap-ptr [(ArrayList (slice u8))] (create [(ArrayList (slice u8))] a))] (store! bp (al-new [(slice u8)] a)) bp))
      (store! (field sd layout) (LC))
      (store! (field sd fields) (let [bp (unwrap-ptr [(ArrayList Field)] (create [(ArrayList Field)] a))] (store! bp (load fs)) bp))
      (al-push! (mut ss) (load sd))
      (store! (field p structs) (let [bp (unwrap-ptr [(ArrayList StructDef)] (create [(ArrayList StructDef)] a))] (store! bp (load ss)) bp)))
    ; sums: [Opt[T] (Some [v:T]) (None [])]
    (let [(mut su) (al-new [SumDef] a) sm (alloc-stack SumDef)
          (mut tps) (al-new [(slice u8)] a)
          (mut vs) (al-new [Variant] a) v1 (alloc-stack Variant) v2 (alloc-stack Variant)
          (mut f1) (al-new [Field] a) fv (alloc-stack Field)]
      (al-push! (mut tps) "T")
      (store! (field fv name) "v") (store! (field fv ty) (TStruct "T")) (al-push! (mut f1) (load fv))
      (store! (field v1 name) "Some") (store! (field v1 fields) (let [bp (unwrap-ptr [(ArrayList Field)] (create [(ArrayList Field)] a))] (store! bp (load f1)) bp))
      (store! (field v2 name) "None") (store! (field v2 fields) (let [bp (unwrap-ptr [(ArrayList Field)] (create [(ArrayList Field)] a))] (store! bp (al-new [Field] a)) bp))
      (al-push! (mut vs) (load v1)) (al-push! (mut vs) (load v2))
      (store! (field sm name) "Opt")
      (store! (field sm type_params) (let [bp (unwrap-ptr [(ArrayList (slice u8))] (create [(ArrayList (slice u8))] a))] (store! bp (load tps)) bp))
      (store! (field sm variants) (let [bp (unwrap-ptr [(ArrayList Variant)] (create [(ArrayList Variant)] a))] (store! bp (load vs)) bp))
      (al-push! (mut su) (load sm))
      (store! (field p sums) (let [bp (unwrap-ptr [(ArrayList SumDef)] (create [(ArrayList SumDef)] a))] (store! bp (load su)) bp)))
    ; externs: [puts (ptr i8) -> i32]
    (let [(mut es) (al-new [Extern] a) ex (alloc-stack Extern) (mut eps) (al-new [Type] a)]
      (al-push! (mut eps) (TPtr (box-type a (TInt 8 true))))
      (store! (field ex name) "puts") (store! (field ex cc) "c")
      (store! (field ex params) (let [bp (unwrap-ptr [(ArrayList Type)] (create [(ArrayList Type)] a))] (store! bp (load eps)) bp))
      (store! (field ex variadic) false) (store! (field ex ret) (TInt 32 true))
      (al-push! (mut es) (load ex))
      (store! (field p externs) (let [bp (unwrap-ptr [(ArrayList Extern)] (create [(ArrayList Extern)] a))] (store! bp (load es)) bp)))
    ; empty sections
    (store! (field p funcs) (let [bp (unwrap-ptr [(ArrayList Func)] (create [(ArrayList Func)] a))] (store! bp (al-new [Func] a)) bp))
    (store! (field p asserts) (let [bp (unwrap-ptr [(ArrayList StaticAssert)] (create [(ArrayList StaticAssert)] a))] (store! bp (al-new [StaticAssert] a)) bp))
    (store! (field p consts) (let [bp (unwrap-ptr [(ArrayList Const)] (create [(ArrayList Const)] a))] (store! bp (al-new [Const] a)) bp))
    (store! (field p traits) (let [bp (unwrap-ptr [(ArrayList TraitDef)] (create [(ArrayList TraitDef)] a))] (store! bp (al-new [TraitDef] a)) bp))
    (store! (field p impls) (let [bp (unwrap-ptr [(ArrayList ImplDef)] (create [(ArrayList ImplDef)] a))] (store! bp (al-new [ImplDef] a)) bp))
    (store! (field p metas) (let [bp (unwrap-ptr [(ArrayList Expr)] (create [(ArrayList Expr)] a))] (store! bp (al-new [Expr] a)) bp))
    (store! (field p exports) (let [bp (unwrap-ptr [(ArrayList ExportC)] (create [(ArrayList ExportC)] a))] (store! bp (al-new [ExportC] a)) bp))
    (d-program w p a))
  0)

; ============================ loader representation =========================
; Mirrors src/macros.rs (copied from the completed loader pass). The two HashMaps
; (ImportMap/ExportMap) and the inner HashMap (aliases) become ArrayLists keyed by
; name (linear scan); Vec fields (uses/reexports/export-names) stay ordered.
(defstruct TaggedForm [(form Sexp) (module (Option (slice u8)))])

(defstruct Alias [(alias (slice u8)) (target (slice u8))])
(defsum UseSpec
  (UAll   [])
  (UNames [(names (ptr (ArrayList (slice u8))))]))
(defstruct Use [(target (slice u8)) (spec UseSpec)])

(defstruct ModImports
  [(aliases   (ArrayList Alias))
   (uses      (ArrayList Use))
   (reexports (ArrayList (slice u8)))])

(defstruct ImpEntry [(name (slice u8)) (imp ModImports)])
(defstruct ExpEntry [(name (slice u8)) (names (ArrayList (slice u8)))])

(defstruct LS
  [(a       (ptr Allocator))
   (out     (ArrayList TaggedForm))
   (loaded  (ArrayList (slice u8)))
   (imports (ArrayList ImpEntry))
   (exports (ArrayList ExpEntry))
   ; Next SourceMap id to hand out. Main file is source 0 (read in the dump entry),
   ; so this starts at 1; the prelude then takes 1, each import the next (a duplicate
   ; import still consumes an id, mirroring src/macros.rs sm.add before dedup).
   (srccount i64)])

(defstruct Resolved [(text (slice u8)) (incdir (slice u8))])

; ============================ loader helpers (copied) ======================
(defn mk-tagged [(form Sexp) (module (Option (slice u8)))] (-> TaggedForm)
  (let [p (alloc-stack TaggedForm)]
    (store! (field p form) form) (store! (field p module) module)
    (load p)))

(defn loader-abort [(msg (slice u8))] (-> i64)
  (let [w (stderr)] (ps w "loader error: ") (ps w msg) (wb w 10))
  (abort)
  0)

(defn cstr-len [(p (ptr i8))] (-> i64)
  (let [(mut i) 0]
    (loop (if (icmp-eq (cast i64 (load (index p (load i)))) 0) (break)
            (store! i (iadd (load i) 1))))
    (load i)))
(defn cstr->slice [(p (ptr i8))] (-> (slice u8))
  (slice-new [u8] (cast (ptr u8) p) (cstr-len p)))

(defn cwd-slice [(a (ptr Allocator))] (-> (slice u8))
  (let [buf (unwrap-ptr [i8] (raw-alloc a 4096 1))
        r (getcwd buf 4096)]
    (if (icmp-eq (cast i64 r) 0)
        (do (loader-abort "getcwd failed") "")
        (cstr->slice buf))))

(defn path-join [(a (ptr Allocator)) (base (slice u8)) (path (slice u8))] (-> (slice u8))
  (if (and (icmp-gt (slice-len path) 0) (icmp-eq (cast i64 (slice-get path 0)) 47))
      path
      (let [m1 (match (str-concat a base "/") (Some [v] v) (None [] ""))]
        (match (str-concat a m1 path) (Some [v] v) (None [] "")))))

(defn dirname [(p (slice u8))] (-> (slice u8))
  (let [n (slice-len p) (mut idx) -1 (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-eq (cast i64 (slice-get p (load i))) 47) (store! idx (load i)) 0)
          (store! i (iadd (load i) 1)))))
    (if (icmp-lt (load idx) 0) "." (subslice p 0 (load idx)))))

(defn basename [(p (slice u8))] (-> (slice u8))
  (let [n (slice-len p) (mut idx) -1 (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-eq (cast i64 (slice-get p (load i))) 47) (store! idx (load i)) 0)
          (store! i (iadd (load i) 1)))))
    (if (icmp-lt (load idx) 0) p (subslice p (iadd (load idx) 1) n))))

(defn bundled? [(name (slice u8))] (-> bool)
  (let [(mut f) false]
    (if (str-eq name "alloc.coil")     (do (store! f true) 0) 0)
    (if (str-eq name "arraylist.coil") (do (store! f true) 0) 0)
    (if (str-eq name "atomic.coil")    (do (store! f true) 0) 0)
    (if (str-eq name "closure.coil")   (do (store! f true) 0) 0)
    (if (str-eq name "control.coil")   (do (store! f true) 0) 0)
    (if (str-eq name "derive.coil")    (do (store! f true) 0) 0)
    (if (str-eq name "fmt.coil")       (do (store! f true) 0) 0)
    (if (str-eq name "hashmap.coil")   (do (store! f true) 0) 0)
    (if (str-eq name "io.coil")        (do (store! f true) 0) 0)
    (if (str-eq name "match.coil")     (do (store! f true) 0) 0)
    (if (str-eq name "mem.coil")       (do (store! f true) 0) 0)
    (if (str-eq name "mmio.coil")      (do (store! f true) 0) 0)
    (if (str-eq name "print.coil")     (do (store! f true) 0) 0)
    (if (str-eq name "result.coil")    (do (store! f true) 0) 0)
    (if (str-eq name "sexp.coil")      (do (store! f true) 0) 0)
    (if (str-eq name "simd.coil")      (do (store! f true) 0) 0)
    (if (str-eq name "slice.coil")     (do (store! f true) 0) 0)
    (if (str-eq name "str.coil")       (do (store! f true) 0) 0)
    (if (str-eq name "thread.coil")    (do (store! f true) 0) 0)
    (if (str-eq name "try.coil")       (do (store! f true) 0) 0)
    (load f)))

(defn resolve-source [(a (ptr Allocator)) (base (slice u8)) (path (slice u8))] (-> Resolved)
  (let [joined (path-join a base path)
        jc (slice->cstr a joined)
        buf (unwrap-ptr [i8] (raw-alloc a 4096 1))
        r (realpath jc buf)]
    (if (icmp-ne (cast i64 r) 0)
        (let [canon (cstr->slice buf)
              text (read-file a buf)
              incdir (dirname canon)
              rp (alloc-stack Resolved)]
          (store! (field rp text) text) (store! (field rp incdir) incdir)
          (load rp))
        (let [bn (basename path)]
          (if (bundled? bn)
              (let [libpath (path-join a "lib" bn)
                    lc (slice->cstr a libpath)
                    text (read-file a lc)
                    rp (alloc-stack Resolved)]
                (store! (field rp text) text) (store! (field rp incdir) base)
                (load rp))
              (do (loader-abort "import: not found (no such file, not bundled)")
                  (zeroed Resolved)))))))

(defn l-as-list [(f (ptr Sexp))] (-> (ptr (ArrayList Sexp)))
  (match (load (field f kind))
    (KList [items] items)
    (KInt   [_] (do (loader-abort "expected a list") (box-items (malloc-allocator) (al-new [Sexp] (malloc-allocator)))))
    (KFloat [_] (do (loader-abort "expected a list") (box-items (malloc-allocator) (al-new [Sexp] (malloc-allocator)))))
    (KSym   [_] (do (loader-abort "expected a list") (box-items (malloc-allocator) (al-new [Sexp] (malloc-allocator)))))
    (KKw    [_] (do (loader-abort "expected a list") (box-items (malloc-allocator) (al-new [Sexp] (malloc-allocator)))))
    (KStr   [_] (do (loader-abort "expected a list") (box-items (malloc-allocator) (al-new [Sexp] (malloc-allocator)))))
    (KCStr  [_] (do (loader-abort "expected a list") (box-items (malloc-allocator) (al-new [Sexp] (malloc-allocator)))))
    (KVec   [_] (do (loader-abort "expected a list") (box-items (malloc-allocator) (al-new [Sexp] (malloc-allocator)))))))

(defn l-sym-name [(f (ptr Sexp))] (-> (Option (slice u8)))
  (match (load (field f kind))
    (KSym   [s] (Some s))
    (KInt   [_] (None [(slice u8)]))
    (KFloat [_] (None [(slice u8)]))
    (KKw    [_] (None [(slice u8)]))
    (KStr   [_] (None [(slice u8)]))
    (KCStr  [_] (None [(slice u8)]))
    (KList  [_] (None [(slice u8)]))
    (KVec   [_] (None [(slice u8)]))))

(defn l-list-head [(f (ptr Sexp))] (-> (Option (slice u8)))
  (match (load (field f kind))
    (KList [items]
      (if (icmp-gt (al-len [Sexp] (load items)) 0)
          (let [h (alloc-stack Sexp)] (store! h (al-get [Sexp] (load items) 0)) (l-sym-name h))
          (None [(slice u8)])))
    (KInt   [_] (None [(slice u8)]))
    (KFloat [_] (None [(slice u8)]))
    (KSym   [_] (None [(slice u8)]))
    (KKw    [_] (None [(slice u8)]))
    (KStr   [_] (None [(slice u8)]))
    (KCStr  [_] (None [(slice u8)]))
    (KVec   [_] (None [(slice u8)]))))

(defn l-as-str [(f (ptr Sexp))] (-> (Option (slice u8)))
  (match (load (field f kind))
    (KStr   [s] (Some s))
    (KInt   [_] (None [(slice u8)]))
    (KFloat [_] (None [(slice u8)]))
    (KSym   [_] (None [(slice u8)]))
    (KKw    [_] (None [(slice u8)]))
    (KCStr  [_] (None [(slice u8)]))
    (KList  [_] (None [(slice u8)]))
    (KVec   [_] (None [(slice u8)]))))

(defn module-name [(f (ptr Sexp))] (-> (slice u8))
  (let [items (l-as-list f) n (al-len [Sexp] (load items))]
    (if (icmp-lt n 2)
        (do (loader-abort "module: expected a name") "")
        (let [it (alloc-stack Sexp)] (store! it (al-get [Sexp] (load items) 1))
          (match (l-sym-name it)
            (Some [x] x)
            (None []  (do (loader-abort "module: expected a name") "")))))))

(defn declared-module [(forms (ptr (ArrayList Sexp)))] (-> (Option (slice u8)))
  (let [n (al-len [Sexp] (load forms)) (mut res) (None [(slice u8)]) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [f (alloc-stack Sexp)] (store! f (al-get [Sexp] (load forms) (load i)))
            (match (l-list-head f)
              (Some [h] (if (str-eq h "module") (do (store! res (Some (module-name f))) (break)) 0))
              (None []  0)))
          (store! i (iadd (load i) 1)))))
    (load res)))

(defn collect-syms [(a (ptr Allocator)) (items (ptr (ArrayList Sexp)))] (-> (ptr (ArrayList (slice u8))))
  (let [n (al-len [Sexp] (load items)) (mut out) (al-new [(slice u8)] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [it (alloc-stack Sexp)] (store! it (al-get [Sexp] (load items) (load i)))
            (match (l-sym-name it) (Some [nm] (al-push! (mut out) nm)) (None [] 0)))
          (store! i (iadd (load i) 1)))))
    (let [bp (unwrap-ptr [(ArrayList (slice u8))] (create [(ArrayList (slice u8))] a))]
      (store! bp (load out)) bp)))

(defn imp-elem [(s (mut LS)) (i i64)] (-> (ptr ImpEntry))
  (let [hdr (alloc-stack (ArrayList ImpEntry))]
    (store! hdr (load (field s imports)))
    (index (load (field hdr data)) i)))
(defn exp-elem [(s (mut LS)) (i i64)] (-> (ptr ExpEntry))
  (let [hdr (alloc-stack (ArrayList ExpEntry))]
    (store! hdr (load (field s exports)))
    (index (load (field hdr data)) i)))

(defn imp-entry [(s (mut LS)) (name (slice u8))] (-> (ptr ImpEntry))
  (let [n (al-len [ImpEntry] (load (field s imports))) (mut idx) -1 (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (imp-elem (mut s) (load i)) name)) name)
              (do (store! idx (load i)) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (if (icmp-ge (load idx) 0)
        (imp-elem (mut s) (load idx))
        (let [e (alloc-stack ImpEntry) a (load (field s a))]
          (store! (field e name) name)
          (store! (field (field e imp) aliases)   (al-new [Alias] a))
          (store! (field (field e imp) uses)      (al-new [Use] a))
          (store! (field (field e imp) reexports) (al-new [(slice u8)] a))
          (al-push! (mut (field s imports)) (load e))
          (imp-elem (mut s) n)))))

(defn exp-entry [(s (mut LS)) (name (slice u8))] (-> (ptr ExpEntry))
  (let [n (al-len [ExpEntry] (load (field s exports))) (mut idx) -1 (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (exp-elem (mut s) (load i)) name)) name)
              (do (store! idx (load i)) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (if (icmp-ge (load idx) 0)
        (exp-elem (mut s) (load idx))
        (let [e (alloc-stack ExpEntry) a (load (field s a))]
          (store! (field e name) name)
          (store! (field e names) (al-new [(slice u8)] a))
          (al-push! (mut (field s exports)) (load e))
          (exp-elem (mut s) n)))))

(defn ee-add-name! [(e (ptr ExpEntry)) (name (slice u8))] (-> i64)
  (let [n (al-len [(slice u8)] (load (field e names))) (mut found) false (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (al-get [(slice u8)] (load (field e names)) (load i)) name) (do (store! found true) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (if (load found) 0 (al-push! (mut (field e names)) name))))

(defn mi-add-alias! [(e (ptr ImpEntry)) (alias (slice u8)) (target (slice u8))] (-> i64)
  (let [n (al-len [Alias] (load (field (field e imp) aliases))) (mut idx) -1 (mut i) 0
        v (let [ap (alloc-stack Alias)] (store! (field ap alias) alias) (store! (field ap target) target) (load ap))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (let [ep (alloc-stack Alias)] (store! ep (al-get [Alias] (load (field (field e imp) aliases)) (load i))) (load (field ep alias))) alias)
              (do (store! idx (load i)) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (if (icmp-ge (load idx) 0)
        (al-set! [Alias] (mut (field (field e imp) aliases)) (load idx) v)
        (al-push! (mut (field (field e imp) aliases)) v))))

(defn mi-add-use! [(e (ptr ImpEntry)) (target (slice u8)) (spec UseSpec)] (-> i64)
  (let [u (alloc-stack Use)] (store! (field u target) target) (store! (field u spec) spec)
    (al-push! (mut (field (field e imp) uses)) (load u))))

(defn mi-add-reexport! [(e (ptr ImpEntry)) (target (slice u8))] (-> i64)
  (al-push! (mut (field (field e imp) reexports)) target))

(defn loaded-insert! [(s (mut LS)) (name (slice u8))] (-> bool)
  (let [n (al-len [(slice u8)] (load (field s loaded))) (mut found) false (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (al-get [(slice u8)] (load (field s loaded)) (load i)) name) (do (store! found true) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (if (load found) false (do (al-push! (mut (field s loaded)) name) true))))

(defn handle-export [(s (mut LS)) (f (ptr Sexp)) (cur (Option (slice u8)))] (-> i64)
  (match cur
    (Some [m]
      (let [items (l-as-list f) n (al-len [Sexp] (load items)) ep (exp-entry (mut s) m) (mut i) 1]
        (loop (if (icmp-ge (load i) n) (break)
          (do (let [it (alloc-stack Sexp)] (store! it (al-get [Sexp] (load items) (load i)))
                (match (l-sym-name it)
                  (Some [nm] (ee-add-name! ep nm))
                  (None []   (do (loader-abort "export: names must be symbols") 0))))
              (store! i (iadd (load i) 1)))))
        0))
    (None [] (do (loader-abort "export: only valid inside a (module …)") 0))))

(defn process-import [(s (mut LS)) (form (ptr Sexp)) (base (slice u8)) (cur (Option (slice u8)))] (-> i64)
  (let [a (load (field s a))
        items (l-as-list form) nit (al-len [Sexp] (load items))
        path (if (icmp-lt nit 2)
                 (do (loader-abort "import: expected (import \"path\" [:as alias])") "")
                 (let [it (alloc-stack Sexp)] (store! it (al-get [Sexp] (load items) 1))
                   (match (l-as-str it)
                     (Some [p] p)
                     (None []  (do (loader-abort "import: expected (import \"path\" [:as alias])") "")))))
        (mut alias)    (None [(slice u8)])
        (mut use-spec) (None [UseSpec])
        (mut reexport) false
        (mut i) 2]
    (loop (if (icmp-ge (load i) nit) (break)
      (let [it (alloc-stack Sexp)] (store! it (al-get [Sexp] (load items) (load i)))
        (match (load (field it kind))
          (KKw [k]
            (if (str-eq k "as")
                (let [a2 (alloc-stack Sexp)] (store! a2 (al-get [Sexp] (load items) (iadd (load i) 1)))
                  (match (l-sym-name a2)
                    (Some [al] (do (store! alias (Some al)) (store! i (iadd (load i) 2))))
                    (None []   (do (loader-abort "import: :as expects an alias symbol") (store! i (iadd (load i) 2))))))
              (if (str-eq k "reexport")
                  (do (store! reexport true) (store! i (iadd (load i) 1)))
                (if (str-eq k "use")
                    (let [v2 (alloc-stack Sexp)] (store! v2 (al-get [Sexp] (load items) (iadd (load i) 1)))
                      (match (load (field v2 kind))
                        (KSym [sm] (if (str-eq sm "*")
                                       (do (store! use-spec (Some (UAll))) (store! i (iadd (load i) 2)))
                                       (do (loader-abort "import: :use expects * or [names]") (store! i (iadd (load i) 2)))))
                        (KVec [vit] (do (store! use-spec (Some (UNames (collect-syms a vit)))) (store! i (iadd (load i) 2))))
                        (KInt   [_] (do (loader-abort "import: :use expects * or [names]") (store! i (iadd (load i) 2))))
                        (KFloat [_] (do (loader-abort "import: :use expects * or [names]") (store! i (iadd (load i) 2))))
                        (KKw    [_] (do (loader-abort "import: :use expects * or [names]") (store! i (iadd (load i) 2))))
                        (KStr   [_] (do (loader-abort "import: :use expects * or [names]") (store! i (iadd (load i) 2))))
                        (KCStr  [_] (do (loader-abort "import: :use expects * or [names]") (store! i (iadd (load i) 2))))
                        (KList  [_] (do (loader-abort "import: :use expects * or [names]") (store! i (iadd (load i) 2))))))
                  (do (loader-abort "import: expected :as alias, :use *|[names], or :reexport") (store! i (iadd (load i) 1)))))))
          (KInt   [_] (do (loader-abort "import: expected :as alias, :use *|[names], or :reexport") (store! i (iadd (load i) 1))))
          (KFloat [_] (do (loader-abort "import: expected :as alias, :use *|[names], or :reexport") (store! i (iadd (load i) 1))))
          (KSym   [_] (do (loader-abort "import: expected :as alias, :use *|[names], or :reexport") (store! i (iadd (load i) 1))))
          (KStr   [_] (do (loader-abort "import: expected :as alias, :use *|[names], or :reexport") (store! i (iadd (load i) 1))))
          (KCStr  [_] (do (loader-abort "import: expected :as alias, :use *|[names], or :reexport") (store! i (iadd (load i) 1))))
          (KList  [_] (do (loader-abort "import: expected :as alias, :use *|[names], or :reexport") (store! i (iadd (load i) 1))))
          (KVec   [_] (do (loader-abort "import: expected :as alias, :use *|[names], or :reexport") (store! i (iadd (load i) 1))))))))
    (let [rr (resolve-source a base path)
          rp (alloc-stack Resolved)]
      (store! rp rr)
      (let [text (load (field rp text)) incdir (load (field rp incdir))
            ; A source id is claimed for EVERY import (before the load-once dedup),
            ; exactly like src/macros.rs registers the source then dedups.
            inc-id (load (field s srccount))
            _ignore (store! (field s srccount) (iadd inc-id 1))]
        (match (read-all a text inc-id)
          (Err [d] (do (loader-abort "import: read error in imported file") 0))
          (Ok [inc-forms]
            (let [modname (match (declared-module inc-forms)
                            (Some [m] m)
                            (None []  (do (loader-abort "import: file has no (module …) declaration") "")))
                  importer (match cur (Some [m] m) (None [] ""))
                  imp (imp-entry (mut s) importer)
                  alias-name (match (load alias) (Some [al] al) (None [] modname))]
              (mi-add-alias! imp alias-name modname)
              (match (load use-spec)
                (Some [spec] (mi-add-use! imp modname spec))
                (None []     0))
              (if (load reexport) (mi-add-reexport! imp modname) 0)
              (if (loaded-insert! (mut s) modname)
                  (process-forms (mut s) inc-forms incdir (None [(slice u8)]))
                  0)
              0)))))))

(defn process-forms [(s (mut LS)) (forms (ptr (ArrayList Sexp))) (base (slice u8)) (cur0 (Option (slice u8)))] (-> i64)
  (let [n (al-len [Sexp] (load forms)) (mut cur) (None [(slice u8)]) (mut i) 0]
    (store! cur cur0)
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [f (alloc-stack Sexp)] (store! f (al-get [Sexp] (load forms) (load i)))
            (match (l-list-head f)
              (Some [h]
                (if (str-eq h "module")
                    (let [name (module-name f)] (imp-entry (mut s) name) (store! cur (Some name)) 0)
                  (if (str-eq h "export")
                      (handle-export (mut s) f (load cur))
                    (if (str-eq h "import")
                        (match (load cur)
                          (Some [m] (process-import (mut s) f base (load cur)))
                          (None []  (do (loader-abort "import requires a (module …) declaration") 0)))
                      (al-push! (mut (field s out)) (mk-tagged (load f) (load cur)))))))
              (None []
                (al-push! (mut (field s out)) (mk-tagged (load f) (load cur))))))
          (store! i (iadd (load i) 1)))))
    0))

(defn load-program [(s (mut LS)) (forms (ptr (ArrayList Sexp))) (base (slice u8))] (-> i64)
  (let [a (load (field s a))
        prelude-text (read-file a (slice->cstr a "src/prelude.coil"))
        ; The prelude is its own source (id 1: main is 0, claimed in the dump entry).
        prelude-id (load (field s srccount))
        _ignore (store! (field s srccount) (iadd prelude-id 1))]
    (match (read-all a prelude-text prelude-id)
      (Err [d] (do (loader-abort "read error in prelude") 0))
      (Ok [pf]  (process-forms (mut s) pf base (None [(slice u8)]))))
    (process-forms (mut s) forms base (None [(slice u8)]))
    0))

; ============================ resolve representation =======================
; Mirrors src/resolve.rs. `Defs` = a module's definition names split by namespace
; (HashSets become ArrayLists, membership = linear str-eq scan). `DefTable` =
; per-module Defs (ArrayList of DefEntry). `ParsedForm` = one tagged form parsed
; into its own Program, retaining its module identity.
; `Defs` sets are BY-VALUE ArrayLists so names can be pushed via (field …).
(defstruct Defs
  [(callables (ArrayList (slice u8)))
   (types     (ArrayList (slice u8)))
   (traits    (ArrayList (slice u8)))
   (convs     (ArrayList (slice u8)))
   (externs   (ArrayList (slice u8)))])
(defstruct DefEntry [(module (slice u8)) (defs Defs)])
(defstruct ParsedForm [(prog (ptr Program)) (module (Option (slice u8)))])

; One-field wrapper structs: an `(ArrayList X)` BY VALUE inside a heap struct, so it
; can be GROWN via the field place `(field box items)` (al-push! needs a place; a
; bare `(ptr (ArrayList X))` cannot be pushed into). `(field box items)` is itself a
; `(ptr (ArrayList X))`, usable directly for read-only queries (table-find etc.).
(defstruct PBox [(items (ArrayList ParsedForm))])
(defstruct TBox [(items (ArrayList DefEntry))])
(defstruct SBox [(items (ArrayList (slice u8)))])

; The threaded resolution context (mirrors the args of src/resolve.rs::resolve /
; qualify_*). `m`/`imp` change per module; `strict`/`bareok` are constant for the
; whole program (dump-resolved resolves with strict=true).
(defstruct Ctx
  [(a (ptr Allocator)) (m (slice u8)) (imp (ptr ImpEntry))
   (table (ptr (ArrayList DefEntry))) (exp (ptr (ArrayList ExpEntry)))
   (strict bool) (bareok (ptr (ArrayList (slice u8))))])

; The merged output program, sections as BY-VALUE ArrayLists so merge can push.
(defstruct Out
  [(conventions (ArrayList Convention))
   (structs (ArrayList StructDef))
   (sums (ArrayList SumDef))
   (externs (ArrayList Extern))
   (funcs (ArrayList Func))
   (asserts (ArrayList StaticAssert))
   (consts (ArrayList Const))
   (traits (ArrayList TraitDef))
   (impls (ArrayList ImplDef))
   (metas (ArrayList Expr))
   (exports (ArrayList ExportC))])

; ---- small generic + string helpers ---------------------------------------
; pointer to element i of an ArrayList reached by pointer (live, mutable).
(defn al-elem [T] [(p (ptr (ArrayList T))) (i i64)] (-> (ptr T))
  (index (load (field p data)) i))

(defn booleq [(x bool) (y bool)] (-> bool)
  (or (and x y) (and (not x) (not y))))

(defn has-dot [(s (slice u8))] (-> bool)
  (let [n (slice-len s) (mut i) 0 (mut f) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-eq (cast i64 (slice-get s (load i))) 46) (do (store! f true) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load f)))

(defn find-slash [(s (slice u8))] (-> i64)
  (let [n (slice-len s) (mut i) 0 (mut r) -1]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-eq (cast i64 (slice-get s (load i))) 47) (do (store! r (load i)) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))

(defn empty-strs [(a (ptr Allocator))] (-> (ptr (ArrayList (slice u8))))
  (let [bp (unwrap-ptr [(ArrayList (slice u8))] (create [(ArrayList (slice u8))] a))]
    (store! bp (al-new [(slice u8)] a)) bp))

; src/ast.rs is_scalar_typename: bool / f32 / f64 / (i|u)<digits>.
(defn is-scalar-typename [(s (slice u8))] (-> bool)
  (if (str-eq s "bool") true
    (if (str-eq s "f32") true
      (if (str-eq s "f64") true
        (let [n (slice-len s)]
          (if (icmp-lt n 2) false
            (let [c0 (cast i64 (slice-get s 0))]
              (if (or (icmp-eq c0 105) (icmp-eq c0 117))
                  (let [(mut ok) true (mut j) 1]
                    (loop (if (icmp-ge (load j) n) (break)
                      (do (let [ch (cast i64 (slice-get s (load j)))]
                            (if (and (icmp-ge ch 48) (icmp-le ch 57)) 0 (do (store! ok false) (break))))
                          (store! j (iadd (load j) 1)))))
                    (load ok))
                  false))))))))

; ---- error messages (faithful to src/resolve.rs) --------------------------
(defn priv-msg [(a (ptr Allocator)) (m (slice u8)) (rest (slice u8)) (target (slice u8))] (-> (slice u8))
  (let [p1 (sconcat3 a "in module '" m "': '")
        p2 (sconcat3 a p1 rest "' is private to module '")]
    (sconcat3 a p2 target "' (add it to that module's (export …))")))
(defn undef-msg [(a (ptr Allocator)) (m (slice u8)) (func (slice u8))] (-> (slice u8))
  (let [p1 (sconcat3 a "in module '" m "': call to undefined function '")]
    (sconcat3 a p1 func "'")))
(defn extern-conflict-msg [(a (ptr Allocator)) (nm (slice u8))] (-> (slice u8))
  (sconcat3 a "extern '" nm "' declared with conflicting signatures"))
(defn const-dup-msg [(a (ptr Allocator)) (nm (slice u8))] (-> (slice u8))
  (sconcat3 a "const '" nm "' defined more than once"))

; ---- table / import / export queries --------------------------------------
(defn defs-set [(d (ptr Defs)) (kind i64)] (-> (ptr (ArrayList (slice u8))))
  (if (icmp-eq kind 0) (field d callables)
    (if (icmp-eq kind 1) (field d types)
      (if (icmp-eq kind 2) (field d traits)
        (if (icmp-eq kind 3) (field d convs)
          (field d externs))))))

(defn set-contains [(setp (ptr (ArrayList (slice u8)))) (name (slice u8))] (-> bool)
  (let [n (al-len [(slice u8)] (load setp)) (mut i) 0 (mut f) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (al-get [(slice u8)] (load setp) (load i)) name) (do (store! f true) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load f)))

(defn table-find [(table (ptr (ArrayList DefEntry))) (m (slice u8))] (-> (ptr DefEntry))
  (let [n (al-len [DefEntry] (load table)) (mut i) 0 (mut r) (cast (ptr DefEntry) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [DefEntry] table (load i)) module)) m)
              (do (store! r (al-elem [DefEntry] table (load i))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))

(defn imports-find [(impb (ptr (ArrayList ImpEntry))) (m (slice u8))] (-> (ptr ImpEntry))
  (let [n (al-len [ImpEntry] (load impb)) (mut i) 0 (mut r) (cast (ptr ImpEntry) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [ImpEntry] impb (load i)) name)) m)
              (do (store! r (al-elem [ImpEntry] impb (load i))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))

; macros::exports — `exports.get(m).map(contains).unwrap_or(true)`.
(defn exports-check [(expb (ptr (ArrayList ExpEntry))) (m (slice u8)) (name (slice u8))] (-> bool)
  (let [n (al-len [ExpEntry] (load expb)) (mut i) 0 (mut found) (cast (ptr ExpEntry) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [ExpEntry] expb (load i)) name)) m)
              (do (store! found (al-elem [ExpEntry] expb (load i))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (if (icmp-eq (cast i64 (load found)) 0) true (set-contains (field (load found) names) name))))

(defn alias-target [(imp (ptr ImpEntry)) (alias (slice u8))] (-> (Option (slice u8)))
  (let [als (field (field imp imp) aliases) n (al-len [Alias] (load als)) (mut i) 0 (mut r) (None [(slice u8)])]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [ep (alloc-stack Alias)] (store! ep (al-get [Alias] (load als) (load i)))
            (if (str-eq (load (field ep alias)) alias)
                (do (store! r (Some (load (field ep target)))) (break)) 0))
          (store! i (iadd (load i) 1)))))
    (load r)))

; the `:use`d-modules branch of resolve (extracted so no try!/return runs in a loop).
(defn resolve-use [(c (ptr Ctx)) (imp (ptr ImpEntry)) (name (slice u8)) (kind i64)] (-> (Option (slice u8)))
  (let [a (load (field c a)) table (load (field c table)) exp (load (field c exp))
        uses (field (field imp imp) uses) n (al-len [Use] (load uses)) (mut i) 0 (mut r) (None [(slice u8)])]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [up (alloc-stack Use)] (store! up (al-get [Use] (load uses) (load i)))
            (let [target (load (field up target))
                  used (match (load (field up spec)) (UAll [] true) (UNames [names] (set-contains names name)))]
              (if (and used (exports-check exp target name))
                  (let [td (table-find table target)]
                    (if (and (icmp-ne (cast i64 td) 0) (set-contains (defs-set (field td defs) kind) name))
                        (do (store! r (Some (sconcat3 a target "." name))) (break)) 0))
                  0)))
          (store! i (iadd (load i) 1)))))
    (load r)))

; src/resolve.rs::resolve — kind: 0 callables, 1 types, 2 traits, 3 convs.
(defn resolve [(c (ptr Ctx)) (name (slice u8)) (kind i64)] (-> (Result (slice u8) Diag))
  (let [a (load (field c a)) m (load (field c m)) imp (load (field c imp))
        table (load (field c table)) exp (load (field c exp)) sl (find-slash name)]
    (if (icmp-ge sl 0)
        (let [alias (subslice name 0 sl) rest (subslice name (iadd sl 1) (slice-len name))]
          (if (icmp-ne (cast i64 imp) 0)
              (match (alias-target imp alias)
                (Some [target]
                  (if (not (exports-check exp target rest))
                      (Err [(slice u8) Diag] (derr (priv-msg a m rest target)))
                      (Ok [(slice u8) Diag] (sconcat3 a target "." rest))))
                (None [] (Ok [(slice u8) Diag] name)))
              (Ok [(slice u8) Diag] name)))
        (let [tf (table-find table m)]
          (if (and (icmp-ne (cast i64 tf) 0) (set-contains (defs-set (field tf defs) kind) name))
              (Ok [(slice u8) Diag] (sconcat3 a m "." name))
              (match (if (icmp-ne (cast i64 imp) 0) (resolve-use c imp name kind) (None [(slice u8)]))
                (Some [q] (Ok [(slice u8) Diag] q))
                (None []
                  (if (not (str-eq m "coil.core"))
                      (let [ct (table-find table "coil.core")]
                        (if (and (and (icmp-ne (cast i64 ct) 0) (set-contains (defs-set (field ct defs) kind) name))
                                 (exports-check exp "coil.core" name))
                            (Ok [(slice u8) Diag] (sconcat3 a "coil.core" "." name))
                            (Ok [(slice u8) Diag] name)))
                      (Ok [(slice u8) Diag] name)))))))))

; ---- type-equality (for extern dedup in merge) ----------------------------
; All take/recurse on `(ptr Type)` — passing a `Type` sum BY VALUE into a recursive
; call corrupts its payload (Coil by-value-aggregate-in-recursion bug), so we keep
; everything behind pointers (as the rest of the resolver does for aggregates).
(defn type-tag [(t (ptr Type))] (-> i64)
  (match (load t) (TInt [_ _] 0) (TFloat [_] 1) (TBool [] 2) (TVoid [] 3) (TPtr [_] 4) (TRef [_ _] 5)
    (TStruct [_] 6) (TArray [_ _] 7) (TSlice [_] 8) (TVec [_ _] 9) (TFn [_ _ _] 10) (TApp [_ _] 11)
    (TNever [] 12) (TCode [] 13)))
(defn t-inner [(t (ptr Type))] (-> (ptr Type))
  (match (load t) (TPtr [i] i) (TRef [_ i] i) (TArray [i _] i) (TSlice [i] i) (TVec [i _] i)
    (TInt [_ _] (do (loader-abort "t-inner: not a wrapper type") (box-type (malloc-allocator) (TVoid))))
    (TFloat [_] (do (loader-abort "t-inner") (box-type (malloc-allocator) (TVoid))))
    (TBool [] (do (loader-abort "t-inner") (box-type (malloc-allocator) (TVoid))))
    (TVoid [] (do (loader-abort "t-inner") (box-type (malloc-allocator) (TVoid))))
    (TStruct [_] (do (loader-abort "t-inner") (box-type (malloc-allocator) (TVoid))))
    (TFn [_ _ _] (do (loader-abort "t-inner") (box-type (malloc-allocator) (TVoid))))
    (TApp [_ _] (do (loader-abort "t-inner") (box-type (malloc-allocator) (TVoid))))
    (TNever [] (do (loader-abort "t-inner") (box-type (malloc-allocator) (TVoid))))
    (TCode [] (do (loader-abort "t-inner") (box-type (malloc-allocator) (TVoid))))))
(defn type-struct-name [(t (ptr Type))] (-> (slice u8))
  (match (load t) (TStruct [n] n)
    (TInt [_ _] (do (loader-abort "type-struct-name: not a struct") ""))
    (TFloat [_] (do (loader-abort "type-struct-name") "")) (TBool [] (do (loader-abort "type-struct-name") ""))
    (TVoid [] (do (loader-abort "type-struct-name") "")) (TPtr [_] (do (loader-abort "type-struct-name") ""))
    (TRef [_ _] (do (loader-abort "type-struct-name") "")) (TArray [_ _] (do (loader-abort "type-struct-name") ""))
    (TSlice [_] (do (loader-abort "type-struct-name") "")) (TVec [_ _] (do (loader-abort "type-struct-name") ""))
    (TFn [_ _ _] (do (loader-abort "type-struct-name") "")) (TApp [_ _] (do (loader-abort "type-struct-name") ""))
    (TNever [] (do (loader-abort "type-struct-name") "")) (TCode [] (do (loader-abort "type-struct-name") ""))))
(defn t-int-bits [(t (ptr Type))] (-> i64) (match (load t) (TInt [b _] b) (TFloat [b] b) (TBool [] 0) (TVoid [] 0) (TPtr [_] 0) (TRef [_ _] 0) (TStruct [_] 0) (TArray [_ _] 0) (TSlice [_] 0) (TVec [_ _] 0) (TFn [_ _ _] 0) (TApp [_ _] 0) (TNever [] 0) (TCode [] 0)))
(defn t-int-signed [(t (ptr Type))] (-> bool) (match (load t) (TInt [_ s] s) (TFloat [_] false) (TBool [] false) (TVoid [] false) (TPtr [_] false) (TRef [_ _] false) (TStruct [_] false) (TArray [_ _] false) (TSlice [_] false) (TVec [_ _] false) (TFn [_ _ _] false) (TApp [_ _] false) (TNever [] false) (TCode [] false)))
(defn t-ref-mut [(t (ptr Type))] (-> bool) (match (load t) (TRef [m _] m) (TInt [_ _] false) (TFloat [_] false) (TBool [] false) (TVoid [] false) (TPtr [_] false) (TStruct [_] false) (TArray [_ _] false) (TSlice [_] false) (TVec [_ _] false) (TFn [_ _ _] false) (TApp [_ _] false) (TNever [] false) (TCode [] false)))
(defn t-arrn [(t (ptr Type))] (-> i64) (match (load t) (TArray [_ n] n) (TVec [_ n] n) (TInt [_ _] 0) (TFloat [_] 0) (TBool [] 0) (TVoid [] 0) (TPtr [_] 0) (TRef [_ _] 0) (TStruct [_] 0) (TSlice [_] 0) (TFn [_ _ _] 0) (TApp [_ _] 0) (TNever [] 0) (TCode [] 0)))
(defn t-fn-cc [(t (ptr Type))] (-> (slice u8)) (match (load t) (TFn [cc _ _] cc) (TInt [_ _] "") (TFloat [_] "") (TBool [] "") (TVoid [] "") (TPtr [_] "") (TRef [_ _] "") (TStruct [_] "") (TArray [_ _] "") (TSlice [_] "") (TVec [_ _] "") (TApp [_ _] "") (TNever [] "") (TCode [] "")))
(defn t-fn-params [(t (ptr Type))] (-> (ptr (ArrayList Type))) (match (load t) (TFn [_ p _] p) (TApp [_ args] args) (TInt [_ _] (box-items-type (malloc-allocator))) (TFloat [_] (box-items-type (malloc-allocator))) (TBool [] (box-items-type (malloc-allocator))) (TVoid [] (box-items-type (malloc-allocator))) (TPtr [_] (box-items-type (malloc-allocator))) (TRef [_ _] (box-items-type (malloc-allocator))) (TStruct [_] (box-items-type (malloc-allocator))) (TArray [_ _] (box-items-type (malloc-allocator))) (TSlice [_] (box-items-type (malloc-allocator))) (TVec [_ _] (box-items-type (malloc-allocator))) (TNever [] (box-items-type (malloc-allocator))) (TCode [] (box-items-type (malloc-allocator)))))
(defn t-fn-ret [(t (ptr Type))] (-> (ptr Type)) (match (load t) (TFn [_ _ r] r) (TInt [_ _] (box-type (malloc-allocator) (TVoid))) (TFloat [_] (box-type (malloc-allocator) (TVoid))) (TBool [] (box-type (malloc-allocator) (TVoid))) (TVoid [] (box-type (malloc-allocator) (TVoid))) (TPtr [_] (box-type (malloc-allocator) (TVoid))) (TRef [_ _] (box-type (malloc-allocator) (TVoid))) (TStruct [_] (box-type (malloc-allocator) (TVoid))) (TArray [_ _] (box-type (malloc-allocator) (TVoid))) (TSlice [_] (box-type (malloc-allocator) (TVoid))) (TVec [_ _] (box-type (malloc-allocator) (TVoid))) (TApp [_ _] (box-type (malloc-allocator) (TVoid))) (TNever [] (box-type (malloc-allocator) (TVoid))) (TCode [] (box-type (malloc-allocator) (TVoid)))))
(defn t-app-name [(t (ptr Type))] (-> (slice u8)) (match (load t) (TApp [n _] n) (TInt [_ _] "") (TFloat [_] "") (TBool [] "") (TVoid [] "") (TPtr [_] "") (TRef [_ _] "") (TStruct [_] "") (TArray [_ _] "") (TSlice [_] "") (TVec [_ _] "") (TFn [_ _ _] "") (TNever [] "") (TCode [] "")))
(defn box-items-type [(a (ptr Allocator))] (-> (ptr (ArrayList Type)))
  (let [bp (unwrap-ptr [(ArrayList Type)] (create [(ArrayList Type)] a))] (store! bp (al-new [Type] a)) bp))

(defn type-list-eq [(xs (ptr (ArrayList Type))) (ys (ptr (ArrayList Type)))] (-> bool)
  (let [nx (al-len [Type] (load xs)) ny (al-len [Type] (load ys))]
    (if (not (icmp-eq nx ny)) false
        (let [(mut i) 0 (mut ok) true]
          (loop (if (icmp-ge (load i) nx) (break)
            (do (if (not (type-eq (al-elem [Type] xs (load i)) (al-elem [Type] ys (load i)))) (do (store! ok false) (break)) 0)
                (store! i (iadd (load i) 1)))))
          (load ok)))))
(defn type-eq [(x (ptr Type)) (y (ptr Type))] (-> bool)
  (if (not (icmp-eq (type-tag x) (type-tag y))) false
    (let [tg (type-tag x)]
      (if (icmp-eq tg 0) (and (icmp-eq (t-int-bits x) (t-int-bits y)) (booleq (t-int-signed x) (t-int-signed y)))
      (if (icmp-eq tg 1) (icmp-eq (t-int-bits x) (t-int-bits y))
      (if (icmp-eq tg 2) true
      (if (icmp-eq tg 3) true
      (if (icmp-eq tg 4) (type-eq (t-inner x) (t-inner y))
      (if (icmp-eq tg 5) (and (booleq (t-ref-mut x) (t-ref-mut y)) (type-eq (t-inner x) (t-inner y)))
      (if (icmp-eq tg 6) (str-eq (type-struct-name x) (type-struct-name y))
      (if (icmp-eq tg 7) (and (icmp-eq (t-arrn x) (t-arrn y)) (type-eq (t-inner x) (t-inner y)))
      (if (icmp-eq tg 8) (type-eq (t-inner x) (t-inner y))
      (if (icmp-eq tg 9) (and (icmp-eq (t-arrn x) (t-arrn y)) (type-eq (t-inner x) (t-inner y)))
      (if (icmp-eq tg 10) (and (str-eq (t-fn-cc x) (t-fn-cc y)) (and (type-list-eq (t-fn-params x) (t-fn-params y)) (type-eq (t-fn-ret x) (t-fn-ret y))))
      (if (icmp-eq tg 11) (and (str-eq (t-app-name x) (t-app-name y)) (type-list-eq (t-fn-params x) (t-fn-params y)))
        true)))))))))))))))

(defn extern-eq [(x (ptr Extern)) (y (ptr Extern))] (-> bool)
  (and (str-eq (load (field x cc)) (load (field y cc)))
    (and (type-list-eq (load (field x params)) (load (field y params)))
      (and (booleq (load (field x variadic)) (load (field y variadic)))
           (type-eq (field x ret) (field y ret))))))

; ============================ check.rs foundation =============================
; display_name (src/check.rs:116) — strip the auto-referred "coil.core." prefix
; from a name for diagnostics. "coil.core." is 10 bytes.
(defn display-name [(n (slice u8))] (-> (slice u8))
  (if (starts-with n "coil.core.")
      (subslice [u8] n 10 (slice-len [u8] n))
      n))

; ty_str (src/check.rs:3017) — render a Type as the human string used in type
; diagnostics. Pointer-accessor style (NOT match-by-value) to avoid the recursive
; sum-by-value tag corruption; mirrors the resolver's type-eq.
(defn ty-str-join [(a (ptr Allocator)) (v (ptr (ArrayList Type)))] (-> (slice u8))
  (let [(mut out) "" n (al-len [Type] (load v)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (do (store! out (sconcat a (load out) " ")) 0) 0)
          (let [tp (alloc-stack Type)] (store! tp (al-get [Type] (load v) (load i)))
            (store! out (sconcat a (load out) (ty-str a tp))))
          (store! i (iadd (load i) 1)))))
    (load out)))

(defn ty-str [(a (ptr Allocator)) (t (ptr Type))] (-> (slice u8))
  (let [tg (type-tag t)]
    (if (icmp-eq tg 12) "!"
    (if (icmp-eq tg 13) "code"
    (if (icmp-eq tg 3) "void"
    (if (icmp-eq tg 0) (sconcat a (if (t-int-signed t) "i" "u") (i64->str a (t-int-bits t)))
    (if (icmp-eq tg 1) (sconcat a "f" (i64->str a (t-int-bits t)))
    (if (icmp-eq tg 2) "bool"
    (if (icmp-eq tg 4) (sconcat3 a "(ptr " (ty-str a (t-inner t)) ")")
    (if (icmp-eq tg 5) (if (t-ref-mut t) (sconcat3 a "(mut " (ty-str a (t-inner t)) ")") (sconcat3 a "(ref " (ty-str a (t-inner t)) ")"))
    (if (icmp-eq tg 6) (type-struct-name t)
    (if (icmp-eq tg 7) (sconcat3 a (sconcat3 a "(array " (ty-str a (t-inner t)) " ") (i64->str a (t-arrn t)) ")")
    (if (icmp-eq tg 8) (sconcat3 a "(slice " (ty-str a (t-inner t)) ")")
    (if (icmp-eq tg 9) (sconcat3 a (sconcat3 a "(vec " (ty-str a (t-inner t)) " ") (i64->str a (t-arrn t)) ")")
    (if (icmp-eq tg 10) (sconcat3 a (sconcat3 a (sconcat3 a "(fnptr " (t-fn-cc t) " [") (ty-str-join a (t-fn-params t)) "] ") (ty-str a (t-fn-ret t)) ")")
    (sconcat3 a (sconcat3 a "(" (t-app-name t) " ") (ty-str-join a (t-fn-params t)) ")"))))))))))))))))

; ---- qualify a Type in place (src/resolve.rs::qualify_type) ----------------
(defn qualify-type-list [(c (ptr Ctx)) (lst (ptr (ArrayList Type))) (tps (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [n (al-len [Type] (load lst)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-type c (al-elem [Type] lst (load i)) tps)
            (Err [d] (do (store! err d) (store! failed true) (break)))
            (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn qualify-type [(c (ptr Ctx)) (typ (ptr Type)) (tps (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [a (load (field c a))]
    (match (load typ)
      (TNever [] (Ok [i64 Diag] 0))
      (TCode  [] (Ok [i64 Diag] 0))
      (TBool  [] (Ok [i64 Diag] 0))
      (TVoid  [] (Ok [i64 Diag] 0))
      (TInt   [_ _] (Ok [i64 Diag] 0))
      (TFloat [_] (Ok [i64 Diag] 0))
      (TStruct [nm]
        (if (set-contains tps nm) (Ok [i64 Diag] 0)
            (match (resolve c nm 1)
              (Err [d] (Err [i64 Diag] d))
              (Ok [nn] (do (store! typ (TStruct nn)) (Ok [i64 Diag] 0))))))
      (TApp [nm args]
        (let [r0 (if (set-contains tps nm) (Ok [i64 Diag] 0)
                     (match (resolve c nm 1) (Err [d] (Err [i64 Diag] d))
                       (Ok [nn] (do (store! typ (TApp nn args)) (Ok [i64 Diag] 0)))))]
          (match r0 (Err [d] (Err [i64 Diag] d))
            (Ok [_] (qualify-type-list c args tps)))))
      (TPtr  [inner] (qualify-type c inner tps))
      (TRef  [mu inner] (qualify-type c inner tps))
      (TArray [inner nn] (qualify-type c inner tps))
      (TSlice [inner] (qualify-type c inner tps))
      (TVec  [inner nn] (qualify-type c inner tps))
      (TFn [cc params ret]
        (match (resolve c cc 3) (Err [d] (Err [i64 Diag] d))
          (Ok [ncc]
            (do (store! typ (TFn ncc params ret))
                (match (qualify-type-list c params tps) (Err [d] (Err [i64 Diag] d))
                  (Ok [_] (qualify-type c ret tps))))))))))

; ---- qualify Exprs / quasi / lists (src/resolve.rs::qualify_expr) ----------
(defn qualify-expr-list [(c (ptr Ctx)) (lst (ptr (ArrayList Expr))) (tps (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [n (al-len [Expr] (load lst)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-expr c (al-elem [Expr] lst (load i)) tps)
            (Err [d] (do (store! err d) (store! failed true) (break)))
            (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn qualify-bind-list [(c (ptr Ctx)) (binds (ptr (ArrayList Bind))) (tps (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [n (al-len [Bind] (load binds)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-expr c (field (al-elem [Bind] binds (load i)) value) tps)
            (Err [d] (do (store! err d) (store! failed true) (break)))
            (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn qualify-arm-list [(c (ptr Ctx)) (arms (ptr (ArrayList Arm))) (tps (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [n (al-len [Arm] (load arms)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [ap (al-elem [Arm] arms (load i))]
            (match (resolve c (load (field ap variant)) 0)
              (Err [d] (do (store! err d) (store! failed true) (break)))
              (Ok [nv] (do (store! (field ap variant) nv)
                           (match (qualify-expr c (field ap body) tps)
                             (Err [d] (do (store! err d) (store! failed true) (break)))
                             (Ok [_] 0))))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn qualify-quasi-list [(c (ptr Ctx)) (items (ptr (ArrayList Quasi))) (tps (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [n (al-len [Quasi] (load items)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-quasi c (al-elem [Quasi] items (load i)) tps)
            (Err [d] (do (store! err d) (store! failed true) (break)))
            (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn qualify-quasi [(c (ptr Ctx)) (qp (ptr Quasi)) (tps (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (match (load qp)
    (QLit [_] (Ok [i64 Diag] 0))
    (QUnquote [e] (qualify-expr c e tps))
    (QSplice [e] (qualify-expr c e tps))
    (QList [items] (qualify-quasi-list c items tps))
    (QVector [items] (qualify-quasi-list c items tps))))
(defn qualify-expr [(c (ptr Ctx)) (ep (ptr Expr)) (tps (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [a (load (field c a))]
    (try
      (do
        (match (load (field ep kind))
          (EInt   [_] 0) (EFloat [_] 0) (EBool [_] 0) (EStr [_] 0) (ECStr [_] 0) (EVar [_] 0)
          (EZeroed [t] (do (let [tp (alloc-stack Type)] (store! tp t) (try! (qualify-type c tp tps)) (store! (field ep kind) (EZeroed (load tp)))) 0))
          (EBorrow [mu place] (do (try! (qualify-expr c place tps)) 0))
          (ELet [binds body] (do (try! (qualify-bind-list c binds tps)) (try! (qualify-expr-list c body tps)) 0))
          (EBin [op lhs rhs] (do (try! (qualify-expr c lhs tps)) (try! (qualify-expr c rhs tps)) 0))
          (ENot [inner] (do (try! (qualify-expr c inner tps)) 0))
          (ECmp [op lhs rhs] (do (try! (qualify-expr c lhs tps)) (try! (qualify-expr c rhs tps)) 0))
          (EIf [cnd thn els] (do (try! (qualify-expr c cnd tps)) (try! (qualify-expr c thn tps)) (try! (qualify-expr c els tps)) 0))
          (EDo [body] (do (try! (qualify-expr-list c body tps)) 0))
          (ECall [func type_args args]
            (do (let [nf (try! (resolve c func 0))]
                  (store! (field ep kind) (ECall nf type_args args))
                  (if (and (load (field c strict)) (and (not (has-dot nf)) (not (set-contains (load (field c bareok)) nf))))
                      (return-from :try (Err (derr (undef-msg a (load (field c m)) nf))))
                      0))
                (try! (qualify-type-list c type_args tps))
                (try! (qualify-expr-list c args tps))
                0))
          (EAlloc [storage t] (do (let [tp (alloc-stack Type)] (store! tp t) (try! (qualify-type c tp tps)) (store! (field ep kind) (EAlloc storage (load tp)))) 0))
          (EField [p fname] (do (try! (qualify-expr c p tps)) 0))
          (ELoad [inner] (do (try! (qualify-expr c inner tps)) 0))
          (EStore [p val] (do (try! (qualify-expr c p tps)) (try! (qualify-expr c val tps)) 0))
          (EIndex [p idx] (do (try! (qualify-expr c p tps)) (try! (qualify-expr c idx tps)) 0))
          (ECast [t inner] (do (let [tp (alloc-stack Type)] (store! tp t) (try! (qualify-type c tp tps)) (store! (field ep kind) (ECast (load tp) inner))) (try! (qualify-expr c inner tps)) 0))
          (ESizeOf [t] (do (let [tp (alloc-stack Type)] (store! tp t) (try! (qualify-type c tp tps)) (store! (field ep kind) (ESizeOf (load tp)))) 0))
          (EAlignOf [t] (do (let [tp (alloc-stack Type)] (store! tp t) (try! (qualify-type c tp tps)) (store! (field ep kind) (EAlignOf (load tp)))) 0))
          (EOffsetOf [t fname] (do (let [tp (alloc-stack Type)] (store! tp t) (try! (qualify-type c tp tps)) (store! (field ep kind) (EOffsetOf (load tp) fname))) 0))
          (EBitGet [p fname] (do (try! (qualify-expr c p tps)) 0))
          (EBitSet [p fname val] (do (try! (qualify-expr c p tps)) (try! (qualify-expr c val tps)) 0))
          (EFree [inner] (do (try! (qualify-expr c inner tps)) 0))
          (EErase [trait_name inner]
            (do (let [tp (alloc-stack Type)] (store! tp (TStruct trait_name)) (try! (qualify-type c tp tps))
                  (store! (field ep kind) (EErase (type-struct-name tp) inner)))
                (try! (qualify-expr c inner tps)) 0))
          (EMatch [scrut arms] (do (try! (qualify-expr c scrut tps)) (try! (qualify-arm-list c arms tps)) 0))
          (EFnPtrOf [nm] (do (let [nn (try! (resolve c nm 0))] (store! (field ep kind) (EFnPtrOf nn))) 0))
          (ECallPtr [fp args] (do (try! (qualify-expr c fp tps)) (try! (qualify-expr-list c args tps)) 0))
          (ELoop [label body] (do (try! (qualify-expr-list c body tps)) 0))
          (EBreak [label value] (do (match value (Some [vp] (try! (qualify-expr c vp tps))) (None [] 0)) 0))
          (EContinue [label] 0)
          (ELlvmIr [result args body] (do (let [tp (alloc-stack Type)] (store! tp result) (try! (qualify-type c tp tps)) (store! (field ep kind) (ELlvmIr (load tp) args body))) (try! (qualify-expr-list c args tps)) 0))
          (ETypeQuery [q t] (do (let [tp (alloc-stack Type)] (store! tp t) (try! (qualify-type c tp tps)) (store! (field ep kind) (ETypeQuery q (load tp)))) 0))
          (EFieldMeta [meta t idx] (do (let [tp (alloc-stack Type)] (store! tp t) (try! (qualify-type c tp tps)) (store! (field ep kind) (EFieldMeta meta (load tp) idx))) (try! (qualify-expr c idx tps)) 0))
          (EFieldIndex [t nm] (do (let [tp (alloc-stack Type)] (store! tp t) (try! (qualify-type c tp tps)) (store! (field ep kind) (EFieldIndex (load tp) nm))) (try! (qualify-expr c nm tps)) 0))
          (EQuote [form] 0)
          (ECodeOp [op args] (do (try! (qualify-expr-list c args tps)) 0))
          (EQuasi [q] (do (let [qp (alloc-stack Quasi)] (store! qp q) (try! (qualify-quasi c qp tps))) 0))
          (EComptime [inner] (do (try! (qualify-expr c inner tps)) 0))
          ; ---- check-introduced variants: cannot occur during resolve (they are
          ; produced by the LATER check pass), so reaching them here is a bug. ----
          (ESpillRef [_] (do (unimplemented "qualify/ESpillRef") 0))
          (EConstruct [_ _ _] (do (unimplemented "qualify/EConstruct") 0))
          (ETraitCall [_ _ _ _] (do (unimplemented "qualify/ETraitCall") 0))
          (EDynDispatch [_ _ _ _ _ _ _ _] (do (unimplemented "qualify/EDynDispatch") 0))
          (EMakeDyn [_ _ _ _] (do (unimplemented "qualify/EMakeDyn") 0))
          (EStaticRef [_] (do (unimplemented "qualify/EStaticRef") 0)))
        (Ok 0)))))

; ---- qualify per-section helpers (src/resolve.rs::qualify_program) ---------
(defn qualify-param-types [(c (ptr Ctx)) (ps (ptr (ArrayList Param))) (tps (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [n (al-len [Param] (load ps)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-type c (field (al-elem [Param] ps (load i)) ty) tps)
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn qualify-field-types [(c (ptr Ctx)) (fs (ptr (ArrayList Field))) (tps (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [n (al-len [Field] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-type c (field (al-elem [Field] fs (load i)) ty) tps)
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn qualify-trait-names [(c (ptr Ctx)) (lst (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [n (al-len [(slice u8)] (load lst)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (resolve c (al-get [(slice u8)] (load lst) (load i)) 2)
            (Err [d] (do (store! err d) (store! failed true) (break)))
            (Ok [nn] (store! (al-elem [(slice u8)] lst (load i)) nn)))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn qualify-bound-list [(c (ptr Ctx)) (bounds (ptr (ArrayList Bound)))] (-> (Result i64 Diag))
  (let [n (al-len [Bound] (load bounds)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-trait-names c (load (field (al-elem [Bound] bounds (load i)) traits)))
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))

(defn qualify-one-func [(c (ptr Ctx)) (fp (ptr Func))] (-> (Result i64 Diag))
  (let [a (load (field c a)) m (load (field c m)) tps (load (field fp type_params))]
    (try
      (do
        (if (not (str-eq (load (field fp name)) "main"))
            (do (store! (field fp name) (sconcat3 a m "." (load (field fp name)))) 0) 0)
        (store! (field fp cc) (try! (resolve c (load (field fp cc)) 3)))
        (try! (qualify-bound-list c (load (field fp bounds))))
        (try! (qualify-param-types c (load (field fp params)) tps))
        (try! (qualify-type c (field fp ret) tps))
        (try! (qualify-expr-list c (load (field fp body)) tps))
        (Ok 0)))))
(defn qualify-one-struct [(c (ptr Ctx)) (sp (ptr StructDef))] (-> (Result i64 Diag))
  (let [a (load (field c a)) m (load (field c m)) tps (load (field sp type_params))]
    (store! (field sp name) (sconcat3 a m "." (load (field sp name))))
    (qualify-field-types c (load (field sp fields)) tps)))
(defn qualify-variants [(c (ptr Ctx)) (vs (ptr (ArrayList Variant))) (m (slice u8)) (a (ptr Allocator)) (tps (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [n (al-len [Variant] (load vs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [vp (al-elem [Variant] vs (load i))]
            (store! (field vp name) (sconcat3 a m "." (load (field vp name))))
            (match (qualify-field-types c (load (field vp fields)) tps)
              (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0)))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn qualify-one-sum [(c (ptr Ctx)) (sp (ptr SumDef))] (-> (Result i64 Diag))
  (let [a (load (field c a)) m (load (field c m)) tps (load (field sp type_params))]
    (store! (field sp name) (sconcat3 a m "." (load (field sp name))))
    (qualify-variants c (load (field sp variants)) m a tps)))
(defn qualify-one-conv [(c (ptr Ctx)) (cp (ptr Convention))] (-> (Result i64 Diag))
  (let [a (load (field c a)) m (load (field c m))]
    (if (not (str-eq (load (field cp name)) "c"))
        (do (store! (field cp name) (sconcat3 a m "." (load (field cp name)))) 0) 0)
    (Ok [i64 Diag] 0)))
(defn qualify-one-extern [(c (ptr Ctx)) (ep (ptr Extern)) (empty (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [a (load (field c a)) m (load (field c m))]
    (try
      (do (store! (field ep name) (sconcat3 a m "." (load (field ep name))))
          (try! (qualify-type-list c (load (field ep params)) empty))
          (try! (qualify-type c (field ep ret) empty))
          (Ok 0)))))
(defn qualify-one-export [(c (ptr Ctx)) (ep (ptr ExportC))] (-> (Result i64 Diag))
  (match (resolve c (load (field ep name)) 0)
    (Err [d] (Err [i64 Diag] d))
    (Ok [nn] (do (store! (field ep name) nn) (Ok [i64 Diag] 0)))))
(defn qualify-one-assert [(c (ptr Ctx)) (ap (ptr StaticAssert)) (empty (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (qualify-expr c (field ap cnd) empty))
(defn qualify-one-const [(c (ptr Ctx)) (kp (ptr Const)) (empty (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (try
    (do (match (load (field kp ty))
          (Some [t] (let [tp (alloc-stack Type)] (store! tp t) (try! (qualify-type c tp empty)) (store! (field kp ty) (Some (load tp))) 0))
          (None [] 0))
        (try! (qualify-expr c (field kp value) empty))
        (Ok 0))))
(defn qualify-trait-methods [(c (ptr Ctx)) (ms (ptr (ArrayList TraitMethod))) (tps (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [n (al-len [TraitMethod] (load ms)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [mp (al-elem [TraitMethod] ms (load i))]
            (match (qualify-param-types c (load (field mp params)) tps)
              (Err [d] (do (store! err d) (store! failed true) (break)))
              (Ok [_] (match (qualify-type c (field mp ret) tps)
                        (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0)))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn qualify-one-trait [(c (ptr Ctx)) (tp (ptr TraitDef))] (-> (Result i64 Diag))
  (let [a (load (field c a)) m (load (field c m)) (mut tl) (al-new [(slice u8)] a)]
    (al-push! (mut tl) (load (field tp self_param)))
    (let [tlb (unwrap-ptr [(ArrayList (slice u8))] (create [(ArrayList (slice u8))] a))]
      (store! tlb (load tl))
      (store! (field tp name) (sconcat3 a m "." (load (field tp name))))
      (qualify-trait-methods c (load (field tp methods)) tlb))))
(defn qualify-impl-method [(c (ptr Ctx)) (fp (ptr Func)) (tps (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (try
    (do (try! (qualify-param-types c (load (field fp params)) tps))
        (try! (qualify-type c (field fp ret) tps))
        (try! (qualify-expr-list c (load (field fp body)) tps))
        (Ok 0))))
(defn qualify-impl-methods [(c (ptr Ctx)) (ms (ptr (ArrayList Func)))] (-> (Result i64 Diag))
  (let [n (al-len [Func] (load ms)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [fp (al-elem [Func] ms (load i))]
            (match (qualify-impl-method c fp (load (field fp type_params)))
              (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0)))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn qualify-one-impl [(c (ptr Ctx)) (ip (ptr ImplDef)) (empty (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [a (load (field c a))]
    (try
      (do (store! (field ip trait_name) (try! (resolve c (load (field ip trait_name)) 2)))
          (if (not (is-scalar-typename (load (field ip for_type))))
              (let [tp (alloc-stack Type)] (store! tp (TStruct (load (field ip for_type))))
                (try! (qualify-type c tp empty))
                (store! (field ip for_type) (type-struct-name tp)) 0)
              0)
          (try! (qualify-impl-methods c (load (field ip methods))))
          (Ok 0)))))

(defn q-funcs [(c (ptr Ctx)) (p (ptr Program))] (-> (Result i64 Diag))
  (let [fs (load (field p funcs)) n (al-len [Func] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-one-func c (al-elem [Func] fs (load i)))
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn q-structs [(c (ptr Ctx)) (p (ptr Program))] (-> (Result i64 Diag))
  (let [fs (load (field p structs)) n (al-len [StructDef] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-one-struct c (al-elem [StructDef] fs (load i)))
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn q-sums [(c (ptr Ctx)) (p (ptr Program))] (-> (Result i64 Diag))
  (let [fs (load (field p sums)) n (al-len [SumDef] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-one-sum c (al-elem [SumDef] fs (load i)))
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn q-convs [(c (ptr Ctx)) (p (ptr Program))] (-> (Result i64 Diag))
  (let [fs (load (field p conventions)) n (al-len [Convention] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-one-conv c (al-elem [Convention] fs (load i)))
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn q-externs [(c (ptr Ctx)) (p (ptr Program)) (empty (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [fs (load (field p externs)) n (al-len [Extern] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-one-extern c (al-elem [Extern] fs (load i)) empty)
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn q-exports [(c (ptr Ctx)) (p (ptr Program))] (-> (Result i64 Diag))
  (let [fs (load (field p exports)) n (al-len [ExportC] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-one-export c (al-elem [ExportC] fs (load i)))
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn q-asserts [(c (ptr Ctx)) (p (ptr Program)) (empty (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [fs (load (field p asserts)) n (al-len [StaticAssert] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-one-assert c (al-elem [StaticAssert] fs (load i)) empty)
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn q-consts [(c (ptr Ctx)) (p (ptr Program)) (empty (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [fs (load (field p consts)) n (al-len [Const] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-one-const c (al-elem [Const] fs (load i)) empty)
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn q-metas [(c (ptr Ctx)) (p (ptr Program)) (empty (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [fs (load (field p metas)) n (al-len [Expr] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-expr c (al-elem [Expr] fs (load i)) empty)
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn q-traits [(c (ptr Ctx)) (p (ptr Program))] (-> (Result i64 Diag))
  (let [fs (load (field p traits)) n (al-len [TraitDef] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-one-trait c (al-elem [TraitDef] fs (load i)))
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn q-impls [(c (ptr Ctx)) (p (ptr Program)) (empty (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [fs (load (field p impls)) n (al-len [ImplDef] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (qualify-one-impl c (al-elem [ImplDef] fs (load i)) empty)
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))

(defn qualify-program [(c (ptr Ctx)) (p (ptr Program))] (-> (Result i64 Diag))
  (let [empty (empty-strs (load (field c a)))]
    (try
      (do (try! (q-funcs c p)) (try! (q-structs c p)) (try! (q-sums c p)) (try! (q-convs c p))
          (try! (q-externs c p empty)) (try! (q-exports c p)) (try! (q-asserts c p empty))
          (try! (q-consts c p empty)) (try! (q-metas c p empty)) (try! (q-traits c p)) (try! (q-impls c p empty))
          (Ok 0)))))

; ---- merge (src/resolve.rs::merge) -----------------------------------------
(defn out-extern [(o (mut Out)) (i i64)] (-> (ptr Extern)) (index (load (field (field o externs) data)) i))
(defn out-const  [(o (mut Out)) (i i64)] (-> (ptr Const))  (index (load (field (field o consts) data)) i))

(defn merge-structs [(o (mut Out)) (p (ptr Program))] (-> i64)
  (let [src (load (field p structs)) n (al-len [StructDef] (load src)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut (field o structs)) (al-get [StructDef] (load src) (load i))) (store! i (iadd (load i) 1)))))) 0)
(defn merge-sums [(o (mut Out)) (p (ptr Program))] (-> i64)
  (let [src (load (field p sums)) n (al-len [SumDef] (load src)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut (field o sums)) (al-get [SumDef] (load src) (load i))) (store! i (iadd (load i) 1)))))) 0)
(defn merge-funcs [(o (mut Out)) (p (ptr Program))] (-> i64)
  (let [src (load (field p funcs)) n (al-len [Func] (load src)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut (field o funcs)) (al-get [Func] (load src) (load i))) (store! i (iadd (load i) 1)))))) 0)
(defn merge-exports [(o (mut Out)) (p (ptr Program))] (-> i64)
  (let [src (load (field p exports)) n (al-len [ExportC] (load src)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut (field o exports)) (al-get [ExportC] (load src) (load i))) (store! i (iadd (load i) 1)))))) 0)
(defn merge-asserts [(o (mut Out)) (p (ptr Program))] (-> i64)
  (let [src (load (field p asserts)) n (al-len [StaticAssert] (load src)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut (field o asserts)) (al-get [StaticAssert] (load src) (load i))) (store! i (iadd (load i) 1)))))) 0)
(defn merge-metas [(o (mut Out)) (p (ptr Program))] (-> i64)
  (let [src (load (field p metas)) n (al-len [Expr] (load src)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut (field o metas)) (al-get [Expr] (load src) (load i))) (store! i (iadd (load i) 1)))))) 0)
(defn merge-traits [(o (mut Out)) (p (ptr Program))] (-> i64)
  (let [src (load (field p traits)) n (al-len [TraitDef] (load src)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut (field o traits)) (al-get [TraitDef] (load src) (load i))) (store! i (iadd (load i) 1)))))) 0)
(defn merge-impls [(o (mut Out)) (p (ptr Program))] (-> i64)
  (let [src (load (field p impls)) n (al-len [ImplDef] (load src)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut (field o impls)) (al-get [ImplDef] (load src) (load i))) (store! i (iadd (load i) 1)))))) 0)
(defn conv-in-out [(o (mut Out)) (name (slice u8))] (-> bool)
  (let [n (al-len [Convention] (load (field o conventions))) (mut i) 0 (mut f) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (conv-name (al-get [Convention] (load (field o conventions)) (load i))) name) (do (store! f true) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load f)))
(defn merge-convs [(o (mut Out)) (p (ptr Program))] (-> i64)
  (let [src (load (field p conventions)) n (al-len [Convention] (load src)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [cv (al-get [Convention] (load src) (load i))]
            (if (conv-in-out (mut o) (conv-name cv)) 0 (al-push! (mut (field o conventions)) cv)))
          (store! i (iadd (load i) 1)))))) 0)
(defn merge-externs [(o (mut Out)) (p (ptr Program)) (a (ptr Allocator))] (-> (Result i64 Diag))
  (let [src (load (field p externs)) n (al-len [Extern] (load src)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [ev (al-get [Extern] (load src) (load i)) esp (alloc-stack Extern)] (store! esp ev)
            (let [nm (load (field esp name)) on (al-len [Extern] (load (field o externs))) (mut idx) -1 (mut j) 0]
              (loop (if (icmp-ge (load j) on) (break)
                (do (if (str-eq (load (field (out-extern (mut o) (load j)) name)) nm) (do (store! idx (load j)) (break)) 0)
                    (store! j (iadd (load j) 1)))))
              (if (icmp-ge (load idx) 0)
                  (if (extern-eq (out-extern (mut o) (load idx)) esp) 0
                      (do (store! err (derr (extern-conflict-msg a nm))) (store! failed true) (break)))
                  (al-push! (mut (field o externs)) ev))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn merge-consts [(o (mut Out)) (p (ptr Program)) (a (ptr Allocator))] (-> (Result i64 Diag))
  (let [src (load (field p consts)) n (al-len [Const] (load src)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [cv (al-get [Const] (load src) (load i)) csp (alloc-stack Const)] (store! csp cv)
            (let [nm (load (field csp name)) on (al-len [Const] (load (field o consts))) (mut dup) false (mut j) 0]
              (loop (if (icmp-ge (load j) on) (break)
                (do (if (str-eq (load (field (out-const (mut o) (load j)) name)) nm) (do (store! dup true) (break)) 0)
                    (store! j (iadd (load j) 1)))))
              (if (load dup)
                  (do (store! err (derr (const-dup-msg a nm))) (store! failed true) (break))
                  (al-push! (mut (field o consts)) cv))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn merge-into [(o (mut Out)) (p (ptr Program)) (a (ptr Allocator))] (-> (Result i64 Diag))
  (merge-convs (mut o) p)
  (merge-structs (mut o) p)
  (merge-sums (mut o) p)
  (match (merge-externs (mut o) p a) (Err [d] (Err [i64 Diag] d))
    (Ok [_]
      (do (merge-funcs (mut o) p) (merge-exports (mut o) p) (merge-asserts (mut o) p) (merge-metas (mut o) p)
          (merge-traits (mut o) p) (merge-impls (mut o) p)
          (merge-consts (mut o) p a)))))

; ---- build the DefTable + bare-ok set (pass 1) ----------------------------
(defn mk-empty-defs [(a (ptr Allocator))] (-> Defs)
  (let [d (alloc-stack Defs)]
    (store! (field d callables) (al-new [(slice u8)] a)) (store! (field d types) (al-new [(slice u8)] a))
    (store! (field d traits) (al-new [(slice u8)] a)) (store! (field d convs) (al-new [(slice u8)] a))
    (store! (field d externs) (al-new [(slice u8)] a))
    (load d)))
(defn table-getc [(a (ptr Allocator)) (tb (ptr TBox)) (m (slice u8))] (-> (ptr DefEntry))
  (let [hit (table-find (field tb items) m)]
    (if (icmp-ne (cast i64 hit) 0) hit
        (let [e (alloc-stack DefEntry) n (al-len [DefEntry] (load (field tb items)))]
          (store! (field e module) m) (store! (field e defs) (mk-empty-defs a))
          (al-push! (mut (field tb items)) (load e))
          (al-elem [DefEntry] (field tb items) n)))))
(defn add-module-defs [(a (ptr Allocator)) (tb (ptr TBox)) (m (slice u8)) (prog (ptr Program))] (-> i64)
  (let [de (table-getc a tb m)]
    ; funcs (non-main) -> callables
    (let [fs (load (field prog funcs)) n (al-len [Func] (load fs)) (mut i) 0]
      (loop (if (icmp-ge (load i) n) (break)
        (do (let [nm (func-name (al-get [Func] (load fs) (load i)))]
              (if (not (str-eq nm "main")) (al-push! (mut (field (field de defs) callables)) nm) 0))
            (store! i (iadd (load i) 1))))))
    ; structs -> types
    (let [fs (load (field prog structs)) n (al-len [StructDef] (load fs)) (mut i) 0]
      (loop (if (icmp-ge (load i) n) (break)
        (do (let [sp (al-elem [StructDef] fs (load i))] (al-push! (mut (field (field de defs) types)) (load (field sp name))))
            (store! i (iadd (load i) 1))))))
    ; sums -> types + variants -> callables
    (let [fs (load (field prog sums)) n (al-len [SumDef] (load fs)) (mut i) 0]
      (loop (if (icmp-ge (load i) n) (break)
        (do (let [sp (al-elem [SumDef] fs (load i))]
              (al-push! (mut (field (field de defs) types)) (load (field sp name)))
              (let [vs (load (field sp variants)) vn (al-len [Variant] (load vs)) (mut j) 0]
                (loop (if (icmp-ge (load j) vn) (break)
                  (do (al-push! (mut (field (field de defs) callables)) (load (field (al-elem [Variant] vs (load j)) name)))
                      (store! j (iadd (load j) 1)))))))
            (store! i (iadd (load i) 1))))))
    ; traits -> traits
    (let [fs (load (field prog traits)) n (al-len [TraitDef] (load fs)) (mut i) 0]
      (loop (if (icmp-ge (load i) n) (break)
        (do (al-push! (mut (field (field de defs) traits)) (load (field (al-elem [TraitDef] fs (load i)) name)))
            (store! i (iadd (load i) 1))))))
    ; conventions (non-c) -> convs
    (let [fs (load (field prog conventions)) n (al-len [Convention] (load fs)) (mut i) 0]
      (loop (if (icmp-ge (load i) n) (break)
        (do (let [nm (conv-name (al-get [Convention] (load fs) (load i)))]
              (if (not (str-eq nm "c")) (al-push! (mut (field (field de defs) convs)) nm) 0))
            (store! i (iadd (load i) 1))))))
    ; externs -> externs + callables
    (let [fs (load (field prog externs)) n (al-len [Extern] (load fs)) (mut i) 0]
      (loop (if (icmp-ge (load i) n) (break)
        (do (let [nm (load (field (al-elem [Extern] fs (load i)) name))]
              (al-push! (mut (field (field de defs) externs)) nm)
              (al-push! (mut (field (field de defs) callables)) nm))
            (store! i (iadd (load i) 1))))))
    0))
(defn build-deftable [(a (ptr Allocator)) (parsed (ptr (ArrayList ParsedForm)))] (-> (ptr (ArrayList DefEntry)))
  (let [tb (unwrap-ptr [TBox] (create [TBox] a))
        n (al-len [ParsedForm] (load parsed)) (mut i) 0]
    (store! (field tb items) (al-new [DefEntry] a))
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [pf (al-elem [ParsedForm] parsed (load i))]
            (match (load (field pf module))
              (Some [m] (add-module-defs a tb m (load (field pf prog))))
              (None [] 0)))
          (store! i (iadd (load i) 1)))))
    (field tb items)))
(defn build-bareok [(a (ptr Allocator)) (parsed (ptr (ArrayList ParsedForm)))] (-> (ptr (ArrayList (slice u8))))
  (let [sb (unwrap-ptr [SBox] (create [SBox] a)) n (al-len [ParsedForm] (load parsed)) (mut i) 0]
    (store! (field sb items) (al-new [(slice u8)] a))
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [prog (load (field (al-elem [ParsedForm] parsed (load i)) prog))
                ts (load (field prog traits)) tn (al-len [TraitDef] (load ts)) (mut j) 0]
            (loop (if (icmp-ge (load j) tn) (break)
              (do (let [tp (al-elem [TraitDef] ts (load j))
                        ms (load (field tp methods)) mn (al-len [TraitMethod] (load ms)) (mut k) 0]
                    (loop (if (icmp-ge (load k) mn) (break)
                      (do (al-push! (mut (field sb items)) (load (field (al-elem [TraitMethod] ms (load k)) name)))
                          (store! k (iadd (load k) 1))))))
                  (store! j (iadd (load j) 1))))))
          (store! i (iadd (load i) 1)))))
    (field sb items)))

; ---- Out -> Program + Ctx/Out init -----------------------------------------
(defn init-out [(o (ptr Out)) (a (ptr Allocator))] (-> i64)
  (store! (field o conventions) (al-new [Convention] a)) (store! (field o structs) (al-new [StructDef] a))
  (store! (field o sums) (al-new [SumDef] a)) (store! (field o externs) (al-new [Extern] a))
  (store! (field o funcs) (al-new [Func] a)) (store! (field o asserts) (al-new [StaticAssert] a))
  (store! (field o consts) (al-new [Const] a)) (store! (field o traits) (al-new [TraitDef] a))
  (store! (field o impls) (al-new [ImplDef] a)) (store! (field o metas) (al-new [Expr] a))
  (store! (field o exports) (al-new [ExportC] a))
  0)
(defn out->program [(o (ptr Out)) (a (ptr Allocator))] (-> (ptr Program))
  (let [pp (unwrap-ptr [Program] (create [Program] a))]
    (store! (field pp conventions) (box-al [Convention] a (load (field o conventions))))
    (store! (field pp structs) (box-al [StructDef] a (load (field o structs))))
    (store! (field pp sums) (box-al [SumDef] a (load (field o sums))))
    (store! (field pp externs) (box-al [Extern] a (load (field o externs))))
    (store! (field pp funcs) (box-al [Func] a (load (field o funcs))))
    (store! (field pp asserts) (box-al [StaticAssert] a (load (field o asserts))))
    (store! (field pp consts) (box-al [Const] a (load (field o consts))))
    (store! (field pp traits) (box-al [TraitDef] a (load (field o traits))))
    (store! (field pp impls) (box-al [ImplDef] a (load (field o impls))))
    (store! (field pp metas) (box-al [Expr] a (load (field o metas))))
    (store! (field pp exports) (box-al [ExportC] a (load (field o exports))))
    pp))
(defn init-ctx [(c (ptr Ctx)) (a (ptr Allocator)) (m (slice u8)) (imp (ptr ImpEntry)) (table (ptr (ArrayList DefEntry))) (exp (ptr (ArrayList ExpEntry))) (bareok (ptr (ArrayList (slice u8)))) (strict bool)] (-> i64)
  (store! (field c a) a) (store! (field c m) m) (store! (field c imp) imp)
  (store! (field c table) table) (store! (field c exp) exp) (store! (field c strict) strict) (store! (field c bareok) bareok)
  0)

; ---- resolve-program (src/resolve.rs::resolve_program), strict=true --------
(defn resolve-program [(a (ptr Allocator)) (s (mut LS)) (strict bool)] (-> (Result (ptr Program) Diag))
  (let [impb (unwrap-ptr [(ArrayList ImpEntry)] (create [(ArrayList ImpEntry)] a))
        expb (unwrap-ptr [(ArrayList ExpEntry)] (create [(ArrayList ExpEntry)] a))
        out-forms (field s out) nforms (al-len [TaggedForm] (load out-forms))
        pb (unwrap-ptr [PBox] (create [PBox] a)) parsed (field pb items)
        (mut perr) (zeroed Diag) (mut pfailed) false (mut fi) 0]
    (store! impb (load (field s imports)))
    (store! expb (load (field s exports)))
    (store! (field pb items) (al-new [ParsedForm] a))
    ; pass 0: parse each tagged form into its own Program
    (loop (if (icmp-ge (load fi) nforms) (break)
      (do (let [tfp (alloc-stack TaggedForm)] (store! tfp (al-get [TaggedForm] (load out-forms) (load fi)))
            (let [single (unwrap-ptr [(ArrayList Sexp)] (create [(ArrayList Sexp)] a)) (mut sl) (al-new [Sexp] a)]
              (al-push! (mut sl) (load (field tfp form)))
              (store! single (load sl))
              (match (parse-program a single)
                (Err [d] (do (store! perr d) (store! pfailed true) (break)))
                (Ok [prog]
                  (let [pp (unwrap-ptr [Program] (create [Program] a)) pf (alloc-stack ParsedForm)]
                    (store! pp prog)
                    (store! (field pf prog) pp) (store! (field pf module) (load (field tfp module)))
                    (al-push! (mut (field pb items)) (load pf)))))))
          (store! fi (iadd (load fi) 1)))))
    (if (load pfailed) (Err (load perr))
        (let [table (build-deftable a parsed) bareok (build-bareok a parsed)
              o (alloc-stack Out) np (al-len [ParsedForm] (load parsed))
              (mut qerr) (zeroed Diag) (mut qfailed) false (mut qi) 0]
          (init-out o a)
          (loop (if (icmp-ge (load qi) np) (break)
            (do (let [pf (al-elem [ParsedForm] parsed (load qi)) prog (load (field pf prog))]
                  (match (load (field pf module))
                    (Some [m]
                      (let [imp (imports-find impb m) cx (alloc-stack Ctx)]
                        (init-ctx cx a m imp table expb bareok strict)
                        (match (qualify-program cx prog)
                          (Err [d] (do (store! qerr d) (store! qfailed true) (break)))
                          (Ok [_] 0))))
                    (None [] 0))
                  (if (load qfailed) 0
                      (match (merge-into (mut o) prog a)
                        (Err [d] (do (store! qerr d) (store! qfailed true) (break)))
                        (Ok [_] 0))))
                (store! qi (iadd (load qi) 1)))))
          (if (load qfailed) (Err (load qerr)) (Ok (out->program o a)))))))

; ============================ check.rs: tables (Cx) ==========================
; Mirror src/check.rs's Sig/StructInfo/SumInfo/Cx. The Rust HashMaps become
; linear-scan ArrayList tables (the resolver's deftable idiom). Cx tables are
; BY-VALUE ArrayList fields so they can be pushed via (mut (field cx X)); they are
; read via (field cx X) for al-elem and (load (field cx X)) for al-len/al-get.
(defstruct Sig
  [(name (slice u8))
   (type_params (ptr (ArrayList (slice u8))))
   (bounds (ptr (ArrayList Bound)))
   (params (ptr (ArrayList Type)))
   (ret Type)
   (is_extern bool)
   (variadic bool)
   (cc (slice u8))
   (fnptr_ok bool)])
(defstruct StructInfo
  [(name (slice u8))
   (type_params (ptr (ArrayList (slice u8))))
   (fields (ptr (ArrayList Field)))
   (is_bits bool)])
(defstruct SumInfo
  [(name (slice u8))
   (type_params (ptr (ArrayList (slice u8))))
   (variants (ptr (ArrayList Variant)))])
(defstruct VtoS [(variant (slice u8)) (sum (slice u8))])
(defstruct ConstEntry [(name (slice u8)) (value Expr) (ty Type)])
(defstruct MethodEntry [(name (slice u8)) (trait (slice u8)) (self_idx i64)])
(defstruct ImplPair [(trait (slice u8)) (for_type (slice u8))])
(defstruct LoopFrame [(label (Option (slice u8))) (break_ty (Option Type)) (expected (Option Type))])
(defstruct EnvEntry [(name (slice u8)) (ty Type)])
(defstruct EvalPair [(e Expr) (t Type)])
(defstruct FBox [(items (ArrayList Func))])

(defstruct Cx
  [(a (ptr Allocator))
   (sigs (ArrayList Sig))
   (structs (ArrayList StructInfo))
   (sums (ArrayList SumInfo))
   (variant_to_sum (ArrayList VtoS))
   (consts (ArrayList ConstEntry))
   (static_consts (ArrayList (slice u8)))
   (trait_defs (ArrayList TraitDef))
   (methods (ArrayList MethodEntry))
   (impls (ArrayList ImplPair))
   (imports (ptr (ArrayList ImpEntry)))
   (exports (ptr (ArrayList ExpEntry)))
   (conventions (ptr (ArrayList Convention)))
   (cur_bounds (ArrayList Bound))
   (loops (ArrayList LoopFrame))])

(defn mk-evalpair [(e Expr) (t Type)] (-> EvalPair)
  (let [p (alloc-stack EvalPair)] (store! (field p e) e) (store! (field p t) t) (load p)))
(defn env-new [(a (ptr Allocator))] (-> (ptr (ArrayList EnvEntry)))
  (box-al [EnvEntry] a (al-new [EnvEntry] a)))

; ---- Cx table lookups (return a live (ptr T) or null) ----------------------
(defn sig-find [(cx (ptr Cx)) (name (slice u8))] (-> (ptr Sig))
  ; Mirror Rust's `sigs.insert` HashMap semantics: on a duplicate function name
  ; the LAST inserted sig wins, so keep scanning and return the final match.
  (let [n (al-len [Sig] (load (field cx sigs))) (mut i) 0 (mut r) (cast (ptr Sig) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [Sig] (field cx sigs) (load i)) name)) name)
              (do (store! r (al-elem [Sig] (field cx sigs) (load i))) 0) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn struct-find [(cx (ptr Cx)) (name (slice u8))] (-> (ptr StructInfo))
  (let [n (al-len [StructInfo] (load (field cx structs))) (mut i) 0 (mut r) (cast (ptr StructInfo) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [StructInfo] (field cx structs) (load i)) name)) name)
              (do (store! r (al-elem [StructInfo] (field cx structs) (load i))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn sum-find [(cx (ptr Cx)) (name (slice u8))] (-> (ptr SumInfo))
  (let [n (al-len [SumInfo] (load (field cx sums))) (mut i) 0 (mut r) (cast (ptr SumInfo) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [SumInfo] (field cx sums) (load i)) name)) name)
              (do (store! r (al-elem [SumInfo] (field cx sums) (load i))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn vts-find [(cx (ptr Cx)) (variant (slice u8))] (-> (ptr VtoS))
  (let [n (al-len [VtoS] (load (field cx variant_to_sum))) (mut i) 0 (mut r) (cast (ptr VtoS) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [VtoS] (field cx variant_to_sum) (load i)) variant)) variant)
              (do (store! r (al-elem [VtoS] (field cx variant_to_sum) (load i))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn trait-find [(cx (ptr Cx)) (name (slice u8))] (-> (ptr TraitDef))
  (let [n (al-len [TraitDef] (load (field cx trait_defs))) (mut i) 0 (mut r) (cast (ptr TraitDef) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [TraitDef] (field cx trait_defs) (load i)) name)) name)
              (do (store! r (al-elem [TraitDef] (field cx trait_defs) (load i))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn const-find [(cx (ptr Cx)) (name (slice u8))] (-> (ptr ConstEntry))
  (let [n (al-len [ConstEntry] (load (field cx consts))) (mut i) 0 (mut r) (cast (ptr ConstEntry) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [ConstEntry] (field cx consts) (load i)) name)) name)
              (do (store! r (al-elem [ConstEntry] (field cx consts) (load i))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn impl-has [(cx (ptr Cx)) (tr (slice u8)) (forty (slice u8))] (-> bool)
  (let [n (al-len [ImplPair] (load (field cx impls))) (mut i) 0 (mut f) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [ip (al-elem [ImplPair] (field cx impls) (load i))]
            (if (and (str-eq (load (field ip trait)) tr) (str-eq (load (field ip for_type)) forty)) (do (store! f true) (break)) 0))
          (store! i (iadd (load i) 1)))))
    (load f)))

; ============================ check.rs: pure type helpers ====================
(defn type-is-void  [(t (ptr Type))] (-> bool) (match-else (load t) (TVoid [] true) (_ false)))
(defn type-is-never [(t (ptr Type))] (-> bool) (match-else (load t) (TNever [] true) (_ false)))
(defn type-is-int   [(t (ptr Type))] (-> bool) (match-else (load t) (TInt [_ _] true) (_ false)))
(defn type-is-float [(t (ptr Type))] (-> bool) (match-else (load t) (TFloat [_] true) (_ false)))
(defn type-is-ptr   [(t (ptr Type))] (-> bool) (match-else (load t) (TPtr [_] true) (_ false)))

; type_mentions (src/check.rs:2290)
(defn type-list-mentions [(v (ptr (ArrayList Type))) (name (slice u8))] (-> bool)
  (let [n (al-len [Type] (load v)) (mut i) 0 (mut f) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (type-mentions (al-elem [Type] v (load i)) name) (do (store! f true) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load f)))
(defn type-mentions [(t (ptr Type)) (name (slice u8))] (-> bool)
  (match-else (load t)
    (TStruct [n] (str-eq n name))
    (TRef   [m p] (type-mentions p name))
    (TPtr   [p] (type-mentions p name))
    (TSlice [p] (type-mentions p name))
    (TArray [p k] (type-mentions p name))
    (TApp   [n args] (type-list-mentions args name))
    (TFn    [cc ps r] (or (type-list-mentions ps name) (type-mentions r name)))
    (_ false)))

; typename_to_type (src/check.rs:2303)
(defn typename-to-type [(name (slice u8))] (-> Type)
  (if (str-eq name "bool") (TBool)
    (if (str-eq name "f32") (TFloat 32)
      (if (str-eq name "f64") (TFloat 64)
        (let [n (slice-len name)]
          (if (icmp-lt n 2) (TStruct name)
            (let [c0 (cast i64 (slice-get name 0))]
              (if (or (icmp-eq c0 105) (icmp-eq c0 117))
                  (let [(mut ok) true (mut val) 0 (mut j) 1]
                    (loop (if (icmp-ge (load j) n) (break)
                      (do (let [ch (cast i64 (slice-get name (load j)))]
                            (if (and (icmp-ge ch 48) (icmp-le ch 57))
                                (do (store! val (iadd (imul (load val) 10) (isub ch 48))) 0)
                                (do (store! ok false) (break))))
                          (store! j (iadd (load j) 1)))))
                    (if (load ok) (TInt (load val) (icmp-eq c0 105)) (TStruct name)))
                  (TStruct name)))))))))

; subst_self (src/check.rs:2326)
(defn subst-self-list [(a (ptr Allocator)) (v (ptr (ArrayList Type))) (selfp (slice u8)) (concrete (ptr Type))] (-> (ptr (ArrayList Type)))
  (let [(mut out) (al-new [Type] a) n (al-len [Type] (load v)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut out) (subst-self a (al-elem [Type] v (load i)) selfp concrete))
          (store! i (iadd (load i) 1)))))
    (box-al [Type] a (load out))))
(defn subst-self [(a (ptr Allocator)) (t (ptr Type)) (selfp (slice u8)) (concrete (ptr Type))] (-> Type)
  (match-else (load t)
    (TStruct [n] (if (str-eq n selfp) (load concrete) (TStruct n)))
    (TRef   [m p] (TRef m (box-type a (subst-self a p selfp concrete))))
    (TPtr   [p] (TPtr (box-type a (subst-self a p selfp concrete))))
    (TSlice [p] (TSlice (box-type a (subst-self a p selfp concrete))))
    (TArray [p k] (TArray (box-type a (subst-self a p selfp concrete)) k))
    (TApp   [n args] (TApp n (subst-self-list a args selfp concrete)))
    (TFn    [cc ps r] (TFn cc (subst-self-list a ps selfp concrete) (box-type a (subst-self a r selfp concrete))))
    (_ (load t))))

; erase_refs (src/check.rs:2345)
(defn erase-refs-list [(a (ptr Allocator)) (v (ptr (ArrayList Type)))] (-> (ptr (ArrayList Type)))
  (let [(mut out) (al-new [Type] a) n (al-len [Type] (load v)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut out) (erase-refs a (al-elem [Type] v (load i))))
          (store! i (iadd (load i) 1)))))
    (box-al [Type] a (load out))))
(defn erase-refs [(a (ptr Allocator)) (t (ptr Type))] (-> Type)
  (match-else (load t)
    (TRef   [m p] (TPtr (box-type a (erase-refs a p))))
    (TPtr   [p]   (TPtr (box-type a (erase-refs a p))))
    (TArray [e k] (TArray (box-type a (erase-refs a e)) k))
    (TFn    [cc ps r] (TFn cc (erase-refs-list a ps) (box-type a (erase-refs a r))))
    (_ (load t))))

; param_ref_type (src/check.rs:2364)
(defn is-aggregate-name [(cx (ptr Cx)) (name (slice u8)) (tps (ptr (ArrayList (slice u8))))] (-> bool)
  (and (not (set-contains tps name))
       (or (icmp-ne (cast i64 (struct-find cx name)) 0) (icmp-ne (cast i64 (sum-find cx name)) 0))))
(defn param-ref-type [(cx (ptr Cx)) (t (ptr Type)) (tps (ptr (ArrayList (slice u8))))] (-> Type)
  (let [a (load (field cx a))]
    (match-else (load t)
      (TRef [m p] (load t))
      (TPtr [p] (load t))
      (TStruct [name] (if (is-aggregate-name cx name tps) (TRef false (box-type a (load t))) (load t)))
      (TApp [name args] (if (is-aggregate-name cx name tps) (TRef false (box-type a (load t))) (load t)))
      (TArray [e k] (TRef false (box-type a (load t))))
      (_ (load t)))))

; is_literal (src/check.rs:2750), is_literal_value (2827), numeric/is_cond/etc.
(defn al-last-expr [(v (ptr (ArrayList Expr)))] (-> (ptr Expr))
  (let [n (al-len [Expr] (load v))]
    (if (icmp-le n 0) (cast (ptr Expr) 0) (al-elem [Expr] v (isub n 1)))))
(defn is-literal [(e (ptr Expr))] (-> bool)
  (match-else (load (field e kind))
    (EInt   [_] true)
    (EFloat [_] true)
    (EBin   [op lhs rhs] (and (is-literal lhs) (is-literal rhs)))
    (EIf    [cnd thn els] (and (is-literal thn) (is-literal els)))
    (EDo    [body] (let [l (al-last-expr body)] (if (icmp-eq (cast i64 l) 0) false (is-literal l))))
    (ELet   [binds body] (let [l (al-last-expr body)] (if (icmp-eq (cast i64 l) 0) false (is-literal l))))
    (_ false)))
(defn is-literal-value [(e (ptr Expr))] (-> bool)
  (match-else (load (field e kind)) (EInt [_] true) (EFloat [_] true) (EBool [_] true) (_ false)))
(defn numeric [(t (ptr Type)) (tps (ptr (ArrayList (slice u8))))] (-> bool)
  (match-else (load t) (TInt [_ _] true) (TFloat [_] true) (TStruct [n] (set-contains tps n)) (_ false)))
(defn is-cond [(t (ptr Type))] (-> bool)
  (match-else (load t) (TBool [] true) (TInt [_ _] true) (_ false)))
(defn same-number-kind [(x (ptr Type)) (y (ptr Type))] (-> bool)
  (or (and (type-is-int x) (type-is-int y)) (and (type-is-float x) (type-is-float y))))
(defn arg-ok [(got (ptr Type)) (want (ptr Type)) (is_extern bool)] (-> bool)
  (if (type-eq got want) true (and is_extern (and (type-is-ptr got) (type-is-ptr want)))))
; fits (src/check.rs:2783)
(defn fits [(n i64) (bits i64) (signed bool)] (-> bool)
  (if (icmp-ge bits 64) true
    (if signed
        (let [lo (isub 0 (ishl 1 (isub bits 1))) hi (isub (ishl 1 (isub bits 1)) 1)]
          (and (icmp-ge n lo) (icmp-le n hi)))
        (if (icmp-ge bits 63) (icmp-ge n 0)
            (and (icmp-ge n 0) (icmp-lt n (ishl 1 bits)))))))

(defn prefix-diag [(a (ptr Allocator)) (d Diag) (pre (slice u8))] (-> Diag)
  (let [dp (alloc-stack Diag)] (store! dp d) (derr (sconcat a pre (load (field dp msg))))))

; ============================ check.rs: coerce =============================
; coerce_lit (src/check.rs:2867)
(defn coerce-lit [(a (ptr Allocator)) (e Expr) (target (ptr Type)) (fname (slice u8))] (-> (Result Expr Diag))
  (let [ep (alloc-stack Expr)] (store! ep e)
    (let [wrap (mk-expr (ECast (load target) (box-expr a (load ep))) (load (field ep lo)) (load (field ep hi)))]
      (match-else (load (field ep kind))
        (EInt [n]
          (match-else (load target)
            (TInt [bits signed]
              (if (not (fits n bits signed))
                  (Err [Expr Diag] (derr (sconcat a (sconcat a (sconcat3 a "in '" fname "': literal ") (i64->str a n)) (sconcat a " does not fit in " (ty-str a target)))))
                  (Ok wrap)))
            (_ (Ok wrap))))
        (_ (Ok wrap))))))
; coerce (src/check.rs:2886)
(defn coerce-fail [(a (ptr Allocator)) (et (ptr Type)) (target (ptr Type)) (fname (slice u8)) (what (slice u8))] (-> (Result Expr Diag))
  (Err [Expr Diag] (derr (sconcat a (sconcat a (sconcat a (sconcat a (sconcat3 a "in '" fname "': ") (sconcat a what " has type ")) (ty-str a et)) " but expected ") (ty-str a target)))))
(defn coerce [(a (ptr Allocator)) (e Expr) (et (ptr Type)) (target (ptr Type)) (is_extern bool) (fname (slice u8)) (what (slice u8))] (-> (Result Expr Diag))
  (let [ep (alloc-stack Expr)] (store! ep e)
    (if (type-eq et target) (Ok (load ep))
      (if (type-is-void target) (Ok (load ep))
        (if (type-is-void et) (Err [Expr Diag] (derr (sconcat a (sconcat3 a "in '" fname "': ") (sconcat a what " uses a void value (a (-> void) call yields nothing)"))))
          (if (type-is-never et) (Ok (load ep))
            (if (and (same-number-kind et target) (is-literal ep)) (coerce-lit a (load ep) target fname)
              (if (arg-ok et target is_extern) (Ok (load ep))
                (match-else (load et)
                  (TRef [m inner]
                    (if (type-eq inner target)
                        (Ok (mk-expr (ELoad (box-expr a (load ep))) (load (field ep lo)) (load (field ep hi))))
                        (coerce-fail a et target fname what)))
                  (_ (coerce-fail a et target fname what)))))))))))

; const_entry (src/check.rs:2835)
(defn const-entry [(a (ptr Allocator)) (cp (ptr Const))] (-> (Result EvalPair Diag))
  (let [nm (load (field cp name))]
    (match-else (load (field (field cp value) kind))
      (EInt [n]
        (match (load (field cp ty))
          (None [] (Ok (mk-evalpair (mk-expr (EInt n) -1 -1) (TInt 64 true))))
          (Some [wt]
            (match-else wt
              (TInt [bits signed]
                (if (not (fits n bits signed))
                    (Err [EvalPair Diag] (derr (sconcat a (sconcat a (sconcat3 a "const '" nm "': literal ") (i64->str a n)) (sconcat a " does not fit in " (ty-str a (box-type a wt))))))
                    (Ok (mk-evalpair (mk-expr (EInt n) -1 -1) (TInt bits signed)))))
              (_ (Err [EvalPair Diag] (derr (sconcat a (sconcat3 a "const '" nm "': integer value cannot have type ") (ty-str a (box-type a wt))))))))))
      (EFloat [bits]
        (match (load (field cp ty))
          (None [] (Ok (mk-evalpair (mk-expr (EFloat bits) -1 -1) (TFloat 64))))
          (Some [wt]
            (match-else wt
              (TFloat [b] (Ok (mk-evalpair (mk-expr (EFloat bits) -1 -1) (TFloat b))))
              (_ (Err [EvalPair Diag] (derr (sconcat a (sconcat3 a "const '" nm "': float value cannot have type ") (ty-str a (box-type a wt))))))))))
      (EBool [b]
        (match (load (field cp ty))
          (None [] (Ok (mk-evalpair (mk-expr (EBool b) -1 -1) (TBool))))
          (Some [wt]
            (match-else wt
              (TBool [] (Ok (mk-evalpair (mk-expr (EBool b) -1 -1) (TBool))))
              (_ (Err [EvalPair Diag] (derr (sconcat a (sconcat3 a "const '" nm "': boolean value cannot have type ") (ty-str a (box-type a wt))))))))))
      (_ (do (unimplemented "check/const-entry called on non-literal (unreachable)") (Err [EvalPair Diag] (derr "")))))))

; ============================ check.rs: validate_type ========================
(defn validate-type-list [(v (ptr (ArrayList Type))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [n (al-len [Type] (load v)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (validate-type (al-elem [Type] v (load i)) cx tps)
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn validate-struct-name [(a (ptr Allocator)) (cx (ptr Cx)) (name (slice u8)) (tps (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (if (set-contains tps name) (Ok [i64 Diag] 0)
    (let [si (struct-find cx name)]
      (if (icmp-ne (cast i64 si) 0)
          (let [np (al-len [(slice u8)] (load (field si type_params)))]
            (if (icmp-eq np 0) (Ok [i64 Diag] 0)
                (Err [i64 Diag] (derr (sconcat a (sconcat a (sconcat3 a "generic type '" name "' expects ") (i64->str a np)) " type arguments, got 0")))))
          (let [su (sum-find cx name)]
            (if (icmp-ne (cast i64 su) 0)
                (let [np (al-len [(slice u8)] (load (field su type_params)))]
                  (if (icmp-eq np 0) (Ok [i64 Diag] 0)
                      (Err [i64 Diag] (derr (sconcat a (sconcat a (sconcat3 a "generic type '" name "' expects ") (i64->str a np)) " type arguments, got 0")))))
                (Err [i64 Diag] (derr (sconcat3 a "unknown type '" name "'")))))))))
(defn validate-app [(a (ptr Allocator)) (cx (ptr Cx)) (name (slice u8)) (args (ptr (ArrayList Type))) (tps (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (match (validate-type-list args cx tps) (Err [d] (Err [i64 Diag] d))
    (Ok [_]
      (let [si (struct-find cx name) su (sum-find cx name) (mut arity) -1]
        (if (icmp-ne (cast i64 si) 0) (do (store! arity (al-len [(slice u8)] (load (field si type_params)))) 0)
          (if (icmp-ne (cast i64 su) 0) (do (store! arity (al-len [(slice u8)] (load (field su type_params)))) 0) 0))
        (if (icmp-lt (load arity) 0)
            (Err [i64 Diag] (derr (sconcat3 a "unknown generic type '" name "'")))
            (let [na (al-len [Type] (load args))]
              (if (icmp-ne (load arity) na)
                  (Err [i64 Diag] (derr (sconcat a (sconcat a (sconcat a (sconcat3 a "generic type '" name "' expects ") (i64->str a (load arity))) " type arguments, got ") (i64->str a na))))
                  (Ok [i64 Diag] 0))))))))
(defn validate-type [(t (ptr Type)) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8))))] (-> (Result i64 Diag))
  (let [a (load (field cx a))]
    (match (load t)
      (TNever [] (Ok [i64 Diag] 0))
      (TCode  [] (Ok [i64 Diag] 0))
      (TVoid  [] (Err [i64 Diag] (derr "'void' is only valid as a return type")))
      (TInt   [_ _] (Ok [i64 Diag] 0))
      (TFloat [_] (Ok [i64 Diag] 0))
      (TBool  [] (Ok [i64 Diag] 0))
      (TPtr   [p] (validate-type p cx tps))
      (TRef   [m p] (validate-type p cx tps))
      (TArray [e k] (validate-type e cx tps))
      (TSlice [e] (validate-type e cx tps))
      (TVec   [e k]
        (if (icmp-eq k 0) (Err [i64 Diag] (derr "vec must have a positive lane count"))
          (match-else (load e)
            (TInt   [_ _] (Ok [i64 Diag] 0))
            (TFloat [_] (Ok [i64 Diag] 0))
            (TStruct [p] (if (set-contains tps p) (Ok [i64 Diag] 0)
                            (Err [i64 Diag] (derr (sconcat a "vec element must be a scalar int/float, got " (ty-str a e))))))
            (_ (Err [i64 Diag] (derr (sconcat a "vec element must be a scalar int/float, got " (ty-str a e))))))))
      (TStruct [name] (validate-struct-name a cx name tps))
      (TFn [cc params ret]
        (match (validate-type-list params cx tps) (Err [d] (Err [i64 Diag] d)) (Ok [_] (validate-type ret cx tps))))
      (TApp [name args] (validate-app a cx name args tps)))))

; ============================ check.rs: setup (Phase 1) ======================
(defn layout-is-bits [(l (ptr Layout))] (-> bool) (match-else (load l) (LBits [b o] true) (_ false)))
(defn conv-find [(cx (ptr Cx)) (name (slice u8))] (-> (ptr Convention))
  (let [cv (field cx conventions) n (al-len [Convention] (load (load (field cx conventions)))) (mut i) 0 (mut r) (cast (ptr Convention) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (conv-name (al-get [Convention] (load (load cv)) (load i))) name)
              (do (store! r (al-elem [Convention] (load cv) (load i))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn conv-is-shim [(c (ptr Convention))] (-> bool) (match-else (load (field c lowering)) (LShim [] true) (_ false)))
(defn conv-is-native [(cx (ptr Cx)) (name (slice u8))] (-> bool)
  (let [c (conv-find cx name)] (and (icmp-ne (cast i64 c) 0) (not (conv-is-shim c)))))
(defn conv-ret-none [(c (ptr Convention))] (-> bool) (match-else (load (field c ret)) (None [] true) (_ false)))
(defn conv-params-len [(c (ptr Convention))] (-> i64) (al-len [(slice u8)] (load (field c params))))

(defn cx-init-tables [(cx (ptr Cx)) (a (ptr Allocator))] (-> i64)
  (store! (field cx a) a)
  (store! (field cx sigs) (al-new [Sig] a))
  (store! (field cx structs) (al-new [StructInfo] a))
  (store! (field cx sums) (al-new [SumInfo] a))
  (store! (field cx variant_to_sum) (al-new [VtoS] a))
  (store! (field cx consts) (al-new [ConstEntry] a))
  (store! (field cx static_consts) (al-new [(slice u8)] a))
  (store! (field cx trait_defs) (al-new [TraitDef] a))
  (store! (field cx methods) (al-new [MethodEntry] a))
  (store! (field cx impls) (al-new [ImplPair] a))
  (store! (field cx cur_bounds) (al-new [Bound] a))
  (store! (field cx loops) (al-new [LoopFrame] a))
  0)

(defn setup-structs [(a (ptr Allocator)) (cx (ptr Cx)) (prog (ptr Program))] (-> (Result i64 Diag))
  (let [fs (load (field prog structs)) n (al-len [StructDef] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [sp (al-elem [StructDef] fs (load i)) nm (load (field sp name))]
            (if (icmp-ne (cast i64 (struct-find cx nm)) 0)
                (do (store! err (derr (sconcat3 a "struct '" nm "' defined twice"))) (store! failed true) (break))
                (let [info (alloc-stack StructInfo)]
                  (store! (field info name) nm)
                  (store! (field info type_params) (load (field sp type_params)))
                  (store! (field info fields) (load (field sp fields)))
                  (store! (field info is_bits) (layout-is-bits (field sp layout)))
                  (al-push! (mut (field cx structs)) (load info)))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn setup-sums [(a (ptr Allocator)) (cx (ptr Cx)) (prog (ptr Program))] (-> (Result i64 Diag))
  (let [fs (load (field prog sums)) n (al-len [SumDef] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [sp (al-elem [SumDef] fs (load i)) nm (load (field sp name))]
            (if (icmp-ne (cast i64 (sum-find cx nm)) 0)
                (do (store! err (derr (sconcat3 a "sum '" nm "' defined twice"))) (store! failed true) (break))
                (do (let [info (alloc-stack SumInfo)]
                      (store! (field info name) nm)
                      (store! (field info type_params) (load (field sp type_params)))
                      (store! (field info variants) (load (field sp variants)))
                      (al-push! (mut (field cx sums)) (load info)))
                    (let [vs (load (field sp variants)) vn (al-len [Variant] (load vs)) (mut j) 0]
                      (loop (if (icmp-ge (load j) vn) (break)
                        (do (let [vp (al-elem [Variant] vs (load j)) vnm (load (field vp name))]
                              (if (icmp-ne (cast i64 (vts-find cx vnm)) 0)
                                  (do (store! err (derr (sconcat3 a "variant '" vnm "' is declared in two sum types"))) (store! failed true) (break))
                                  (let [ve (alloc-stack VtoS)] (store! (field ve variant) vnm) (store! (field ve sum) nm) (al-push! (mut (field cx variant_to_sum)) (load ve)))))
                            (store! j (iadd (load j) 1)))))
                    (if (load failed) (break) 0)))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn trait-method-self-idx [(tp (ptr TraitMethod)) (selfp (slice u8))] (-> i64)
  (let [ps (load (field tp params)) n (al-len [Param] (load ps)) (mut i) 0 (mut r) -1]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (type-mentions (field (al-elem [Param] ps (load i)) ty) selfp) (do (store! r (load i)) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn setup-traits [(a (ptr Allocator)) (cx (ptr Cx)) (prog (ptr Program))] (-> (Result i64 Diag))
  (let [ts (load (field prog traits)) n (al-len [TraitDef] (load ts)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [tp (al-elem [TraitDef] ts (load i)) tnm (load (field tp name)) selfp (load (field tp self_param))]
            (let [ms (load (field tp methods)) mn (al-len [TraitMethod] (load ms)) (mut j) 0]
              (loop (if (icmp-ge (load j) mn) (break)
                (do (let [mp (al-elem [TraitMethod] ms (load j)) mnm (load (field mp name)) idx (trait-method-self-idx mp selfp)]
                      (if (icmp-lt idx 0)
                          (do (store! err (derr (sconcat a (sconcat a (sconcat3 a "trait '" tnm "' method '") (sconcat3 a mnm "': needs a " selfp)) " (Self) parameter"))) (store! failed true) (break))
                          (let [me (alloc-stack MethodEntry)] (store! (field me name) mnm) (store! (field me trait) tnm) (store! (field me self_idx) idx) (al-push! (mut (field cx methods)) (load me)))))
                    (store! j (iadd (load j) 1))))))
            (if (load failed) (break)
                (if (icmp-ne (cast i64 (trait-find cx tnm)) 0)
                    (do (store! err (derr (sconcat3 a "trait '" tnm "' defined twice"))) (store! failed true) (break))
                    (al-push! (mut (field cx trait_defs)) (load tp)))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn copy-funcs [(a (ptr Allocator)) (fb (ptr FBox)) (prog (ptr Program))] (-> i64)
  (let [fs (load (field prog funcs)) n (al-len [Func] (load fs)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut (field fb items)) (al-get [Func] (load fs) (load i)))
          (store! i (iadd (load i) 1)))))
    0))
(defn tmfn [(a (ptr Allocator)) (tr (slice u8)) (ty (slice u8)) (m (slice u8))] (-> (slice u8))
  (sconcat3 a (sconcat3 a tr "$" ty) "$" m))
(defn impl-find-method [(im (ptr ImplDef)) (mname (slice u8))] (-> (ptr Func))
  (let [ms (load (field im methods)) n (al-len [Func] (load ms)) (mut i) 0 (mut r) (cast (ptr Func) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (func-name (al-get [Func] (load ms) (load i))) mname) (do (store! r (al-elem [Func] ms (load i))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn subst-self-params [(a (ptr Allocator)) (tm (ptr TraitMethod)) (selfp (slice u8)) (cty (ptr Type))] (-> (ptr (ArrayList Type)))
  (let [ps (load (field tm params)) (mut out) (al-new [Type] a) n (al-len [Param] (load ps)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut out) (subst-self a (field (al-elem [Param] ps (load i)) ty) selfp cty))
          (store! i (iadd (load i) 1)))))
    (box-al [Type] a (load out))))
(defn param-types [(a (ptr Allocator)) (ps (ptr (ArrayList Param)))] (-> (ptr (ArrayList Type)))
  (let [(mut out) (al-new [Type] a) n (al-len [Param] (load ps)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut out) (load (field (al-elem [Param] ps (load i)) ty)))
          (store! i (iadd (load i) 1)))))
    (box-al [Type] a (load out))))
(defn impl-prefix [(a (ptr Allocator)) (tr (slice u8)) (forty (slice u8))] (-> (slice u8))
  (sconcat a (sconcat3 a "impl " tr " for ") (sconcat a forty ": ")))
(defn check-impl-methods [(a (ptr Allocator)) (cx (ptr Cx)) (im (ptr ImplDef)) (td (ptr TraitDef)) (cty (ptr Type))] (-> (Result i64 Diag))
  (let [tr (load (field im trait_name)) forty (load (field im for_type)) selfp (load (field td self_param))
        tms (load (field td methods)) n (al-len [TraitMethod] (load tms)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [tm (al-elem [TraitMethod] tms (load i)) tmn (load (field tm name)) m (impl-find-method im tmn)]
            (if (icmp-eq (cast i64 m) 0)
                (do (store! err (derr (sconcat a (impl-prefix a tr forty) (sconcat3 a "missing method '" tmn "'")))) (store! failed true) (break))
                (let [want (subst-self-params a tm selfp cty) got (param-types a (load (field m params)))
                      wantret (subst-self a (field tm ret) selfp cty) gotret (field m ret)]
                  (if (or (not (type-list-eq want got)) (not (type-eq (box-type a wantret) gotret)))
                      (do (store! err (derr (sconcat a (impl-prefix a tr forty) (sconcat3 a "method '" tmn "' signature doesn't match the trait")))) (store! failed true) (break))
                      0))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn append-impl-methods [(a (ptr Allocator)) (im (ptr ImplDef)) (fb (ptr FBox))] (-> i64)
  (let [tr (load (field im trait_name)) forty (load (field im for_type)) ms (load (field im methods)) n (al-len [Func] (load ms)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [lf (alloc-stack Func)]
            (store! lf (al-get [Func] (load ms) (load i)))
            (store! (field lf name) (tmfn a tr forty (load (field lf name))))
            (al-push! (mut (field fb items)) (load lf)))
          (store! i (iadd (load i) 1)))))
    0))
(defn setup-one-impl [(a (ptr Allocator)) (cx (ptr Cx)) (im (ptr ImplDef)) (fb (ptr FBox))] (-> (Result i64 Diag))
  (try
   (do
    (let [tr (load (field im trait_name)) forty (load (field im for_type))]
      (if (icmp-eq (cast i64 (trait-find cx tr)) 0)
          (return-from :try (Err [i64 Diag] (derr (sconcat3 a "impl: unknown trait '" tr "'")))) 0)
      (if (impl-has cx tr forty)
          (return-from :try (Err [i64 Diag] (derr (sconcat a (sconcat3 a "duplicate impl of '" tr "' for '") (sconcat a forty "'"))))) 0)
      (let [ip (alloc-stack ImplPair)] (store! (field ip trait) tr) (store! (field ip for_type) forty) (al-push! (mut (field cx impls)) (load ip)))
      (let [td (trait-find cx tr) cty (box-type a (typename-to-type forty))]
        (try! (check-impl-methods a cx im td cty)))
      (append-impl-methods a im fb)
      (Ok 0)))))
(defn setup-impls [(a (ptr Allocator)) (cx (ptr Cx)) (prog (ptr Program)) (fb (ptr FBox))] (-> (Result i64 Diag))
  (let [is (load (field prog impls)) n (al-len [ImplDef] (load is)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (setup-one-impl a cx (al-elem [ImplDef] is (load i)) fb)
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn setup-one-sig [(a (ptr Allocator)) (cx (ptr Cx)) (fp (ptr Func))] (-> i64)
  (let [cc (load (field fp cc)) tps (load (field fp type_params)) native (conv-is-native cx cc) sg (alloc-stack Sig)]
    (store! (field sg name) (load (field fp name)))
    (store! (field sg type_params) tps)
    (store! (field sg bounds) (load (field fp bounds)))
    (store! (field sg params) (param-ref-types a cx (load (field fp params)) tps))
    (store! (field sg ret) (load (field fp ret)))
    (store! (field sg is_extern) false)
    (store! (field sg variadic) false)
    (store! (field sg cc) cc)
    (store! (field sg fnptr_ok) (and native (icmp-eq (al-len [(slice u8)] (load tps)) 0)))
    (al-push! (mut (field cx sigs)) (load sg))
    0))
(defn param-ref-types [(a (ptr Allocator)) (cx (ptr Cx)) (ps (ptr (ArrayList Param))) (tps (ptr (ArrayList (slice u8))))] (-> (ptr (ArrayList Type)))
  (let [(mut out) (al-new [Type] a) n (al-len [Param] (load ps)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut out) (param-ref-type cx (field (al-elem [Param] ps (load i)) ty) tps))
          (store! i (iadd (load i) 1)))))
    (box-al [Type] a (load out))))
(defn setup-sigs [(a (ptr Allocator)) (cx (ptr Cx)) (allf (ptr (ArrayList Func)))] (-> i64)
  (let [n (al-len [Func] (load allf)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (setup-one-sig a cx (al-elem [Func] allf (load i)))
          (store! i (iadd (load i) 1)))))
    0))
(defn setup-externs [(a (ptr Allocator)) (cx (ptr Cx)) (prog (ptr Program))] (-> (Result i64 Diag))
  (let [es (load (field prog externs)) n (al-len [Extern] (load es)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [ep (al-elem [Extern] es (load i)) nm (load (field ep name))]
            (if (icmp-ne (cast i64 (sig-find cx nm)) 0)
                (do (store! err (derr (sconcat3 a "'" nm "' is declared more than once"))) (store! failed true) (break))
                (let [c (conv-find cx (load (field ep cc)))]
                  (if (icmp-eq (cast i64 c) 0)
                      (do (store! err (derr (sconcat3 a (sconcat3 a "extern '" nm "': unknown convention '") (load (field ep cc)) "'"))) (store! failed true) (break))
                      (if (conv-is-shim c)
                          (do (store! err (derr (sconcat3 a "extern '" nm "': shim conventions for externs are not supported yet"))) (store! failed true) (break))
                          (let [sg (alloc-stack Sig)]
                            (store! (field sg name) nm)
                            (store! (field sg type_params) (empty-strs a))
                            (store! (field sg bounds) (box-al [Bound] a (al-new [Bound] a)))
                            (store! (field sg params) (load (field ep params)))
                            (store! (field sg ret) (load (field ep ret)))
                            (store! (field sg is_extern) true)
                            (store! (field sg variadic) (load (field ep variadic)))
                            (store! (field sg cc) (load (field ep cc)))
                            (store! (field sg fnptr_ok) true)
                            (al-push! (mut (field cx sigs)) (load sg))))))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn opt-type-some? [(o (ptr (Option Type)))] (-> bool) (match-else (load o) (Some [t] true) (_ false)))
(defn opt-type-val [(o (ptr (Option Type)))] (-> Type) (match-else (load o) (Some [t] t) (_ (TVoid))))
(defn type-is-aggregate-static [(t (ptr Type))] (-> bool)
  (match-else (load t) (TStruct [_] true) (TArray [_ _] true) (_ false)))
(defn compute-const-entry [(a (ptr Allocator)) (cx (ptr Cx)) (cp (ptr Const))] (-> (Result EvalPair Diag))
  (if (is-literal-value (field cp value))
      (const-entry a cp)
      ; non-literal const value = a compile-time computation: requires synth +
      ; (typed) coerce. synth is not yet ported, so this is a hard-error stub.
      (do (unimplemented "check/setup: non-literal const value (needs synth)")
          (Err [EvalPair Diag] (derr "")))))
(defn setup-consts [(a (ptr Allocator)) (cx (ptr Cx)) (prog (ptr Program))] (-> (Result i64 Diag))
  (let [cs (load (field prog consts)) n (al-len [Const] (load cs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [cp (al-elem [Const] cs (load i)) nm (load (field cp name))]
            (if (or (icmp-ne (cast i64 (sig-find cx nm)) 0) (icmp-ne (cast i64 (const-find cx nm)) 0))
                (do (store! err (derr (sconcat3 a "'" nm "' is declared more than once"))) (store! failed true) (break))
                (match (compute-const-entry a cx cp)
                  (Err [d] (do (store! err d) (store! failed true) (break)))
                  (Ok [epv]
                    (let [ep (alloc-stack EvalPair)] (store! ep epv)
                      (do (if (type-is-aggregate-static (field ep t)) (do (al-push! (mut (field cx static_consts)) nm) 0) 0)
                          (let [ce (alloc-stack ConstEntry)]
                            (store! (field ce name) nm) (store! (field ce value) (load (field ep e))) (store! (field ce ty) (load (field ep t)))
                            (al-push! (mut (field cx consts)) (load ce)))))))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn setup-validate-const-types [(a (ptr Allocator)) (cx (ptr Cx)) (prog (ptr Program))] (-> (Result i64 Diag))
  (let [cs (load (field prog consts)) n (al-len [Const] (load cs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [cp (al-elem [Const] cs (load i)) nm (load (field cp name))]
            (if (opt-type-some? (field cp ty))
                (match (validate-type (box-type a (opt-type-val (field cp ty))) cx (empty-strs a))
                  (Err [d] (do (store! err (prefix-diag a d (sconcat3 a "const '" nm "': "))) (store! failed true) (break)))
                  (Ok [_] 0))
                0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn validate-one-struct-fields [(a (ptr Allocator)) (cx (ptr Cx)) (sp (ptr StructDef))] (-> (Result i64 Diag))
  (let [nm (load (field sp name)) tps (load (field sp type_params)) fs (load (field sp fields))
        n (al-len [Field] (load fs)) (mut i) 0 (mut seen) (al-new [(slice u8)] a) (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [fp (al-elem [Field] fs (load i)) fnm (load (field fp name))]
            (if (set-contains (box-al [(slice u8)] a (load seen)) fnm)
                (do (store! err (derr (sconcat a (sconcat3 a "struct '" nm "': duplicate field '") (sconcat a fnm "'")))) (store! failed true) (break))
                (do (al-push! (mut seen) fnm)
                    (match (validate-type (field fp ty) cx tps)
                      (Err [d] (do (store! err (prefix-diag a d (sconcat a (sconcat3 a "struct '" nm "' field '") (sconcat a fnm "': ")))) (store! failed true) (break)))
                      (Ok [_] 0)))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn setup-validate-struct-fields [(a (ptr Allocator)) (cx (ptr Cx)) (prog (ptr Program))] (-> (Result i64 Diag))
  (let [fs (load (field prog structs)) n (al-len [StructDef] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (validate-one-struct-fields a cx (al-elem [StructDef] fs (load i)))
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn validate-one-variant-fields [(a (ptr Allocator)) (cx (ptr Cx)) (sumnm (slice u8)) (tps (ptr (ArrayList (slice u8)))) (vp (ptr Variant))] (-> (Result i64 Diag))
  (let [vnm (load (field vp name)) fs (load (field vp fields)) n (al-len [Field] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [fp (al-elem [Field] fs (load i)) fnm (load (field fp name))]
            (match (validate-type (field fp ty) cx tps)
              (Err [d] (do (store! err (prefix-diag a d (sconcat a (sconcat a (sconcat3 a "sum '" sumnm "' variant '") (sconcat3 a vnm "' field '" fnm)) "': "))) (store! failed true) (break)))
              (Ok [_] 0)))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn validate-one-sum-fields [(a (ptr Allocator)) (cx (ptr Cx)) (sp (ptr SumDef))] (-> (Result i64 Diag))
  (let [sumnm (load (field sp name)) tps (load (field sp type_params)) vs (load (field sp variants))
        n (al-len [Variant] (load vs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (validate-one-variant-fields a cx sumnm tps (al-elem [Variant] vs (load i)))
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn setup-validate-sum-fields [(a (ptr Allocator)) (cx (ptr Cx)) (prog (ptr Program))] (-> (Result i64 Diag))
  (let [fs (load (field prog sums)) n (al-len [SumDef] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (validate-one-sum-fields a cx (al-elem [SumDef] fs (load i)))
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))

(defn setup [(a (ptr Allocator)) (cx (ptr Cx)) (prog (ptr Program)) (impb (ptr (ArrayList ImpEntry))) (expb (ptr (ArrayList ExpEntry)))] (-> (Result (ptr (ArrayList Func)) Diag))
  (try
   (do
    (cx-init-tables cx a)
    (store! (field cx imports) impb) (store! (field cx exports) expb)
    (store! (field cx conventions) (load (field prog conventions)))
    (try! (setup-structs a cx prog))
    (try! (setup-sums a cx prog))
    (try! (setup-traits a cx prog))
    (let [fb (unwrap-ptr [FBox] (create [FBox] a))]
      (store! (field fb items) (al-new [Func] a))
      (copy-funcs a fb prog)
      (try! (setup-impls a cx prog fb))
      (setup-sigs a cx (field fb items))
      (try! (setup-externs a cx prog))
      (try! (setup-consts a cx prog))
      (try! (setup-validate-const-types a cx prog))
      (try! (setup-validate-struct-fields a cx prog))
      (try! (setup-validate-sum-fields a cx prog))
      (Ok (field fb items))))))

; ============================ check.rs: check_func (Phase 2) =================
(defn validate-params [(a (ptr Allocator)) (cx (ptr Cx)) (ps (ptr (ArrayList Param))) (tps (ptr (ArrayList (slice u8)))) (fnm (slice u8))] (-> (Result i64 Diag))
  (let [n (al-len [Param] (load ps)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [pp (al-elem [Param] ps (load i)) pnm (load (field pp name))]
            (match (validate-type (field pp ty) cx tps)
              (Err [d] (do (store! err (prefix-diag a d (sconcat a (sconcat3 a "function '" fnm "' param '") (sconcat a pnm "': ")))) (store! failed true) (break)))
              (Ok [_] 0)))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok [i64 Diag] 0))))
(defn build-param-env [(a (ptr Allocator)) (cx (ptr Cx)) (ps (ptr (ArrayList Param))) (tps (ptr (ArrayList (slice u8))))] (-> (ptr (ArrayList EnvEntry)))
  (let [(mut out) (al-new [EnvEntry] a) n (al-len [Param] (load ps)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [pp (al-elem [Param] ps (load i)) ee (alloc-stack EnvEntry)]
            (store! (field ee name) (load (field pp name)))
            (store! (field ee ty) (param-ref-type cx (field pp ty) tps))
            (al-push! (mut out) (load ee)))
          (store! i (iadd (load i) 1)))))
    (box-al [EnvEntry] a (load out))))
(defn erase-param-types [(a (ptr Allocator)) (cx (ptr Cx)) (ps (ptr (ArrayList Param))) (tps (ptr (ArrayList (slice u8))))] (-> (ptr (ArrayList Param)))
  (let [(mut out) (al-new [Param] a) n (al-len [Param] (load ps)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [pp (al-elem [Param] ps (load i)) np (alloc-stack Param)]
            (store! (field np name) (load (field pp name)))
            (store! (field np ty) (erase-refs a (box-type a (param-ref-type cx (field pp ty) tps))))
            (al-push! (mut out) (load np)))
          (store! i (iadd (load i) 1)))))
    (box-al [Param] a (load out))))
; check one body, accumulator-style (NO return-from inside the loop — gotcha #1).
(defn check-body [(a (ptr Allocator)) (cx (ptr Cx)) (fp (ptr Func)) (env (ptr (ArrayList EnvEntry))) (tps (ptr (ArrayList (slice u8)))) (fnm (slice u8))] (-> (Result (ptr (ArrayList Expr)) Diag))
  (let [body (load (field fp body)) bn (al-len [Expr] (load body)) (mut out) (al-new [Expr] a)
        (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) bn) (break)
      (do (let [ep (al-elem [Expr] body (load i)) istail (icmp-eq (iadd (load i) 1) bn)]
            (if istail
                (match (synth a ep (field fp ret) env cx tps fnm)
                  (Err [d] (do (store! err d) (store! failed true) (break)))
                  (Ok [rv]
                    (let [r (alloc-stack EvalPair)] (store! r rv)
                      (match (coerce a (load (field r e)) (box-type a (load (field r t))) (field fp ret) false fnm "body")
                        (Err [_] (do (store! err (derr (sconcat a (sconcat a (sconcat a (sconcat3 a "function '" fnm "': body has type ") (ty-str a (box-type a (load (field r t))))) " but the declared return type is ") (ty-str a (field fp ret))))) (store! failed true) (break)))
                        (Ok [ee] (al-push! (mut out) ee))))))
                (match (synth a ep (cast (ptr Type) 0) env cx tps fnm)
                  (Err [d] (do (store! err d) (store! failed true) (break)))
                  (Ok [rv] (let [r (alloc-stack EvalPair)] (store! r rv) (al-push! (mut out) (load (field r e))))))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok (box-al [Expr] a (load out))))))
(defn check-func [(a (ptr Allocator)) (cx (ptr Cx)) (fp (ptr Func))] (-> (Result Func Diag))
  (try
   (do
    (let [tps (load (field fp type_params)) fnm (load (field fp name))]
      (store! (field cx cur_bounds) (load (load (field fp bounds))))
      (let [conv (conv-find cx (load (field fp cc)))]
        (if (icmp-eq (cast i64 conv) 0)
            (return-from :try (Err [Func Diag] (derr (sconcat3 a (sconcat3 a "function '" fnm "': unknown convention '") (load (field fp cc)) "'"))))
            (if (conv-is-shim conv)
                (do (if (conv-ret-none conv)
                        (return-from :try (Err [Func Diag] (derr (sconcat3 a (sconcat3 a "function '" fnm "': shim convention '") (load (field fp cc)) "' needs a :ret register")))) 0)
                    (if (icmp-lt (conv-params-len conv) (al-len [Param] (load (load (field fp params)))))
                        (return-from :try (Err [Func Diag] (derr (sconcat a (sconcat a (sconcat a (sconcat a (sconcat3 a "function '" fnm "': convention '") (sconcat a (load (field fp cc)) "' provides ")) (i64->str a (conv-params-len conv))) (sconcat a " param registers but the function has " (i64->str a (al-len [Param] (load (load (field fp params))))))) " parameters")))) 0))
                0)))
      (try! (validate-params a cx (load (field fp params)) tps fnm))
      (if (type-is-void (field fp ret)) 0
          (match (validate-type (field fp ret) cx tps)
            (Err [d] (return-from :try (Err [Func Diag] (prefix-diag a d (sconcat3 a "function '" fnm "' return type: ")))))
            (Ok [_] 0)))
      (let [env (build-param-env a cx (load (field fp params)) tps) body (load (field fp body)) bn (al-len [Expr] (load body))]
        (if (icmp-eq bn 0)
            (if (and (not (type-eq (field fp ret) (box-type a (TInt 64 true)))) (not (type-is-void (field fp ret))))
                (return-from :try (Err [Func Diag] (derr (sconcat a (sconcat3 a "function '" fnm "': body has type i64 but the declared return type is ") (ty-str a (field fp ret)))))) 0)
            0)
        (let [out-body (try! (check-body a cx fp env tps fnm)) outf (alloc-stack Func)]
          (store! (field outf name) fnm)
          (store! (field outf type_params) tps)
          (store! (field outf bounds) (load (field fp bounds)))
          (store! (field outf cc) (load (field fp cc)))
          (store! (field outf params) (erase-param-types a cx (load (field fp params)) tps))
          (store! (field outf ret) (erase-refs a (field fp ret)))
          (store! (field outf body) out-body)
          (store! (field outf macro_variadic) (load (field fp macro_variadic)))
          (store! (field outf lo) (load (field fp lo)))
          (store! (field outf hi) (load (field fp hi)))
          (Ok (load outf))))))))

; ============================ check.rs: synth helpers =======================
(defstruct SynPair [(e (ptr Expr)) (t (ptr Type))])
(defstruct SubstEntry [(name (slice u8)) (ty Type)])
(defstruct ArgSlot [(present bool) (e (ptr Expr)) (t (ptr Type))])
(defstruct Deferred [(idx i64) (err Diag)])
(defstruct SumVars [(found bool) (name (slice u8)) (variants (ptr (ArrayList Variant)))])
(defstruct TargsOpt [(found bool) (targs (ptr (ArrayList Type)))])
(defstruct Branch [(e (ptr Expr)) (t (ptr Type))])

(defn sconcat1 [(a (ptr Allocator)) (x (slice u8))] (-> (slice u8)) x)
(defn sconcat4 [(a (ptr Allocator)) (w (slice u8)) (x (slice u8)) (y (slice u8)) (z (slice u8))] (-> (slice u8)) (sconcat a (sconcat3 a w x y) z))
(defn sconcat5 [(a (ptr Allocator)) (v (slice u8)) (w (slice u8)) (x (slice u8)) (y (slice u8)) (z (slice u8))] (-> (slice u8)) (sconcat a (sconcat4 a v w x y) z))
(defn mk-synpair [(a (ptr Allocator)) (e (ptr Expr)) (t (ptr Type))] (-> SynPair)
  (let [p (alloc-stack SynPair)] (store! (field p e) e) (store! (field p t) t) (load p)))
(defn ok-ep [(e Expr) (t Type)] (-> (Result EvalPair Diag)) (Ok [EvalPair Diag] (mk-evalpair e t)))
(defn err-ep [(d Diag)] (-> (Result EvalPair Diag)) (Err [EvalPair Diag] d))

(defn do-synth [(a (ptr Allocator)) (e (ptr Expr)) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result SynPair Diag))
  (match (synth a e expected env cx tps fname)
    (Err [d] (Err [SynPair Diag] d))
    (Ok [rv] (let [r (alloc-stack EvalPair)] (store! r rv)
               (Ok (mk-synpair a (box-expr a (load (field r e))) (box-type a (load (field r t)))))))))

(defn expected-some? [(expected (ptr Type))] (-> bool) (icmp-ne (cast i64 expected) 0))
(defn null-type [] (-> (ptr Type)) (cast (ptr Type) 0))

; ---- env --------------------------------------------------------------------
(defn env-get [(env (ptr (ArrayList EnvEntry))) (name (slice u8))] (-> (ptr Type))
  (let [n (al-len [EnvEntry] (load env)) (mut i) (isub n 1) (mut r) (cast (ptr Type) 0)]
    (loop (if (icmp-lt (load i) 0) (break)
      (do (if (str-eq (load (field (al-elem [EnvEntry] env (load i)) name)) name)
              (do (store! r (field (al-elem [EnvEntry] env (load i)) ty)) (break)) 0)
          (store! i (isub (load i) 1)))))
    (load r)))
(defn env-insert! [(env (ptr (ArrayList EnvEntry))) (name (slice u8)) (ty (ptr Type))] (-> i64)
  (let [ee (alloc-stack EnvEntry)] (store! (field ee name) name) (store! (field ee ty) (load ty))
    (al-push! [EnvEntry] env (load ee))))
(defn env-truncate! [(env (ptr (ArrayList EnvEntry))) (newlen i64)] (-> i64)
  (store! (field env len) newlen) 0)

; ---- substitution map -------------------------------------------------------
(defn subst-new [(a (ptr Allocator))] (-> (ptr (ArrayList SubstEntry)))
  (box-al [SubstEntry] a (al-new [SubstEntry] a)))
(defn subst-get [(s (ptr (ArrayList SubstEntry))) (name (slice u8))] (-> (ptr Type))
  (let [n (al-len [SubstEntry] (load s)) (mut i) 0 (mut r) (cast (ptr Type) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [SubstEntry] s (load i)) name)) name)
              (do (store! r (field (al-elem [SubstEntry] s (load i)) ty)) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn subst-has [(s (ptr (ArrayList SubstEntry))) (name (slice u8))] (-> bool)
  (icmp-ne (cast i64 (subst-get s name)) 0))
(defn subst-insert! [(s (ptr (ArrayList SubstEntry))) (name (slice u8)) (ty (ptr Type))] (-> i64)
  (let [se (alloc-stack SubstEntry)] (store! (field se name) name) (store! (field se ty) (load ty))
    (al-push! [SubstEntry] s (load se))))

; ---- pure type helpers ------------------------------------------------------
(defn after-last-dot [(s (slice u8))] (-> (slice u8))
  (let [n (slice-len [u8] s) (mut i) (isub n 1) (mut at) -1]
    (loop (if (icmp-lt (load i) 0) (break)
      (do (if (icmp-eq (cast i64 (slice-get s (load i))) 46) (do (store! at (load i)) (break)) 0)
          (store! i (isub (load i) 1)))))
    (if (icmp-lt (load at) 0) s (subslice [u8] s (iadd (load at) 1) n))))
(defn is-struct-or-app [(t (ptr Type))] (-> bool)
  (let [tg (type-tag t)] (or (icmp-eq tg 6) (icmp-eq tg 11))))
(defn struct-name [(t (ptr Type))] (-> (slice u8))
  (let [tg (type-tag t)] (if (icmp-eq tg 6) (type-struct-name t) (if (icmp-eq tg 11) (t-app-name t) ""))))
(defn place-pointee [(t (ptr Type))] (-> (ptr Type))
  (let [tg (type-tag t)] (if (or (icmp-eq tg 4) (icmp-eq tg 5)) (t-inner t) (cast (ptr Type) 0))))
(defn is-writable [(t (ptr Type))] (-> bool)
  (let [tg (type-tag t)] (or (icmp-eq tg 4) (and (icmp-eq tg 5) (t-ref-mut t)))))
(defn replace-pointee [(a (ptr Allocator)) (place (ptr Type)) (new (ptr Type))] (-> Type)
  (if (icmp-eq (type-tag place) 5) (TRef (t-ref-mut place) (box-type a (load new))) (TPtr (box-type a (load new)))))
(defn is-place-value-type [(t (ptr Type)) (cx (ptr Cx))] (-> bool)
  (let [tg (type-tag t)]
    (if (icmp-eq tg 6) (icmp-ne (cast i64 (struct-find cx (type-struct-name t))) 0)
    (if (icmp-eq tg 11) (icmp-ne (cast i64 (struct-find cx (t-app-name t))) 0)
    (if (icmp-eq tg 7) true false)))))
(defn has-impl-name [(t (ptr Type))] (-> bool)
  (let [tg (type-tag t)] (or (icmp-eq tg 6) (or (icmp-eq tg 11) (or (icmp-eq tg 0) (or (icmp-eq tg 2) (icmp-eq tg 1)))))))
(defn type-impl-name [(a (ptr Allocator)) (t (ptr Type))] (-> (slice u8))
  (let [tg (type-tag t)]
    (if (or (icmp-eq tg 6) (icmp-eq tg 11)) (struct-name t)
    (if (icmp-eq tg 0) (sconcat a (if (t-int-signed t) "i" "u") (i64->str a (t-int-bits t)))
    (if (icmp-eq tg 2) "bool"
    (if (icmp-eq tg 1) (sconcat a "f" (i64->str a (t-int-bits t)))
    ""))))))

(defn subst-apply-list [(a (ptr Allocator)) (v (ptr (ArrayList Type))) (subst (ptr (ArrayList SubstEntry)))] (-> (ptr (ArrayList Type)))
  (let [(mut out) (al-new [Type] a) n (al-len [Type] (load v)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut out) (subst-apply a (al-elem [Type] v (load i)) subst))
          (store! i (iadd (load i) 1)))))
    (box-al [Type] a (load out))))
(defn subst-apply [(a (ptr Allocator)) (t (ptr Type)) (subst (ptr (ArrayList SubstEntry)))] (-> Type)
  (match-else (load t)
    (TPtr   [p] (TPtr (box-type a (subst-apply a p subst))))
    (TRef   [m p] (TRef m (box-type a (subst-apply a p subst))))
    (TArray [e k] (TArray (box-type a (subst-apply a e subst)) k))
    (TSlice [e] (TSlice (box-type a (subst-apply a e subst))))
    (TVec   [e k] (TVec (box-type a (subst-apply a e subst)) k))
    (TStruct [n] (let [r (subst-get subst n)] (if (icmp-eq (cast i64 r) 0) (TStruct n) (load r))))
    (TApp   [n args] (TApp n (subst-apply-list a args subst)))
    (TFn    [cc ps r] (TFn cc (subst-apply-list a ps subst) (box-type a (subst-apply a r subst))))
    (_ (load t))))

(defn fields-subst [(a (ptr Allocator)) (si (ptr StructInfo)) (args (ptr (ArrayList Type)))] (-> (ptr (ArrayList Field)))
  (let [subst (subst-new a) tparams (load (field si type_params)) np (al-len [(slice u8)] (load tparams)) (mut i) 0]
    (loop (if (icmp-ge (load i) np) (break)
      (do (subst-insert! subst (al-get [(slice u8)] (load tparams) (load i)) (al-elem [Type] args (load i)))
          (store! i (iadd (load i) 1)))))
    (let [fs (load (field si fields)) nf (al-len [Field] (load fs)) (mut out) (al-new [Field] a) (mut j) 0]
      (loop (if (icmp-ge (load j) nf) (break)
        (do (let [fp (al-elem [Field] fs (load j)) nf2 (alloc-stack Field)]
              (store! (field nf2 name) (load (field fp name)))
              (store! (field nf2 ty) (subst-apply a (field fp ty) subst))
              (al-push! (mut out) (load nf2)))
            (store! j (iadd (load j) 1)))))
      (box-al [Field] a (load out)))))
(defn struct-fields [(a (ptr Allocator)) (t (ptr Type)) (cx (ptr Cx))] (-> (Result (ptr (ArrayList Field)) Diag))
  (let [tg (type-tag t)]
    (if (icmp-eq tg 6)
        (let [si (struct-find cx (type-struct-name t))]
          (if (icmp-eq (cast i64 si) 0) (Err [(ptr (ArrayList Field)) Diag] (derr (sconcat3 a "unknown struct '" (type-struct-name t) "'")))
              (Ok (load (field si fields)))))
    (if (icmp-eq tg 11)
        (let [si (struct-find cx (t-app-name t))]
          (if (icmp-eq (cast i64 si) 0) (Err [(ptr (ArrayList Field)) Diag] (derr (sconcat3 a "unknown generic struct '" (t-app-name t) "'")))
              (Ok (fields-subst a si (t-fn-params t)))))
    (Err [(ptr (ArrayList Field)) Diag] (derr (sconcat a "not a struct: " (ty-str a t))))))))

(defn mk-sumvars [(found bool) (name (slice u8)) (variants (ptr (ArrayList Variant)))] (-> SumVars)
  (let [p (alloc-stack SumVars)] (store! (field p found) found) (store! (field p name) name) (store! (field p variants) variants) (load p)))
(defn variants-subst [(a (ptr Allocator)) (si (ptr SumInfo)) (args (ptr (ArrayList Type)))] (-> (ptr (ArrayList Variant)))
  (let [subst (subst-new a) tparams (load (field si type_params)) np (al-len [(slice u8)] (load tparams)) (mut i) 0]
    (loop (if (icmp-ge (load i) np) (break)
      (do (subst-insert! subst (al-get [(slice u8)] (load tparams) (load i)) (al-elem [Type] args (load i)))
          (store! i (iadd (load i) 1)))))
    (let [vs (load (field si variants)) nv (al-len [Variant] (load vs)) (mut out) (al-new [Variant] a) (mut j) 0]
      (loop (if (icmp-ge (load j) nv) (break)
        (do (let [vp (al-elem [Variant] vs (load j)) fs (load (field vp fields)) nf (al-len [Field] (load fs))
                  (mut fout) (al-new [Field] a) (mut k) 0 nv2 (alloc-stack Variant)]
              (loop (if (icmp-ge (load k) nf) (break)
                (do (let [fp (al-elem [Field] fs (load k)) nf2 (alloc-stack Field)]
                      (store! (field nf2 name) (load (field fp name)))
                      (store! (field nf2 ty) (subst-apply a (field fp ty) subst))
                      (al-push! (mut fout) (load nf2)))
                    (store! k (iadd (load k) 1)))))
              (store! (field nv2 name) (load (field vp name)))
              (store! (field nv2 fields) (box-al [Field] a (load fout)))
              (al-push! (mut out) (load nv2)))
            (store! j (iadd (load j) 1)))))
      (box-al [Variant] a (load out)))))
(defn sum-variants [(a (ptr Allocator)) (t (ptr Type)) (cx (ptr Cx))] (-> SumVars)
  (let [tg (type-tag t)]
    (if (icmp-eq tg 6)
        (let [si (sum-find cx (type-struct-name t))]
          (if (icmp-eq (cast i64 si) 0) (mk-sumvars false "" (cast (ptr (ArrayList Variant)) 0))
              (mk-sumvars true (type-struct-name t) (load (field si variants)))))
    (if (icmp-eq tg 11)
        (let [si (sum-find cx (t-app-name t))]
          (if (icmp-eq (cast i64 si) 0) (mk-sumvars false "" (cast (ptr (ArrayList Variant)) 0))
              (mk-sumvars true (t-app-name t) (variants-subst a si (t-fn-params t)))))
    (mk-sumvars false "" (cast (ptr (ArrayList Variant)) 0))))))

(defn expected-sum-targs [(a (ptr Allocator)) (expected (ptr Type)) (sumname (slice u8)) (arity i64)] (-> TargsOpt)
  (let [p (alloc-stack TargsOpt) tg (type-tag expected)]
    (store! (field p found) false) (store! (field p targs) (cast (ptr (ArrayList Type)) 0))
    (if (icmp-eq tg 11)
        (if (and (str-eq (t-app-name expected) sumname) (icmp-eq (al-len [Type] (load (t-fn-params expected))) arity))
            (do (store! (field p found) true) (store! (field p targs) (t-fn-params expected)) 0) 0)
    (if (icmp-eq tg 6)
        (if (and (str-eq (type-struct-name expected) sumname) (icmp-eq arity 0))
            (do (store! (field p found) true) (store! (field p targs) (box-items-type a)) 0) 0)
      0))
    (load p)))

(defn mismatch-msg [(a (ptr Allocator)) (x (ptr Type)) (y (ptr Type)) (fname (slice u8)) (what (slice u8))] (-> Diag)
  (if (and (type-is-int x) (type-is-int y))
      (if (not (icmp-eq (t-int-bits x) (t-int-bits y)))
          (derr (sconcat a (sconcat a (sconcat a (sconcat3 a "in '" fname "': ") (sconcat a what " on mixed widths (")) (i64->str a (t-int-bits x))) (sconcat a " and " (sconcat a (i64->str a (t-int-bits y)) " bits)"))))
          (derr (sconcat a (sconcat a (sconcat a (sconcat3 a "in '" fname "': ") (sconcat a what " on mixed signedness (")) (ty-str a x)) (sconcat a " and " (sconcat a (ty-str a y) ")")))))
      (derr (sconcat a (sconcat a (sconcat a (sconcat3 a "in '" fname "': ") (sconcat a what " on different types (")) (ty-str a x)) (sconcat a " vs " (sconcat a (ty-str a y) ")"))))))

; unify_branches (src/check.rs:2943): fill `out` with coerced exprs, return target type.
(defn unify-branches [(a (ptr Allocator)) (branches (ptr (ArrayList Branch))) (out (ptr (ArrayList Expr))) (fname (slice u8)) (what (slice u8))] (-> (Result Type Diag))
  (let [n (al-len [Branch] (load branches)) (mut i) 0 (mut have) false (mut concrete) (cast (ptr Type) 0)
        (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [bp (al-elem [Branch] branches (load i)) be (load (field bp e)) bt (load (field bp t))]
            (if (and (not (is-literal be)) (not (type-is-never bt)))
                (if (not (load have)) (do (store! have true) (store! concrete bt) 0)
                    (if (not (type-eq (load concrete) bt))
                        (do (store! err (mismatch-msg a (load concrete) bt fname what)) (store! failed true) (break)) 0))
                0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [Type Diag] (load err))
      (let [(mut target) (cast (ptr Type) 0)]
        (if (load have) (do (store! target (load concrete)) 0)
          (let [(mut j) 0 (mut done) false]
            (loop (if (or (load done) (icmp-ge (load j) n)) (break)
              (do (let [bp (al-elem [Branch] branches (load j))]
                    (if (not (type-is-never (load (field bp t)))) (do (store! target (load (field bp t))) (store! done true) 0) 0))
                  (store! j (iadd (load j) 1)))))
            (if (not (load done)) (do (store! target (box-type a (TInt 64 true))) 0) 0)))
        (let [(mut k) 0 (mut err2) (zeroed Diag) (mut failed2) false]
          (loop (if (icmp-ge (load k) n) (break)
            (do (let [bp (al-elem [Branch] branches (load k)) be (load (field bp e)) bt (load (field bp t))]
                  (if (or (type-eq bt (load target)) (type-is-never bt)) (al-push! [Expr] out (load be))
                    (if (and (same-number-kind bt (load target)) (is-literal be))
                        (match (coerce-lit a (load be) (load target) fname)
                          (Err [d] (do (store! err2 d) (store! failed2 true) (break)))
                          (Ok [ce] (al-push! [Expr] out ce)))
                        (do (store! err2 (mismatch-msg a bt (load target) fname what)) (store! failed2 true) (break)))))
                (store! k (iadd (load k) 1)))))
          (if (load failed2) (Err [Type Diag] (load err2)) (Ok (load (load target)))))))))

; coerce_arg (src/check.rs:2485)
(defn coerce-arg [(a (ptr Allocator)) (is_mut_borrow bool) (ae Expr) (at (ptr Type)) (want (ptr Type)) (is_extern bool) (fname (slice u8)) (what (slice u8))] (-> (Result Expr Diag))
  (let [aep (alloc-stack Expr)] (store! aep ae)
    (let [wtg (type-tag want)]
      (if (icmp-eq wtg 5)
          (let [wp (t-inner want) want_mut (t-ref-mut want) ap (place-pointee at)]
            (if (icmp-eq (cast i64 ap) 0)
                (if want_mut (Err [Expr Diag] (derr (sconcat a (sconcat a (sconcat3 a "in '" fname "': ") (sconcat a what " is a (mut ")) (sconcat a (ty-str a wp) ") parameter; pass a mutable place as (mut …)"))))
                  (if (not (type-eq at wp)) (Err [Expr Diag] (derr (sconcat a (sconcat a (sconcat a (sconcat3 a "in '" fname "': ") (sconcat a what " expects a reference to ")) (ty-str a wp)) (sconcat a ", got " (ty-str a at)))))
                    (Ok (mk-expr (ESpillRef (box-expr a (load aep))) (load (field aep lo)) (load (field aep hi))))))
                (if (not (type-eq ap wp))
                    (Err [Expr Diag] (derr (sconcat a (sconcat a (sconcat a (sconcat3 a "in '" fname "': ") (sconcat a what " has type ")) (ty-str a at)) (sconcat a " but expected a reference to " (ty-str a wp)))))
                  (if want_mut
                      (let [explicitly_mut (or is_mut_borrow (type-is-ptr at))]
                        (if (not explicitly_mut) (Err [Expr Diag] (derr (sconcat a (sconcat a (sconcat3 a "in '" fname "': ") (sconcat a what " is a (mut ")) (sconcat a (ty-str a wp) ") parameter; pass a mutable place as (mut …)"))))
                          (if (not (is-writable at)) (Err [Expr Diag] (derr (sconcat a (sconcat3 a "in '" fname "': ") (sconcat a what " cannot be mutably borrowed (it is immutable)"))))
                            (Ok (load aep)))))
                      (Ok (load aep))))))
      (if (icmp-eq wtg 6)
          (if (type-eq at want) (Ok (load aep))
            (if is_extern
                (let [pp (place-pointee at)]
                  (if (and (icmp-ne (cast i64 pp) 0) (str-eq (struct-name pp) (type-struct-name want))) (Ok (load aep))
                      (coerce a (load aep) at want is_extern fname what)))
                (coerce a (load aep) at want is_extern fname what)))
      (if (icmp-eq wtg 4)
          (let [wp (t-inner want) pp (place-pointee at)]
            (if (and (icmp-ne (cast i64 pp) 0) (and (type-eq pp wp) (is-writable at))) (Ok (load aep))
                (coerce a (load aep) at want is_extern fname what)))
        (coerce a (load aep) at want is_extern fname what)))))))

(defn check-to [(a (ptr Allocator)) (e (ptr Expr)) (want (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (what (slice u8))] (-> (Result Expr Diag))
  (match (do-synth a e want env cx tps fname)
    (Err [d] (Err [Expr Diag] d))
    (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
                (coerce a (load (load (field sp e))) (load (field sp t)) want false fname what)))))

; unify (src/check.rs:2212)
(defn unify [(a (ptr Allocator)) (decl (ptr Type)) (actual (ptr Type)) (tpset (ptr (ArrayList (slice u8)))) (subst (ptr (ArrayList SubstEntry))) (fname (slice u8))] (-> (Result i64 Diag))
  (if (or (type-is-void decl) (type-is-void actual))
      (Err [i64 Diag] (derr (sconcat3 a "in '" fname "': a void value cannot be used as a type argument (a (-> void) call yields nothing)")))
    (if (and (icmp-eq (type-tag decl) 6) (set-contains tpset (type-struct-name decl)))
        (let [p (type-struct-name decl)
              act (if (icmp-eq (type-tag actual) 5) (t-inner actual) actual)
              prev (subst-get subst p)]
          (if (icmp-ne (cast i64 prev) 0)
              (if (not (type-eq prev act))
                  (Err [i64 Diag] (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': conflicting types for parameter '" (sconcat a p "' (")) (ty-str a prev)) " vs ") (sconcat a (ty-str a act) ")"))))
                  (Ok [i64 Diag] 0))
              (do (subst-insert! subst p act) (Ok [i64 Diag] 0))))
      (let [dt (type-tag decl) at2 (type-tag actual)]
        (if (and (icmp-eq dt 4) (icmp-eq at2 4)) (unify a (t-inner decl) (t-inner actual) tpset subst fname)
        (if (icmp-eq dt 5) (unify a (t-inner decl) actual tpset subst fname)
        (if (icmp-eq at2 5) (unify a decl (t-inner actual) tpset subst fname)
        (if (and (icmp-eq dt 7) (icmp-eq at2 7)) (unify a (t-inner decl) (t-inner actual) tpset subst fname)
        (if (and (icmp-eq dt 8) (icmp-eq at2 8)) (unify a (t-inner decl) (t-inner actual) tpset subst fname)
        (if (and (and (icmp-eq dt 11) (icmp-eq at2 11)) (and (str-eq (t-app-name decl) (t-app-name actual)) (icmp-eq (al-len [Type] (load (t-fn-params decl))) (al-len [Type] (load (t-fn-params actual))))))
            (unify-list a (t-fn-params decl) (t-fn-params actual) tpset subst fname)
        (if (and (and (icmp-eq dt 10) (icmp-eq at2 10)) (icmp-eq (al-len [Type] (load (t-fn-params decl))) (al-len [Type] (load (t-fn-params actual)))))
            (match (unify-list a (t-fn-params decl) (t-fn-params actual) tpset subst fname)
              (Err [d] (Err [i64 Diag] d)) (Ok [_] (unify a (t-fn-ret decl) (t-fn-ret actual) tpset subst fname)))
          (Ok [i64 Diag] 0))))))))))))
(defn unify-list [(a (ptr Allocator)) (xs (ptr (ArrayList Type))) (ys (ptr (ArrayList Type))) (tpset (ptr (ArrayList (slice u8)))) (subst (ptr (ArrayList SubstEntry))) (fname (slice u8))] (-> (Result i64 Diag))
  (let [n (al-len [Type] (load xs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (unify a (al-elem [Type] xs (load i)) (al-elem [Type] ys (load i)) tpset subst fname)
            (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [i64 Diag] (load err)) (Ok [i64 Diag] 0))))

; solve_type_args (src/check.rs:2160)
(defn solve-type-args [(a (ptr Allocator)) (type_params (ptr (ArrayList (slice u8)))) (declared (ptr (ArrayList Type))) (type_args (ptr (ArrayList Type))) (arglist (ptr (ArrayList ArgSlot))) (ret_tmpl (ptr Type)) (expected (ptr Type)) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (what (slice u8))] (-> (Result (ptr (ArrayList SubstEntry)) Diag))
  (let [subst (subst-new a) np (al-len [(slice u8)] (load type_params))]
    (if (icmp-gt (al-len [Type] (load type_args)) 0)
        (if (not (icmp-eq (al-len [Type] (load type_args)) np))
            (Err [(ptr (ArrayList SubstEntry)) Diag] (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': '" (sconcat a what "' expects ")) (i64->str a np)) " type arguments, got ") (i64->str a (al-len [Type] (load type_args))))))
          (let [(mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
            (loop (if (icmp-ge (load i) np) (break)
              (do (match (validate-type (al-elem [Type] type_args (load i)) cx tps)
                    (Err [d] (do (store! err (prefix-diag a d (sconcat3 a "in '" fname "': type argument: "))) (store! failed true) (break))) (Ok [_] 0))
                  (subst-insert! subst (al-get [(slice u8)] (load type_params) (load i)) (al-elem [Type] type_args (load i)))
                  (store! i (iadd (load i) 1)))))
            (if (load failed) (Err [(ptr (ArrayList SubstEntry)) Diag] (load err)) (Ok subst))))
      (let [(mut err) (zeroed Diag) (mut failed) false]
        (if (expected-some? expected)
            (match (unify a ret_tmpl expected type_params subst fname)
              (Err [d] (do (store! err d) (store! failed true) 0)) (Ok [_] 0)) 0)
        (if (load failed) (Err [(ptr (ArrayList SubstEntry)) Diag] (load err))
          (let [nd (al-len [Type] (load declared)) (mut j) 0]
            (loop (if (icmp-ge (load j) nd) (break)
              (do (let [slot (al-elem [ArgSlot] arglist (load j))]
                    (if (load (field slot present))
                        (match (unify a (al-elem [Type] declared (load j)) (load (field slot t)) type_params subst fname)
                          (Err [d] (do (store! err d) (store! failed true) (break))) (Ok [_] 0))
                        0))
                  (store! j (iadd (load j) 1)))))
            (if (load failed) (Err [(ptr (ArrayList SubstEntry)) Diag] (load err))
              (let [(mut k) 0 (mut missing) false (mut mp) ""]
                (loop (if (icmp-ge (load k) np) (break)
                  (do (let [pn (al-get [(slice u8)] (load type_params) (load k))]
                        (if (not (subst-has subst pn)) (do (store! missing true) (store! mp pn) (break)) 0))
                      (store! k (iadd (load k) 1)))))
                (if (load missing)
                    (Err [(ptr (ArrayList SubstEntry)) Diag] (derr (sconcat a (sconcat a (sconcat4 a "in '" fname "': cannot infer type argument '" (sconcat a (load mp) "' for '")) (sconcat a what "'; provide it explicitly: (")) (sconcat a what " [<types>] ...)"))))
                  (Ok subst))))))))))

; bit_field_type (src/check.rs:2715)
(defn bit-field-type [(a (ptr Allocator)) (ptr (ptr Expr)) (field (slice u8)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result SynPair Diag))
  (match (do-synth a ptr (null-type) env cx tps fname)
    (Err [d] (Err [SynPair Diag] d))
    (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
      (let [pt (load (field sp t))]
        (if (not (type-is-ptr pt))
            (Err [SynPair Diag] (derr (sconcat a (sconcat3 a "in '" fname "': get/set! needs a pointer, got ") (ty-str a pt))))
          (let [pointee (t-inner pt) s (struct-name pointee) si (struct-find cx s)]
            (if (and (is-struct-or-app pointee) (and (icmp-ne (cast i64 si) 0) (load (field si is_bits))))
                (match (struct-fields a pointee cx)
                  (Err [_] (Err [SynPair Diag] (derr (sconcat a (sconcat a (sconcat5 a "in '" fname "': bit struct '" s "' has no field '") field) "'"))))
                  (Ok [fs]
                    (let [n (al-len [Field] (load fs)) (mut i) 0 (mut fty) (cast (ptr Type) 0)]
                      (loop (if (icmp-ge (load i) n) (break)
                        (do (if (str-eq (load (field (al-elem [Field] fs (load i)) name)) field) (do (store! fty (field (al-elem [Field] fs (load i)) ty)) (break)) 0)
                            (store! i (iadd (load i) 1)))))
                      (if (icmp-eq (cast i64 (load fty)) 0)
                          (Err [SynPair Diag] (derr (sconcat a (sconcat a (sconcat5 a "in '" fname "': bit struct '" s "' has no field '") field) "'")))
                          (Ok (mk-synpair a (load (field sp e)) (load fty)))))))
                (Err [SynPair Diag] (derr (sconcat a (sconcat a (sconcat3 a "in '" fname "': get/set! needs a pointer to a :layout bits struct, got (ptr ") (ty-str a pointee)) ")")))))))))))

; check_quasi (src/check.rs:2799)
(defn check-quasi [(a (ptr Allocator)) (qp (ptr Quasi)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result Quasi Diag))
  (match-else (load qp)
    (QLit [form] (Ok [Quasi Diag] (QLit form)))
    (QUnquote [e] (match (do-synth a e (null-type) env cx tps fname) (Err [d] (Err [Quasi Diag] d)) (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0) (Ok (QUnquote (load (field sp e))))))))
    (QSplice [e] (match (do-synth a e (null-type) env cx tps fname) (Err [d] (Err [Quasi Diag] d)) (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0) (Ok (QSplice (load (field sp e))))))))
    (QList [items] (match (check-quasi-list a items env cx tps fname) (Err [d] (Err [Quasi Diag] d)) (Ok [nl] (Ok (QList nl)))))
    (QVector [items] (match (check-quasi-list a items env cx tps fname) (Err [d] (Err [Quasi Diag] d)) (Ok [nl] (Ok (QVector nl)))))
    (_ (Ok [Quasi Diag] (load qp)))))
(defn check-quasi-list [(a (ptr Allocator)) (items (ptr (ArrayList Quasi))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result (ptr (ArrayList Quasi)) Diag))
  (let [n (al-len [Quasi] (load items)) (mut out) (al-new [Quasi] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (check-quasi a (al-elem [Quasi] items (load i)) env cx tps fname)
            (Err [d] (do (store! err d) (store! failed true) (break)))
            (Ok [q] (al-push! (mut out) q)))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList Quasi)) Diag] (load err)) (Ok (box-al [Quasi] a (load out))))))

; ---- dyn / trait helpers ----------------------------------------------------
(defn dyn-struct-trait [(cx (ptr Cx)) (name (slice u8))] (-> (slice u8))
  (let [n (slice-len [u8] name)]
    (if (icmp-lt n 4) ""
      (let [base (subslice [u8] name 0 (isub n 4)) suf (subslice [u8] name (isub n 4) n)]
        (if (str-eq suf "-dyn") (if (icmp-ne (cast i64 (trait-find cx base)) 0) base "") "")))))
(defn is-dyn-target [(t (ptr Type)) (cx (ptr Cx))] (-> bool)
  (let [tg (type-tag t)]
    (if (icmp-eq tg 6) (icmp-gt (slice-len [u8] (dyn-struct-trait cx (type-struct-name t))) 0)
    (if (icmp-eq tg 5)
        (let [inner (t-inner t)]
          (if (icmp-eq (type-tag inner) 6) (icmp-gt (slice-len [u8] (dyn-struct-trait cx (type-struct-name inner))) 0) false))
      false))))
(defn resolve-trait-name [(cx (ptr Cx)) (name (slice u8))] (-> (slice u8))
  (if (icmp-ne (cast i64 (trait-find cx name)) 0) name
    (let [n (al-len [TraitDef] (load (field cx trait_defs))) (mut i) 0 (mut found) "" (mut cnt) 0]
      (loop (if (icmp-ge (load i) n) (break)
        (do (let [k (load (field (al-elem [TraitDef] (field cx trait_defs) (load i)) name))]
              (if (str-eq (after-last-dot k) name) (do (store! found k) (store! cnt (iadd (load cnt) 1))) 0))
            (store! i (iadd (load i) 1)))))
      (if (icmp-eq (load cnt) 1) (load found) ""))))
(defn trait-visible [(cx (ptr Cx)) (tr (slice u8)) (caller (slice u8)) (has_caller bool)] (-> bool)
  (if (not (has-dot tr)) true
    (let [tmod (subslice [u8] tr 0 (find-slash-dot tr)) tname (after-last-dot tr)]
      (if (or (str-eq tmod "coil.core") (and has_caller (str-eq tmod caller))) true
        (if (not has_caller) false
          (let [imp (imports-find (load (field cx imports)) caller)]
            (if (icmp-eq (cast i64 imp) 0) false
              (let [uses (field (field imp imp) uses) nu (al-len [Use] (load (field (field imp imp) uses))) (mut i) 0 (mut vis) false]
                (loop (if (icmp-ge (load i) nu) (break)
                  (do (let [up (al-elem [Use] uses (load i))]
                        (if (str-eq (load (field up target)) tmod)
                            (let [okspec (match-else (load (field up spec)) (UAll [] true) (UNames [ns] (set-contains ns tname)) (_ false))]
                              (if (and okspec (exports-check (load (field cx exports)) tmod tname)) (do (store! vis true) (break)) 0)) 0))
                      (store! i (iadd (load i) 1)))))
                (load vis)))))))))
(defn find-slash-dot [(s (slice u8))] (-> i64)
  (let [n (slice-len [u8] s) (mut i) (isub n 1) (mut at) -1]
    (loop (if (icmp-lt (load i) 0) (break)
      (do (if (icmp-eq (cast i64 (slice-get s (load i))) 46) (do (store! at (load i)) (break)) 0)
          (store! i (isub (load i) 1)))))
    (load at)))

; resolve_method (src/check.rs:125) — returns a chosen MethodEntry.
(defn resolve-method [(a (ptr Allocator)) (cx (ptr Cx)) (func (slice u8)) (fname (slice u8))] (-> (Result MethodEntry Diag))
  (let [ms (field cx methods) n (al-len [MethodEntry] (load (field cx methods))) (mut i) 0 (mut cnt) 0 (mut only) (cast (ptr MethodEntry) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [MethodEntry] ms (load i)) name)) func) (do (store! cnt (iadd (load cnt) 1)) (store! only (al-elem [MethodEntry] ms (load i))) 0) 0)
          (store! i (iadd (load i) 1)))))
    (if (icmp-eq (load cnt) 1) (Ok (load (load only)))
      (let [has_caller (has-dot fname) caller (if (has-dot fname) (subslice [u8] fname 0 (find-slash-dot fname)) "")
            (mut j) 0 (mut vcnt) 0 (mut vonly) (cast (ptr MethodEntry) 0)]
        (loop (if (icmp-ge (load j) n) (break)
          (do (let [me (al-elem [MethodEntry] ms (load j))]
                (if (and (str-eq (load (field me name)) func) (trait-visible cx (load (field me trait)) caller has_caller))
                    (do (store! vcnt (iadd (load vcnt) 1)) (store! vonly me) 0) 0))
              (store! j (iadd (load j) 1)))))
        (if (icmp-eq (load vcnt) 1) (Ok (load (load vonly)))
          (if (icmp-eq (load vcnt) 0)
              (Err [MethodEntry Diag] (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': trait method '" (sconcat a func "' is declared in ")) (i64->str a (load cnt))) " traits, none in scope here ") "(`:use` the module whose trait you mean)")))
              (Err [MethodEntry Diag] (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': trait method '" (sconcat a func "' is ambiguous — ")) (i64->str a (load vcnt))) " in-scope traits declare it; ") "rename one method to disambiguate")))))))))

(defn bounds-has [(bounds (ptr (ArrayList Bound))) (tp (slice u8)) (tr (slice u8))] (-> bool)
  (let [n (al-len [Bound] (load bounds)) (mut i) 0 (mut r) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [bp (al-elem [Bound] bounds (load i))]
            (if (str-eq (load (field bp name)) tp)
                (let [trs (load (field bp traits)) m (al-len [(slice u8)] (load trs)) (mut k) 0]
                  (loop (if (icmp-ge (load k) m) (break)
                    (do (if (str-eq (al-get [(slice u8)] (load trs) (load k)) tr) (do (store! r true) (break)) 0)
                        (store! k (iadd (load k) 1)))))) 0))
          (store! i (iadd (load i) 1)))))
    (load r)))

; build_make_dyn / dyn dispatch — not yet ported (hard error, never reached by
; non-dyn programs because maybe-coerce-dyn/is-dyn-target gate on a -dyn struct).
(defn dyn-method-names [(a (ptr Allocator)) (td (ptr TraitDef)) (tr (slice u8)) (tn (slice u8))] (-> (ptr (ArrayList (slice u8))))
  (let [ms (load (field td methods)) n (al-len [TraitMethod] (load ms)) (mut out) (al-new [(slice u8)] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut out) (tmfn a tr tn (load (field (al-elem [TraitMethod] ms (load i)) name))))
          (store! i (iadd (load i) 1)))))
    (box-al [(slice u8)] a (load out))))
(defn build-make-dyn [(a (ptr Allocator)) (cx (ptr Cx)) (trait_name (slice u8)) (inner (ptr Expr)) (inner_ty (ptr Type)) (lo i64) (hi i64) (fname (slice u8))] (-> (Result SynPair Diag))
  (let [tr (resolve-trait-name cx trait_name)]
    (if (icmp-eq (slice-len [u8] tr) 0)
        (Err [SynPair Diag] (derr-at lo hi (sconcat1 a (sconcat4 a "in '" fname "': make-dyn: unknown trait '" (sconcat a trait_name "'")))))
      (if (not (type-is-ptr inner_ty))
          (Err [SynPair Diag] (derr-at lo hi (sconcat a (sconcat3 a "in '" fname "': make-dyn expects a pointer to an implementer, got ") (ty-str a inner_ty))))
        (let [pointee (t-inner inner_ty)]
          (if (not (has-impl-name pointee))
              (Err [SynPair Diag] (derr-at lo hi (sconcat a (sconcat a (sconcat4 a "in '" fname "': make-dyn: " (ty-str a pointee)) " cannot implement a trait") "")))
            (let [tn (type-impl-name a pointee)]
              (if (not (impl-has cx tr tn))
                  (Err [SynPair Diag] (derr-at lo hi (sconcat a (sconcat a (sconcat a (sconcat5 a "in '" fname "': '" (display-name tn) "' does not implement '") (display-name tr)) "' (needed for (dyn ") (sconcat a (display-name tr) "))"))))
                (let [dyn_struct (sconcat a tr "-dyn") vtable_struct (sconcat a tr "-vtable")]
                  (if (icmp-eq (cast i64 (struct-find cx dyn_struct)) 0)
                      (Err [SynPair Diag] (derr-at lo hi (sconcat a (sconcat a (sconcat5 a "in '" fname "': trait '" (display-name tr) "' has no trait object — call (defdyn ") (display-name tr)) ") after the trait")))
                    (let [td (trait-find cx tr) methods (dyn-method-names a td tr tn)]
                      (Ok (mk-synpair a (box-expr a (mk-expr (EMakeDyn dyn_struct vtable_struct methods inner) lo hi)) (box-type a (TStruct dyn_struct)))))))))))))))
(defn maybe-coerce-dyn [(a (ptr Allocator)) (cx (ptr Cx)) (ae (ptr Expr)) (at (ptr Type)) (want (ptr Type)) (lo i64) (hi i64) (fname (slice u8))] (-> (Result SynPair Diag))
  (let [wtg (type-tag want)
        wdname (if (icmp-eq wtg 6) (type-struct-name want) (if (and (icmp-eq wtg 5) (icmp-eq (type-tag (t-inner want)) 6)) (type-struct-name (t-inner want)) ""))]
    (if (icmp-eq (slice-len [u8] wdname) 0) (Ok (mk-synpair a ae at))
      (if (and (type-is-ptr at) (not (and (icmp-eq (type-tag (t-inner at)) 6) (str-eq (type-struct-name (t-inner at)) wdname))))
          (let [tr (dyn-struct-trait cx wdname)]
            (if (icmp-gt (slice-len [u8] tr) 0) (build-make-dyn a cx tr ae at lo hi fname) (Ok (mk-synpair a ae at))))
        (Ok (mk-synpair a ae at))))))
; synth_construct (src/check.rs:2016)
(defn variant-in-sum [(si (ptr SumInfo)) (variant (slice u8))] (-> (ptr Variant))
  (let [vs (load (field si variants)) n (al-len [Variant] (load vs)) (mut i) 0 (mut r) (cast (ptr Variant) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [Variant] vs (load i)) name)) variant) (do (store! r (al-elem [Variant] vs (load i))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn field-types-of [(a (ptr Allocator)) (v (ptr Variant))] (-> (ptr (ArrayList Type)))
  (let [fs (load (field v fields)) n (al-len [Field] (load fs)) (mut out) (al-new [Type] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut out) (load (field (al-elem [Field] fs (load i)) ty)))
          (store! i (iadd (load i) 1)))))
    (box-al [Type] a (load out))))
(defn all-tparams-bound [(tparams (ptr (ArrayList (slice u8)))) (subst (ptr (ArrayList SubstEntry)))] (-> bool)
  (let [n (al-len [(slice u8)] (load tparams)) (mut i) 0 (mut all) true]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (not (subst-has subst (al-get [(slice u8)] (load tparams) (load i)))) (do (store! all false) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load all)))

(defn synth-construct [(a (ptr Allocator)) (variant (slice u8)) (type_args (ptr (ArrayList Type))) (args (ptr (ArrayList Expr))) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (lo i64) (hi i64)] (-> (Result EvalPair Diag))
  (try
   (do
    (let [sumname (load (field (vts-find cx variant) sum)) si (sum-find cx (load (field (vts-find cx variant) sum)))
          v (variant-in-sum si variant)]
      (if (not (icmp-eq (al-len [Field] (load (field v fields))) (al-len [Expr] (load args))))
          (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': variant '" (sconcat a variant "' takes ")) (i64->str a (al-len [Field] (load (field v fields))))) " field(s), got ") (i64->str a (al-len [Expr] (load args))))))) 0)
      (let [tparams (load (field si type_params)) field_types (field-types-of a v)
            subst (subst-new a) np (al-len [(slice u8)] (load tparams))]
        (if (icmp-gt (al-len [Type] (load type_args)) 0)
            (do (if (not (icmp-eq (al-len [Type] (load type_args)) np))
                    (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': '" (sconcat a variant "' expects ")) (i64->str a np)) " type arguments, got ") (i64->str a (al-len [Type] (load type_args))))))) 0)
                (try! (validate-targs a cx type_args tps fname))
                (build-subst! subst tparams type_args))
          (if (expected-some? expected)
              (let [to (alloc-stack-store-targs a expected sumname np)]
                (if (load (field to found)) (build-subst! subst tparams (load (field to targs))) 0))
            0))
        (let [new_args
              (if (all-tparams-bound tparams subst)
                  (try! (construct-check-args a field_types args subst variant env cx tps fname))
                  (try! (construct-infer-args a field_types args subst tparams variant env cx tps fname)))]
          (if (icmp-eq np 0)
              (ok-ep (mk-expr (ECall variant (box-items-type a) new_args) lo hi) (TStruct sumname))
            (let [out_targs (subst-targs a tparams subst)]
              (ok-ep (mk-expr (ECall variant out_targs new_args) lo hi) (TApp sumname out_targs))))))))))

(defn validate-targs [(a (ptr Allocator)) (cx (ptr Cx)) (type_args (ptr (ArrayList Type))) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result i64 Diag))
  (let [n (al-len [Type] (load type_args)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (validate-type (al-elem [Type] type_args (load i)) cx tps)
            (Err [d] (do (store! err (prefix-diag a d (sconcat3 a "in '" fname "': type argument: "))) (store! failed true) (break))) (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [i64 Diag] (load err)) (Ok [i64 Diag] 0))))
(defn build-subst! [(subst (ptr (ArrayList SubstEntry))) (tparams (ptr (ArrayList (slice u8)))) (targs (ptr (ArrayList Type)))] (-> i64)
  (let [n (al-len [(slice u8)] (load tparams)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (subst-insert! subst (al-get [(slice u8)] (load tparams) (load i)) (al-elem [Type] targs (load i)))
          (store! i (iadd (load i) 1)))))
    0))
(defn alloc-stack-store-targs [(a (ptr Allocator)) (expected (ptr Type)) (sumname (slice u8)) (np i64)] (-> (ptr TargsOpt))
  (let [p (unwrap-ptr [TargsOpt] (create [TargsOpt] a))] (store! p (expected-sum-targs a expected sumname np)) p))
(defn subst-targs [(a (ptr Allocator)) (tparams (ptr (ArrayList (slice u8)))) (subst (ptr (ArrayList SubstEntry)))] (-> (ptr (ArrayList Type)))
  (let [n (al-len [(slice u8)] (load tparams)) (mut out) (al-new [Type] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut out) (load (subst-get subst (al-get [(slice u8)] (load tparams) (load i)))))
          (store! i (iadd (load i) 1)))))
    (box-al [Type] a (load out))))
(defn construct-check-args [(a (ptr Allocator)) (field_types (ptr (ArrayList Type))) (args (ptr (ArrayList Expr))) (subst (ptr (ArrayList SubstEntry))) (variant (slice u8)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result (ptr (ArrayList Expr)) Diag))
  (let [n (al-len [Expr] (load args)) (mut out) (al-new [Expr] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [want (subst-apply a (al-elem [Type] field_types (load i)) subst) wp (box-type a want)
                what (sconcat a (sconcat a (sconcat3 a "'" variant "' field ") (i64->str a (iadd (load i) 1))) "")]
            (match (check-to a (al-elem [Expr] args (load i)) wp env cx tps fname what)
              (Err [d] (do (store! err d) (store! failed true) (break)))
              (Ok [ce] (al-push! (mut out) ce))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList Expr)) Diag] (load err)) (Ok (box-al [Expr] a (load out))))))
(defn construct-infer-args [(a (ptr Allocator)) (field_types (ptr (ArrayList Type))) (args (ptr (ArrayList Expr))) (subst (ptr (ArrayList SubstEntry))) (tparams (ptr (ArrayList (slice u8)))) (variant (slice u8)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result (ptr (ArrayList Expr)) Diag))
  (let [n (al-len [Expr] (load args)) (mut argl) (al-new [ArgSlot] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (do-synth a (al-elem [Expr] args (load i)) (null-type) env cx tps fname)
            (Err [d] (do (store! err d) (store! failed true) (break)))
            (Ok [sp0] (let [sp (alloc-stack SynPair) sl (alloc-stack ArgSlot)] (store! sp sp0)
                        (store! (field sl present) true) (store! (field sl e) (load (field sp e))) (store! (field sl t) (load (field sp t)))
                        (al-push! (mut argl) (load sl)))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList Expr)) Diag] (load err))
      (let [argl2 (box-al [ArgSlot] a (load argl)) (mut j) 0 (mut err2) (zeroed Diag) (mut failed2) false]
        (loop (if (icmp-ge (load j) n) (break)
          (do (match (unify a (al-elem [Type] field_types (load j)) (load (field (al-elem [ArgSlot] argl2 (load j)) t)) tparams subst fname)
                (Err [d] (do (store! err2 d) (store! failed2 true) (break))) (Ok [_] 0))
              (store! j (iadd (load j) 1)))))
        (if (load failed2) (Err [(ptr (ArrayList Expr)) Diag] (load err2))
          (let [npm (al-len [(slice u8)] (load tparams)) (mut k) 0 (mut missing) false (mut mp) ""]
            (loop (if (icmp-ge (load k) npm) (break)
              (do (if (not (subst-has subst (al-get [(slice u8)] (load tparams) (load k)))) (do (store! missing true) (store! mp (al-get [(slice u8)] (load tparams) (load k))) (break)) 0)
                  (store! k (iadd (load k) 1)))))
            (if (load missing)
                (Err [(ptr (ArrayList Expr)) Diag] (derr (sconcat a (sconcat a (sconcat4 a "in '" fname "': cannot infer type argument '" (sconcat a (load mp) "' for '")) (sconcat a variant "'; provide it explicitly: (")) (sconcat a variant " [<types>] ...)"))))
              (let [(mut m) 0 (mut out2) (al-new [Expr] a) (mut err3) (zeroed Diag) (mut failed3) false]
                (loop (if (icmp-ge (load m) n) (break)
                  (do (let [sl (al-elem [ArgSlot] argl2 (load m)) want (subst-apply a (al-elem [Type] field_types (load m)) subst) wp (box-type a want)
                            what (sconcat a (sconcat3 a "'" variant "' field ") (i64->str a (iadd (load m) 1)))]
                        (match (coerce a (load (load (field sl e))) (load (field sl t)) wp false fname what)
                          (Err [d] (do (store! err3 d) (store! failed3 true) (break)))
                          (Ok [ce] (al-push! (mut out2) ce))))
                      (store! m (iadd (load m) 1)))))
                (if (load failed3) (Err [(ptr (ArrayList Expr)) Diag] (load err3)) (Ok (box-al [Expr] a (load out2))))))))))))

; ---- ECall (src/check.rs:1324) ----
(defn methods-has [(cx (ptr Cx)) (func (slice u8))] (-> bool)
  (let [n (al-len [MethodEntry] (load (field cx methods))) (mut i) 0 (mut r) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [MethodEntry] (field cx methods) (load i)) name)) func) (do (store! r true) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn trait-method-find [(td (ptr TraitDef)) (func (slice u8))] (-> (ptr TraitMethod))
  (let [ms (load (field td methods)) n (al-len [TraitMethod] (load ms)) (mut i) 0 (mut r) (cast (ptr TraitMethod) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [TraitMethod] ms (load i)) name)) func) (do (store! r (al-elem [TraitMethod] ms (load i))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn is-mut-borrow [(e (ptr Expr))] (-> bool) (match-else (load (field e kind)) (EBorrow [mu place] mu) (_ false)))
(defn peel-ref-ptr [(t (ptr Type))] (-> (ptr Type))
  (let [(mut r) t]
    (loop (let [tg (type-tag (load r))] (if (or (icmp-eq tg 4) (icmp-eq tg 5)) (do (store! r (t-inner (load r))) 0) (break))))
    (load r)))

; trait type-parameter Self deferred args (check.rs:1424)
(defn trait-tp-args [(a (ptr Allocator)) (tm (ptr TraitMethod)) (self_pname (slice u8)) (self_as_ty (ptr Type)) (args (ptr (ArrayList Expr))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (func (slice u8))] (-> (Result (ptr (ArrayList Expr)) Diag))
  (let [ps (load (field tm params)) n (al-len [Expr] (load args)) (mut out) (al-new [Expr] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [want (subst-self a (field (al-elem [Param] ps (load i)) ty) self_pname self_as_ty) wp (box-type a want)
                ismut (is-mut-borrow (al-elem [Expr] args (load i)))
                exp (if (icmp-eq (type-tag wp) 5) (t-inner wp) wp)
                what (sconcat a (sconcat a (sconcat3 a "argument " (i64->str a (iadd (load i) 1)) " to '") func) "'")]
            (match (do-synth a (al-elem [Expr] args (load i)) exp env cx tps fname)
              (Err [d] (do (store! err d) (store! failed true) (break)))
              (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
                          (match (coerce-arg a ismut (load (load (field sp e))) (load (field sp t)) wp false fname what)
                            (Err [d] (do (store! err d) (store! failed true) (break)))
                            (Ok [ce] (al-push! (mut out) ce)))))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList Expr)) Diag] (load err)) (Ok (box-al [Expr] a (load out))))))

; non-generic call args (check.rs:1476)
(defn ca-nongeneric [(a (ptr Allocator)) (sig (ptr Sig)) (args (ptr (ArrayList Expr))) (func (slice u8)) (elo i64) (ehi i64) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result (ptr (ArrayList Expr)) Diag))
  (let [params (load (field sig params)) nparams (al-len [Type] (load params)) is_extern (load (field sig is_extern))
        n (al-len [Expr] (load args)) (mut out) (al-new [Expr] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-ge (load i) nparams)
              (match (do-synth a (al-elem [Expr] args (load i)) (null-type) env cx tps fname)
                (Err [d] (do (store! err d) (store! failed true) (break)))
                (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
                            (if (type-is-void (load (field sp t)))
                                (do (store! err (derr (sconcat3 a "in '" fname "': variadic argument uses a void value (a (-> void) call yields nothing)"))) (store! failed true) (break))
                                (al-push! (mut out) (load (load (field sp e))))))))
              (let [want (al-elem [Type] params (load i)) ismut (is-mut-borrow (al-elem [Expr] args (load i)))
                    exp (if (icmp-eq (type-tag want) 5) (t-inner want) want)
                    what (sconcat a (sconcat a (sconcat3 a "argument " (i64->str a (iadd (load i) 1)) " to '") func) "'")]
                (match (do-synth a (al-elem [Expr] args (load i)) exp env cx tps fname)
                  (Err [d] (do (store! err d) (store! failed true) (break)))
                  (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
                              (match (maybe-coerce-dyn a cx (load (field sp e)) (load (field sp t)) want elo ehi fname)
                                (Err [d] (do (store! err d) (store! failed true) (break)))
                                (Ok [mp0] (let [mp (alloc-stack SynPair)] (store! mp mp0)
                                            (match (coerce-arg a ismut (load (load (field mp e))) (load (field mp t)) want is_extern fname what)
                                              (Err [d] (do (store! err d) (store! failed true) (break)))
                                              (Ok [ce] (al-push! (mut out) ce)))))))))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList Expr)) Diag] (load err)) (Ok (box-al [Expr] a (load out))))))

; generic call (check.rs:1536). Returns the elaborated ECall as EvalPair.
(defn ca-build-arglist [(a (ptr Allocator)) (args (ptr (ArrayList Expr))) (defs (ptr (ArrayList Deferred))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (ptr (ArrayList ArgSlot)))
  (let [n (al-len [Expr] (load args)) (mut out) (al-new [ArgSlot] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [saved (al-len [EnvEntry] (load env))]
            (match (do-synth a (al-elem [Expr] args (load i)) (null-type) env cx tps fname)
              (Ok [sp0] (let [sp (alloc-stack SynPair) sl (alloc-stack ArgSlot)] (store! sp sp0)
                          (store! (field sl present) true) (store! (field sl e) (load (field sp e))) (store! (field sl t) (load (field sp t)))
                          (al-push! (mut out) (load sl))))
              (Err [d] (do (env-truncate! env saved)
                           (let [sl (alloc-stack ArgSlot) df (alloc-stack Deferred)]
                             (store! (field sl present) false) (store! (field sl e) (cast (ptr Expr) 0)) (store! (field sl t) (cast (ptr Type) 0))
                             (al-push! (mut out) (load sl))
                             (store! (field df idx) (load i)) (store! (field df err) d) (al-push! [Deferred] defs (load df)))))))
          (store! i (iadd (load i) 1)))))
    (box-al [ArgSlot] a (load out))))
(defn ca-check-bounds [(a (ptr Allocator)) (sig (ptr Sig)) (subst (ptr (ArrayList SubstEntry))) (func (slice u8)) (cx (ptr Cx)) (fname (slice u8))] (-> (Result i64 Diag))
  (let [bounds (load (field sig bounds)) n (al-len [Bound] (load bounds)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [bp (al-elem [Bound] bounds (load i)) param (load (field bp name)) tyr (subst-get subst (load (field bp name)))]
            (if (icmp-ne (cast i64 tyr) 0)
                (let [trs (load (field bp traits)) m (al-len [(slice u8)] (load trs)) (mut k) 0]
                  (loop (if (icmp-ge (load k) m) (break)
                    (do (let [tr (al-get [(slice u8)] (load trs) (load k))
                              ok (and (has-impl-name tyr) (impl-has cx tr (type-impl-name a tyr)))]
                          (if (not ok)
                              (do (store! err (derr (sconcat a (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': '" (sconcat a (ty-str a tyr) "' does not implement '")) (display-name tr)) "' (required by '") func) (sconcat a "' bound on '" (sconcat a param "')"))))) (store! failed true) (break)) 0))
                        (store! k (iadd (load k) 1)))))
                  0)
                0))
          (if (load failed) (break) (store! i (iadd (load i) 1))))))
    (if (load failed) (Err [i64 Diag] (load err)) (Ok [i64 Diag] 0))))
(defn ca-resynth-deferred [(a (ptr Allocator)) (defs (ptr (ArrayList Deferred))) (argl (ptr (ArrayList ArgSlot))) (sig (ptr Sig)) (subst (ptr (ArrayList SubstEntry))) (args (ptr (ArrayList Expr))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result i64 Diag))
  (let [params (load (field sig params)) n (al-len [Deferred] (load defs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [df (al-elem [Deferred] defs (load i)) idx (load (field df idx))
                want (subst-apply a (al-elem [Type] params idx) subst) wp (box-type a want)]
            (match (do-synth a (al-elem [Expr] args idx) wp env cx tps fname)
              (Err [_] (do (store! err (load (field df err))) (store! failed true) (break)))
              (Ok [sp0] (let [sp (alloc-stack SynPair) sl (al-elem [ArgSlot] argl idx)] (store! sp sp0)
                          (store! (field sl present) true) (store! (field sl e) (load (field sp e))) (store! (field sl t) (load (field sp t)))))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [i64 Diag] (load err)) (Ok [i64 Diag] 0))))
(defn ca-final-coerce [(a (ptr Allocator)) (argl (ptr (ArrayList ArgSlot))) (sig (ptr Sig)) (subst (ptr (ArrayList SubstEntry))) (args (ptr (ArrayList Expr))) (func (slice u8)) (fname (slice u8))] (-> (Result (ptr (ArrayList Expr)) Diag))
  (let [params (load (field sig params)) is_extern (load (field sig is_extern)) n (al-len [Expr] (load args)) (mut out) (al-new [Expr] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [sl (al-elem [ArgSlot] argl (load i)) want (subst-apply a (al-elem [Type] params (load i)) subst) wp (box-type a want)
                ismut (is-mut-borrow (al-elem [Expr] args (load i)))
                what (sconcat a (sconcat a (sconcat3 a "argument " (i64->str a (iadd (load i) 1)) " to '") func) "'")]
            (match (coerce-arg a ismut (load (load (field sl e))) (load (field sl t)) wp is_extern fname what)
              (Err [d] (do (store! err d) (store! failed true) (break)))
              (Ok [ce] (al-push! (mut out) ce))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList Expr)) Diag] (load err)) (Ok (box-al [Expr] a (load out))))))

(defn method-index-of [(td (ptr TraitDef)) (func (slice u8))] (-> i64)
  (let [ms (load (field td methods)) n (al-len [TraitMethod] (load ms)) (mut i) 0 (mut r) -1]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [TraitMethod] ms (load i)) name)) func) (do (store! r (load i)) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn dyn-dispatch-args [(a (ptr Allocator)) (tm (ptr TraitMethod)) (self_idx i64) (func (slice u8)) (args (ptr (ArrayList Expr))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64) (params (ptr (ArrayList Type))) (newargs (ptr (ArrayList Expr)))] (-> (Result i64 Diag))
  (let [ps (load (field tm params)) n (al-len [Expr] (load args)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-eq (load i) self_idx) 0
            (let [want (field (al-elem [Param] ps (load i)) ty) exp (if (icmp-eq (type-tag (field (al-elem [Param] ps (load i)) ty)) 5) (t-inner (field (al-elem [Param] ps (load i)) ty)) (field (al-elem [Param] ps (load i)) ty))
                  ismut (is-mut-borrow (al-elem [Expr] args (load i))) what (sconcat1 a (sconcat3 a "argument to '" func "'"))]
              (match (do-synth a (al-elem [Expr] args (load i)) exp env cx tps fname)
                (Err [d] (do (store! err d) (store! failed true) (break)))
                (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
                  (match (maybe-coerce-dyn a cx (load (field sp e)) (load (field sp t)) want elo ehi fname)
                    (Err [d] (do (store! err d) (store! failed true) (break)))
                    (Ok [mp0] (let [mp (alloc-stack SynPair)] (store! mp mp0)
                      (match (coerce-arg a ismut (load (load (field mp e))) (load (field mp t)) want false fname what)
                        (Err [d] (do (store! err d) (store! failed true) (break)))
                        (Ok [ce] (do (al-push! [Expr] newargs ce) (al-push! [Type] params (load want)) 0)))))))))) )
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [i64 Diag] (load err)) (Ok [i64 Diag] 0))))
(defn synth-dyn-dispatch [(a (ptr Allocator)) (cx (ptr Cx)) (func (slice u8)) (self_name (slice u8)) (self_idx i64) (td (ptr TraitDef)) (tm (ptr TraitMethod)) (args (ptr (ArrayList Expr))) (env (ptr (ArrayList EnvEntry))) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (let [mi (method-index-of td func) dyn_ty (box-type a (TStruct self_name))]
    (match (do-synth a (al-elem [Expr] args self_idx) dyn_ty env cx tps fname)
      (Err [d] (err-ep d))
      (Ok [rsp0] (let [rsp (alloc-stack SynPair)] (store! rsp rsp0)
        (match (coerce a (load (load (field rsp e))) (load (field rsp t)) dyn_ty false fname "trait-object receiver")
          (Err [d] (err-ep d))
          (Ok [recv]
            (let [params (box-al [Type] a (al-new [Type] a)) newargs (box-al [Expr] a (al-new [Expr] a))]
              (al-push! [Type] params (TPtr (box-type a (TInt 8 false))))
              (match (dyn-dispatch-args a tm self_idx func args env cx tps fname elo ehi params newargs)
                (Err [d] (err-ep d))
                (Ok [_]
                  (let [vtable_struct (sconcat a (subslice [u8] self_name 0 (isub (slice-len [u8] self_name) 4)) "-vtable")]
                    (ok-ep (mk-expr (EDynDispatch self_name vtable_struct mi "c" params (load (field tm ret)) (box-expr a recv) newargs) elo ehi) (load (field tm ret)))))))))))))) 

(defn synth-call-general [(a (ptr Allocator)) (func (slice u8)) (call_func (slice u8)) (type_args (ptr (ArrayList Type))) (args (ptr (ArrayList Expr))) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try
   (do
    (let [sig (sig-find cx call_func)]
      (if (icmp-eq (cast i64 sig) 0)
          (return-from :try (err-ep (derr (sconcat3 a (sconcat3 a "in '" fname "': call to undefined function '") func "'")))) 0)
      (let [nparams (al-len [Type] (load (field sig params))) nargs (al-len [Expr] (load args)) variadic (load (field sig variadic))
            arity_ok (if variadic (icmp-ge nargs nparams) (icmp-eq nargs nparams))]
        (if (not arity_ok)
            (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': '" (sconcat a func "' expects ")) (if variadic "at least " "")) (i64->str a nparams)) (sconcat a " args, got " (i64->str a nargs)))))) 0)
        (if (icmp-eq (al-len [(slice u8)] (load (field sig type_params))) 0)
            (do (if (icmp-gt (al-len [Type] (load type_args)) 0)
                    (return-from :try (err-ep (derr (sconcat1 a (sconcat5 a "in '" fname "': '" func "' is not generic but got type arguments"))))) 0)
                (let [new_args (try! (ca-nongeneric a sig args func elo ehi env cx tps fname))]
                  (return-from :try (ok-ep (mk-expr (ECall call_func (box-items-type a) new_args) elo ehi) (load (field sig ret))))))
          (let [defs (box-al [Deferred] a (al-new [Deferred] a))
                argl (ca-build-arglist a args defs env cx tps fname)
                subst (try! (solve-type-args a (load (field sig type_params)) (load (field sig params)) type_args argl (field sig ret) expected cx tps fname func))]
            (try! (ca-check-bounds a sig subst func cx fname))
            (try! (ca-resynth-deferred a defs argl sig subst args env cx tps fname))
            (let [new_args (try! (ca-final-coerce a argl sig subst args func fname))
                  out_targs (subst-targs a (load (field sig type_params)) subst)
                  ret (subst-apply a (field sig ret) subst)]
              (ok-ep (mk-expr (ECall func out_targs new_args) elo ehi) ret)))))))))

(defn synth-call [(a (ptr Allocator)) (func (slice u8)) (type_args (ptr (ArrayList Type))) (args (ptr (ArrayList Expr))) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try
   (do
    (if (icmp-ne (cast i64 (vts-find cx func)) 0)
        (return-from :try (synth-construct a func type_args args expected env cx tps fname elo ehi)) 0)
    (let [(mut call_func) func]
      (if (methods-has cx func)
          (let [me0 (try! (resolve-method a cx func fname)) me (alloc-stack MethodEntry)] (store! me me0)
            (let [trait_name (load (field me trait)) self_idx (load (field me self_idx))
                  td (trait-find cx (load (field me trait))) tm (trait-method-find (trait-find cx (load (field me trait))) func)
                  self_pname (load (field td self_param))]
              (if (not (icmp-eq (al-len [Expr] (load args)) (al-len [Param] (load (field tm params)))))
                  (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': '" (sconcat a func "' expects ")) (i64->str a (al-len [Param] (load (field tm params))))) " args, got ") (i64->str a (al-len [Expr] (load args))))))) 0)
              (let [selfsp (try! (do-synth a (al-elem [Expr] args self_idx) (null-type) env cx tps fname)) ssp (alloc-stack SynPair)] (store! ssp selfsp)
                (let [self_ty (peel-ref-ptr (load (field ssp t)))]
                  (if (not (has-impl-name self_ty))
                      (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat4 a "in '" fname "': trait method '" (sconcat a func "' called on a type that can't carry an impl: ")) (ty-str a self_ty)) "")))) 0)
                  (let [self_name (type-impl-name a self_ty)]
                    (if (icmp-gt (slice-len [u8] (dyn-struct-trait cx self_name)) 0)
                        (return-from :try (synth-dyn-dispatch a cx func self_name self_idx td tm args env tps fname elo ehi)) 0)
                    (if (set-contains tps self_name)
                        (if (not (bounds-has (field cx cur_bounds) self_name trait_name))
                            (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': type parameter '" (sconcat a self_name "' is not bounded by '")) (display-name trait_name)) "' (required to call '") (sconcat a func "')")))))
                          (let [self_as_ty (box-type a (TStruct self_name))
                                new_args (try! (trait-tp-args a tm self_pname self_as_ty args env cx tps fname func))
                                ret (subst-self a (field tm ret) self_pname self_as_ty)]
                            (return-from :try (ok-ep (mk-expr (ETraitCall trait_name func self_name new_args) elo ehi) ret))))
                      (do (if (not (impl-has cx trait_name self_name))
                              (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat5 a "in '" fname "': '" (display-name self_name) "' does not implement '") (display-name trait_name)) "'")))) 0)
                          (store! call_func (tmfn a trait_name self_name func)) 0)))))))
          0)
      (synth-call-general a func (load call_func) type_args args expected env cx tps fname elo ehi)))))
; ELet (src/check.rs:1231)
(defn mk-bind [(name (slice u8)) (mutable bool) (value Expr)] (-> Bind)
  (let [p (alloc-stack Bind)] (store! (field p name) name) (store! (field p mutable) mutable) (store! (field p value) value) (load p)))
(defn synth-let-body [(a (ptr Allocator)) (body (ptr (ArrayList Expr))) (expected (ptr Type)) (out (ptr (ArrayList Expr))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (what (slice u8))] (-> (Result Type Diag))
  (let [n (al-len [Expr] (load body)) (mut i) 0 (mut last) (TInt 64 true) (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-eq (iadd (load i) 1) n)
              (if (expected-some? expected)
                  (match (check-to a (al-elem [Expr] body (load i)) expected env cx tps fname what)
                    (Err [d] (do (store! err d) (store! failed true) (break)))
                    (Ok [ce] (do (al-push! [Expr] out ce) (store! last (load expected)) 0)))
                  (match (do-synth a (al-elem [Expr] body (load i)) (null-type) env cx tps fname)
                    (Err [d] (do (store! err d) (store! failed true) (break)))
                    (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0) (store! last (load (load (field sp t)))) (al-push! [Expr] out (load (load (field sp e))))))))
              (match (do-synth a (al-elem [Expr] body (load i)) (null-type) env cx tps fname)
                (Err [d] (do (store! err d) (store! failed true) (break)))
                (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0) (al-push! [Expr] out (load (load (field sp e))))))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [Type Diag] (load err)) (Ok (load last)))))

(defn process-let-bind [(a (ptr Allocator)) (bp (ptr Bind)) (nbinds (ptr (ArrayList Bind))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result i64 Diag))
  (let [name (load (field bp name)) mutable (load (field bp mutable))]
    (match (do-synth a (field bp value) (null-type) env cx tps fname)
      (Err [d] (Err [i64 Diag] d))
      (Ok [vsp] (let [sp (alloc-stack SynPair)] (store! sp vsp)
        (let [ve (load (load (field sp e))) vt (load (field sp t))]
          (if (type-is-void vt)
              (Err [i64 Diag] (derr (sconcat1 a (sconcat4 a "in '" fname "': cannot bind '" (sconcat a name "' to a void value (a (-> void) call yields nothing)")))))
            (if (icmp-eq (type-tag vt) 5)
                (let [src_mut (t-ref-mut vt) pointee (t-inner vt)]
                  (if (and mutable (not src_mut))
                      (Err [i64 Diag] (derr (sconcat1 a (sconcat4 a "in '" fname "': cannot make a mutable alias '" (sconcat a name "' of an immutable reference")))))
                    (do (env-insert! env name (box-type a (TRef mutable pointee)))
                        (al-push! [Bind] nbinds (mk-bind name false ve)) (Ok [i64 Diag] 0))))
              (if (or mutable (is-place-value-type vt cx))
                  (let [slot (sconcat a name ".slot") (mut initdo) (al-new [Expr] a)]
                    (env-insert! env name (box-type a (TRef mutable (box-type a (load vt)))))
                    (al-push! (mut initdo) (mk-expr (EStore (box-expr a (mk-expr (EVar slot) elo ehi)) (box-expr a ve)) elo ehi))
                    (al-push! (mut initdo) (mk-expr (EVar slot) elo ehi))
                    (al-push! [Bind] nbinds (mk-bind slot false (mk-expr (EAlloc 0 (erase-refs a vt)) elo ehi)))
                    (al-push! [Bind] nbinds (mk-bind name false (mk-expr (EDo (box-al [Expr] a (load initdo))) elo ehi)))
                    (Ok [i64 Diag] 0))
                (do (env-insert! env name (box-type a (load vt)))
                    (al-push! [Bind] nbinds (mk-bind name false ve)) (Ok [i64 Diag] 0))))))))) ))

(defn process-let-binds [(a (ptr Allocator)) (binds (ptr (ArrayList Bind))) (nbinds (ptr (ArrayList Bind))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result i64 Diag))
  (let [nb (al-len [Bind] (load binds)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) nb) (break)
      (do (match (process-let-bind a (al-elem [Bind] binds (load i)) nbinds env cx tps fname elo ehi)
            (Err [d] (do (store! err d) (store! failed true) (break)))
            (Ok [_] 0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [i64 Diag] (load err)) (Ok [i64 Diag] 0))))

(defn synth-let [(a (ptr Allocator)) (binds (ptr (ArrayList Bind))) (body (ptr (ArrayList Expr))) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (let [saved (al-len [EnvEntry] (load env)) nbinds (box-al [Bind] a (al-new [Bind] a))]
    (match (process-let-binds a binds nbinds env cx tps fname elo ehi)
      (Err [d] (err-ep d))
      (Ok [_]
        (let [outl (box-al [Expr] a (al-new [Expr] a))]
          (match (synth-let-body a body expected outl env cx tps fname "let body")
            (Err [d] (err-ep d))
            (Ok [last] (do (env-truncate! env saved) (ok-ep (mk-expr (ELet nbinds outl) elo ehi) last)))))))))

; EMatch (src/check.rs:1848)
(defn variant-by-name [(variants (ptr (ArrayList Variant))) (name (slice u8))] (-> (ptr Variant))
  (let [n (al-len [Variant] (load variants)) (mut i) 0 (mut r) (cast (ptr Variant) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [Variant] variants (load i)) name)) name) (do (store! r (al-elem [Variant] variants (load i))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn covered-has [(cov (ptr (ArrayList (slice u8)))) (name (slice u8))] (-> bool) (set-contains cov name))

(defn match-arms-loop [(a (ptr Allocator)) (arms (ptr (ArrayList Arm))) (variants (ptr (ArrayList Variant))) (sumname (slice u8)) (expected (ptr Type)) (covered (ptr (ArrayList (slice u8)))) (checked (ptr (ArrayList Arm))) (synb (ptr (ArrayList Branch))) (metav (ptr (ArrayList (slice u8)))) (metab (ptr (ArrayList (ptr (ArrayList (slice u8)))))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result i64 Diag))
  (let [narms (al-len [Arm] (load arms)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) narms) (break)
      (do (let [arm (al-elem [Arm] arms (load i)) av (load (field arm variant)) abinds (load (field arm binds))
                v (variant-by-name variants av)]
            (if (icmp-eq (cast i64 v) 0)
                (do (store! err (derr (sconcat a (sconcat a (sconcat4 a "in '" fname "': sum '" (sconcat a sumname "' has no variant '")) av) "'"))) (store! failed true) (break))
              (if (set-contains covered av)
                  (do (store! err (derr (sconcat a (sconcat a (sconcat4 a "in '" fname "': duplicate match arm for '" av) "'") ""))) (store! failed true) (break))
                (if (not (icmp-eq (al-len [(slice u8)] (load abinds)) (al-len [Field] (load (field v fields)))))
                    (do (store! err (derr (sconcat a (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': arm '" (sconcat a av "' binds ")) (i64->str a (al-len [(slice u8)] (load abinds)))) " name(s) but the variant has ") (i64->str a (al-len [Field] (load (field v fields))))) " field(s)"))) (store! failed true) (break))
                  (do (al-push! [(slice u8)] covered av)
                      (let [saved (al-len [EnvEntry] (load env)) fs (load (field v fields)) nbn (al-len [(slice u8)] (load abinds)) (mut k) 0]
                        (loop (if (icmp-ge (load k) nbn) (break)
                          (do (env-insert! env (al-get [(slice u8)] (load abinds) (load k)) (field (al-elem [Field] fs (load k)) ty))
                              (store! k (iadd (load k) 1)))))
                        (if (expected-some? expected)
                            (match (check-to a (field arm body) expected env cx tps fname "match arm")
                              (Err [d] (do (env-truncate! env saved) (store! err d) (store! failed true) (break)))
                              (Ok [be] (do (let [na (alloc-stack Arm)] (store! (field na variant) av) (store! (field na binds) abinds) (store! (field na body) be) (al-push! [Arm] checked (load na))) (env-truncate! env saved) 0)))
                          (match (do-synth a (field arm body) (null-type) env cx tps fname)
                            (Err [d] (do (env-truncate! env saved) (store! err d) (store! failed true) (break)))
                            (Ok [sp0] (let [sp (alloc-stack SynPair) br (alloc-stack Branch)] (store! sp sp0)
                                        (store! (field br e) (load (field sp e))) (store! (field br t) (load (field sp t))) (al-push! [Branch] synb (load br))
                                        (al-push! [(slice u8)] metav av) (al-push! [(ptr (ArrayList (slice u8)))] metab abinds)
                                        (env-truncate! env saved) 0)))))))))
          (store! i (iadd (load i) 1))))))
    (if (load failed) (Err [i64 Diag] (load err)) (Ok [i64 Diag] 0))))

(defn build-newarms [(a (ptr Allocator)) (metav (ptr (ArrayList (slice u8)))) (metab (ptr (ArrayList (ptr (ArrayList (slice u8)))))) (outl (ptr (ArrayList Expr)))] (-> (ptr (ArrayList Arm)))
  (let [nm (al-len [(slice u8)] (load metav)) (mut newarms) (al-new [Arm] a) (mut j) 0]
    (loop (if (icmp-ge (load j) nm) (break)
      (do (let [na (alloc-stack Arm)]
            (store! (field na variant) (al-get [(slice u8)] (load metav) (load j)))
            (store! (field na binds) (al-get [(ptr (ArrayList (slice u8)))] (load metab) (load j)))
            (store! (field na body) (al-get [Expr] (load outl) (load j)))
            (al-push! (mut newarms) (load na)))
          (store! j (iadd (load j) 1)))))
    (box-al [Arm] a (load newarms))))

(defn synth-match [(a (ptr Allocator)) (scrut (ptr Expr)) (arms (ptr (ArrayList Arm))) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try
   (do
    (let [ssp0 (try! (do-synth a scrut (null-type) env cx tps fname)) ssp (alloc-stack SynPair)] (store! ssp ssp0)
      (let [(mut se) (load (field ssp e)) st0 (load (field ssp t)) (mut st) st0]
        (if (icmp-eq (type-tag st0) 5)
            (let [inner (t-inner st0)]
              (if (load (field (alloc-stack-store-sumvars a inner cx) found))
                  (do (store! se (box-expr a (mk-expr (ELoad (load se)) elo ehi))) (store! st inner) 0) 0)) 0)
        (let [svp (alloc-stack-store-sumvars a (load st) cx)]
          (if (not (load (field svp found)))
              (return-from :try (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': match expects a sum value, got ") (ty-str a (load st)))))) 0)
          (let [sumname (load (field svp name)) variants (load (field svp variants))]
            (if (icmp-eq (al-len [Arm] (load arms)) 0) (return-from :try (err-ep (derr (sconcat3 a "in '" fname "': empty match")))) 0)
            (let [covered (box-al [(slice u8)] a (al-new [(slice u8)] a)) checked (box-al [Arm] a (al-new [Arm] a))
                  synb (box-al [Branch] a (al-new [Branch] a)) metav (box-al [(slice u8)] a (al-new [(slice u8)] a))
                  metab (box-al [(ptr (ArrayList (slice u8)))] a (al-new [(ptr (ArrayList (slice u8)))] a))]
              (try! (match-arms-loop a arms variants sumname expected covered checked synb metav metab env cx tps fname))
              (if (not (icmp-eq (al-len [(slice u8)] (load covered)) (al-len [Variant] (load variants))))
                  (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': non-exhaustive match on '" (sconcat a sumname "' (")) (i64->str a (al-len [(slice u8)] (load covered)))) " of ") (i64->str a (al-len [Variant] (load variants)))) " variants)")))) 0)
              (if (expected-some? expected)
                  (ok-ep (mk-expr (EMatch (load se) checked) elo ehi) (load expected))
                (let [outl (box-al [Expr] a (al-new [Expr] a))
                      t (try! (unify-branches a synb outl fname "match arms"))]
                  (ok-ep (mk-expr (EMatch (load se) (build-newarms a metav metab outl)) elo ehi) t))))))))))) 
(defn alloc-stack-store-sumvars [(a (ptr Allocator)) (t (ptr Type)) (cx (ptr Cx))] (-> (ptr SumVars))
  (let [p (unwrap-ptr [SumVars] (create [SumVars] a))] (store! p (sum-variants a t cx)) p))
; ---- loop / break / continue (cx.loops frames) ----
(defn loops-len [(cx (ptr Cx))] (-> i64) (al-len [LoopFrame] (load (field cx loops))))
(defn loop-label-exists [(cx (ptr Cx)) (l (slice u8))] (-> bool)
  (let [n (loops-len cx) (mut i) 0 (mut r) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match-else (load (field (al-elem [LoopFrame] (field cx loops) (load i)) label)) (Some [fl] (if (str-eq fl l) (do (store! r true) (break)) 0)) (_ 0))
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn loops-rpos-label [(cx (ptr Cx)) (l (slice u8))] (-> i64)
  (let [n (loops-len cx) (mut i) (isub n 1) (mut at) -1]
    (loop (if (icmp-lt (load i) 0) (break)
      (do (match-else (load (field (al-elem [LoopFrame] (field cx loops) (load i)) label)) (Some [fl] (if (str-eq fl l) (do (store! at (load i)) (break)) 0)) (_ 0))
          (store! i (isub (load i) 1)))))
    (load at)))

(defn label-some? [(label (Option (slice u8)))] (-> bool) (match-else label (Some [l] true) (_ false)))
(defn label-val [(label (Option (slice u8)))] (-> (slice u8)) (match-else label (Some [l] l) (_ "")))
(defn run-loop-body [(a (ptr Allocator)) (label (Option (slice u8))) (body (ptr (ArrayList Expr))) (expected (ptr Type)) (out (ptr (ArrayList Expr))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result Type Diag))
  (let [fr (alloc-stack LoopFrame)]
    (store! (field fr label) label) (store! (field fr break_ty) (None [Type]))
    (store! (field fr expected) (if (expected-some? expected) (Some (load expected)) (None [Type])))
    (al-push! [LoopFrame] (field cx loops) (load fr)))
  (let [n (al-len [Expr] (load body)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (do-synth a (al-elem [Expr] body (load i)) (null-type) env cx tps fname)
            (Err [d] (do (store! err d) (store! failed true) (break)))
            (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0) (al-push! [Expr] out (load (load (field sp e)))))))
          (store! i (iadd (load i) 1)))))
    (let [popped (al-pop! [LoopFrame] (field cx loops))]
      (if (load failed) (Err [Type Diag] (load err))
        (let [(mut lty) (TNever)]
          (if (expected-some? expected) (store! lty (load expected))
            (match-else popped (Some [pf] (let [pfp (alloc-stack LoopFrame)] (store! pfp pf) (match-else (load (field pfp break_ty)) (Some [bt] (store! lty bt)) (_ (store! lty (TNever)))))) (_ (store! lty (TNever)))))
          (Ok (load lty)))))))

(defn synth-loop [(a (ptr Allocator)) (label (Option (slice u8))) (body (ptr (ArrayList Expr))) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (if (and (label-some? label) (loop-label-exists cx (label-val label)))
      (err-ep (derr (sconcat1 a (sconcat4 a "in '" fname "': loop label ':" (sconcat a (label-val label) "' shadows an enclosing loop with the same label")))))
    (let [outl (box-al [Expr] a (al-new [Expr] a))]
      (match (run-loop-body a label body expected outl env cx tps fname)
        (Err [d] (err-ep d))
        (Ok [lty] (ok-ep (mk-expr (ELoop label outl) elo ehi) lty))))))

(defn synth-break [(a (ptr Allocator)) (label (Option (slice u8))) (value (Option (ptr Expr))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try
   (do
    (if (icmp-eq (loops-len cx) 0) (return-from :try (err-ep (derr (sconcat3 a "in '" fname "': break outside of a loop")))) 0)
    (let [idx (match-else label (Some [l] (loops-rpos-label cx l)) (_ (isub (loops-len cx) 1)))]
      (match-else label (Some [l] (if (icmp-lt idx 0) (return-from :try (err-ep (derr (sconcat a (sconcat4 a "in '" fname "': break to unknown loop label ':" l) "'")))) 0)) (_ 0))
      (let [fr (al-elem [LoopFrame] (field cx loops) idx) texp (field fr expected)]
        (let [valpair (alloc-stack SynPair) (mut have_val) false (mut valexpr) (cast (ptr Expr) 0) (mut vty) (box-type a (TInt 64 true))]
          (match value
            (Some [vp]
              (do (store! have_val true)
                  (match-else (load texp)
                    (Some [exp]
                      (let [ve (try! (check-to a vp (box-type a exp) env cx tps fname "break value"))]
                        (store! valexpr (box-expr a ve)) (store! vty (box-type a exp)) 0))
                    (_ (let [vsp (try! (do-synth a vp (null-type) env cx tps fname))] (store! valpair vsp)
                         (store! valexpr (load (field valpair e))) (store! vty (load (field valpair t))) 0))) 0))
            (None [] 0))
          (if (not (type-is-never (load vty)))
              (match-else (load (field (al-elem [LoopFrame] (field cx loops) idx) break_ty))
                (Some [prev] (if (not (type-eq (box-type a prev) (load vty)))
                                 (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': loop breaks with different value types (" (ty-str a (box-type a prev))) " vs ") (ty-str a (load vty))) ")")))) 0))
                (_ (do (store! (field (al-elem [LoopFrame] (field cx loops) idx) break_ty) (Some (load (load vty)))) 0))) 0)
          (ok-ep (mk-expr (EBreak label (if (load have_val) (Some (load valexpr)) (None [(ptr Expr)]))) elo ehi) (TNever))))))))

(defn synth-continue [(a (ptr Allocator)) (label (Option (slice u8))) (cx (ptr Cx)) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (if (icmp-eq (loops-len cx) 0) (err-ep (derr (sconcat3 a "in '" fname "': continue outside of a loop")))
    (match-else label
      (Some [l] (if (icmp-lt (loops-rpos-label cx l) 0) (err-ep (derr (sconcat a (sconcat4 a "in '" fname "': continue to unknown loop label ':" l) "'"))) (ok-ep (mk-expr (EContinue label) elo ehi) (TNever))))
      (_ (ok-ep (mk-expr (EContinue label) elo ehi) (TNever))))))

; ---- bin/cmp ----
(defn mk-branch [(e (ptr Expr)) (t (ptr Type))] (-> Branch)
  (let [p (alloc-stack Branch)] (store! (field p e) e) (store! (field p t) t) (load p)))
(defn synth-binop [(a (ptr Allocator)) (op i64) (lhs (ptr Expr)) (rhs (ptr Expr)) (iscmp bool) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try
   (do
    (let [lsp (try! (do-synth a lhs (null-type) env cx tps fname)) lp (alloc-stack SynPair)] (store! lp lsp)
      (let [rsp (try! (do-synth a rhs (null-type) env cx tps fname)) rp (alloc-stack SynPair)] (store! rp rsp)
        (let [(mut brs) (al-new [Branch] a) outl (box-al [Expr] a (al-new [Expr] a))]
          (al-push! (mut brs) (mk-branch (load (field lp e)) (load (field lp t))))
          (al-push! (mut brs) (mk-branch (load (field rp e)) (load (field rp t))))
          (let [t (try! (unify-branches a (box-al [Branch] a (load brs)) outl fname (if iscmp "comparison" "arithmetic"))) tp (box-type a t)]
            (if (not (numeric tp tps))
                (return-from :try (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': ") (sconcat a (if iscmp "comparison requires integers, got " "arithmetic requires integers, got ") (ty-str a tp))))))
              (if iscmp
                  (ok-ep (mk-expr (ECmp op (al-elem [Expr] outl 0) (al-elem [Expr] outl 1)) elo ehi) (TBool))
                  (ok-ep (mk-expr (EBin op (al-elem [Expr] outl 0) (al-elem [Expr] outl 1)) elo ehi) t))))))))))

; ---- small arg-loop helpers ----
(defn synth-discard-args [(a (ptr Allocator)) (args (ptr (ArrayList Expr))) (forbidvoid bool) (voidmsg (slice u8)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result (ptr (ArrayList Expr)) Diag))
  (let [n (al-len [Expr] (load args)) (mut out) (al-new [Expr] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (do-synth a (al-elem [Expr] args (load i)) (null-type) env cx tps fname)
            (Err [d] (do (store! err d) (store! failed true) (break)))
            (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
                        (if (and forbidvoid (type-is-void (load (field sp t))))
                            (do (store! err (derr voidmsg)) (store! failed true) (break))
                            (al-push! (mut out) (load (load (field sp e))))))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList Expr)) Diag] (load err)) (Ok (box-al [Expr] a (load out))))))
(defn codeop-rty [(op i64)] (-> Type)
  (if (or (icmp-eq op 3) (or (icmp-eq op 6) (or (icmp-eq op 14) (or (icmp-eq op 16) (or (icmp-eq op 19) (or (icmp-eq op 21) (or (icmp-eq op 22) (icmp-eq op 24)))))))) (TInt 64 true)
  (if (or (icmp-eq op 5) (icmp-eq op 13)) (TSlice (box-type (malloc-allocator) (TInt 8 false)))
  (if (or (icmp-eq op 0) (or (icmp-eq op 1) (or (icmp-eq op 2) (or (icmp-eq op 10) (icmp-eq op 11))))) (TBool)
  (if (icmp-eq op 9) (TNever)
    (TCode))))))

(defn synth-callptr-args [(a (ptr Allocator)) (params (ptr (ArrayList Type))) (args (ptr (ArrayList Expr))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result (ptr (ArrayList Expr)) Diag))
  (let [n (al-len [Expr] (load args)) (mut out) (al-new [Expr] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [wp (al-elem [Type] params (load i)) what (sconcat a "call-ptr argument " (i64->str a (iadd (load i) 1)))]
            (match (do-synth a (al-elem [Expr] args (load i)) wp env cx tps fname)
              (Err [d] (do (store! err d) (store! failed true) (break)))
              (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
                          (match (coerce a (load (load (field sp e))) (load (field sp t)) wp false fname what)
                            (Err [d] (do (store! err d) (store! failed true) (break)))
                            (Ok [ce] (al-push! (mut out) ce)))))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList Expr)) Diag] (load err)) (Ok (box-al [Expr] a (load out))))))
; ---- per-arm helpers for the complex variants ----
(defn synth-do [(a (ptr Allocator)) (body (ptr (ArrayList Expr))) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try (do
    (let [outl (box-al [Expr] a (al-new [Expr] a))
          last (try! (synth-let-body a body expected outl env cx tps fname "do result"))]
      (ok-ep (mk-expr (EDo outl) elo ehi) last)))))

(defn synth-if [(a (ptr Allocator)) (cnd (ptr Expr)) (thn (ptr Expr)) (els (ptr Expr)) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try (do
    (let [csp0 (try! (do-synth a cnd (null-type) env cx tps fname)) csp (alloc-stack SynPair)] (store! csp csp0)
      (if (not (is-cond (load (field csp t))))
          (return-from :try (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': if condition must be a bool or integer, got ") (ty-str a (load (field csp t))))))) 0)
      (if (expected-some? expected)
          (let [te (try! (check-to a thn expected env cx tps fname "if branch"))
                ee (try! (check-to a els expected env cx tps fname "if branch"))]
            (ok-ep (mk-expr (EIf (load (field csp e)) (box-expr a te) (box-expr a ee)) elo ehi) (load expected)))
        (let [tsp0 (try! (do-synth a thn (null-type) env cx tps fname)) tsp (alloc-stack SynPair)] (store! tsp tsp0)
          (let [esp0 (try! (do-synth a els (null-type) env cx tps fname)) esp (alloc-stack SynPair)] (store! esp esp0)
            (let [(mut brs) (al-new [Branch] a) outl (box-al [Expr] a (al-new [Expr] a))]
              (al-push! (mut brs) (mk-branch (load (field tsp e)) (load (field tsp t))))
              (al-push! (mut brs) (mk-branch (load (field esp e)) (load (field esp t))))
              (let [t (try! (unify-branches a (box-al [Branch] a (load brs)) outl fname "if branches"))]
                (ok-ep (mk-expr (EIf (load (field csp e)) (al-elem [Expr] outl 0) (al-elem [Expr] outl 1)) elo ehi) t))))))))))

(defn synth-field [(a (ptr Allocator)) (pp (ptr Expr)) (ffld (slice u8)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try (do
    (let [psp (try! (do-synth a pp (null-type) env cx tps fname)) sp (alloc-stack SynPair)] (store! sp psp)
      (let [pt (load (field sp t)) pointee (place-pointee pt)]
        (if (icmp-eq (cast i64 pointee) 0)
            (return-from :try (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': field access needs a pointer or reference, got ") (ty-str a pt))))) 0)
        (if (not (is-struct-or-app pointee))
            (return-from :try (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': field access needs a pointer to a struct, got (ptr ") (sconcat a (ty-str a pointee) ")"))))) 0)
        (let [sname (struct-name pointee) si (struct-find cx sname)]
          (if (and (icmp-ne (cast i64 si) 0) (load (field si is_bits)))
              (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat a (sconcat5 a "in '" fname "': '" sname "' is a :layout bits struct; use (get p ") ffld) ") / (set! p ") ffld) " v)")))) 0)
          (match (struct-fields a pointee cx)
            (Err [d] (return-from :try (err-ep (prefix-diag a d (sconcat4 a "in '" fname "': " "")))))
            (Ok [fs]
              (let [nf (al-len [Field] (load fs)) (mut i) 0 (mut fty) (cast (ptr Type) 0)]
                (loop (if (icmp-ge (load i) nf) (break)
                  (do (if (str-eq (load (field (al-elem [Field] fs (load i)) name)) ffld) (do (store! fty (field (al-elem [Field] fs (load i)) ty)) (break)) 0)
                      (store! i (iadd (load i) 1)))))
                (if (icmp-eq (cast i64 (load fty)) 0)
                    (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat4 a "in '" fname "': struct '" (sconcat a sname "' has no field '")) ffld) "'")))) 0)
                (ok-ep (mk-expr (EField (load (field sp e)) ffld) elo ehi) (replace-pointee a pt fty)))))))))))

(defn synth-store [(a (ptr Allocator)) (pp (ptr Expr)) (val (ptr Expr)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try (do
    (let [psp (try! (do-synth a pp (null-type) env cx tps fname)) sp (alloc-stack SynPair)] (store! sp psp)
      (let [pt (load (field sp t)) pointee (place-pointee pt)]
        (if (icmp-eq (cast i64 pointee) 0) (return-from :try (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': store! expects a pointer or reference, got ") (ty-str a pt))))) 0)
        (if (not (is-writable pt)) (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat4 a "in '" fname "': cannot store! through immutable reference of type " (ty-str a pt)) " (declare it `(mut …)` to make it writable)") "")))) 0)
        (let [vsp (try! (do-synth a val pointee env cx tps fname)) vp (alloc-stack SynPair)] (store! vp vsp)
          (match (coerce a (load (load (field vp e))) (load (field vp t)) pointee false fname "store! value")
            (Err [d] (return-from :try (err-ep d)))
            (Ok [ve] (ok-ep (mk-expr (EStore (load (field sp e)) (box-expr a ve)) elo ehi) (load pointee))))))))))

(defn synth-index [(a (ptr Allocator)) (pp (ptr Expr)) (idx (ptr Expr)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try (do
    (let [psp (try! (do-synth a pp (null-type) env cx tps fname)) sp (alloc-stack SynPair)] (store! sp psp)
      (let [isp (try! (do-synth a idx (null-type) env cx tps fname)) ip (alloc-stack SynPair)] (store! ip isp)
        (let [ie (match (coerce a (load (load (field ip e))) (load (field ip t)) (box-type a (TInt 64 true)) false fname "index")
                   (Err [_] (return-from :try (err-ep (derr (sconcat3 a "in '" fname "': index must be i64"))))) (Ok [ce] ce))
              pt (load (field sp t)) pointee (place-pointee pt)]
          (if (icmp-eq (cast i64 pointee) 0) (return-from :try (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': index expects a pointer or reference, got ") (ty-str a pt))))) 0)
          (let [elem (if (icmp-eq (type-tag pointee) 7) (t-inner pointee) pointee)]
            (ok-ep (mk-expr (EIndex (load (field sp e)) (box-expr a ie)) elo ehi) (replace-pointee a pt elem)))))))))

(defn synth-cast [(a (ptr Allocator)) (ty Type) (inner (ptr Expr)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (let [tp (box-type a ty)]
    (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': cast target: "))))
      (Ok [_] (match (do-synth a inner (null-type) env cx tps fname) (Err [d] (err-ep d))
        (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
          (let [et (load (field sp t)) tt (type-tag tp) etg (type-tag et)
                ok (or (and (icmp-eq tt 0) (icmp-eq etg 0)) (or (and (icmp-eq tt 4) (icmp-eq etg 4)) (or (and (icmp-eq tt 0) (icmp-eq etg 4)) (or (and (icmp-eq tt 4) (icmp-eq etg 0)) (or (and (icmp-eq tt 1) (icmp-eq etg 1)) (or (and (icmp-eq tt 1) (icmp-eq etg 0)) (or (and (icmp-eq tt 0) (icmp-eq etg 1)) (or (and (icmp-eq tt 10) (icmp-eq etg 10)) (or (and (icmp-eq tt 10) (icmp-eq etg 4)) (and (icmp-eq tt 4) (icmp-eq etg 10)))))))))))]
            (if ok (ok-ep (mk-expr (ECast ty (load (field sp e))) elo ehi) ty)
              (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': cast only converts among int, float, and ptr (got " (ty-str a et)) " to ") (ty-str a tp)) ")")))))))))))) 

(defn synth-offsetof [(a (ptr Allocator)) (ty Type) (ffld (slice u8)) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (let [tp (box-type a ty)]
    (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': offsetof: "))))
      (Ok [_] (match (struct-fields a tp cx) (Err [_] (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': offsetof needs a struct type, got ") (ty-str a tp)))))
        (Ok [fs] (let [nf (al-len [Field] (load fs)) (mut i) 0 (mut found) false]
          (loop (if (icmp-ge (load i) nf) (break) (do (if (str-eq (load (field (al-elem [Field] fs (load i)) name)) ffld) (do (store! found true) (break)) 0) (store! i (iadd (load i) 1)))))
          (if (not (load found)) (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': offsetof: struct '" (struct-name tp)) "' has no field '") ffld) "'")))
            (ok-ep (mk-expr (EOffsetOf ty ffld) elo ehi) (TInt 64 true))))))))))

(defn synth-fnptr [(a (ptr Allocator)) (name (slice u8)) (cx (ptr Cx)) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (let [sig (sig-find cx name)]
    (if (icmp-eq (cast i64 sig) 0) (err-ep (derr (sconcat a (sconcat4 a "in '" fname "': fnptr-of unknown function '" name) "'")))
      (if (icmp-gt (al-len [(slice u8)] (load (field sig type_params))) 0) (err-ep (derr (sconcat a (sconcat4 a "in '" fname "': cannot take a function pointer to generic function '" name) "'")))
        (if (not (load (field sig fnptr_ok))) (err-ep (derr (sconcat a (sconcat4 a "in '" fname "': cannot take a function pointer to '" name) "' (shim-convention functions are not supported yet)")))
          (ok-ep (mk-expr (EFnPtrOf name) elo ehi) (TFn (load (field sig cc)) (load (field sig params)) (box-type a (load (field sig ret))))))))))

(defn synth-callptr [(a (ptr Allocator)) (fp (ptr Expr)) (args (ptr (ArrayList Expr))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try (do
    (let [fsp (try! (do-synth a fp (null-type) env cx tps fname)) sp (alloc-stack SynPair)] (store! sp fsp)
      (let [ft (load (field sp t))]
        (if (not (icmp-eq (type-tag ft) 10)) (return-from :try (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': call-ptr expects a function pointer, got ") (ty-str a ft))))) 0)
        (let [params (t-fn-params ft) ret (t-fn-ret ft)]
          (if (not (icmp-eq (al-len [Type] (load params)) (al-len [Expr] (load args))))
              (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': function pointer expects " (i64->str a (al-len [Type] (load params)))) " args, got ") (i64->str a (al-len [Expr] (load args)))) "")))) 0)
          (let [na (try! (synth-callptr-args a params args env cx tps fname))]
            (ok-ep (mk-expr (ECallPtr (load (field sp e)) na) elo ehi) (load ret)))))))))

; ============================ synth_inner (src/check.rs:836) =================
(defn synth-inner [(a (ptr Allocator)) (e (ptr Expr)) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result EvalPair Diag))
  (let [elo (load (field e lo)) ehi (load (field e hi))]
    (match (load (field e kind))
      (EInt   [v] (ok-ep (mk-expr (EInt v) elo ehi) (TInt 64 true)))
      (EFloat [bits] (ok-ep (mk-expr (EFloat bits) elo ehi) (TFloat 64)))
      (EBool  [b] (ok-ep (mk-expr (EBool b) elo ehi) (TBool)))
      (EStr   [s] (ok-ep (mk-expr (EStr s) elo ehi) (TSlice (box-type a (TInt 8 false)))))
      (ECStr  [s] (ok-ep (mk-expr (ECStr s) elo ehi) (TPtr (box-type a (TInt 8 true)))))
      (EZeroed [ty]
        (let [tp (box-type a ty)] (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': zeroed: ")))) (Ok [_] (ok-ep (mk-expr (EZeroed ty) elo ehi) ty)))))
      (EBorrow [mutable place]
        (match (do-synth a place (null-type) env cx tps fname) (Err [d] (err-ep d))
          (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
            (let [pt (load (field sp t)) pointee (place-pointee pt)]
              (if (icmp-eq (cast i64 pointee) 0) (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': cannot borrow a non-place of type ") (ty-str a pt))))
                (if (and mutable (not (is-writable pt))) (err-ep (derr (sconcat a (sconcat a (sconcat4 a "in '" fname "': cannot take a mutable borrow of immutable '" (ty-str a pt)) "'") "")))
                  (ok-ep (load (load (field sp e))) (TRef mutable (box-type a (load pointee)))))))))))
      (EVar [name]
        (let [te (env-get env name)]
          (if (icmp-ne (cast i64 te) 0) (ok-ep (mk-expr (EVar name) elo ehi) (load te))
            (let [ce (const-find cx name)]
              (if (icmp-ne (cast i64 ce) 0)
                  (if (set-contains (field cx static_consts) name)
                      (ok-ep (mk-expr (EStaticRef name) elo ehi) (TRef false (box-type a (load (field ce ty)))))
                    (if (is-literal-value (field ce value))
                        (ok-ep (mk-expr (load (field (field ce value) kind)) elo ehi) (load (field ce ty)))
                      (ok-ep (mk-expr (EComptime (box-expr a (load (field ce value)))) elo ehi) (load (field ce ty)))))
                (err-ep (derr (sconcat a (sconcat4 a "in '" fname "': unbound variable '" name) "'"))))))))
      (ELlvmIr [result args body]
        (let [rp (box-type a result)] (match (validate-type rp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': llvm-ir result type: "))))
          (Ok [_] (match (synth-discard-args a args true (sconcat3 a "in '" fname "': llvm-ir operand uses a void value (a (-> void) call yields nothing)") env cx tps fname)
                    (Err [d] (err-ep d)) (Ok [eargs] (ok-ep (mk-expr (ELlvmIr result eargs body) elo ehi) result)))))))
      (ETraitCall [trait_name method self_tp args]
        (err-ep (derr (sconcat a (sconcat4 a "in '" fname "': internal: unresolved trait call '" method) "' in input"))))
      (EComptime [inner]
        (match (do-synth a inner expected env cx tps fname) (Err [d] (err-ep d)) (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0) (ok-ep (mk-expr (EComptime (load (field sp e))) elo ehi) (load (load (field sp t))))))))
      (EStaticRef [name]
        (err-ep (derr (sconcat a (sconcat4 a "in '" fname "': internal: unexpected static-ref '" name) "' in input"))))
      (ETypeQuery [q ty]
        (let [tp (box-type a ty)] (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': type reflection: ")))) (Ok [_] (ok-ep (mk-expr (ETypeQuery q ty) elo ehi) (if (icmp-le q 1) (TInt 64 true) (TBool)))))))
      (EFieldMeta [meta ty idx]
        (let [tp (box-type a ty)] (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': field reflection: "))))
          (Ok [_] (match (do-synth a idx (box-type a (TInt 64 true)) env cx tps fname) (Err [d] (err-ep d))
            (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
              (if (not (type-is-int (load (field sp t)))) (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': field index must be an integer, got ") (ty-str a (load (field sp t))))))
                (ok-ep (mk-expr (EFieldMeta meta ty (load (field sp e))) elo ehi) (if (icmp-eq meta 1) (TInt 64 true) (TSlice (box-type a (TInt 8 false)))))))))))))
      (EQuote [form] (ok-ep (mk-expr (EQuote form) elo ehi) (TCode)))
      (EQuasi [q]
        (let [qp (alloc-stack Quasi)] (store! qp q) (match (check-quasi a qp env cx tps fname) (Err [d] (err-ep d)) (Ok [nq] (ok-ep (mk-expr (EQuasi nq) elo ehi) (TCode))))))
      (ECodeOp [op args]
        (match (synth-discard-args a args false "" env cx tps fname) (Err [d] (err-ep d)) (Ok [na] (ok-ep (mk-expr (ECodeOp op na) elo ehi) (codeop-rty op)))))
      (EFieldIndex [ty name]
        (let [tp (box-type a ty)] (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': field-index: "))))
          (Ok [_] (match (do-synth a name (null-type) env cx tps fname) (Err [d] (err-ep d))
            (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
              (if (not (icmp-eq (type-tag (load (field sp t))) 8)) (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': field-index name must be a string, got ") (ty-str a (load (field sp t))))))
                (ok-ep (mk-expr (EFieldIndex ty (load (field sp e))) elo ehi) (TInt 64 true))))))))))
      (EBin [op lhs rhs] (synth-binop a op lhs rhs false env cx tps fname elo ehi))
      (ENot [inner]
        (match (do-synth a inner (null-type) env cx tps fname) (Err [d] (err-ep d)) (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
          (if (not (numeric (load (field sp t)) tps)) (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': inot requires an integer, got ") (ty-str a (load (field sp t))))))
            (ok-ep (mk-expr (ENot (load (field sp e))) elo ehi) (load (load (field sp t)))))))))
      (ECmp [op lhs rhs] (synth-binop a op lhs rhs true env cx tps fname elo ehi))
      (ELoop [label body] (synth-loop a label body expected env cx tps fname elo ehi))
      (EBreak [label value] (synth-break a label value env cx tps fname elo ehi))
      (EContinue [label] (synth-continue a label cx fname elo ehi))
      (EIf [cnd thn els] (synth-if a cnd thn els expected env cx tps fname elo ehi))
      (EDo [body] (synth-do a body expected env cx tps fname elo ehi))
      (ELet [binds body] (synth-let a binds body expected env cx tps fname elo ehi))
      (ECall [func type_args args] (synth-call a func type_args args expected env cx tps fname elo ehi))
      (EAlloc [storage ty]
        (let [tp (box-type a ty)] (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': alloc: ")))) (Ok [_] (ok-ep (mk-expr (EAlloc storage ty) elo ehi) (TPtr (box-type a ty)))))))
      (EField [pp ffld] (synth-field a pp ffld env cx tps fname elo ehi))
      (ELoad [inner]
        (match (do-synth a inner (null-type) env cx tps fname) (Err [d] (err-ep d)) (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
          (let [pp (place-pointee (load (field sp t)))]
            (if (icmp-ne (cast i64 pp) 0) (ok-ep (mk-expr (ELoad (load (field sp e))) elo ehi) (load pp))
              (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': load expects a pointer or reference, got ") (ty-str a (load (field sp t)))))))))))) 
      (EStore [pp val] (synth-store a pp val env cx tps fname elo ehi))
      (EIndex [pp idx] (synth-index a pp idx env cx tps fname elo ehi))
      (ECast [ty inner] (synth-cast a ty inner env cx tps fname elo ehi))
      (ESizeOf [ty]
        (let [tp (box-type a ty)] (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': sizeof: ")))) (Ok [_] (ok-ep (mk-expr (ESizeOf ty) elo ehi) (TInt 64 true))))))
      (EAlignOf [ty]
        (let [tp (box-type a ty)] (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': alignof: ")))) (Ok [_] (ok-ep (mk-expr (EAlignOf ty) elo ehi) (TInt 64 true))))))
      (EOffsetOf [ty ffld] (synth-offsetof a ty ffld cx tps fname elo ehi))
      (EBitGet [pp bfld]
        (match (bit-field-type a pp bfld env cx tps fname) (Err [d] (err-ep d)) (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0) (ok-ep (mk-expr (EBitGet (load (field sp e)) bfld) elo ehi) (load (load (field sp t))))))))
      (EBitSet [pp bfld val]
        (match (bit-field-type a pp bfld env cx tps fname) (Err [d] (err-ep d)) (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
          (let [fty (load (field sp t))]
            (match (do-synth a val fty env cx tps fname) (Err [d] (err-ep d)) (Ok [vsp0] (let [vsp (alloc-stack SynPair)] (store! vsp vsp0)
              (match (coerce a (load (load (field vsp e))) (load (field vsp t)) fty false fname (sconcat a (sconcat3 a "set! into bitfield '" bfld "'") "")) (Err [d] (err-ep d))
                (Ok [ve] (ok-ep (mk-expr (EBitSet (load (field sp e)) bfld (box-expr a ve)) elo ehi) (load fty)))))))))))) 
      (EFree [inner]
        (match (do-synth a inner (null-type) env cx tps fname) (Err [d] (err-ep d)) (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
          (if (type-is-ptr (load (field sp t))) (ok-ep (mk-expr (EFree (load (field sp e))) elo ehi) (TInt 64 true))
            (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': free expects a pointer, got ") (ty-str a (load (field sp t)))))))))))
      (EErase [trait_name inner]
        (match (do-synth a inner (null-type) env cx tps fname) (Err [d] (err-ep d)) (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
          (match (build-make-dyn a cx trait_name (load (field sp e)) (load (field sp t)) elo ehi fname) (Err [d] (err-ep d))
            (Ok [mp0] (let [mp (alloc-stack SynPair)] (store! mp mp0) (ok-ep (load (load (field mp e))) (load (load (field mp t)))))))))))
      (EMatch [scrut arms] (synth-match a scrut arms expected env cx tps fname elo ehi))
      (EFnPtrOf [name] (synth-fnptr a name cx fname elo ehi))
      (ECallPtr [fp args] (synth-callptr a fp args env cx tps fname elo ehi))
      (EConstruct [sum variant args]
        (match (synth-construct a variant (box-items-type a) args (null-type) env cx tps fname elo ehi) (Err [d] (err-ep d))
          (Ok [rv] (let [r (alloc-stack EvalPair)] (store! r rv) (ok-ep (load (field r e)) (TStruct sum))))))
      (EMakeDyn [dyn_struct vtable_struct methods inner] (ok-ep (load e) (TStruct dyn_struct)))
      (EDynDispatch [ds vt mi cc params ret recv args] (ok-ep (load e) ret))
      (ESpillRef [inner] (err-ep (derr (sconcat3 a "in '" fname "': internal: SpillRef in input")))))))

; synth (src/check.rs:800) — span-fill + auto dyn-coercion wrapper.
(defn synth [(a (ptr Allocator)) (e (ptr Expr)) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result EvalPair Diag))
  (let [dynt (if (expected-some? expected) (is-dyn-target expected cx) false)]
    (match (synth-inner a e expected env cx tps fname)
      (Err [d] (err-ep (dwspan d (load (field e lo)) (load (field e hi)))))
      (Ok [rv]
        (if (not dynt) (Ok [EvalPair Diag] rv)
          (let [r (alloc-stack EvalPair)] (store! r rv)
            (match (maybe-coerce-dyn a cx (box-expr a (load (field r e))) (box-type a (load (field r t))) expected (load (field e lo)) (load (field e hi)) fname)
              (Err [d] (err-ep d))
              (Ok [mp0] (let [mp (alloc-stack SynPair)] (store! mp mp0) (ok-ep (load (load (field mp e))) (load (load (field mp t))))))))))) ))



; ============================ check.rs: finish (Phase 3) =====================
; Static-assert conditions are synth'd + is-cond-checked. The comptime fold
; (comptime::fold_program), aggregate-const statics, (meta …) elaboration, and
; export-c symbol resolution are a separate unported subsystem: finish passes
; funcs through unchanged (a no-op fold for comptime-free programs — any program
; that actually USES comptime will then mismatch the reference and fail the gate,
; never silently pass), and hard-errors on (meta …)/(export-c …) which the dump
; would otherwise misrepresent. Aggregate-const statics do not affect the dump
; (the dumper hardcodes an empty (statics) section), so static_consts are ignored.
(defn finish-asserts [(a (ptr Allocator)) (cx (ptr Cx)) (prog (ptr Program))] (-> (Result (ptr (ArrayList StaticAssert)) Diag))
  (let [as (load (field prog asserts)) n (al-len [StaticAssert] (load as)) (mut out) (al-new [StaticAssert] a)
        (mut i) 0 (mut err) (zeroed Diag) (mut failed) false
        empty-tps (box-al [(slice u8)] a (al-new [(slice u8)] a))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [ap (al-elem [StaticAssert] as (load i)) env (env-new a)]
            (match (do-synth a (field ap cnd) (null-type) env cx empty-tps "static-assert")
              (Err [d] (do (store! err d) (store! failed true) (break)))
              (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
                          (if (not (is-cond (load (field sp t))))
                              (do (store! err (derr (sconcat a "static-assert: condition must be a bool or integer, got " (ty-str a (load (field sp t)))))) (store! failed true) (break))
                            (let [na (alloc-stack StaticAssert)] (store! (field na cnd) (load (load (field sp e)))) (store! (field na msg) (load (field ap msg))) (al-push! (mut out) (load na)) 0))))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList StaticAssert)) Diag] (load err)) (Ok (box-al [StaticAssert] a (load out))))))

(defn finish [(a (ptr Allocator)) (cx (ptr Cx)) (prog (ptr Program)) (funcs (ptr (ArrayList Func)))] (-> (Result (ptr Program) Diag))
  (match (finish-asserts a cx prog)
    (Err [d] (Err [(ptr Program) Diag] d))
    (Ok [asserts]
      (if (icmp-gt (al-len [Expr] (load (field prog metas))) 0)
          (do (unimplemented "check/finish: (meta …) staged macros not ported") (Err [(ptr Program) Diag] (derr "")))
        (if (icmp-gt (al-len [ExportC] (load (field prog exports))) 0)
            (do (unimplemented "check/finish: (export-c …) symbol resolution not ported") (Err [(ptr Program) Diag] (derr "")))
          (let [out (unwrap-ptr [Program] (create [Program] a))]
            (store! (field out conventions) (load (field prog conventions)))
            (store! (field out structs) (load (field prog structs)))
            (store! (field out sums) (load (field prog sums)))
            (store! (field out externs) (load (field prog externs)))
            (store! (field out funcs) funcs)
            (store! (field out asserts) asserts)
            (store! (field out consts) (load (field prog consts)))
            (store! (field out traits) (load (field prog traits)))
            (store! (field out impls) (load (field prog impls)))
            (store! (field out metas) (load (field prog metas)))
            (store! (field out exports) (load (field prog exports)))
            (Ok out)))))))

; ============================ the check pass (src/check.rs) ===================
; check-program mirrors src/check.rs::check_with: setup (Phase 1, fail-fast) ->
; check_func over every function (Phase 2; FIRST error wins, matching the oracle's
; dump_error of diagnostics[0]) -> finish (Phase 3). Returns the typed/elaborated/
; LOWERED Program, or Err(diag) dumped canonically.
(defn check-all-funcs [(a (ptr Allocator)) (cx (ptr Cx)) (allf (ptr (ArrayList Func)))] (-> (Result (ptr (ArrayList Func)) Diag))
  (let [n (al-len [Func] (load allf)) (mut out) (al-new [Func] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (check-func a cx (al-elem [Func] allf (load i)))
            (Err [d] (do (store! err d) (store! failed true) (break)))
            (Ok [f] (al-push! (mut out) f)))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok (box-al [Func] a (load out))))))
(defn check-program [(a (ptr Allocator)) (p (ptr Program)) (s (mut LS))] (-> (Result (ptr Program) Diag))
  (let [impb (unwrap-ptr [(ArrayList ImpEntry)] (create [(ArrayList ImpEntry)] a))
        expb (unwrap-ptr [(ArrayList ExpEntry)] (create [(ArrayList ExpEntry)] a))
        cx (unwrap-ptr [Cx] (create [Cx] a))]
    (store! impb (load (field s imports)))
    (store! expb (load (field s exports)))
    (match (setup a cx p impb expb)
      (Err [d] (Err [(ptr Program) Diag] d))
      (Ok [allf]
        (match (check-all-funcs a cx allf)
          (Err [d] (Err [(ptr Program) Diag] d))
          (Ok [funcs] (finish a cx p funcs)))))))

; ============================ entry ========================================
(defn dump-checked-program [(a (ptr Allocator)) (src (slice u8)) (cwd (slice u8))] (-> i64)
  (let [w (stdout) s (alloc-stack LS)]
    (store! (field s a) a)
    (store! (field s out)     (al-new [TaggedForm] a))
    (store! (field s loaded)  (al-new [(slice u8)] a))
    (store! (field s imports) (al-new [ImpEntry] a))
    (store! (field s exports) (al-new [ExpEntry] a))
    (store! (field s srccount) 1)
    (match (read-all a src 0)
      (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
      (Ok [forms]
        (do (load-program (mut s) forms cwd)
            (match (resolve-program a (mut s) true)
              (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
              (Ok [prog]
                (match (check-program a prog (mut s))
                  (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
                  (Ok [cp] (d-program w cp a)))))))))
  0)

; A standalone byte-exact smoke for the 6 new d-expr arms (run: `<bin> __smoke`).
; Each line must match exactly what src/dump_ast.rs would emit for the same node.
(defn smoke [(a (ptr Allocator))] (-> i64)
  (let [w (stdout)]
    ; (staticref@1:2 "foo")
    (let [e (alloc-stack Expr)] (store! e (mk-expr (EStaticRef "foo") 1 2)) (d-expr w e)) (wb w 10)
    ; (spillref@5:6 (eint@3:4 7))
    (let [inner (box-expr a (mk-expr (EInt 7) 3 4)) e (alloc-stack Expr)]
      (store! e (mk-expr (ESpillRef inner) 5 6)) (d-expr w e)) (wb w 10)
    ; (construct@9:10 "Opt" "Some" [(eint@7:8 9)])
    (let [(mut xs) (al-new [Expr] a)]
      (al-push! (mut xs) (mk-expr (EInt 9) 7 8))
      (let [args (box-al [Expr] a (load xs)) e (alloc-stack Expr)]
        (store! e (mk-expr (EConstruct "Opt" "Some" args) 9 10)) (d-expr w e))) (wb w 10)
    ; (traitcall@11:12 "Eq" "eq" "T" [])
    (let [args (box-al [Expr] a (al-new [Expr] a)) e (alloc-stack Expr)]
      (store! e (mk-expr (ETraitCall "Eq" "eq" "T" args) 11 12)) (d-expr w e)) (wb w 10)
    ; (makedyn@13:14 "Dyn" "VT" ["m0" "m1"] (var@15:16 "x"))
    (let [(mut ms) (al-new [(slice u8)] a)]
      (al-push! (mut ms) "m0") (al-push! (mut ms) "m1")
      (let [methods (box-al [(slice u8)] a (load ms))
            inner (box-expr a (mk-expr (EVar "x") 15 16)) e (alloc-stack Expr)]
        (store! e (mk-expr (EMakeDyn "Dyn" "VT" methods inner) 13 14)) (d-expr w e))) (wb w 10)
    ; (dyndispatch@17:18 "Dyn" "VT" 2 "c" [] void (var@19:20 "r") [])
    (let [params (box-al [Type] a (al-new [Type] a))
          args (box-al [Expr] a (al-new [Expr] a))
          recv (box-expr a (mk-expr (EVar "r") 19 20)) e (alloc-stack Expr)]
      (store! e (mk-expr (EDynDispatch "Dyn" "VT" 2 "c" params (TVoid) recv args) 17 18)) (d-expr w e)) (wb w 10)
    ; ---- ty-str byte-exact checks (vs src/check.rs::ty_str) ----
    (let [t (alloc-stack Type)] (store! t (TInt 64 true))  (ps w (ty-str a t))) (wb w 10)  ; i64
    (let [t (alloc-stack Type)] (store! t (TInt 8 false))  (ps w (ty-str a t))) (wb w 10)  ; u8
    (let [t (alloc-stack Type)] (store! t (TPtr (box-type a (TInt 8 false)))) (ps w (ty-str a t))) (wb w 10)  ; (ptr u8)
    (let [t (alloc-stack Type)] (store! t (TRef true (box-type a (TStruct "Foo")))) (ps w (ty-str a t))) (wb w 10)  ; (mut Foo)
    (let [(mut ps2) (al-new [Type] a)]
      (al-push! (mut ps2) (TInt 64 true)) (al-push! (mut ps2) (TInt 64 true))
      (let [t (alloc-stack Type)] (store! t (TApp "Pair" (box-al [Type] a (load ps2)))) (ps w (ty-str a t)))) (wb w 10)  ; (Pair i64 i64)
    (let [(mut ps3) (al-new [Type] a)]
      (al-push! (mut ps3) (TPtr (box-type a (TInt 8 true))))
      (let [t (alloc-stack Type)] (store! t (TFn "c" (box-al [Type] a (load ps3)) (box-type a (TInt 64 true)))) (ps w (ty-str a t)))) (wb w 10)  ; (fnptr c [(ptr i8)] i64)
    0))

; ============================ comptime CtVal + cell arena ====================
; Mirrors src/comptime.rs. Comptime memory is ARENA-lived and NEVER FREED, so
; Rust's `Cell = Rc<RefCell<CtVal>>` collapses to a malloc'd heap pointer to a
; tagged CtVal: a Cell = `(ptr CtVal)`, a Ref = that pointer, mutate-through =
; `store!`. No refcounting, no GC. Struct/Array/Sum hold an ArrayList of cell
; pointers; Code holds a Sexp (by value). CFloat stores the f64 directly (mirrors
; CtVal::Float — float arithmetic at comptime stays exact).
(defsum CtVal
  (CInt    [(v i64)])
  (CBool   [(b bool)])
  (CFloat  [(x f64)])
  (CStr    [(s (slice u8))])
  (CCode   [(form Sexp)])
  (CStruct [(name (slice u8)) (fields (ptr (ArrayList (ptr CtVal))))])
  (CArray  [(elem Type) (cells (ptr (ArrayList (ptr CtVal))))])
  (CSum    [(variant (slice u8)) (fields (ptr (ArrayList (ptr CtVal))))])
  (CRef    [(cell (ptr CtVal))]))

; new_cell: a fresh arena cell holding `c` (src/comptime.rs::new_cell). The arena
; is the process malloc-allocator singleton (never freed during a compile).
(defn new-cell [(c CtVal)] (-> (ptr CtVal))
  (let [p (unwrap-ptr [CtVal] (create [CtVal] (malloc-allocator)))] (store! p c) p))

; is_aggregate (src/comptime.rs::is_aggregate): Struct/Array/Sum are aggregates.
(defn is-aggregate [(c (ptr CtVal))] (-> bool)
  (match (load c)
    (CStruct [name fields]    true)
    (CArray  [elem cells]     true)
    (CSum    [variant fields] true)
    (CInt    [v]    false)
    (CBool   [b]    false)
    (CFloat  [x]    false)
    (CStr    [s]    false)
    (CCode   [f]    false)
    (CRef    [cell] false)))

; deep_clone helper: clone an ArrayList of cells, each into a FRESH cell.
(defn clone-cells [(cells (ptr (ArrayList (ptr CtVal))))] (-> (ptr (ArrayList (ptr CtVal))))
  (let [a (malloc-allocator) n (al-len [(ptr CtVal)] (load cells)) (mut out) (al-new [(ptr CtVal)] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut out) (new-cell (deep-clone (al-get [(ptr CtVal)] (load cells) (load i)))))
          (store! i (iadd (load i) 1)))))
    (box-al [(ptr CtVal)] a (load out))))

; deep_clone (src/comptime.rs::deep_clone): deep-copy cell CONTENT — scalars copy
; (Ref shares its cell, matching Rust's scalar fallthrough); aggregates get fresh
; cells, giving value semantics where the language copies.
(defn deep-clone [(c (ptr CtVal))] (-> CtVal)
  (match (load c)
    (CStruct [name fields]    (CStruct name    (clone-cells fields)))
    (CArray  [elem cells]     (CArray  elem    (clone-cells cells)))
    (CSum    [variant fields] (CSum    variant (clone-cells fields)))
    (CInt    [v]    (CInt v))
    (CBool   [b]    (CBool b))
    (CFloat  [x]    (CFloat x))
    (CStr    [s]    (CStr s))
    (CCode   [f]    (CCode f))
    (CRef    [cell] (CRef cell))))

; to_content (src/comptime.rs::to_content): turn an evaluated value into cell
; CONTENT — a reference's pointee is copied in (so a cell never holds a Ref).
(defn to-content [(c (ptr CtVal))] (-> CtVal)
  (match (load c)
    (CRef    [cell] (deep-clone cell))
    (CInt    [v]    (CInt v))
    (CBool   [b]    (CBool b))
    (CFloat  [x]    (CFloat x))
    (CStr    [s]    (CStr s))
    (CCode   [f]    (CCode f))
    (CStruct [name fields]    (CStruct name fields))
    (CArray  [elem cells]     (CArray elem cells))
    (CSum    [variant fields] (CSum variant fields))))

; cell_value (src/comptime.rs::cell_value): read a cell as a VALUE — a scalar comes
; back directly; an aggregate comes back as a Ref to the cell (aggregate-value rep).
(defn cell-value [(cell (ptr CtVal))] (-> CtVal)
  (if (is-aggregate cell) (CRef cell) (load cell)))

; ============================ comptime interpreter (Flow/Env/Ctx) ============
; Mirrors src/comptime.rs's interpreter. `eval` returns a Flow (a `(Result Flow
; Diag)`): a normal value is FVal, a `break`/`continue` propagate as FBrk/FCont up
; to the enclosing loop (Rust's `Flow`). A real comptime error is the Err channel.
(defsum Flow
  (FVal  [(v CtVal)])
  (FBrk  [(value (Option CtVal)) (label (Option (slice u8)))])
  (FCont [(label (Option (slice u8)))]))

; Env: Rust's `HashMap<String, CtVal>`, modelled as an assoc-list with HashMap
; semantics — insert APPENDS, lookup returns the LAST match (so a later binding of
; the same name shadows). Scopes are cloned per Let/Match (never mutated in place;
; `eval` only READS its env), Calls start from a fresh empty env (comptime fns are
; closed). CtVal is stored by value (a CRef just copies the cell pointer = sharing).
(defstruct EnvBind [(name (slice u8)) (val CtVal)])

(defn env-clone [(a (ptr Allocator)) (env (ptr (ArrayList EnvBind)))] (-> (ptr (ArrayList EnvBind)))
  (let [n (al-len [EnvBind] (load env)) (mut out) (al-new [EnvBind] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut out) (al-get [EnvBind] (load env) (load i)))
          (store! i (iadd (load i) 1)))))
    (box-al [EnvBind] a (load out))))

; env.clone() + scope.insert(name, v): a fresh env with `name`→`v` appended.
(defn env-with [(a (ptr Allocator)) (env (ptr (ArrayList EnvBind))) (name (slice u8)) (v CtVal)] (-> (ptr (ArrayList EnvBind)))
  (let [n (al-len [EnvBind] (load env)) (mut out) (al-new [EnvBind] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut out) (al-get [EnvBind] (load env) (load i)))
          (store! i (iadd (load i) 1)))))
    (let [eb (alloc-stack EnvBind)]
      (store! (field eb name) name)
      (store! (field eb val) v)
      (al-push! (mut out) (load eb)))
    (box-al [EnvBind] a (load out))))

; env.get(name).cloned(): the LAST matching binding's value (HashMap last-wins).
(defn env-find [(env (ptr (ArrayList EnvBind))) (name (slice u8))] (-> (Option CtVal))
  (let [n (al-len [EnvBind] (load env)) (mut i) 0 (mut r) (None [CtVal])]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [p (al-elem [EnvBind] env (load i))]
            (if (str-eq (load (field p name)) name) (do (store! r (Some (load (field p val)))) 0) 0))
          (store! i (iadd (load i) 1)))))
    (load r)))

; The comptime evaluation context (src/comptime.rs::Ctx). The type/fn tables are
; ArrayLists of the AST defs (the macro closure); fuel/depth/gensym are mutated
; through the pointer. The qualify_* hygiene fields are present for the driver
; (unused by the scalar interpreter; null/None = "outside macro expansion").
(defstruct CtCtx
  [(a (ptr Allocator))
   (fns      (ptr (ArrayList Func)))
   (structs  (ptr (ArrayList StructDef)))
   (sums     (ptr (ArrayList SumDef)))
   (variants (ptr (ArrayList (slice u8))))
   (traits   (ptr (ArrayList TraitDef)))
   (fuel i64)
   (depth i64)
   (gensym i64)
   ; ---- referential-hygiene fields (driver chunk; null/None when not expanding)
   (qmodule  (Option (slice u8)))
   (module_fns      (ptr (ArrayList (slice u8))))
   (qimports (ptr ModImports))
   (qexports (ptr (ArrayList ExpEntry)))])

; vget! — Rust's `val!` macro: unwrap a `(Result Flow Diag)`, yielding the CtVal of
; an FVal; an FBrk/FCont short-circuits the enclosing `(try …)` returning the Flow
; UNCHANGED (propagating break/continue up to the loop); a Diag propagates via try!.
(defn vget! [(fl Code)] (-> Code)
  (let [f (gensym) v (gensym)]
    `(let [~f (try! ~fl)]
       (match ~f
         (FVal  [~v] ~v)
         (FBrk  [vv ll] (return-from :try (Ok [Flow Diag] ~f)))
         (FCont [ll]    (return-from :try (Ok [Flow Diag] ~f)))))))

; Hard-error stub for an un-ported eval arm (RECIPE rule 2: never a silent fake).
(defn eval-todo [(who (slice u8))] (-> (Result Flow Diag))
  (do (unimplemented who) (Ok [Flow Diag] (FVal (CInt 0)))))

; ---- CtVal scalar accessors (tag + total extractors; extractors are GUARDED by a
;      tag check at every call site, mirroring Rust's irrefutable pattern matches).
(defn ct-tag [(v CtVal)] (-> i64)
  (match v (CInt [n] 0) (CBool [b] 1) (CFloat [x] 2) (CStr [s] 3) (CCode [f] 4)
           (CStruct [a b] 5) (CArray [a b] 6) (CSum [a b] 7) (CRef [c] 8)))
(defn cint-of [(v CtVal)] (-> i64)
  (match v (CInt [n] n) (CBool [b] 0) (CFloat [x] 0) (CStr [s] 0) (CCode [f] 0)
           (CStruct [a b] 0) (CArray [a b] 0) (CSum [a b] 0) (CRef [c] 0)))
(defn cfloat-of [(v CtVal)] (-> f64)
  (match v (CFloat [x] x) (CInt [n] 0.0) (CBool [b] 0.0) (CStr [s] 0.0) (CCode [f] 0.0)
           (CStruct [a b] 0.0) (CArray [a b] 0.0) (CSum [a b] 0.0) (CRef [c] 0.0)))
(defn cbool-of [(v CtVal)] (-> bool)
  (match v (CBool [b] b) (CInt [n] false) (CFloat [x] false) (CStr [s] false) (CCode [f] false)
           (CStruct [a b] false) (CArray [a b] false) (CSum [a b] false) (CRef [c] false)))

; truthy (src/comptime.rs::truthy): a condition must be a bool or integer.
(defn truthy [(v CtVal)] (-> (Result bool Diag))
  (match v
    (CBool [b] (Ok b))
    (CInt  [n] (Ok (icmp-ne n 0)))
    (CFloat [x] (Err [bool Diag] (derr "comptime: condition must be a bool or integer")))
    (CStr  [s] (Err [bool Diag] (derr "comptime: condition must be a bool or integer")))
    (CCode [f] (Err [bool Diag] (derr "comptime: condition must be a bool or integer")))
    (CStruct [a b] (Err [bool Diag] (derr "comptime: condition must be a bool or integer")))
    (CArray  [a b] (Err [bool Diag] (derr "comptime: condition must be a bool or integer")))
    (CSum    [a b] (Err [bool Diag] (derr "comptime: condition must be a bool or integer")))
    (CRef    [c]   (Err [bool Diag] (derr "comptime: condition must be a bool or integer")))))

; i64 bit-pattern -> f64 (reverse of f64-bits; EFloat stores the bit pattern).
(defn bits->f64 [(n i64)] (-> f64)
  (let [p (alloc-stack i64)] (store! p n) (load (cast (ptr f64) p))))

; trunc (src/comptime.rs::trunc): truncate `n` to `bits`, sign- or zero-extending.
; Done in i64 (no i128): for bits<64 every intermediate fits (mask, masked, and
; masked-(1<<bits) all in range).
(defn trunc [(n i64) (bits i64) (signed bool)] (-> i64)
  (if (icmp-ge bits 64) n
    (let [mask (isub (ishl 1 bits) 1)
          masked (iand n mask)]
      (if (and signed (icmp-ne (iand masked (ishl 1 (isub bits 1))) 0))
          (isub masked (ishl 1 bits))
          masked))))

; ---- ordering helpers (ord = -1/0/1; NaN sorts Less, matching Rust's
;      partial_cmp(...).unwrap_or(Less)).
(defn icmp-ord [(x i64) (y i64)] (-> i64) (if (icmp-lt x y) -1 (if (icmp-gt x y) 1 0)))
(defn fcmp-ord [(x f64) (y f64)] (-> i64) (if (fcmp-lt x y) -1 (if (fcmp-eq x y) 0 (if (fcmp-gt x y) 1 -1))))
(defn bool-ord [(x bool) (y bool)] (-> i64) (if (and (not x) y) -1 (if (and x (not y)) 1 0)))
(defn cmp-apply [(op i64) (ord i64)] (-> bool)
  (if (icmp-eq op 0) (icmp-eq ord -1)
  (if (icmp-eq op 1) (icmp-ne ord 1)
  (if (icmp-eq op 2) (icmp-eq ord 1)
  (if (icmp-eq op 3) (icmp-ne ord -1)
  (if (icmp-eq op 4) (icmp-eq ord 0)
      (icmp-ne ord 0)))))))

; bin (src/comptime.rs::bin): two floats -> float op (add/sub/mul/div only); else
; two ints -> the full int op set; anything else is a type error.
(defn ct-bin-float [(op i64) (x f64) (y f64)] (-> (Result CtVal Diag))
  (if (icmp-eq op 0) (Ok (CFloat (fadd x y)))
  (if (icmp-eq op 1) (Ok (CFloat (fsub x y)))
  (if (icmp-eq op 2) (Ok (CFloat (fmul x y)))
  (if (icmp-eq op 3) (Ok (CFloat (fdiv x y)))
      (Err [CtVal Diag] (derr "comptime: unsupported float operation")))))))
(defn ct-bin-int [(op i64) (x i64) (y i64)] (-> (Result CtVal Diag))
  (if (icmp-eq op 0) (Ok (CInt (iadd x y)))
  (if (icmp-eq op 1) (Ok (CInt (isub x y)))
  (if (icmp-eq op 2) (Ok (CInt (imul x y)))
  (if (icmp-eq op 3) (if (icmp-eq y 0) (Err [CtVal Diag] (derr "comptime: division by zero")) (Ok (CInt (idiv x y))))
  (if (icmp-eq op 4) (if (icmp-eq y 0) (Err [CtVal Diag] (derr "comptime: remainder by zero")) (Ok (CInt (irem x y))))
  (if (icmp-eq op 5) (if (icmp-eq y 0) (Err [CtVal Diag] (derr "comptime: division by zero")) (Ok (CInt (udiv x y))))
  (if (icmp-eq op 6) (if (icmp-eq y 0) (Err [CtVal Diag] (derr "comptime: remainder by zero")) (Ok (CInt (urem x y))))
  (if (icmp-eq op 7) (Ok (CInt (iand x y)))
  (if (icmp-eq op 8) (Ok (CInt (ior x y)))
  (if (icmp-eq op 9) (Ok (CInt (ixor x y)))
  (if (icmp-eq op 10) (Ok (CInt (ishl x y)))
      (Ok (CInt (ishr x y)))))))))))))))
(defn ct-bin [(op i64) (a CtVal) (b CtVal)] (-> (Result CtVal Diag))
  (if (and (icmp-eq (ct-tag a) 2) (icmp-eq (ct-tag b) 2))
      (ct-bin-float op (cfloat-of a) (cfloat-of b))
  (if (and (icmp-eq (ct-tag a) 0) (icmp-eq (ct-tag b) 0))
      (ct-bin-int op (cint-of a) (cint-of b))
      (Err [CtVal Diag] (derr "comptime: arithmetic needs two integers (or two floats)")))))

; cmp (src/comptime.rs::cmp): compares two same-kind scalars (int/float/bool) -> bool.
(defn ct-cmp [(op i64) (a CtVal) (b CtVal)] (-> (Result CtVal Diag))
  (if (and (icmp-eq (ct-tag a) 0) (icmp-eq (ct-tag b) 0))
      (Ok (CBool (cmp-apply op (icmp-ord (cint-of a) (cint-of b)))))
  (if (and (icmp-eq (ct-tag a) 2) (icmp-eq (ct-tag b) 2))
      (Ok (CBool (cmp-apply op (fcmp-ord (cfloat-of a) (cfloat-of b)))))
  (if (and (icmp-eq (ct-tag a) 1) (icmp-eq (ct-tag b) 1))
      (Ok (CBool (cmp-apply op (bool-ord (cbool-of a) (cbool-of b)))))
      (Err [CtVal Diag] (derr "comptime: comparison needs two values of the same scalar kind"))))))

; let-mut binding (src/comptime.rs Let arm): a mutable place. An aggregate already
; IS a place (CRef); a scalar gets a fresh cell so it can be written through.
(defn wrap-mut [(v CtVal)] (-> CtVal)
  (if (icmp-eq (ct-tag v) 8) v (CRef (new-cell v))))

; ct-cast (src/comptime.rs Cast arm): (Int, Int-type) truncates; everything else is
; identity (the value passes through unchanged).
(defn cast-trunc [(n i64) (ty Type)] (-> CtVal)
  (match ty
    (TInt  [bits signed] (CInt (trunc n bits signed)))
    (TFloat [b] (CInt n)) (TBool [] (CInt n)) (TVoid [] (CInt n))
    (TPtr [i] (CInt n)) (TRef [m i] (CInt n)) (TStruct [nm] (CInt n))
    (TArray [e k] (CInt n)) (TSlice [e] (CInt n)) (TVec [e k] (CInt n))
    (TFn [c p r] (CInt n)) (TApp [nm ar] (CInt n)) (TNever [] (CInt n)) (TCode [] (CInt n))))
(defn ct-cast [(v CtVal) (ty Type)] (-> CtVal)
  (if (icmp-eq (ct-tag v) 0) (cast-trunc (cint-of v) ty) v))

; ============================ CtVal payload accessors ========================
; Guarded (tag-checked) at every call site, mirroring Rust's irrefutable matches.
(defn cref-cell    [(v CtVal)] (-> (ptr CtVal)) (match-else v (CRef [c] c) (_ (cast (ptr CtVal) 0))))
(defn cstruct-name [(v CtVal)] (-> (slice u8))  (match-else v (CStruct [nm f] nm) (_ "")))
(defn cstruct-fields [(v CtVal)] (-> (ptr (ArrayList (ptr CtVal)))) (match-else v (CStruct [nm f] f) (_ (cast (ptr (ArrayList (ptr CtVal))) 0))))
(defn carray-cells [(v CtVal)] (-> (ptr (ArrayList (ptr CtVal)))) (match-else v (CArray [el c] c) (_ (cast (ptr (ArrayList (ptr CtVal))) 0))))
(defn csum-variant [(v CtVal)] (-> (slice u8))  (match-else v (CSum [vr f] vr) (_ "")))
(defn csum-fields  [(v CtVal)] (-> (ptr (ArrayList (ptr CtVal)))) (match-else v (CSum [vr f] f) (_ (cast (ptr (ArrayList (ptr CtVal))) 0))))

; is_aggregate on a CtVal by value (Struct/Array/Sum). Mirrors is-aggregate.
(defn is-aggregate-v [(c CtVal)] (-> bool)
  (let [t (ct-tag c)] (or (icmp-eq t 5) (or (icmp-eq t 6) (icmp-eq t 7)))))

; to_content on a CtVal by value (Rust takes CtVal by value: new_cell(to_content(v))).
(defn to-content-v [(v CtVal)] (-> CtVal) (to-content (new-cell v)))

; v.unwrap_or(CtVal::Int(0)) for a break value (FBrk).
(defn opt-ctval-or [(o (Option CtVal))] (-> CtVal) (match o (Some [v] v) (None [] (CInt 0))))

; label match: `l.is_none() || l == *label` (both `(Option (slice u8))`).
(defn lbl-match [(l (Option (slice u8))) (label (Option (slice u8)))] (-> bool)
  (match l
    (None [] true)
    (Some [ls] (match label (None [] false) (Some [lab] (str-eq ls lab))))))

; Is an `(Option Diag)` a Some? (loop error-flag predicate).
(defn diag-some? [(o (Option Diag))] (-> bool) (match o (Some [d] true) (None [] false)))

; decimal string of an i64 (for `array index {i} out of bounds`).
(defn dec->str [(a (ptr Allocator)) (n i64)] (-> (slice u8))
  (if (icmp-eq n 0) "0"
    (let [neg (icmp-lt n 0)
          (mut m) (if neg (isub 0 n) n)
          tmp (cast (ptr u8) (unwrap-ptr [i8] (raw-alloc a 24 1)))
          (mut cnt) 0]
      (loop (if (icmp-eq (load m) 0) (break)
        (do (store! (index tmp (load cnt)) (cast u8 (iadd (urem (load m) 10) 48)))
            (store! cnt (iadd (load cnt) 1))
            (store! m (udiv (load m) 10)))))
      (let [extra (if neg 1 0)
            total (iadd (load cnt) extra)
            out (cast (ptr u8) (unwrap-ptr [i8] (raw-alloc a total 1)))
            (mut j) (if neg 1 0)
            (mut k) (load cnt)]
        (if neg (do (store! (index out 0) (cast u8 45)) 0) 0)
        (loop (if (icmp-eq (load k) 0) (break)
          (do (store! k (isub (load k) 1))
              (store! (index out (load j)) (load (index tmp (load k))))
              (store! j (iadd (load j) 1)))))
        (slice-new [u8] out total)))))

; ---- CtCtx table lookups. ctx.structs/ctx.fns are Rust HashMaps (last-insert
;      wins on `.get`), so the find returns the LAST matching entry (no break);
;      ctx.variants is a HashSet (any match = contains). Null pointer = not found.
(defn ct-struct-find [(cx (ptr CtCtx)) (name (slice u8))] (-> (ptr StructDef))
  (let [lst (load (field cx structs)) n (al-len [StructDef] (load lst)) (mut i) 0 (mut r) (cast (ptr StructDef) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [StructDef] lst (load i)) name)) name)
              (do (store! r (al-elem [StructDef] lst (load i))) 0) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn ct-fn-find [(cx (ptr CtCtx)) (name (slice u8))] (-> (ptr Func))
  (let [lst (load (field cx fns)) n (al-len [Func] (load lst)) (mut i) 0 (mut r) (cast (ptr Func) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [Func] lst (load i)) name)) name)
              (do (store! r (al-elem [Func] lst (load i))) 0) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn ct-variant? [(cx (ptr CtCtx)) (name (slice u8))] (-> bool)
  (let [lst (load (field cx variants)) n (al-len [(slice u8)] (load lst)) (mut i) 0 (mut r) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (al-get [(slice u8)] (load lst) (load i)) name) (do (store! r true) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))

; field_index (src/comptime.rs::field_index): position of field `f` in struct `name`.
(defn ct-field-index [(name (slice u8)) (f (slice u8)) (cx (ptr CtCtx))] (-> (Result i64 Diag))
  (let [a (load (field cx a)) sd (ct-struct-find cx name)]
    (if (icmp-eq (cast i64 sd) 0)
        (Err [i64 Diag] (derr (sconcat3 a "comptime: unknown struct '" name "'")))
        (let [flds (load (field sd fields)) nf (al-len [Field] (load flds)) (mut i) 0 (mut r) -1]
          (loop (if (icmp-ge (load i) nf) (break)
            (do (if (str-eq (load (field (al-elem [Field] flds (load i)) name)) f)
                    (do (store! r (load i)) (break)) 0)
                (store! i (iadd (load i) 1)))))
          (if (icmp-lt (load r) 0)
              (Err [i64 Diag] (derr (sconcat3 a (sconcat3 a "comptime: struct '" name "' has no field '") f "'")))
              (Ok [i64 Diag] (load r)))))))

; is the elem of a slice `(int 8 _)` (a u8 string)? — zeroed `(slice u8)` => "".
(defn is-u8 [(t Type)] (-> bool) (match-else t (TInt [bits signed] (icmp-eq bits 8)) (_ false)))

; zeroed_content for a struct's field cells (fallible loop; error-flag style to
; avoid loop+control-flow PHI pitfalls).
(defn zeroed-struct-cells [(flds (ptr (ArrayList Field))) (cx (ptr CtCtx))] (-> (Result (ptr (ArrayList (ptr CtVal))) Diag))
  (let [a (load (field cx a)) nf (al-len [Field] (load flds)) (mut out) (al-new [(ptr CtVal)] a) (mut i) 0 (mut errf) (None [Diag])]
    (loop (if (or (diag-some? (load errf)) (icmp-ge (load i) nf)) (break)
      (do (match (zeroed-content (load (field (al-elem [Field] flds (load i)) ty)) cx)
            (Err [d] (do (store! errf (Some d)) 0))
            (Ok  [c] (do (al-push! (mut out) (new-cell c)) 0)))
          (store! i (iadd (load i) 1)))))
    (match (load errf)
      (Some [d] (Err [(ptr (ArrayList (ptr CtVal))) Diag] d))
      (None []  (Ok [(ptr (ArrayList (ptr CtVal))) Diag] (box-al [(ptr CtVal)] a (load out)))))))
(defn zeroed-array-cells [(el Type) (k i64) (cx (ptr CtCtx))] (-> (Result (ptr (ArrayList (ptr CtVal))) Diag))
  (let [a (load (field cx a)) (mut out) (al-new [(ptr CtVal)] a) (mut i) 0 (mut errf) (None [Diag])]
    (loop (if (or (diag-some? (load errf)) (icmp-ge (load i) k)) (break)
      (do (match (zeroed-content el cx)
            (Err [d] (do (store! errf (Some d)) 0))
            (Ok  [c] (do (al-push! (mut out) (new-cell c)) 0)))
          (store! i (iadd (load i) 1)))))
    (match (load errf)
      (Some [d] (Err [(ptr (ArrayList (ptr CtVal))) Diag] d))
      (None []  (Ok [(ptr (ArrayList (ptr CtVal))) Diag] (box-al [(ptr CtVal)] a (load out)))))))

; zeroed_content (src/comptime.rs::zeroed_content): the zero CONTENT of a type.
; NOTE(deviation): the unsupported-type error elides Rust's `{ty:?}` Debug form
; (reproducing derive(Debug) for Type is out of scope); this path is unreachable
; in the clean-expanding corpus.
(defn zeroed-content [(ty Type) (cx (ptr CtCtx))] (-> (Result CtVal Diag))
  (let [a (load (field cx a))]
    (match ty
      (TInt   [bits signed] (Ok [CtVal Diag] (CInt 0)))
      (TBool  []            (Ok [CtVal Diag] (CBool false)))
      (TFloat [bits]        (Ok [CtVal Diag] (CFloat 0.0)))
      (TSlice [el] (if (is-u8 (load el)) (Ok [CtVal Diag] (CStr "")) (Err [CtVal Diag] (derr "comptime: `zeroed` of this type isn't supported yet"))))
      (TStruct [n]
        (let [sd (ct-struct-find cx n)]
          (if (icmp-eq (cast i64 sd) 0)
              (Err [CtVal Diag] (derr (sconcat3 a "comptime: unknown struct '" n "'")))
              (match (zeroed-struct-cells (load (field sd fields)) cx)
                (Err [d]    (Err [CtVal Diag] d))
                (Ok [cells] (Ok [CtVal Diag] (CStruct n cells)))))))
      (TArray [el k]
        (match (zeroed-array-cells (load el) k cx)
          (Err [d]    (Err [CtVal Diag] d))
          (Ok [cells] (Ok [CtVal Diag] (CArray (load el) cells)))))
      (TVoid  []      (Err [CtVal Diag] (derr "comptime: `zeroed` of this type isn't supported yet")))
      (TPtr   [i]     (Err [CtVal Diag] (derr "comptime: `zeroed` of this type isn't supported yet")))
      (TRef   [m i]   (Err [CtVal Diag] (derr "comptime: `zeroed` of this type isn't supported yet")))
      (TVec   [e k]   (Err [CtVal Diag] (derr "comptime: `zeroed` of this type isn't supported yet")))
      (TFn    [c p r] (Err [CtVal Diag] (derr "comptime: `zeroed` of this type isn't supported yet")))
      (TApp   [nm ar] (Err [CtVal Diag] (derr "comptime: `zeroed` of this type isn't supported yet")))
      (TNever []      (Err [CtVal Diag] (derr "comptime: `zeroed` of this type isn't supported yet")))
      (TCode  []      (Err [CtVal Diag] (derr "comptime: `zeroed` of this type isn't supported yet"))))))

; zeroed_value (src/comptime.rs::zeroed_value): aggregates become a fresh Ref.
(defn zeroed-value [(ty Type) (cx (ptr CtCtx))] (-> (Result CtVal Diag))
  (match (zeroed-content ty cx)
    (Err [d] (Err [CtVal Diag] d))
    (Ok [c]  (Ok [CtVal Diag] (if (is-aggregate-v c) (CRef (new-cell c)) c)))))

; cells-of-vals: argv.into_iter().map(|v| new_cell(to_content(v))) (variant build).
(defn vals->cells [(vals (ptr (ArrayList CtVal))) (a (ptr Allocator))] (-> (ptr (ArrayList (ptr CtVal))))
  (let [n (al-len [CtVal] (load vals)) (mut out) (al-new [(ptr CtVal)] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut out) (new-cell (to-content-v (al-get [CtVal] (load vals) (load i)))))
          (store! i (iadd (load i) 1)))))
    (box-al [(ptr CtVal)] a (load out))))

; arm find by variant (src/comptime.rs Match arm: arms.find(|a| a.variant==v)).
(defn match-arm-find [(arms (ptr (ArrayList Arm))) (variant (slice u8))] (-> (ptr Arm))
  (let [n (al-len [Arm] (load arms)) (mut i) 0 (mut r) (cast (ptr Arm) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [Arm] arms (load i)) variant)) variant)
              (do (store! r (al-elem [Arm] arms (load i))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))

; ---- argument evaluation (Rust val!-in-a-loop). Returns AOK with the evaluated
;      CtVals, OR AFlow if any argument propagated a break/continue (Rust's
;      `val!` does `return Ok(ctrl)` from eval). Error-flag loop (no try!-in-loop).
(defsum ArgsOut
  (AOK   [(vals (ptr (ArrayList CtVal)))])
  (AFlow [(f Flow)]))
(defn eval-args [(args (ptr (ArrayList Expr))) (env (ptr (ArrayList EnvBind))) (cx (ptr CtCtx))] (-> (Result ArgsOut Diag))
  (let [a (load (field cx a)) n (al-len [Expr] (load args)) (mut i) 0
        (mut out) (al-new [CtVal] a) (mut errf) (None [Diag]) (mut flowf) (None [Flow]) (mut stop) false]
    (loop (if (or (load stop) (icmp-ge (load i) n)) (break)
      (do (match (eval (al-elem [Expr] args (load i)) env cx)
            (Err [d] (do (store! errf (Some d)) (store! stop true) 0))
            (Ok [fl] (match fl
                       (FVal [v]     (do (al-push! (mut out) v) 0))
                       (FBrk [vv ll] (do (store! flowf (Some fl)) (store! stop true) 0))
                       (FCont [ll]   (do (store! flowf (Some fl)) (store! stop true) 0)))))
          (store! i (iadd (load i) 1)))))
    (match (load errf)
      (Some [d] (Err [ArgsOut Diag] d))
      (None []
        (match (load flowf)
          (Some [fl] (Ok [ArgsOut Diag] (AFlow fl)))
          (None []   (Ok [ArgsOut Diag] (AOK (box-al [CtVal] a (load out))))))))))

; place_ref (src/comptime.rs::place_ref): an expr denoting a PLACE -> a Ref cell.
(defn place-ref [(e (ptr Expr)) (env (ptr (ArrayList EnvBind))) (cx (ptr CtCtx))] (-> (Result CtVal Diag))
  (try
    (match-else (load (field e kind))
      (EField [p fname]
        (let [base (match (try! (eval p env cx))
                     (FVal  [v] v)
                     (FBrk  [vv ll] (return-from :try (Err [CtVal Diag] (derr "comptime: control flow in a place"))))
                     (FCont [ll]    (return-from :try (Err [CtVal Diag] (derr "comptime: control flow in a place")))))]
          (if (icmp-ne (ct-tag base) 8)
              (Err [CtVal Diag] (derr "comptime: `field` base isn't a place"))
              (let [cell (cref-cell base)]
                (if (icmp-ne (ct-tag (load cell)) 5)
                    (Err [CtVal Diag] (derr "comptime: `field` of a non-struct"))
                    (let [sname (cstruct-name (load cell)) fields (cstruct-fields (load cell))
                          idx (try! (ct-field-index sname fname cx))]
                      (Ok [CtVal Diag] (CRef (al-get [(ptr CtVal)] (load fields) idx)))))))))
      (EIndex [p idx]
        (let [base (match (try! (eval p env cx))
                     (FVal  [v] v)
                     (FBrk  [vv ll] (return-from :try (Err [CtVal Diag] (derr "comptime: control flow in a place"))))
                     (FCont [ll]    (return-from :try (Err [CtVal Diag] (derr "comptime: control flow in a place")))))
              i (match (try! (eval idx env cx))
                  (FVal  [v] (if (icmp-eq (ct-tag v) 0) (cint-of v) (return-from :try (Err [CtVal Diag] (derr "comptime: array index must be an integer")))))
                  (FBrk  [vv ll] (return-from :try (Err [CtVal Diag] (derr "comptime: array index must be an integer"))))
                  (FCont [ll]    (return-from :try (Err [CtVal Diag] (derr "comptime: array index must be an integer")))))]
          (if (icmp-ne (ct-tag base) 8)
              (Err [CtVal Diag] (derr "comptime: `index` base isn't a place"))
              (let [cell (cref-cell base)]
                (if (icmp-ne (ct-tag (load cell)) 6)
                    (Err [CtVal Diag] (derr "comptime: `index` of a non-array"))
                    (let [cells (carray-cells (load cell)) ncells (al-len [(ptr CtVal)] (load cells))]
                      (if (or (icmp-lt i 0) (icmp-ge i ncells))
                          (Err [CtVal Diag] (derr (sconcat3 (load (field cx a)) "comptime: array index " (dec->str (load (field cx a)) i) " out of bounds")))
                          (Ok [CtVal Diag] (CRef (al-get [(ptr CtVal)] (load cells) i))))))))))
      (_ (match (try! (eval e env cx))
           (FVal  [v] (Ok [CtVal Diag] (if (icmp-eq (ct-tag v) 8) v (CRef (new-cell v)))))
           (FBrk  [vv ll] (Err [CtVal Diag] (derr "comptime: control flow where a place was expected")))
           (FCont [ll]    (Err [CtVal Diag] (derr "comptime: control flow where a place was expected"))))))))

; one pass of a comptime loop body (src/comptime.rs Loop inner `for`). Returns:
;   LSAgain = fell off the end / continue-this-loop  -> iterate again
;   LSDone v = break-this-loop with value            -> Flow::Val v
;   LSProp f = a continue/break for an OUTER label    -> propagate Flow f
; Error-flag loop (no try!/return-from inside) to dodge the loop+PHI bug.
(defsum LoopStep
  (LSAgain [])
  (LSDone  [(v CtVal)])
  (LSProp  [(f Flow)]))
(defn loop-body-once [(body (ptr (ArrayList Expr))) (label (Option (slice u8))) (env (ptr (ArrayList EnvBind))) (cx (ptr CtCtx))] (-> (Result LoopStep Diag))
  (let [n (al-len [Expr] (load body)) (mut i) 0 (mut step) (LSAgain) (mut errf) (None [Diag]) (mut stop) false]
    (loop (if (or (load stop) (icmp-ge (load i) n)) (break)
      (do (match (eval (al-elem [Expr] body (load i)) env cx)
            (Err [d] (do (store! errf (Some d)) (store! stop true) 0))
            (Ok [fl] (match fl
                       (FVal  [v] 0)
                       (FCont [l] (if (lbl-match l label)
                                      (do (store! stop true) 0)
                                      (do (store! step (LSProp (FCont l))) (store! stop true) 0)))
                       (FBrk  [v l] (if (lbl-match l label)
                                        (do (store! step (LSDone (opt-ctval-or v))) (store! stop true) 0)
                                        (do (store! step (LSProp (FBrk v l))) (store! stop true) 0))))))
          (store! i (iadd (load i) 1)))))
    (match (load errf)
      (Some [d] (Err [LoopStep Diag] d))
      (None []  (Ok [LoopStep Diag] (load step))))))

; eval (src/comptime.rs::eval). SCALAR arms are ported; memory/loop/quote/code-op/
; reflection/call arms hard-error via `eval-todo` until later fill chunks land, so a
; partial port can never silently pass the gate.
(defn eval [(e (ptr Expr)) (env (ptr (ArrayList EnvBind))) (cx (ptr CtCtx))] (-> (Result Flow Diag))
  (try
    (let [f (load (field cx fuel))]
      (if (icmp-eq f 0)
          (return-from :try (Err [Flow Diag] (derr "comptime: evaluation budget exhausted (infinite loop/recursion?)")))
          0)
      (store! (field cx fuel) (isub f 1))
      (match (load (field e kind))
        (EInt   [n] (Ok (FVal (CInt n))))
        (EBool  [b] (Ok (FVal (CBool b))))
        (EFloat [bits] (Ok (FVal (CFloat (bits->f64 bits)))))
        (EStr   [s] (Ok (FVal (CStr s))))
        (EComptime [inner] (eval inner env cx))
        (EVar [name]
          (match (env-find env name)
            (Some [v] (Ok (FVal v)))
            (None []  (Err [Flow Diag] (derr (sconcat3 (load (field cx a)) "comptime: unbound variable '" name "'"))))))
        (ENot [inner]
          (let [v (vget! (eval inner env cx))]
            (if (icmp-eq (ct-tag v) 0)
                (Ok (FVal (CInt (ixor (cint-of v) -1))))
                (Err [Flow Diag] (derr "comptime: `inot` needs an integer")))))
        (EBin [op lhs rhs]
          (let [x (vget! (eval lhs env cx)) y (vget! (eval rhs env cx))]
            (Ok (FVal (try! (ct-bin op x y))))))
        (ECmp [op lhs rhs]
          (let [x (vget! (eval lhs env cx)) y (vget! (eval rhs env cx))]
            (Ok (FVal (try! (ct-cmp op x y))))))
        (EIf [cnd thn els]
          (let [c (vget! (eval cnd env cx))]
            (if (try! (truthy c)) (eval thn env cx) (eval els env cx))))
        (EDo [body] (eval-seq body env cx))
        (ELet [binds body]
          (let [(mut scope) (env-clone (load (field cx a)) env) nb (al-len [Bind] (load binds)) (mut i) 0]
            (loop (if (icmp-ge (load i) nb) (break)
              (do (let [bp (al-elem [Bind] binds (load i))
                        v  (vget! (eval (field bp value) (load scope) cx))
                        bound (if (load (field bp mutable)) (wrap-mut v) v)]
                    (store! scope (env-with (load (field cx a)) (load scope) (load (field bp name)) bound)))
                  (store! i (iadd (load i) 1)))))
            (eval-seq body (load scope) cx)))
        (ECast [ty inner]
          (let [v (vget! (eval inner env cx))]
            (Ok (FVal (ct-cast v ty)))))
        ; ---- memory arms (src/comptime.rs) ----
        (EZeroed [ty] (Ok (FVal (try! (zeroed-value ty cx)))))
        (EAlloc [storage ty] (Ok (FVal (CRef (new-cell (try! (zeroed-content ty cx)))))))
        (EBorrow [mutable place] (Ok (FVal (try! (place-ref place env cx)))))
        (ESpillRef [inner]
          (let [v (vget! (eval inner env cx))]
            (Ok (FVal (if (icmp-eq (ct-tag v) 8) v (CRef (new-cell v)))))))
        (ELoad [inner]
          (let [r (vget! (eval inner env cx))]
            (Ok (FVal (if (icmp-eq (ct-tag r) 8) (cell-value (cref-cell r)) r)))))
        (EStore [p val]
          (let [r (vget! (eval p env cx)) v (vget! (eval val env cx))]
            (if (icmp-ne (ct-tag r) 8)
                (Err [Flow Diag] (derr "comptime: `store!` target isn't a place"))
                (do (store! (cref-cell r) (to-content-v v)) (Ok (FVal v))))))
        (EField [p fname] (Ok (FVal (try! (place-ref e env cx)))))
        (EIndex [p idx]   (Ok (FVal (try! (place-ref e env cx)))))
        ; ---- construct / match / call ----
        (EConstruct [sum variant args]
          (match (try! (eval-args args env cx))
            (AFlow [fl] (Ok [Flow Diag] fl))
            (AOK [vals] (Ok (FVal (CRef (new-cell (CSum variant (vals->cells vals (load (field cx a))))))))) ))
        (EMatch [scrut arms]
          (let [s (vget! (eval scrut env cx))]
            (if (icmp-ne (ct-tag s) 8)
                (Err [Flow Diag] (derr "comptime: `match` scrutinee must be a sum value"))
                (let [cell (cref-cell s)]
                  (if (icmp-ne (ct-tag (load cell)) 7)
                      (Err [Flow Diag] (derr "comptime: `match` scrutinee must be a sum value"))
                      (let [al (load (field cx a))
                            variant (csum-variant (load cell)) fields (csum-fields (load cell))
                            arm (match-arm-find arms variant)]
                        (if (icmp-eq (cast i64 arm) 0)
                            (Err [Flow Diag] (derr (sconcat3 al "comptime: no match arm for variant '" variant "'")))
                            (let [(mut scope) (env-clone al env)
                                  binds (load (field arm binds))
                                  nb (al-len [(slice u8)] (load binds)) nf (al-len [(ptr CtVal)] (load fields))
                                  nn (if (icmp-lt nb nf) nb nf) (mut k) 0]
                              (loop (if (icmp-ge (load k) nn) (break)
                                (do (store! scope (env-with al (load scope)
                                                    (al-get [(slice u8)] (load binds) (load k))
                                                    (cell-value (al-get [(ptr CtVal)] (load fields) (load k)))))
                                    (store! k (iadd (load k) 1)))))
                              (eval (field arm body) (load scope) cx)))))))) )
        (ECall [func type_args args]
          (let [al (load (field cx a))]
            (match (try! (eval-args args env cx))
              (AFlow [fl] (Ok [Flow Diag] fl))
              (AOK [vals]
                (if (ct-variant? cx func)
                    (Ok (FVal (CRef (new-cell (CSum func (vals->cells vals al))))))
                    (if (icmp-gt (al-len [Type] (load type_args)) 0)
                        (Err [Flow Diag] (derr (sconcat3 al "comptime: generic call to '" func "' isn't supported yet")))
                        (let [callee (ct-fn-find cx func)]
                          (if (icmp-eq (cast i64 callee) 0)
                              (Err [Flow Diag] (derr (sconcat3 al "comptime: call to '" func "' (not a comptime-evaluable function — extern/FFI?)")))
                              (let [pparams (load (field callee params))
                                    np (al-len [Param] (load pparams)) na (al-len [CtVal] (load vals))]
                                (if (icmp-ne np na)
                                    (Err [Flow Diag] (derr (sconcat3 al "comptime: '" func "' arity mismatch")))
                                    (let [(mut scope) (al-new [EnvBind] al) (mut j) 0]
                                      (loop (if (icmp-ge (load j) np) (break)
                                        (do (let [pp (al-elem [Param] pparams (load j)) eb (alloc-stack EnvBind)]
                                              (store! (field eb name) (load (field pp name)))
                                              (store! (field eb val) (al-get [CtVal] (load vals) (load j)))
                                              (al-push! (mut scope) (load eb)))
                                            (store! j (iadd (load j) 1)))))
                                      (let [d (iadd (load (field cx depth)) 1)]
                                        (if (icmp-gt d 2000)
                                            (Err [Flow Diag] (derr (sconcat3 al "comptime: call stack too deep (> 2000) calling '" func "' — runaway recursion?")))
                                            (do (store! (field cx depth) d)
                                                (let [r (eval-seq (load (field callee body)) (box-al [EnvBind] al (load scope)) cx)]
                                                  (store! (field cx depth) (isub d 1))
                                                  r)))))))))))))) )
        ; ---- loop / break / continue (Flow sum) ----
        (ELoop [label body]
          (loop
            (let [r (loop-body-once body label env cx)]
              (match r
                (Err [d] (return-from :try (Err [Flow Diag] d)))
                (Ok [step]
                  (match step
                    (LSAgain []
                      (let [f (load (field cx fuel))]
                        (if (icmp-eq f 0)
                            (return-from :try (Err [Flow Diag] (derr "comptime: loop budget exhausted")))
                            (do (store! (field cx fuel) (isub f 1)) 0))))
                    (LSDone [v] (return-from :try (Ok [Flow Diag] (FVal v))))
                    (LSProp [fl] (return-from :try (Ok [Flow Diag] fl)))))))))
        (EBreak [label value]
          (match value
            (Some [ve] (let [v (vget! (eval ve env cx))] (Ok (FBrk (Some v) label))))
            (None []   (Ok (FBrk (None [CtVal]) label)))))
        (EContinue [label] (Ok (FCont label)))
        ; ---- still un-ported arms (quote / code-op / reflection / dyn) ----
        (ECStr  [s] (eval-todo "comptime/eval/ECStr"))
        (ESizeOf [ty] (eval-todo "comptime/eval/ESizeOf"))
        (EAlignOf [ty] (eval-todo "comptime/eval/EAlignOf"))
        (EOffsetOf [ty fname] (eval-todo "comptime/eval/EOffsetOf"))
        (EBitGet [p fname] (eval-todo "comptime/eval/EBitGet"))
        (EBitSet [p fname val] (eval-todo "comptime/eval/EBitSet"))
        (EFree [inner] (eval-todo "comptime/eval/EFree"))
        (EErase [trait_name inner] (eval-todo "comptime/eval/EErase"))
        (EFnPtrOf [name] (eval-todo "comptime/eval/EFnPtrOf"))
        (ECallPtr [fp args] (eval-todo "comptime/eval/ECallPtr"))
        (ELlvmIr [result args body] (eval-todo "comptime/eval/ELlvmIr"))
        (ETypeQuery [q ty]
          (match (type-query q ty cx)
            (Err [d] (Err [Flow Diag] d))
            (Ok [v] (Ok [Flow Diag] (FVal v)))))
        (EFieldMeta [meta ty idx]
          (let [iv (vget! (eval idx env cx))]
            (if (icmp-ne (ct-tag iv) 0) (Err [Flow Diag] (derr "comptime: field index must be an integer"))
              (match (field-meta meta ty (cint-of iv) cx)
                (Err [d] (Err [Flow Diag] d))
                (Ok [v] (Ok [Flow Diag] (FVal v)))))))
        (EFieldIndex [ty name]
          (let [nv (vget! (eval name env cx))]
            (if (icmp-ne (ct-tag nv) 3) (Err [Flow Diag] (derr "comptime: field-index name must be a string"))
              (match (find-field-index ty (cstr-of nv) cx)
                (Err [d] (Err [Flow Diag] d))
                (Ok [v] (Ok [Flow Diag] (FVal v)))))))
        (EQuote [form] (Ok (FVal (CCode (load form)))))
        (ECodeOp [op args]
          (match (try! (eval-args args env cx))
            (AFlow [fl] (Ok [Flow Diag] fl))
            (AOK [vals]
              (match (code-op op vals cx)
                (Err [d] (Err [Flow Diag] d))
                (Ok [v] (Ok [Flow Diag] (FVal v)))))))
        (EQuasi [q]
          (let [qp (alloc-stack Quasi)] (store! qp q)
            (match (eval-quasi qp env cx)
              (Err [d] (Err [Flow Diag] d))
              (Ok [s] (Ok [Flow Diag] (FVal (CCode s)))))))
        (ETraitCall [trait_name method self_tp args] (eval-todo "comptime/eval/ETraitCall"))
        (EDynDispatch [dyn_struct vtable_struct method_index cc params ret recv args] (eval-todo "comptime/eval/EDynDispatch"))
        (EMakeDyn [dyn_struct vtable_struct methods inner] (eval-todo "comptime/eval/EMakeDyn"))
        (EStaticRef [name] (eval-todo "comptime/eval/EStaticRef"))))))

; eval_seq (src/comptime.rs::eval_seq): evaluate a sequence, returning the LAST
; expr's Flow; a break/continue in any non-last element short-circuits via vget!.
(defn eval-seq [(es (ptr (ArrayList Expr))) (env (ptr (ArrayList EnvBind))) (cx (ptr CtCtx))] (-> (Result Flow Diag))
  (try
    (let [n (al-len [Expr] (load es))]
      (if (icmp-eq n 0) (Ok [Flow Diag] (FVal (CInt 0)))
        (let [(mut i) 0]
          (loop (if (icmp-ge (load i) (isub n 1)) (break)
            (do (let [discard (vget! (eval (al-elem [Expr] es (load i)) env cx))] 0)
                (store! i (iadd (load i) 1)))))
          (eval (al-elem [Expr] es (isub n 1)) env cx))))))

; ============================ comptime: reflection + code-ops ================
; Ported from src/comptime.rs: type_query / field_meta / find_field_index /
; type_kind_tag / type_name_str / type_to_code / sexp_eq / ctval_to_sexp / code_op
; / eval_quasi / qualify_head / resolve_in_module, plus the global gensym counter.

; A process-global gensym counter (mirrors src/comptime.rs's `static GENSYM`). One
; textual `(alloc-static GsCell)` = one zero-initialized global, returned by every
; call — so the counter is shared across all expansions in a compile.
(defstruct GsCell [(n i64)])
(defn gensym-cell [] (-> (ptr GsCell)) (alloc-static GsCell))
(defn next-gensym [] (-> i64)
  (let [c (gensym-cell) v (load (field c n))]
    (store! (field c n) (iadd v 1))
    v))

; target-arch: Coil AOT-targets the host, so this is the compile-host arch
; (src/comptime.rs uses std::env::consts::ARCH). Pinned to the build host.
(defn target-arch-str [] (-> (slice u8)) "aarch64")

; sum/trait table lookups (last-match, HashMap .get semantics; null = not found).
(defn ct-sum-find [(cx (ptr CtCtx)) (name (slice u8))] (-> (ptr SumDef))
  (let [lst (load (field cx sums)) n (al-len [SumDef] (load lst)) (mut i) 0 (mut r) (cast (ptr SumDef) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [SumDef] lst (load i)) name)) name)
              (do (store! r (al-elem [SumDef] lst (load i))) 0) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn ct-trait-find [(cx (ptr CtCtx)) (name (slice u8))] (-> (ptr TraitDef))
  (let [lst (load (field cx traits)) n (al-len [TraitDef] (load lst)) (mut i) 0 (mut r) (cast (ptr TraitDef) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [TraitDef] lst (load i)) name)) name)
              (do (store! r (al-elem [TraitDef] lst (load i))) 0) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))

; CtVal scalar accessors used by the reflection / code ops.
(defn cstr-of  [(v CtVal)] (-> (slice u8)) (match-else v (CStr [s] s) (_ "")))
(defn is-cstr [(v CtVal)] (-> bool) (match-else v (CStr [s] true) (_ false)))
(defn is-ccode [(v CtVal)] (-> bool) (match-else v (CCode [c] true) (_ false)))
(defn ccode-of [(v CtVal)] (-> Sexp) (match-else v (CCode [c] c) (_ (zeroed Sexp))))

; ---- Sexp constructors (DUMMY span = -1/-1) -------------------------------
(defn sx-sym  [(s (slice u8))] (-> Sexp) (mk-sexp (KSym s) -1 -1))
(defn sx-mkstr [(s (slice u8))] (-> Sexp) (mk-sexp (KStr s) -1 -1))
(defn sx-mkint [(n i64)]        (-> Sexp) (mk-sexp (KInt n) -1 -1))
(defn sx-mklist [(items (ptr (ArrayList Sexp)))] (-> Sexp) (mk-sexp (KList items) -1 -1))

; "i{b}"/"u{b}"/"f{b}" name fragments.
(defn intw-name [(a (ptr Allocator)) (pre (slice u8)) (b i64)] (-> (slice u8))
  (sconcat a pre (dec->str a b)))

; ---- type_kind_tag (src/comptime.rs::type_kind_tag) -----------------------
(defn type-kind-tag [(t Type) (cx (ptr CtCtx))] (-> i64)
  (match-else t
    (TInt   [b s] 0)
    (TFloat [b]   1)
    (TBool  []    2)
    (TStruct [n] (if (icmp-ne (cast i64 (ct-struct-find cx n)) 0) 3
                   (if (icmp-ne (cast i64 (ct-sum-find cx n)) 0) 4 8)))
    (TApp   [n a] (if (icmp-ne (cast i64 (ct-struct-find cx n)) 0) 3
                   (if (icmp-ne (cast i64 (ct-sum-find cx n)) 0) 4 8)))
    (TPtr   [i]   5)
    (TRef   [m i] 5)
    (TArray [e k] 6)
    (TSlice [e]   7)
    (_ 8)))

; ---- type_name_str (src/comptime.rs::type_name_str). The exotic Debug-form
;      cases (Void/Vec/Fn/Never/Code) are unreachable in the clean corpus; a
;      faithful {ty:?} Debug rendering is out of scope, so they hard-error.
(defn type-name-str [(a (ptr Allocator)) (t (ptr Type))] (-> (slice u8))
  (match-else (load t)
    (TInt   [b s] (if s (intw-name a "i" b) (intw-name a "u" b)))
    (TFloat [b]   (intw-name a "f" b))
    (TBool  []    "bool")
    (TStruct [n]  (after-last-dot n))
    (TApp   [n ar] (after-last-dot n))
    (TPtr   [i]   "ptr")
    (TRef   [m i] "ptr")
    (TArray [e k] "array")
    (TSlice [e]   "slice")
    (_ (do (unimplemented "comptime/type_name_str: Debug form of exotic type") ""))))

; ---- type_to_code (src/comptime.rs::type_to_code). Renders a Type back to
;      surface syntax as a Code value (DUMMY spans). Recurse over (ptr Type).
(defn type->code [(t (ptr Type))] (-> Sexp)
  (let [a (malloc-allocator)]
    (match (load t)
      (TInt   [b s] (sx-sym (if s (intw-name a "i" b) (intw-name a "u" b))))
      (TFloat [b]   (sx-sym (intw-name a "f" b)))
      (TBool  []    (sx-sym "bool"))
      (TVoid  []    (sx-sym "void"))
      (TCode  []    (sx-sym "Code"))
      (TNever []    (sx-sym "Never"))
      (TStruct [n]  (sx-sym n))
      (TPtr   [i]   (let [(mut xs) (al-new [Sexp] a)] (al-push! (mut xs) (sx-sym "ptr")) (al-push! (mut xs) (type->code i)) (sx-mklist (box-al [Sexp] a (load xs)))))
      (TRef   [m i] (let [(mut xs) (al-new [Sexp] a)] (al-push! (mut xs) (sx-sym (if m "mut" "ref"))) (al-push! (mut xs) (type->code i)) (sx-mklist (box-al [Sexp] a (load xs)))))
      (TSlice [i]   (let [(mut xs) (al-new [Sexp] a)] (al-push! (mut xs) (sx-sym "slice")) (al-push! (mut xs) (type->code i)) (sx-mklist (box-al [Sexp] a (load xs)))))
      (TArray [i n] (let [(mut xs) (al-new [Sexp] a)] (al-push! (mut xs) (sx-sym "array")) (al-push! (mut xs) (type->code i)) (al-push! (mut xs) (sx-mkint n)) (sx-mklist (box-al [Sexp] a (load xs)))))
      (TVec   [i n] (let [(mut xs) (al-new [Sexp] a)] (al-push! (mut xs) (sx-sym "vec")) (al-push! (mut xs) (type->code i)) (al-push! (mut xs) (sx-mkint n)) (sx-mklist (box-al [Sexp] a (load xs)))))
      (TFn    [cc p r]
        (let [(mut pv) (al-new [Sexp] a) np (al-len [Type] (load p)) (mut j) 0]
          (loop (if (icmp-ge (load j) np) (break)
            (do (al-push! (mut pv) (type->code (al-elem [Type] p (load j)))) (store! j (iadd (load j) 1)))))
          (let [(mut xs) (al-new [Sexp] a)]
            (al-push! (mut xs) (sx-sym "fnptr")) (al-push! (mut xs) (sx-sym cc))
            (al-push! (mut xs) (mk-sexp (KVec (box-al [Sexp] a (load pv))) -1 -1))
            (al-push! (mut xs) (type->code r))
            (sx-mklist (box-al [Sexp] a (load xs))))))
      (TApp   [n ar]
        (let [(mut xs) (al-new [Sexp] a) na (al-len [Type] (load ar)) (mut j) 0]
          (al-push! (mut xs) (sx-sym n))
          (loop (if (icmp-ge (load j) na) (break)
            (do (al-push! (mut xs) (type->code (al-elem [Type] ar (load j)))) (store! j (iadd (load j) 1)))))
          (sx-mklist (box-al [Sexp] a (load xs))))))))

; ---- type_query (src/comptime.rs::type_query). Error msgs elide the Rust
;      {ty:?} Debug (unreachable in clean corpus; same deviation as zeroed).
(defn ty-is-named [(t Type)] (-> bool) (match-else t (TStruct [n] true) (TApp [n a] true) (_ false)))
(defn ty-name-opt [(t Type)] (-> (slice u8)) (match-else t (TStruct [n] n) (TApp [n a] n) (_ "")))
(defn type-query [(q i64) (ty Type) (cx (ptr CtCtx))] (-> (Result CtVal Diag))
  (let [named (ty-is-named ty) nm (ty-name-opt ty)]
    (if (icmp-eq q 0)
        (let [sd (if named (ct-struct-find cx nm) (cast (ptr StructDef) 0))]
          (if (icmp-eq (cast i64 sd) 0) (Err [CtVal Diag] (derr "field-count: type is not a struct"))
              (Ok [CtVal Diag] (CInt (al-len [Field] (load (field sd fields)))))))
    (if (icmp-eq q 1)
        (let [sd (if named (ct-sum-find cx nm) (cast (ptr SumDef) 0))]
          (if (icmp-eq (cast i64 sd) 0) (Err [CtVal Diag] (derr "variant-count: type is not a sum"))
              (Ok [CtVal Diag] (CInt (al-len [Variant] (load (field sd variants)))))))
    (if (icmp-eq q 2) (Ok [CtVal Diag] (CBool (and named (icmp-ne (cast i64 (ct-struct-find cx nm)) 0))))
    (if (icmp-eq q 3) (Ok [CtVal Diag] (CBool (and named (icmp-ne (cast i64 (ct-sum-find cx nm)) 0))))
    (if (icmp-eq q 4) (Ok [CtVal Diag] (CBool (match-else ty (TInt [b s] true) (_ false))))
    (if (icmp-eq q 5) (Ok [CtVal Diag] (CBool (match-else ty (TFloat [b] true) (_ false))))
    (if (icmp-eq q 6) (Ok [CtVal Diag] (CBool (match-else ty (TPtr [i] true) (TRef [m i] true) (_ false))))
        (Ok [CtVal Diag] (CBool (match-else ty (TArray [e k] true) (_ false)))))))))))))

; ---- field_meta (src/comptime.rs::field_meta) -----------------------------
(defn field-meta [(meta i64) (ty Type) (i i64) (cx (ptr CtCtx))] (-> (Result CtVal Diag))
  (let [a (load (field cx a))]
    (if (not (ty-is-named ty)) (Err [CtVal Diag] (derr "field reflection: type is not a struct"))
      (let [sd (ct-struct-find cx (ty-name-opt ty))]
        (if (icmp-eq (cast i64 sd) 0) (Err [CtVal Diag] (derr "field reflection: not a struct"))
          (let [flds (load (field sd fields)) nf (al-len [Field] (load flds))]
            (if (or (icmp-lt i 0) (icmp-ge i nf)) (Err [CtVal Diag] (derr "field reflection: index out of range"))
              (let [fp (al-elem [Field] flds i) fname (load (field fp name)) ftyp (field fp ty)]
                (if (icmp-eq meta 0) (Ok [CtVal Diag] (CStr fname))
                (if (icmp-eq meta 1) (Ok [CtVal Diag] (CInt (type-kind-tag (load ftyp) cx)))
                    (Ok [CtVal Diag] (CStr (type-name-str a ftyp)))))))))))))

; ---- find_field_index (src/comptime.rs::find_field_index) ------------------
(defn find-field-index [(ty Type) (want (slice u8)) (cx (ptr CtCtx))] (-> (Result CtVal Diag))
  (let [a (load (field cx a))]
    (if (not (ty-is-named ty)) (Err [CtVal Diag] (derr "field-index: type is not a struct"))
      (let [sd (ct-struct-find cx (ty-name-opt ty))]
        (if (icmp-eq (cast i64 sd) 0) (Err [CtVal Diag] (derr "field-index: not a struct"))
          (let [flds (load (field sd fields)) nf (al-len [Field] (load flds)) (mut i) 0 (mut r) -1]
            (loop (if (icmp-ge (load i) nf) (break)
              (do (if (str-eq (load (field (al-elem [Field] flds (load i)) name)) want)
                      (do (store! r (load i)) (break)) 0)
                  (store! i (iadd (load i) 1)))))
            (if (icmp-lt (load r) 0)
                (Err [CtVal Diag] (derr (sconcat3 a "field-index: struct has no field '" want "'")))
                (Ok [CtVal Diag] (CInt (load r))))))))))

; ---- sexp_eq (src/comptime.rs::sexp_eq): structural, span-agnostic ---------
(defn sexp-list-eq [(xs (ptr (ArrayList Sexp))) (ys (ptr (ArrayList Sexp)))] (-> bool)
  (let [nx (al-len [Sexp] (load xs)) ny (al-len [Sexp] (load ys))]
    (if (icmp-ne nx ny) false
      (let [(mut i) 0 (mut ok) true]
        (loop (if (or (not (load ok)) (icmp-ge (load i) nx)) (break)
          (do (if (sexp-eq (al-get [Sexp] (load xs) (load i)) (al-get [Sexp] (load ys) (load i))) 0 (do (store! ok false) 0))
              (store! i (iadd (load i) 1)))))
        (load ok)))))
(defn sexp-eq [(x Sexp) (y Sexp)] (-> bool)
  (let [tx (sx-tag x) ty (sx-tag y)]
    (if (icmp-ne tx ty) false
      (if (or (icmp-eq tx 0) (icmp-eq tx 1)) (icmp-eq (sx-ival x) (sx-ival y))
      (if (or (icmp-eq tx 2) (or (icmp-eq tx 3) (or (icmp-eq tx 4) (icmp-eq tx 5)))) (str-eq (sx-sval x) (sx-sval y))
      (if (or (icmp-eq tx 6) (icmp-eq tx 7)) (sexp-list-eq (sx-items x) (sx-items y))
          false))))))

; ---- ctval_to_sexp (src/comptime.rs::ctval_to_sexp) -----------------------
(defn ctval->sexp [(v CtVal)] (-> (Result Sexp Diag))
  (match-else v
    (CCode  [c] (Ok [Sexp Diag] c))
    (CInt   [n] (Ok [Sexp Diag] (sx-mkint n)))
    (CFloat [x] (Ok [Sexp Diag] (mk-sexp (KFloat (f64-bits x)) -1 -1)))
    (CBool  [b] (Ok [Sexp Diag] (sx-sym (if b "true" "false"))))
    (CStr   [s] (Ok [Sexp Diag] (sx-mkstr s)))
    (_ (Err [Sexp Diag] (derr "comptime: can't unquote an aggregate value into code")))))

; flexible-by-suffix lookup result (0=ok,1=none,2=ambiguous).
(defstruct FindS [(p (ptr StructDef)) (status i64)])
(defn find-struct-flex [(cx (ptr CtCtx)) (tname (slice u8))] (-> FindS)
  (let [r (alloc-stack FindS) exact (ct-struct-find cx tname)]
    (if (icmp-ne (cast i64 exact) 0) (do (store! (field r p) exact) (store! (field r status) 0) (load r))
      (let [lst (load (field cx structs)) n (al-len [StructDef] (load lst)) (mut i) 0 (mut cnt) 0 (mut first) (cast (ptr StructDef) 0)]
        (loop (if (icmp-ge (load i) n) (break)
          (do (let [sp (al-elem [StructDef] lst (load i))]
                (if (str-eq (after-last-dot (load (field sp name))) tname)
                    (do (if (icmp-eq (load cnt) 0) (do (store! first sp) 0) 0) (store! cnt (iadd (load cnt) 1))) 0))
              (store! i (iadd (load i) 1)))))
        (if (icmp-eq (load cnt) 0) (do (store! (field r status) 1) (load r))
          (if (icmp-eq (load cnt) 1) (do (store! (field r p) (load first)) (store! (field r status) 0) (load r))
              (do (store! (field r status) 2) (load r))))))))
(defstruct FindSum [(p (ptr SumDef)) (status i64)])
(defn find-sum-flex [(cx (ptr CtCtx)) (tname (slice u8))] (-> FindSum)
  (let [r (alloc-stack FindSum) exact (ct-sum-find cx tname)]
    (if (icmp-ne (cast i64 exact) 0) (do (store! (field r p) exact) (store! (field r status) 0) (load r))
      (let [lst (load (field cx sums)) n (al-len [SumDef] (load lst)) (mut i) 0 (mut cnt) 0 (mut first) (cast (ptr SumDef) 0)]
        (loop (if (icmp-ge (load i) n) (break)
          (do (let [sp (al-elem [SumDef] lst (load i))]
                (if (str-eq (after-last-dot (load (field sp name))) tname)
                    (do (if (icmp-eq (load cnt) 0) (do (store! first sp) 0) 0) (store! cnt (iadd (load cnt) 1))) 0))
              (store! i (iadd (load i) 1)))))
        (if (icmp-eq (load cnt) 0) (do (store! (field r status) 1) (load r))
          (if (icmp-eq (load cnt) 1) (do (store! (field r p) (load first)) (store! (field r status) 0) (load r))
              (do (store! (field r status) 2) (load r))))))))
(defstruct FindTr [(p (ptr TraitDef)) (status i64)])
(defn find-trait-flex [(cx (ptr CtCtx)) (tname (slice u8))] (-> FindTr)
  (let [r (alloc-stack FindTr) exact (ct-trait-find cx tname)]
    (if (icmp-ne (cast i64 exact) 0) (do (store! (field r p) exact) (store! (field r status) 0) (load r))
      (let [lst (load (field cx traits)) n (al-len [TraitDef] (load lst)) (mut i) 0 (mut cnt) 0 (mut first) (cast (ptr TraitDef) 0)]
        (loop (if (icmp-ge (load i) n) (break)
          (do (let [sp (al-elem [TraitDef] lst (load i))]
                (if (str-eq (after-last-dot (load (field sp name))) tname)
                    (do (if (icmp-eq (load cnt) 0) (do (store! first sp) 0) 0) (store! cnt (iadd (load cnt) 1))) 0))
              (store! i (iadd (load i) 1)))))
        (if (icmp-eq (load cnt) 0) (do (store! (field r status) 1) (load r))
          (if (icmp-eq (load cnt) 1) (do (store! (field r p) (load first)) (store! (field r status) 0) (load r))
              (do (store! (field r status) 2) (load r))))))))

; the sum whose variants include `want` (bare suffix), unique. status 0/1/2.
(defstruct FindVS [(name (slice u8)) (status i64)])
(defn sum-has-variant [(sd (ptr SumDef)) (want (slice u8))] (-> bool)
  (let [vs (load (field sd variants)) n (al-len [Variant] (load vs)) (mut i) 0 (mut r) false]
    (loop (if (or (load r) (icmp-ge (load i) n)) (break)
      (do (if (str-eq (after-last-dot (load (field (al-elem [Variant] vs (load i)) name))) want) (do (store! r true) 0) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn find-variant-sum [(cx (ptr CtCtx)) (want (slice u8))] (-> FindVS)
  (let [r (alloc-stack FindVS) lst (load (field cx sums)) n (al-len [SumDef] (load lst)) (mut i) 0 (mut cnt) 0 (mut first) ""]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [sp (al-elem [SumDef] lst (load i))]
            (if (sum-has-variant sp want)
                (do (if (icmp-eq (load cnt) 0) (do (store! first (load (field sp name))) 0) 0) (store! cnt (iadd (load cnt) 1))) 0))
          (store! i (iadd (load i) 1)))))
    (if (icmp-eq (load cnt) 0) (do (store! (field r status) 1) (load r))
      (if (icmp-eq (load cnt) 1) (do (store! (field r name) (load first)) (store! (field r status) 0) (load r))
          (do (store! (field r status) 2) (load r))))))

; cv-get: args.get(i) as (Option CtVal).
(defn cv-get [(args (ptr (ArrayList CtVal))) (i i64)] (-> (Option CtVal))
  (if (or (icmp-lt i 0) (icmp-ge i (al-len [CtVal] (load args)))) (None [CtVal]) (Some (al-get [CtVal] (load args) i))))

; arg as an i64 (CInt), with default error path (caller checks Option for presence).
(defn code-symname [(args (ptr (ArrayList CtVal)))] (-> (slice u8))
  ; first arg as a Code symbol name (for code-field-*/code-variant-*/code-trait-*).
  (match (cv-get args 0) (Some [v] (if (is-ccode v) (let [c (ccode-of v)] (if (icmp-eq (sx-tag c) 2) (sx-sval c) "")) "")) (None [] "")))

; ---- code_op (src/comptime.rs::code_op) -----------------------------------
; ---- code_op (src/comptime.rs::code_op), split into per-group helpers so the
;      nesting stays legible. Each helper returns (Result CtVal Diag).

; append every byte of slice `s` to buf (avoids a loop-carried mutable SLICE,
; which miscompiles a loop+trailing function — accumulate into a u8 ArrayList).
(defn append-bytes! [(buf (mut (ArrayList u8))) (s (slice u8))] (-> i64)
  (let [n (slice-len s) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut buf) (slice-get s (load i))) (store! i (iadd (load i) 1))))))
  0)
; finish cop-concat outside the loop.
(defn cop-concat-finish [(op i64) (name (slice u8)) (errf (Option Diag))] (-> (Result CtVal Diag))
  (match errf
    (Some [d] (Err [CtVal Diag] d))
    (None [] (Ok [CtVal Diag] (if (icmp-eq op 12) (CCode (sx-sym name)) (CStr name))))))
; append ONE part to buf, or return Some err. No loop here (append-bytes! has the
; only loop) — keeps it out of concat-into!'s recursion.
(defn concat-one! [(a (ptr Allocator)) (buf (mut (ArrayList u8))) (v CtVal) (tg i64)] (-> (Option Diag))
  (if (icmp-eq tg 3) (do (append-bytes! (mut buf) (cstr-of v)) (None [Diag]))
  (if (icmp-eq tg 0) (do (append-bytes! (mut buf) (dec->str a (cint-of v))) (None [Diag]))
  (if (icmp-eq tg 4)
      (let [c (ccode-of v) ctg (sx-tag c)]
        (if (or (icmp-eq ctg 2) (icmp-eq ctg 4)) (do (append-bytes! (mut buf) (sx-sval c)) (None [Diag]))
        (if (icmp-eq ctg 0) (do (append-bytes! (mut buf) (dec->str a (sx-ival c))) (None [Diag]))
            (Some (derr "comptime: code-symbol/str part must be a symbol/string/int")))))
      (Some (derr "comptime: code-symbol/str part must be a string/int/code"))))))
; concat the parts into buf RECURSIVELY (no loop — a Coil loop calling a
; loop-bearing fn miscompiles a loop+trailing function, so recurse instead).
(defn concat-into! [(args (ptr (ArrayList CtVal))) (i i64) (n i64) (a (ptr Allocator)) (buf (mut (ArrayList u8)))] (-> (Option Diag))
  (if (icmp-ge i n) (None [Diag])
    (let [v (al-get [CtVal] (load args) i)]
      (match (concat-one! a (mut buf) v (ct-tag v))
        (Some [d] (Some d))
        (None [] (concat-into! args (iadd i 1) n a (mut buf)))))))
; symbol (12) / str (13): concatenate the parts.
(defn cop-concat [(op i64) (args (ptr (ArrayList CtVal))) (cx (ptr CtCtx))] (-> (Result CtVal Diag))
  (let [a (load (field cx a)) (mut buf) (al-new [u8] a) e (concat-into! args 0 (al-len [CtVal] (load args)) a (mut buf))]
    (cop-concat-finish op (al-slice [u8] (load buf)) e)))

; code-field-* (14-17).
(defn cop-field [(op i64) (args (ptr (ArrayList CtVal))) (cx (ptr CtCtx))] (-> (Result CtVal Diag))
  (let [a (load (field cx a)) tname (code-symname args)]
    (if (str-eq tname "") (Err [CtVal Diag] (derr "comptime: code-field-* expects a type symbol"))
      (let [fsp (alloc-stack FindS)]
        (store! fsp (find-struct-flex cx tname))
        (if (icmp-eq (load (field fsp status)) 1) (Err [CtVal Diag] (derr (sconcat3 a "comptime: '" tname "' is not a struct (field reflection needs a struct; sums unsupported)")))
        (if (icmp-eq (load (field fsp status)) 2) (Err [CtVal Diag] (derr (sconcat3 a "comptime: ambiguous type '" tname "' — multiple modules define it; field reflection can't disambiguate (qualify the type)")))
        (let [sd (load (field fsp p))]
          (if (icmp-eq op 14) (Ok [CtVal Diag] (CInt (al-len [Field] (load (field sd fields)))))
            (match (cv-get args 1)
              (None [] (Err [CtVal Diag] (derr "comptime: code-field-* index must be an integer")))
              (Some [iv]
                (if (icmp-ne (ct-tag iv) 0) (Err [CtVal Diag] (derr "comptime: code-field-* index must be an integer"))
                  (let [i (cint-of iv) flds (load (field sd fields)) nf (al-len [Field] (load flds))]
                    (if (or (icmp-lt i 0) (icmp-ge i nf)) (Err [CtVal Diag] (derr (sconcat3 a "comptime: field index " (dec->str a i) " out of range")))
                      (let [fp (al-elem [Field] flds i) fname (load (field fp name)) ftyp (field fp ty)]
                        (if (icmp-eq op 15) (Ok [CtVal Diag] (CCode (sx-sym fname)))
                        (if (icmp-eq op 16) (Ok [CtVal Diag] (CInt (type-kind-tag (load ftyp) cx)))
                            (Ok [CtVal Diag] (CCode (sx-sym (type-name-str a ftyp))))))))))))))))))))

; code-variant-* (18-21).
(defn cop-variant [(op i64) (args (ptr (ArrayList CtVal))) (cx (ptr CtCtx))] (-> (Result CtVal Diag))
  (let [a (load (field cx a)) arg (code-symname args)]
    (if (str-eq arg "") (Err [CtVal Diag] (derr "comptime: code-variant-* expects a symbol"))
      (if (icmp-eq op 18)
          (let [vsp (alloc-stack FindVS)]
            (store! vsp (find-variant-sum cx (after-last-dot arg)))
            (if (icmp-eq (load (field vsp status)) 1) (Err [CtVal Diag] (derr (sconcat3 a "comptime: '" arg "' is not a known variant")))
            (if (icmp-eq (load (field vsp status)) 2) (Err [CtVal Diag] (derr (sconcat3 a "comptime: ambiguous variant '" arg "' — declared in multiple sums; reflection can't disambiguate")))
                (Ok [CtVal Diag] (CCode (sx-sym (load (field vsp name))))))))
          (let [fsp (alloc-stack FindSum)]
            (store! fsp (find-sum-flex cx arg))
            (if (icmp-eq (load (field fsp status)) 1) (Err [CtVal Diag] (derr (sconcat3 a "comptime: '" arg "' is not a known sum")))
            (if (icmp-eq (load (field fsp status)) 2) (Err [CtVal Diag] (derr (sconcat3 a "comptime: ambiguous sum '" arg "' — multiple modules define it; reflection can't disambiguate (qualify it)")))
            (let [sd (load (field fsp p))]
              (if (icmp-eq op 19) (Ok [CtVal Diag] (CInt (al-len [Variant] (load (field sd variants)))))
                (match (cv-get args 1)
                  (None [] (Err [CtVal Diag] (derr "comptime: code-variant-* index must be an integer")))
                  (Some [iv]
                    (if (icmp-ne (ct-tag iv) 0) (Err [CtVal Diag] (derr "comptime: code-variant-* index must be an integer"))
                      (let [i (cint-of iv) vs (load (field sd variants)) nv (al-len [Variant] (load vs))]
                        (if (or (icmp-lt i 0) (icmp-ge i nv)) (Err [CtVal Diag] (derr (sconcat3 a "comptime: variant index " (dec->str a i) " out of range")))
                          (let [vp (al-elem [Variant] vs i)]
                            (if (icmp-eq op 20) (Ok [CtVal Diag] (CCode (sx-sym (after-last-dot (load (field vp name))))))
                                (Ok [CtVal Diag] (CInt (al-len [Field] (load (field vp fields)))))))))))))))))))))

; code-trait-* (22-27).
(defn cop-trait [(op i64) (args (ptr (ArrayList CtVal))) (cx (ptr CtCtx))] (-> (Result CtVal Diag))
  (let [a (load (field cx a)) tname (code-symname args)]
    (if (str-eq tname "") (Err [CtVal Diag] (derr "comptime: code-trait-* expects a trait symbol"))
      (let [ftp (alloc-stack FindTr)]
        (store! ftp (find-trait-flex cx tname))
        (if (icmp-eq (load (field ftp status)) 1) (Err [CtVal Diag] (derr (sconcat3 a "comptime: '" tname "' is not a known trait")))
        (if (icmp-eq (load (field ftp status)) 2) (Err [CtVal Diag] (derr (sconcat3 a "comptime: ambiguous trait '" tname "' — multiple modules define it; reflection can't disambiguate (qualify it)")))
        (let [td (load (field ftp p))]
          (if (icmp-eq op 22) (Ok [CtVal Diag] (CInt (al-len [TraitMethod] (load (field td methods)))))
            (match (cv-get args 1)
              (None [] (Err [CtVal Diag] (derr "comptime: code-trait-* method index must be an integer")))
              (Some [mv]
                (if (icmp-ne (ct-tag mv) 0) (Err [CtVal Diag] (derr "comptime: code-trait-* method index must be an integer"))
                  (let [mi (cint-of mv) ms (load (field td methods)) nm (al-len [TraitMethod] (load ms))]
                    (if (or (icmp-lt mi 0) (icmp-ge mi nm)) (Err [CtVal Diag] (derr (sconcat3 a "comptime: trait method index " (dec->str a mi) " out of range")))
                      (let [m (al-elem [TraitMethod] ms mi)]
                        (cop-trait-method op args m cx)))))))))))))))

; the per-method/-param tail of code-trait-* (split out to shrink nesting).
(defn cop-trait-method [(op i64) (args (ptr (ArrayList CtVal))) (m (ptr TraitMethod)) (cx (ptr CtCtx))] (-> (Result CtVal Diag))
  (let [a (load (field cx a))]
    (if (icmp-eq op 23) (Ok [CtVal Diag] (CCode (sx-sym (load (field m name)))))
    (if (icmp-eq op 24) (Ok [CtVal Diag] (CInt (al-len [Param] (load (field m params)))))
    (if (icmp-eq op 27) (Ok [CtVal Diag] (CCode (type->code (field m ret))))
      (match (cv-get args 2)
        (None [] (Err [CtVal Diag] (derr "comptime: code-trait-param-* needs a method index and a param index")))
        (Some [pv]
          (if (icmp-ne (ct-tag pv) 0) (Err [CtVal Diag] (derr "comptime: code-trait-param-* needs a method index and a param index"))
            (let [pj (cint-of pv) ps (load (field m params)) np (al-len [Param] (load ps))]
              (if (or (icmp-lt pj 0) (icmp-ge pj np)) (Err [CtVal Diag] (derr (sconcat3 a "comptime: trait param index " (dec->str a pj) " out of range")))
                (let [p (al-elem [Param] ps pj)]
                  (if (icmp-eq op 25) (Ok [CtVal Diag] (CCode (sx-sym (load (field p name)))))
                      (Ok [CtVal Diag] (CCode (type->code (field p ty))))))))))))))))

; str-bytes (28).
(defn cop-strbytes [(args (ptr (ArrayList CtVal))) (cx (ptr CtCtx))] (-> (Result CtVal Diag))
  (let [a (load (field cx a))]
    (match (cv-get args 0)
      (None [] (Err [CtVal Diag] (derr "comptime: str-bytes expects a string")))
      (Some [v]
        (let [ok (or (is-cstr v) (and (is-ccode v) (icmp-eq (sx-tag (ccode-of v)) 4)))]
          (if (not ok) (Err [CtVal Diag] (derr "comptime: str-bytes expects a string"))
            (let [s (if (is-cstr v) (cstr-of v) (sx-sval (ccode-of v))) n (slice-len s) (mut xs) (al-new [Sexp] a) (mut i) 0]
              (loop (if (icmp-ge (load i) n) (break)
                (do (al-push! (mut xs) (sx-mkint (cast i64 (slice-get s (load i))))) (store! i (iadd (load i) 1)))))
              (Ok [CtVal Diag] (CCode (sx-mklist (box-al [Sexp] a (load xs))))))))))))

; bytes->str (29).
(defn cop-bytestostr [(args (ptr (ArrayList CtVal))) (cx (ptr CtCtx))] (-> (Result CtVal Diag))
  (let [a (load (field cx a))]
    (match (cv-get args 0)
      (None [] (Err [CtVal Diag] (derr "comptime: bytes->str expects a list")))
      (Some [v]
        (let [islist (and (is-ccode v) (let [tg (sx-tag (ccode-of v))] (or (icmp-eq tg 6) (icmp-eq tg 7))))]
          (if (not islist) (Err [CtVal Diag] (derr "comptime: bytes->str expects a list"))
            (let [items (sx-items (ccode-of v)) n (sx-len items) (mut buf) (al-new [u8] a) (mut errf) (None [Diag]) (mut i) 0]
              (loop (if (or (diag-some? (load errf)) (icmp-ge (load i) n)) (break)
                (do (let [it (sx-at items (load i))]
                      (if (icmp-eq (sx-tag it) 0) (do (al-push! (mut buf) (cast u8 (sx-ival it))) 0) (do (store! errf (Some (derr "comptime: bytes->str list must be all ints"))) 0)))
                    (store! i (iadd (load i) 1)))))
              (match (load errf) (Some [d] (Err [CtVal Diag] d))
                (None [] (Ok [CtVal Diag] (CCode (sx-mkstr (al-slice [u8] (load buf))))))))))))))

; the Code-first-arg ops (0-7,10,11).
(defn cop-codearg [(op i64) (args (ptr (ArrayList CtVal))) (cx (ptr CtCtx))] (-> (Result CtVal Diag))
  (let [a (load (field cx a))]
    (match (cv-get args 0)
      (None [] (Err [CtVal Diag] (derr "comptime: code op expects a Code value")))
      (Some [v0]
        (if (not (is-ccode v0)) (Err [CtVal Diag] (derr "comptime: code op expects a Code value"))
          (let [code (ccode-of v0) tg (sx-tag code)]
            (if (icmp-eq op 0) (Ok [CtVal Diag] (CBool (or (icmp-eq tg 6) (icmp-eq tg 7))))
            (if (icmp-eq op 1) (Ok [CtVal Diag] (CBool (icmp-eq tg 2)))
            (if (icmp-eq op 2) (Ok [CtVal Diag] (CBool (icmp-eq tg 0)))
            (if (icmp-eq op 11) (Ok [CtVal Diag] (CBool (icmp-eq tg 3)))
            (if (icmp-eq op 3) (if (or (icmp-eq tg 6) (icmp-eq tg 7)) (Ok [CtVal Diag] (CInt (sx-len (sx-items code)))) (Err [CtVal Diag] (derr "comptime: code-count expects a list/vector")))
            (if (icmp-eq op 5) (if (icmp-eq tg 2) (Ok [CtVal Diag] (CStr (sx-sval code))) (Err [CtVal Diag] (derr "comptime: code-sym expects a symbol")))
            (if (icmp-eq op 6) (if (icmp-eq tg 0) (Ok [CtVal Diag] (CInt (sx-ival code))) (Err [CtVal Diag] (derr "comptime: code-int expects an integer")))
            (if (icmp-eq op 7)
                (if (or (icmp-eq tg 6) (icmp-eq tg 7))
                    (let [items (sx-items code) n (sx-len items) (mut xs) (al-new [Sexp] a) (mut i) 1]
                      (loop (if (icmp-ge (load i) n) (break) (do (al-push! (mut xs) (sx-at items (load i))) (store! i (iadd (load i) 1)))))
                      (Ok [CtVal Diag] (CCode (sx-mklist (box-al [Sexp] a (load xs))))))
                    (Err [CtVal Diag] (derr "comptime: code-rest expects a list")))
            (if (icmp-eq op 4)
                (match (cv-get args 1)
                  (None [] (Err [CtVal Diag] (derr "comptime: code-nth index must be an integer")))
                  (Some [iv]
                    (if (icmp-ne (ct-tag iv) 0) (Err [CtVal Diag] (derr "comptime: code-nth index must be an integer"))
                      (if (or (icmp-eq tg 6) (icmp-eq tg 7))
                          (let [items (sx-items code) i (cint-of iv)]
                            (if (or (icmp-lt i 0) (icmp-ge i (sx-len items))) (Err [CtVal Diag] (derr (sconcat3 a "comptime: code-nth index " (dec->str a i) " out of range")))
                                (Ok [CtVal Diag] (CCode (sx-at items i)))))
                          (Err [CtVal Diag] (derr "comptime: code-nth expects a list/vector"))))))
                (match (cv-get args 1)
                  (None [] (Err [CtVal Diag] (derr "comptime: code-eq expects two Code values")))
                  (Some [v1]
                    (if (not (is-ccode v1)) (Err [CtVal Diag] (derr "comptime: code-eq expects two Code values"))
                        (Ok [CtVal Diag] (CBool (sexp-eq code (ccode-of v1))))))))))))))))))))))

; code_op dispatcher: the no-Code-arg ops inline, the rest delegated by group.
(defn code-op [(op i64) (args (ptr (ArrayList CtVal))) (cx (ptr CtCtx))] (-> (Result CtVal Diag))
  (let [a (load (field cx a))]
    (if (icmp-eq op 8) (Ok [CtVal Diag] (CCode (sx-sym (sconcat a "$g" (dec->str a (next-gensym))))))
    (if (icmp-eq op 30) (Ok [CtVal Diag] (CCode (sx-sym (target-arch-str))))
    (if (icmp-eq op 9)
        (match (cv-get args 0) (Some [v] (if (is-cstr v) (Err [CtVal Diag] (derr (cstr-of v))) (Err [CtVal Diag] (derr "error: message must be a string")))) (None [] (Err [CtVal Diag] (derr "error: message must be a string"))))
    (if (or (icmp-eq op 12) (icmp-eq op 13)) (cop-concat op args cx)
    (if (or (icmp-eq op 14) (or (icmp-eq op 15) (or (icmp-eq op 16) (icmp-eq op 17)))) (cop-field op args cx)
    (if (or (icmp-eq op 18) (or (icmp-eq op 19) (or (icmp-eq op 20) (icmp-eq op 21)))) (cop-variant op args cx)
    (if (or (icmp-eq op 22) (or (icmp-eq op 23) (or (icmp-eq op 24) (or (icmp-eq op 25) (or (icmp-eq op 26) (icmp-eq op 27)))))) (cop-trait op args cx)
    (if (icmp-eq op 28) (cop-strbytes args cx)
    (if (icmp-eq op 29) (cop-bytestostr args cx)
        (cop-codearg op args cx))))))))))))

(defn module-fns-has [(cx (ptr CtCtx)) (q (slice u8))] (-> bool)
  (let [lst (load (field cx module_fns)) n (al-len [(slice u8)] (load lst)) (mut i) 0 (mut r) false]
    (loop (if (or (load r) (icmp-ge (load i) n)) (break)
      (do (if (str-eq (al-get [(slice u8)] (load lst) (load i)) q) (do (store! r true) 0) 0) (store! i (iadd (load i) 1)))))
    (load r)))
(defn resolve-in-module [(cx (ptr CtCtx)) (name (slice u8)) (m (slice u8))] (-> (Option (slice u8)))
  (let [a (load (field cx a)) own (sconcat3 a m "." name)]
    (if (module-fns-has cx own) (Some own)
      (let [imp (load (field cx qimports))]
        (if (icmp-eq (cast i64 imp) 0) (None [(slice u8)])
          (let [uses (field imp uses) n (al-len [Use] (load uses)) (mut i) 0 (mut r) (None [(slice u8)])]
            (loop (if (icmp-ge (load i) n) (break)
              (do (let [up (alloc-stack Use)] (store! up (al-get [Use] (load uses) (load i)))
                    (let [target (load (field up target))
                          used (match (load (field up spec)) (UAll [] true) (UNames [names] (set-contains names name)))
                          exported (exports-check (load (field cx qexports)) target name)]
                      (if (and used exported)
                          (let [q (sconcat3 a target "." name)]
                            (if (module-fns-has cx q) (do (store! r (Some q)) (break)) 0)) 0)))
                  (store! i (iadd (load i) 1)))))
            (load r)))))))

; ---- qualify_head (src/comptime.rs::qualify_head): referential hygiene of a
;      generated list's CALL HEAD. `items` is the original Quasi item list; only
;      when items[0] is a literal symbol Quasi do we qualify out[0].
(defn quasi-head-is-lit-sym [(items (ptr (ArrayList Quasi)))] (-> bool)
  (if (icmp-eq (al-len [Quasi] (load items)) 0) false
    (match-else (al-get [Quasi] (load items) 0)
      (QLit [fp] (icmp-eq (sx-tag (load fp)) 2))
      (_ false))))
(defn qualify-head [(out (ptr (ArrayList Sexp))) (items (ptr (ArrayList Quasi))) (cx (ptr CtCtx))] (-> i64)
  (if (not (quasi-head-is-lit-sym items)) 0
    (if (icmp-eq (al-len [Sexp] (load out)) 0) 0
      (match (load (field cx qmodule))
        (None [] 0)
        (Some [m]
          (if (icmp-eq (cast i64 (load (field cx module_fns))) 0) 0
            (let [hp (al-elem [Sexp] out 0)]
              (if (icmp-ne (sx-tag (load hp)) 2) 0
                (let [name (sx-sval (load hp))]
                  (if (or (has-dot name) (icmp-ge (find-slash name) 0)) 0
                    (match (resolve-in-module cx name m)
                      (None [] 0)
                      (Some [q] (do (store! (field hp kind) (KSym q)) 0)))))))))))))

; ---- eval_quasi / eval_quasi_items (src/comptime.rs) ----------------------
(defn eval-quasi-items [(items (ptr (ArrayList Quasi))) (env (ptr (ArrayList EnvBind))) (cx (ptr CtCtx))] (-> (Result (ptr (ArrayList Sexp)) Diag))
  (let [a (load (field cx a)) n (al-len [Quasi] (load items)) (mut out) (al-new [Sexp] a) (mut i) 0 (mut errf) (None [Diag])]
    (loop (if (or (diag-some? (load errf)) (icmp-ge (load i) n)) (break)
      (do (let [it (al-elem [Quasi] items (load i))]
            (match-else (load it)
              (QSplice [e]
                (match (eval e env cx)
                  (Err [d] (do (store! errf (Some d)) 0))
                  (Ok [fl]
                    (match fl
                      (FBrk [vv ll] (do (store! errf (Some (derr "comptime: control flow inside a ~@ splice"))) 0))
                      (FCont [ll]   (do (store! errf (Some (derr "comptime: control flow inside a ~@ splice"))) 0))
                      (FVal [v]
                        (if (not (is-ccode v)) (do (store! errf (Some (derr "comptime: ~@ splice expects a Code list"))) 0)
                          (let [c (ccode-of v) tg (sx-tag c)]
                            (if (not (or (icmp-eq tg 6) (icmp-eq tg 7))) (do (store! errf (Some (derr "comptime: ~@ splice expects a Code list"))) 0)
                              (let [xs (sx-items c) m (sx-len xs) (mut j) 0]
                                (loop (if (icmp-ge (load j) m) (break) (do (al-push! (mut out) (sx-at xs (load j))) (store! j (iadd (load j) 1)))))
                                0)))))))))
              (_ (match (eval-quasi it env cx)
                   (Err [d] (do (store! errf (Some d)) 0))
                   (Ok [s] (do (al-push! (mut out) s) 0))))))
          (store! i (iadd (load i) 1)))))
    (match (load errf)
      (Some [d] (Err [(ptr (ArrayList Sexp)) Diag] d))
      (None []  (Ok [(ptr (ArrayList Sexp)) Diag] (box-al [Sexp] a (load out)))))))
(defn eval-quasi [(q (ptr Quasi)) (env (ptr (ArrayList EnvBind))) (cx (ptr CtCtx))] (-> (Result Sexp Diag))
  (try
    (let [a (load (field cx a))]
      (match (load q)
        (QLit [fp] (Ok [Sexp Diag] (load fp)))
        (QUnquote [e]
          (match (try! (eval e env cx))
            (FVal  [v] (ctval->sexp v))
            (FBrk  [vv ll] (Err [Sexp Diag] (derr "comptime: control flow inside an unquote")))
            (FCont [ll]    (Err [Sexp Diag] (derr "comptime: control flow inside an unquote")))))
        (QSplice [e] (Err [Sexp Diag] (derr "comptime: ~@ (splice) is only valid inside a list/vector")))
        (QList [items]
          (let [out (try! (eval-quasi-items items env cx))]
            (qualify-head out items cx)
            (Ok [Sexp Diag] (mk-sexp (KList out) -1 -1))))
        (QVector [items]
          (let [out (try! (eval-quasi-items items env cx))]
            (Ok [Sexp Diag] (mk-sexp (KVec out) -1 -1))))))))


; ============================ THE EXPANDER (the FILL) ========================
; The Stage-3 macro EXPANDER: port of src/lib.rs::expand_stage3_macros +
; src/comptime.rs (the comptime tree-walk interpreter). Runs the Coil macro fns
; (`[Code…]->Code`) over the loaded, module-tagged forms to a fixpoint, splicing
; generated syntax. OUTPUT = the macro-free form list (dumped by d-expanded).
;
; dump-expand pipeline (mirrors src/lib.rs::dump_expand): read -> load_program ->
; expand-stage3 (this; internally resolves+checks the macro closure, then runs the
; interpreter) -> d-expanded. NO resolve/check/metas in the dump path itself.
;
; STATUS: hard-error stub. The whole comptime interpreter + elaboration driver
; hang off `expand-stage3`. Until ported, hard-error so a partial port can never
; silently pass the gate. FILL ORDER (foundation analysis): CtVal+cell arena -> Env
; + scalar eval -> memory arms -> loop/break/continue -> quote/quasi/code_op +
; reflection -> expand_macro -> driver (macro detection, resolve-macro scoping,
; expand_calls outside-in fixpoint, incremental generated decls, qualify_head).

; ============================ THE DRIVER (expand_stage3) =====================
; Port of src/lib.rs::expand_stage3_macros_inner + the helpers it calls.

; ---- macro detection (keep_for_macro_detection / defn_involves_code) -------
(defn type-is-code [(t (ptr Type))] (-> bool) (match-else (load t) (TCode [] true) (_ false)))
; a (-> Code) list, or a param vector with a (name Code) entry => a macro/helper.
(defn defn-involves-code [(items (ptr (ArrayList Sexp)))] (-> bool)
  (let [n (sx-len items) (mut i) 0 (mut r) false]
    (loop (if (or (load r) (icmp-ge (load i) n)) (break)
      (do (let [it (sx-at items (load i)) tg (sx-tag it)]
            (if (icmp-eq tg 6)  ; list: (-> Code) ?
                (let [l (sx-items it)]
                  (if (and (icmp-ge (sx-len l) 2)
                           (and (icmp-eq (sx-tag (sx-at l 0)) 2) (str-eq (sx-sval (sx-at l 0)) "->")))
                      (if (and (icmp-eq (sx-tag (sx-at l 1)) 2) (str-eq (sx-sval (sx-at l 1)) "Code")) (do (store! r true) 0) 0) 0))
            (if (icmp-eq tg 7)  ; vector of params: any (name Code) ?
                (let [ps (sx-items it) np (sx-len ps) (mut j) 0]
                  (loop (if (or (load r) (icmp-ge (load j) np)) (break)
                    (do (let [p (sx-at ps (load j))]
                          (if (icmp-eq (sx-tag p) 6)
                              (let [pl (sx-items p)]
                                (if (and (icmp-ge (sx-len pl) 2) (and (icmp-eq (sx-tag (sx-at pl 1)) 2) (str-eq (sx-sval (sx-at pl 1)) "Code"))) (do (store! r true) 0) 0)) 0))
                        (store! j (iadd (load j) 1)))))) 0)))
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn keep-for-macro-detection [(f (ptr Sexp))] (-> bool)
  (if (icmp-ne (sx-tag (load f)) 6) true
    (let [items (sx-items (load f))]
      (if (icmp-eq (sx-len items) 0) true
        (let [h (sx-at items 0)]
          (if (icmp-ne (sx-tag h) 2) true
            (let [head (sx-sval h)]
              (if (str-eq head "defn") (defn-involves-code items)
              (if (or (str-eq head "defstruct") (or (str-eq head "defsum") (or (str-eq head "deftrait")
                  (or (str-eq head "extern") (or (str-eq head "module") (or (str-eq head "import")
                  (or (str-eq head "include") (or (str-eq head "export") (or (str-eq head "export-c") (str-eq head "defcc"))))))))))
                  true false)))))))))

; ---- collect_calls (src/lib.rs::collect_calls): names of called fns (restricted
;      to `names`) reachable in an expr. Pushes into an SBox.
(defn cc-push! [(out (ptr SBox)) (names (ptr (ArrayList (slice u8)))) (func (slice u8))] (-> i64)
  (if (set-contains names func) (do (al-push! (mut (field out items)) func) 0) 0))
(defn cc-list [(es (ptr (ArrayList Expr))) (names (ptr (ArrayList (slice u8)))) (out (ptr SBox))] (-> i64)
  (let [n (al-len [Expr] (load es)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break) (do (collect-calls (al-elem [Expr] es (load i)) names out) (store! i (iadd (load i) 1)))))) 0)
(defn cc-opt [(o (Option (ptr Expr))) (names (ptr (ArrayList (slice u8)))) (out (ptr SBox))] (-> i64)
  (match o (Some [e] (collect-calls e names out)) (None [] 0)))
(defn cc-binds [(bs (ptr (ArrayList Bind))) (names (ptr (ArrayList (slice u8)))) (out (ptr SBox))] (-> i64)
  (let [n (al-len [Bind] (load bs)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break) (do (collect-calls (field (al-elem [Bind] bs (load i)) value) names out) (store! i (iadd (load i) 1)))))) 0)
(defn cc-arms [(as (ptr (ArrayList Arm))) (names (ptr (ArrayList (slice u8)))) (out (ptr SBox))] (-> i64)
  (let [n (al-len [Arm] (load as)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break) (do (collect-calls (field (al-elem [Arm] as (load i)) body) names out) (store! i (iadd (load i) 1)))))) 0)
(defn cc-quasi-list [(items (ptr (ArrayList Quasi))) (names (ptr (ArrayList (slice u8)))) (out (ptr SBox))] (-> i64)
  (let [n (al-len [Quasi] (load items)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break) (do (cc-quasi (al-elem [Quasi] items (load i)) names out) (store! i (iadd (load i) 1)))))) 0)
(defn cc-quasi [(q (ptr Quasi)) (names (ptr (ArrayList (slice u8)))) (out (ptr SBox))] (-> i64)
  (match-else (load q)
    (QUnquote [e] (collect-calls e names out))
    (QSplice  [e] (collect-calls e names out))
    (QList    [items] (cc-quasi-list items names out))
    (QVector  [items] (cc-quasi-list items names out))
    (_ 0)))
(defn collect-calls [(e (ptr Expr)) (names (ptr (ArrayList (slice u8)))) (out (ptr SBox))] (-> i64)
  (match-else (load (field e kind))
    (ECall    [func ta args] (do (cc-push! out names func) (cc-list args names out)))
    (EBorrow  [m place] (collect-calls place names out))
    (ESpillRef [x] (collect-calls x names out))
    (ENot     [x] (collect-calls x names out))
    (ELoad    [x] (collect-calls x names out))
    (EFree    [x] (collect-calls x names out))
    (EComptime [x] (collect-calls x names out))
    (EErase   [tn inner] (collect-calls inner names out))
    (EMakeDyn [ds vs ms inner] (collect-calls inner names out))
    (EDynDispatch [ds vs mi cc ps r recv args] (do (collect-calls recv names out) (cc-list args names out)))
    (ECast    [ty x] (collect-calls x names out))
    (EBin     [op l r] (do (collect-calls l names out) (collect-calls r names out)))
    (ECmp     [op l r] (do (collect-calls l names out) (collect-calls r names out)))
    (EIf      [c t el] (do (collect-calls c names out) (collect-calls t names out) (collect-calls el names out)))
    (EDo      [es] (cc-list es names out))
    (ELoop    [lbl es] (cc-list es names out))
    (EBreak   [lbl v] (cc-opt v names out))
    (ELet     [bs body] (do (cc-binds bs names out) (cc-list body names out)))
    (EField   [p fn] (collect-calls p names out))
    (EBitGet  [p fn] (collect-calls p names out))
    (EStore   [p v] (do (collect-calls p names out) (collect-calls v names out)))
    (EIndex   [p idx] (do (collect-calls p names out) (collect-calls idx names out)))
    (EBitSet  [p fn v] (do (collect-calls p names out) (collect-calls v names out)))
    (EConstruct [sm vr args] (cc-list args names out))
    (ECodeOp  [op args] (cc-list args names out))
    (ETraitCall [tn m stp args] (cc-list args names out))
    (ELlvmIr  [r args body] (cc-list args names out))
    (ECallPtr [fp args] (do (collect-calls fp names out) (cc-list args names out)))
    (EMatch   [scrut arms] (do (collect-calls scrut names out) (cc-arms arms names out)))
    (EFieldMeta [meta ty idx] (collect-calls idx names out))
    (EFieldIndex [ty nm] (collect-calls nm names out))
    (EQuasi   [q] (let [qp (alloc-stack Quasi)] (store! qp q) (cc-quasi qp names out)))
    (_ 0)))

; ---- closure_funcs (src/lib.rs::closure_funcs) ----------------------------
(defn prog-fn-names [(p (ptr Program)) (a (ptr Allocator))] (-> (ptr (ArrayList (slice u8))))
  (let [fs (load (field p funcs)) n (al-len [Func] (load fs)) (mut out) (al-new [(slice u8)] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break) (do (al-push! (mut out) (load (field (al-elem [Func] fs (load i)) name))) (store! i (iadd (load i) 1)))))
    (box-al [(slice u8)] a (load out))))
(defn prog-fn-find [(p (ptr Program)) (name (slice u8))] (-> (ptr Func))
  (let [fs (load (field p funcs)) n (al-len [Func] (load fs)) (mut i) 0 (mut r) (cast (ptr Func) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [Func] fs (load i)) name)) name) (do (store! r (al-elem [Func] fs (load i))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
; transitive callees of `seeds` within program p (worklist + visited set).
(defn closure-funcs [(p (ptr Program)) (seeds (ptr (ArrayList (slice u8)))) (a (ptr Allocator))] (-> (ptr (ArrayList (slice u8))))
  (let [names (prog-fn-names p a)
        stackb (unwrap-ptr [SBox] (create [SBox] a)) wantedb (unwrap-ptr [SBox] (create [SBox] a))]
    (store! (field stackb items) (al-new [(slice u8)] a))
    (store! (field wantedb items) (al-new [(slice u8)] a))
    (let [ns (al-len [(slice u8)] (load seeds)) (mut si) 0]
      (loop (if (icmp-ge (load si) ns) (break) (do (al-push! (mut (field stackb items)) (al-get [(slice u8)] (load seeds) (load si))) (store! si (iadd (load si) 1))))))
    (loop (if (icmp-eq (al-len [(slice u8)] (load (field stackb items))) 0) (break)
      (do (let [sl (load (field stackb items)) top (al-len [(slice u8)] sl) nm (al-get [(slice u8)] sl (isub top 1))]
            ; pop
            (store! (field (field stackb items) len) (isub top 1))
            (if (set-contains (field wantedb items) nm) 0
                (do (al-push! (mut (field wantedb items)) nm)
                    (let [f (prog-fn-find p nm)]
                      (if (icmp-eq (cast i64 f) 0) 0 (cc-list (load (field f body)) names stackb)))))))))
    (field wantedb items)))

; ---- closure_subprogram (src/lib.rs::closure_subprogram): only `wanted` funcs. -
(defn closure-subprogram [(p (ptr Program)) (wanted (ptr (ArrayList (slice u8)))) (a (ptr Allocator))] (-> (ptr Program))
  (let [pp (unwrap-ptr [Program] (create [Program] a)) fs (load (field p funcs)) n (al-len [Func] (load fs)) (mut keep) (al-new [Func] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [fp (al-elem [Func] fs (load i))]
            (if (set-contains wanted (load (field fp name))) (do (al-push! (mut keep) (load fp)) 0) 0))
          (store! i (iadd (load i) 1)))))
    (store! (field pp conventions) (load (field p conventions)))
    (store! (field pp structs) (load (field p structs)))
    (store! (field pp sums) (load (field p sums)))
    (store! (field pp externs) (load (field p externs)))
    (store! (field pp funcs) (box-al [Func] a (load keep)))
    (store! (field pp asserts) (box-al [StaticAssert] a (al-new [StaticAssert] a)))
    (store! (field pp consts) (load (field p consts)))
    (store! (field pp traits) (load (field p traits)))
    (store! (field pp impls) (load (field p impls)))
    (store! (field pp metas) (box-al [Expr] a (al-new [Expr] a)))
    (store! (field pp exports) (box-al [ExportC] a (al-new [ExportC] a)))
    pp))

; ---- macro/comptime form predicates --------------------------------------
(defn is-meta-form [(f (ptr Sexp))] (-> bool)
  (and (icmp-eq (sx-tag (load f)) 6)
       (let [it (sx-items (load f))]
         (and (icmp-ge (sx-len it) 1) (and (icmp-eq (sx-tag (sx-at it 0)) 2) (str-eq (sx-sval (sx-at it 0)) "meta"))))))
(defn defn-name-of [(f (ptr Sexp))] (-> (Option (slice u8)))
  (if (icmp-ne (sx-tag (load f)) 6) (None [(slice u8)])
    (let [it (sx-items (load f))]
      (if (icmp-lt (sx-len it) 2) (None [(slice u8)])
        (if (and (icmp-eq (sx-tag (sx-at it 0)) 2) (and (str-eq (sx-sval (sx-at it 0)) "defn") (icmp-eq (sx-tag (sx-at it 1)) 2)))
            (Some (sx-sval (sx-at it 1))) (None [(slice u8)]))))))
(defn qualify-name [(a (ptr Allocator)) (n (slice u8)) (m (Option (slice u8)))] (-> (slice u8))
  (match m (Some [md] (sconcat3 a md "." n)) (None [] n)))
(defn is-comptime-defn [(f (ptr Sexp)) (module (Option (slice u8))) (comptime (ptr (ArrayList (slice u8)))) (a (ptr Allocator))] (-> bool)
  (match (defn-name-of f)
    (None [] false)
    (Some [n] (set-contains comptime (qualify-name a n module)))))

; ---- resolve_macro (src/lib.rs::resolve_macro) ----------------------------
(defn macro-use-match [(impe (ptr ImpEntry)) (macros (ptr (ArrayList (slice u8)))) (expb (ptr (ArrayList ExpEntry))) (head (slice u8)) (a (ptr Allocator))] (-> (Option (slice u8)))
  (let [uses (field (field impe imp) uses) n (al-len [Use] (load uses)) (mut i) 0 (mut r) (None [(slice u8)])]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [up (alloc-stack Use)] (store! up (al-get [Use] (load uses) (load i)))
            (let [target (load (field up target))
                  used (match (load (field up spec)) (UAll [] true) (UNames [names] (set-contains names head)))
                  q (sconcat3 a target "." head)]
              (if (and used (and (exports-check expb target head) (set-contains macros q))) (do (store! r (Some q)) (break)) 0)))
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn macro-reexport-match [(core (ptr ImpEntry)) (macros (ptr (ArrayList (slice u8)))) (expb (ptr (ArrayList ExpEntry))) (head (slice u8)) (a (ptr Allocator))] (-> (Option (slice u8)))
  (let [res (field (field core imp) reexports) n (al-len [(slice u8)] (load res)) (mut i) 0 (mut r) (None [(slice u8)])]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [target (al-get [(slice u8)] (load res) (load i)) q (sconcat3 a target "." head)]
            (if (and (exports-check expb target head) (set-contains macros q)) (do (store! r (Some q)) (break)) 0))
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn resolve-macro [(head (slice u8)) (module (Option (slice u8))) (macros (ptr (ArrayList (slice u8)))) (impb (ptr (ArrayList ImpEntry))) (expb (ptr (ArrayList ExpEntry))) (a (ptr Allocator))] (-> (Option (slice u8)))
  (let [sl (find-slash head)]
    (if (icmp-ge sl 0)
        ; alias/name
        (let [alias (subslice head 0 sl) rest (subslice head (iadd sl 1) (slice-len head))]
          (match module
            (None [] (None [(slice u8)]))
            (Some [m]
              (let [impe (imports-find impb m)]
                (if (icmp-eq (cast i64 impe) 0) (None [(slice u8)])
                  (match (alias-target impe alias)
                    (None [] (None [(slice u8)]))
                    (Some [target]
                      (let [q (sconcat3 a target "." rest)]
                        (if (and (set-contains macros q) (exports-check expb target rest)) (Some q) (None [(slice u8)]))))))))))
        (if (has-dot head)
            (if (set-contains macros head) (Some head) (None [(slice u8)]))
            ; bare
            (let [own (qualify-name a head module)]
              (if (set-contains macros own) (Some own)
                (let [mname (match module (Some [m] m) (None [] ""))
                      impe (imports-find impb mname)
                      r1 (if (icmp-eq (cast i64 impe) 0) (None [(slice u8)]) (macro-use-match impe macros expb head a))]
                  (match r1
                    (Some [q] (Some q))
                    (None []
                      (if (str-eq mname "coil.core") (None [(slice u8)])
                        (let [core (imports-find impb "coil.core")]
                          (if (icmp-eq (cast i64 core) 0) (None [(slice u8)]) (macro-reexport-match core macros expb head a)))))))))))))

; ---- stamp_expansion (src/lib.rs::stamp_expansion): every macro-synthesized node
;      (a template wrapper the quasiquote builder left DUMMY, lo<0) is relocated to
;      the call site {source,lo,hi} and tagged with the expansion `ctxt`. Non-dummy
;      nodes (template literals, ~unquote-spliced caller code) are left untouched;
;      recursion into List/Vector children happens either way.
(defn stamp-expansion [(s (ptr Sexp)) (source i64) (lo i64) (hi i64) (ctxt i64)] (-> i64)
  (if (icmp-lt (sx-lo (load s)) 0)
      (do (store! (field s source) source) (store! (field s lo) lo) (store! (field s hi) hi) (store! (field s ctxt) ctxt) 0) 0)
  (let [tg (sx-tag (load s))]
    (if (or (icmp-eq tg 6) (icmp-eq tg 7))
        (let [items (sx-items (load s)) n (sx-len items) (mut i) 0]
          (loop (if (icmp-ge (load i) n) (break) (do (stamp-expansion (al-elem [Sexp] items (load i)) source lo hi ctxt) (store! i (iadd (load i) 1)))))) 0)) 0)

; ---- expand_macro (src/comptime.rs::expand_macro) -------------------------
; Merge sub structs/sums with the (gap-filling) generated ones, build a CtCtx,
; bind params to CCode, run eval-seq, expect a CCode result.
(defn merge-structs-gen [(sub (ptr Program)) (gen (ptr (ArrayList StructDef))) (a (ptr Allocator))] (-> (ptr (ArrayList StructDef)))
  (let [base (load (field sub structs)) nb (al-len [StructDef] (load base)) (mut out) (al-new [StructDef] a) (mut i) 0]
    (loop (if (icmp-ge (load i) nb) (break) (do (al-push! (mut out) (al-get [StructDef] (load base) (load i))) (store! i (iadd (load i) 1)))))
    (let [ng (al-len [StructDef] (load gen)) (mut j) 0]
      (loop (if (icmp-ge (load j) ng) (break)
        (do (let [g (al-elem [StructDef] gen (load j)) gname (load (field g name)) (mut found) false (mut k) 0]
              (loop (if (icmp-ge (load k) nb) (break) (do (if (str-eq (load (field (al-elem [StructDef] base (load k)) name)) gname) (do (store! found true) (break)) 0) (store! k (iadd (load k) 1)))))
              (if (load found) 0 (do (al-push! (mut out) (load g)) 0)))
            (store! j (iadd (load j) 1))))))
    (box-al [StructDef] a (load out))))
(defn merge-sums-gen [(sub (ptr Program)) (gen (ptr (ArrayList SumDef))) (a (ptr Allocator))] (-> (ptr (ArrayList SumDef)))
  (let [base (load (field sub sums)) nb (al-len [SumDef] (load base)) (mut out) (al-new [SumDef] a) (mut i) 0]
    (loop (if (icmp-ge (load i) nb) (break) (do (al-push! (mut out) (al-get [SumDef] (load base) (load i))) (store! i (iadd (load i) 1)))))
    (let [ng (al-len [SumDef] (load gen)) (mut j) 0]
      (loop (if (icmp-ge (load j) ng) (break)
        (do (let [g (al-elem [SumDef] gen (load j)) gname (load (field g name)) (mut found) false (mut k) 0]
              (loop (if (icmp-ge (load k) nb) (break) (do (if (str-eq (load (field (al-elem [SumDef] base (load k)) name)) gname) (do (store! found true) (break)) 0) (store! k (iadd (load k) 1)))))
              (if (load found) 0 (do (al-push! (mut out) (load g)) 0)))
            (store! j (iadd (load j) 1))))))
    (box-al [SumDef] a (load out))))
(defn all-variant-names [(sums (ptr (ArrayList SumDef))) (a (ptr Allocator))] (-> (ptr (ArrayList (slice u8))))
  (let [n (al-len [SumDef] (load sums)) (mut out) (al-new [(slice u8)] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [vs (load (field (al-elem [SumDef] sums (load i)) variants)) nv (al-len [Variant] (load vs)) (mut j) 0]
            (loop (if (icmp-ge (load j) nv) (break) (do (al-push! (mut out) (load (field (al-elem [Variant] vs (load j)) name))) (store! j (iadd (load j) 1))))))
          (store! i (iadd (load i) 1)))))
    (box-al [(slice u8)] a (load out))))
; module of a qualified fn name (everything before the LAST dot), or None.
(defn module-of [(name (slice u8))] (-> (Option (slice u8)))
  (let [n (slice-len name) (mut i) (isub n 1) (mut at) -1]
    (loop (if (icmp-lt (load i) 0) (break) (do (if (and (icmp-lt (load at) 0) (icmp-eq (cast i64 (slice-get name (load i))) 46)) (store! at (load i)) 0) (store! i (isub (load i) 1)))))
    (if (icmp-lt (load at) 0) (None [(slice u8)]) (Some (subslice name 0 (load at))))))
(defn expand-macro [(sub (ptr Program)) (fn-name (slice u8)) (margs (ptr (ArrayList Sexp))) (allfns (ptr (ArrayList (slice u8)))) (genstructs (ptr (ArrayList StructDef))) (gensums (ptr (ArrayList SumDef))) (impb (ptr (ArrayList ImpEntry))) (expb (ptr (ArrayList ExpEntry))) (a (ptr Allocator))] (-> (Result Sexp Diag))
  (let [smap (merge-structs-gen sub genstructs a) sumap (merge-sums-gen sub gensums a)
        cx (alloc-stack CtCtx) callee (prog-fn-find sub fn-name)]
    (store! (field cx a) a)
    (store! (field cx fns) (load (field sub funcs)))
    (store! (field cx structs) smap)
    (store! (field cx sums) sumap)
    (store! (field cx variants) (all-variant-names (load (field sub sums)) a))
    (store! (field cx traits) (load (field sub traits)))
    (store! (field cx fuel) 50000000)
    (store! (field cx depth) 0)
    (store! (field cx gensym) 0)
    (store! (field cx qmodule) (module-of fn-name))
    (store! (field cx module_fns) allfns)
    (store! (field cx qimports) (match (module-of fn-name) (Some [m] (let [ie (imports-find impb m)] (if (icmp-eq (cast i64 ie) 0) (cast (ptr ModImports) 0) (field ie imp)))) (None [] (cast (ptr ModImports) 0))))
    (store! (field cx qexports) expb)
    (if (icmp-eq (cast i64 callee) 0) (Err [Sexp Diag] (derr (sconcat3 a "macro '" fn-name "' not found")))
      (let [pparams (load (field callee params)) np (al-len [Param] (load pparams)) na (al-len [Sexp] (load margs)) (mut env) (al-new [EnvBind] a)]
        (if (load (field callee macro_variadic))
            (if (icmp-lt na (isub np 1)) (Err [Sexp Diag] (derr (sconcat3 a "macro '" fn-name "' arity (variadic) mismatch")))
              (do (let [(mut k) 0]
                    (loop (if (icmp-ge (load k) (isub np 1)) (break)
                      (do (let [eb (alloc-stack EnvBind)] (store! (field eb name) (load (field (al-elem [Param] pparams (load k)) name))) (store! (field eb val) (CCode (al-get [Sexp] (load margs) (load k)))) (al-push! (mut env) (load eb)))
                          (store! k (iadd (load k) 1)))))
                  (let [(mut rest) (al-new [Sexp] a) (mut r) (isub np 1)]
                    (loop (if (icmp-ge (load r) na) (break) (do (al-push! (mut rest) (al-get [Sexp] (load margs) (load r))) (store! r (iadd (load r) 1)))))
                    (let [eb (alloc-stack EnvBind)] (store! (field eb name) (load (field (al-elem [Param] pparams (isub np 1)) name))) (store! (field eb val) (CCode (mk-sexp (KList (box-al [Sexp] a (load rest))) -1 -1))) (al-push! (mut env) (load eb))))
                  (finish-macro callee (box-al [EnvBind] a (load env)) cx a fn-name))))
            (if (icmp-ne np na) (Err [Sexp Diag] (derr (sconcat3 a "macro '" fn-name "' arity mismatch")))
              (do (let [(mut k) 0]
                    (loop (if (icmp-ge (load k) np) (break)
                      (do (let [eb (alloc-stack EnvBind)] (store! (field eb name) (load (field (al-elem [Param] pparams (load k)) name))) (store! (field eb val) (CCode (al-get [Sexp] (load margs) (load k)))) (al-push! (mut env) (load eb)))
                          (store! k (iadd (load k) 1)))))
                  (finish-macro callee (box-al [EnvBind] a (load env)) cx a fn-name)))))))))
(defn finish-macro [(callee (ptr Func)) (env (ptr (ArrayList EnvBind))) (cx (ptr CtCtx)) (a (ptr Allocator)) (fn-name (slice u8))] (-> (Result Sexp Diag))
  (match (eval-seq (load (field callee body)) env cx)
    (Err [d] (Err [Sexp Diag] d))
    (Ok [fl]
      (match fl
        (FVal [v] (if (is-ccode v) (Ok [Sexp Diag] (ccode-of v)) (Err [Sexp Diag] (derr (sconcat3 a "macro '" fn-name "' did not return Code")))))
        (FBrk [vv ll] (Err [Sexp Diag] (derr (sconcat3 a "macro '" fn-name "': stray control flow"))))
        (FCont [ll]   (Err [Sexp Diag] (derr (sconcat3 a "macro '" fn-name "': stray control flow"))))))))

; ---- expand_calls (src/lib.rs::expand_calls) outside-in to a fixpoint ------
(defstruct ExpEnv
  [(macros (ptr (ArrayList (slice u8)))) (comptime (ptr (ArrayList (slice u8))))
   (sub (ptr Program)) (impb (ptr (ArrayList ImpEntry))) (expb (ptr (ArrayList ExpEntry))) (a (ptr Allocator))
   ; Monotonic expansion counter (mirrors SourceMap.add_expansion returning the
   ; 1-based count). Bumped once per macro expansion, in outside-in DFS order; the
   ; resulting id is stamped onto that expansion's synthesized nodes as their ctxt.
   (expcount i64)])
(defn expand-calls-list [(items (ptr (ArrayList Sexp))) (module (Option (slice u8))) (env (ptr ExpEnv)) (allfns (ptr (ArrayList (slice u8)))) (gs (ptr (ArrayList StructDef))) (gu (ptr (ArrayList SumDef))) (depth (ptr i64))] (-> (Result (ptr (ArrayList Sexp)) Diag))
  (let [a (load (field env a)) n (sx-len items) (mut out) (al-new [Sexp] a) (mut i) 0 (mut errf) (None [Diag])]
    (loop (if (or (diag-some? (load errf)) (icmp-ge (load i) n)) (break)
      (do (match (expand-calls (al-elem [Sexp] items (load i)) module env allfns gs gu depth)
            (Err [d] (do (store! errf (Some d)) 0))
            (Ok [r] (do (al-push! (mut out) r) 0)))
          (store! i (iadd (load i) 1)))))
    (match (load errf) (Some [d] (Err [(ptr (ArrayList Sexp)) Diag] d)) (None [] (Ok [(ptr (ArrayList Sexp)) Diag] (box-al [Sexp] a (load out)))))))
(defn expand-calls [(s (ptr Sexp)) (module (Option (slice u8))) (env (ptr ExpEnv)) (allfns (ptr (ArrayList (slice u8)))) (gs (ptr (ArrayList StructDef))) (gu (ptr (ArrayList SumDef))) (depth (ptr i64))] (-> (Result Sexp Diag))
  (let [a (load (field env a)) tg (sx-tag (load s))]
    (if (icmp-eq tg 6)
        (let [items (sx-items (load s)) headq (if (and (icmp-ge (sx-len items) 1) (icmp-eq (sx-tag (sx-at items 0)) 2)) (resolve-macro (sx-sval (sx-at items 0)) module (load (field env macros)) (load (field env impb)) (load (field env expb)) a) (None [(slice u8)]))]
          (match headq
            (Some [q]
              (do (store! depth (iadd (load depth) 1))
                  (if (icmp-gt (load depth) 100000) (Err [Sexp Diag] (derr "macro expansion did not terminate"))
                    (match (expand-macro (load (field env sub)) q (rest-from a items 1) allfns gs gu (load (field env impb)) (load (field env expb)) a)
                      (Err [d] (Err [Sexp Diag] d))
                      (Ok [outs]
                        (let [op (box-sexp a outs)]
                          ; Record this expansion (bump the counter, 1-based like
                          ; SourceMap.add_expansion) and tag the synthesized output
                          ; with it, BEFORE re-expanding (nested macros bump further).
                          (store! (field env expcount) (iadd (load (field env expcount)) 1))
                          (let [ctxt (load (field env expcount))]
                            (stamp-expansion op (load (field s source)) (sx-lo (load s)) (sx-hi (load s)) ctxt)
                            (expand-calls op module env allfns gs gu depth))))))))
            (None []
              (match (expand-calls-list items module env allfns gs gu depth)
                (Err [d] (Err [Sexp Diag] d))
                (Ok [outitems] (Ok [Sexp Diag] (mk-sexp-like (KList outitems) s)))))))
        (if (icmp-eq tg 7)
            (match (expand-calls-list (sx-items (load s)) module env allfns gs gu depth)
              (Err [d] (Err [Sexp Diag] d))
              (Ok [outitems] (Ok [Sexp Diag] (mk-sexp-like (KVec outitems) s))))
            (Ok [Sexp Diag] (load s))))))
(defn expand-top-form [(f (ptr Sexp)) (module (Option (slice u8))) (env (ptr ExpEnv)) (allfns (ptr (ArrayList (slice u8)))) (gs (ptr (ArrayList StructDef))) (gu (ptr (ArrayList SumDef))) (depth (ptr i64))] (-> (Result Sexp Diag))
  (if (or (is-meta-form f) (is-comptime-defn f module (load (field env comptime)) (load (field env a)))) (Ok [Sexp Diag] (load f))
    (expand-calls f module env allfns gs gu depth)))

; ---- register_generated_decl (src/lib.rs::register_generated_decl) ---------
(defn qualify-structdefs! [(p (ptr Program)) (module (Option (slice u8))) (gs (ptr SBoxStruct)) (a (ptr Allocator))] (-> i64)
  (let [ss (load (field p structs)) n (al-len [StructDef] (load ss)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [sd (alloc-stack StructDef)] (store! sd (al-get [StructDef] (load ss) (load i)))
            (store! (field sd name) (qualify-name a (load (field sd name)) module))
            (al-push! (mut (field gs items)) (load sd)))
          (store! i (iadd (load i) 1)))))) 0)
(defn qualify-sumdefs! [(p (ptr Program)) (module (Option (slice u8))) (gu (ptr SBoxSum)) (a (ptr Allocator))] (-> i64)
  (let [ss (load (field p sums)) n (al-len [SumDef] (load ss)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [sd (alloc-stack SumDef)] (store! sd (al-get [SumDef] (load ss) (load i)))
            (store! (field sd name) (qualify-name a (load (field sd name)) module))
            (al-push! (mut (field gu items)) (load sd)))
          (store! i (iadd (load i) 1)))))) 0)
(defn register-generated-decl [(form (ptr Sexp)) (module (Option (slice u8))) (gs (ptr SBoxStruct)) (gu (ptr SBoxSum)) (a (ptr Allocator))] (-> (Option Diag))
  (if (icmp-ne (sx-tag (load form)) 6) (None [Diag])
    (let [it (sx-items (load form))]
      (if (icmp-lt (sx-len it) 1) (None [Diag])
        (if (icmp-ne (sx-tag (sx-at it 0)) 2) (None [Diag])
          (let [head (sx-sval (sx-at it 0))]
            (if (not (or (str-eq head "defstruct") (str-eq head "defsum"))) (None [Diag])
              (let [single (unwrap-ptr [(ArrayList Sexp)] (create [(ArrayList Sexp)] a)) (mut sl) (al-new [Sexp] a)]
                (al-push! (mut sl) (load form)) (store! single (load sl))
                (match (parse-program a single)
                  (Err [d] (Some d))
                  (Ok [p] (let [pp (box-program a p)]
                            (qualify-structdefs! pp module gs a)
                            (qualify-sumdefs! pp module gu a)
                            (None [Diag]))))))))))))
(defn box-program [(a (ptr Allocator)) (p Program)] (-> (ptr Program)) (let [pp (unwrap-ptr [Program] (create [Program] a))] (store! pp p) pp))

; ---- the driver itself (expand_stage3_macros_inner) -----------------------
(defstruct SBoxStruct [(items (ArrayList StructDef))])
(defstruct SBoxSum    [(items (ArrayList SumDef))])
(defstruct SBoxTF     [(items (ArrayList TaggedForm))])
; funcs in p whose signature is [Code…] -> Code (the macros).
(defn code-sig-funcs [(p (ptr Program)) (a (ptr Allocator))] (-> (ptr (ArrayList (slice u8))))
  (let [fs (load (field p funcs)) n (al-len [Func] (load fs)) (mut out) (al-new [(slice u8)] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [fp (al-elem [Func] fs (load i))]
            (if (and (type-is-code (field fp ret)) (all-params-code (load (field fp params)))) (do (al-push! (mut out) (load (field fp name))) 0) 0))
          (store! i (iadd (load i) 1)))))
    (box-al [(slice u8)] a (load out))))
(defn all-params-code [(ps (ptr (ArrayList Param)))] (-> bool)
  (let [n (al-len [Param] (load ps)) (mut i) 0 (mut r) true]
    (loop (if (or (not (load r)) (icmp-ge (load i) n)) (break)
      (do (if (type-is-code (field (al-elem [Param] ps (load i)) ty)) 0 (do (store! r false) 0)) (store! i (iadd (load i) 1)))))
    (load r)))
; all qualified defn names across the tagged forms (for referential hygiene).
(defn all-defn-names [(out-forms (ptr (ArrayList TaggedForm))) (a (ptr Allocator))] (-> (ptr SBox))
  (let [sb (unwrap-ptr [SBox] (create [SBox] a)) n (al-len [TaggedForm] (load out-forms)) (mut i) 0]
    (store! (field sb items) (al-new [(slice u8)] a))
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [tf (al-elem [TaggedForm] out-forms (load i)) fp (field tf form)]
            (match (defn-name-of fp) (Some [nm] (al-push! (mut (field sb items)) (qualify-name a nm (load (field tf module))))) (None [] 0)))
          (store! i (iadd (load i) 1)))))
    sb))
(defn expand-stage3 [(s (mut LS))] (-> (Result i64 Diag))
  (let [a (load (field s a)) out-forms (box-al [TaggedForm] a (load (field s out))) nforms (al-len [TaggedForm] (load out-forms))
        ; 1. macro detection subset
        subls (alloc-stack LS) (mut subset) (al-new [TaggedForm] a) (mut i) 0]
    (loop (if (icmp-ge (load i) nforms) (break)
      (do (let [tf (al-elem [TaggedForm] out-forms (load i))]
            (if (keep-for-macro-detection (field tf form)) (do (al-push! (mut subset) (load tf)) 0) 0))
          (store! i (iadd (load i) 1)))))
    (store! (field subls a) a)
    (store! (field subls out) (load subset))
    (store! (field subls loaded) (al-new [(slice u8)] a))
    (store! (field subls imports) (load (field s imports)))
    (store! (field subls exports) (load (field s exports)))
    (match (resolve-program a (mut subls) false)
      (Err [d] (Err [i64 Diag] d))
      (Ok [macroctx]
        (let [quals (code-sig-funcs macroctx a)]
          (if (icmp-eq (al-len [(slice u8)] (load quals)) 0) (Ok [i64 Diag] 0)
            (let [wanted (closure-funcs macroctx quals a) sub (closure-subprogram macroctx wanted a)
                  checkls (alloc-stack LS)]
              (store! (field checkls a) a)
              (store! (field checkls out) (al-new [TaggedForm] a))
              (store! (field checkls loaded) (al-new [(slice u8)] a))
              (store! (field checkls imports) (al-new [ImpEntry] a))
              (store! (field checkls exports) (al-new [ExpEntry] a))
              (match (check-program a sub (mut checkls))
                (Err [d] (Err [i64 Diag] d))
                (Ok [checked] (run-expand (mut s) quals wanted checked a))))))))))
(defn run-expand [(s (mut LS)) (macros (ptr (ArrayList (slice u8)))) (comptime (ptr (ArrayList (slice u8)))) (checked (ptr Program)) (a (ptr Allocator))] (-> (Result i64 Diag))
  (let [out-forms (box-al [TaggedForm] a (load (field s out))) nforms (al-len [TaggedForm] (load out-forms))
        impb (unwrap-ptr [(ArrayList ImpEntry)] (create [(ArrayList ImpEntry)] a))
        expb (unwrap-ptr [(ArrayList ExpEntry)] (create [(ArrayList ExpEntry)] a))
        env (alloc-stack ExpEnv)
        allfns (all-defn-names out-forms a)
        gs (unwrap-ptr [SBoxStruct] (create [SBoxStruct] a)) gu (unwrap-ptr [SBoxSum] (create [SBoxSum] a))
        result (unwrap-ptr [SBoxTF] (create [SBoxTF] a))
        (mut i) 0 (mut errf) (None [Diag]) (mut depthv) 0]
    (store! impb (load (field s imports))) (store! expb (load (field s exports)))
    (store! (field gs items) (al-new [StructDef] a)) (store! (field gu items) (al-new [SumDef] a))
    (store! (field result items) (al-new [TaggedForm] a))
    (store! (field env macros) macros) (store! (field env comptime) comptime)
    (store! (field env sub) checked) (store! (field env impb) impb) (store! (field env expb) expb) (store! (field env a) a)
    (store! (field env expcount) 0)
    (loop (if (or (diag-some? (load errf)) (icmp-ge (load i) nforms)) (break)
      (do (let [tf (alloc-stack TaggedForm)] (store! tf (al-get [TaggedForm] (load out-forms) (load i)))
            (let [module (load (field tf module))]
              (match (expand-top-form (field tf form) module env (field allfns items) (field gs items) (field gu items) (mut depthv))
                (Err [d] (do (store! errf (Some d)) 0))
                (Ok [outf]
                  (do-produced (box-sexp a outf) module result gs gu allfns a (mut errf))))))
          (store! i (iadd (load i) 1)))))
    (match (load errf)
      (Some [d] (Err [i64 Diag] d))
      (None [] (do (store! (field s out) (load (field result items))) (Ok [i64 Diag] 0))))))
; split a (do …) result into several forms; register decls + names; push each.
(defn do-produced [(outf (ptr Sexp)) (module (Option (slice u8))) (result (ptr SBoxTF)) (gs (ptr SBoxStruct)) (gu (ptr SBoxSum)) (allfns (ptr SBox)) (a (ptr Allocator)) (errf (mut (Option Diag)))] (-> i64)
  (let [(mut produced) (al-new [Sexp] a)]
    (if (and (icmp-eq (sx-tag (load outf)) 6)
             (let [it (sx-items (load outf))] (and (icmp-ge (sx-len it) 1) (and (icmp-eq (sx-tag (sx-at it 0)) 2) (str-eq (sx-sval (sx-at it 0)) "do")))))
        (let [it (sx-items (load outf)) n (sx-len it) (mut k) 1]
          (loop (if (icmp-ge (load k) n) (break) (do (al-push! (mut produced) (sx-at it (load k))) (store! k (iadd (load k) 1))))))
        (al-push! (mut produced) (load outf)))
    (let [np (al-len [Sexp] (load produced)) (mut j) 0]
      (loop (if (or (diag-some? (load errf)) (icmp-ge (load j) np)) (break)
        (do (let [form (al-elem [Sexp] produced (load j))]
              (match (register-generated-decl form module gs gu a)
                (Some [d] (do (store! errf (Some d)) 0))
                (None []
                  (do (match (defn-name-of form) (Some [nm] (al-push! (mut (field allfns items)) (qualify-name a nm module))) (None [] 0))
                      (let [tf (alloc-stack TaggedForm)] (store! (field tf form) (load form)) (store! (field tf module) module) (al-push! (mut (field result items)) (load tf)) 0)))))
            (store! j (iadd (load j) 1))))))) 0)


; Run the Stage-3 macro expander over the loaded, module-tagged forms IN PLACE:
; replace `(field s out)` with the macro-free, fully-expanded form list. Mirrors
; src/lib.rs::expand_stage3_macros_inner.

; Canonical dump of the EXPANDED module-tagged form list — ONLY the `(forms …)`
; section (the import/export tables are passed through from the loader unchanged
; and gated by the loader oracle). Byte-identical to src/dump_expand.rs.
(defn d-expanded [(w (ptr Writer)) (a (ptr Allocator)) (s (mut LS))] (-> i64)
  (ps w "(forms")
  (let [n (al-len [TaggedForm] (load (field s out))) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (ps w " (tf ")
          (let [tf (alloc-stack TaggedForm)]
            (store! tf (al-get [TaggedForm] (load (field s out)) (load i)))
            (d-opt-str w (load (field tf module)))
            (wb w 32)
            (let [fp (alloc-stack Sexp)] (store! fp (load (field tf form))) (sx-node w fp)))
          (wb w 41)
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  0)

; read -> load_program -> expand-stage3 -> d-expanded. A read error dumps the
; `(error@lo:hi "msg")` shape (mirrors dump_expand). Load errors are filesystem-
; dependent and EXCLUDED from the corpus, so a load failure aborts loudly.
(defn dump-expand-program [(a (ptr Allocator)) (src (slice u8)) (cwd (slice u8))] (-> i64)
  (let [w (stdout) s (alloc-stack LS)]
    (store! (field s a) a)
    (store! (field s out)     (al-new [TaggedForm] a))
    (store! (field s loaded)  (al-new [(slice u8)] a))
    (store! (field s imports) (al-new [ImpEntry] a))
    (store! (field s exports) (al-new [ExpEntry] a))
    ; Main file = source 0; the next id handed out (prelude) is 1.
    (store! (field s srccount) 1)
    (match (read-all a src 0)
      (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
      (Ok [forms]
        (do (load-program (mut s) forms cwd)
            (match (expand-stage3 (mut s))
              (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
              (Ok [_] (d-expanded w a (mut s))))))))
  0)

(defn main [(argc i32) (argv (ptr (ptr i8)))] (-> i64)
  (let [a    (malloc-allocator)
        sub  (cstr->slice (load (index argv 1)))]
    (if (str-eq sub "__smoke")
        (smoke a)
        (let [path (load (index argv 2))
              src  (read-file a path)
              cwd  (cwd-slice a)]
          (dump-expand-program a src cwd))))
  0)