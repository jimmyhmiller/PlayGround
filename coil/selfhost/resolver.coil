; selfhost/resolver.coil — the Coil port of src/resolve.rs (the name-resolution /
; "qualify" pass), composed over the already-completed reader + parser + loader.
;
; THE CONTRACT (see selfhost/oracle/resolved/): build this with the Rust `coil`,
;   selfhost/oracle/gate-resolved.sh <this-binary>
; must be byte-identical to the reference `coil dump-resolved` across the whole
; corpus. A shortcut (dropped qualification, skipped reference) makes the corpus
; diff non-empty and the gate FAILS.
;
; PIPELINE: selfread (reader) -> selfload (loader = src/macros.rs::load_program,
; producing module-tagged forms + import/export tables) -> resolve (parse each
; tagged form via parse-program, qualify it under its module, merge) -> the
; canonical Program dump (d-program, REUSED from the parser pass).
;
; WHAT IS ALREADY WRITTEN (do not touch): the reader/AST representation, the
; reused reader, parse-program + its helpers, the canonical Program dumper, and
; file IO — copied verbatim from the COMPLETED parser pass. The loader port (LS /
; process-forms / load-program …) is copied from the completed loader pass. WHAT
; YOU IMPLEMENT: the resolve/qualify logic, ported FAITHFULLY from src/resolve.rs.
(module selfhost.resolver)

(import "lib/alloc.coil"     :use *)
(import "lib/result.coil"    :use *)
(import "lib/slice.coil"     :use *)
(import "lib/str.coil"       :use *)
(import "lib/arraylist.coil" :use *)
(import "lib/io.coil"        :use *)
(import "lib/control.coil"   :use *)
(import "lib/try.coil"       :use *)

; ---- libc the self-host tool needs ------------------------------------------
(extern open     :cc c [(ptr i8) i32] (-> i32))
(extern close    :cc c [i32] (-> i32))
(extern strtod   :cc c [(ptr i8) (ptr (ptr i8))] (-> f64))
(extern realpath :cc c [(ptr i8) (ptr i8)] (-> (ptr i8)))   ; NULL on failure
(extern getcwd   :cc c [(ptr i8) i64] (-> (ptr i8)))

; ============================ reader representation ==========================
; Copied verbatim from selfhost/reader.coil (the reader is a completed pass; the
; parser reuses it to turn source text into Sexp before parsing).
(defsum SexpKind
  (KInt   [(v i64)])
  (KFloat [(bits i64)])
  (KSym   [(s (slice u8))])
  (KKw    [(s (slice u8))])
  (KStr   [(s (slice u8))])
  (KCStr  [(s (slice u8))])
  (KList  [(items (ptr (ArrayList Sexp)))])
  (KVec   [(items (ptr (ArrayList Sexp)))]))

(defstruct Sexp [(kind SexpKind) (lo i64) (hi i64)])

(defsum TokKind
  (TOpen   [(c i64)])
  (TClose  [(c i64)])
  (TPrefix [(s (slice u8))])
  (TStr    [(s (slice u8))])
  (TCStr   [(s (slice u8))])
  (TAtom   [(s (slice u8))]))

(defstruct Tok [(kind TokKind) (lo i64) (hi i64)])
(defstruct Parser [(toks (ptr (ArrayList Tok))) (pos i64)])
(defstruct StrRead [(s (slice u8)) (end i64)])

; ============================ AST representation =============================
; Mirrors src/ast.rs. Recursion goes through (ptr Expr) / (ptr Type) (single
; box) and (ptr (ArrayList X)) (a sequence), like reader.coil/Sexp. Spans live as
; raw i64 lo/hi (dummy = -1), exactly as the reader stores them.

; Type — 14 constructable variants (src/ast.rs Type).
(defsum Type
  (TInt    [(bits i64) (signed bool)])
  (TFloat  [(bits i64)])
  (TBool   [])
  (TVoid   [])
  (TPtr    [(inner (ptr Type))])
  (TRef    [(mutable bool) (inner (ptr Type))])
  (TStruct [(name (slice u8))])
  (TArray  [(elem (ptr Type)) (n i64)])
  (TSlice  [(elem (ptr Type))])
  (TVec    [(elem (ptr Type)) (n i64)])
  (TFn     [(cc (slice u8)) (params (ptr (ArrayList Type))) (ret (ptr Type))])
  (TApp    [(name (slice u8)) (args (ptr (ArrayList Type)))])
  (TNever  [])
  (TCode   []))

; A function parameter (name + type).
(defstruct Param [(name (slice u8)) (ty Type)])
; A struct/variant field (name + type).
(defstruct Field [(name (slice u8)) (ty Type)])

; ExprKind — the 42 variants `parse_program` can PRODUCE (the 6 checker/mono-only
; variants — SpillRef, DynDispatch, MakeDyn, Construct, StaticRef, TraitCall —
; are never produced by the parser, so they are intentionally absent here).
; Numeric op tags: BinOp/CmpOp/Storage/TypeQuery/FieldMeta/CodeOp are stored as
; i64 codes (see the d-*-tag dumpers for the code->string mapping).
(defsum ExprKind
  (EInt       [(v i64)])
  (EStr       [(s (slice u8))])
  (ECStr      [(s (slice u8))])
  (EVar       [(name (slice u8))])
  (EZeroed    [(ty Type)])
  (EBorrow    [(mutable bool) (place (ptr Expr))])
  (ELet       [(binds (ptr (ArrayList Bind))) (body (ptr (ArrayList Expr)))])
  (EBin       [(op i64) (lhs (ptr Expr)) (rhs (ptr Expr))])
  (ENot       [(inner (ptr Expr))])
  (EFloat     [(bits i64)])
  (EBool      [(b bool)])
  (ECmp       [(op i64) (lhs (ptr Expr)) (rhs (ptr Expr))])
  (EIf        [(cnd (ptr Expr)) (thn (ptr Expr)) (els (ptr Expr))])
  (EDo        [(body (ptr (ArrayList Expr)))])
  (ECall      [(func (slice u8)) (type_args (ptr (ArrayList Type))) (args (ptr (ArrayList Expr)))])
  (EAlloc     [(storage i64) (ty Type)])
  (EField     [(p (ptr Expr)) (fname (slice u8))])
  (ELoad      [(inner (ptr Expr))])
  (EStore     [(p (ptr Expr)) (val (ptr Expr))])
  (EIndex     [(p (ptr Expr)) (idx (ptr Expr))])
  (ECast      [(ty Type) (inner (ptr Expr))])
  (ESizeOf    [(ty Type)])
  (EAlignOf   [(ty Type)])
  (EOffsetOf  [(ty Type) (fname (slice u8))])
  (EBitGet    [(p (ptr Expr)) (fname (slice u8))])
  (EBitSet    [(p (ptr Expr)) (fname (slice u8)) (val (ptr Expr))])
  (EFree      [(inner (ptr Expr))])
  (EErase     [(trait_name (slice u8)) (inner (ptr Expr))])
  (EMatch     [(scrut (ptr Expr)) (arms (ptr (ArrayList Arm)))])
  (EFnPtrOf   [(name (slice u8))])
  (ECallPtr   [(fp (ptr Expr)) (args (ptr (ArrayList Expr)))])
  (ELoop      [(label (Option (slice u8))) (body (ptr (ArrayList Expr)))])
  (EBreak     [(label (Option (slice u8))) (value (Option (ptr Expr)))])
  (EContinue  [(label (Option (slice u8)))])
  (ELlvmIr    [(result Type) (args (ptr (ArrayList Expr))) (body (slice u8))])
  (ETypeQuery [(q i64) (ty Type)])
  (EFieldMeta [(meta i64) (ty Type) (idx (ptr Expr))])
  (EFieldIndex[(ty Type) (name (ptr Expr))])
  (EQuote     [(form (ptr Sexp))])
  (ECodeOp    [(op i64) (args (ptr (ArrayList Expr)))])
  (EQuasi     [(q Quasi)])
  (EComptime  [(inner (ptr Expr))]))

(defstruct Expr [(kind ExprKind) (lo i64) (hi i64)])

; A let binding (name, mutable, value).
(defstruct Bind [(name (slice u8)) (mutable bool) (value Expr)])
; A match arm (variant, bound names, body).
(defstruct Arm [(variant (slice u8)) (binds (ptr (ArrayList (slice u8)))) (body Expr)])

; A quasiquote template node (src/ast.rs Quasi).
(defsum Quasi
  (QLit     [(form (ptr Sexp))])
  (QUnquote [(e (ptr Expr))])
  (QSplice  [(e (ptr Expr))])
  (QList    [(items (ptr (ArrayList Quasi)))])
  (QVector  [(items (ptr (ArrayList Quasi)))]))

; Calling-convention lowering (src/convention.rs).
(defsum Lowering
  (LNative [(cc i64)])   ; cc: 0=c 1=fast 2=cold
  (LShim   []))

(defstruct Convention
  [(name (slice u8))
   (params (ptr (ArrayList (slice u8))))
   (ret (Option (slice u8)))
   (clobber (ptr (ArrayList (slice u8))))
   (preserve (ptr (ArrayList (slice u8))))
   (lowering Lowering)])

; Struct memory layout (src/ast.rs Layout).
(defsum Layout
  (LC       [])
  (LPacked  [])
  (LAligned [(n i64)])
  (LExplicit[(offsets (ptr (ArrayList i64))) (size (Option i64)) (align i64)])
  (LBits    [(backing i64) (offsets (ptr (ArrayList i64)))]))

(defstruct StructDef
  [(name (slice u8))
   (type_params (ptr (ArrayList (slice u8))))
   (layout Layout)
   (fields (ptr (ArrayList Field)))])

(defstruct Variant [(name (slice u8)) (fields (ptr (ArrayList Field)))])
(defstruct SumDef
  [(name (slice u8))
   (type_params (ptr (ArrayList (slice u8))))
   (variants (ptr (ArrayList Variant)))])

(defstruct Extern
  [(name (slice u8)) (cc (slice u8)) (params (ptr (ArrayList Type)))
   (variadic bool) (ret Type)])

; A trait bound on a type parameter (name + required trait names).
(defstruct Bound [(name (slice u8)) (traits (ptr (ArrayList (slice u8))))])

(defstruct Func
  [(name (slice u8))
   (type_params (ptr (ArrayList (slice u8))))
   (bounds (ptr (ArrayList Bound)))
   (cc (slice u8))
   (params (ptr (ArrayList Param)))
   (ret Type)
   (body (ptr (ArrayList Expr)))
   (macro_variadic bool)
   (lo i64) (hi i64)])

(defstruct StaticAssert [(cnd Expr) (msg (slice u8))])
(defstruct Const [(name (slice u8)) (ty (Option Type)) (value Expr)])

(defstruct TraitMethod [(name (slice u8)) (params (ptr (ArrayList Param))) (ret Type)])
(defstruct TraitDef
  [(name (slice u8)) (self_param (slice u8)) (methods (ptr (ArrayList TraitMethod)))])
(defstruct ImplDef
  [(trait_name (slice u8)) (for_type (slice u8)) (methods (ptr (ArrayList Func)))])

(defstruct ExportC
  [(name (slice u8)) (symbol (Option (slice u8))) (params (ptr (ArrayList Type)))
   (lo i64) (hi i64)])

; The whole program (src/ast.rs Program). `statics` is omitted: parsing never
; produces statics (they come from checking), so the dump always emits an empty
; `(statics)` section.
(defstruct Program
  [(conventions (ptr (ArrayList Convention)))
   (structs (ptr (ArrayList StructDef)))
   (sums (ptr (ArrayList SumDef)))
   (externs (ptr (ArrayList Extern)))
   (funcs (ptr (ArrayList Func)))
   (asserts (ptr (ArrayList StaticAssert)))
   (consts (ptr (ArrayList Const)))
   (traits (ptr (ArrayList TraitDef)))
   (impls (ptr (ArrayList ImplDef)))
   (metas (ptr (ArrayList Expr)))
   (exports (ptr (ArrayList ExportC)))])

; A parse/read diagnostic (src/span.rs Diag); dummy span = -1.
(defstruct Diag [(lo i64) (hi i64) (msg (slice u8))])

; ============================ small constructors =============================
(defn mk-sexp [(kind SexpKind) (lo i64) (hi i64)] (-> Sexp)
  (let [p (alloc-stack Sexp)]
    (store! (field p kind) kind) (store! (field p lo) lo) (store! (field p hi) hi)
    (load p)))
(defn mk-tok [(kind TokKind) (lo i64) (hi i64)] (-> Tok)
  (let [p (alloc-stack Tok)]
    (store! (field p kind) kind) (store! (field p lo) lo) (store! (field p hi) hi)
    (load p)))
(defn mk-diag [(lo i64) (hi i64) (msg (slice u8))] (-> Diag)
  (let [p (alloc-stack Diag)]
    (store! (field p lo) lo) (store! (field p hi) hi) (store! (field p msg) msg)
    (load p)))
(defn mk-strread [(s (slice u8)) (end i64)] (-> StrRead)
  (let [p (alloc-stack StrRead)]
    (store! (field p s) s) (store! (field p end) end)
    (load p)))

(defn box-items [(a (ptr Allocator)) (items (ArrayList Sexp))] (-> (ptr (ArrayList Sexp)))
  (let [p (unwrap-ptr [(ArrayList Sexp)] (create [(ArrayList Sexp)] a))]
    (store! p items) p))
(defn box-sexp [(a (ptr Allocator)) (s Sexp)] (-> (ptr Sexp))
  (let [p (unwrap-ptr [Sexp] (create [Sexp] a))] (store! p s) p))
(defn box-expr [(a (ptr Allocator)) (e Expr)] (-> (ptr Expr))
  (let [p (unwrap-ptr [Expr] (create [Expr] a))] (store! p e) p))
(defn box-type [(a (ptr Allocator)) (t Type)] (-> (ptr Type))
  (let [p (unwrap-ptr [Type] (create [Type] a))] (store! p t) p))

(defn mk-expr [(kind ExprKind) (lo i64) (hi i64)] (-> Expr)
  (let [p (alloc-stack Expr)]
    (store! (field p kind) kind) (store! (field p lo) lo) (store! (field p hi) hi)
    (load p)))

; ============================ numeric/string utils ===========================
(defn f64-bits [(x f64)] (-> i64)
  (let [p (alloc-stack f64)] (store! p x) (load (cast (ptr i64) p))))

(defn slice->cstr [(a (ptr Allocator)) (s (slice u8))] (-> (ptr i8))
  (let [n (slice-len s)
        buf (unwrap-ptr [i8] (raw-alloc a (iadd n 1) 1))
        (mut i) 0]
    (loop
      (if (icmp-ge (load i) n) (break)
        (do (store! (index buf (load i)) (cast i8 (slice-get s (load i))))
            (store! i (iadd (load i) 1)))))
    (store! (index buf n) (cast i8 0))
    buf))

; ============================ output primitives ==============================
(defn wb [(w (ptr Writer)) (b i64)] (-> i64) (write-byte w (cast u8 b)) 0)
(defn ps [(w (ptr Writer)) (s (slice u8))] (-> i64) (print-str w s) 0)
(defn hexd [(d i64)] (-> i64) (if (icmp-lt d 10) (iadd d 48) (iadd d 87)))

(defn dump-dec-mag [(w (ptr Writer)) (n i64)] (-> i64)
  (if (icmp-lt n 10)
      (wb w (iadd n 48))
      (do (dump-dec-mag w (udiv n 10)) (wb w (iadd (urem n 10) 48)))))
(defn dump-dec [(w (ptr Writer)) (n i64)] (-> i64)
  (if (icmp-lt n 0)
      (do (wb w 45) (dump-dec-mag w (isub 0 n)))
      (dump-dec-mag w n)))

(defn u-hex16 [(w (ptr Writer)) (n i64)] (-> i64)
  (let [(mut k) 60]
    (loop
      (if (icmp-lt (load k) 0) (break)
        (do (wb w (hexd (iand (ishr n (load k)) 15))) (store! k (isub (load k) 4))))))
  0)

; A span `@lo:hi`, dummy (lo/hi = -1) prints as `@D:…`/`…:D` (mirrors dump_span).
(defn dump-span [(w (ptr Writer)) (lo i64) (hi i64)] (-> i64)
  (wb w 64)
  (if (icmp-lt lo 0) (wb w 68) (dump-dec w lo))
  (wb w 58)
  (if (icmp-lt hi 0) (wb w 68) (dump-dec w hi)))

(defn hex2 [(w (ptr Writer)) (b i64)] (-> i64)
  (wb w (hexd (iand (ishr b 4) 15))) (wb w (hexd (iand b 15))))
(defn esc-write [(w (ptr Writer)) (s (slice u8))] (-> i64)
  (let [(mut i) 0 n (slice-len s)]
    (loop
      (if (icmp-ge (load i) n) (break)
        (do (let [b (cast i64 (slice-get s (load i)))]
              (if (icmp-eq b 92) (ps w "\\\\")
              (if (icmp-eq b 34) (ps w "\\\"")
              (if (icmp-eq b 10) (ps w "\\n")
              (if (icmp-eq b 9)  (ps w "\\t")
              (if (icmp-eq b 13) (ps w "\\r")
              (if (and (icmp-ge b 32) (icmp-le b 126)) (wb w b)
              (do (ps w "\\x") (hex2 w b)))))))))
            (store! i (iadd (load i) 1))))))
  0)
; A quoted string `"<escaped>"`.
(defn dstr [(w (ptr Writer)) (s (slice u8))] (-> i64)
  (wb w 34) (esc-write w s) (wb w 34))
; A bool as '1'/'0'.
(defn dbool [(w (ptr Writer)) (b bool)] (-> i64) (if b (wb w 49) (wb w 48)))

; ============================ Sexp canonical dump (for quote) =================
; Mirrors src/reader.rs dump_node (reused by EQuote / QLit). Identical to
; selfhost/reader.coil's dumper.
(defn sx-atom [(w (ptr Writer)) (tag (slice u8)) (s (slice u8)) (lo i64) (hi i64)] (-> i64)
  (wb w 40) (ps w tag) (dump-span w lo hi) (ps w " \"") (esc-write w s) (ps w "\")"))
(defn sx-seq [(w (ptr Writer)) (tag (slice u8)) (items (ptr (ArrayList Sexp))) (lo i64) (hi i64)] (-> i64)
  (wb w 40) (ps w tag) (dump-span w lo hi)
  (let [(mut i) 0 n (al-len [Sexp] (load items))]
    (loop
      (if (icmp-ge (load i) n) (break)
        (do (wb w 32)
            (let [child (alloc-stack Sexp)]
              (store! child (al-get [Sexp] (load items) (load i)))
              (sx-node w child))
            (store! i (iadd (load i) 1))))))
  (wb w 41))
(defn sx-node [(w (ptr Writer)) (x (ptr Sexp))] (-> i64)
  (let [lo (load (field x lo)) hi (load (field x hi))]
    (match (load (field x kind))
      (KInt   [v]     (do (ps w "(int") (dump-span w lo hi) (wb w 32) (dump-dec w v) (wb w 41)))
      (KFloat [bits]  (do (ps w "(float") (dump-span w lo hi) (ps w " 0x") (u-hex16 w bits) (wb w 41)))
      (KSym   [s]     (sx-atom w "sym" s lo hi))
      (KKw    [s]     (sx-atom w "kw" s lo hi))
      (KStr   [s]     (sx-atom w "str" s lo hi))
      (KCStr  [s]     (sx-atom w "cstr" s lo hi))
      (KList  [items] (sx-seq w "list" items lo hi))
      (KVec   [items] (sx-seq w "vec" items lo hi)))))

; ============================ AST canonical dump =============================
; Mirrors src/dump_ast.rs EXACTLY. Every helper corresponds to a Rust dumper.

; `["a" "b"]` — a vector of strings.
(defn d-strs [(w (ptr Writer)) (v (ptr (ArrayList (slice u8))))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [(slice u8)] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (dstr w (al-get [(slice u8)] (load v) (load i)))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

; `(some "x")` / `(none)` — an optional string.
(defn d-opt-str [(w (ptr Writer)) (v (Option (slice u8)))] (-> i64)
  (match v
    (Some [s] (do (ps w "(some ") (dstr w s) (wb w 41)))
    (None []  (ps w "(none)"))))

; ---- types ----
(defn d-types [(w (ptr Writer)) (v (ptr (ArrayList Type)))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Type] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [t (alloc-stack Type)] (store! t (al-get [Type] (load v) (load i))) (d-type w t))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

(defn d-type [(w (ptr Writer)) (t (ptr Type))] (-> i64)
  (match (load t)
    (TInt   [bits signed] (do (ps w "(int ") (dump-dec w bits) (wb w 32) (dbool w signed) (wb w 41)))
    (TFloat [bits]        (do (ps w "(float ") (dump-dec w bits) (wb w 41)))
    (TBool  []            (ps w "bool"))
    (TVoid  []            (ps w "void"))
    (TPtr   [inner]       (do (ps w "(ptr ") (d-type w inner) (wb w 41)))
    (TRef   [m inner]     (do (ps w "(ref ") (dbool w m) (wb w 32) (d-type w inner) (wb w 41)))
    (TStruct[name]        (do (ps w "(struct ") (dstr w name) (wb w 41)))
    (TArray [elem n]      (do (ps w "(array ") (d-type w elem) (wb w 32) (dump-dec w n) (wb w 41)))
    (TSlice [elem]        (do (ps w "(slice ") (d-type w elem) (wb w 41)))
    (TVec   [elem n]      (do (ps w "(vec ") (d-type w elem) (wb w 32) (dump-dec w n) (wb w 41)))
    (TFn    [cc params ret] (do (ps w "(fn ") (dstr w cc) (wb w 32) (d-types w params) (wb w 32) (d-type w ret) (wb w 41)))
    (TApp   [name args]   (do (ps w "(app ") (dstr w name) (wb w 32) (d-types w args) (wb w 41)))
    (TNever []            (ps w "never"))
    (TCode  []            (ps w "code"))))

; ---- enum-tag dumpers (i64 code -> string, mirrors *_tag in dump_ast.rs) ----
(defn d-binop [(w (ptr Writer)) (op i64)] (-> i64)
  (ps w (if (icmp-eq op 0) "add" (if (icmp-eq op 1) "sub" (if (icmp-eq op 2) "mul"
        (if (icmp-eq op 3) "div" (if (icmp-eq op 4) "rem" (if (icmp-eq op 5) "udiv"
        (if (icmp-eq op 6) "urem" (if (icmp-eq op 7) "and" (if (icmp-eq op 8) "or"
        (if (icmp-eq op 9) "xor" (if (icmp-eq op 10) "shl" "shr")))))))))))))
(defn d-cmpop [(w (ptr Writer)) (op i64)] (-> i64)
  (ps w (if (icmp-eq op 0) "lt" (if (icmp-eq op 1) "le" (if (icmp-eq op 2) "gt"
        (if (icmp-eq op 3) "ge" (if (icmp-eq op 4) "eq" "ne")))))))
(defn d-storage [(w (ptr Writer)) (s i64)] (-> i64)
  (ps w (if (icmp-eq s 0) "stack" (if (icmp-eq s 1) "static" "heap"))))
(defn d-typequery [(w (ptr Writer)) (q i64)] (-> i64)
  (ps w (if (icmp-eq q 0) "fieldcount" (if (icmp-eq q 1) "variantcount"
        (if (icmp-eq q 2) "isstruct" (if (icmp-eq q 3) "issum" (if (icmp-eq q 4) "isint"
        (if (icmp-eq q 5) "isfloat" (if (icmp-eq q 6) "isptr" "isarray")))))))))
(defn d-fieldmeta [(w (ptr Writer)) (m i64)] (-> i64)
  (ps w (if (icmp-eq m 0) "name" (if (icmp-eq m 1) "typekind" "typename"))))
(defn d-codeop [(w (ptr Writer)) (op i64)] (-> i64)
  (ps w (if (icmp-eq op 0) "islist" (if (icmp-eq op 1) "issym" (if (icmp-eq op 2) "isint"
        (if (icmp-eq op 3) "count" (if (icmp-eq op 4) "nth" (if (icmp-eq op 5) "sym"
        (if (icmp-eq op 6) "int" (if (icmp-eq op 7) "rest" (if (icmp-eq op 8) "gensym"
        (if (icmp-eq op 9) "error" (if (icmp-eq op 10) "eq" (if (icmp-eq op 11) "iskeyword"
        (if (icmp-eq op 12) "symbol" (if (icmp-eq op 13) "str" (if (icmp-eq op 14) "cfieldcount"
        (if (icmp-eq op 15) "cfieldname" (if (icmp-eq op 16) "cfieldkind" (if (icmp-eq op 17) "cfieldtype"
        (if (icmp-eq op 18) "cvariantsum" (if (icmp-eq op 19) "cvariantcount" (if (icmp-eq op 20) "cvariantname"
        (if (icmp-eq op 21) "cvariantfields" (if (icmp-eq op 22) "ctraitmethodcount" (if (icmp-eq op 23) "ctraitmethodname"
        (if (icmp-eq op 24) "ctraitarity" (if (icmp-eq op 25) "ctraitparamname" (if (icmp-eq op 26) "ctraitparamtype"
        (if (icmp-eq op 27) "ctraitrettype" (if (icmp-eq op 28) "strbytes" (if (icmp-eq op 29) "bytestostr"
        "targetarch"))))))))))))))))))))))))))))))))

; ---- exprs ----
(defn d-exprs [(w (ptr Writer)) (v (ptr (ArrayList Expr)))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Expr] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [e (alloc-stack Expr)] (store! e (al-get [Expr] (load v) (load i))) (d-expr w e))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

(defn d-opt-expr [(w (ptr Writer)) (v (Option (ptr Expr)))] (-> i64)
  (match v
    (Some [e] (do (ps w "(some ") (d-expr w e) (wb w 41)))
    (None []  (ps w "(none)"))))

(defn d-binds [(w (ptr Writer)) (v (ptr (ArrayList Bind)))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Bind] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [b (alloc-stack Bind)]
            (store! b (al-get [Bind] (load v) (load i)))
            (ps w "(bind ") (dstr w (load (field b name))) (wb w 32)
            (dbool w (load (field b mutable))) (wb w 32)
            (let [ve (alloc-stack Expr)] (store! ve (load (field b value))) (d-expr w ve))
            (wb w 41))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

(defn d-arms [(w (ptr Writer)) (v (ptr (ArrayList Arm)))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Arm] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [a (alloc-stack Arm)]
            (store! a (al-get [Arm] (load v) (load i)))
            (ps w "(arm ") (dstr w (load (field a variant))) (wb w 32)
            (d-strs w (load (field a binds))) (wb w 32)
            (let [be (alloc-stack Expr)] (store! be (load (field a body))) (d-expr w be))
            (wb w 41))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

(defn d-quasi [(w (ptr Writer)) (q (ptr Quasi))] (-> i64)
  (match (load q)
    (QLit     [form] (do (ps w "(qlit ") (sx-node w form) (wb w 41)))
    (QUnquote [e]    (do (ps w "(qunq ") (d-expr w e) (wb w 41)))
    (QSplice  [e]    (do (ps w "(qspl ") (d-expr w e) (wb w 41)))
    (QList    [items] (do (ps w "(qlist")
                          (let [(mut i) 0 n (al-len [Quasi] (load items))]
                            (loop (if (icmp-ge (load i) n) (break)
                              (do (wb w 32)
                                  (let [c (alloc-stack Quasi)] (store! c (al-get [Quasi] (load items) (load i))) (d-quasi w c))
                                  (store! i (iadd (load i) 1))))))
                          (wb w 41)))
    (QVector  [items] (do (ps w "(qvec")
                          (let [(mut i) 0 n (al-len [Quasi] (load items))]
                            (loop (if (icmp-ge (load i) n) (break)
                              (do (wb w 32)
                                  (let [c (alloc-stack Quasi)] (store! c (al-get [Quasi] (load items) (load i))) (d-quasi w c))
                                  (store! i (iadd (load i) 1))))))
                          (wb w 41)))))

(defn d-expr [(w (ptr Writer)) (e (ptr Expr))] (-> i64)
  (let [lo (load (field e lo)) hi (load (field e hi))]
    (wb w 40)
    (match (load (field e kind))
      (EInt   [v]    (do (ps w "eint") (dump-span w lo hi) (wb w 32) (dump-dec w v)))
      (EFloat [bits] (do (ps w "efloat") (dump-span w lo hi) (ps w " 0x") (u-hex16 w bits)))
      (EBool  [b]    (do (ps w "ebool") (dump-span w lo hi) (wb w 32) (dbool w b)))
      (EStr   [s]    (do (ps w "estr") (dump-span w lo hi) (wb w 32) (dstr w s)))
      (ECStr  [s]    (do (ps w "ecstr") (dump-span w lo hi) (wb w 32) (dstr w s)))
      (EVar   [name] (do (ps w "var") (dump-span w lo hi) (wb w 32) (dstr w name)))
      (EZeroed[ty]   (do (ps w "zeroed") (dump-span w lo hi) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t))))
      (EBorrow[m place] (do (ps w "borrow") (dump-span w lo hi) (wb w 32) (dbool w m) (wb w 32) (d-expr w place)))
      (ELet   [binds body] (do (ps w "let") (dump-span w lo hi) (wb w 32) (d-binds w binds) (wb w 32) (d-exprs w body)))
      (EBin   [op lhs rhs] (do (ps w "bin") (dump-span w lo hi) (wb w 32) (d-binop w op) (wb w 32) (d-expr w lhs) (wb w 32) (d-expr w rhs)))
      (ENot   [inner] (do (ps w "inot") (dump-span w lo hi) (wb w 32) (d-expr w inner)))
      (ECmp   [op lhs rhs] (do (ps w "cmp") (dump-span w lo hi) (wb w 32) (d-cmpop w op) (wb w 32) (d-expr w lhs) (wb w 32) (d-expr w rhs)))
      (EIf    [cnd thn els] (do (ps w "if") (dump-span w lo hi) (wb w 32) (d-expr w cnd) (wb w 32) (d-expr w thn) (wb w 32) (d-expr w els)))
      (EDo    [body] (do (ps w "do") (dump-span w lo hi) (wb w 32) (d-exprs w body)))
      (ECall  [func type_args args] (do (ps w "call") (dump-span w lo hi) (wb w 32) (dstr w func) (wb w 32) (d-types w type_args) (wb w 32) (d-exprs w args)))
      (EAlloc [storage ty] (do (ps w "alloc") (dump-span w lo hi) (wb w 32) (d-storage w storage) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t))))
      (EField [p fname] (do (ps w "field") (dump-span w lo hi) (wb w 32) (d-expr w p) (wb w 32) (dstr w fname)))
      (ELoad  [inner] (do (ps w "load") (dump-span w lo hi) (wb w 32) (d-expr w inner)))
      (EStore [p val] (do (ps w "store") (dump-span w lo hi) (wb w 32) (d-expr w p) (wb w 32) (d-expr w val)))
      (EIndex [p idx] (do (ps w "index") (dump-span w lo hi) (wb w 32) (d-expr w p) (wb w 32) (d-expr w idx)))
      (ECast  [ty inner] (do (ps w "cast") (dump-span w lo hi) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t)) (wb w 32) (d-expr w inner)))
      (ESizeOf[ty] (do (ps w "sizeof") (dump-span w lo hi) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t))))
      (EAlignOf[ty] (do (ps w "alignof") (dump-span w lo hi) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t))))
      (EOffsetOf[ty fname] (do (ps w "offsetof") (dump-span w lo hi) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t)) (wb w 32) (dstr w fname)))
      (EBitGet[p fname] (do (ps w "bitget") (dump-span w lo hi) (wb w 32) (d-expr w p) (wb w 32) (dstr w fname)))
      (EBitSet[p fname val] (do (ps w "bitset") (dump-span w lo hi) (wb w 32) (d-expr w p) (wb w 32) (dstr w fname) (wb w 32) (d-expr w val)))
      (EFree  [inner] (do (ps w "free") (dump-span w lo hi) (wb w 32) (d-expr w inner)))
      (EErase [trait_name inner] (do (ps w "erase") (dump-span w lo hi) (wb w 32) (dstr w trait_name) (wb w 32) (d-expr w inner)))
      (EMatch [scrut arms] (do (ps w "match") (dump-span w lo hi) (wb w 32) (d-expr w scrut) (wb w 32) (d-arms w arms)))
      (EFnPtrOf[name] (do (ps w "fnptrof") (dump-span w lo hi) (wb w 32) (dstr w name)))
      (ECallPtr[fp args] (do (ps w "callptr") (dump-span w lo hi) (wb w 32) (d-expr w fp) (wb w 32) (d-exprs w args)))
      (ELoop  [label body] (do (ps w "loop") (dump-span w lo hi) (wb w 32) (d-opt-str w label) (wb w 32) (d-exprs w body)))
      (EBreak [label value] (do (ps w "break") (dump-span w lo hi) (wb w 32) (d-opt-str w label) (wb w 32) (d-opt-expr w value)))
      (EContinue[label] (do (ps w "continue") (dump-span w lo hi) (wb w 32) (d-opt-str w label)))
      (ELlvmIr[result args body] (do (ps w "llvmir") (dump-span w lo hi) (wb w 32) (let [t (alloc-stack Type)] (store! t result) (d-type w t)) (wb w 32) (d-exprs w args) (wb w 32) (dstr w body)))
      (ETypeQuery[q ty] (do (ps w "typequery") (dump-span w lo hi) (wb w 32) (d-typequery w q) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t))))
      (EFieldMeta[meta ty idx] (do (ps w "fieldmeta") (dump-span w lo hi) (wb w 32) (d-fieldmeta w meta) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t)) (wb w 32) (d-expr w idx)))
      (EFieldIndex[ty name] (do (ps w "fieldindex") (dump-span w lo hi) (wb w 32) (let [t (alloc-stack Type)] (store! t ty) (d-type w t)) (wb w 32) (d-expr w name)))
      (EQuote [form] (do (ps w "quote") (dump-span w lo hi) (wb w 32) (sx-node w form)))
      (ECodeOp[op args] (do (ps w "codeop") (dump-span w lo hi) (wb w 32) (d-codeop w op) (wb w 32) (d-exprs w args)))
      (EQuasi [q] (do (ps w "quasi") (dump-span w lo hi) (wb w 32) (let [qp (alloc-stack Quasi)] (store! qp q) (d-quasi w qp))))
      (EComptime[inner] (do (ps w "comptime") (dump-span w lo hi) (wb w 32) (d-expr w inner))))
    (wb w 41)))

; ---- declarations ----
(defn d-param [(w (ptr Writer)) (p (ptr Param))] (-> i64)
  (ps w "(param ") (dstr w (load (field p name))) (wb w 32)
  (let [t (alloc-stack Type)] (store! t (load (field p ty))) (d-type w t)) (wb w 41))
(defn d-params [(w (ptr Writer)) (v (ptr (ArrayList Param)))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Param] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [p (alloc-stack Param)] (store! p (al-get [Param] (load v) (load i))) (d-param w p))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

(defn d-field [(w (ptr Writer)) (f (ptr Field))] (-> i64)
  (ps w "(fld ") (dstr w (load (field f name))) (wb w 32)
  (let [t (alloc-stack Type)] (store! t (load (field f ty))) (d-type w t)) (wb w 41))
(defn d-fields [(w (ptr Writer)) (v (ptr (ArrayList Field)))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Field] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [f (alloc-stack Field)] (store! f (al-get [Field] (load v) (load i))) (d-field w f))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

(defn d-i64s [(w (ptr Writer)) (v (ptr (ArrayList i64)))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [i64] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (dump-dec w (al-get [i64] (load v) (load i)))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

(defn d-bounds [(w (ptr Writer)) (v (ptr (ArrayList Bound)))] (-> i64)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Bound] (load v))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [b (alloc-stack Bound)]
            (store! b (al-get [Bound] (load v) (load i)))
            (ps w "(bound ") (dstr w (load (field b name))) (wb w 32)
            (d-strs w (load (field b traits))) (wb w 41))
          (store! i (iadd (load i) 1))))))
  (wb w 93))

(defn d-func [(w (ptr Writer)) (f (ptr Func))] (-> i64)
  (ps w "(func ") (dstr w (load (field f name))) (wb w 32)
  (d-strs w (load (field f type_params))) (wb w 32)
  (d-bounds w (load (field f bounds))) (wb w 32)
  (dstr w (load (field f cc))) (wb w 32)
  (d-params w (load (field f params))) (wb w 32)
  (let [t (alloc-stack Type)] (store! t (load (field f ret))) (d-type w t)) (wb w 32)
  (d-exprs w (load (field f body))) (wb w 32)
  (dbool w (load (field f macro_variadic))) (wb w 32)
  (dump-span w (load (field f lo)) (load (field f hi))) (wb w 41))

(defn d-convention [(w (ptr Writer)) (c (ptr Convention))] (-> i64)
  (ps w "(cc ") (dstr w (load (field c name))) (wb w 32)
  (d-strs w (load (field c params))) (wb w 32)
  (d-opt-str w (load (field c ret))) (wb w 32)
  (d-strs w (load (field c clobber))) (wb w 32)
  (d-strs w (load (field c preserve))) (wb w 32)
  (match (load (field c lowering))
    (LNative [cc] (do (ps w "(native ") (ps w (if (icmp-eq cc 0) "c" (if (icmp-eq cc 1) "fast" "cold"))) (wb w 41)))
    (LShim   []   (ps w "(shim)")))
  (wb w 41))

(defn d-layout [(w (ptr Writer)) (l (ptr Layout))] (-> i64)
  (match (load l)
    (LC       []   (ps w "(c)"))
    (LPacked  []   (ps w "(packed)"))
    (LAligned [n]  (do (ps w "(aligned ") (dump-dec w n) (wb w 41)))
    (LExplicit[offsets size align]
      (do (ps w "(explicit ") (d-i64s w offsets) (wb w 32)
          (match size (Some [n] (do (ps w "(some ") (dump-dec w n) (wb w 41))) (None [] (ps w "(none)")))
          (wb w 32) (dump-dec w align) (wb w 41)))
    (LBits    [backing offsets]
      (do (ps w "(bits ") (dump-dec w backing) (wb w 32) (d-i64s w offsets) (wb w 41)))))

(defn d-struct [(w (ptr Writer)) (s (ptr StructDef))] (-> i64)
  (ps w "(struct ") (dstr w (load (field s name))) (wb w 32)
  (d-strs w (load (field s type_params))) (wb w 32)
  (let [lp (alloc-stack Layout)] (store! lp (load (field s layout))) (d-layout w lp)) (wb w 32)
  (d-fields w (load (field s fields))) (wb w 41))

(defn d-variant [(w (ptr Writer)) (vr (ptr Variant))] (-> i64)
  (ps w "(variant ") (dstr w (load (field vr name))) (wb w 32)
  (d-fields w (load (field vr fields))) (wb w 41))
(defn d-sum [(w (ptr Writer)) (s (ptr SumDef))] (-> i64)
  (ps w "(sum ") (dstr w (load (field s name))) (wb w 32)
  (d-strs w (load (field s type_params))) (wb w 32)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Variant] (load (field s variants)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [vr (alloc-stack Variant)] (store! vr (al-get [Variant] (load (field s variants)) (load i))) (d-variant w vr))
          (store! i (iadd (load i) 1))))))
  (wb w 93) (wb w 41))

(defn d-extern [(w (ptr Writer)) (e (ptr Extern))] (-> i64)
  (ps w "(extern ") (dstr w (load (field e name))) (wb w 32)
  (dstr w (load (field e cc))) (wb w 32)
  (d-types w (load (field e params))) (wb w 32)
  (dbool w (load (field e variadic))) (wb w 32)
  (let [t (alloc-stack Type)] (store! t (load (field e ret))) (d-type w t)) (wb w 41))

(defn d-assert [(w (ptr Writer)) (a (ptr StaticAssert))] (-> i64)
  (ps w "(assert ")
  (let [ce (alloc-stack Expr)] (store! ce (load (field a cnd))) (d-expr w ce)) (wb w 32)
  (dstr w (load (field a msg))) (wb w 41))

(defn d-const [(w (ptr Writer)) (c (ptr Const))] (-> i64)
  (ps w "(const ") (dstr w (load (field c name))) (wb w 32)
  (match (load (field c ty))
    (Some [t] (do (ps w "(some ") (let [tp (alloc-stack Type)] (store! tp t) (d-type w tp)) (wb w 41)))
    (None []  (ps w "(none)")))
  (wb w 32)
  (let [ve (alloc-stack Expr)] (store! ve (load (field c value))) (d-expr w ve)) (wb w 41))

(defn d-trait [(w (ptr Writer)) (t (ptr TraitDef))] (-> i64)
  (ps w "(trait ") (dstr w (load (field t name))) (wb w 32)
  (dstr w (load (field t self_param))) (wb w 32)
  (wb w 91)
  (let [(mut i) 0 n (al-len [TraitMethod] (load (field t methods)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [m (alloc-stack TraitMethod)]
            (store! m (al-get [TraitMethod] (load (field t methods)) (load i)))
            (ps w "(method ") (dstr w (load (field m name))) (wb w 32)
            (d-params w (load (field m params))) (wb w 32)
            (let [rt (alloc-stack Type)] (store! rt (load (field m ret))) (d-type w rt)) (wb w 41))
          (store! i (iadd (load i) 1))))))
  (wb w 93) (wb w 41))

(defn d-impl [(w (ptr Writer)) (im (ptr ImplDef))] (-> i64)
  (ps w "(impl ") (dstr w (load (field im trait_name))) (wb w 32)
  (dstr w (load (field im for_type))) (wb w 32)
  (wb w 91)
  (let [(mut i) 0 n (al-len [Func] (load (field im methods)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (wb w 32) 0)
          (let [f (alloc-stack Func)] (store! f (al-get [Func] (load (field im methods)) (load i))) (d-func w f))
          (store! i (iadd (load i) 1))))))
  (wb w 93) (wb w 41))

(defn d-export [(w (ptr Writer)) (e (ptr ExportC))] (-> i64)
  (ps w "(export ") (dstr w (load (field e name))) (wb w 32)
  (d-opt-str w (load (field e symbol))) (wb w 32)
  (d-types w (load (field e params))) (wb w 32)
  (dump-span w (load (field e lo)) (load (field e hi))) (wb w 41))

; Byte-lexicographic `<` on strings (Rust String Ord over ASCII conv names):
; a proper prefix is less than the longer string.
(defn str-lt [(x (slice u8)) (y (slice u8))] (-> bool)
  (let [nx (slice-len x) ny (slice-len y) (mut i) 0 (mut res) 0]
    (loop (if (or (icmp-ge (load i) nx) (icmp-ge (load i) ny)) (break)
      (let [cx (cast i64 (slice-get x (load i))) cy (cast i64 (slice-get y (load i)))]
        (if (icmp-lt cx cy) (do (store! res 1) (break))
          (if (icmp-gt cx cy) (do (store! res 2) (break))
            (store! i (iadd (load i) 1)))))))
    (if (icmp-eq (load res) 1) true (if (icmp-eq (load res) 2) false (icmp-lt nx ny)))))
(defn conv-name [(c Convention)] (-> (slice u8))
  (let [p (alloc-stack Convention)] (store! p c) (load (field p name))))

; A whole-section dumper: `(<tag>` then a space+item per element, then `)`.
; Mirrors dump_program's per-section loops.
(defn d-program [(w (ptr Writer)) (p (ptr Program)) (a (ptr Allocator))] (-> i64)
  ; conventions — sorted by name (mirrors dump_program's keys().sort()).
  (ps w "(conventions")
  (let [convs (load (field p conventions)) n (al-len [Convention] convs) (mut used) (al-new [bool] a) (mut k) 0]
    (loop (if (icmp-ge (load k) n) (break) (do (al-push! (mut used) false) (store! k (iadd (load k) 1)))))
    (let [(mut c) 0]
      (loop (if (icmp-ge (load c) n) (break)
        (do (let [(mut best) -1 (mut bi) 0]
              (loop (if (icmp-ge (load bi) n) (break)
                (do (if (not (al-get [bool] (load used) (load bi)))
                        (if (or (icmp-lt (load best) 0)
                                (str-lt (conv-name (al-get [Convention] convs (load bi))) (conv-name (al-get [Convention] convs (load best)))))
                            (store! best (load bi)) 0) 0)
                    (store! bi (iadd (load bi) 1)))))
              (al-set! [bool] (mut used) (load best) true)
              (wb w 32)
              (let [cc (alloc-stack Convention)] (store! cc (al-get [Convention] convs (load best))) (d-convention w cc)))
            (store! c (iadd (load c) 1)))))))
  (wb w 41)
  (ps w "\n(structs")
  (let [(mut i) 0 n (al-len [StructDef] (load (field p structs)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [s (alloc-stack StructDef)] (store! s (al-get [StructDef] (load (field p structs)) (load i))) (d-struct w s))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(sums")
  (let [(mut i) 0 n (al-len [SumDef] (load (field p sums)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [s (alloc-stack SumDef)] (store! s (al-get [SumDef] (load (field p sums)) (load i))) (d-sum w s))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(externs")
  (let [(mut i) 0 n (al-len [Extern] (load (field p externs)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [e (alloc-stack Extern)] (store! e (al-get [Extern] (load (field p externs)) (load i))) (d-extern w e))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(funcs")
  (let [(mut i) 0 n (al-len [Func] (load (field p funcs)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [f (alloc-stack Func)] (store! f (al-get [Func] (load (field p funcs)) (load i))) (d-func w f))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(asserts")
  (let [(mut i) 0 n (al-len [StaticAssert] (load (field p asserts)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [a (alloc-stack StaticAssert)] (store! a (al-get [StaticAssert] (load (field p asserts)) (load i))) (d-assert w a))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(consts")
  (let [(mut i) 0 n (al-len [Const] (load (field p consts)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [c (alloc-stack Const)] (store! c (al-get [Const] (load (field p consts)) (load i))) (d-const w c))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(traits")
  (let [(mut i) 0 n (al-len [TraitDef] (load (field p traits)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [t (alloc-stack TraitDef)] (store! t (al-get [TraitDef] (load (field p traits)) (load i))) (d-trait w t))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(impls")
  (let [(mut i) 0 n (al-len [ImplDef] (load (field p impls)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [im (alloc-stack ImplDef)] (store! im (al-get [ImplDef] (load (field p impls)) (load i))) (d-impl w im))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(statics)")
  (ps w "\n(metas")
  (let [(mut i) 0 n (al-len [Expr] (load (field p metas)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [m (alloc-stack Expr)] (store! m (al-get [Expr] (load (field p metas)) (load i))) (d-expr w m))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  (ps w "\n(exports")
  (let [(mut i) 0 n (al-len [ExportC] (load (field p exports)))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (wb w 32) (let [e (alloc-stack ExportC)] (store! e (al-get [ExportC] (load (field p exports)) (load i))) (d-export w e))
          (store! i (iadd (load i) 1))))))
  (wb w 41)
  0)

; ============================ the PORT (implement these) =====================
; Each stub HARD-ABORTS (never a silent wrong value). Replace the body with a
; faithful port of the same-named function in src/parse.rs.
(defn unimplemented [(who (slice u8))] (-> i64)
  (let [w (stderr)] (ps w "UNIMPLEMENTED: ") (ps w who) (wb w 10))
  (abort) 0)

; ---- generic boxing + string helpers ----
(defn box-al [T] [(a (ptr Allocator)) (l (ArrayList T))] (-> (ptr (ArrayList T)))
  (let [p (unwrap-ptr [(ArrayList T)] (create [(ArrayList T)] a))] (store! p l) p))
(defn sconcat [(a (ptr Allocator)) (x (slice u8)) (y (slice u8))] (-> (slice u8))
  (match (str-concat a x y) (Some [v] v) (None [] "")))
(defn sconcat3 [(a (ptr Allocator)) (x (slice u8)) (y (slice u8)) (z (slice u8))] (-> (slice u8))
  (sconcat a (sconcat a x y) z))
(defn push-mag [(buf (mut (ArrayList u8))) (n i64)] (-> i64)
  (if (icmp-lt n 10) (al-push! (mut buf) (cast u8 (iadd n 48)))
      (do (push-mag (mut buf) (udiv n 10)) (al-push! (mut buf) (cast u8 (iadd (urem n 10) 48))))))
(defn i64->str [(a (ptr Allocator)) (n i64)] (-> (slice u8))
  (let [(mut buf) (al-new [u8] a)]
    (if (icmp-lt n 0) (do (al-push! (mut buf) (cast u8 45)) (push-mag (mut buf) (isub 0 n))) (push-mag (mut buf) n))
    (al-slice [u8] (load buf))))
(defn char1 [(a (ptr Allocator)) (c i64)] (-> (slice u8))
  (slice-new [u8] (let [cb (cast (ptr u8) (unwrap-ptr [i8] (raw-alloc a 1 1)))] (store! (index cb 0) (cast u8 c)) cb) 1))

; ---- Sexp inspection (one match -> a flat info struct) ----
(defstruct SxInfo [(tag i64) (ival i64) (sval (slice u8)) (items (ptr (ArrayList Sexp)))])
(defn sx-info [(s Sexp)] (-> SxInfo)
  (let [sp (alloc-stack Sexp) p (alloc-stack SxInfo)]
    (store! sp s)
    (store! (field p ival) 0) (store! (field p sval) "") (store! (field p items) (zeroed (ptr (ArrayList Sexp))))
    (match (load (field sp kind))
      (KInt   [v]  (do (store! (field p tag) 0) (store! (field p ival) v) 0))
      (KFloat [b]  (do (store! (field p tag) 1) (store! (field p ival) b) 0))
      (KSym   [x]  (do (store! (field p tag) 2) (store! (field p sval) x) 0))
      (KKw    [x]  (do (store! (field p tag) 3) (store! (field p sval) x) 0))
      (KStr   [x]  (do (store! (field p tag) 4) (store! (field p sval) x) 0))
      (KCStr  [x]  (do (store! (field p tag) 5) (store! (field p sval) x) 0))
      (KList  [it] (do (store! (field p tag) 6) (store! (field p items) it) 0))
      (KVec   [it] (do (store! (field p tag) 7) (store! (field p items) it) 0)))
    (load p)))
(defn sx-tag   [(s Sexp)] (-> i64) (let [p (alloc-stack SxInfo)] (store! p (sx-info s)) (load (field p tag))))
(defn sx-ival  [(s Sexp)] (-> i64) (let [p (alloc-stack SxInfo)] (store! p (sx-info s)) (load (field p ival))))
(defn sx-sval  [(s Sexp)] (-> (slice u8)) (let [p (alloc-stack SxInfo)] (store! p (sx-info s)) (load (field p sval))))
(defn sx-items [(s Sexp)] (-> (ptr (ArrayList Sexp))) (let [p (alloc-stack SxInfo)] (store! p (sx-info s)) (load (field p items))))
(defn sx-lo [(s Sexp)] (-> i64) (let [p (alloc-stack Sexp)] (store! p s) (load (field p lo))))
(defn sx-hi [(s Sexp)] (-> i64) (let [p (alloc-stack Sexp)] (store! p s) (load (field p hi))))
(defn sx-len [(l (ptr (ArrayList Sexp)))] (-> i64) (al-len [Sexp] (load l)))
(defn sx-at  [(l (ptr (ArrayList Sexp))) (i i64)] (-> Sexp) (al-get [Sexp] (load l) i))
(defn sx-get [(l (ptr (ArrayList Sexp))) (i i64)] (-> (Option Sexp))
  (if (or (icmp-lt i 0) (icmp-ge i (sx-len l))) (None [Sexp]) (Some (sx-at l i))))
(defn rest-from [(a (ptr Allocator)) (l (ptr (ArrayList Sexp))) (start i64)] (-> (ptr (ArrayList Sexp)))
  (let [(mut out) (al-new [Sexp] a) n (sx-len l) (mut i) start]
    (loop (if (icmp-ge (load i) n) (break) (do (al-push! (mut out) (sx-at l (load i))) (store! i (iadd (load i) 1)))))
    (box-al [Sexp] a (load out))))

; small Option<Sexp> predicates
(defn opt-is-vec [(o (Option Sexp))] (-> bool) (match o (Some [s] (icmp-eq (sx-tag s) 7)) (None [] false)))
(defn opt-get [(o (Option Sexp))] (-> Sexp) (match o (Some [s] s) (None [] (zeroed Sexp))))
(defn opt-is-kw [(o (Option Sexp)) (name (slice u8))] (-> bool) (match o (Some [s] (and (icmp-eq (sx-tag s) 3) (str-eq (sx-sval s) name))) (None [] false)))
(defn opt-is-pos-int [(o (Option Sexp))] (-> bool) (match o (Some [s] (and (icmp-eq (sx-tag s) 0) (icmp-gt (sx-ival s) 0))) (None [] false)))
(defn opt-int [(o (Option Sexp))] (-> i64) (match o (Some [s] (sx-ival s)) (None [] 0)))
(defn opt-is-str [(o (Option Sexp))] (-> bool) (match o (Some [s] (icmp-eq (sx-tag s) 4)) (None [] false)))
(defn opt-str-val [(o (Option Sexp))] (-> (slice u8)) (match o (Some [s] (sx-sval s)) (None [] "")))

; ---- Sexp Display (src/reader.rs Display), for error interpolation ----
(defn sexp-display [(a (ptr Allocator)) (s Sexp)] (-> (slice u8))
  (let [tg (sx-tag s)]
    (if (icmp-eq tg 0) (i64->str a (sx-ival s))
    (if (icmp-eq tg 2) (sx-sval s)
    (if (icmp-eq tg 3) (sconcat a ":" (sx-sval s))
    (if (icmp-eq tg 6) (seq-display a (sx-items s) 40 41)
    (if (icmp-eq tg 7) (seq-display a (sx-items s) 91 93)
      (do (unimplemented "sexp-display/float-str-cstr") ""))))))))
(defn seq-display [(a (ptr Allocator)) (items (ptr (ArrayList Sexp))) (open i64) (close i64)] (-> (slice u8))
  (let [(mut acc) (char1 a open) n (sx-len items) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-gt (load i) 0) (do (store! acc (sconcat a (load acc) " ")) 0) 0)
          (store! acc (sconcat a (load acc) (sexp-display a (sx-at items (load i)))))
          (store! i (iadd (load i) 1)))))
    (sconcat a (load acc) (char1 a close))))

; ---- diagnostics ----
(defn derr    [(msg (slice u8))] (-> Diag) (mk-diag -1 -1 msg))
(defn derr-at [(lo i64) (hi i64) (msg (slice u8))] (-> Diag) (mk-diag lo hi msg))
(defn dwspan  [(d Diag) (lo i64) (hi i64)] (-> Diag)
  (let [p (alloc-stack Diag)] (store! p d)
    (if (icmp-lt (load (field p lo)) 0) (do (store! (field p lo) lo) (store! (field p hi) hi)) 0)
    (load p)))

; ---- Option -> Result with a message (mirrors `.ok_or(msg)?`) ----
(defn need [T] [(o (Option T)) (msg (slice u8))] (-> (Result T Diag))
  (match o (Some [v] (Ok v)) (None [] (Err (derr msg)))))

; ---- matchers (src/parse.rs small helpers) ----
(defn as-list [(s Sexp) (msg (slice u8))] (-> (Result (ptr (ArrayList Sexp)) Diag))
  (if (icmp-eq (sx-tag s) 6) (Ok (sx-items s)) (Err (derr-at (sx-lo s) (sx-hi s) msg))))
(defn head-sym [(a (ptr Allocator)) (items (ptr (ArrayList Sexp)))] (-> (Result (slice u8) Diag))
  (if (icmp-eq (sx-len items) 0) (Err (derr "empty list"))
      (let [h (sx-at items 0)]
        (if (icmp-eq (sx-tag h) 2) (Ok (sx-sval h))
            (Err (derr-at (sx-lo h) (sx-hi h) (sconcat a "expected a symbol head, got " (sexp-display a h))))))))
(defn sym-of [(a (ptr Allocator)) (s Sexp) (what (slice u8))] (-> (Result (slice u8) Diag))
  (if (icmp-eq (sx-tag s) 2) (Ok (sx-sval s))
      (Err (derr-at (sx-lo s) (sx-hi s) (sconcat a what (sconcat a ": expected symbol, got " (sexp-display a s)))))))
(defn kw-of [(a (ptr Allocator)) (s Sexp) (what (slice u8))] (-> (Result (slice u8) Diag))
  (if (icmp-eq (sx-tag s) 3) (Ok (sx-sval s))
      (Err (derr-at (sx-lo s) (sx-hi s) (sconcat a what (sconcat a ": expected keyword, got " (sexp-display a s)))))))
(defn int-val [(a (ptr Allocator)) (s Sexp) (what (slice u8))] (-> (Result i64 Diag))
  (if (icmp-eq (sx-tag s) 0) (Ok (sx-ival s))
      (Err (derr-at (sx-lo s) (sx-hi s) (sconcat a what (sconcat a ": expected an integer, got " (sexp-display a s)))))))
(defn pow2 [(s (Option Sexp))] (-> (Result i64 Diag))
  (match s
    (Some [x] (if (and (icmp-eq (sx-tag x) 0) (let [n (sx-ival x)] (and (icmp-gt n 0) (icmp-eq (iand n (isub n 1)) 0)))) (Ok (sx-ival x)) (Err (derr "alignment must be a positive power of two"))))
    (None [] (Err (derr "alignment must be a positive power of two")))))
(defn sym-vec [(a (ptr Allocator)) (s Sexp) (what (slice u8))] (-> (Result (ptr (ArrayList (slice u8))) Diag))
  (if (icmp-eq (sx-tag s) 7)
      (try (let [items (sx-items s) (mut out) (al-new [(slice u8)] a) n (sx-len items) (mut i) 0]
        (loop (if (icmp-ge (load i) n) (break) (do (al-push! (mut out) (try! (sym-of a (sx-at items (load i)) what))) (store! i (iadd (load i) 1)))))
        (Ok (box-al [(slice u8)] a (load out)))))
      (Err [(ptr (ArrayList (slice u8))) Diag] (derr-at (sx-lo s) (sx-hi s) (sconcat a what (sconcat a ": expected vector, got " (sexp-display a s)))))))
(defn need-vec [(o (Option Sexp)) (msg (slice u8))] (-> (Result (ptr (ArrayList Sexp)) Diag))
  (match o (Some [s] (if (icmp-eq (sx-tag s) 7) (Ok (sx-items s)) (Err (derr msg)))) (None [] (Err (derr msg)))))
(defstruct Two [(x Sexp) (y Sexp)])
(defn need-two [(a (ptr Allocator)) (args (ptr (ArrayList Sexp))) (head (slice u8))] (-> (Result Two Diag))
  (if (icmp-ne (sx-len args) 2) (Err (derr (sconcat a head ": expects exactly 2 arguments")))
      (Ok (let [p (alloc-stack Two)] (store! (field p x) (sx-at args 0)) (store! (field p y) (sx-at args 1)) (load p)))))

; ---- types (src/parse.rs prim_type / int_type / parse_type) ----
(defn type-int-bits [(t Type)] (-> i64)
  (match t (TInt [b s] b) (TFloat [_] -1) (TBool [] -1) (TVoid [] -1) (TPtr [_] -1) (TRef [_ _] -1)
    (TStruct [_] -1) (TArray [_ _] -1) (TSlice [_] -1) (TVec [_ _] -1) (TFn [_ _ _] -1) (TApp [_ _] -1) (TNever [] -1) (TCode [] -1)))
(defn not-int-diag [(a (ptr Allocator)) (name (slice u8))] (-> Diag) (derr (sconcat3 a "not an int type '" name "'")))
(defn int-type [(a (ptr Allocator)) (name (slice u8))] (-> (Result Type Diag))
  (let [n (slice-len name)]
    (if (icmp-eq n 0) (Err (not-int-diag a name))
      (let [c0 (cast i64 (slice-get name 0)) signed (if (icmp-eq c0 105) 1 (if (icmp-eq c0 117) 0 -1))]
        (if (icmp-lt signed 0) (Err (not-int-diag a name))
          (if (icmp-eq n 1) (Err (not-int-diag a name))
            (let [(mut bits) 0 (mut bad) false (mut over) false (mut i) 1]
              (loop (if (icmp-ge (load i) n) (break)
                (let [c (cast i64 (slice-get name (load i)))]
                  (if (and (icmp-ge c 48) (icmp-le c 57))
                      (do (store! bits (iadd (imul (load bits) 10) (isub c 48)))
                          (if (icmp-gt (load bits) 4294967295) (do (store! over true) 0) 0)
                          (store! i (iadd (load i) 1)))
                      (do (store! bad true) (break))))))
              (if (load bad) (Err (not-int-diag a name))
                (if (load over) (Err (derr (sconcat3 a "int width too large in '" name "'")))
                  (if (or (icmp-eq (load bits) 0) (icmp-gt (load bits) 65535))
                      (Err (derr (sconcat3 a "int width out of range in '" name "' (1..=65535)")))
                      (Ok (TInt (load bits) (icmp-eq signed 1)))))))))))))
(defn prim-type [(a (ptr Allocator)) (name (slice u8))] (-> (Result Type Diag))
  (if (str-eq name "f32") (Ok (TFloat 32))
  (if (str-eq name "f64") (Ok (TFloat 64))
  (if (str-eq name "bool") (Ok (TBool))
  (if (str-eq name "void") (Ok (TVoid))
    (int-type a name))))))
(defn parse-types [(a (ptr Allocator)) (items (ptr (ArrayList Sexp)))] (-> (Result (ptr (ArrayList Type)) Diag))
  (try (let [(mut out) (al-new [Type] a) n (sx-len items) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break) (do (al-push! (mut out) (try! (parse-type a (sx-at items (load i))))) (store! i (iadd (load i) 1)))))
    (Ok (box-al [Type] a (load out))))))
(defn parse-type [(a (ptr Allocator)) (s Sexp)] (-> (Result Type Diag))
  (match (parse-type-inner a s)
    (Err [d] (Err (dwspan d (sx-lo s) (sx-hi s))))
    (Ok [t] (Ok t))))
(defn parse-type-inner [(a (ptr Allocator)) (s Sexp)] (-> (Result Type Diag))
  (let [tg (sx-tag s) slo (sx-lo s) shi (sx-hi s)]
    (if (icmp-eq tg 3) (prim-type a (sx-sval s))
    (if (icmp-eq tg 2) (let [k (sx-sval s)] (if (str-eq k "Code") (Ok (TCode)) (match (prim-type a k) (Ok [t] (Ok t)) (Err [_] (Ok (TStruct k))))))
    (if (icmp-eq tg 6) (parse-type-list a (sx-items s))
      (Err (derr-at slo shi (sconcat a "unsupported type: " (sexp-display a s)))))))))
(defn parse-type-list [(a (ptr Allocator)) (items (ptr (ArrayList Sexp)))] (-> (Result Type Diag))
  (try (let [head (try! (head-sym a items))]
    (if (str-eq head "mut")
        (Ok (TRef true (box-type a (try! (parse-type a (try! (need [Sexp] (sx-get items 1) "mut: expects (mut TYPE)")))))))
    (if (str-eq head "ref")
        (Ok (TRef false (box-type a (try! (parse-type a (try! (need [Sexp] (sx-get items 1) "ref: expects (ref TYPE)")))))))
    (if (str-eq head "ptr")
        (Ok (TPtr (box-type a (match (sx-get items 1) (Some [t] (try! (parse-type a t))) (None [] (TInt 64 true))))))
    (if (str-eq head "array")
        (let [elem (box-type a (try! (parse-type a (try! (need [Sexp] (sx-get items 1) "array type: missing element type")))))
              nn (if (opt-is-pos-int (sx-get items 2)) (opt-int (sx-get items 2)) -1)]
          (if (icmp-lt nn 0) (Err [Type Diag] (derr "array type: expected a positive length")) (Ok (TArray elem nn))))
    (if (str-eq head "slice")
        (Ok (TSlice (box-type a (try! (parse-type a (try! (need [Sexp] (sx-get items 1) "slice type: missing element type")))))))
    (if (str-eq head "vec")
        (let [elem (box-type a (try! (parse-type a (try! (need [Sexp] (sx-get items 1) "vec type: missing element type")))))
              nn (if (opt-is-pos-int (sx-get items 2)) (opt-int (sx-get items 2)) -1)]
          (if (icmp-lt nn 0) (Err [Type Diag] (derr "vec type: expected a positive lane count")) (Ok (TVec elem nn))))
    (if (str-eq head "struct")
        (Ok (TStruct (try! (sym-of a (try! (need [Sexp] (sx-get items 1) "struct type: missing name")) "struct name"))))
    (if (str-eq head "dyn")
        (Ok (TStruct (sconcat a (try! (sym-of a (try! (need [Sexp] (sx-get items 1) "dyn type: expected (dyn Trait)")) "dyn trait name")) "-dyn")))
    (if (str-eq head "fnptr")
        (let [cc (try! (sym-of a (try! (need [Sexp] (sx-get items 1) "fnptr type: missing convention")) "fnptr cc"))
              pv (try! (need-vec (sx-get items 2) "fnptr type: expected a vector of parameter types"))
              params (try! (parse-types a pv))
              ret (box-type a (try! (parse-type a (try! (need [Sexp] (sx-get items 3) "fnptr type: missing return type")))))]
          (Ok (TFn cc params ret)))
      (Ok (TApp head (try! (parse-types a (rest-from a items 1)))))))))))))))))

; ---- type parameters (src/parse.rs parse_type_params) ----
(defstruct TPResult [(params (ptr (ArrayList (slice u8)))) (bounds (ptr (ArrayList Bound))) (consumed bool)])
(defn parse-type-params [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp))) (i i64)] (-> (Result TPResult Diag))
  (try (let [a0 (sx-get rest i) a1 (sx-get rest (iadd i 1))]
    (if (not (and (opt-is-vec a0) (opt-is-vec a1)))
        (Ok (let [r (alloc-stack TPResult)]
              (store! (field r params) (box-al [(slice u8)] a (al-new [(slice u8)] a)))
              (store! (field r bounds) (box-al [Bound] a (al-new [Bound] a)))
              (store! (field r consumed) false) (load r)))
        (let [tp (sx-items (opt-get a0)) (mut params) (al-new [(slice u8)] a) (mut bounds) (al-new [Bound] a) n (sx-len tp) (mut k) 0]
          (loop (if (icmp-ge (load k) n) (break)
            (let [entry (sx-at tp (load k))]
              (store! k (iadd (load k) 1))
              (if (icmp-eq (sx-tag entry) 2) (al-push! (mut params) (sx-sval entry))
                (if (icmp-eq (sx-tag entry) 6)
                    (let [eitems (sx-items entry)
                          pname (try! (sym-of a (try! (need [Sexp] (sx-get eitems 0) "type parameter: empty () bound")) "type parameter"))
                          (mut traits) (al-new [(slice u8)] a) tn (sx-len eitems) (mut ti) 1]
                      (loop (if (icmp-ge (load ti) tn) (break) (do (al-push! (mut traits) (try! (sym-of a (sx-at eitems (load ti)) "bound trait"))) (store! ti (iadd (load ti) 1)))))
                      (if (icmp-gt (al-len [(slice u8)] (load traits)) 0)
                          (let [bp (alloc-stack Bound)] (store! (field bp name) pname) (store! (field bp traits) (box-al [(slice u8)] a (load traits))) (al-push! (mut bounds) (load bp))) 0)
                      (al-push! (mut params) pname))
                  (return-from :try (Err [TPResult Diag] (derr-at (sx-lo entry) (sx-hi entry) "type parameter must be a name or (name Trait…)"))))))))
          (Ok (let [r (alloc-stack TPResult)]
                (store! (field r params) (box-al [(slice u8)] a (load params)))
                (store! (field r bounds) (box-al [Bound] a (load bounds)))
                (store! (field r consumed) true) (load r))))))))

; ---- quasiquote (src/parse.rs build_quasi) ----
(defn build-quasi-seq [(a (ptr Allocator)) (items (ptr (ArrayList Sexp))) (isvec bool)] (-> (Result Quasi Diag))
  (try (let [(mut out) (al-new [Quasi] a) n (sx-len items) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break) (do (al-push! (mut out) (try! (build-quasi a (sx-at items (load i))))) (store! i (iadd (load i) 1)))))
    (Ok (if isvec (QVector (box-al [Quasi] a (load out))) (QList (box-al [Quasi] a (load out))))))))
(defn build-quasi [(a (ptr Allocator)) (s Sexp)] (-> (Result Quasi Diag))
  (let [tg (sx-tag s)]
    (if (icmp-eq tg 6)
        (let [items (sx-items s)]
          (if (icmp-eq (sx-len items) 2)
              (let [h (sx-at items 0)]
                (if (icmp-eq (sx-tag h) 2)
                    (let [hs (sx-sval h)]
                      (if (str-eq hs "unquote")
                          (match (parse-expr a (sx-at items 1)) (Err [d] (Err d)) (Ok [e] (Ok (QUnquote (box-expr a e)))))
                        (if (str-eq hs "unquote-splicing")
                          (match (parse-expr a (sx-at items 1)) (Err [d] (Err d)) (Ok [e] (Ok (QSplice (box-expr a e)))))
                          (build-quasi-seq a items false))))
                    (build-quasi-seq a items false)))
              (build-quasi-seq a items false)))
      (if (icmp-eq tg 7) (build-quasi-seq a (sx-items s) true)
          (Ok (QLit (box-sexp a s)))))))

; ---- expressions (src/parse.rs parse_expr / parse_list_expr) ----
(defn mk-bin [(a (ptr Allocator)) (args (ptr (ArrayList Sexp))) (head (slice u8)) (op i64)] (-> (Result ExprKind Diag))
  (try (let [tp (alloc-stack Two)] (store! tp (try! (need-two a args head)))
    (Ok (EBin op (box-expr a (try! (parse-expr a (load (field tp x))))) (box-expr a (try! (parse-expr a (load (field tp y))))))))))
(defn mk-cmp [(a (ptr Allocator)) (args (ptr (ArrayList Sexp))) (head (slice u8)) (op i64)] (-> (Result ExprKind Diag))
  (try (let [tp (alloc-stack Two)] (store! tp (try! (need-two a args head)))
    (Ok (ECmp op (box-expr a (try! (parse-expr a (load (field tp x))))) (box-expr a (try! (parse-expr a (load (field tp y))))))))))
(defn binop-of [(h (slice u8))] (-> i64)
  (if (str-eq h "iadd") 0 (if (str-eq h "isub") 1 (if (str-eq h "imul") 2 (if (str-eq h "idiv") 3 (if (str-eq h "irem") 4 (if (str-eq h "udiv") 5 (if (str-eq h "urem") 6 (if (str-eq h "iand") 7 (if (str-eq h "ior") 8 (if (str-eq h "ixor") 9 (if (str-eq h "ishl") 10 (if (str-eq h "ishr") 11 (if (str-eq h "fadd") 0 (if (str-eq h "fsub") 1 (if (str-eq h "fmul") 2 (if (str-eq h "fdiv") 3 (if (str-eq h "frem") 4 -1))))))))))))))))))
(defn cmpop-of [(h (slice u8))] (-> i64)
  (if (str-eq h "fcmp-lt") 0 (if (str-eq h "fcmp-le") 1 (if (str-eq h "fcmp-gt") 2 (if (str-eq h "fcmp-ge") 3 (if (str-eq h "fcmp-eq") 4 (if (str-eq h "fcmp-ne") 5 (if (str-eq h "icmp-lt") 0 (if (str-eq h "icmp-le") 1 (if (str-eq h "icmp-gt") 2 (if (str-eq h "icmp-ge") 3 (if (str-eq h "icmp-eq") 4 (if (str-eq h "icmp-ne") 5 -1)))))))))))))
(defn codeop-of [(h (slice u8))] (-> i64)
  (if (str-eq h "code-list?") 0 (if (str-eq h "code-sym?") 1 (if (str-eq h "code-int?") 2 (if (str-eq h "code-count") 3 (if (str-eq h "code-nth") 4 (if (str-eq h "code-sym") 5 (if (str-eq h "code-int") 6 (if (str-eq h "code-rest") 7 (if (str-eq h "code-eq") 10 (if (str-eq h "code-keyword?") 11 (if (str-eq h "code-symbol") 12 (if (str-eq h "code-str") 13 (if (str-eq h "code-field-count") 14 (if (str-eq h "code-field-name") 15 (if (str-eq h "code-field-kind") 16 (if (str-eq h "code-field-type") 17 (if (str-eq h "code-variant-sum") 18 (if (str-eq h "code-variant-count") 19 (if (str-eq h "code-variant-name") 20 (if (str-eq h "code-variant-fields") 21 (if (str-eq h "code-trait-method-count") 22 (if (str-eq h "code-trait-method-name") 23 (if (str-eq h "code-trait-arity") 24 (if (str-eq h "code-trait-param-name") 25 (if (str-eq h "code-trait-param-type") 26 (if (str-eq h "code-trait-ret-type") 27 (if (str-eq h "str-bytes") 28 (if (str-eq h "bytes->str") 29 -1)))))))))))))))))))))))))))))
(defn typequery-of [(h (slice u8))] (-> i64)
  (if (str-eq h "field-count") 0 (if (str-eq h "variant-count") 1 (if (str-eq h "struct?") 2 (if (str-eq h "sum?") 3 (if (str-eq h "int?") 4 (if (str-eq h "float?") 5 (if (str-eq h "ptr?") 6 (if (str-eq h "array?") 7 -1)))))))))
(defn fieldmeta-of [(h (slice u8))] (-> i64)
  (if (str-eq h "field-name") 0 (if (str-eq h "field-type-kind") 1 (if (str-eq h "field-type-name") 2 -1))))
(defn alloc-form [(a (ptr Allocator)) (args (ptr (ArrayList Sexp))) (storage i64)] (-> (Result ExprKind Diag))
  (try (let [ty (match (sx-get args 0) (Some [t] (try! (parse-type a t))) (None [] (TInt 64 true)))] (Ok (EAlloc storage ty)))))
(defn parse-exprs [(a (ptr Allocator)) (items (ptr (ArrayList Sexp)))] (-> (Result (ptr (ArrayList Expr)) Diag))
  (try (let [(mut out) (al-new [Expr] a) n (sx-len items) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break) (do (al-push! (mut out) (try! (parse-expr a (sx-at items (load i))))) (store! i (iadd (load i) 1)))))
    (Ok (box-al [Expr] a (load out))))))
(defn parse-expr [(a (ptr Allocator)) (s Sexp)] (-> (Result Expr Diag))
  (match (parse-expr-inner a s)
    (Err [d] (Err (dwspan d (sx-lo s) (sx-hi s))))
    (Ok [kind] (Ok (mk-expr kind (sx-lo s) (sx-hi s))))))
(defn parse-expr-inner [(a (ptr Allocator)) (s Sexp)] (-> (Result ExprKind Diag))
  (let [tg (sx-tag s) slo (sx-lo s) shi (sx-hi s)]
    (if (icmp-eq tg 0) (Ok (EInt (sx-ival s)))
    (if (icmp-eq tg 1) (Ok (EFloat (sx-ival s)))
    (if (icmp-eq tg 2) (let [nm (sx-sval s)] (if (str-eq nm "true") (Ok (EBool true)) (if (str-eq nm "false") (Ok (EBool false)) (Ok (EVar nm)))))
    (if (icmp-eq tg 3) (Err (derr-at slo shi (sconcat a "unexpected keyword :" (sconcat a (sx-sval s) " in expression"))))
    (if (icmp-eq tg 4) (Ok (EStr (sx-sval s)))
    (if (icmp-eq tg 5) (Ok (ECStr (sx-sval s)))
    (if (icmp-eq tg 7) (Err (derr-at slo shi "unexpected vector in expression"))
      (parse-list-expr a (sx-items s) slo shi))))))))))

; A leading :label keyword (src/parse.rs parse_label).
(defstruct LabelSplit [(label (Option (slice u8))) (rest (ptr (ArrayList Sexp)))])
(defn split-label [(a (ptr Allocator)) (args (ptr (ArrayList Sexp)))] (-> LabelSplit)
  (let [r (alloc-stack LabelSplit)]
    (if (and (icmp-gt (sx-len args) 0) (icmp-eq (sx-tag (sx-at args 0)) 3))
        (do (store! (field r label) (Some (sx-sval (sx-at args 0)))) (store! (field r rest) (rest-from a args 1)))
        (do (store! (field r label) (None [(slice u8)])) (store! (field r rest) args)))
    (load r)))

; (let [binds...] body...) — src/parse.rs `let` arm.
(defn parse-let [(a (ptr Allocator)) (args (ptr (ArrayList Sexp))) (slo i64) (shi i64)] (-> (Result ExprKind Diag))
  (try (let [bvo (sx-get args 0)]
    (if (not (opt-is-vec bvo)) (return-from :try (Err [ExprKind Diag] (derr-at slo shi "let: expected binding vector"))) 0)
    (let [bv (sx-items (opt-get bvo)) nb (sx-len bv)]
      (if (not (icmp-eq (urem nb 2) 0)) (return-from :try (Err [ExprKind Diag] (derr-at slo shi "let: bindings must be name/value pairs"))) 0)
      (let [(mut binds) (al-new [Bind] a) (mut k) 0]
        (loop (if (icmp-ge (load k) nb) (break)
          (let [nmf (sx-at bv (load k)) vf (sx-at bv (iadd (load k) 1))]
            (let [bp (alloc-stack Bind)]
              (if (icmp-eq (sx-tag nmf) 2)
                  (do (store! (field bp name) (sx-sval nmf)) (store! (field bp mutable) false))
                (if (and (icmp-eq (sx-tag nmf) 6) (and (icmp-eq (sx-len (sx-items nmf)) 2) (str-eq (try! (head-sym a (sx-items nmf))) "mut")))
                    (do (store! (field bp name) (try! (sym-of a (sx-at (sx-items nmf) 1) "let binding name"))) (store! (field bp mutable) true))
                  (return-from :try (Err [ExprKind Diag] (derr-at (sx-lo nmf) (sx-hi nmf) (sconcat3 a "let binding name must be `name` or `(mut name)`, got " (sexp-display a nmf) ""))))))
              (store! (field bp value) (try! (parse-expr a vf)))
              (al-push! (mut binds) (load bp)))
            (store! k (iadd (load k) 2)))))
        (let [body (try! (parse-exprs a (rest-from a args 1)))]
          (if (icmp-eq (al-len [Expr] (load body)) 0) (return-from :try (Err [ExprKind Diag] (derr-at slo shi "let: empty body"))) 0)
          (Ok (ELet (box-al [Bind] a (load binds)) body))))))))

; (match scrut arms...) — src/parse.rs `match` arm.
(defn parse-match [(a (ptr Allocator)) (args (ptr (ArrayList Sexp))) (slo i64) (shi i64)] (-> (Result ExprKind Diag))
  (try (let [scrut (box-expr a (try! (parse-expr a (try! (need [Sexp] (sx-get args 0) "match: missing scrutinee")))))
             (mut arms) (al-new [Arm] a) n (sx-len args) (mut i) 1]
    (loop (if (icmp-ge (load i) n) (break)
      (let [arm-s (sx-at args (load i))]
        (store! i (iadd (load i) 1))
        (let [al (try! (as-list arm-s "match arm must be (Variant [binds] body)"))
              variant (try! (sym-of a (try! (need [Sexp] (sx-get al 0) "arm: missing variant")) "variant"))
              bvo (sx-get al 1)]
          (if (not (opt-is-vec bvo)) (return-from :try (Err [ExprKind Diag] (derr-at (sx-lo arm-s) (sx-hi arm-s) (sconcat3 a "arm '" variant "': expected a bind vector")))) 0)
          (let [bv (sx-items (opt-get bvo)) (mut binds) (al-new [(slice u8)] a) nb (sx-len bv) (mut bi) 0]
            (loop (if (icmp-ge (load bi) nb) (break) (do (al-push! (mut binds) (try! (sym-of a (sx-at bv (load bi)) "bind"))) (store! bi (iadd (load bi) 1)))))
            (let [bodyf (try! (parse-exprs a (rest-from a al 2))) nbody (al-len [Expr] (load bodyf))]
              (let [body (if (icmp-eq nbody 0) (return-from :try (Err [ExprKind Diag] (derr-at (sx-lo arm-s) (sx-hi arm-s) (sconcat3 a "arm '" variant "': missing body"))))
                           (if (icmp-eq nbody 1) (al-get [Expr] (load bodyf) 0) (mk-expr (EDo bodyf) (sx-lo arm-s) (sx-hi arm-s))))]
                (let [ap (alloc-stack Arm)] (store! (field ap variant) variant) (store! (field ap binds) (box-al [(slice u8)] a (load binds))) (store! (field ap body) body) (al-push! (mut arms) (load ap))))))))))
    (Ok (EMatch scrut (box-al [Arm] a (load arms)))))))

; (llvm-ir RESULT [operands] "BODY") — src/parse.rs `llvm-ir` arm.
(defn parse-llvm-ir [(a (ptr Allocator)) (args (ptr (ArrayList Sexp))) (slo i64) (shi i64)] (-> (Result ExprKind Diag))
  (try (if (icmp-ne (sx-len args) 3) (Err [ExprKind Diag] (derr-at slo shi "llvm-ir: expects (llvm-ir RESULT-TYPE [operands...] \"BODY\")"))
    (let [result (try! (parse-type a (sx-at args 0)))
          ov (sx-at args 1)]
      (if (not (icmp-eq (sx-tag ov) 7)) (return-from :try (Err [ExprKind Diag] (derr-at (sx-lo ov) (sx-hi ov) "llvm-ir: expected a [operand...] vector"))) 0)
      (let [operands (try! (parse-exprs a (sx-items ov))) bv (sx-at args 2)]
        (if (not (icmp-eq (sx-tag bv) 4)) (return-from :try (Err [ExprKind Diag] (derr-at (sx-lo bv) (sx-hi bv) "llvm-ir: body must be a string literal"))) 0)
        (Ok (ELlvmIr result operands (sx-sval bv))))))))

; the big head dispatch (src/parse.rs parse_list_expr).
(defn parse-list-expr [(a (ptr Allocator)) (items (ptr (ArrayList Sexp))) (slo i64) (shi i64)] (-> (Result ExprKind Diag))
  (try (let [head (try! (head-sym a items)) args (rest-from a items 1) nargs (sx-len args)]
    (let [bop (binop-of head)]
    (if (icmp-ge bop 0) (mk-bin a args head bop)
    (let [cop (cmpop-of head)]
    (if (icmp-ge cop 0) (mk-cmp a args head cop)
    (if (str-eq head "inot") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "inot: expects (inot x)")) (Ok (ENot (box-expr a (try! (parse-expr a (sx-at args 0)))))))
    (if (str-eq head "and")
        (let [tp (alloc-stack Two)] (store! tp (try! (need-two a args "and")))
          (Ok (EIf (box-expr a (try! (parse-expr a (load (field tp x))))) (box-expr a (try! (parse-expr a (load (field tp y))))) (box-expr a (mk-expr (EBool false) slo shi)))))
    (if (str-eq head "or")
        (let [tp (alloc-stack Two)] (store! tp (try! (need-two a args "or")))
          (Ok (EIf (box-expr a (try! (parse-expr a (load (field tp x))))) (box-expr a (mk-expr (EBool true) slo shi)) (box-expr a (try! (parse-expr a (load (field tp y))))))))
    (if (str-eq head "not") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "not: expects (not x)"))
        (Ok (EIf (box-expr a (try! (parse-expr a (sx-at args 0)))) (box-expr a (mk-expr (EBool false) slo shi)) (box-expr a (mk-expr (EBool true) slo shi)))))
    (if (str-eq head "if") (if (icmp-ne nargs 3) (Err [ExprKind Diag] (derr-at slo shi "if: expects (if cond then else)"))
        (Ok (EIf (box-expr a (try! (parse-expr a (sx-at args 0)))) (box-expr a (try! (parse-expr a (sx-at args 1)))) (box-expr a (try! (parse-expr a (sx-at args 2)))))))
    (if (str-eq head "do") (Ok (EDo (try! (parse-exprs a args))))
    (if (str-eq head "comptime") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "comptime: expects (comptime expr)")) (Ok (EComptime (box-expr a (try! (parse-expr a (sx-at args 0)))))))
    (if (str-eq head "let") (parse-let a args slo shi)
    (if (str-eq head "call")
        (let [f (try! (sym-of a (try! (need [Sexp] (sx-get args 0) "call: missing function")) "call target"))]
          (Ok (ECall f (box-al [Type] a (al-new [Type] a)) (try! (parse-exprs a (rest-from a args 1))))))
    (if (str-eq head "zeroed") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "zeroed: expects (zeroed TYPE)")) (Ok (EZeroed (try! (parse-type a (sx-at args 0))))))
    (if (str-eq head "mut") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "mut: expects (mut PLACE)")) (Ok (EBorrow true (box-expr a (try! (parse-expr a (sx-at args 0)))))))
    (if (str-eq head "alloc-stack") (alloc-form a args 0)
    (if (str-eq head "alloc-static") (alloc-form a args 1)
    (if (str-eq head "alloc-heap") (alloc-form a args 2)
    (if (str-eq head "field")
        (Ok (EField (box-expr a (try! (parse-expr a (try! (need [Sexp] (sx-get args 0) "field: missing pointer"))))) (try! (sym-of a (try! (need [Sexp] (sx-get args 1) "field: missing field name")) "field name"))))
    (if (str-eq head "get")
        (Ok (EBitGet (box-expr a (try! (parse-expr a (try! (need [Sexp] (sx-get args 0) "get: missing pointer"))))) (try! (sym-of a (try! (need [Sexp] (sx-get args 1) "get: missing field name")) "field name"))))
    (if (str-eq head "set!")
        (Ok (EBitSet (box-expr a (try! (parse-expr a (try! (need [Sexp] (sx-get args 0) "set!: missing pointer"))))) (try! (sym-of a (try! (need [Sexp] (sx-get args 1) "set!: missing field name")) "field name")) (box-expr a (try! (parse-expr a (try! (need [Sexp] (sx-get args 2) "set!: missing value")))))))
    (if (str-eq head "fnptr-of") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "fnptr-of: expects (fnptr-of name)")) (Ok (EFnPtrOf (try! (sym-of a (sx-at args 0) "function name")))))
    (if (str-eq head "call-ptr")
        (Ok (ECallPtr (box-expr a (try! (parse-expr a (try! (need [Sexp] (sx-get args 0) "call-ptr: missing function pointer"))))) (try! (parse-exprs a (rest-from a args 1)))))
    (if (str-eq head "load") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "load: expects (load ptr)")) (Ok (ELoad (box-expr a (try! (parse-expr a (sx-at args 0)))))))
    (if (str-eq head "store!")
        (let [tp (alloc-stack Two)] (store! tp (try! (need-two a args "store!"))) (Ok (EStore (box-expr a (try! (parse-expr a (load (field tp x))))) (box-expr a (try! (parse-expr a (load (field tp y))))))))
    (if (str-eq head "free") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "free: expects (free ptr)")) (Ok (EFree (box-expr a (try! (parse-expr a (sx-at args 0)))))))
    (if (str-eq head "make-dyn") (if (icmp-ne nargs 2) (Err [ExprKind Diag] (derr-at slo shi "make-dyn: expects (make-dyn Trait expr)"))
        (Ok (EErase (try! (sym-of a (sx-at args 0) "make-dyn trait name")) (box-expr a (try! (parse-expr a (sx-at args 1)))))))
    (if (str-eq head "index")
        (let [tp (alloc-stack Two)] (store! tp (try! (need-two a args "index"))) (Ok (EIndex (box-expr a (try! (parse-expr a (load (field tp x))))) (box-expr a (try! (parse-expr a (load (field tp y))))))))
    (if (str-eq head "cast") (if (icmp-ne nargs 2) (Err [ExprKind Diag] (derr-at slo shi "cast: expects (cast :type expr)"))
        (Ok (ECast (try! (parse-type a (sx-at args 0))) (box-expr a (try! (parse-expr a (sx-at args 1)))))))
    (if (str-eq head "match") (parse-match a args slo shi)
    (if (str-eq head "sizeof") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "sizeof: expects (sizeof TYPE)")) (Ok (ESizeOf (try! (parse-type a (sx-at args 0))))))
    (if (str-eq head "alignof") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "alignof: expects (alignof TYPE)")) (Ok (EAlignOf (try! (parse-type a (sx-at args 0))))))
    (if (str-eq head "offsetof") (if (icmp-ne nargs 2) (Err [ExprKind Diag] (derr-at slo shi "offsetof: expects (offsetof TYPE field)")) (Ok (EOffsetOf (try! (parse-type a (sx-at args 0))) (try! (sym-of a (sx-at args 1) "field")))))
    (if (icmp-ge (typequery-of head) 0)
        (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi (sconcat a head (sconcat a ": expects (" (sconcat a head " TYPE)"))))) (Ok (ETypeQuery (typequery-of head) (try! (parse-type a (sx-at args 0))))))
    (if (icmp-ge (fieldmeta-of head) 0)
        (if (icmp-ne nargs 2) (Err [ExprKind Diag] (derr-at slo shi (sconcat a head (sconcat a ": expects (" (sconcat a head " TYPE index)"))))) (Ok (EFieldMeta (fieldmeta-of head) (try! (parse-type a (sx-at args 0))) (box-expr a (try! (parse-expr a (sx-at args 1)))))))
    (if (str-eq head "field-index") (if (icmp-ne nargs 2) (Err [ExprKind Diag] (derr-at slo shi "field-index: expects (field-index TYPE name)")) (Ok (EFieldIndex (try! (parse-type a (sx-at args 0))) (box-expr a (try! (parse-expr a (sx-at args 1)))))))
    (if (str-eq head "quote") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "quote: expects (quote FORM)")) (Ok (EQuote (box-sexp a (sx-at args 0)))))
    (if (str-eq head "quasiquote") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "quasiquote: expects one template")) (Ok (EQuasi (try! (build-quasi a (sx-at args 0))))))
    (if (str-eq head "unquote") (Err [ExprKind Diag] (derr-at slo shi "unquote (~) is only valid inside a quasiquote (`)"))
    (if (str-eq head "gensym") (if (not (icmp-eq nargs 0)) (Err [ExprKind Diag] (derr-at slo shi "gensym: expects (gensym)")) (Ok (ECodeOp 8 (box-al [Expr] a (al-new [Expr] a)))))
    (if (str-eq head "target-arch") (if (not (icmp-eq nargs 0)) (Err [ExprKind Diag] (derr-at slo shi "target-arch: expects (target-arch)")) (Ok (ECodeOp 30 (box-al [Expr] a (al-new [Expr] a)))))
    (if (str-eq head "error") (if (icmp-ne nargs 1) (Err [ExprKind Diag] (derr-at slo shi "error: expects (error MSG)")) (Ok (ECodeOp 9 (try! (parse-exprs a args)))))
    (if (icmp-ge (codeop-of head) 0) (Ok (ECodeOp (codeop-of head) (try! (parse-exprs a args))))
    (if (str-eq head "loop")
        (let [lr (alloc-stack LabelSplit)] (store! lr (split-label a args))
          (let [body (try! (parse-exprs a (load (field lr rest))))]
            (if (icmp-eq (al-len [Expr] (load body)) 0) (Err [ExprKind Diag] (derr-at slo shi "loop: expects (loop [:label] body...)")) (Ok (ELoop (load (field lr label)) body)))))
    (if (str-eq head "break")
        (let [lr (alloc-stack LabelSplit)] (store! lr (split-label a args))
          (let [r (load (field lr rest))]
            (if (icmp-gt (sx-len r) 1) (Err [ExprKind Diag] (derr-at slo shi "break: expects (break [:label] [value])"))
                (Ok (EBreak (load (field lr label)) (match (sx-get r 0) (Some [e] (Some (box-expr a (try! (parse-expr a e))))) (None [] (None [(ptr Expr)]))))))))
    (if (str-eq head "continue")
        (let [lr (alloc-stack LabelSplit)] (store! lr (split-label a args))
          (if (icmp-gt (sx-len (load (field lr rest))) 0) (Err [ExprKind Diag] (derr-at slo shi "continue: expects (continue [:label])")) (Ok (EContinue (load (field lr label))))))
    (if (str-eq head "llvm-ir") (parse-llvm-ir a args slo shi)
      (let [fv (sx-get args 0)]
        (if (opt-is-vec fv)
            (Ok (ECall head (try! (parse-types a (sx-items (opt-get fv)))) (try! (parse-exprs a (rest-from a args 1)))))
            (Ok (ECall head (box-al [Type] a (al-new [Type] a)) (try! (parse-exprs a args))))))))))))))))))))))))))))))))))))))))))))))))))))))))

; ---- declaration parsers (src/parse.rs) ----
(defn func-name [(f Func)] (-> (slice u8)) (let [p (alloc-stack Func)] (store! p f) (load (field p name))))

; variant/struct fields: (name :type) -> Field.
(defn parse-fields [(a (ptr Allocator)) (fv (ptr (ArrayList Sexp)))] (-> (Result (ptr (ArrayList Field)) Diag))
  (try (let [(mut fs) (al-new [Field] a) n (sx-len fv) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (let [f (sx-at fv (load i))]
        (store! i (iadd (load i) 1))
        (let [fl (try! (as-list f "field must be (name :type)"))
              fn0 (try! (sym-of a (sx-at fl 0) "field name"))
              ft (try! (parse-type a (try! (need [Sexp] (sx-get fl 1) "field type"))))]
          (let [fp (alloc-stack Field)] (store! (field fp name) fn0) (store! (field fp ty) ft) (al-push! (mut fs) (load fp)))))))
    (Ok (box-al [Field] a (load fs))))))

(defn parse-const [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp)))] (-> (Result Const Diag))
  (try (let [name (try! (sym-of a (try! (need [Sexp] (sx-get rest 0) "const: missing name")) "const name")) nr (sx-len rest)]
    (if (icmp-eq nr 2)
        (let [value (try! (parse-expr a (sx-at rest 1)))]
          (Ok (let [c (alloc-stack Const)] (store! (field c name) name) (store! (field c ty) (None [Type])) (store! (field c value) value) (load c))))
      (if (icmp-eq nr 3)
          (let [ty (try! (parse-type a (sx-at rest 1))) value (try! (parse-expr a (sx-at rest 2)))]
            (Ok (let [c (alloc-stack Const)] (store! (field c name) name) (store! (field c ty) (Some ty)) (store! (field c value) value) (load c))))
          (Err [Const Diag] (derr "const: expected (const NAME VALUE) or (const NAME TYPE VALUE)")))))))

(defn parse-defsum [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp)))] (-> (Result SumDef Diag))
  (try (let [name (try! (sym-of a (try! (need [Sexp] (sx-get rest 0) "defsum: missing name")) "sum name"))
             (mut i) 1 (mut tps) (al-new [(slice u8)] a)]
    (if (opt-is-vec (sx-get rest (load i)))
        (do (let [it (sx-items (opt-get (sx-get rest (load i)))) n (sx-len it) (mut k) 0]
              (loop (if (icmp-ge (load k) n) (break) (do (al-push! (mut tps) (try! (sym-of a (sx-at it (load k)) "type parameter"))) (store! k (iadd (load k) 1))))))
            (store! i (iadd (load i) 1))) 0)
    (let [(mut variants) (al-new [Variant] a) nr (sx-len rest) (mut vi) (load i)]
      (loop (if (icmp-ge (load vi) nr) (break)
        (let [v (sx-at rest (load vi))]
          (store! vi (iadd (load vi) 1))
          (let [vl (try! (as-list v "variant must be (Name [fields])"))
                vname (try! (sym-of a (try! (need [Sexp] (sx-get vl 0) "variant: missing name")) "variant name"))
                fields (if (opt-is-vec (sx-get vl 1)) (try! (parse-fields a (sx-items (opt-get (sx-get vl 1)))))
                         (match (sx-get vl 1)
                           (Some [_] (return-from :try (Err [SumDef Diag] (derr-at (sx-lo v) (sx-hi v) (sconcat3 a "variant '" vname "': fields must be a vector")))))
                           (None [] (box-al [Field] a (al-new [Field] a)))))]
            (let [vp (alloc-stack Variant)] (store! (field vp name) vname) (store! (field vp fields) fields) (al-push! (mut variants) (load vp)))))))
      (Ok (let [sd (alloc-stack SumDef)] (store! (field sd name) name) (store! (field sd type_params) (box-al [(slice u8)] a (load tps))) (store! (field sd variants) (box-al [Variant] a (load variants))) (load sd)))))))

(defn compute-backing [(a (ptr Allocator)) (name (slice u8)) (acc i64) (backing i64)] (-> (Result i64 Diag))
  (if (icmp-ge backing 0)
      (if (icmp-ge backing acc) (Ok backing)
          (Err [i64 Diag] (derr (sconcat a (sconcat3 a "defstruct '" name "': :backing i") (sconcat a (i64->str a backing) (sconcat a " too small for " (sconcat a (i64->str a acc) " bits")))))))
      (if (icmp-le acc 8) (Ok 8) (if (icmp-le acc 16) (Ok 16) (if (icmp-le acc 32) (Ok 32) (if (icmp-le acc 64) (Ok 64)
          (Err [i64 Diag] (derr (sconcat a (sconcat3 a "defstruct '" name "': ") (sconcat a (i64->str a acc) " bits needs an explicit :backing"))))))))))

(defstruct BitField [(fname (slice u8)) (width i64)])
(defn parse-bitfield [(a (ptr Allocator)) (f Sexp)] (-> (Result BitField Diag))
  (try (let [fl (try! (as-list f "bitfield must be (name :bits N)"))
             fname (try! (sym-of a (sx-at fl 0) "field name"))
             width (if (and (opt-is-kw (sx-get fl 1) "bits") (opt-is-pos-int (sx-get fl 2))) (opt-int (sx-get fl 2)) -1)]
    (if (icmp-lt width 0) (Err [BitField Diag] (derr-at (sx-lo f) (sx-hi f) (sconcat3 a "field '" fname "' must be (name :bits N)")))
        (Ok (let [b (alloc-stack BitField)] (store! (field b fname) fname) (store! (field b width) width) (load b)))))))

(defn finish-bits [(a (ptr Allocator)) (name (slice u8)) (tparams (ptr (ArrayList (slice u8)))) (backing i64) (fields-items (ptr (ArrayList Sexp)))] (-> (Result StructDef Diag))
  (let [(mut fields) (al-new [Field] a) (mut offsets) (al-new [i64] a) (mut acc) 0 n (sx-len fields-items) (mut fi) 0
        (mut out) (zeroed (Result StructDef Diag)) (mut failed) false]
    (loop (if (icmp-ge (load fi) n) (break)
      (let [f (sx-at fields-items (load fi))]
        (store! fi (iadd (load fi) 1))
        (match (parse-bitfield a f)
          (Err [d] (do (store! out (Err d)) (store! failed true) (break)))
          (Ok [fld]
            (let [bp (alloc-stack BitField)] (store! bp fld)
              (let [fr (alloc-stack Field)] (store! (field fr name) (load (field bp fname))) (store! (field fr ty) (TInt (load (field bp width)) false)) (al-push! (mut fields) (load fr)))
              (al-push! (mut offsets) (load acc))
              (store! acc (iadd (load acc) (load (field bp width))))))))))
    (if (load failed) (load out)
        (match (compute-backing a name (load acc) backing)
          (Err [d] (Err d))
          (Ok [bk] (Ok (let [sd (alloc-stack StructDef)] (store! (field sd name) name) (store! (field sd type_params) tparams) (store! (field sd layout) (LBits bk (box-al [i64] a (load offsets)))) (store! (field sd fields) (box-al [Field] a (load fields))) (load sd))))))))

(defstruct NField [(fname (slice u8)) (fty Type) (at (Option i64))])
(defn parse-normal-field [(a (ptr Allocator)) (f Sexp)] (-> (Result NField Diag))
  (try (let [fl (try! (as-list f "field must be (name :type [:at N])"))
             fname (try! (sym-of a (sx-at fl 0) "field name"))
             fty (try! (parse-type a (try! (need [Sexp] (sx-get fl 1) "field missing type"))))
             (mut at) (None [i64]) (mut j) 2 fln (sx-len fl) (mut out) (zeroed (Result NField Diag)) (mut bad) false]
    (loop (if (icmp-ge (load j) fln) (break)
      (let [fj (sx-at fl (load j))]
        (if (and (icmp-eq (sx-tag fj) 3) (str-eq (sx-sval fj) "at"))
            (do (store! at (Some (try! (int-val a (try! (need [Sexp] (sx-get fl (iadd (load j) 1)) ":at missing value")) "at")))) (store! j (iadd (load j) 2)))
            (do (store! out (Err (derr-at (sx-lo fj) (sx-hi fj) (sconcat a "unknown field option " (sexp-display a fj))))) (store! bad true) (break))))))
    (if (load bad) (load out)
        (Ok (let [nf (alloc-stack NField)] (store! (field nf fname) fname) (store! (field nf fty) fty) (store! (field nf at) (load at)) (load nf)))))))

(defn compute-layout [(a (ptr Allocator)) (name (slice u8)) (packed bool) (explicit bool) (aligned i64) (exp-size i64) (has-size bool) (exp-align i64) (anyat bool) (ats (ptr (ArrayList (Option i64))))] (-> (Result Layout Diag))
  (if (icmp-ge aligned 0) (Ok (LAligned aligned))
    (if (or explicit anyat)
        (let [(mut offs) (al-new [i64] a) na (al-len [(Option i64)] (load ats)) (mut oi) 0 (mut bad) false]
          (loop (if (icmp-ge (load oi) na) (break)
            (match (al-get [(Option i64)] (load ats) (load oi))
              (Some [o] (do (al-push! (mut offs) o) (store! oi (iadd (load oi) 1))))
              (None [] (do (store! bad true) (break))))))
          (if (load bad) (Err (derr (sconcat3 a "defstruct '" name "': explicit layout needs :at on every field")))
              (Ok (LExplicit (box-al [i64] a (load offs)) (if has-size (Some exp-size) (None [i64])) exp-align))))
      (if packed (Ok (LPacked)) (Ok (LC))))))

(defn finish-normal [(a (ptr Allocator)) (name (slice u8)) (tparams (ptr (ArrayList (slice u8)))) (packed bool) (explicit bool) (aligned i64) (exp-size i64) (has-size bool) (exp-align i64) (fields-items (ptr (ArrayList Sexp)))] (-> (Result StructDef Diag))
  (let [(mut fields) (al-new [Field] a) (mut ats) (al-new [(Option i64)] a) (mut anyat) false n (sx-len fields-items) (mut fi) 0
        (mut out) (zeroed (Result StructDef Diag)) (mut failed) false]
    (loop (if (icmp-ge (load fi) n) (break)
      (let [f (sx-at fields-items (load fi))]
        (store! fi (iadd (load fi) 1))
        (match (parse-normal-field a f)
          (Err [d] (do (store! out (Err d)) (store! failed true) (break)))
          (Ok [nf]
            (let [np (alloc-stack NField)] (store! np nf)
              (let [fr (alloc-stack Field)] (store! (field fr name) (load (field np fname))) (store! (field fr ty) (load (field np fty))) (al-push! (mut fields) (load fr)))
              (match (load (field np at)) (Some [_] (store! anyat true)) (None [] false))
              (al-push! (mut ats) (load (field np at)))))))))
    (if (load failed) (load out)
        (match (compute-layout a name packed explicit aligned exp-size has-size exp-align (load anyat) (box-al [(Option i64)] a (load ats)))
          (Err [d] (Err d))
          (Ok [layout] (Ok (let [sd (alloc-stack StructDef)] (store! (field sd name) name) (store! (field sd type_params) tparams) (store! (field sd layout) layout) (store! (field sd fields) (box-al [Field] a (load fields))) (load sd))))))))

(defstruct StructOpts [(packed bool) (explicit bool) (bits bool) (aligned i64) (exp-size i64) (has-size bool) (exp-align i64) (backing i64) (next i64)])
(defn parse-struct-opts [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp))) (start i64)] (-> (Result StructOpts Diag))
  (let [(mut packed) false (mut explicit) false (mut bits) false (mut aligned) -1 (mut exp-size) -1 (mut has-size) false (mut exp-align) 0 (mut backing) -1
        (mut i) start (mut out) (zeroed (Result StructOpts Diag)) (mut failed) false]
    (loop
      (match (sx-get rest (load i))
        (None [] (break))
        (Some [kw]
          (if (not (icmp-eq (sx-tag kw) 3)) (break)
            (match (need [Sexp] (sx-get rest (iadd (load i) 1)) (sconcat3 a "defstruct: ':" (sx-sval kw) "' missing value"))
              (Err [d] (do (store! out (Err d)) (store! failed true) (break)))
              (Ok [val]
                (let [k (sx-sval kw) (mut stop) false]
                  (if (str-eq k "layout")
                      (if (icmp-eq (sx-tag val) 2)
                          (let [vs (sx-sval val)]
                            (if (str-eq vs "c") 0
                              (if (str-eq vs "packed") (do (store! packed true) 0)
                                (if (str-eq vs "explicit") (do (store! explicit true) 0)
                                  (if (str-eq vs "bits") (do (store! bits true) 0)
                                    (do (store! out (Err [StructOpts Diag] (derr-at (sx-lo val) (sx-hi val) "layout must be c, packed, explicit, bits, or (align N)"))) (store! failed true) (store! stop true) 0))))))
                        (if (and (icmp-eq (sx-tag val) 6) (icmp-gt (sx-len (sx-items val)) 0))
                            (let [vit (sx-items val)]
                              (if (and (icmp-eq (sx-tag (sx-at vit 0)) 2) (str-eq (sx-sval (sx-at vit 0)) "align"))
                                  (match (pow2 (sx-get vit 1)) (Ok [v] (store! aligned v)) (Err [d] (do (store! out (Err d)) (store! failed true) (store! stop true) 0)))
                                  (do (store! out (Err [StructOpts Diag] (derr-at (sx-lo val) (sx-hi val) "layout must be c, packed, explicit, bits, or (align N)"))) (store! failed true) (store! stop true) 0)))
                            (do (store! out (Err [StructOpts Diag] (derr-at (sx-lo val) (sx-hi val) "layout must be c, packed, explicit, bits, or (align N)"))) (store! failed true) (store! stop true) 0)))
                    (if (str-eq k "size")
                        (match (int-val a val "size") (Ok [v] (do (store! exp-size v) (store! has-size true) 0)) (Err [d] (do (store! out (Err d)) (store! failed true) (store! stop true) 0)))
                      (if (str-eq k "align")
                          (match (pow2 (sx-get rest (iadd (load i) 1))) (Ok [v] (store! exp-align v)) (Err [d] (do (store! out (Err d)) (store! failed true) (store! stop true) 0)))
                        (if (str-eq k "backing")
                            (match (parse-type a val) (Err [d] (do (store! out (Err d)) (store! failed true) (store! stop true) 0))
                              (Ok [bt] (let [bb (type-int-bits bt)] (if (icmp-lt bb 0) (do (store! out (Err [StructOpts Diag] (derr-at (sx-lo val) (sx-hi val) ":backing must be an integer type"))) (store! failed true) (store! stop true) 0) (store! backing bb)))))
                          (do (store! stop true) 0)))))
                  (if (load stop) (break) (store! i (iadd (load i) 2))))))))))
    (if (load failed) (load out)
        (Ok (let [o (alloc-stack StructOpts)]
              (store! (field o packed) (load packed)) (store! (field o explicit) (load explicit)) (store! (field o bits) (load bits))
              (store! (field o aligned) (load aligned)) (store! (field o exp-size) (load exp-size)) (store! (field o has-size) (load has-size))
              (store! (field o exp-align) (load exp-align)) (store! (field o backing) (load backing)) (store! (field o next) (load i)) (load o))))))

(defn parse-defstruct [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp)))] (-> (Result StructDef Diag))
  (try (let [name (try! (sym-of a (try! (need [Sexp] (sx-get rest 0) "defstruct: missing name")) "struct name"))
             opts (alloc-stack StructOpts)]
    (store! opts (try! (parse-struct-opts a rest 1)))
    (let [tpr (alloc-stack TPResult)] (store! tpr (try! (parse-type-params a rest (load (field opts next)))))
      (let [i (if (load (field tpr consumed)) (iadd (load (field opts next)) 1) (load (field opts next)))
            fields-items (if (opt-is-vec (sx-get rest i)) (sx-items (opt-get (sx-get rest i))) (zeroed (ptr (ArrayList Sexp))))]
        (if (icmp-eq (cast i64 fields-items) 0) (Err [StructDef Diag] (derr (sconcat3 a "defstruct '" name "': expected a field vector")))
          (if (load (field opts bits))
              (finish-bits a name (load (field tpr params)) (load (field opts backing)) fields-items)
              (finish-normal a name (load (field tpr params)) (load (field opts packed)) (load (field opts explicit)) (load (field opts aligned)) (load (field opts exp-size)) (load (field opts has-size)) (load (field opts exp-align)) fields-items))))))))
(defn parse-extern [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp)))] (-> (Result Extern Diag))
  (try (let [name (try! (sym-of a (try! (need [Sexp] (sx-get rest 0) "extern: missing name")) "extern name")) (mut i) 1 (mut cc) "c"]
    (match (sx-get rest (load i))
      (Some [k] (if (and (icmp-eq (sx-tag k) 3) (str-eq (sx-sval k) "cc"))
                    (do (store! cc (try! (sym-of a (try! (need [Sexp] (sx-get rest (iadd (load i) 1)) "extern: ':cc' missing convention")) "cc name"))) (store! i (iadd (load i) 2)) 0) 0))
      (None [] 0))
    (let [params-items (try! (need-vec (sx-get rest (load i)) (sconcat3 a "extern '" name "': expected a vector of parameter types")))]
      (store! i (iadd (load i) 1))
      (let [pn (sx-len params-items)
            variadic (if (icmp-gt pn 0) (let [last (sx-at params-items (isub pn 1))] (and (icmp-eq (sx-tag last) 2) (str-eq (sx-sval last) "..."))) false)
            fixed-n (if variadic (isub pn 1) pn) (mut params) (al-new [Type] a) (mut pi) 0]
        (loop (if (icmp-ge (load pi) fixed-n) (break) (do (al-push! (mut params) (try! (parse-type a (sx-at params-items (load pi))))) (store! pi (iadd (load pi) 1)))))
        (let [ret-l (try! (as-list (try! (need [Sexp] (sx-get rest (load i)) "extern: missing (-> :type)")) "expected (-> :type)"))]
          (if (not (str-eq (try! (head-sym a ret-l)) "->")) (return-from :try (Err [Extern Diag] (derr (sconcat3 a "extern '" name "': expected (-> :type)")))) 0)
          (let [ret (try! (parse-type a (try! (need [Sexp] (sx-get ret-l 1) "(-> ) missing type"))))]
            (Ok (let [e (alloc-stack Extern)] (store! (field e name) name) (store! (field e cc) (load cc)) (store! (field e params) (box-al [Type] a (load params))) (store! (field e variadic) variadic) (store! (field e ret) ret) (load e))))))))))

(defn native-cc-parse [(s (slice u8))] (-> i64)
  (if (or (str-eq s "c") (str-eq s "ccc")) 0 (if (or (str-eq s "fast") (str-eq s "fastcc")) 1 (if (or (str-eq s "cold") (str-eq s "coldcc")) 2 -1))))

(defn parse-defcc [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp)))] (-> (Result Convention Diag))
  (try (let [name (try! (sym-of a (try! (need [Sexp] (sx-get rest 0) "defcc: missing name")) "defcc name"))
             (mut params) (box-al [(slice u8)] a (al-new [(slice u8)] a)) (mut ret) (None [(slice u8)])
             (mut clobber) (box-al [(slice u8)] a (al-new [(slice u8)] a)) (mut preserve) (box-al [(slice u8)] a (al-new [(slice u8)] a))
             (mut native) -1 (mut shim) false (mut i) 1 nr (sx-len rest)]
    (loop (if (icmp-ge (load i) nr) (break)
      (let [kw (try! (kw-of a (sx-at rest (load i)) "defcc option"))
            val (try! (need [Sexp] (sx-get rest (iadd (load i) 1)) (sconcat3 a "defcc: option ':" kw "' missing value")))]
        (if (str-eq kw "params") (do (store! params (try! (sym-vec a val "params"))) 0)
          (if (str-eq kw "ret") (do (store! ret (Some (try! (sym-of a val "ret")))) 0)
            (if (str-eq kw "clobber") (do (store! clobber (try! (sym-vec a val "clobber"))) 0)
              (if (str-eq kw "preserve") (do (store! preserve (try! (sym-vec a val "preserve"))) 0)
                (if (str-eq kw "native")
                    (let [nn (try! (sym-of a val "native")) code (native-cc-parse nn)]
                      (if (icmp-lt code 0) (return-from :try (Err [Convention Diag] (derr-at (sx-lo val) (sx-hi val) (sconcat3 a "defcc: unknown native cc '" nn "'")))) (do (store! native code) 0)))
                  (if (str-eq kw "lower")
                      (if (str-eq (try! (sym-of a val "lower")) "shim") (do (store! shim true) 0) 0)
                    (return-from :try (Err [Convention Diag] (derr-at (sx-lo (sx-at rest (load i))) (sx-hi (sx-at rest (load i))) (sconcat3 a "defcc: unknown option ':" kw "'"))))))))))
        (store! i (iadd (load i) 2)))))
    (let [lowering (if (icmp-ge (load native) 0) (LNative (load native)) (if (load shim) (LShim) (return-from :try (Err [Convention Diag] (derr (sconcat3 a "defcc '" name "': needs a lowering (:native <c|fast|cold> or :lower shim)"))))))]
      (Ok (let [c (alloc-stack Convention)] (store! (field c name) name) (store! (field c params) (load params)) (store! (field c ret) (load ret)) (store! (field c clobber) (load clobber)) (store! (field c preserve) (load preserve)) (store! (field c lowering) lowering) (load c)))))))

(defn parse-defn [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp)))] (-> (Result Func Diag))
  (try (let [name (try! (sym-of a (try! (need [Sexp] (sx-get rest 0) "defn: missing name")) "defn name")) (mut i) 1 (mut cc) "c"]
    (match (sx-get rest (load i))
      (Some [k] (if (and (icmp-eq (sx-tag k) 3) (str-eq (sx-sval k) "cc"))
                    (do (store! cc (try! (sym-of a (try! (need [Sexp] (sx-get rest (iadd (load i) 1)) "defn: ':cc' missing convention name")) "cc name"))) (store! i (iadd (load i) 2)) 0) 0))
      (None [] 0))
    (let [tpr (alloc-stack TPResult)] (store! tpr (try! (parse-type-params a rest (load i))))
      (if (load (field tpr consumed)) (do (store! i (iadd (load i) 1)) 0) 0)
      (let [params-items (try! (need-vec (sx-get rest (load i)) (sconcat3 a "defn '" name "': expected parameter vector")))]
        (store! i (iadd (load i) 1))
        (let [(mut params) (al-new [Param] a) (mut macrov) false np (sx-len params-items) (mut pi) 0]
          (loop (if (icmp-ge (load pi) np) (break)
            (let [p (sx-at params-items (load pi))]
              (store! pi (iadd (load pi) 1))
              (if (and (icmp-eq (sx-tag p) 2) (str-eq (sx-sval p) "&")) (do (store! macrov true) 0)
                (let [pl (try! (as-list p "parameter must be (name :type)"))
                      pn (try! (sym-of a (sx-at pl 0) "param name"))
                      pt (try! (parse-type a (try! (need [Sexp] (sx-get pl 1) "param missing type"))))]
                  (let [pp (alloc-stack Param)] (store! (field pp name) pn) (store! (field pp ty) pt) (al-push! (mut params) (load pp))))))))
          (let [ret-l (try! (as-list (try! (need [Sexp] (sx-get rest (load i)) "defn: missing (-> :type)")) "expected (-> :type)"))]
            (if (not (str-eq (try! (head-sym a ret-l)) "->")) (return-from :try (Err [Func Diag] (derr "defn: expected (-> :type) after params"))) 0)
            (let [ret (try! (parse-type a (try! (need [Sexp] (sx-get ret-l 1) "(-> ) missing type"))))]
              (store! i (iadd (load i) 1))
              (let [body (try! (parse-exprs a (rest-from a rest (load i))))]
                (if (icmp-eq (al-len [Expr] (load body)) 0) (return-from :try (Err [Func Diag] (derr (sconcat3 a "defn '" name "': empty body")))) 0)
                (Ok (let [f (alloc-stack Func)]
                      (store! (field f name) name) (store! (field f type_params) (load (field tpr params))) (store! (field f bounds) (load (field tpr bounds)))
                      (store! (field f cc) (load cc)) (store! (field f params) (box-al [Param] a (load params))) (store! (field f ret) ret)
                      (store! (field f body) body) (store! (field f macro_variadic) (load macrov)) (store! (field f lo) -1) (store! (field f hi) -1) (load f))))))))))))

(defn parse-deftrait [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp)))] (-> (Result TraitDef Diag))
  (try (let [name (try! (sym-of a (try! (need [Sexp] (sx-get rest 0) "deftrait: missing name")) "trait name"))
             self-param (if (and (opt-is-vec (sx-get rest 1)) (icmp-eq (sx-len (sx-items (opt-get (sx-get rest 1)))) 1))
                            (try! (sym-of a (sx-at (sx-items (opt-get (sx-get rest 1))) 0) "Self parameter"))
                            (return-from :try (Err [TraitDef Diag] (derr "deftrait: expected [Self] after the name"))))
             (mut methods) (al-new [TraitMethod] a) nr (sx-len rest) (mut mi) 2]
    (loop (if (icmp-ge (load mi) nr) (break)
      (let [m (sx-at rest (load mi))]
        (store! mi (iadd (load mi) 1))
        (let [ml (try! (as-list m "trait method must be (name [params] (-> ret))"))
              mname (try! (sym-of a (try! (need [Sexp] (sx-get ml 0) "trait method: missing name")) "method name"))
              params-items (if (opt-is-vec (sx-get ml 1)) (sx-items (opt-get (sx-get ml 1))) (return-from :try (Err [TraitDef Diag] (derr-at (sx-lo m) (sx-hi m) (sconcat3 a "trait method '" mname "': expected a param vector")))))
              (mut params) (al-new [Param] a) pnn (sx-len params-items) (mut pi) 0]
          (loop (if (icmp-ge (load pi) pnn) (break)
            (let [p (sx-at params-items (load pi))]
              (store! pi (iadd (load pi) 1))
              (let [pl (try! (as-list p "method param must be (name :type)"))
                    pnm (try! (sym-of a (sx-at pl 0) "param name"))
                    pty (try! (parse-type a (try! (need [Sexp] (sx-get pl 1) "method param missing type"))))]
                (let [pp (alloc-stack Param)] (store! (field pp name) pnm) (store! (field pp ty) pty) (al-push! (mut params) (load pp)))))))
          (let [ret-l (try! (as-list (try! (need [Sexp] (sx-get ml 2) "trait method: missing (-> ret)")) "expected (-> ret)"))]
            (if (not (str-eq (try! (head-sym a ret-l)) "->")) (return-from :try (Err [TraitDef Diag] (derr-at (sx-lo m) (sx-hi m) (sconcat3 a "trait method '" mname "': expected (-> ret)")))) 0)
            (let [ret (try! (parse-type a (try! (need [Sexp] (sx-get ret-l 1) "(-> ) missing type"))))]
              (let [mp (alloc-stack TraitMethod)] (store! (field mp name) mname) (store! (field mp params) (box-al [Param] a (load params))) (store! (field mp ret) ret) (al-push! (mut methods) (load mp)))))))))
    (Ok (let [t (alloc-stack TraitDef)] (store! (field t name) name) (store! (field t self_param) self-param) (store! (field t methods) (box-al [TraitMethod] a (load methods))) (load t))))))

(defn parse-impl [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp))) (slo i64) (shi i64)] (-> (Result ImplDef Diag))
  (try (let [trait-name (try! (sym-of a (try! (need [Sexp] (sx-get rest 0) "impl: missing trait name")) "trait name"))
             for-type (try! (sym-of a (try! (need [Sexp] (sx-get rest 1) "impl: missing type name")) "impl type"))
             (mut methods) (al-new [Func] a) nr (sx-len rest) (mut mi) 2]
    (loop (if (icmp-ge (load mi) nr) (break)
      (let [m (sx-at rest (load mi))]
        (store! mi (iadd (load mi) 1))
        (let [ml (try! (as-list m "impl method must be (name [params] (-> ret) body…)"))
              f0 (try! (parse-defn a ml))]
          (let [fp (alloc-stack Func)] (store! fp f0) (store! (field fp lo) slo) (store! (field fp hi) shi) (al-push! (mut methods) (load fp)))))))
    (Ok (let [im (alloc-stack ImplDef)] (store! (field im trait_name) trait-name) (store! (field im for_type) for-type) (store! (field im methods) (box-al [Func] a (load methods))) (load im))))))

(defn parse-export-c [(a (ptr Allocator)) (rest (ptr (ArrayList Sexp)))] (-> (Result (ptr (ArrayList ExportC)) Diag))
  (try (let [(mut out) (al-new [ExportC] a) n (sx-len rest) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (let [item (sx-at rest (load i))]
        (store! i (iadd (load i) 1))
        (let [tg (sx-tag item)]
          (if (icmp-eq tg 2)
              (let [ep (alloc-stack ExportC)] (store! (field ep name) (sx-sval item)) (store! (field ep symbol) (None [(slice u8)])) (store! (field ep params) (box-al [Type] a (al-new [Type] a))) (store! (field ep lo) (sx-lo item)) (store! (field ep hi) (sx-hi item)) (al-push! (mut out) (load ep)))
            (if (icmp-eq tg 7)
                (let [v (sx-items item)
                      nm (if (and (icmp-gt (sx-len v) 0) (icmp-eq (sx-tag (sx-at v 0)) 2)) (sx-sval (sx-at v 0)) (return-from :try (Err [(ptr (ArrayList ExportC)) Diag] (derr-at (sx-lo item) (sx-hi item) "export-c: expected [name :as \"symbol\"]"))))
                      sym0 (if (and (opt-is-kw (sx-get v 1) "as") (opt-is-str (sx-get v 2))) (opt-str-val (sx-get v 2)) (return-from :try (Err [(ptr (ArrayList ExportC)) Diag] (derr-at (sx-lo item) (sx-hi item) "export-c: expected [name :as \"symbol\"]"))))]
                  (let [ep (alloc-stack ExportC)] (store! (field ep name) nm) (store! (field ep symbol) (Some sym0)) (store! (field ep params) (box-al [Type] a (al-new [Type] a))) (store! (field ep lo) (sx-lo item)) (store! (field ep hi) (sx-hi item)) (al-push! (mut out) (load ep))))
              (return-from :try (Err [(ptr (ArrayList ExportC)) Diag] (derr-at (sx-lo item) (sx-hi item) "export-c: each entry is a function name or [name :as \"symbol\"]")))))))))
    (Ok (box-al [ExportC] a (load out))))))

(defn default-c-convention [(a (ptr Allocator))] (-> Convention)
  (let [c (alloc-stack Convention)]
    (store! (field c name) "c") (store! (field c params) (box-al [(slice u8)] a (al-new [(slice u8)] a))) (store! (field c ret) (None [(slice u8)]))
    (store! (field c clobber) (box-al [(slice u8)] a (al-new [(slice u8)] a))) (store! (field c preserve) (box-al [(slice u8)] a (al-new [(slice u8)] a)))
    (store! (field c lowering) (LNative 0)) (load c)))

; `parse_program` in src/parse.rs: fold the top-level forms into a Program.
(defn parse-program [(a (ptr Allocator)) (forms (ptr (ArrayList Sexp)))] (-> (Result Program Diag))
  (let [(mut convs) (al-new [Convention] a) (mut structs) (al-new [StructDef] a) (mut sums) (al-new [SumDef] a)
        (mut externs) (al-new [Extern] a) (mut funcs) (al-new [Func] a) (mut asserts) (al-new [StaticAssert] a)
        (mut consts) (al-new [Const] a) (mut traits) (al-new [TraitDef] a) (mut impls) (al-new [ImplDef] a)
        (mut metas) (al-new [Expr] a) (mut exports) (al-new [ExportC] a)
        (mut err) (zeroed Diag) (mut failed) false]
    (al-push! (mut convs) (default-c-convention a))
    (let [nf (sx-len forms) (mut fi) 0]
      (loop (if (icmp-ge (load fi) nf) (break)
        (let [form (sx-at forms (load fi)) flo (sx-lo form) fhi (sx-hi form)]
          (store! fi (iadd (load fi) 1))
          (let [res
                (match (as-list form "top-level form must be a list")
                  (Err [d] (Err [i64 Diag] d))
                  (Ok [items]
                    (match (head-sym a items)
                      (Err [d] (Err [i64 Diag] d))
                      (Ok [head]
                        (let [rest (rest-from a items 1)]
                          (if (str-eq head "defcc")
                              (match (parse-defcc a rest) (Err [d] (Err [i64 Diag] d))
                                (Ok [c]
                                  (let [cp (alloc-stack Convention)] (store! cp c)
                                    (let [nm (load (field cp name)) (mut found) -1 (mut ci) 0 cn (al-len [Convention] (load convs))]
                                      (loop (if (icmp-ge (load ci) cn) (break) (do (if (str-eq (conv-name (al-get [Convention] (load convs) (load ci))) nm) (do (store! found (load ci)) 0) 0) (store! ci (iadd (load ci) 1)))))
                                      (if (icmp-ge (load found) 0)
                                          (if (str-eq nm "c") (do (al-set! [Convention] (mut convs) (load found) (load cp)) (Ok [i64 Diag] 0)) (Err [i64 Diag] (derr (sconcat3 a "convention '" nm "' defined twice"))))
                                          (do (al-push! (mut convs) (load cp)) (Ok [i64 Diag] 0)))))))
                          (if (str-eq head "defstruct") (match (parse-defstruct a rest) (Ok [sd] (do (al-push! (mut structs) sd) (Ok [i64 Diag] 0))) (Err [d] (Err [i64 Diag] d)))
                          (if (str-eq head "defsum") (match (parse-defsum a rest) (Ok [sd] (do (al-push! (mut sums) sd) (Ok [i64 Diag] 0))) (Err [d] (Err [i64 Diag] d)))
                          (if (str-eq head "defn")
                              (match (parse-defn a rest) (Err [d] (Err [i64 Diag] d))
                                (Ok [f0]
                                  (let [fp (alloc-stack Func)] (store! fp f0) (store! (field fp lo) flo) (store! (field fp hi) fhi)
                                    (let [nm (load (field fp name)) (mut dup) false (mut ci) 0 cn (al-len [Func] (load funcs))]
                                      (loop (if (icmp-ge (load ci) cn) (break) (do (if (str-eq (func-name (al-get [Func] (load funcs) (load ci))) nm) (do (store! dup true) 0) 0) (store! ci (iadd (load ci) 1)))))
                                      (if (load dup) (Err [i64 Diag] (derr (sconcat3 a "function '" nm "' defined twice"))) (do (al-push! (mut funcs) (load fp)) (Ok [i64 Diag] 0)))))))
                          (if (str-eq head "extern") (match (parse-extern a rest) (Ok [e] (do (al-push! (mut externs) e) (Ok [i64 Diag] 0))) (Err [d] (Err [i64 Diag] d)))
                          (if (str-eq head "export-c")
                              (match (parse-export-c a rest) (Err [d] (Err [i64 Diag] d))
                                (Ok [es] (do (let [en (al-len [ExportC] (load es)) (mut ei) 0] (loop (if (icmp-ge (load ei) en) (break) (do (al-push! (mut exports) (al-get [ExportC] (load es) (load ei))) (store! ei (iadd (load ei) 1)))))) (Ok [i64 Diag] 0))))
                          (if (str-eq head "static-assert")
                              (match (parse-static-assert a items) (Ok [sa] (do (al-push! (mut asserts) sa) (Ok [i64 Diag] 0))) (Err [d] (Err [i64 Diag] d)))
                          (if (str-eq head "const") (match (parse-const a rest) (Ok [c] (do (al-push! (mut consts) c) (Ok [i64 Diag] 0))) (Err [d] (Err [i64 Diag] d)))
                          (if (str-eq head "deftrait") (match (parse-deftrait a rest) (Ok [t] (do (al-push! (mut traits) t) (Ok [i64 Diag] 0))) (Err [d] (Err [i64 Diag] d)))
                          (if (str-eq head "impl") (match (parse-impl a rest flo fhi) (Ok [im] (do (al-push! (mut impls) im) (Ok [i64 Diag] 0))) (Err [d] (Err [i64 Diag] d)))
                          (if (str-eq head "meta")
                              (if (not (icmp-eq (sx-len items) 2)) (Err [i64 Diag] (derr "meta: expected (meta EXPR)"))
                                  (match (parse-expr a (sx-at items 1)) (Ok [e] (do (al-push! (mut metas) e) (Ok [i64 Diag] 0))) (Err [d] (Err [i64 Diag] d))))
                            (Err [i64 Diag] (derr (sconcat3 a "unknown top-level form '" head "'")))))))))))))))))))]
            (match res (Ok [_] 0) (Err [d] (do (store! err (dwspan d flo fhi)) (store! failed true) (break)))))))))
    (if (load failed) (Err (load err))
        (Ok (let [pp (alloc-stack Program)]
              (store! (field pp conventions) (box-al [Convention] a (load convs)))
              (store! (field pp structs) (box-al [StructDef] a (load structs)))
              (store! (field pp sums) (box-al [SumDef] a (load sums)))
              (store! (field pp externs) (box-al [Extern] a (load externs)))
              (store! (field pp funcs) (box-al [Func] a (load funcs)))
              (store! (field pp asserts) (box-al [StaticAssert] a (load asserts)))
              (store! (field pp consts) (box-al [Const] a (load consts)))
              (store! (field pp traits) (box-al [TraitDef] a (load traits)))
              (store! (field pp impls) (box-al [ImplDef] a (load impls)))
              (store! (field pp metas) (box-al [Expr] a (load metas)))
              (store! (field pp exports) (box-al [ExportC] a (load exports)))
              (load pp))))))

; static-assert (src/parse.rs): condition presence + message rule.
(defn assert-msg [(a (ptr Allocator)) (items (ptr (ArrayList Sexp)))] (-> (Result (slice u8) Diag))
  (match (sx-get items 2)
    (None [] (Ok "static assertion failed"))
    (Some [s] (if (icmp-eq (sx-tag s) 4) (Ok (sx-sval s)) (Err (derr "static-assert: message must be a string"))))))
(defn parse-static-assert [(a (ptr Allocator)) (items (ptr (ArrayList Sexp)))] (-> (Result StaticAssert Diag))
  (try (let [cond (try! (parse-expr a (try! (need [Sexp] (sx-get items 1) "static-assert: missing condition"))))
             msg (try! (assert-msg a items))]
    (Ok (let [ap (alloc-stack StaticAssert)] (store! (field ap cnd) cond) (store! (field ap msg) msg) (load ap))))))

; ============================ reused reader =================================
; Ported (and verified) in selfhost/reader.coil — copied here so the parser can
; turn source into Sexp. Treat as already-correct.
(defn looks-numeric [(s (slice u8))] (-> bool)
  (let [n (slice-len s)]
    (if (icmp-eq n 0) false
        (let [c0 (cast i64 (slice-get s 0))]
          (if (and (icmp-ge c0 48) (icmp-le c0 57)) true
              (if (or (icmp-eq c0 45) (or (icmp-eq c0 43) (icmp-eq c0 46)))
                  (if (icmp-ge n 2)
                      (let [c1 (cast i64 (slice-get s 1))] (and (icmp-ge c1 48) (icmp-le c1 57)))
                      false)
                  false))))))

(defn parse-int [(s (slice u8))] (-> (Option i64))
  (let [n (slice-len s)]
    (let [dec
          (if (icmp-eq n 0) (None [i64])
              (let [(mut i) 0 (mut neg) false]
                (let [c0 (cast i64 (slice-get s 0))]
                  (if (icmp-eq c0 45) (do (store! neg true) (store! i 1))
                    (if (icmp-eq c0 43) (store! i 1) 0)))
                (if (icmp-ge (load i) n) (None [i64])
                    (let [(mut mag) 0 (mut ok) true (mut overflow) false
                          maxrem (if (load neg) 8 7)]
                      (loop
                        (if (icmp-ge (load i) n) (break)
                          (let [c (cast i64 (slice-get s (load i)))]
                            (if (and (icmp-ge c 48) (icmp-le c 57))
                                (let [d (isub c 48)]
                                  (if (or (icmp-gt (load mag) 922337203685477580)
                                          (and (icmp-eq (load mag) 922337203685477580) (icmp-gt d maxrem)))
                                      (do (store! overflow true) (break))
                                      (do (store! mag (iadd (imul (load mag) 10) d)) (store! i (iadd (load i) 1)))))
                                (do (store! ok false) (break))))))
                      (if (or (not (load ok)) (load overflow)) (None [i64])
                          (Some (if (load neg) (isub 0 (load mag)) (load mag))))))))]
      (match dec
        (Some [v] (Some v))
        (None []
          (if (icmp-eq n 0) (None [i64])
              (let [(mut neg2) false (mut bstart) 0]
                (let [c0 (cast i64 (slice-get s 0))]
                  (if (icmp-eq c0 45) (do (store! neg2 true) (store! bstart 1))
                    (if (icmp-eq c0 43) (store! bstart 1) 0)))
                (let [blen (isub n (load bstart)) (mut radix) 0 (mut dstart) (load bstart)]
                  (if (and (icmp-ge blen 2) (icmp-eq (cast i64 (slice-get s (load bstart))) 48))
                      (let [c1 (cast i64 (slice-get s (iadd (load bstart) 1)))]
                        (if (or (icmp-eq c1 120) (icmp-eq c1 88)) (do (store! radix 16) (store! dstart (iadd (load bstart) 2)))
                          (if (or (icmp-eq c1 98) (icmp-eq c1 66)) (do (store! radix 2) (store! dstart (iadd (load bstart) 2)))
                            (if (or (icmp-eq c1 111) (icmp-eq c1 79)) (do (store! radix 8) (store! dstart (iadd (load bstart) 2)))
                              0))))
                      0)
                  (if (icmp-eq (load radix) 0)
                      (let [body (subslice s (load bstart) n)
                            has-us (do (let [(mut f) false (mut j) (load bstart)]
                                         (loop (if (icmp-ge (load j) n) (break)
                                             (do (if (icmp-eq (cast i64 (slice-get s (load j))) 95) (store! f true) false)
                                                 (store! j (iadd (load j) 1)))))
                                         (load f)))]
                        (if (and has-us (looks-numeric body)) (do (store! radix 10) (store! dstart (load bstart))) 0))
                      0)
                  (if (icmp-eq (load radix) 0) (None [i64])
                      (let [(mut mag) 0 (mut count) 0 (mut bad) false (mut ovf) false
                            (mut j) (load dstart) rr (load radix)]
                        (loop
                          (if (icmp-ge (load j) n) (break)
                            (let [c (cast i64 (slice-get s (load j)))]
                              (store! j (iadd (load j) 1))
                              (if (icmp-eq c 95) 0
                                (let [dv (let [v0 (if (and (icmp-ge c 48) (icmp-le c 57)) (isub c 48)
                                                    (if (and (icmp-ge c 97) (icmp-le c 122)) (iadd (isub c 97) 10)
                                                      (if (and (icmp-ge c 65) (icmp-le c 90)) (iadd (isub c 65) 10) -1)))]
                                           (if (icmp-lt v0 0) -1 (if (icmp-ge v0 rr) -1 v0)))]
                                  (if (icmp-lt dv 0) (do (store! bad true) (break))
                                      (let [maxdiv (udiv -1 rr) maxrem (urem -1 rr)]
                                        (if (or (icmp-gt (cast u64 (load mag)) (cast u64 maxdiv))
                                                (and (icmp-eq (load mag) maxdiv) (icmp-gt (cast u64 dv) (cast u64 maxrem))))
                                            (do (store! ovf true) (break))
                                            (do (store! mag (iadd (imul (load mag) rr) dv)) (store! count (iadd (load count) 1)))))))))))
                        (if (or (load bad) (or (load ovf) (icmp-eq (load count) 0))) (None [i64])
                            (Some (if (load neg2) (isub 0 (load mag)) (load mag))))))))))))))

(defn atom [(s (slice u8))] (-> SexpKind)
  (let [n (slice-len s)]
    (if (and (icmp-gt n 0) (icmp-eq (cast i64 (slice-get s 0)) 58)) (KKw (subslice s 1 n))
        (match (parse-int s)
          (Some [v] (KInt v))
          (None []
            (if (and (looks-numeric s)
                     (do (let [(mut f) false (mut j) 0]
                           (loop (if (icmp-ge (load j) n) (break)
                               (do (let [c (cast i64 (slice-get s (load j)))]
                                     (if (or (icmp-eq c 46) (or (icmp-eq c 101) (icmp-eq c 69))) (store! f true) false))
                                   (store! j (iadd (load j) 1)))))
                           (load f))))
                (let [a (malloc-allocator) buf (slice->cstr a s) ep (alloc-stack (ptr i8))
                      x (strtod buf ep) consumed (isub (cast i64 (load ep)) (cast i64 buf))]
                  (if (and (icmp-gt n 0) (icmp-eq consumed n)) (KFloat (f64-bits x)) (KSym s)))
                (KSym s)))))))

(defn read-string-body [(a (ptr Allocator)) (src (slice u8)) (open-off i64) (i i64)] (-> (Result StrRead Diag))
  (let [n (slice-len src) (mut buf) (al-new [u8] a) (mut k) i (mut out) (zeroed (Result StrRead Diag))]
    (loop
      (if (icmp-ge (load k) n)
          (do (store! out (Err (mk-diag open-off n "unterminated string literal"))) (break))
          (let [c (cast i64 (slice-get src (load k)))]
            (store! k (iadd (load k) 1))
            (if (icmp-eq c 34)
                (do (store! out (Ok (mk-strread (al-slice [u8] (load buf)) (load k)))) (break))
              (if (icmp-eq c 92)
                  (if (icmp-ge (load k) n)
                      (do (store! out (Err (mk-diag open-off n "unterminated string escape"))) (break))
                      (let [e (cast i64 (slice-get src (load k)))]
                        (store! k (iadd (load k) 1))
                        (al-push! (mut buf)
                          (cast u8 (if (icmp-eq e 110) 10 (if (icmp-eq e 116) 9 (if (icmp-eq e 34) 34 (if (icmp-eq e 92) 92 e))))))))
                  (al-push! (mut buf) (cast u8 c)))))))
    (load out)))

(defn tokenize [(a (ptr Allocator)) (src (slice u8))] (-> (Result (ptr (ArrayList Tok)) Diag))
  (let [n (slice-len src) (mut toks) (al-new [Tok] a) (mut i) 0
        (mut out) (zeroed (Result (ptr (ArrayList Tok)) Diag)) (mut done) false]
    (loop
      (if (icmp-ge (load i) n) (break)
        (let [c (cast i64 (slice-get src (load i)))]
          (if (or (icmp-eq c 32) (or (icmp-eq c 9) (or (icmp-eq c 10) (or (icmp-eq c 13) (or (icmp-eq c 11) (icmp-eq c 12))))))
              (store! i (iadd (load i) 1))
            (if (icmp-eq c 59)
                (loop (if (icmp-ge (load i) n) (break)
                    (let [ch (cast i64 (slice-get src (load i)))]
                      (store! i (iadd (load i) 1)) (if (icmp-eq ch 10) (break) 0))))
              (if (or (icmp-eq c 40) (icmp-eq c 91))
                  (do (al-push! (mut toks) (mk-tok (TOpen c) (load i) (iadd (load i) 1))) (store! i (iadd (load i) 1)))
                (if (or (icmp-eq c 41) (icmp-eq c 93))
                    (do (al-push! (mut toks) (mk-tok (TClose c) (load i) (iadd (load i) 1))) (store! i (iadd (load i) 1)))
                  (if (icmp-eq c 39)
                      (do (al-push! (mut toks) (mk-tok (TPrefix "quote") (load i) (iadd (load i) 1))) (store! i (iadd (load i) 1)))
                    (if (icmp-eq c 96)
                        (do (al-push! (mut toks) (mk-tok (TPrefix "quasiquote") (load i) (iadd (load i) 1))) (store! i (iadd (load i) 1)))
                      (if (icmp-eq c 126)
                          (let [istart (load i)]
                            (store! i (iadd (load i) 1))
                            (if (and (icmp-lt (load i) n) (icmp-eq (cast i64 (slice-get src (load i))) 64))
                                (do (al-push! (mut toks) (mk-tok (TPrefix "unquote-splicing") istart (iadd (load i) 1))) (store! i (iadd (load i) 1)))
                                (al-push! (mut toks) (mk-tok (TPrefix "unquote") istart (iadd istart 1)))))
                        (if (icmp-eq c 34)
                            (let [istart (load i)]
                              (store! i (iadd (load i) 1))
                              (match (read-string-body a src istart (load i))
                                (Err [d] (do (store! out (Err d)) (store! done true) (break)))
                                (Ok [sr]
                                  (let [srp (alloc-stack StrRead)]
                                    (store! srp sr)
                                    (al-push! (mut toks) (mk-tok (TStr (load (field srp s))) istart (load (field srp end))))
                                    (store! i (load (field srp end)))))))
                            (let [start (load i) (mut end) (load i)]
                              (loop
                                (if (icmp-ge (load i) n) (break)
                                  (let [cc (cast i64 (slice-get src (load i)))]
                                    (if (or (or (icmp-eq cc 32) (or (icmp-eq cc 9) (or (icmp-eq cc 10) (or (icmp-eq cc 13) (or (icmp-eq cc 11) (icmp-eq cc 12))))))
                                            (or (icmp-eq cc 40) (or (icmp-eq cc 41) (or (icmp-eq cc 91) (or (icmp-eq cc 93) (or (icmp-eq cc 59) (or (icmp-eq cc 39) (or (icmp-eq cc 96) (or (icmp-eq cc 126) (icmp-eq cc 34))))))))))
                                        (break)
                                        (do (store! i (iadd (load i) 1)) (store! end (load i)))))))
                              (let [stok (subslice src start (load end))]
                                (if (and (and (icmp-eq (isub (load end) start) 1) (icmp-eq (cast i64 (slice-get src start)) 99))
                                         (and (icmp-lt (load i) n) (icmp-eq (cast i64 (slice-get src (load i))) 34)))
                                    (do (store! i (iadd (load i) 1))
                                        (match (read-string-body a src start (load i))
                                          (Err [d] (do (store! out (Err d)) (store! done true) (break)))
                                          (Ok [sr]
                                            (let [srp (alloc-stack StrRead)]
                                              (store! srp sr)
                                              (al-push! (mut toks) (mk-tok (TCStr (load (field srp s))) start (load (field srp end))))
                                              (store! i (load (field srp end)))))))
                                    (al-push! (mut toks) (mk-tok (TAtom stok) start (load end)))))))))))))))))
    (if (load done) (load out)
        (Ok (let [bp (unwrap-ptr [(ArrayList Tok)] (create [(ArrayList Tok)] a))] (store! bp (load toks)) bp)))))

(defn parse-one [(p (ptr Parser)) (a (ptr Allocator))] (-> (Result Sexp Diag))
  (let [toks (load (field p toks)) ntok (al-len [Tok] (load toks)) pos (load (field p pos))]
    (if (icmp-ge pos ntok) (Err (mk-diag -1 -1 "unexpected end of input"))
        (let [tok (alloc-stack Tok)]
          (store! tok (al-get [Tok] (load toks) pos))
          (store! (field p pos) (iadd pos 1))
          (let [tlo (load (field tok lo)) thi (load (field tok hi))]
            (match (load (field tok kind))
              (TStr  [s] (Ok (mk-sexp (KStr s) tlo thi)))
              (TCStr [s] (Ok (mk-sexp (KCStr s) tlo thi)))
              (TAtom [s] (Ok (mk-sexp (atom s) tlo thi)))
              (TClose [c]
                (let [cs (slice-new [u8] (let [cb (cast (ptr u8) (unwrap-ptr [i8] (raw-alloc a 1 1)))] (store! (index cb 0) (cast u8 c)) cb) 1)
                      m1 (match (str-concat a "unexpected '" cs) (Some [v] v) (None [] ""))
                      m2 (match (str-concat a m1 "'") (Some [v] v) (None [] ""))]
                  (Err (mk-diag tlo thi m2))))
              (TPrefix [sym]
                (match (parse-one p a)
                  (Err [d] (Err d))
                  (Ok [inner]
                    (let [ip (alloc-stack Sexp)]
                      (store! ip inner)
                      (let [ihi (load (field ip hi)) (mut kids) (al-new [Sexp] a)]
                        (al-push! (mut kids) (mk-sexp (KSym sym) tlo thi))
                        (al-push! (mut kids) (load ip))
                        (Ok (mk-sexp (KList (box-items a (load kids))) tlo ihi)))))))
              (TOpen [open]
                (let [close (if (icmp-eq open 40) 41 93) (mut items) (al-new [Sexp] a) (mut out) (zeroed (Result Sexp Diag))]
                  (loop
                    (let [cpos (load (field p pos))]
                      (if (icmp-ge cpos ntok)
                          (do (let [cs (slice-new [u8] (let [cb (cast (ptr u8) (unwrap-ptr [i8] (raw-alloc a 1 1)))] (store! (index cb 0) (cast u8 open)) cb) 1)
                                    m1 (match (str-concat a "unclosed '" cs) (Some [v] v) (None [] ""))
                                    m2 (match (str-concat a m1 "'") (Some [v] v) (None [] ""))]
                                (store! out (Err (mk-diag tlo thi m2))))
                              (break))
                          (let [nt (alloc-stack Tok)]
                            (store! nt (al-get [Tok] (load toks) cpos))
                            (let [cdelim (match (load (field nt kind))
                                           (TClose [cc] cc) (TOpen [_] -1) (TPrefix [_] -1)
                                           (TStr [_] -1) (TCStr [_] -1) (TAtom [_] -1))]
                              (if (icmp-ge cdelim 0)
                                  (if (icmp-ne cdelim close)
                                      (do (let [os (slice-new [u8] (let [cb (cast (ptr u8) (unwrap-ptr [i8] (raw-alloc a 1 1)))] (store! (index cb 0) (cast u8 open)) cb) 1)
                                                ds (slice-new [u8] (let [cb (cast (ptr u8) (unwrap-ptr [i8] (raw-alloc a 1 1)))] (store! (index cb 0) (cast u8 cdelim)) cb) 1)
                                                m1 (match (str-concat a "mismatched delimiters: '" os) (Some [v] v) (None [] ""))
                                                m2 (match (str-concat a m1 "' .. '") (Some [v] v) (None [] ""))
                                                m3 (match (str-concat a m2 ds) (Some [v] v) (None [] ""))
                                                m4 (match (str-concat a m3 "'") (Some [v] v) (None [] ""))]
                                            (store! out (Err (mk-diag (load (field nt lo)) (load (field nt hi)) m4))))
                                          (break))
                                      (do (store! (field p pos) (iadd cpos 1))
                                          (store! out (Ok (mk-sexp (if (icmp-eq open 40)
                                                                       (KList (box-items a (load items)))
                                                                       (KVec (box-items a (load items))))
                                                                   tlo (load (field nt hi)))))
                                          (break)))
                                  (match (parse-one p a)
                                    (Ok [child] (do (al-push! (mut items) child) 0))
                                    (Err [d] (do (store! out (Err d)) (break))))))))))
                  (load out)))))))))

(defn read-all [(a (ptr Allocator)) (src (slice u8))] (-> (Result (ptr (ArrayList Sexp)) Diag))
  (match (tokenize a src)
    (Err [d] (Err d))
    (Ok [toks]
      (let [p (alloc-stack Parser) (mut out) (al-new [Sexp] a) (mut err) (zeroed Diag) (mut failed) false]
        (store! (field p toks) toks) (store! (field p pos) 0)
        (loop
          (if (icmp-ge (load (field p pos)) (al-len [Tok] (load toks))) (break)
            (match (parse-one p a)
              (Ok [s] (do (al-push! (mut out) s) 0))
              (Err [d] (do (store! err d) (store! failed true) (break))))))
        (if (load failed) (Err (load err)) (Ok (box-items a (load out))))))))

; ============================ canonical dump entry ==========================
; Emits the `(error@lo:hi "msg")` shape on a read/parse error (mirrors dump_ast
; in src/lib.rs). A dummy span (lo/hi = -1) prints `D`.
(defn dump-error [(w (ptr Writer)) (d (ptr Diag))] (-> i64)
  (ps w "(error") (dump-span w (load (field d lo)) (load (field d hi)))
  (ps w " \"") (esc-write w (load (field d msg))) (ps w "\")"))

(defn dump-ast-program [(a (ptr Allocator)) (src (slice u8))] (-> i64)
  (let [w (stdout)]
    (match (read-all a src)
      (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
      (Ok [forms]
        (match (parse-program a forms)
          (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
          (Ok [prog] (let [pp (alloc-stack Program)] (store! pp prog) (d-program w pp a)))))))
  0)

; ============================ file IO + entry ===============================
(defn read-file [(a (ptr Allocator)) (path (ptr i8))] (-> (slice u8))
  (let [fd (open path 0) buf (unwrap-ptr [i8] (raw-alloc a 65536 1)) (mut bytes) (al-new [u8] a)]
    (loop
      (let [n (read (cast i64 fd) buf 65536)]
        (if (icmp-le n 0) (break)
          (let [(mut i) 0]
            (loop (if (icmp-ge (load i) n) (break)
                (do (al-push! (mut bytes) (cast u8 (load (index buf (load i))))) (store! i (iadd (load i) 1)))))))))
    (close fd)
    (al-slice [u8] (load bytes))))

; A hand-built Program smoke test (no spans → byte-exact against `coil dump-ast`
; of the equivalent source). Validates the dumper before the parser is filled.
(defn smoke [(a (ptr Allocator))] (-> i64)
  (let [w (stdout) p (alloc-stack Program)]
    ; conventions: [c]
    (let [(mut cs) (al-new [Convention] a) cv (alloc-stack Convention)]
      (store! (field cv name) "c")
      (store! (field cv params) (let [bp (unwrap-ptr [(ArrayList (slice u8))] (create [(ArrayList (slice u8))] a))] (store! bp (al-new [(slice u8)] a)) bp))
      (store! (field cv ret) (None [(slice u8)]))
      (store! (field cv clobber) (let [bp (unwrap-ptr [(ArrayList (slice u8))] (create [(ArrayList (slice u8))] a))] (store! bp (al-new [(slice u8)] a)) bp))
      (store! (field cv preserve) (let [bp (unwrap-ptr [(ArrayList (slice u8))] (create [(ArrayList (slice u8))] a))] (store! bp (al-new [(slice u8)] a)) bp))
      (store! (field cv lowering) (LNative 0))
      (al-push! (mut cs) (load cv))
      (store! (field p conventions) (let [bp (unwrap-ptr [(ArrayList Convention)] (create [(ArrayList Convention)] a))] (store! bp (load cs)) bp)))
    ; structs: [Point {x:i64,y:i64}]
    (let [(mut ss) (al-new [StructDef] a) sd (alloc-stack StructDef)
          (mut fs) (al-new [Field] a) fx (alloc-stack Field) fy (alloc-stack Field)]
      (store! (field fx name) "x") (store! (field fx ty) (TInt 64 true)) (al-push! (mut fs) (load fx))
      (store! (field fy name) "y") (store! (field fy ty) (TInt 64 true)) (al-push! (mut fs) (load fy))
      (store! (field sd name) "Point")
      (store! (field sd type_params) (let [bp (unwrap-ptr [(ArrayList (slice u8))] (create [(ArrayList (slice u8))] a))] (store! bp (al-new [(slice u8)] a)) bp))
      (store! (field sd layout) (LC))
      (store! (field sd fields) (let [bp (unwrap-ptr [(ArrayList Field)] (create [(ArrayList Field)] a))] (store! bp (load fs)) bp))
      (al-push! (mut ss) (load sd))
      (store! (field p structs) (let [bp (unwrap-ptr [(ArrayList StructDef)] (create [(ArrayList StructDef)] a))] (store! bp (load ss)) bp)))
    ; sums: [Opt[T] (Some [v:T]) (None [])]
    (let [(mut su) (al-new [SumDef] a) sm (alloc-stack SumDef)
          (mut tps) (al-new [(slice u8)] a)
          (mut vs) (al-new [Variant] a) v1 (alloc-stack Variant) v2 (alloc-stack Variant)
          (mut f1) (al-new [Field] a) fv (alloc-stack Field)]
      (al-push! (mut tps) "T")
      (store! (field fv name) "v") (store! (field fv ty) (TStruct "T")) (al-push! (mut f1) (load fv))
      (store! (field v1 name) "Some") (store! (field v1 fields) (let [bp (unwrap-ptr [(ArrayList Field)] (create [(ArrayList Field)] a))] (store! bp (load f1)) bp))
      (store! (field v2 name) "None") (store! (field v2 fields) (let [bp (unwrap-ptr [(ArrayList Field)] (create [(ArrayList Field)] a))] (store! bp (al-new [Field] a)) bp))
      (al-push! (mut vs) (load v1)) (al-push! (mut vs) (load v2))
      (store! (field sm name) "Opt")
      (store! (field sm type_params) (let [bp (unwrap-ptr [(ArrayList (slice u8))] (create [(ArrayList (slice u8))] a))] (store! bp (load tps)) bp))
      (store! (field sm variants) (let [bp (unwrap-ptr [(ArrayList Variant)] (create [(ArrayList Variant)] a))] (store! bp (load vs)) bp))
      (al-push! (mut su) (load sm))
      (store! (field p sums) (let [bp (unwrap-ptr [(ArrayList SumDef)] (create [(ArrayList SumDef)] a))] (store! bp (load su)) bp)))
    ; externs: [puts (ptr i8) -> i32]
    (let [(mut es) (al-new [Extern] a) ex (alloc-stack Extern) (mut eps) (al-new [Type] a)]
      (al-push! (mut eps) (TPtr (box-type a (TInt 8 true))))
      (store! (field ex name) "puts") (store! (field ex cc) "c")
      (store! (field ex params) (let [bp (unwrap-ptr [(ArrayList Type)] (create [(ArrayList Type)] a))] (store! bp (load eps)) bp))
      (store! (field ex variadic) false) (store! (field ex ret) (TInt 32 true))
      (al-push! (mut es) (load ex))
      (store! (field p externs) (let [bp (unwrap-ptr [(ArrayList Extern)] (create [(ArrayList Extern)] a))] (store! bp (load es)) bp)))
    ; empty sections
    (store! (field p funcs) (let [bp (unwrap-ptr [(ArrayList Func)] (create [(ArrayList Func)] a))] (store! bp (al-new [Func] a)) bp))
    (store! (field p asserts) (let [bp (unwrap-ptr [(ArrayList StaticAssert)] (create [(ArrayList StaticAssert)] a))] (store! bp (al-new [StaticAssert] a)) bp))
    (store! (field p consts) (let [bp (unwrap-ptr [(ArrayList Const)] (create [(ArrayList Const)] a))] (store! bp (al-new [Const] a)) bp))
    (store! (field p traits) (let [bp (unwrap-ptr [(ArrayList TraitDef)] (create [(ArrayList TraitDef)] a))] (store! bp (al-new [TraitDef] a)) bp))
    (store! (field p impls) (let [bp (unwrap-ptr [(ArrayList ImplDef)] (create [(ArrayList ImplDef)] a))] (store! bp (al-new [ImplDef] a)) bp))
    (store! (field p metas) (let [bp (unwrap-ptr [(ArrayList Expr)] (create [(ArrayList Expr)] a))] (store! bp (al-new [Expr] a)) bp))
    (store! (field p exports) (let [bp (unwrap-ptr [(ArrayList ExportC)] (create [(ArrayList ExportC)] a))] (store! bp (al-new [ExportC] a)) bp))
    (d-program w p a))
  0)

; ============================ loader representation =========================
; Mirrors src/macros.rs (copied from the completed loader pass). The two HashMaps
; (ImportMap/ExportMap) and the inner HashMap (aliases) become ArrayLists keyed by
; name (linear scan); Vec fields (uses/reexports/export-names) stay ordered.
(defstruct TaggedForm [(form Sexp) (module (Option (slice u8)))])

(defstruct Alias [(alias (slice u8)) (target (slice u8))])
(defsum UseSpec
  (UAll   [])
  (UNames [(names (ptr (ArrayList (slice u8))))]))
(defstruct Use [(target (slice u8)) (spec UseSpec)])

(defstruct ModImports
  [(aliases   (ArrayList Alias))
   (uses      (ArrayList Use))
   (reexports (ArrayList (slice u8)))])

(defstruct ImpEntry [(name (slice u8)) (imp ModImports)])
(defstruct ExpEntry [(name (slice u8)) (names (ArrayList (slice u8)))])

(defstruct LS
  [(a       (ptr Allocator))
   (out     (ArrayList TaggedForm))
   (loaded  (ArrayList (slice u8)))
   (imports (ArrayList ImpEntry))
   (exports (ArrayList ExpEntry))])

(defstruct Resolved [(text (slice u8)) (incdir (slice u8))])

; ============================ loader helpers (copied) ======================
(defn mk-tagged [(form Sexp) (module (Option (slice u8)))] (-> TaggedForm)
  (let [p (alloc-stack TaggedForm)]
    (store! (field p form) form) (store! (field p module) module)
    (load p)))

(defn loader-abort [(msg (slice u8))] (-> i64)
  (let [w (stderr)] (ps w "loader error: ") (ps w msg) (wb w 10))
  (abort)
  0)

(defn cstr-len [(p (ptr i8))] (-> i64)
  (let [(mut i) 0]
    (loop (if (icmp-eq (cast i64 (load (index p (load i)))) 0) (break)
            (store! i (iadd (load i) 1))))
    (load i)))
(defn cstr->slice [(p (ptr i8))] (-> (slice u8))
  (slice-new [u8] (cast (ptr u8) p) (cstr-len p)))

(defn cwd-slice [(a (ptr Allocator))] (-> (slice u8))
  (let [buf (unwrap-ptr [i8] (raw-alloc a 4096 1))
        r (getcwd buf 4096)]
    (if (icmp-eq (cast i64 r) 0)
        (do (loader-abort "getcwd failed") "")
        (cstr->slice buf))))

(defn path-join [(a (ptr Allocator)) (base (slice u8)) (path (slice u8))] (-> (slice u8))
  (if (and (icmp-gt (slice-len path) 0) (icmp-eq (cast i64 (slice-get path 0)) 47))
      path
      (let [m1 (match (str-concat a base "/") (Some [v] v) (None [] ""))]
        (match (str-concat a m1 path) (Some [v] v) (None [] "")))))

(defn dirname [(p (slice u8))] (-> (slice u8))
  (let [n (slice-len p) (mut idx) -1 (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-eq (cast i64 (slice-get p (load i))) 47) (store! idx (load i)) 0)
          (store! i (iadd (load i) 1)))))
    (if (icmp-lt (load idx) 0) "." (subslice p 0 (load idx)))))

(defn basename [(p (slice u8))] (-> (slice u8))
  (let [n (slice-len p) (mut idx) -1 (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (icmp-eq (cast i64 (slice-get p (load i))) 47) (store! idx (load i)) 0)
          (store! i (iadd (load i) 1)))))
    (if (icmp-lt (load idx) 0) p (subslice p (iadd (load idx) 1) n))))

(defn bundled? [(name (slice u8))] (-> bool)
  (let [(mut f) false]
    (if (str-eq name "alloc.coil")     (do (store! f true) 0) 0)
    (if (str-eq name "arraylist.coil") (do (store! f true) 0) 0)
    (if (str-eq name "atomic.coil")    (do (store! f true) 0) 0)
    (if (str-eq name "closure.coil")   (do (store! f true) 0) 0)
    (if (str-eq name "control.coil")   (do (store! f true) 0) 0)
    (if (str-eq name "derive.coil")    (do (store! f true) 0) 0)
    (if (str-eq name "fmt.coil")       (do (store! f true) 0) 0)
    (if (str-eq name "hashmap.coil")   (do (store! f true) 0) 0)
    (if (str-eq name "io.coil")        (do (store! f true) 0) 0)
    (if (str-eq name "match.coil")     (do (store! f true) 0) 0)
    (if (str-eq name "mem.coil")       (do (store! f true) 0) 0)
    (if (str-eq name "mmio.coil")      (do (store! f true) 0) 0)
    (if (str-eq name "print.coil")     (do (store! f true) 0) 0)
    (if (str-eq name "result.coil")    (do (store! f true) 0) 0)
    (if (str-eq name "sexp.coil")      (do (store! f true) 0) 0)
    (if (str-eq name "simd.coil")      (do (store! f true) 0) 0)
    (if (str-eq name "slice.coil")     (do (store! f true) 0) 0)
    (if (str-eq name "str.coil")       (do (store! f true) 0) 0)
    (if (str-eq name "thread.coil")    (do (store! f true) 0) 0)
    (if (str-eq name "try.coil")       (do (store! f true) 0) 0)
    (load f)))

(defn resolve-source [(a (ptr Allocator)) (base (slice u8)) (path (slice u8))] (-> Resolved)
  (let [joined (path-join a base path)
        jc (slice->cstr a joined)
        buf (unwrap-ptr [i8] (raw-alloc a 4096 1))
        r (realpath jc buf)]
    (if (icmp-ne (cast i64 r) 0)
        (let [canon (cstr->slice buf)
              text (read-file a buf)
              incdir (dirname canon)
              rp (alloc-stack Resolved)]
          (store! (field rp text) text) (store! (field rp incdir) incdir)
          (load rp))
        (let [bn (basename path)]
          (if (bundled? bn)
              (let [libpath (path-join a "lib" bn)
                    lc (slice->cstr a libpath)
                    text (read-file a lc)
                    rp (alloc-stack Resolved)]
                (store! (field rp text) text) (store! (field rp incdir) base)
                (load rp))
              (do (loader-abort "import: not found (no such file, not bundled)")
                  (zeroed Resolved)))))))

(defn l-as-list [(f (ptr Sexp))] (-> (ptr (ArrayList Sexp)))
  (match (load (field f kind))
    (KList [items] items)
    (KInt   [_] (do (loader-abort "expected a list") (box-items (malloc-allocator) (al-new [Sexp] (malloc-allocator)))))
    (KFloat [_] (do (loader-abort "expected a list") (box-items (malloc-allocator) (al-new [Sexp] (malloc-allocator)))))
    (KSym   [_] (do (loader-abort "expected a list") (box-items (malloc-allocator) (al-new [Sexp] (malloc-allocator)))))
    (KKw    [_] (do (loader-abort "expected a list") (box-items (malloc-allocator) (al-new [Sexp] (malloc-allocator)))))
    (KStr   [_] (do (loader-abort "expected a list") (box-items (malloc-allocator) (al-new [Sexp] (malloc-allocator)))))
    (KCStr  [_] (do (loader-abort "expected a list") (box-items (malloc-allocator) (al-new [Sexp] (malloc-allocator)))))
    (KVec   [_] (do (loader-abort "expected a list") (box-items (malloc-allocator) (al-new [Sexp] (malloc-allocator)))))))

(defn l-sym-name [(f (ptr Sexp))] (-> (Option (slice u8)))
  (match (load (field f kind))
    (KSym   [s] (Some s))
    (KInt   [_] (None [(slice u8)]))
    (KFloat [_] (None [(slice u8)]))
    (KKw    [_] (None [(slice u8)]))
    (KStr   [_] (None [(slice u8)]))
    (KCStr  [_] (None [(slice u8)]))
    (KList  [_] (None [(slice u8)]))
    (KVec   [_] (None [(slice u8)]))))

(defn l-list-head [(f (ptr Sexp))] (-> (Option (slice u8)))
  (match (load (field f kind))
    (KList [items]
      (if (icmp-gt (al-len [Sexp] (load items)) 0)
          (let [h (alloc-stack Sexp)] (store! h (al-get [Sexp] (load items) 0)) (l-sym-name h))
          (None [(slice u8)])))
    (KInt   [_] (None [(slice u8)]))
    (KFloat [_] (None [(slice u8)]))
    (KSym   [_] (None [(slice u8)]))
    (KKw    [_] (None [(slice u8)]))
    (KStr   [_] (None [(slice u8)]))
    (KCStr  [_] (None [(slice u8)]))
    (KVec   [_] (None [(slice u8)]))))

(defn l-as-str [(f (ptr Sexp))] (-> (Option (slice u8)))
  (match (load (field f kind))
    (KStr   [s] (Some s))
    (KInt   [_] (None [(slice u8)]))
    (KFloat [_] (None [(slice u8)]))
    (KSym   [_] (None [(slice u8)]))
    (KKw    [_] (None [(slice u8)]))
    (KCStr  [_] (None [(slice u8)]))
    (KList  [_] (None [(slice u8)]))
    (KVec   [_] (None [(slice u8)]))))

(defn module-name [(f (ptr Sexp))] (-> (slice u8))
  (let [items (l-as-list f) n (al-len [Sexp] (load items))]
    (if (icmp-lt n 2)
        (do (loader-abort "module: expected a name") "")
        (let [it (alloc-stack Sexp)] (store! it (al-get [Sexp] (load items) 1))
          (match (l-sym-name it)
            (Some [x] x)
            (None []  (do (loader-abort "module: expected a name") "")))))))

(defn declared-module [(forms (ptr (ArrayList Sexp)))] (-> (Option (slice u8)))
  (let [n (al-len [Sexp] (load forms)) (mut res) (None [(slice u8)]) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [f (alloc-stack Sexp)] (store! f (al-get [Sexp] (load forms) (load i)))
            (match (l-list-head f)
              (Some [h] (if (str-eq h "module") (do (store! res (Some (module-name f))) (break)) 0))
              (None []  0)))
          (store! i (iadd (load i) 1)))))
    (load res)))

(defn collect-syms [(a (ptr Allocator)) (items (ptr (ArrayList Sexp)))] (-> (ptr (ArrayList (slice u8))))
  (let [n (al-len [Sexp] (load items)) (mut out) (al-new [(slice u8)] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [it (alloc-stack Sexp)] (store! it (al-get [Sexp] (load items) (load i)))
            (match (l-sym-name it) (Some [nm] (al-push! (mut out) nm)) (None [] 0)))
          (store! i (iadd (load i) 1)))))
    (let [bp (unwrap-ptr [(ArrayList (slice u8))] (create [(ArrayList (slice u8))] a))]
      (store! bp (load out)) bp)))

(defn imp-elem [(s (mut LS)) (i i64)] (-> (ptr ImpEntry))
  (let [hdr (alloc-stack (ArrayList ImpEntry))]
    (store! hdr (load (field s imports)))
    (index (load (field hdr data)) i)))
(defn exp-elem [(s (mut LS)) (i i64)] (-> (ptr ExpEntry))
  (let [hdr (alloc-stack (ArrayList ExpEntry))]
    (store! hdr (load (field s exports)))
    (index (load (field hdr data)) i)))

(defn imp-entry [(s (mut LS)) (name (slice u8))] (-> (ptr ImpEntry))
  (let [n (al-len [ImpEntry] (load (field s imports))) (mut idx) -1 (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (imp-elem (mut s) (load i)) name)) name)
              (do (store! idx (load i)) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (if (icmp-ge (load idx) 0)
        (imp-elem (mut s) (load idx))
        (let [e (alloc-stack ImpEntry) a (load (field s a))]
          (store! (field e name) name)
          (store! (field (field e imp) aliases)   (al-new [Alias] a))
          (store! (field (field e imp) uses)      (al-new [Use] a))
          (store! (field (field e imp) reexports) (al-new [(slice u8)] a))
          (al-push! (mut (field s imports)) (load e))
          (imp-elem (mut s) n)))))

(defn exp-entry [(s (mut LS)) (name (slice u8))] (-> (ptr ExpEntry))
  (let [n (al-len [ExpEntry] (load (field s exports))) (mut idx) -1 (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (exp-elem (mut s) (load i)) name)) name)
              (do (store! idx (load i)) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (if (icmp-ge (load idx) 0)
        (exp-elem (mut s) (load idx))
        (let [e (alloc-stack ExpEntry) a (load (field s a))]
          (store! (field e name) name)
          (store! (field e names) (al-new [(slice u8)] a))
          (al-push! (mut (field s exports)) (load e))
          (exp-elem (mut s) n)))))

(defn ee-add-name! [(e (ptr ExpEntry)) (name (slice u8))] (-> i64)
  (let [n (al-len [(slice u8)] (load (field e names))) (mut found) false (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (al-get [(slice u8)] (load (field e names)) (load i)) name) (do (store! found true) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (if (load found) 0 (al-push! (mut (field e names)) name))))

(defn mi-add-alias! [(e (ptr ImpEntry)) (alias (slice u8)) (target (slice u8))] (-> i64)
  (let [n (al-len [Alias] (load (field (field e imp) aliases))) (mut idx) -1 (mut i) 0
        v (let [ap (alloc-stack Alias)] (store! (field ap alias) alias) (store! (field ap target) target) (load ap))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (let [ep (alloc-stack Alias)] (store! ep (al-get [Alias] (load (field (field e imp) aliases)) (load i))) (load (field ep alias))) alias)
              (do (store! idx (load i)) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (if (icmp-ge (load idx) 0)
        (al-set! [Alias] (mut (field (field e imp) aliases)) (load idx) v)
        (al-push! (mut (field (field e imp) aliases)) v))))

(defn mi-add-use! [(e (ptr ImpEntry)) (target (slice u8)) (spec UseSpec)] (-> i64)
  (let [u (alloc-stack Use)] (store! (field u target) target) (store! (field u spec) spec)
    (al-push! (mut (field (field e imp) uses)) (load u))))

(defn mi-add-reexport! [(e (ptr ImpEntry)) (target (slice u8))] (-> i64)
  (al-push! (mut (field (field e imp) reexports)) target))

(defn loaded-insert! [(s (mut LS)) (name (slice u8))] (-> bool)
  (let [n (al-len [(slice u8)] (load (field s loaded))) (mut found) false (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (al-get [(slice u8)] (load (field s loaded)) (load i)) name) (do (store! found true) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (if (load found) false (do (al-push! (mut (field s loaded)) name) true))))

(defn handle-export [(s (mut LS)) (f (ptr Sexp)) (cur (Option (slice u8)))] (-> i64)
  (match cur
    (Some [m]
      (let [items (l-as-list f) n (al-len [Sexp] (load items)) ep (exp-entry (mut s) m) (mut i) 1]
        (loop (if (icmp-ge (load i) n) (break)
          (do (let [it (alloc-stack Sexp)] (store! it (al-get [Sexp] (load items) (load i)))
                (match (l-sym-name it)
                  (Some [nm] (ee-add-name! ep nm))
                  (None []   (do (loader-abort "export: names must be symbols") 0))))
              (store! i (iadd (load i) 1)))))
        0))
    (None [] (do (loader-abort "export: only valid inside a (module …)") 0))))

(defn process-import [(s (mut LS)) (form (ptr Sexp)) (base (slice u8)) (cur (Option (slice u8)))] (-> i64)
  (let [a (load (field s a))
        items (l-as-list form) nit (al-len [Sexp] (load items))
        path (if (icmp-lt nit 2)
                 (do (loader-abort "import: expected (import \"path\" [:as alias])") "")
                 (let [it (alloc-stack Sexp)] (store! it (al-get [Sexp] (load items) 1))
                   (match (l-as-str it)
                     (Some [p] p)
                     (None []  (do (loader-abort "import: expected (import \"path\" [:as alias])") "")))))
        (mut alias)    (None [(slice u8)])
        (mut use-spec) (None [UseSpec])
        (mut reexport) false
        (mut i) 2]
    (loop (if (icmp-ge (load i) nit) (break)
      (let [it (alloc-stack Sexp)] (store! it (al-get [Sexp] (load items) (load i)))
        (match (load (field it kind))
          (KKw [k]
            (if (str-eq k "as")
                (let [a2 (alloc-stack Sexp)] (store! a2 (al-get [Sexp] (load items) (iadd (load i) 1)))
                  (match (l-sym-name a2)
                    (Some [al] (do (store! alias (Some al)) (store! i (iadd (load i) 2))))
                    (None []   (do (loader-abort "import: :as expects an alias symbol") (store! i (iadd (load i) 2))))))
              (if (str-eq k "reexport")
                  (do (store! reexport true) (store! i (iadd (load i) 1)))
                (if (str-eq k "use")
                    (let [v2 (alloc-stack Sexp)] (store! v2 (al-get [Sexp] (load items) (iadd (load i) 1)))
                      (match (load (field v2 kind))
                        (KSym [sm] (if (str-eq sm "*")
                                       (do (store! use-spec (Some (UAll))) (store! i (iadd (load i) 2)))
                                       (do (loader-abort "import: :use expects * or [names]") (store! i (iadd (load i) 2)))))
                        (KVec [vit] (do (store! use-spec (Some (UNames (collect-syms a vit)))) (store! i (iadd (load i) 2))))
                        (KInt   [_] (do (loader-abort "import: :use expects * or [names]") (store! i (iadd (load i) 2))))
                        (KFloat [_] (do (loader-abort "import: :use expects * or [names]") (store! i (iadd (load i) 2))))
                        (KKw    [_] (do (loader-abort "import: :use expects * or [names]") (store! i (iadd (load i) 2))))
                        (KStr   [_] (do (loader-abort "import: :use expects * or [names]") (store! i (iadd (load i) 2))))
                        (KCStr  [_] (do (loader-abort "import: :use expects * or [names]") (store! i (iadd (load i) 2))))
                        (KList  [_] (do (loader-abort "import: :use expects * or [names]") (store! i (iadd (load i) 2))))))
                  (do (loader-abort "import: expected :as alias, :use *|[names], or :reexport") (store! i (iadd (load i) 1)))))))
          (KInt   [_] (do (loader-abort "import: expected :as alias, :use *|[names], or :reexport") (store! i (iadd (load i) 1))))
          (KFloat [_] (do (loader-abort "import: expected :as alias, :use *|[names], or :reexport") (store! i (iadd (load i) 1))))
          (KSym   [_] (do (loader-abort "import: expected :as alias, :use *|[names], or :reexport") (store! i (iadd (load i) 1))))
          (KStr   [_] (do (loader-abort "import: expected :as alias, :use *|[names], or :reexport") (store! i (iadd (load i) 1))))
          (KCStr  [_] (do (loader-abort "import: expected :as alias, :use *|[names], or :reexport") (store! i (iadd (load i) 1))))
          (KList  [_] (do (loader-abort "import: expected :as alias, :use *|[names], or :reexport") (store! i (iadd (load i) 1))))
          (KVec   [_] (do (loader-abort "import: expected :as alias, :use *|[names], or :reexport") (store! i (iadd (load i) 1))))))))
    (let [rr (resolve-source a base path)
          rp (alloc-stack Resolved)]
      (store! rp rr)
      (let [text (load (field rp text)) incdir (load (field rp incdir))]
        (match (read-all a text)
          (Err [d] (do (loader-abort "import: read error in imported file") 0))
          (Ok [inc-forms]
            (let [modname (match (declared-module inc-forms)
                            (Some [m] m)
                            (None []  (do (loader-abort "import: file has no (module …) declaration") "")))
                  importer (match cur (Some [m] m) (None [] ""))
                  imp (imp-entry (mut s) importer)
                  alias-name (match (load alias) (Some [al] al) (None [] modname))]
              (mi-add-alias! imp alias-name modname)
              (match (load use-spec)
                (Some [spec] (mi-add-use! imp modname spec))
                (None []     0))
              (if (load reexport) (mi-add-reexport! imp modname) 0)
              (if (loaded-insert! (mut s) modname)
                  (process-forms (mut s) inc-forms incdir (None [(slice u8)]))
                  0)
              0)))))))

(defn process-forms [(s (mut LS)) (forms (ptr (ArrayList Sexp))) (base (slice u8)) (cur0 (Option (slice u8)))] (-> i64)
  (let [n (al-len [Sexp] (load forms)) (mut cur) (None [(slice u8)]) (mut i) 0]
    (store! cur cur0)
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [f (alloc-stack Sexp)] (store! f (al-get [Sexp] (load forms) (load i)))
            (match (l-list-head f)
              (Some [h]
                (if (str-eq h "module")
                    (let [name (module-name f)] (imp-entry (mut s) name) (store! cur (Some name)) 0)
                  (if (str-eq h "export")
                      (handle-export (mut s) f (load cur))
                    (if (str-eq h "import")
                        (match (load cur)
                          (Some [m] (process-import (mut s) f base (load cur)))
                          (None []  (do (loader-abort "import requires a (module …) declaration") 0)))
                      (al-push! (mut (field s out)) (mk-tagged (load f) (load cur)))))))
              (None []
                (al-push! (mut (field s out)) (mk-tagged (load f) (load cur))))))
          (store! i (iadd (load i) 1)))))
    0))

(defn load-program [(s (mut LS)) (forms (ptr (ArrayList Sexp))) (base (slice u8))] (-> i64)
  (let [a (load (field s a))
        prelude-text (read-file a (slice->cstr a "src/prelude.coil"))]
    (match (read-all a prelude-text)
      (Err [d] (do (loader-abort "read error in prelude") 0))
      (Ok [pf]  (process-forms (mut s) pf base (None [(slice u8)]))))
    (process-forms (mut s) forms base (None [(slice u8)]))
    0))

; ============================ resolve representation =======================
; Mirrors src/resolve.rs. `Defs` = a module's definition names split by namespace
; (HashSets become ArrayLists, membership = linear str-eq scan). `DefTable` =
; per-module Defs (ArrayList of DefEntry). `ParsedForm` = one tagged form parsed
; into its own Program, retaining its module identity.
(defstruct Defs
  [(callables (ptr (ArrayList (slice u8))))
   (types     (ptr (ArrayList (slice u8))))
   (traits    (ptr (ArrayList (slice u8))))
   (convs     (ptr (ArrayList (slice u8))))
   (externs   (ptr (ArrayList (slice u8))))])
(defstruct DefEntry [(module (slice u8)) (defs Defs)])
(defstruct ParsedForm [(prog (ptr Program)) (module (Option (slice u8)))])

; The auto-referred core namespace.
(defn core-name [] (-> (slice u8)) "coil.core")

; ---- resolve/qualify logic (ported from src/resolve.rs) -------------------
(defn resolve-program [(a (ptr Allocator)) (s (mut LS))] (-> (Result (ptr Program) Diag))
  (do (unimplemented "resolve/resolve-program") (Err (derr "unimplemented"))))

; ============================ entry ========================================
(defn dump-resolved-program [(a (ptr Allocator)) (src (slice u8)) (cwd (slice u8))] (-> i64)
  (let [w (stdout) s (alloc-stack LS)]
    (store! (field s a) a)
    (store! (field s out)     (al-new [TaggedForm] a))
    (store! (field s loaded)  (al-new [(slice u8)] a))
    (store! (field s imports) (al-new [ImpEntry] a))
    (store! (field s exports) (al-new [ExpEntry] a))
    (match (read-all a src)
      (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
      (Ok [forms]
        (do (load-program (mut s) forms cwd)
            (match (resolve-program a (mut s))
              (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
              (Ok [prog] (d-program w prog a)))))))
  0)

(defn main [(argc i32) (argv (ptr (ptr i8)))] (-> i64)
  (let [a    (malloc-allocator)
        path (load (index argv 2))
        src  (read-file a path)
        cwd  (cwd-slice a)]
    (dump-resolved-program a src cwd))
  0)