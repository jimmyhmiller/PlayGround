                          (store! (field sl present) true) (store! (field sl e) (load (field sp e))) (store! (field sl t) (load (field sp t)))))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [i64 Diag] (load err)) (Ok [i64 Diag] 0))))
(defn ca-final-coerce [(a (ptr Allocator)) (argl (ptr (ArrayList ArgSlot))) (sig (ptr Sig)) (subst (ptr (ArrayList SubstEntry))) (args (ptr (ArrayList Expr))) (func (slice u8)) (fname (slice u8))] (-> (Result (ptr (ArrayList Expr)) Diag))
