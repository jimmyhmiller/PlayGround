                  synb (box-al [Branch] a (al-new [Branch] a)) metav (box-al [(slice u8)] a (al-new [(slice u8)] a))
                  metab (box-al [(ptr (ArrayList (slice u8)))] a (al-new [(ptr (ArrayList (slice u8)))] a))]
              (try! (match-arms-loop a arms variants sumname expected covered checked synb metav metab env cx tps fname))
              (if (not (icmp-eq (al-len [(slice u8)] (load covered)) (al-len [Variant] (load variants))))
                  (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': non-exhaustive match on '" (sconcat a sumname "' (")) (i64->str a (al-len [(slice u8)] (load covered)))) " of ") (i64->str a (al-len [Variant] (load variants)))) " variants)")))) 0)
              (if (expected-some? expected)
                  (ok-ep (mk-expr (EMatch (load se) checked) elo ehi) (load expected))
                (let [outl (box-al [Expr] a (al-new [Expr] a))
                      t (try! (unify-branches a synb outl fname "match arms"))]
                  (ok-ep (mk-expr (EMatch (load se) (build-newarms a metav metab outl)) elo ehi) t))))))))))) 
(defn alloc-stack-store-sumvars [(a (ptr Allocator)) (t (ptr Type)) (cx (ptr Cx))] (-> (ptr SumVars))
  (let [p (unwrap-ptr [SumVars] (create [SumVars] a))] (store! p (sum-variants a t cx)) p))
; ---- loop / break / continue (cx.loops frames) ----
(defn loops-len [(cx (ptr Cx))] (-> i64) (al-len [LoopFrame] (load (field cx loops))))
(defn loop-label-exists [(cx (ptr Cx)) (l (slice u8))] (-> bool)
  (let [n (loops-len cx) (mut i) 0 (mut r) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match-else (load (field (al-elem [LoopFrame] (field cx loops) (load i)) label)) (Some [fl] (if (str-eq fl l) (do (store! r true) (break)) 0)) (_ 0))
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn loops-rpos-label [(cx (ptr Cx)) (l (slice u8))] (-> i64)
  (let [n (loops-len cx) (mut i) (isub n 1) (mut at) -1]
    (loop (if (icmp-lt (load i) 0) (break)
      (do (match-else (load (field (al-elem [LoopFrame] (field cx loops) (load i)) label)) (Some [fl] (if (str-eq fl l) (do (store! at (load i)) (break)) 0)) (_ 0))
          (store! i (isub (load i) 1)))))
    (load at)))

(defn label-some? [(label (Option (slice u8)))] (-> bool) (match-else label (Some [l] true) (_ false)))
(defn label-val [(label (Option (slice u8)))] (-> (slice u8)) (match-else label (Some [l] l) (_ "")))
(defn run-loop-body [(a (ptr Allocator)) (label (Option (slice u8))) (body (ptr (ArrayList Expr))) (expected (ptr Type)) (out (ptr (ArrayList Expr))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result Type Diag))
  (let [fr (alloc-stack LoopFrame)]
    (store! (field fr label) label) (store! (field fr break_ty) (None [Type]))
    (store! (field fr expected) (if (expected-some? expected) (Some (load expected)) (None [Type])))
    (al-push! [LoopFrame] (field cx loops) (load fr)))
  (let [n (al-len [Expr] (load body)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (do-synth a (al-elem [Expr] body (load i)) (null-type) env cx tps fname)
            (Err [d] (do (store! err d) (store! failed true) (break)))
            (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0) (al-push! [Expr] out (load (load (field sp e)))))))
          (store! i (iadd (load i) 1)))))
    (let [popped (al-pop! [LoopFrame] (field cx loops))]
      (if (load failed) (Err [Type Diag] (load err))
        (let [(mut lty) (TNever)]
          (if (expected-some? expected) (store! lty (load expected))
            (match-else popped (Some [pf] (let [pfp (alloc-stack LoopFrame)] (store! pfp pf) (match-else (load (field pfp break_ty)) (Some [bt] (store! lty bt)) (_ (store! lty (TNever)))))) (_ (store! lty (TNever)))))
          (Ok (load lty)))))))

(defn synth-loop [(a (ptr Allocator)) (label (Option (slice u8))) (body (ptr (ArrayList Expr))) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (if (and (label-some? label) (loop-label-exists cx (label-val label)))
      (err-ep (derr (sconcat1 a (sconcat4 a "in '" fname "': loop label ':" (sconcat a (label-val label) "' shadows an enclosing loop with the same label")))))
    (let [outl (box-al [Expr] a (al-new [Expr] a))]
      (match (run-loop-body a label body expected outl env cx tps fname)
        (Err [d] (err-ep d))
        (Ok [lty] (ok-ep (mk-expr (ELoop label outl) elo ehi) lty))))))

(defn synth-break [(a (ptr Allocator)) (label (Option (slice u8))) (value (Option (ptr Expr))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try
   (do
    (if (icmp-eq (loops-len cx) 0) (return-from :try (err-ep (derr (sconcat3 a "in '" fname "': break outside of a loop")))) 0)
    (let [idx (match-else label (Some [l] (loops-rpos-label cx l)) (_ (isub (loops-len cx) 1)))]
      (match-else label (Some [l] (if (icmp-lt idx 0) (return-from :try (err-ep (derr (sconcat a (sconcat4 a "in '" fname "': break to unknown loop label ':" l) "'")))) 0)) (_ 0))
      (let [fr (al-elem [LoopFrame] (field cx loops) idx) texp (field fr expected)]
        (let [valpair (alloc-stack SynPair) (mut have_val) false (mut valexpr) (cast (ptr Expr) 0) (mut vty) (box-type a (TInt 64 true))]
          (match value
            (Some [vp]
              (do (store! have_val true)
                  (match-else (load texp)
                    (Some [exp]
                      (let [ve (try! (check-to a vp (box-type a exp) env cx tps fname "break value"))]
                        (store! valexpr (box-expr a ve)) (store! vty (box-type a exp)) 0))
                    (_ (let [vsp (try! (do-synth a vp (null-type) env cx tps fname))] (store! valpair vsp)
                         (store! valexpr (load (field valpair e))) (store! vty (load (field valpair t))) 0))) 0))
            (None [] 0))
          (if (not (type-is-never (load vty)))
              (match-else (load (field (al-elem [LoopFrame] (field cx loops) idx) break_ty))
                (Some [prev] (if (not (type-eq (box-type a prev) (load vty)))
                                 (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': loop breaks with different value types (" (ty-str a (box-type a prev))) " vs ") (ty-str a (load vty))) ")")))) 0))
                (_ (do (store! (field (al-elem [LoopFrame] (field cx loops) idx) break_ty) (Some (load (load vty)))) 0))) 0)
          (ok-ep (mk-expr (EBreak label (if (load have_val) (Some (load valexpr)) (None [(ptr Expr)]))) elo ehi) (TNever))))))))

(defn synth-continue [(a (ptr Allocator)) (label (Option (slice u8))) (cx (ptr Cx)) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (if (icmp-eq (loops-len cx) 0) (err-ep (derr (sconcat3 a "in '" fname "': continue outside of a loop")))
    (match-else label
      (Some [l] (if (icmp-lt (loops-rpos-label cx l) 0) (err-ep (derr (sconcat a (sconcat4 a "in '" fname "': continue to unknown loop label ':" l) "'"))) (ok-ep (mk-expr (EContinue label) elo ehi) (TNever))))
      (_ (ok-ep (mk-expr (EContinue label) elo ehi) (TNever))))))

; ---- bin/cmp ----
(defn mk-branch [(e (ptr Expr)) (t (ptr Type))] (-> Branch)
  (let [p (alloc-stack Branch)] (store! (field p e) e) (store! (field p t) t) (load p)))
(defn synth-binop [(a (ptr Allocator)) (op i64) (lhs (ptr Expr)) (rhs (ptr Expr)) (iscmp bool) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try
   (do
    (let [lsp (try! (do-synth a lhs (null-type) env cx tps fname)) lp (alloc-stack SynPair)] (store! lp lsp)
      (let [rsp (try! (do-synth a rhs (null-type) env cx tps fname)) rp (alloc-stack SynPair)] (store! rp rsp)
        (let [(mut brs) (al-new [Branch] a) outl (box-al [Expr] a (al-new [Expr] a))]
          (al-push! (mut brs) (mk-branch (load (field lp e)) (load (field lp t))))
          (al-push! (mut brs) (mk-branch (load (field rp e)) (load (field rp t))))
          (let [t (try! (unify-branches a (box-al [Branch] a (load brs)) outl fname (if iscmp "comparison" "arithmetic"))) tp (box-type a t)]
            (if (not (numeric tp tps))
                (return-from :try (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': ") (sconcat a (if iscmp "comparison requires integers, got " "arithmetic requires integers, got ") (ty-str a tp))))))
              (if iscmp
                  (ok-ep (mk-expr (ECmp op (al-elem [Expr] outl 0) (al-elem [Expr] outl 1)) elo ehi) (TBool))
                  (ok-ep (mk-expr (EBin op (al-elem [Expr] outl 0) (al-elem [Expr] outl 1)) elo ehi) t))))))))))

; ---- small arg-loop helpers ----
(defn synth-discard-args [(a (ptr Allocator)) (args (ptr (ArrayList Expr))) (forbidvoid bool) (voidmsg (slice u8)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result (ptr (ArrayList Expr)) Diag))
  (let [n (al-len [Expr] (load args)) (mut out) (al-new [Expr] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (do-synth a (al-elem [Expr] args (load i)) (null-type) env cx tps fname)
            (Err [d] (do (store! err d) (store! failed true) (break)))
            (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
                        (if (and forbidvoid (type-is-void (load (field sp t))))
                            (do (store! err (derr voidmsg)) (store! failed true) (break))
                            (al-push! (mut out) (load (load (field sp e))))))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList Expr)) Diag] (load err)) (Ok (box-al [Expr] a (load out))))))
(defn codeop-rty [(op i64)] (-> Type)
  (if (or (icmp-eq op 3) (or (icmp-eq op 6) (or (icmp-eq op 14) (or (icmp-eq op 16) (or (icmp-eq op 19) (or (icmp-eq op 21) (or (icmp-eq op 22) (icmp-eq op 24)))))))) (TInt 64 true)
  (if (or (icmp-eq op 5) (icmp-eq op 13)) (TSlice (box-type (malloc-allocator) (TInt 8 false)))
  (if (or (icmp-eq op 0) (or (icmp-eq op 1) (or (icmp-eq op 2) (or (icmp-eq op 10) (icmp-eq op 11))))) (TBool)
  (if (icmp-eq op 9) (TNever)
    (TCode))))))

(defn synth-callptr-args [(a (ptr Allocator)) (params (ptr (ArrayList Type))) (args (ptr (ArrayList Expr))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result (ptr (ArrayList Expr)) Diag))
  (let [n (al-len [Expr] (load args)) (mut out) (al-new [Expr] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [wp (al-elem [Type] params (load i)) what (sconcat a "call-ptr argument " (i64->str a (iadd (load i) 1)))]
            (match (do-synth a (al-elem [Expr] args (load i)) wp env cx tps fname)
              (Err [d] (do (store! err d) (store! failed true) (break)))
              (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
                          (match (coerce a (load (load (field sp e))) (load (field sp t)) wp false fname what)
                            (Err [d] (do (store! err d) (store! failed true) (break)))
                            (Ok [ce] (al-push! (mut out) ce)))))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList Expr)) Diag] (load err)) (Ok (box-al [Expr] a (load out))))))
; ---- per-arm helpers for the complex variants ----
(defn synth-do [(a (ptr Allocator)) (body (ptr (ArrayList Expr))) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try (do
    (let [outl (box-al [Expr] a (al-new [Expr] a))
          last (try! (synth-let-body a body expected outl env cx tps fname "do result"))]
      (ok-ep (mk-expr (EDo outl) elo ehi) last)))))

(defn synth-if [(a (ptr Allocator)) (cnd (ptr Expr)) (thn (ptr Expr)) (els (ptr Expr)) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try (do
    (let [csp0 (try! (do-synth a cnd (null-type) env cx tps fname)) csp (alloc-stack SynPair)] (store! csp csp0)
      (if (not (is-cond (load (field csp t))))
          (return-from :try (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': if condition must be a bool or integer, got ") (ty-str a (load (field csp t))))))) 0)
      (if (expected-some? expected)
          (let [te (try! (check-to a thn expected env cx tps fname "if branch"))
                ee (try! (check-to a els expected env cx tps fname "if branch"))]
            (ok-ep (mk-expr (EIf (load (field csp e)) (box-expr a te) (box-expr a ee)) elo ehi) (load expected)))
        (let [tsp0 (try! (do-synth a thn (null-type) env cx tps fname)) tsp (alloc-stack SynPair)] (store! tsp tsp0)
          (let [esp0 (try! (do-synth a els (null-type) env cx tps fname)) esp (alloc-stack SynPair)] (store! esp esp0)
            (let [(mut brs) (al-new [Branch] a) outl (box-al [Expr] a (al-new [Expr] a))]
              (al-push! (mut brs) (mk-branch (load (field tsp e)) (load (field tsp t))))
              (al-push! (mut brs) (mk-branch (load (field esp e)) (load (field esp t))))
              (let [t (try! (unify-branches a (box-al [Branch] a (load brs)) outl fname "if branches"))]
                (ok-ep (mk-expr (EIf (load (field csp e)) (al-elem [Expr] outl 0) (al-elem [Expr] outl 1)) elo ehi) t))))))))))

(defn synth-field [(a (ptr Allocator)) (pp (ptr Expr)) (ffld (slice u8)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try (do
    (let [psp (try! (do-synth a pp (null-type) env cx tps fname)) sp (alloc-stack SynPair)] (store! sp psp)
      (let [pt (load (field sp t)) pointee (place-pointee pt)]
        (if (icmp-eq (cast i64 pointee) 0)
            (return-from :try (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': field access needs a pointer or reference, got ") (ty-str a pt))))) 0)
        (if (not (is-struct-or-app pointee))
            (return-from :try (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': field access needs a pointer to a struct, got (ptr ") (sconcat a (ty-str a pointee) ")"))))) 0)
        (let [sname (struct-name pointee) si (struct-find cx sname)]
          (if (and (icmp-ne (cast i64 si) 0) (load (field si is_bits)))
              (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat a (sconcat5 a "in '" fname "': '" sname "' is a :layout bits struct; use (get p ") ffld) ") / (set! p ") ffld) " v)")))) 0)
          (match (struct-fields a pointee cx)
            (Err [d] (return-from :try (err-ep (prefix-diag a d (sconcat4 a "in '" fname "': " "")))))
            (Ok [fs]
              (let [nf (al-len [Field] (load fs)) (mut i) 0 (mut fty) (cast (ptr Type) 0)]
                (loop (if (icmp-ge (load i) nf) (break)
                  (do (if (str-eq (load (field (al-elem [Field] fs (load i)) name)) ffld) (do (store! fty (field (al-elem [Field] fs (load i)) ty)) (break)) 0)
                      (store! i (iadd (load i) 1)))))
                (if (icmp-eq (cast i64 (load fty)) 0)
                    (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat4 a "in '" fname "': struct '" (sconcat a sname "' has no field '")) ffld) "'")))) 0)
                (ok-ep (mk-expr (EField (load (field sp e)) ffld) elo ehi) (replace-pointee a pt fty)))))))))))

(defn synth-store [(a (ptr Allocator)) (pp (ptr Expr)) (val (ptr Expr)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try (do
    (let [psp (try! (do-synth a pp (null-type) env cx tps fname)) sp (alloc-stack SynPair)] (store! sp psp)
      (let [pt (load (field sp t)) pointee (place-pointee pt)]
        (if (icmp-eq (cast i64 pointee) 0) (return-from :try (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': store! expects a pointer or reference, got ") (ty-str a pt))))) 0)
        (if (not (is-writable pt)) (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat4 a "in '" fname "': cannot store! through immutable reference of type " (ty-str a pt)) " (declare it `(mut …)` to make it writable)") "")))) 0)
        (let [vsp (try! (do-synth a val pointee env cx tps fname)) vp (alloc-stack SynPair)] (store! vp vsp)
          (match (coerce a (load (load (field vp e))) (load (field vp t)) pointee false fname "store! value")
            (Err [d] (return-from :try (err-ep d)))
            (Ok [ve] (ok-ep (mk-expr (EStore (load (field sp e)) (box-expr a ve)) elo ehi) (load pointee))))))))))

(defn synth-index [(a (ptr Allocator)) (pp (ptr Expr)) (idx (ptr Expr)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try (do
    (let [psp (try! (do-synth a pp (null-type) env cx tps fname)) sp (alloc-stack SynPair)] (store! sp psp)
      (let [isp (try! (do-synth a idx (null-type) env cx tps fname)) ip (alloc-stack SynPair)] (store! ip isp)
        (let [ie (match (coerce a (load (load (field ip e))) (load (field ip t)) (box-type a (TInt 64 true)) false fname "index")
                   (Err [_] (return-from :try (err-ep (derr (sconcat3 a "in '" fname "': index must be i64"))))) (Ok [ce] ce))
              pt (load (field sp t)) pointee (place-pointee pt)]
          (if (icmp-eq (cast i64 pointee) 0) (return-from :try (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': index expects a pointer or reference, got ") (ty-str a pt))))) 0)
          (let [elem (if (icmp-eq (type-tag pointee) 7) (t-inner pointee) pointee)]
            (ok-ep (mk-expr (EIndex (load (field sp e)) (box-expr a ie)) elo ehi) (replace-pointee a pt elem)))))))))

(defn synth-cast [(a (ptr Allocator)) (ty Type) (inner (ptr Expr)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (let [tp (box-type a ty)]
    (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': cast target: "))))
      (Ok [_] (match (do-synth a inner (null-type) env cx tps fname) (Err [d] (err-ep d))
        (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
          (let [et (load (field sp t)) tt (type-tag tp) etg (type-tag et)
                ok (or (and (icmp-eq tt 0) (icmp-eq etg 0)) (or (and (icmp-eq tt 4) (icmp-eq etg 4)) (or (and (icmp-eq tt 0) (icmp-eq etg 4)) (or (and (icmp-eq tt 4) (icmp-eq etg 0)) (or (and (icmp-eq tt 1) (icmp-eq etg 1)) (or (and (icmp-eq tt 1) (icmp-eq etg 0)) (or (and (icmp-eq tt 0) (icmp-eq etg 1)) (or (and (icmp-eq tt 10) (icmp-eq etg 10)) (or (and (icmp-eq tt 10) (icmp-eq etg 4)) (and (icmp-eq tt 4) (icmp-eq etg 10)))))))))))]
            (if ok (ok-ep (mk-expr (ECast ty (load (field sp e))) elo ehi) ty)
              (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': cast only converts among int, float, and ptr (got " (ty-str a et)) " to ") (ty-str a tp)) ")")))))))))))) 

(defn synth-offsetof [(a (ptr Allocator)) (ty Type) (ffld (slice u8)) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (let [tp (box-type a ty)]
    (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': offsetof: "))))
      (Ok [_] (match (struct-fields a tp cx) (Err [_] (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': offsetof needs a struct type, got ") (ty-str a tp)))))
        (Ok [fs] (let [nf (al-len [Field] (load fs)) (mut i) 0 (mut found) false]
          (loop (if (icmp-ge (load i) nf) (break) (do (if (str-eq (load (field (al-elem [Field] fs (load i)) name)) ffld) (do (store! found true) (break)) 0) (store! i (iadd (load i) 1)))))
          (if (not (load found)) (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': offsetof: struct '" (struct-name tp)) "' has no field '") ffld) "'")))
            (ok-ep (mk-expr (EOffsetOf ty ffld) elo ehi) (TInt 64 true))))))))))

(defn synth-fnptr [(a (ptr Allocator)) (name (slice u8)) (cx (ptr Cx)) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (let [sig (sig-find cx name)]
    (if (icmp-eq (cast i64 sig) 0) (err-ep (derr (sconcat a (sconcat4 a "in '" fname "': fnptr-of unknown function '" name) "'")))
      (if (icmp-gt (al-len [(slice u8)] (load (field sig type_params))) 0) (err-ep (derr (sconcat a (sconcat4 a "in '" fname "': cannot take a function pointer to generic function '" name) "'")))
        (if (not (load (field sig fnptr_ok))) (err-ep (derr (sconcat a (sconcat4 a "in '" fname "': cannot take a function pointer to '" name) "' (shim-convention functions are not supported yet)")))
          (ok-ep (mk-expr (EFnPtrOf name) elo ehi) (TFn (load (field sig cc)) (load (field sig params)) (box-type a (load (field sig ret))))))))))

(defn synth-callptr [(a (ptr Allocator)) (fp (ptr Expr)) (args (ptr (ArrayList Expr))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try (do
    (let [fsp (try! (do-synth a fp (null-type) env cx tps fname)) sp (alloc-stack SynPair)] (store! sp fsp)
      (let [ft (load (field sp t))]
        (if (not (icmp-eq (type-tag ft) 10)) (return-from :try (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': call-ptr expects a function pointer, got ") (ty-str a ft))))) 0)
        (let [params (t-fn-params ft) ret (t-fn-ret ft)]
          (if (not (icmp-eq (al-len [Type] (load params)) (al-len [Expr] (load args))))
              (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': function pointer expects " (i64->str a (al-len [Type] (load params)))) " args, got ") (i64->str a (al-len [Expr] (load args)))) "")))) 0)
          (let [na (try! (synth-callptr-args a params args env cx tps fname))]
            (ok-ep (mk-expr (ECallPtr (load (field sp e)) na) elo ehi) (load ret)))))))))

; ============================ synth_inner (src/check.rs:836) =================
(defn synth-inner [(a (ptr Allocator)) (e (ptr Expr)) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result EvalPair Diag))
  (let [elo (load (field e lo)) ehi (load (field e hi))]
    (match (load (field e kind))
      (EInt   [v] (ok-ep (mk-expr (EInt v) elo ehi) (TInt 64 true)))
      (EFloat [bits] (ok-ep (mk-expr (EFloat bits) elo ehi) (TFloat 64)))
      (EBool  [b] (ok-ep (mk-expr (EBool b) elo ehi) (TBool)))
      (EStr   [s] (ok-ep (mk-expr (EStr s) elo ehi) (TSlice (box-type a (TInt 8 false)))))
      (ECStr  [s] (ok-ep (mk-expr (ECStr s) elo ehi) (TPtr (box-type a (TInt 8 true)))))
      (EZeroed [ty]
        (let [tp (box-type a ty)] (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': zeroed: ")))) (Ok [_] (ok-ep (mk-expr (EZeroed ty) elo ehi) ty)))))
      (EBorrow [mutable place]
        (match (do-synth a place (null-type) env cx tps fname) (Err [d] (err-ep d))
          (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
            (let [pt (load (field sp t)) pointee (place-pointee pt)]
              (if (icmp-eq (cast i64 pointee) 0) (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': cannot borrow a non-place of type ") (ty-str a pt))))
                (if (and mutable (not (is-writable pt))) (err-ep (derr (sconcat a (sconcat a (sconcat4 a "in '" fname "': cannot take a mutable borrow of immutable '" (ty-str a pt)) "'") "")))
                  (ok-ep (load (load (field sp e))) (TRef mutable (box-type a (load pointee)))))))))))
      (EVar [name]
        (let [te (env-get env name)]
          (if (icmp-ne (cast i64 te) 0) (ok-ep (mk-expr (EVar name) elo ehi) (load te))
            (let [ce (const-find cx name)]
              (if (icmp-ne (cast i64 ce) 0)
                  (if (set-contains (field cx static_consts) name)
                      (ok-ep (mk-expr (EStaticRef name) elo ehi) (TRef false (box-type a (load (field ce ty)))))
                    (if (is-literal-value (field ce value))
                        (ok-ep (mk-expr (load (field (field ce value) kind)) elo ehi) (load (field ce ty)))
                      (ok-ep (mk-expr (EComptime (box-expr a (load (field ce value)))) elo ehi) (load (field ce ty)))))
                (err-ep (derr (sconcat a (sconcat4 a "in '" fname "': unbound variable '" name) "'"))))))))
      (ELlvmIr [result args body]
        (let [rp (box-type a result)] (match (validate-type rp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': llvm-ir result type: "))))
          (Ok [_] (match (synth-discard-args a args true (sconcat3 a "in '" fname "': llvm-ir operand uses a void value (a (-> void) call yields nothing)") env cx tps fname)
                    (Err [d] (err-ep d)) (Ok [eargs] (ok-ep (mk-expr (ELlvmIr result eargs body) elo ehi) result)))))))
      (ETraitCall [trait_name method self_tp args]
        (err-ep (derr (sconcat a (sconcat4 a "in '" fname "': internal: unresolved trait call '" method) "' in input"))))
      (EComptime [inner]
        (match (do-synth a inner expected env cx tps fname) (Err [d] (err-ep d)) (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0) (ok-ep (mk-expr (EComptime (load (field sp e))) elo ehi) (load (load (field sp t))))))))
      (EStaticRef [name]
        (err-ep (derr (sconcat a (sconcat4 a "in '" fname "': internal: unexpected static-ref '" name) "' in input"))))
      (ETypeQuery [q ty]
        (let [tp (box-type a ty)] (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': type reflection: ")))) (Ok [_] (ok-ep (mk-expr (ETypeQuery q ty) elo ehi) (if (icmp-le q 1) (TInt 64 true) (TBool)))))))
      (EFieldMeta [meta ty idx]
        (let [tp (box-type a ty)] (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': field reflection: "))))
          (Ok [_] (match (do-synth a idx (box-type a (TInt 64 true)) env cx tps fname) (Err [d] (err-ep d))
            (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
              (if (not (type-is-int (load (field sp t)))) (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': field index must be an integer, got ") (ty-str a (load (field sp t))))))
                (ok-ep (mk-expr (EFieldMeta meta ty (load (field sp e))) elo ehi) (if (icmp-eq meta 1) (TInt 64 true) (TSlice (box-type a (TInt 8 false)))))))))))))
      (EQuote [form] (ok-ep (mk-expr (EQuote form) elo ehi) (TCode)))
      (EQuasi [q]
        (let [qp (alloc-stack Quasi)] (store! qp q) (match (check-quasi a qp env cx tps fname) (Err [d] (err-ep d)) (Ok [nq] (ok-ep (mk-expr (EQuasi nq) elo ehi) (TCode))))))
      (ECodeOp [op args]
        (match (synth-discard-args a args false "" env cx tps fname) (Err [d] (err-ep d)) (Ok [na] (ok-ep (mk-expr (ECodeOp op na) elo ehi) (codeop-rty op)))))
      (EFieldIndex [ty name]
        (let [tp (box-type a ty)] (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': field-index: "))))
          (Ok [_] (match (do-synth a name (null-type) env cx tps fname) (Err [d] (err-ep d))
            (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
              (if (not (icmp-eq (type-tag (load (field sp t))) 8)) (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': field-index name must be a string, got ") (ty-str a (load (field sp t))))))
                (ok-ep (mk-expr (EFieldIndex ty (load (field sp e))) elo ehi) (TInt 64 true))))))))))
      (EBin [op lhs rhs] (synth-binop a op lhs rhs false env cx tps fname elo ehi))
      (ENot [inner]
        (match (do-synth a inner (null-type) env cx tps fname) (Err [d] (err-ep d)) (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
          (if (not (numeric (load (field sp t)) tps)) (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': inot requires an integer, got ") (ty-str a (load (field sp t))))))
            (ok-ep (mk-expr (ENot (load (field sp e))) elo ehi) (load (load (field sp t)))))))))
      (ECmp [op lhs rhs] (synth-binop a op lhs rhs true env cx tps fname elo ehi))
      (ELoop [label body] (synth-loop a label body expected env cx tps fname elo ehi))
      (EBreak [label value] (synth-break a label value env cx tps fname elo ehi))
      (EContinue [label] (synth-continue a label cx fname elo ehi))
      (EIf [cnd thn els] (synth-if a cnd thn els expected env cx tps fname elo ehi))
      (EDo [body] (synth-do a body expected env cx tps fname elo ehi))
      (ELet [binds body] (synth-let a binds body expected env cx tps fname elo ehi))
      (ECall [func type_args args] (synth-call a func type_args args expected env cx tps fname elo ehi))
      (EAlloc [storage ty]
        (let [tp (box-type a ty)] (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': alloc: ")))) (Ok [_] (ok-ep (mk-expr (EAlloc storage ty) elo ehi) (TPtr (box-type a ty)))))))
      (EField [pp ffld] (synth-field a pp ffld env cx tps fname elo ehi))
      (ELoad [inner]
        (match (do-synth a inner (null-type) env cx tps fname) (Err [d] (err-ep d)) (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
          (let [pp (place-pointee (load (field sp t)))]
            (if (icmp-ne (cast i64 pp) 0) (ok-ep (mk-expr (ELoad (load (field sp e))) elo ehi) (load pp))
              (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': load expects a pointer or reference, got ") (ty-str a (load (field sp t)))))))))))) 
      (EStore [pp val] (synth-store a pp val env cx tps fname elo ehi))
      (EIndex [pp idx] (synth-index a pp idx env cx tps fname elo ehi))
      (ECast [ty inner] (synth-cast a ty inner env cx tps fname elo ehi))
      (ESizeOf [ty]
        (let [tp (box-type a ty)] (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': sizeof: ")))) (Ok [_] (ok-ep (mk-expr (ESizeOf ty) elo ehi) (TInt 64 true))))))
      (EAlignOf [ty]
        (let [tp (box-type a ty)] (match (validate-type tp cx tps) (Err [d] (err-ep (prefix-diag a d (sconcat3 a "in '" fname "': alignof: ")))) (Ok [_] (ok-ep (mk-expr (EAlignOf ty) elo ehi) (TInt 64 true))))))
      (EOffsetOf [ty ffld] (synth-offsetof a ty ffld cx tps fname elo ehi))
      (EBitGet [pp bfld]
        (match (bit-field-type a pp bfld env cx tps fname) (Err [d] (err-ep d)) (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0) (ok-ep (mk-expr (EBitGet (load (field sp e)) bfld) elo ehi) (load (load (field sp t))))))))
      (EBitSet [pp bfld val]
        (match (bit-field-type a pp bfld env cx tps fname) (Err [d] (err-ep d)) (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
          (let [fty (load (field sp t))]
            (match (do-synth a val fty env cx tps fname) (Err [d] (err-ep d)) (Ok [vsp0] (let [vsp (alloc-stack SynPair)] (store! vsp vsp0)
              (match (coerce a (load (load (field vsp e))) (load (field vsp t)) fty false fname (sconcat a (sconcat3 a "set! into bitfield '" bfld "'") "")) (Err [d] (err-ep d))
                (Ok [ve] (ok-ep (mk-expr (EBitSet (load (field sp e)) bfld (box-expr a ve)) elo ehi) (load fty)))))))))))) 
      (EFree [inner]
        (match (do-synth a inner (null-type) env cx tps fname) (Err [d] (err-ep d)) (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
          (if (type-is-ptr (load (field sp t))) (ok-ep (mk-expr (EFree (load (field sp e))) elo ehi) (TInt 64 true))
            (err-ep (derr (sconcat a (sconcat3 a "in '" fname "': free expects a pointer, got ") (ty-str a (load (field sp t)))))))))))
      (EErase [trait_name inner]
        (match (do-synth a inner (null-type) env cx tps fname) (Err [d] (err-ep d)) (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
          (match (build-make-dyn a cx trait_name (load (field sp e)) (load (field sp t)) elo ehi fname) (Err [d] (err-ep d))
            (Ok [mp0] (let [mp (alloc-stack SynPair)] (store! mp mp0) (ok-ep (load (load (field mp e))) (load (load (field mp t)))))))))))
      (EMatch [scrut arms] (synth-match a scrut arms expected env cx tps fname elo ehi))
      (EFnPtrOf [name] (synth-fnptr a name cx fname elo ehi))
      (ECallPtr [fp args] (synth-callptr a fp args env cx tps fname elo ehi))
      (EConstruct [sum variant args]
        (match (synth-construct a variant (box-items-type a) args (null-type) env cx tps fname elo ehi) (Err [d] (err-ep d))
          (Ok [rv] (let [r (alloc-stack EvalPair)] (store! r rv) (ok-ep (load (field r e)) (TStruct sum))))))
      (EMakeDyn [dyn_struct vtable_struct methods inner] (ok-ep (load e) (TStruct dyn_struct)))
      (EDynDispatch [ds vt mi cc params ret recv args] (ok-ep (load e) ret))
      (ESpillRef [inner] (err-ep (derr (sconcat3 a "in '" fname "': internal: SpillRef in input")))))))

; synth (src/check.rs:800) — span-fill + auto dyn-coercion wrapper.
(defn synth [(a (ptr Allocator)) (e (ptr Expr)) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result EvalPair Diag))
  (let [dynt (if (expected-some? expected) (is-dyn-target expected cx) false)]
    (match (synth-inner a e expected env cx tps fname)
      (Err [d] (err-ep (dwspan d (load (field e lo)) (load (field e hi)))))
      (Ok [rv]
        (if (not dynt) (Ok [EvalPair Diag] rv)
          (let [r (alloc-stack EvalPair)] (store! r rv)
            (match (maybe-coerce-dyn a cx (box-expr a (load (field r e))) (box-type a (load (field r t))) expected (load (field e lo)) (load (field e hi)) fname)
              (Err [d] (err-ep d))
              (Ok [mp0] (let [mp (alloc-stack SynPair)] (store! mp mp0) (ok-ep (load (load (field mp e))) (load (load (field mp t))))))))))) ))



; ============================ check.rs: finish (Phase 3) =====================
; Static-assert conditions are synth'd + is-cond-checked. The comptime fold
; (comptime::fold_program), aggregate-const statics, (meta …) elaboration, and
; export-c symbol resolution are a separate unported subsystem: finish passes
; funcs through unchanged (a no-op fold for comptime-free programs — any program
; that actually USES comptime will then mismatch the reference and fail the gate,
; never silently pass), and hard-errors on (meta …)/(export-c …) which the dump
; would otherwise misrepresent. Aggregate-const statics do not affect the dump
; (the dumper hardcodes an empty (statics) section), so static_consts are ignored.
(defn finish-asserts [(a (ptr Allocator)) (cx (ptr Cx)) (prog (ptr Program))] (-> (Result (ptr (ArrayList StaticAssert)) Diag))
  (let [as (load (field prog asserts)) n (al-len [StaticAssert] (load as)) (mut out) (al-new [StaticAssert] a)
        (mut i) 0 (mut err) (zeroed Diag) (mut failed) false
        empty-tps (box-al [(slice u8)] a (al-new [(slice u8)] a))]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [ap (al-elem [StaticAssert] as (load i)) env (env-new a)]
            (match (do-synth a (field ap cnd) (null-type) env cx empty-tps "static-assert")
              (Err [d] (do (store! err d) (store! failed true) (break)))
              (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
                          (if (not (is-cond (load (field sp t))))
                              (do (store! err (derr (sconcat a "static-assert: condition must be a bool or integer, got " (ty-str a (load (field sp t)))))) (store! failed true) (break))
                            (let [na (alloc-stack StaticAssert)] (store! (field na cnd) (load (load (field sp e)))) (store! (field na msg) (load (field ap msg))) (al-push! (mut out) (load na)) 0))))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList StaticAssert)) Diag] (load err)) (Ok (box-al [StaticAssert] a (load out))))))

(defn finish [(a (ptr Allocator)) (cx (ptr Cx)) (prog (ptr Program)) (funcs (ptr (ArrayList Func)))] (-> (Result (ptr Program) Diag))
  (match (finish-asserts a cx prog)
    (Err [d] (Err [(ptr Program) Diag] d))
    (Ok [asserts]
      (if (icmp-gt (al-len [Expr] (load (field prog metas))) 0)
          (do (unimplemented "check/finish: (meta …) staged macros not ported") (Err [(ptr Program) Diag] (derr "")))
        (if (icmp-gt (al-len [ExportC] (load (field prog exports))) 0)
            (do (unimplemented "check/finish: (export-c …) symbol resolution not ported") (Err [(ptr Program) Diag] (derr "")))
          (let [out (unwrap-ptr [Program] (create [Program] a))]
            (store! (field out conventions) (load (field prog conventions)))
            (store! (field out structs) (load (field prog structs)))
            (store! (field out sums) (load (field prog sums)))
            (store! (field out externs) (load (field prog externs)))
            (store! (field out funcs) funcs)
            (store! (field out asserts) asserts)
            (store! (field out consts) (load (field prog consts)))
            (store! (field out traits) (load (field prog traits)))
            (store! (field out impls) (load (field prog impls)))
            (store! (field out metas) (load (field prog metas)))
            (store! (field out exports) (load (field prog exports)))
            (Ok out)))))))

; ============================ the check pass (src/check.rs) ===================
; check-program mirrors src/check.rs::check_with: setup (Phase 1, fail-fast) ->
; check_func over every function (Phase 2; FIRST error wins, matching the oracle's
; dump_error of diagnostics[0]) -> finish (Phase 3). Returns the typed/elaborated/
; LOWERED Program, or Err(diag) dumped canonically.
(defn check-all-funcs [(a (ptr Allocator)) (cx (ptr Cx)) (allf (ptr (ArrayList Func)))] (-> (Result (ptr (ArrayList Func)) Diag))
  (let [n (al-len [Func] (load allf)) (mut out) (al-new [Func] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (check-func a cx (al-elem [Func] allf (load i)))
            (Err [d] (do (store! err d) (store! failed true) (break)))
            (Ok [f] (al-push! (mut out) f)))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err (load err)) (Ok (box-al [Func] a (load out))))))
(defn check-program [(a (ptr Allocator)) (p (ptr Program)) (s (mut LS))] (-> (Result (ptr Program) Diag))
  (let [impb (unwrap-ptr [(ArrayList ImpEntry)] (create [(ArrayList ImpEntry)] a))
        expb (unwrap-ptr [(ArrayList ExpEntry)] (create [(ArrayList ExpEntry)] a))
        cx (unwrap-ptr [Cx] (create [Cx] a))]
    (store! impb (load (field s imports)))
    (store! expb (load (field s exports)))
    (match (setup a cx p impb expb)
      (Err [d] (Err [(ptr Program) Diag] d))
      (Ok [allf]
        (match (check-all-funcs a cx allf)
          (Err [d] (Err [(ptr Program) Diag] d))
          (Ok [funcs] (finish a cx p funcs)))))))

; ============================ the mono pass (src/mono.rs) =====================
; A PURE specializer: the checker already wrote explicit type-args on every
; generic call/construction, so mono instantiates each generic func/struct/sum
; per concrete type-arg set, rewrites calls to the specialized (mangled) names,
; and drops the generic templates. Output is a Program with no remaining
; generics. Faithful port of src/mono.rs; mono's String errors become spanless
; Diags (derr, lo=hi=-1) so they dump as (error@D:D "...") matching the reference.

; A type-parameter substitution (param-name -> concrete Type), parallel lists.
(defstruct Subst [(names (ptr (ArrayList (slice u8)))) (types (ptr (ArrayList Type)))])
; A pending instantiation request (template name + concrete type-args).
(defstruct PendInst [(name (slice u8)) (args (ptr (ArrayList Type)))])
; The monomorphizer state (mirrors src/mono.rs::Mono). gfuncs/gstructs/gsums are
; the FILTERED generic templates; the rest are growable output/work lists.
(defstruct MonoCtx
  [(a (ptr Allocator))
   (gfuncs (ptr (ArrayList Func)))
   (gstructs (ptr (ArrayList StructDef)))
   (gsums (ptr (ArrayList SumDef)))
   (vsum-names (ArrayList (slice u8)))
   (vsum-sums  (ArrayList (slice u8)))
   (out-structs (ArrayList StructDef))
   (out-sums    (ArrayList SumDef))
   (out-funcs   (ArrayList Func))
   (pending-structs (ArrayList PendInst))
   (pending-sums    (ArrayList PendInst))
   (pending-funcs   (ArrayList PendInst))
   (queued-structs (ArrayList (slice u8)))
   (queued-sums    (ArrayList (slice u8)))
   (queued-funcs   (ArrayList (slice u8)))])

; ---- small constructors -----------------------------------------------------
(defn mk-field [(name (slice u8)) (ty Type)] (-> Field)
  (let [p (alloc-stack Field)] (store! (field p name) name) (store! (field p ty) ty) (load p)))
(defn mk-param [(name (slice u8)) (ty Type)] (-> Param)
  (let [p (alloc-stack Param)] (store! (field p name) name) (store! (field p ty) ty) (load p)))
(defn mk-variant [(name (slice u8)) (fields (ptr (ArrayList Field)))] (-> Variant)
  (let [p (alloc-stack Variant)] (store! (field p name) name) (store! (field p fields) fields) (load p)))
(defn mk-arm [(variant (slice u8)) (binds (ptr (ArrayList (slice u8)))) (body Expr)] (-> Arm)
  (let [p (alloc-stack Arm)] (store! (field p variant) variant) (store! (field p binds) binds) (store! (field p body) body) (load p)))
(defn mk-pend [(a (ptr Allocator)) (name (slice u8)) (args (ptr (ArrayList Type)))] (-> PendInst)
  (let [p (alloc-stack PendInst)] (store! (field p name) name) (store! (field p args) args) (load p)))
(defn t-app-args [(t (ptr Type))] (-> (ptr (ArrayList Type))) (t-fn-params t))

; ---- Subst (src/mono.rs Subst = HashMap<String,Type>) -----------------------
(defn mk-subst [(a (ptr Allocator)) (names (ptr (ArrayList (slice u8)))) (types (ptr (ArrayList Type)))] (-> (ptr Subst))
  (let [s (unwrap-ptr [Subst] (create [Subst] a))]
    (store! (field s names) names) (store! (field s types) types) s))
(defn subst-empty [(a (ptr Allocator))] (-> (ptr Subst))
  (mk-subst a (box-al [(slice u8)] a (al-new [(slice u8)] a)) (box-items-type a)))
; src/mono.rs::subst_map — zip params with args (parallel-list HashMap).
(defn subst-map [(a (ptr Allocator)) (params (ptr (ArrayList (slice u8)))) (args (ptr (ArrayList Type)))] (-> (ptr Subst))
  (mk-subst a params args))
(defn subst-lookup [(s (ptr Subst)) (name (slice u8))] (-> (Option Type))
  (let [ns (load (field s names)) ts (load (field s types)) n (al-len [(slice u8)] (load ns)) (mut i) 0 (mut r) (None [Type])]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (al-get [(slice u8)] (load ns) (load i)) name)
              (do (store! r (Some (al-get [Type] (load ts) (load i)))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))

; ---- type_key / mangle (src/mono.rs) — mutually recursive -------------------
(defn type-key [(a (ptr Allocator)) (t (ptr Type))] (-> (slice u8))
  (let [tg (type-tag t)]
    (if (icmp-eq tg 12) "never"
    (if (icmp-eq tg 13) "code"
    (if (icmp-eq tg 3) "void"
    (if (icmp-eq tg 0) (sconcat a (if (t-int-signed t) "i" "u") (i64->str a (t-int-bits t)))
    (if (icmp-eq tg 1) (sconcat a "f" (i64->str a (t-int-bits t)))
    (if (icmp-eq tg 2) "bool"
    (if (icmp-eq tg 4) (sconcat a "ptr_" (type-key a (t-inner t)))
    (if (icmp-eq tg 5) (sconcat a "ref_" (type-key a (t-inner t)))
    (if (icmp-eq tg 6) (type-struct-name t)
    (if (icmp-eq tg 7) (sconcat a (sconcat a "arr" (i64->str a (t-arrn t))) (sconcat a "_" (type-key a (t-inner t))))
    (if (icmp-eq tg 8) (sconcat a "slice_" (type-key a (t-inner t)))
    (if (icmp-eq tg 9) (sconcat a (sconcat a "vec" (i64->str a (t-arrn t))) (sconcat a "_" (type-key a (t-inner t))))
    (if (icmp-eq tg 10) "fn"
      (mangle a (t-app-name t) (t-app-args t)))))))))))))))))
(defn mangle [(a (ptr Allocator)) (name (slice u8)) (args (ptr (ArrayList Type)))] (-> (slice u8))
  (let [(mut s) name n (al-len [Type] (load args)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (store! s (sconcat a (load s) (sconcat a "__" (type-key a (al-elem [Type] args (load i))))))
          (store! i (iadd (load i) 1)))))
    (load s)))

; ---- trait_method_fn / type_impl_name (src/ast.rs) --------------------------
(defn trait-method-fn [(a (ptr Allocator)) (trait (slice u8)) (type-name (slice u8)) (method (slice u8))] (-> (slice u8))
  (sconcat a trait (sconcat a "$" (sconcat a type-name (sconcat a "$" method)))))
(defn mono-impl-name [(a (ptr Allocator)) (t (ptr Type))] (-> (Option (slice u8)))
  (let [tg (type-tag t)]
    (if (icmp-eq tg 6) (Some (type-struct-name t))
    (if (icmp-eq tg 11) (Some (t-app-name t))
    (if (icmp-eq tg 0) (Some (sconcat a (if (t-int-signed t) "i" "u") (i64->str a (t-int-bits t))))
    (if (icmp-eq tg 2) (Some "bool")
    (if (icmp-eq tg 1) (Some (sconcat a "f" (i64->str a (t-int-bits t))))
      (None [(slice u8)]))))))))

; ---- generic-template lookups (the gfuncs/gstructs/gsums HashMaps) -----------
(defn find-struct-named [(lst (ptr (ArrayList StructDef))) (nm (slice u8))] (-> i64)
  (let [n (al-len [StructDef] (load lst)) (mut i) 0 (mut r) -1]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [StructDef] lst (load i)) name)) nm) (do (store! r (load i)) 0) 0)
          (store! i (iadd (load i) 1))))) (load r)))
(defn find-sum-named [(lst (ptr (ArrayList SumDef))) (nm (slice u8))] (-> i64)
  (let [n (al-len [SumDef] (load lst)) (mut i) 0 (mut r) -1]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [SumDef] lst (load i)) name)) nm) (do (store! r (load i)) 0) 0)
          (store! i (iadd (load i) 1))))) (load r)))
(defn find-func-named [(lst (ptr (ArrayList Func))) (nm (slice u8))] (-> i64)
  (let [n (al-len [Func] (load lst)) (mut i) 0 (mut r) -1]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [Func] lst (load i)) name)) nm) (do (store! r (load i)) 0) 0)
          (store! i (iadd (load i) 1))))) (load r)))
(defn gstruct-has [(m (ptr MonoCtx)) (nm (slice u8))] (-> bool) (icmp-ge (find-struct-named (load (field m gstructs)) nm) 0))
(defn gsum-has    [(m (ptr MonoCtx)) (nm (slice u8))] (-> bool) (icmp-ge (find-sum-named (load (field m gsums)) nm) 0))
(defn gfunc-has   [(m (ptr MonoCtx)) (nm (slice u8))] (-> bool) (icmp-ge (find-func-named (load (field m gfuncs)) nm) 0))
(defn gstruct-arity [(m (ptr MonoCtx)) (nm (slice u8))] (-> i64)
  (al-len [(slice u8)] (load (field (al-elem [StructDef] (load (field m gstructs)) (find-struct-named (load (field m gstructs)) nm)) type_params))))
(defn gsum-arity [(m (ptr MonoCtx)) (nm (slice u8))] (-> i64)
  (al-len [(slice u8)] (load (field (al-elem [SumDef] (load (field m gsums)) (find-sum-named (load (field m gsums)) nm)) type_params))))
(defn gfunc-arity [(m (ptr MonoCtx)) (nm (slice u8))] (-> i64)
  (al-len [(slice u8)] (load (field (al-elem [Func] (load (field m gfuncs)) (find-func-named (load (field m gfuncs)) nm)) type_params))))
; variant_to_sum lookup.
(defn variant-sum [(m (ptr MonoCtx)) (func (slice u8))] (-> (Option (slice u8)))
  (let [ns (load (field m vsum-names)) ss (load (field m vsum-sums)) n (al-len [(slice u8)] ns) (mut i) 0 (mut r) (None [(slice u8)])]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (al-get [(slice u8)] ns (load i)) func) (do (store! r (Some (al-get [(slice u8)] ss (load i)))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))

; ---- queues (src/mono.rs::queue_*) — dedup via the queued set ----------------
(defn queue-struct [(m (ptr MonoCtx)) (nm (slice u8)) (args (ptr (ArrayList Type)))] (-> i64)
  (let [a (load (field m a)) mng (mangle a nm args)]
    (if (set-contains (field m queued-structs) mng) 0
        (do (al-push! (mut (field m queued-structs)) mng) (al-push! (mut (field m pending-structs)) (mk-pend a nm args)) 0))))
(defn queue-sum [(m (ptr MonoCtx)) (nm (slice u8)) (args (ptr (ArrayList Type)))] (-> i64)
  (let [a (load (field m a)) mng (mangle a nm args)]
    (if (set-contains (field m queued-sums) mng) 0
        (do (al-push! (mut (field m queued-sums)) mng) (al-push! (mut (field m pending-sums)) (mk-pend a nm args)) 0))))
(defn queue-func [(m (ptr MonoCtx)) (nm (slice u8)) (args (ptr (ArrayList Type)))] (-> i64)
  (let [a (load (field m a)) mng (mangle a nm args)]
    (if (set-contains (field m queued-funcs) mng) 0
        (do (al-push! (mut (field m queued-funcs)) mng) (al-push! (mut (field m pending-funcs)) (mk-pend a nm args)) 0))))

; "<prefix> expects N type arguments, got M" — the shared arity-error shape.
(defn arity-err [(a (ptr Allocator)) (prefix (slice u8)) (n i64) (m i64)] (-> (slice u8))
  (sconcat a prefix (sconcat a " expects " (sconcat a (i64->str a n) (sconcat a " type arguments, got " (i64->str a m))))))

; ---- resolve_ty (src/mono.rs) — substitute params, mangle generic apps ------
(defn resolve-ty-list [(m (ptr MonoCtx)) (lst (ptr (ArrayList Type))) (map (ptr Subst))] (-> (Result (ptr (ArrayList Type)) Diag))
  (let [a (load (field m a)) n (al-len [Type] (load lst)) (mut out) (al-new [Type] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (resolve-ty m (al-elem [Type] lst (load i)) map)
            (Err [d] (do (store! err d) (store! failed true) (break)))
            (Ok [t] (al-push! (mut out) t)))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList Type)) Diag] (load err)) (Ok (box-al [Type] a (load out))))))
(defn resolve-ty-app [(m (ptr MonoCtx)) (t (ptr Type)) (map (ptr Subst))] (-> (Result Type Diag))
  (let [a (load (field m a)) nm (t-app-name t)]
    (match (resolve-ty-list m (t-app-args t) map)
      (Err [d] (Err [Type Diag] d))
      (Ok [rargs]
        (let [mng (mangle a nm rargs) rlen (al-len [Type] (load rargs))]
          (if (gstruct-has m nm)
              (let [ar (gstruct-arity m nm)]
                (if (not (icmp-eq ar rlen))
                    (Err [Type Diag] (derr (arity-err a (sconcat3 a "generic type '" nm "'") ar rlen)))
                    (do (queue-struct m nm rargs) (Ok (TStruct mng)))))
            (if (gsum-has m nm)
                (let [ar (gsum-arity m nm)]
                  (if (not (icmp-eq ar rlen))
                      (Err [Type Diag] (derr (arity-err a (sconcat3 a "generic type '" nm "'") ar rlen)))
                      (do (queue-sum m nm rargs) (Ok (TStruct mng)))))
              (Err [Type Diag] (derr (sconcat3 a "unknown generic type '" nm "'"))))))))))
(defn resolve-ty [(m (ptr MonoCtx)) (t (ptr Type)) (map (ptr Subst))] (-> (Result Type Diag))
  (let [a (load (field m a)) tg (type-tag t)]
    (if (icmp-eq tg 12) (Ok (TNever))
    (if (icmp-eq tg 13) (Ok (TCode))
    (if (icmp-eq tg 3) (Ok (TVoid))
    (if (icmp-eq tg 0) (Ok (TInt (t-int-bits t) (t-int-signed t)))
    (if (icmp-eq tg 1) (Ok (TFloat (t-int-bits t)))
    (if (icmp-eq tg 2) (Ok (TBool))
    (if (icmp-eq tg 4) (match (resolve-ty m (t-inner t) map) (Err [d] (Err [Type Diag] d)) (Ok [it] (Ok (TPtr (box-type a it)))))
    (if (icmp-eq tg 5) (match (resolve-ty m (t-inner t) map) (Err [d] (Err [Type Diag] d)) (Ok [it] (Ok (TRef (t-ref-mut t) (box-type a it)))))
    (if (icmp-eq tg 7) (match (resolve-ty m (t-inner t) map) (Err [d] (Err [Type Diag] d)) (Ok [it] (Ok (TArray (box-type a it) (t-arrn t)))))
    (if (icmp-eq tg 8) (match (resolve-ty m (t-inner t) map) (Err [d] (Err [Type Diag] d)) (Ok [it] (Ok (TSlice (box-type a it)))))
    (if (icmp-eq tg 9) (match (resolve-ty m (t-inner t) map) (Err [d] (Err [Type Diag] d)) (Ok [it] (Ok (TVec (box-type a it) (t-arrn t)))))
    (if (icmp-eq tg 10)
        (match (resolve-ty-list m (t-fn-params t) map) (Err [d] (Err [Type Diag] d))
          (Ok [ps] (match (resolve-ty m (t-fn-ret t) map) (Err [d] (Err [Type Diag] d))
                     (Ok [r] (Ok (TFn (t-fn-cc t) ps (box-type a r)))))))
    (if (icmp-eq tg 6)
        (match (subst-lookup map (type-struct-name t)) (Some [ct] (Ok ct)) (None [] (Ok (TStruct (type-struct-name t)))))
      (resolve-ty-app m t map))))))))))))))))

; ---- resolve a sum / its variants (src/mono.rs::resolve_sum) -----------------
(defn resolve-fields [(m (ptr MonoCtx)) (fs (ptr (ArrayList Field))) (map (ptr Subst))] (-> (Result (ptr (ArrayList Field)) Diag))
  (let [a (load (field m a)) n (al-len [Field] (load fs)) (mut out) (al-new [Field] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [fp (al-elem [Field] fs (load i))]
            (match (resolve-ty m (field fp ty) map)
              (Err [d] (do (store! err d) (store! failed true) (break)))
              (Ok [t] (al-push! (mut out) (mk-field (load (field fp name)) t)))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList Field)) Diag] (load err)) (Ok (box-al [Field] a (load out))))))
(defn resolve-params [(m (ptr MonoCtx)) (ps (ptr (ArrayList Param))) (map (ptr Subst))] (-> (Result (ptr (ArrayList Param)) Diag))
  (let [a (load (field m a)) n (al-len [Param] (load ps)) (mut out) (al-new [Param] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [pp (al-elem [Param] ps (load i))]
            (match (resolve-ty m (field pp ty) map)
              (Err [d] (do (store! err d) (store! failed true) (break)))
              (Ok [t] (al-push! (mut out) (mk-param (load (field pp name)) t)))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList Param)) Diag] (load err)) (Ok (box-al [Param] a (load out))))))
(defn resolve-sum [(m (ptr MonoCtx)) (s (ptr SumDef)) (map (ptr Subst)) (name (slice u8))] (-> (Result SumDef Diag))
  (let [a (load (field m a)) vs (load (field s variants)) n (al-len [Variant] vs) (mut out) (al-new [Variant] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [vp (al-elem [Variant] vs (load i))]
            (match (resolve-fields m (load (field vp fields)) map)
              (Err [d] (do (store! err d) (store! failed true) (break)))
              (Ok [nfs] (al-push! (mut out) (mk-variant (load (field vp name)) nfs)))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [SumDef Diag] (load err))
        (let [ns (alloc-stack SumDef)]
          (store! (field ns name) name)
          (store! (field ns type_params) (box-al [(slice u8)] a (al-new [(slice u8)] a)))
          (store! (field ns variants) (box-al [Variant] a (load out)))
          (Ok (load ns))))))

; ---- resolve a function (src/mono.rs::resolve_func) --------------------------
(defn resolve-func [(m (ptr MonoCtx)) (f (ptr Func)) (map (ptr Subst)) (name (slice u8))] (-> (Result Func Diag))
  (let [a (load (field m a))]
    (match (resolve-params m (load (field f params)) map)
      (Err [d] (Err [Func Diag] d))
      (Ok [params]
        (match (resolve-ty m (field f ret) map)
          (Err [d] (Err [Func Diag] d))
          (Ok [ret]
            (match (resolve-expr-list m (load (field f body)) map)
              (Err [d] (Err [Func Diag] d))
              (Ok [body]
                (let [nf (alloc-stack Func)]
                  (store! (field nf name) name)
                  (store! (field nf type_params) (box-al [(slice u8)] a (al-new [(slice u8)] a)))
                  (store! (field nf bounds) (box-al [Bound] a (al-new [Bound] a)))
                  (store! (field nf cc) (load (field f cc)))
                  (store! (field nf params) params)
                  (store! (field nf ret) ret)
                  (store! (field nf body) body)
                  (store! (field nf macro_variadic) false)
                  (store! (field nf lo) (load (field f lo)))
                  (store! (field nf hi) (load (field f hi)))
                  (Ok (load nf)))))))))))

; ---- resolve expressions (src/mono.rs::resolve_expr) -------------------------
(defn resolve-expr-list [(m (ptr MonoCtx)) (lst (ptr (ArrayList Expr))) (map (ptr Subst))] (-> (Result (ptr (ArrayList Expr)) Diag))
  (let [a (load (field m a)) n (al-len [Expr] (load lst)) (mut out) (al-new [Expr] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (match (resolve-expr m (al-elem [Expr] lst (load i)) map)
            (Err [d] (do (store! err d) (store! failed true) (break)))
            (Ok [e] (al-push! (mut out) e)))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList Expr)) Diag] (load err)) (Ok (box-al [Expr] a (load out))))))
(defn resolve-bind-list [(m (ptr MonoCtx)) (binds (ptr (ArrayList Bind))) (map (ptr Subst))] (-> (Result (ptr (ArrayList Bind)) Diag))
  (let [a (load (field m a)) n (al-len [Bind] (load binds)) (mut out) (al-new [Bind] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [bp (al-elem [Bind] binds (load i))]
            (match (resolve-expr m (field bp value) map)
              (Err [d] (do (store! err d) (store! failed true) (break)))
              (Ok [ne] (al-push! (mut out) (mk-bind (load (field bp name)) (load (field bp mutable)) ne)))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList Bind)) Diag] (load err)) (Ok (box-al [Bind] a (load out))))))
(defn resolve-arm-list [(m (ptr MonoCtx)) (arms (ptr (ArrayList Arm))) (map (ptr Subst))] (-> (Result (ptr (ArrayList Arm)) Diag))
  (let [a (load (field m a)) n (al-len [Arm] (load arms)) (mut out) (al-new [Arm] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [ap (al-elem [Arm] arms (load i))]
            (match (resolve-expr m (field ap body) map)
              (Err [d] (do (store! err d) (store! failed true) (break)))
              (Ok [nb] (al-push! (mut out) (mk-arm (load (field ap variant)) (load (field ap binds)) nb)))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList Arm)) Diag] (load err)) (Ok (box-al [Arm] a (load out))))))
; The ECall arm: variant construction / generic-fn call / plain call.
(defn resolve-call-kind [(m (ptr MonoCtx)) (func (slice u8)) (type_args (ptr (ArrayList Type))) (args (ptr (ArrayList Expr))) (map (ptr Subst))] (-> (Result ExprKind Diag))
  (let [a (load (field m a))]
    (try
      (let [nargs (try! (resolve-expr-list m args map))]
        (match (variant-sum m func)
          (Some [sum-name]
            (if (gsum-has m sum-name)
                (do
                  (if (icmp-eq (al-len [Type] (load type_args)) 0)
                      (return-from :try (Err [ExprKind Diag] (derr (sconcat a (sconcat a (sconcat3 a "variant '" func "' of generic sum '") (sconcat3 a sum-name "' needs type arguments: (" func)) " [<types>] ...)"))))
                      0)
                  (let [rtargs (try! (resolve-ty-list m type_args map))]
                    (if (not (icmp-eq (al-len [Type] (load rtargs)) (gsum-arity m sum-name)))
                        (return-from :try (Err [ExprKind Diag] (derr (arity-err a (sconcat3 a "sum '" sum-name "'") (gsum-arity m sum-name) (al-len [Type] (load rtargs))))))
                        0)
                    (let [mng (mangle a sum-name rtargs)]
                      (queue-sum m sum-name rtargs)
                      (Ok (EConstruct mng func nargs)))))
                (Ok (EConstruct sum-name func nargs))))
          (None []
            (if (gfunc-has m func)
                (do
                  (if (icmp-eq (al-len [Type] (load type_args)) 0)
                      (return-from :try (Err [ExprKind Diag] (derr (sconcat a (sconcat3 a "generic function '" func "' needs explicit type arguments: (") (sconcat a func " [<types>] ...)")))))
                      0)
                  (let [rtargs (try! (resolve-ty-list m type_args map))]
                    (if (not (icmp-eq (al-len [Type] (load rtargs)) (gfunc-arity m func)))
                        (return-from :try (Err [ExprKind Diag] (derr (arity-err a (sconcat3 a "generic function '" func "'") (gfunc-arity m func) (al-len [Type] (load rtargs))))))
                        0)
                    (let [mng (mangle a func rtargs)]
                      (queue-func m func rtargs)
                      (Ok (ECall mng (box-items-type a) nargs)))))
              (Ok (ECall func (box-items-type a) nargs)))))))))
(defn resolve-expr-kind [(m (ptr MonoCtx)) (e (ptr Expr)) (map (ptr Subst))] (-> (Result ExprKind Diag))
  (let [a (load (field m a))]
    (try
      (match (load (field e kind))
        (EInt   [v] (Ok (EInt v)))
        (EStr   [s] (Ok (EStr s)))
        (ECStr  [s] (Ok (ECStr s)))
        (EVar   [nm] (Ok (EVar nm)))
        (EFloat [b] (Ok (EFloat b)))
        (EBool  [b] (Ok (EBool b)))
        (EZeroed [t] (let [tp (alloc-stack Type)] (store! tp t) (Ok (EZeroed (try! (resolve-ty m tp map))))))
        (EBorrow [mu place] (Ok (EBorrow mu (box-expr a (try! (resolve-expr m place map))))))
        (ESpillRef [inner] (Ok (ESpillRef (box-expr a (try! (resolve-expr m inner map))))))
        (ELet [binds body] (Ok (ELet (try! (resolve-bind-list m binds map)) (try! (resolve-expr-list m body map)))))
        (EBin [op lhs rhs] (Ok (EBin op (box-expr a (try! (resolve-expr m lhs map))) (box-expr a (try! (resolve-expr m rhs map))))))
        (ENot [inner] (Ok (ENot (box-expr a (try! (resolve-expr m inner map))))))
        (ECmp [op lhs rhs] (Ok (ECmp op (box-expr a (try! (resolve-expr m lhs map))) (box-expr a (try! (resolve-expr m rhs map))))))
        (EIf [cnd thn els] (Ok (EIf (box-expr a (try! (resolve-expr m cnd map))) (box-expr a (try! (resolve-expr m thn map))) (box-expr a (try! (resolve-expr m els map))))))
        (EDo [body] (Ok (EDo (try! (resolve-expr-list m body map)))))
        (ECall [func type_args args] (resolve-call-kind m func type_args args map))
        (EAlloc [storage t] (let [tp (alloc-stack Type)] (store! tp t) (Ok (EAlloc storage (try! (resolve-ty m tp map))))))
        (EField [p fname] (Ok (EField (box-expr a (try! (resolve-expr m p map))) fname)))
        (ELoad [inner] (Ok (ELoad (box-expr a (try! (resolve-expr m inner map))))))
        (EStore [p val] (Ok (EStore (box-expr a (try! (resolve-expr m p map))) (box-expr a (try! (resolve-expr m val map))))))
        (EIndex [p idx] (Ok (EIndex (box-expr a (try! (resolve-expr m p map))) (box-expr a (try! (resolve-expr m idx map))))))
        (ECast [t inner] (let [tp (alloc-stack Type)] (store! tp t) (Ok (ECast (try! (resolve-ty m tp map)) (box-expr a (try! (resolve-expr m inner map)))))))
        (ESizeOf [t] (let [tp (alloc-stack Type)] (store! tp t) (Ok (ESizeOf (try! (resolve-ty m tp map))))))
        (EAlignOf [t] (let [tp (alloc-stack Type)] (store! tp t) (Ok (EAlignOf (try! (resolve-ty m tp map))))))
        (EOffsetOf [t fname] (let [tp (alloc-stack Type)] (store! tp t) (Ok (EOffsetOf (try! (resolve-ty m tp map)) fname))))
        (EBitGet [p fname] (Ok (EBitGet (box-expr a (try! (resolve-expr m p map))) fname)))
        (EBitSet [p fname val] (Ok (EBitSet (box-expr a (try! (resolve-expr m p map))) fname (box-expr a (try! (resolve-expr m val map))))))
        (EFree [inner] (Ok (EFree (box-expr a (try! (resolve-expr m inner map))))))
        (EErase [trait_name inner] (Ok (EErase trait_name (box-expr a (try! (resolve-expr m inner map))))))
        (EMatch [scrut arms] (Ok (EMatch (box-expr a (try! (resolve-expr m scrut map))) (try! (resolve-arm-list m arms map)))))
        (EFnPtrOf [nm] (if (gfunc-has m nm) (Err [ExprKind Diag] (derr (sconcat3 a "fnptr-of '" nm "': cannot take a function pointer to a generic function"))) (Ok (EFnPtrOf nm))))
        (ECallPtr [fp args] (Ok (ECallPtr (box-expr a (try! (resolve-expr m fp map))) (try! (resolve-expr-list m args map)))))
        (ELoop [label body] (Ok (ELoop label (try! (resolve-expr-list m body map)))))
        (EBreak [label value] (Ok (EBreak label (match value (Some [vp] (Some (box-expr a (try! (resolve-expr m vp map))))) (None [] (None [(ptr Expr)]))))))
        (EContinue [label] (Ok (EContinue label)))
        (ELlvmIr [result args body] (let [tp (alloc-stack Type)] (store! tp result) (Ok (ELlvmIr (try! (resolve-ty m tp map)) (try! (resolve-expr-list m args map)) body))))
        (EConstruct [sum variant args] (Ok (EConstruct sum variant (try! (resolve-expr-list m args map)))))
        (EMakeDyn [dyn_struct vtable_struct methods inner] (Ok (EMakeDyn dyn_struct vtable_struct methods (box-expr a (try! (resolve-expr m inner map))))))
        (EDynDispatch [dyn_struct vtable_struct method_index cc params ret recv args]
          (let [rp (alloc-stack Type)] (store! rp ret)
            (Ok (EDynDispatch dyn_struct vtable_struct method_index cc (try! (resolve-ty-list m params map)) (try! (resolve-ty m rp map)) (box-expr a (try! (resolve-expr m recv map))) (try! (resolve-expr-list m args map))))))
        (EStaticRef [nm] (Ok (EStaticRef nm)))
        ; trait call: substitute Self -> concrete, call the implementing fn directly.
        (ETraitCall [trait_name method self_tp args]
          (let [tp (alloc-stack Type)] (store! tp (TStruct self_tp))
            (let [styp (alloc-stack Type)] (store! styp (try! (resolve-ty m tp map)))
              (match (mono-impl-name a styp)
                (None [] (do (unimplemented "mono/trait-call: Self resolved to a type with no impl name") (Err [ExprKind Diag] (derr ""))))
                (Some [tn] (Ok (ECall (trait-method-fn a trait_name tn method) (box-items-type a) (try! (resolve-expr-list m args map)))))))))
        ; comptime-only / unresolved nodes: a compiler bug if they reach mono.
        (EComptime  [inner] (Err [ExprKind Diag] (derr "mono: unresolved comptime node (compiler bug)")))
        (ETypeQuery [q t] (Err [ExprKind Diag] (derr "mono: unresolved type-query (compiler bug)")))
        (EFieldMeta [meta t idx] (Err [ExprKind Diag] (derr "mono: unresolved field-reflection (compiler bug)")))
        (EFieldIndex [t nm] (Err [ExprKind Diag] (derr "mono: unresolved field-reflection (compiler bug)")))
        (EQuote  [form] (Err [ExprKind Diag] (derr "mono: comptime-only code value reached mono (compiler bug)")))
        (ECodeOp [op args] (Err [ExprKind Diag] (derr "mono: comptime-only code value reached mono (compiler bug)")))
        (EQuasi  [q] (Err [ExprKind Diag] (derr "mono: comptime-only code value reached mono (compiler bug)")))))))
(defn resolve-expr [(m (ptr MonoCtx)) (e (ptr Expr)) (map (ptr Subst))] (-> (Result Expr Diag))
  (match (resolve-expr-kind m e map)
    (Err [d] (Err [Expr Diag] d))
    (Ok [k] (Ok (mk-expr k (load (field e lo)) (load (field e hi)))))))

; ---- drain the worklist (src/mono.rs::drain) --------------------------------
; LIFO in Rust; an append-only cursor sweep here (same fixpoint, output order is
; unobserved by the oracle — every corpus file errors during seeding).
(defn drain [(m (ptr MonoCtx))] (-> (Result i64 Diag))
  (let [a (load (field m a)) (mut sc) 0 (mut uc) 0 (mut fc) 0 (mut err) (zeroed Diag) (mut failed) false (mut done) false]
    (loop (if (load done) (break)
      (do
        (if (icmp-lt (load sc) (al-len [PendInst] (load (field m pending-structs))))
            (do (let [pi (al-elem [PendInst] (field m pending-structs) (load sc))
                      nm (load (field pi name)) args (load (field pi args))
                      gs (al-elem [StructDef] (load (field m gstructs)) (find-struct-named (load (field m gstructs)) nm))
                      smap (subst-map a (load (field gs type_params)) args) mng (mangle a nm args)]
                  (match (resolve-fields m (load (field gs fields)) smap)
                    (Err [d] (do (store! err d) (store! failed true) (store! done true) 0))
                    (Ok [nfs]
                      (let [nd (alloc-stack StructDef)]
                        (store! (field nd name) mng)
                        (store! (field nd type_params) (box-al [(slice u8)] a (al-new [(slice u8)] a)))
                        (store! (field nd layout) (load (field gs layout)))
                        (store! (field nd fields) nfs)
                        (upsert-struct m (load nd))))))
                (store! sc (iadd (load sc) 1)))
          (if (icmp-lt (load uc) (al-len [PendInst] (load (field m pending-sums))))
              (do (let [pi (al-elem [PendInst] (field m pending-sums) (load uc))
                        nm (load (field pi name)) args (load (field pi args))
                        gs (al-elem [SumDef] (load (field m gsums)) (find-sum-named (load (field m gsums)) nm))
                        smap (subst-map a (load (field gs type_params)) args) mng (mangle a nm args)]
                    (match (resolve-sum m gs smap mng)
                      (Err [d] (do (store! err d) (store! failed true) (store! done true) 0))
                      (Ok [ns] (upsert-sum m ns))))
                  (store! uc (iadd (load uc) 1)))
            (if (icmp-lt (load fc) (al-len [PendInst] (load (field m pending-funcs))))
                (do (let [pi (al-elem [PendInst] (field m pending-funcs) (load fc))
                          nm (load (field pi name)) args (load (field pi args))
                          gf (al-elem [Func] (load (field m gfuncs)) (find-func-named (load (field m gfuncs)) nm))
                          smap (subst-map a (load (field gf type_params)) args) mng (mangle a nm args)]
                      (match (resolve-func m gf smap mng)
                        (Err [d] (do (store! err d) (store! failed true) (store! done true) 0))
                        (Ok [nf] (upsert-func m nf))))
                    (store! fc (iadd (load fc) 1)))
              (do (store! done true) 0)))))))
    (if (load failed) (Err [i64 Diag] (load err)) (Ok [i64 Diag] 0))))

; ---- orchestration (src/mono.rs::monomorphize) ------------------------------
(defn collect-generic-structs [(a (ptr Allocator)) (p (ptr Program))] (-> (ptr (ArrayList StructDef)))
  (let [fs (load (field p structs)) n (al-len [StructDef] (load fs)) (mut out) (al-new [StructDef] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [sp (al-elem [StructDef] fs (load i))]
            (if (icmp-gt (al-len [(slice u8)] (load (field sp type_params))) 0) (al-push! (mut out) (load sp)) 0))
          (store! i (iadd (load i) 1)))))
    (box-al [StructDef] a (load out))))
(defn collect-generic-sums [(a (ptr Allocator)) (p (ptr Program))] (-> (ptr (ArrayList SumDef)))
  (let [ss (load (field p sums)) n (al-len [SumDef] (load ss)) (mut out) (al-new [SumDef] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [sp (al-elem [SumDef] ss (load i))]
            (if (icmp-gt (al-len [(slice u8)] (load (field sp type_params))) 0) (al-push! (mut out) (load sp)) 0))
          (store! i (iadd (load i) 1)))))
    (box-al [SumDef] a (load out))))
(defn collect-generic-funcs [(a (ptr Allocator)) (p (ptr Program))] (-> (ptr (ArrayList Func)))
  (let [fs (load (field p funcs)) n (al-len [Func] (load fs)) (mut out) (al-new [Func] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [fp (al-elem [Func] fs (load i))]
            (if (icmp-gt (al-len [(slice u8)] (load (field fp type_params))) 0) (al-push! (mut out) (load fp)) 0))
          (store! i (iadd (load i) 1)))))
    (box-al [Func] a (load out))))
; src/mono.rs: build variant_to_sum (error if a variant name is in two sums).
(defn build-vsum [(m (ptr MonoCtx)) (p (ptr Program))] (-> (Result i64 Diag))
  (let [a (load (field m a)) ss (load (field p sums)) n (al-len [SumDef] (load ss)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (or (load failed) (icmp-ge (load i) n)) (break)
      (do (let [sp (al-elem [SumDef] ss (load i)) vs (load (field sp variants)) nv (al-len [Variant] vs) (mut j) 0]
            (loop (if (or (load failed) (icmp-ge (load j) nv)) (break)
              (do (let [vp (al-elem [Variant] vs (load j)) vn (load (field vp name))]
                    (if (set-contains (field m vsum-names) vn)
                        (do (store! err (derr (sconcat3 a "variant '" vn "' is declared in two sum types"))) (store! failed true) 0)
                        (do (al-push! (mut (field m vsum-names)) vn) (al-push! (mut (field m vsum-sums)) (load (field sp name))))))
                  (store! j (iadd (load j) 1))))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [i64 Diag] (load err)) (Ok [i64 Diag] 0))))
(defn seed-concrete-structs [(m (ptr MonoCtx)) (p (ptr Program)) (map (ptr Subst))] (-> (Result i64 Diag))
  (let [a (load (field m a)) ss (load (field p structs)) n (al-len [StructDef] (load ss)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [sp (al-elem [StructDef] ss (load i))]
            (if (icmp-eq (al-len [(slice u8)] (load (field sp type_params))) 0)
                (match (resolve-fields m (load (field sp fields)) map)
                  (Err [d] (do (store! err d) (store! failed true) (break)))
                  (Ok [nfs]
                    (let [nd (alloc-stack StructDef)]
                      (store! (field nd name) (load (field sp name)))
                      (store! (field nd type_params) (box-al [(slice u8)] a (al-new [(slice u8)] a)))
                      (store! (field nd layout) (load (field sp layout)))
                      (store! (field nd fields) nfs)
                      (upsert-struct m (load nd)) 0)))
                0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [i64 Diag] (load err)) (Ok [i64 Diag] 0))))
(defn seed-concrete-sums [(m (ptr MonoCtx)) (p (ptr Program)) (map (ptr Subst))] (-> (Result i64 Diag))
  (let [a (load (field m a)) ss (load (field p sums)) n (al-len [SumDef] (load ss)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [sp (al-elem [SumDef] ss (load i))]
            (if (icmp-eq (al-len [(slice u8)] (load (field sp type_params))) 0)
                (match (resolve-sum m sp map (load (field sp name)))
                  (Err [d] (do (store! err d) (store! failed true) (break)))
                  (Ok [ns] (upsert-sum m ns)))
                0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [i64 Diag] (load err)) (Ok [i64 Diag] 0))))
(defn seed-concrete-funcs [(m (ptr MonoCtx)) (p (ptr Program)) (map (ptr Subst))] (-> (Result i64 Diag))
  (let [a (load (field m a)) fs (load (field p funcs)) n (al-len [Func] (load fs)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [fp (al-elem [Func] fs (load i))]
            (if (icmp-eq (al-len [(slice u8)] (load (field fp type_params))) 0)
                (match (resolve-func m fp map (load (field fp name)))
                  (Err [d] (do (store! err d) (store! failed true) (break)))
                  (Ok [nf] (upsert-func m nf)))
                0))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [i64 Diag] (load err)) (Ok [i64 Diag] 0))))
(defn mono-asserts [(m (ptr MonoCtx)) (p (ptr Program)) (map (ptr Subst))] (-> (Result (ptr (ArrayList StaticAssert)) Diag))
  (let [a (load (field m a)) as (load (field p asserts)) n (al-len [StaticAssert] (load as)) (mut out) (al-new [StaticAssert] a) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [ap (al-elem [StaticAssert] as (load i))]
            (match (resolve-expr m (field ap cnd) map)
              (Err [d] (do (store! err d) (store! failed true) (break)))
              (Ok [ce] (let [na (alloc-stack StaticAssert)] (store! (field na cnd) ce) (store! (field na msg) (load (field ap msg))) (al-push! (mut out) (load na)) 0))))
          (store! i (iadd (load i) 1)))))
    (if (load failed) (Err [(ptr (ArrayList StaticAssert)) Diag] (load err)) (Ok (box-al [StaticAssert] a (load out))))))
(defn build-mono-program [(a (ptr Allocator)) (m (ptr MonoCtx)) (p (ptr Program)) (asserts (ptr (ArrayList StaticAssert)))] (-> (Result (ptr Program) Diag))
  (let [out (unwrap-ptr [Program] (create [Program] a))]
    (store! (field out conventions) (load (field p conventions)))
    (store! (field out structs) (box-al [StructDef] a (load (field m out-structs))))
    (store! (field out sums) (box-al [SumDef] a (load (field m out-sums))))
    (store! (field out externs) (load (field p externs)))
    (store! (field out funcs) (box-al [Func] a (load (field m out-funcs))))
    (store! (field out asserts) asserts)
    (store! (field out consts) (load (field p consts)))
    (store! (field out traits) (box-al [TraitDef] a (al-new [TraitDef] a)))
    (store! (field out impls) (box-al [ImplDef] a (al-new [ImplDef] a)))
    (store! (field out metas) (box-al [Expr] a (al-new [Expr] a)))
    (store! (field out exports) (load (field p exports)))
    (Ok out)))
; src/mono.rs keeps out_structs/out_sums/out_funcs in HashMaps keyed by name, so a
; second insert with the same name OVERWRITES (last-writer-wins) — duplicate-named
; concrete definitions (e.g. a fn re-seen via two import paths) collapse to one.
; Our out lists are ArrayLists, so mirror that with insert-or-replace by name.
(defn upsert-struct [(m (ptr MonoCtx)) (s StructDef)] (-> i64)
  (let [n (al-len [StructDef] (load (field m out-structs))) (mut i) 0 (mut done) false]
    (loop (if (or (load done) (icmp-ge (load i) n)) (break)
      (do (if (str-eq (sdef-name (al-get [StructDef] (load (field m out-structs)) (load i))) (sdef-name s))
              (do (al-set! [StructDef] (mut (field m out-structs)) (load i) s) (store! done true) 0) 0)
          (store! i (iadd (load i) 1)))))
    (if (load done) 0 (al-push! (mut (field m out-structs)) s))
    0))
(defn upsert-sum [(m (ptr MonoCtx)) (s SumDef)] (-> i64)
  (let [n (al-len [SumDef] (load (field m out-sums))) (mut i) 0 (mut done) false]
    (loop (if (or (load done) (icmp-ge (load i) n)) (break)
      (do (if (str-eq (sumdef-name (al-get [SumDef] (load (field m out-sums)) (load i))) (sumdef-name s))
              (do (al-set! [SumDef] (mut (field m out-sums)) (load i) s) (store! done true) 0) 0)
          (store! i (iadd (load i) 1)))))
    (if (load done) 0 (al-push! (mut (field m out-sums)) s))
    0))
(defn upsert-func [(m (ptr MonoCtx)) (f Func)] (-> i64)
  (let [n (al-len [Func] (load (field m out-funcs))) (mut i) 0 (mut done) false]
    (loop (if (or (load done) (icmp-ge (load i) n)) (break)
      (do (if (str-eq (func-name (al-get [Func] (load (field m out-funcs)) (load i))) (func-name f))
              (do (al-set! [Func] (mut (field m out-funcs)) (load i) f) (store! done true) 0) 0)
          (store! i (iadd (load i) 1)))))
    (if (load done) 0 (al-push! (mut (field m out-funcs)) f))
    0))

(defn monomorphize [(a (ptr Allocator)) (p (ptr Program))] (-> (Result (ptr Program) Diag))
  (let [m (unwrap-ptr [MonoCtx] (create [MonoCtx] a))]
    (store! (field m a) a)
    (store! (field m gfuncs) (collect-generic-funcs a p))
    (store! (field m gstructs) (collect-generic-structs a p))
    (store! (field m gsums) (collect-generic-sums a p))
    (store! (field m vsum-names) (al-new [(slice u8)] a))
    (store! (field m vsum-sums) (al-new [(slice u8)] a))
    (store! (field m out-structs) (al-new [StructDef] a))
    (store! (field m out-sums) (al-new [SumDef] a))
    (store! (field m out-funcs) (al-new [Func] a))
    (store! (field m pending-structs) (al-new [PendInst] a))
    (store! (field m pending-sums) (al-new [PendInst] a))
    (store! (field m pending-funcs) (al-new [PendInst] a))
    (store! (field m queued-structs) (al-new [(slice u8)] a))
    (store! (field m queued-sums) (al-new [(slice u8)] a))
    (store! (field m queued-funcs) (al-new [(slice u8)] a))
    (let [empty (subst-empty a)]
      (match (build-vsum m p)
        (Err [d] (Err [(ptr Program) Diag] d))
        (Ok [_]
          (match (seed-concrete-structs m p empty)
            (Err [d] (Err [(ptr Program) Diag] d))
            (Ok [_]
              (match (seed-concrete-sums m p empty)
                (Err [d] (Err [(ptr Program) Diag] d))
                (Ok [_]
                  (match (seed-concrete-funcs m p empty)
                    (Err [d] (Err [(ptr Program) Diag] d))
                    (Ok [_]
                      (match (mono-asserts m p empty)
                        (Err [d] (Err [(ptr Program) Diag] d))
                        (Ok [asserts]
                          (match (drain m)
                            (Err [d] (Err [(ptr Program) Diag] d))
                            (Ok [_] (build-mono-program a m p asserts))))))))))))))))

; ---- post-check Code-func drop (mirror lib.rs::elaborate_on_stack's retain) --
; Comptime-only functions (a `Code` parameter or return — macros, generators,
; code helpers) have no runtime representation and are dropped after check,
; before mono. Without this the auto-loaded prelude's Code-returning macros reach
; mono and abort it. type-tag 13 == TCode.
(defn func-has-code [(fp (ptr Func))] (-> bool)
  (let [rt (alloc-stack Type)]
    (store! rt (load (field fp ret)))
    (if (icmp-eq (type-tag rt) 13)
        true
        (let [ps (load (field fp params)) n (al-len [Param] ps) (mut i) 0 (mut found) false]
          (loop (if (or (load found) (icmp-ge (load i) n)) (break)
            (do (let [pp (al-elem [Param] ps (load i)) pt (alloc-stack Type)]
                  (store! pt (load (field pp ty)))
                  (if (icmp-eq (type-tag pt) 13) (do (store! found true) 0) 0))
                (store! i (iadd (load i) 1)))))
          (load found)))))
(defn drop-code-funcs [(a (ptr Allocator)) (p (ptr Program))] (-> i64)
  (let [fs (load (field p funcs)) n (al-len [Func] (load fs)) (mut out) (al-new [Func] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [fp (al-elem [Func] fs (load i))]
            (if (func-has-code fp) 0 (al-push! (mut out) (load fp))))
          (store! i (iadd (load i) 1)))))
    (store! (field p funcs) (box-al [Func] a (load out)))
    0))

; ---- canonicalize mono output order (mirror dump_mono.rs's name sorts) -------
; `mono::monomorphize` builds funcs/structs/sums from `HashMap::into_values()`
; (nondeterministic), so the raw dump is not a stable oracle. Sort these three
; sections by name (mangled names are unique → total order) before dumping. This
; sort lives ONLY in the mono dump path; the shared dumper is untouched.
(defn func-name [(f Func)] (-> (slice u8)) (let [p (alloc-stack Func)] (store! p f) (load (field p name))))
(defn sdef-name [(s StructDef)] (-> (slice u8)) (let [p (alloc-stack StructDef)] (store! p s) (load (field p name))))
(defn sumdef-name [(s SumDef)] (-> (slice u8)) (let [p (alloc-stack SumDef)] (store! p s) (load (field p name))))
(defn sort-funcs [(a (ptr Allocator)) (src (ptr (ArrayList Func)))] (-> (ptr (ArrayList Func)))
  (let [n (al-len [Func] (load src)) (mut used) (al-new [bool] a) (mut out) (al-new [Func] a) (mut k) 0]
    (loop (if (icmp-ge (load k) n) (break) (do (al-push! (mut used) false) (store! k (iadd (load k) 1)))))
    (let [(mut c) 0]
      (loop (if (icmp-ge (load c) n) (break)
        (do (let [(mut best) -1 (mut bi) 0]
              (loop (if (icmp-ge (load bi) n) (break)
                (do (if (not (al-get [bool] (load used) (load bi)))
                        (if (or (icmp-lt (load best) 0)
                                (str-lt (func-name (al-get [Func] (load src) (load bi))) (func-name (al-get [Func] (load src) (load best)))))
                            (store! best (load bi)) 0) 0)
                    (store! bi (iadd (load bi) 1)))))
              (al-set! [bool] (mut used) (load best) true)
              (al-push! (mut out) (al-get [Func] (load src) (load best))))
            (store! c (iadd (load c) 1))))))
    (box-al [Func] a (load out))))
(defn sort-structs [(a (ptr Allocator)) (src (ptr (ArrayList StructDef)))] (-> (ptr (ArrayList StructDef)))
  (let [n (al-len [StructDef] (load src)) (mut used) (al-new [bool] a) (mut out) (al-new [StructDef] a) (mut k) 0]
    (loop (if (icmp-ge (load k) n) (break) (do (al-push! (mut used) false) (store! k (iadd (load k) 1)))))
    (let [(mut c) 0]
      (loop (if (icmp-ge (load c) n) (break)
        (do (let [(mut best) -1 (mut bi) 0]
              (loop (if (icmp-ge (load bi) n) (break)
                (do (if (not (al-get [bool] (load used) (load bi)))
                        (if (or (icmp-lt (load best) 0)
                                (str-lt (sdef-name (al-get [StructDef] (load src) (load bi))) (sdef-name (al-get [StructDef] (load src) (load best)))))
                            (store! best (load bi)) 0) 0)
                    (store! bi (iadd (load bi) 1)))))
              (al-set! [bool] (mut used) (load best) true)
              (al-push! (mut out) (al-get [StructDef] (load src) (load best))))
            (store! c (iadd (load c) 1))))))
    (box-al [StructDef] a (load out))))
(defn sort-sums [(a (ptr Allocator)) (src (ptr (ArrayList SumDef)))] (-> (ptr (ArrayList SumDef)))
  (let [n (al-len [SumDef] (load src)) (mut used) (al-new [bool] a) (mut out) (al-new [SumDef] a) (mut k) 0]
    (loop (if (icmp-ge (load k) n) (break) (do (al-push! (mut used) false) (store! k (iadd (load k) 1)))))
    (let [(mut c) 0]
      (loop (if (icmp-ge (load c) n) (break)
        (do (let [(mut best) -1 (mut bi) 0]
              (loop (if (icmp-ge (load bi) n) (break)
                (do (if (not (al-get [bool] (load used) (load bi)))
                        (if (or (icmp-lt (load best) 0)
                                (str-lt (sumdef-name (al-get [SumDef] (load src) (load bi))) (sumdef-name (al-get [SumDef] (load src) (load best)))))
                            (store! best (load bi)) 0) 0)
                    (store! bi (iadd (load bi) 1)))))
              (al-set! [bool] (mut used) (load best) true)
              (al-push! (mut out) (al-get [SumDef] (load src) (load best))))
            (store! c (iadd (load c) 1))))))
    (box-al [SumDef] a (load out))))
(defn sort-mono-program [(a (ptr Allocator)) (p (ptr Program))] (-> i64)
  (store! (field p funcs)   (sort-funcs   a (load (field p funcs))))
  (store! (field p structs) (sort-structs a (load (field p structs))))
  (store! (field p sums)    (sort-sums    a (load (field p sums))))
  0)

; ============================ entry ========================================
(defn dump-checked-program [(a (ptr Allocator)) (src (slice u8)) (cwd (slice u8))] (-> i64)
  (let [w (stdout) s (alloc-stack LS)]
    (store! (field s a) a)
    (store! (field s out)     (al-new [TaggedForm] a))
    (store! (field s loaded)  (al-new [(slice u8)] a))
    (store! (field s imports) (al-new [ImpEntry] a))
    (store! (field s exports) (al-new [ExpEntry] a))
    (match (read-all a src)
      (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
      (Ok [forms]
        (do (load-program (mut s) forms cwd)
            (match (resolve-program a (mut s))
              (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
              (Ok [prog]
                (match (check-program a prog (mut s))
                  (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
                  (Ok [cp]
                    (do (drop-code-funcs a cp)
                        (match (monomorphize a cp)
                          (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
                          (Ok [mp] (do (sort-mono-program a mp) (d-program w mp a)))))))))))))
  0)

; A standalone byte-exact smoke for the 6 new d-expr arms (run: `<bin> __smoke`).
; Each line must match exactly what src/dump_ast.rs would emit for the same node.
(defn smoke [(a (ptr Allocator))] (-> i64)
  (let [w (stdout)]
    ; (staticref@1:2 "foo")
    (let [e (alloc-stack Expr)] (store! e (mk-expr (EStaticRef "foo") 1 2)) (d-expr w e)) (wb w 10)
    ; (spillref@5:6 (eint@3:4 7))
    (let [inner (box-expr a (mk-expr (EInt 7) 3 4)) e (alloc-stack Expr)]
      (store! e (mk-expr (ESpillRef inner) 5 6)) (d-expr w e)) (wb w 10)
    ; (construct@9:10 "Opt" "Some" [(eint@7:8 9)])
    (let [(mut xs) (al-new [Expr] a)]
      (al-push! (mut xs) (mk-expr (EInt 9) 7 8))
      (let [args (box-al [Expr] a (load xs)) e (alloc-stack Expr)]
        (store! e (mk-expr (EConstruct "Opt" "Some" args) 9 10)) (d-expr w e))) (wb w 10)
    ; (traitcall@11:12 "Eq" "eq" "T" [])
    (let [args (box-al [Expr] a (al-new [Expr] a)) e (alloc-stack Expr)]
      (store! e (mk-expr (ETraitCall "Eq" "eq" "T" args) 11 12)) (d-expr w e)) (wb w 10)
    ; (makedyn@13:14 "Dyn" "VT" ["m0" "m1"] (var@15:16 "x"))
    (let [(mut ms) (al-new [(slice u8)] a)]
      (al-push! (mut ms) "m0") (al-push! (mut ms) "m1")
      (let [methods (box-al [(slice u8)] a (load ms))
            inner (box-expr a (mk-expr (EVar "x") 15 16)) e (alloc-stack Expr)]
        (store! e (mk-expr (EMakeDyn "Dyn" "VT" methods inner) 13 14)) (d-expr w e))) (wb w 10)
    ; (dyndispatch@17:18 "Dyn" "VT" 2 "c" [] void (var@19:20 "r") [])
    (let [params (box-al [Type] a (al-new [Type] a))
          args (box-al [Expr] a (al-new [Expr] a))
          recv (box-expr a (mk-expr (EVar "r") 19 20)) e (alloc-stack Expr)]
      (store! e (mk-expr (EDynDispatch "Dyn" "VT" 2 "c" params (TVoid) recv args) 17 18)) (d-expr w e)) (wb w 10)
    ; ---- ty-str byte-exact checks (vs src/check.rs::ty_str) ----
    (let [t (alloc-stack Type)] (store! t (TInt 64 true))  (ps w (ty-str a t))) (wb w 10)  ; i64
    (let [t (alloc-stack Type)] (store! t (TInt 8 false))  (ps w (ty-str a t))) (wb w 10)  ; u8
    (let [t (alloc-stack Type)] (store! t (TPtr (box-type a (TInt 8 false)))) (ps w (ty-str a t))) (wb w 10)  ; (ptr u8)
    (let [t (alloc-stack Type)] (store! t (TRef true (box-type a (TStruct "Foo")))) (ps w (ty-str a t))) (wb w 10)  ; (mut Foo)
    (let [(mut ps2) (al-new [Type] a)]
      (al-push! (mut ps2) (TInt 64 true)) (al-push! (mut ps2) (TInt 64 true))
      (let [t (alloc-stack Type)] (store! t (TApp "Pair" (box-al [Type] a (load ps2)))) (ps w (ty-str a t)))) (wb w 10)  ; (Pair i64 i64)
    (let [(mut ps3) (al-new [Type] a)]
      (al-push! (mut ps3) (TPtr (box-type a (TInt 8 true))))
      (let [t (alloc-stack Type)] (store! t (TFn "c" (box-al [Type] a (load ps3)) (box-type a (TInt 64 true)))) (ps w (ty-str a t)))) (wb w 10)  ; (fnptr c [(ptr i8)] i64)
    0))

; ============================ codegen (the frontier) =========================
; src/codegen.rs (3496 lines): monomorphized Program -> LLVM module, built via the
; LLVM-C FFI surface above. FAITHFUL, call-for-call port of `compile_for_dbg` with
; dbg=None (every debug-info path skipped). The corpus has no shims / no struct-by-
; value C ABI, so abi.rs is deferred (a struct-by-value extern would hard-error).

; ---- Tv: a lowered (value, Coil type) pair (Rust `Tv<'ctx>` = (BasicValueEnum, Type))
(defstruct Tv [(val (ptr i8)) (ty Type)])
(defn mk-tv [(v (ptr i8)) (t Type)] (-> Tv)
  (let [p (alloc-stack Tv)] (store! (field p val) v) (store! (field p ty) t) (load p)))
(defn tv-val [(t Tv)] (-> (ptr i8)) (let [p (alloc-stack Tv)] (store! p t) (load (field p val))))
(defn tv-ty  [(t Tv)] (-> Type)     (let [p (alloc-stack Tv)] (store! p t) (load (field p ty))))

; ---- scope: a persistent cons-list (HashMap<String,Tv> with clone+insert = cons,
;      lookup = linear-from-head so a later binding shadows an earlier one).
(defsum Scope
  (SNil  [])
  (SBind [(name (slice u8)) (val (ptr i8)) (ty Type) (rest (ptr Scope))]))
(defn scope-nil [(a (ptr Allocator))] (-> (ptr Scope))
  (let [p (unwrap-ptr [Scope] (create [Scope] a))] (store! p (SNil)) p))
(defn scope-put [(a (ptr Allocator)) (s (ptr Scope)) (name (slice u8)) (v (ptr i8)) (t Type)] (-> (ptr Scope))
  (let [p (unwrap-ptr [Scope] (create [Scope] a))] (store! p (SBind name v t s)) p))
(defn scope-get [(s (ptr Scope)) (name (slice u8))] (-> (Option Tv))
  (match (load s)
    (SNil  []          (None [Tv]))
    (SBind [n v t rest] (if (str-eq n name) (Some [Tv] (mk-tv v t)) (scope-get rest name)))))

; ---- Cg: codegen state (Rust `Cg<'ctx>` minus the debug-info fields). Maps are
;      ArrayLists keyed by name (the established self-host pattern; mono uses it).
(defstruct CgStruct [(name (slice u8)) (fields (ptr (ArrayList Field))) (ty (ptr i8)) (layout Layout)])
(defstruct CgSum    [(name (slice u8)) (variants (ptr (ArrayList Variant))) (ty (ptr i8)) (vstructs (ptr (ArrayList (ptr i8))))])
(defstruct CgFunc   [(name (slice u8)) (val (ptr i8))])
(defstruct CgRet    [(name (slice u8)) (ty Type)])
(defstruct CgSig    [(name (slice u8)) (cc (slice u8)) (params (ptr (ArrayList Type))) (ret Type)])
(defstruct CgBreak  [(val (ptr i8)) (bb (ptr i8))])
(defstruct CgLoop   [(label (Option (slice u8))) (body_bb (ptr i8)) (after_bb (ptr i8))
                     (breaks (ArrayList CgBreak)) (break_ty (Option Type))])
(defstruct CgStatic [(name (slice u8)) (ptr (ptr i8)) (ty Type)])
(defstruct Cg
  [(ctx (ptr i8)) (module (ptr i8)) (builder (ptr i8)) (td (ptr i8))
   (structs (ArrayList CgStruct)) (sums (ArrayList CgSum))
   (funcs (ArrayList CgFunc)) (rets (ArrayList CgRet)) (sigs (ArrayList CgSig))
   (statics (ArrayList CgStatic))
   (globals i64) (llvm_seq i64)
   (loops (ArrayList CgLoop))
   (a (ptr Allocator))])

; ---- map lookups (linear; names are unique so first/last match is the same) ----
(defn cg-struct-idx [(cg (ptr Cg)) (nm (slice u8))] (-> i64)
  (let [n (al-len [CgStruct] (load (field cg structs))) (mut i) 0 (mut r) -1]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [CgStruct] (field cg structs) (load i)) name)) nm) (store! r (load i)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn cg-sum-idx [(cg (ptr Cg)) (nm (slice u8))] (-> i64)
  (let [n (al-len [CgSum] (load (field cg sums))) (mut i) 0 (mut r) -1]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [CgSum] (field cg sums) (load i)) name)) nm) (store! r (load i)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn cg-func [(cg (ptr Cg)) (nm (slice u8))] (-> (ptr i8))   ; 0 if absent
  (let [n (al-len [CgFunc] (load (field cg funcs))) (mut i) 0 (mut r) (cast (ptr i8) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [fp (al-elem [CgFunc] (field cg funcs) (load i))]
            (if (str-eq (load (field fp name)) nm) (do (store! r (load (field fp val))) 0) 0))
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn cg-ret [(cg (ptr Cg)) (nm (slice u8))] (-> (Option Type))
  (let [n (al-len [CgRet] (load (field cg rets))) (mut i) 0 (mut r) (None [Type])]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [fp (al-elem [CgRet] (field cg rets) (load i))]
            (if (str-eq (load (field fp name)) nm) (do (store! r (Some [Type] (load (field fp ty)))) 0) 0))
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn cg-sig-idx [(cg (ptr Cg)) (nm (slice u8))] (-> i64)
  (let [n (al-len [CgSig] (load (field cg sigs))) (mut i) 0 (mut r) -1]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [CgSig] (field cg sigs) (load i)) name)) nm) (store! r (load i)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn cg-static-idx [(cg (ptr Cg)) (nm (slice u8))] (-> i64)
  (let [n (al-len [CgStatic] (load (field cg statics))) (mut i) 0 (mut r) -1]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [CgStatic] (field cg statics) (load i)) name)) nm) (store! r (load i)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))

; ---- small FFI conveniences ----
(defn cg-bug [(msg (slice u8))] (-> Tv) (unimplemented msg) (mk-tv (cast (ptr i8) 0) (TInt 64 true)))
(defn ty-is-void [(t (ptr Type))] (-> bool) (match-else (load t) (TVoid [] true) (_ false)))
(defn int-width [(ctx (ptr i8)) (bits i64)] (-> (ptr i8)) (LLVMIntTypeInContext ctx (cast i32 bits)))
; an ArrayList of opaque handles -> a contiguous C array (ptr (ptr i8)).
(defn carr [(a (ptr Allocator)) (xs (ArrayList (ptr i8)))] (-> (ptr (ptr i8)))
  (let [n (al-len [(ptr i8)] xs)
        buf (cast (ptr (ptr i8)) (unwrap-ptr [i8] (raw-alloc a (imul (if (icmp-eq n 0) 1 n) 8) 8)))
        (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (store! (index buf (load i)) (al-get [(ptr i8)] xs (load i)))
          (store! i (iadd (load i) 1)))))
    buf))
; LLVMConstInt of `ty` for value 0 (the const_zero of an int/bool type).
(defn cg-zero [(ty (ptr i8))] (-> (ptr i8)) (LLVMConstInt ty 0 0))

; ---- the slice fat-pointer type { ptr, i64 } (a fresh literal struct; LLVM
;      uniques it so repeated calls return the same type, exactly like inkwell).
(defn cg-slice-ty [(cg (ptr Cg))] (-> (ptr i8))
  (let [ctx (load (field cg ctx)) (mut fs) (al-new [(ptr i8)] (load (field cg a)))]
    (al-push! (mut fs) (LLVMPointerTypeInContext ctx 0))
    (al-push! (mut fs) (LLVMInt64TypeInContext ctx))
    (LLVMStructTypeInContext ctx (carr (load (field cg a)) (load fs)) 2 0)))

; ---- basic_ty: Coil Type -> LLVM type (src/codegen.rs:771). void/App/Code are
;      compiler-bug paths (hard error, never a placeholder).
(defn basic-ty [(cg (ptr Cg)) (t (ptr Type))] (-> (ptr i8))
  (let [ctx (load (field cg ctx))]
    (match (load t)
      (TNever  []        (LLVMInt64TypeInContext ctx))
      (TInt    [bits s]  (int-width ctx bits))
      (TFloat  [b]       (if (icmp-eq b 32) (LLVMFloatTypeInContext ctx) (LLVMDoubleTypeInContext ctx)))
      (TBool   []        (LLVMInt1TypeInContext ctx))
      (TPtr    [i]       (LLVMPointerTypeInContext ctx 0))
      (TRef    [m i]     (LLVMPointerTypeInContext ctx 0))
      (TFn     [c p r]   (LLVMPointerTypeInContext ctx 0))
      (TArray  [el n]    (LLVMArrayType2 (basic-ty cg el) n))
      (TSlice  [el]      (cg-slice-ty cg))
      (TStruct [nm]      (cg-nominal-ty cg nm))
      (TVec    [el n]    (LLVMVectorType (basic-ty cg el) (cast i32 n)))
      (TVoid   []        (do (unimplemented "codegen/basic_ty: void reached as a value type (checker hole)") (cast (ptr i8) 0)))
      (TApp    [n a]     (do (unimplemented "codegen/basic_ty: generic type survived monomorphization") (cast (ptr i8) 0)))
      (TCode   []        (do (unimplemented "codegen/basic_ty: comptime-only Code reached codegen") (cast (ptr i8) 0))))))
(defn cg-nominal-ty [(cg (ptr Cg)) (nm (slice u8))] (-> (ptr i8))
  (let [ctx (load (field cg ctx)) si (cg-struct-idx cg nm)]
    (if (icmp-ge si 0)
        (let [sp (al-elem [CgStruct] (field cg structs) si)]
          (match-else (load (field sp layout))
            (LBits [backing offs] (int-width ctx backing))
            (_ (load (field sp ty)))))
      (let [ui (cg-sum-idx cg nm)]
        (if (icmp-ge ui 0)
            (load (field (al-elem [CgSum] (field cg sums) ui) ty))
          (do (unimplemented "codegen/basic_ty: unknown nominal type") (cast (ptr i8) 0)))))))

; ---- layout helpers (src/codegen.rs:3449): conservative payload sizing for sums.
(defn align8 [(x i64)] (-> i64) (imul (udiv (iadd x 7) 8) 8))
(defn type-bytes [(cg (ptr Cg)) (t (ptr Type))] (-> i64)
  (match (load t)
    (TInt   [bits s] (udiv (iadd bits 7) 8))
    (TFloat [bits]   (udiv bits 8))
    (TBool  []       1)
    (TPtr   [i]      8)
    (TFn    [c p r]  8)
    (TRef   [m i]    8)
    (TSlice [el]     16)
    (TArray [el n]   (imul (align8 (type-bytes cg el)) n))
    (TVec   [el n]   (imul (type-bytes cg el) n))
    (TStruct [nm]    (cg-type-bytes-nominal cg nm))
    (TNever []       (do (unimplemented "codegen/type_bytes: Never has no size") 0))
    (TCode  []       (do (unimplemented "codegen/type_bytes: Code has no size") 0))
    (TVoid  []       (do (unimplemented "codegen/type_bytes: void has no size") 0))
    (TApp   [n a]    8)))
(defn cg-type-bytes-nominal [(cg (ptr Cg)) (nm (slice u8))] (-> i64)
  (let [si (cg-struct-idx cg nm)]
    (if (icmp-ge si 0)
        (let [sp (al-elem [CgStruct] (field cg structs) si)
              fs (load (field sp fields)) n (al-len [Field] (load fs)) (mut i) 0 (mut sum) 0]
          (loop (if (icmp-ge (load i) n) (break)
            (do (store! sum (iadd (load sum) (align8 (type-bytes cg (field (al-elem [Field] fs (load i)) ty)))))
                (store! i (iadd (load i) 1)))))
          (load sum))
      (let [ui (cg-sum-idx cg nm)]
        (if (icmp-ge ui 0)
            (iadd 8 (imul (cg-sum-words cg (al-elem [CgSum] (field cg sums) ui)) 8))
          8)))))
(defn cg-sum-words [(cg (ptr Cg)) (sp (ptr CgSum))] (-> i64)
  (let [vs (load (field sp variants)) nv (al-len [Variant] (load vs)) (mut i) 0 (mut maxb) 0]
    (loop (if (icmp-ge (load i) nv) (break)
      (do (let [vp (al-elem [Variant] vs (load i)) fs (load (field vp fields)) nf (al-len [Field] (load fs)) (mut j) 0 (mut acc) 0]
            (loop (if (icmp-ge (load j) nf) (break)
              (do (store! acc (iadd (load acc) (align8 (type-bytes cg (field (al-elem [Field] fs (load j)) ty)))))
                  (store! j (iadd (load j) 1)))))
            (if (icmp-gt (load acc) (load maxb)) (store! maxb (load acc)) 0))
          (store! i (iadd (load i) 1)))))
    (udiv (load maxb) 8)))
; sum_words from a SumDef (used during type registration, before CgSum exists).
(defn cg-sum-words-def [(cg (ptr Cg)) (sd (ptr SumDef))] (-> i64)
  (let [vs (load (field sd variants)) nv (al-len [Variant] (load vs)) (mut i) 0 (mut maxb) 0]
    (loop (if (icmp-ge (load i) nv) (break)
      (do (let [vp (al-elem [Variant] vs (load i)) fs (load (field vp fields)) nf (al-len [Field] (load fs)) (mut j) 0 (mut acc) 0]
            (loop (if (icmp-ge (load j) nf) (break)
              (do (store! acc (iadd (load acc) (align8 (type-bytes cg (field (al-elem [Field] fs (load j)) ty)))))
                  (store! j (iadd (load j) 1)))))
            (if (icmp-gt (load acc) (load maxb)) (store! maxb (load acc)) 0))
          (store! i (iadd (load i) 1)))))
    (udiv (load maxb) 8)))

; ---- offset_of / const_eval (for static-assert; src/codegen.rs:3118/3143).
(defn cg-offset-of [(cg (ptr Cg)) (t (ptr Type)) (fname (slice u8))] (-> i64)
  (match-else (load t)
    (TStruct [nm]
      (let [si (cg-struct-idx cg nm)]
        (if (icmp-lt si 0) (do (unimplemented "codegen/offsetof: non-struct") 0)
          (let [sp (al-elem [CgStruct] (field cg structs) si)
                fs (load (field sp fields)) n (al-len [Field] (load fs)) (mut i) 0 (mut idx) -1]
            (loop (if (icmp-ge (load i) n) (break)
              (do (if (str-eq (load (field (al-elem [Field] fs (load i)) name)) fname) (store! idx (load i)) 0)
                  (store! i (iadd (load i) 1)))))
            (if (icmp-lt (load idx) 0) (do (unimplemented "codegen/offsetof: no such field") 0)
              (match-else (load (field sp layout))
                (LExplicit [offs sz al] (al-get [i64] (load offs) (load idx)))
                (_ (LLVMOffsetOfElement (load (field cg td)) (load (field sp ty)) (cast i32 (load idx))))))))))
    (_ (do (unimplemented "codegen/offsetof: needs a struct") 0))))
; const_eval_t -> (value, is_unsigned). Faithful to src/codegen.rs:3153.
(defstruct CEval [(v i64) (uns bool)])
(defn mk-ceval [(v i64) (u bool)] (-> CEval)
  (let [p (alloc-stack CEval)] (store! (field p v) v) (store! (field p uns) u) (load p)))
(defn cev-v [(c CEval)] (-> i64) (let [p (alloc-stack CEval)] (store! p c) (load (field p v))))
(defn cev-u [(c CEval)] (-> bool) (let [p (alloc-stack CEval)] (store! p c) (load (field p uns))))
(defn const-eval-bin [(op i64) (l i64) (lu bool) (r i64) (ru bool)] (-> CEval)
  (let [uns (or lu ru)]
    (mk-ceval
      (if (icmp-eq op 0)  (iadd l r)
      (if (icmp-eq op 1)  (isub l r)
      (if (icmp-eq op 2)  (imul l r)
      (if (icmp-eq op 7)  (iand l r)
      (if (icmp-eq op 8)  (ior l r)
      (if (icmp-eq op 9)  (ixor l r)
      (if (icmp-eq op 10) (ishl l r)
      (if (icmp-eq op 11) (if uns (cast i64 (ishr (cast u64 l) (cast u64 r))) (ishr l r))
      (if (icmp-eq op 3)  (if (icmp-eq r 0) (do (unimplemented "static-assert: divide by zero") 0) (if uns (udiv l r) (idiv l r)))
      (if (icmp-eq op 4)  (if (icmp-eq r 0) (do (unimplemented "static-assert: mod by zero") 0) (if uns (urem l r) (irem l r)))
      (if (icmp-eq op 5)  (if (icmp-eq r 0) (do (unimplemented "static-assert: divide by zero") 0) (udiv l r))
                          (if (icmp-eq r 0) (do (unimplemented "static-assert: mod by zero") 0) (urem l r)))))))))))))
      uns)))
(defn const-eval-cmp [(op i64) (l i64) (lu bool) (r i64) (ru bool)] (-> CEval)
  (let [b (if (or lu ru)
              (let [lx (cast u64 l) rx (cast u64 r)]
                (if (icmp-eq op 0) (icmp-lt lx rx) (if (icmp-eq op 1) (icmp-le lx rx)
                (if (icmp-eq op 2) (icmp-gt lx rx) (if (icmp-eq op 3) (icmp-ge lx rx)
                (if (icmp-eq op 4) (icmp-eq lx rx) (icmp-ne lx rx)))))))
              (if (icmp-eq op 0) (icmp-lt l r) (if (icmp-eq op 1) (icmp-le l r)
              (if (icmp-eq op 2) (icmp-gt l r) (if (icmp-eq op 3) (icmp-ge l r)
              (if (icmp-eq op 4) (icmp-eq l r) (icmp-ne l r)))))))]
    (mk-ceval (if b 1 0) false)))
(defn const-eval-t [(cg (ptr Cg)) (e (ptr Expr))] (-> CEval)
  (let [a (load (field cg a))]
    (match-else (load (field e kind))
      (EInt    [v]         (mk-ceval v false))
      (EBool   [b]         (mk-ceval (if b 1 0) false))
      (EIf     [c thn els] (if (icmp-ne (cev-v (const-eval-t cg c)) 0) (const-eval-t cg thn) (const-eval-t cg els)))
      (ESizeOf [t]         (mk-ceval (LLVMABISizeOfType (load (field cg td)) (basic-ty cg (box-type a t))) false))
      (EAlignOf[t]         (mk-ceval (cast i64 (LLVMABIAlignmentOfType (load (field cg td)) (basic-ty cg (box-type a t)))) false))
      (EOffsetOf[t fname]  (mk-ceval (cg-offset-of cg (box-type a t) fname) false))
      (ECast   [t inner]   (mk-ceval (cev-v (const-eval-t cg inner)) (match-else t (TInt [bits s] (not s)) (_ false))))
      (EBin    [op lhs rhs] (let [lc (const-eval-t cg lhs) rc (const-eval-t cg rhs)]
                              (const-eval-bin op (cev-v lc) (cev-u lc) (cev-v rc) (cev-u rc))))
      (ECmp    [op lhs rhs] (let [lc (const-eval-t cg lhs) rc (const-eval-t cg rhs)]
                              (const-eval-cmp op (cev-v lc) (cev-u lc) (cev-v rc) (cev-u rc))))
      (_ (do (unimplemented "static-assert: only int literals, sizeof/alignof/offsetof, casts, arithmetic and comparisons are allowed") (mk-ceval 0 false))))))
(defn const-eval [(cg (ptr Cg)) (e (ptr Expr))] (-> i64) (cev-v (const-eval-t cg e)))

; ---- builder conveniences ----
(defn cg-bld [(cg (ptr Cg))] (-> (ptr i8)) (load (field cg builder)))
(defn cg-ctx [(cg (ptr Cg))] (-> (ptr i8)) (load (field cg ctx)))
(defn cg-i64t [(cg (ptr Cg))] (-> (ptr i8)) (LLVMInt64TypeInContext (cg-ctx cg)))
(defn cg-i32t [(cg (ptr Cg))] (-> (ptr i8)) (LLVMInt32TypeInContext (cg-ctx cg)))
(defn cg-const-i64 [(cg (ptr Cg)) (n i64)] (-> (ptr i8)) (LLVMConstInt (cg-i64t cg) n 1))
(defn cg-zero-i64 [(cg (ptr Cg))] (-> (ptr i8)) (LLVMConstInt (cg-i64t cg) 0 0))
(defn cg-append [(cg (ptr Cg)) (func (ptr i8)) (nm (ptr i8))] (-> (ptr i8)) (LLVMAppendBasicBlockInContext (cg-ctx cg) func nm))
(defn cg-pos [(cg (ptr Cg)) (bb (ptr i8))] (-> i64) (LLVMPositionBuilderAtEnd (cg-bld cg) bb) 0)
(defn cg-cur-block [(cg (ptr Cg))] (-> (ptr i8)) (LLVMGetInsertBlock (cg-bld cg)))
(defn cg-cur-func [(cg (ptr Cg))] (-> (ptr i8)) (LLVMGetBasicBlockParent (cg-cur-block cg)))
; Entry-block alloca: a constant-size alloca is a STATIC (allocate-once) frame
; slot only when it sits in the function's ENTRY block. Emitted inline inside a
; loop it becomes a DYNAMIC per-iteration stack growth — the cause of unbounded
; stack use when compiling large programs (e.g. a by-value-aggregate `al-push!`
; loop). Build compiler-internal temp/spill slots here so each is allocated once
; and reused across iterations. Mirrors src/codegen.rs::entry_alloca.
(defn cg-entry-alloca [(cg (ptr Cg)) (ty (ptr i8)) (name (ptr i8))] (-> (ptr i8))
  (let [b (cg-bld cg)
        cur (LLVMGetInsertBlock b)
        entry (LLVMGetEntryBasicBlock (LLVMGetBasicBlockParent cur))
        first (LLVMGetFirstInstruction entry)]
    (if (icmp-eq (cast i64 first) 0)
        (do (LLVMPositionBuilderAtEnd b entry) 0)
        (do (LLVMPositionBuilderBefore b first) 0))
    (let [slot (LLVMBuildAlloca b ty name)]
      (LLVMPositionBuilderAtEnd b cur)
      slot)))
(defn cg-terminated [(cg (ptr Cg))] (-> bool) (icmp-ne (cast i64 (LLVMGetBasicBlockTerminator (cg-cur-block cg))) 0))
(defn cg-bl [(cg (ptr Cg)) (s (slice u8))] (-> (ptr i8)) (slice->cstr (load (field cg a)) s))
; next global counter value (shared g/str/cstr counter, per src/codegen.rs).
(defn cg-next-global [(cg (ptr Cg))] (-> i64)
  (let [n (load (field cg globals))] (store! (field cg globals) (iadd n 1)) n))
(defn cg-gname [(cg (ptr Cg)) (prefix (slice u8)) (n i64)] (-> (ptr i8))
  (slice->cstr (load (field cg a)) (sconcat (load (field cg a)) prefix (i64->str (load (field cg a)) n))))
; build a function type from Coil params/ret (fn_type_types).
(defn cg-fn-type [(cg (ptr Cg)) (params (ptr (ArrayList Type))) (ret (ptr Type))] (-> (ptr i8))
  (let [n (al-len [Type] (load params)) (mut tys) (al-new [(ptr i8)] (load (field cg a))) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut tys) (basic-ty cg (al-elem [Type] params (load i)))) (store! i (iadd (load i) 1)))))
    (let [rt (if (ty-is-void ret) (LLVMVoidTypeInContext (cg-ctx cg)) (basic-ty cg ret))]
      (LLVMFunctionType rt (carr (load (field cg a)) (load tys)) (cast i32 n) 0))))

; ---- variant index in a sum (position of `variant` in its variant list) ----
(defn cg-variant-idx [(cg (ptr Cg)) (sp (ptr CgSum)) (variant (slice u8))] (-> i64)
  (let [vs (load (field sp variants)) n (al-len [Variant] (load vs)) (mut i) 0 (mut r) -1]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [Variant] vs (load i)) name)) variant) (store! r (load i)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))

; ---- string replace (for emit_llvm_ir placeholder substitution) ----
(defn str-replace-all [(a (ptr Allocator)) (hay (slice u8)) (needle (slice u8)) (rep (slice u8))] (-> (slice u8))
  (let [(mut sb) (sb-new a) nl (slice-len needle) n (slice-len hay) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (if (and (icmp-le (iadd (load i) nl) n) (str-eq (substr hay (load i) (iadd (load i) nl)) needle))
          (do (sb-push-str! (mut sb) rep) (store! i (iadd (load i) nl)))
          (do (sb-push-byte! (mut sb) (slice-get hay (load i))) (store! i (iadd (load i) 1))))))
    (sb-str (load sb))))

; ---- emit a list of arg expressions to their LLVM values ----
(defn emit-vals [(cg (ptr Cg)) (es (ptr (ArrayList Expr))) (scp (ptr Scope))] (-> (ArrayList (ptr i8)))
  (let [n (al-len [Expr] (load es)) (mut out) (al-new [(ptr i8)] (load (field cg a))) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut out) (tv-val (emit-expr cg (al-elem [Expr] es (load i)) scp)))
          (store! i (iadd (load i) 1)))))
    (load out)))

; ---- reconcile_args: spill a struct/array VALUE passed to a pointer param ----
(defn reconcile-args [(cg (ptr Cg)) (callee (ptr i8)) (vals (ArrayList (ptr i8)))] (-> (ArrayList (ptr i8)))
  (let [a (load (field cg a)) fnty (LLVMGlobalGetValueType callee)
        np (cast i64 (LLVMCountParamTypes fnty))
        ptbuf (cast (ptr (ptr i8)) (unwrap-ptr [i8] (raw-alloc a (imul (if (icmp-eq np 0) 1 np) 8) 8)))
        n (al-len [(ptr i8)] vals) (mut out) (al-new [(ptr i8)] a) (mut i) 0]
    (LLVMGetParamTypes fnty ptbuf)
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [v (al-get [(ptr i8)] vals (load i)) (mut av) v]
            (if (icmp-lt (load i) np)
                (let [pt (load (index ptbuf (load i))) vk (LLVMGetTypeKind (LLVMTypeOf v))]
                  (if (and (icmp-eq (LLVMGetTypeKind pt) 12) (or (icmp-eq vk 10) (icmp-eq vk 11)))
                      (let [slot (cg-entry-alloca cg (LLVMTypeOf v) (cg-bl cg "arg.spill"))]
                        (LLVMBuildStore (cg-bld cg) v slot) (store! av slot) 0)
                      0))
                0)
            (al-push! (mut out) (load av)))
          (store! i (iadd (load i) 1)))))
    (load out)))

; ======================== emit_expr (src/codegen.rs:2256) =====================
(defn emit-expr [(cg (ptr Cg)) (e (ptr Expr)) (scp (ptr Scope))] (-> Tv)
  (let [a (load (field cg a)) b (cg-bld cg) ctx (cg-ctx cg)]
    (match (load (field e kind))
      (EInt   [v]  (mk-tv (LLVMConstInt (cg-i64t cg) v 1) (TInt 64 true)))
      (EBool  [bv] (mk-tv (LLVMConstInt (LLVMInt1TypeInContext ctx) (if bv 1 0) 0) (TBool)))
      (EFloat [bits] (mk-tv (LLVMConstReal (LLVMDoubleTypeInContext ctx)
                              (let [p (alloc-stack i64)] (store! p bits) (load (cast (ptr f64) p)))) (TFloat 64)))
      (EStr   [s] (let [bytes (LLVMConstStringInContext ctx (cast (ptr i8) (slice-data [u8] s)) (cast i32 (slice-len s)) 1)
                        n (cg-next-global cg)
                        g (LLVMAddGlobal (load (field cg module)) (LLVMTypeOf bytes) (cg-gname cg "str." n))]
                    (LLVMSetInitializer g bytes) (LLVMSetGlobalConstant g 1) (LLVMSetLinkage g 9)
                    (let [(mut fs) (al-new [(ptr i8)] a)]
                      (al-push! (mut fs) g) (al-push! (mut fs) (LLVMConstInt (cg-i64t cg) (slice-len s) 0))
                      (mk-tv (LLVMConstStructInContext ctx (carr a (load fs)) 2 0) (TSlice (box-type a (TInt 8 false)))))))
      (ECStr  [s] (let [bytes (LLVMConstStringInContext ctx (cast (ptr i8) (slice-data [u8] s)) (cast i32 (slice-len s)) 0)
                        n (cg-next-global cg)
                        g (LLVMAddGlobal (load (field cg module)) (LLVMTypeOf bytes) (cg-gname cg "cstr." n))]
                    (LLVMSetInitializer g bytes) (LLVMSetGlobalConstant g 1) (LLVMSetLinkage g 9)
                    (mk-tv g (TPtr (box-type a (TInt 8 true))))))
      (EVar   [name] (match (scope-get scp name)
                       (Some [tv] tv)
                       (None []    (cg-bug (sconcat a "codegen: unbound " name)))))
      (EZeroed [t] (mk-tv (LLVMConstNull (basic-ty cg (box-type a t))) t))
      (EBorrow [m place] (emit-expr cg place scp))
      (ESpillRef [inner] (let [tv (emit-expr cg inner scp) t (tv-ty tv)
                               slot (cg-entry-alloca cg (basic-ty cg (box-type a t)) (cg-bl cg "spill"))]
                           (LLVMBuildStore b (tv-val tv) slot)
                           (mk-tv slot (TPtr (box-type a t)))))
      (EBin [op lhs rhs]
        (let [lv (emit-expr cg lhs scp) rv (emit-expr cg rhs scp) lt (tv-ty lv)
              l (tv-val lv) r (tv-val rv)]
          (if (match-else lt (TFloat [x] true) (_ false))
              (mk-tv (if (icmp-eq op 0) (LLVMBuildFAdd b l r (cg-bl cg "fadd"))
                     (if (icmp-eq op 1) (LLVMBuildFSub b l r (cg-bl cg "fsub"))
                     (if (icmp-eq op 2) (LLVMBuildFMul b l r (cg-bl cg "fmul"))
                     (if (icmp-eq op 3) (LLVMBuildFDiv b l r (cg-bl cg "fdiv"))
                     (if (icmp-eq op 4) (LLVMBuildFRem b l r (cg-bl cg "frem"))
                         (do (unimplemented "codegen: bitwise op on a float") (cast (ptr i8) 0))))))) lt)
            (let [signed (match-else lt (TInt [bits s] s) (_ false))]
              (mk-tv (if (icmp-eq op 0) (LLVMBuildAdd b l r (cg-bl cg "add"))
                     (if (icmp-eq op 1) (LLVMBuildSub b l r (cg-bl cg "sub"))
                     (if (icmp-eq op 2) (LLVMBuildMul b l r (cg-bl cg "mul"))
                     (if (icmp-eq op 3) (if signed (LLVMBuildSDiv b l r (cg-bl cg "div")) (LLVMBuildUDiv b l r (cg-bl cg "div")))
                     (if (icmp-eq op 4) (if signed (LLVMBuildSRem b l r (cg-bl cg "rem")) (LLVMBuildURem b l r (cg-bl cg "rem")))
                     (if (icmp-eq op 5) (LLVMBuildUDiv b l r (cg-bl cg "udiv"))
                     (if (icmp-eq op 6) (LLVMBuildURem b l r (cg-bl cg "urem"))
                     (if (icmp-eq op 7) (LLVMBuildAnd b l r (cg-bl cg "and"))
                     (if (icmp-eq op 8) (LLVMBuildOr  b l r (cg-bl cg "or"))
                     (if (icmp-eq op 9) (LLVMBuildXor b l r (cg-bl cg "xor"))
                     (if (icmp-eq op 10) (LLVMBuildShl b l r (cg-bl cg "shl"))
                         (if signed (LLVMBuildAShr b l r (cg-bl cg "shr")) (LLVMBuildLShr b l r (cg-bl cg "shr")))))))))))))) lt)))))
      (ENot [x] (let [xv (emit-expr cg x scp)]
                  (mk-tv (LLVMBuildNot b (tv-val xv) (cg-bl cg "not")) (tv-ty xv))))
      (ECmp [op lhs rhs]
        (let [lv (emit-expr cg lhs scp) rv (emit-expr cg rhs scp) lt (tv-ty lv)
              l (tv-val lv) r (tv-val rv)]
          (if (match-else lt (TFloat [x] true) (_ false))
              (let [pred (if (icmp-eq op 0) 4 (if (icmp-eq op 1) 5 (if (icmp-eq op 2) 2 (if (icmp-eq op 3) 3 (if (icmp-eq op 4) 1 6)))))]
                (mk-tv (LLVMBuildFCmp b (cast i32 pred) l r (cg-bl cg "fcmp")) (TBool)))
            (let [signed (match-else lt (TInt [bits s] s) (_ false))
                  pred (if (icmp-eq op 0) (if signed 40 36) (if (icmp-eq op 1) (if signed 41 37)
                       (if (icmp-eq op 2) (if signed 38 34) (if (icmp-eq op 3) (if signed 39 35)
                       (if (icmp-eq op 4) 32 33)))))]
              (mk-tv (LLVMBuildICmp b (cast i32 pred) l r (cg-bl cg "cmp")) (TBool))))))
      (EDo [body] (emit-body cg body scp))
      (ELet [binds body]
        (let [child (emit-binds cg binds scp)] (emit-body cg body child)))
      (EIf [cnd thn els] (emit-if cg cnd thn els scp))
      (ELoop [label body] (emit-loop cg label body scp))
      (EBreak [label value] (emit-break cg label value scp))
      (EContinue [label] (emit-continue cg label))
      (ECall [func targs args] (emit-call cg func args scp))
      (EAlloc [storage t] (emit-alloc cg storage (box-type a t)))
      (EField [pe fname] (emit-field cg pe fname scp))
      (EBitGet [pe fname] (emit-bitget cg pe fname scp))
      (EBitSet [pe fname val] (emit-bitset cg pe fname val scp))
      (ELoad [inner]
        (let [pv (emit-expr cg inner scp)
              pointee (match-else (tv-ty pv) (TPtr [pe] (load pe)) (_ (do (unimplemented "codegen: load of non-pointer") (TInt 64 true))))]
          (mk-tv (LLVMBuildLoad2 b (basic-ty cg (box-type a pointee)) (tv-val pv) (cg-bl cg "load")) pointee)))
      (EStore [pe val]
        (let [pv (emit-expr cg pe scp) vv (emit-expr cg val scp)]
          (LLVMBuildStore b (tv-val vv) (tv-val pv)) (mk-tv (tv-val vv) (tv-ty vv))))
      (EIndex [pe idx] (emit-index cg pe idx scp))
      (ECast [t inner] (emit-cast cg (box-type a t) inner scp))
      (ESizeOf [t] (mk-tv (cg-const-i64 cg (LLVMABISizeOfType (load (field cg td)) (basic-ty cg (box-type a t)))) (TInt 64 true)))
      (EAlignOf [t] (mk-tv (cg-const-i64 cg (cast i64 (LLVMABIAlignmentOfType (load (field cg td)) (basic-ty cg (box-type a t))))) (TInt 64 true)))
      (EOffsetOf [t fname] (mk-tv (cg-const-i64 cg (cg-offset-of cg (box-type a t) fname)) (TInt 64 true)))
      (EFree [p] (let [pv (emit-expr cg p scp)] (LLVMBuildFree b (tv-val pv)) (mk-tv (cg-zero-i64 cg) (TInt 64 true))))
      (EConstruct [sum variant args] (emit-construct cg sum variant args scp))
      (EMatch [scrut arms] (emit-match cg scrut arms scp))
      (EFnPtrOf [name] (emit-fnptr cg name))
      (ECallPtr [fp args] (emit-callptr cg fp args scp))
      (ELlvmIr [result args body] (emit-llvm-ir cg (box-type a result) args body scp))
      (EStaticRef [name]
        (let [si (cg-static-idx cg name)]
          (if (icmp-lt si 0) (cg-bug (sconcat a "codegen: unknown static const " name))
            (let [sp (al-elem [CgStatic] (field cg statics) si)]
              (mk-tv (load (field sp ptr)) (TPtr (box-type a (load (field sp ty)))))))))
      (EErase [tn inner] (cg-bug "codegen: unlowered Erase (checker should have made it a MakeDyn)"))
      (ETraitCall [tn m s args] (cg-bug "codegen: unresolved trait call (compiler bug)"))
      (EComptime [inner] (cg-bug "codegen: unresolved comptime node (compiler bug)"))
      (EQuote [form] (cg-bug "codegen: a Code value has no runtime representation"))
      (ECodeOp [op args] (cg-bug "codegen: a Code value has no runtime representation"))
      (EQuasi [q] (cg-bug "codegen: a Code value has no runtime representation"))
      (ETypeQuery [q t] (cg-bug "codegen: unresolved type-query (compiler bug)"))
      (EFieldMeta [m t idx] (cg-bug "codegen: unresolved field-reflection (compiler bug)"))
      (EFieldIndex [t name] (cg-bug "codegen: unresolved field-reflection (compiler bug)"))
      (EMakeDyn [ds vt methods inner] (do (unimplemented "codegen: MakeDyn (deferred; no corpus use)") (cg-bug "makedyn")))
      (EDynDispatch [ds vt mi cc params ret recv args] (do (unimplemented "codegen: DynDispatch (deferred; no corpus use)") (cg-bug "dyndispatch"))))))

; emit a `do`/let body: last value, default (i64 0); stop at a terminator.
(defn emit-body [(cg (ptr Cg)) (body (ptr (ArrayList Expr))) (scp (ptr Scope))] (-> Tv)
  (let [n (al-len [Expr] (load body)) (mut last) (mk-tv (cg-zero-i64 cg) (TInt 64 true)) (mut i) 0]
    (loop (if (or (icmp-ge (load i) n) (cg-terminated cg)) (break)
      (do (store! last (emit-expr cg (al-elem [Expr] body (load i)) scp))
          (store! i (iadd (load i) 1)))))
    (load last)))
; bind a let's bindings into a child scp.
(defn emit-binds [(cg (ptr Cg)) (binds (ptr (ArrayList Bind))) (scp (ptr Scope))] (-> (ptr Scope))
  (let [a (load (field cg a)) n (al-len [Bind] (load binds)) (mut s) scp (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [bp (al-elem [Bind] binds (load i)) tv (emit-expr cg (field bp value) (load s))]
            (store! s (scope-put a (load s) (load (field bp name)) (tv-val tv) (tv-ty tv))))
          (store! i (iadd (load i) 1)))))
    (load s)))

(defn emit-call [(cg (ptr Cg)) (func (slice u8)) (args (ptr (ArrayList Expr))) (scp (ptr Scope))] (-> Tv)
  (let [a (load (field cg a)) b (cg-bld cg)
        vals (emit-vals cg args scp)
        ret-ty (match (cg-ret cg func) (Some [t] t) (None [] (cg-bug-ty (sconcat a "codegen: unknown callable " func))))
        callee (cg-func cg func)]
    (if (icmp-eq (cast i64 callee) 0) (cg-bug (sconcat a "codegen: call to undefined " func))
      (if (icmp-ge (cg-sig-idx cg func) -2)   ; placeholder: no c-abi in corpus
        (let [meta (reconcile-args cg callee vals)
              cs (LLVMBuildCall2 b (LLVMGlobalGetValueType callee) callee (carr a meta) (cast i32 (al-len [(ptr i8)] meta)) (cg-bl cg "call"))]
          (LLVMSetInstructionCallConv cs (LLVMGetFunctionCallConv callee))
          (if (ty-is-void (box-type a ret-ty)) (mk-tv (cg-zero-i64 cg) (TVoid)) (mk-tv cs ret-ty)))
        (cg-bug "unreachable")))))
(defn cg-bug-ty [(msg (slice u8))] (-> Type) (unimplemented msg) (TInt 64 true))

(defn emit-field [(cg (ptr Cg)) (pe (ptr Expr)) (fname (slice u8)) (scp (ptr Scope))] (-> Tv)
  (let [a (load (field cg a)) b (cg-bld cg)
        pv (emit-expr cg pe scp)
        sname (match-else (tv-ty pv) (TPtr [pe2] (match-else (load pe2) (TStruct [s] s) (_ (cg-bug-sl "codegen: field on (ptr non-struct)")))) (_ (cg-bug-sl "codegen: field on non-pointer")))
        si (cg-struct-idx cg sname)]
    (if (icmp-lt si 0) (cg-bug (sconcat a "codegen: unknown struct " sname))
      (let [sp (al-elem [CgStruct] (field cg structs) si)
            fs (load (field sp fields)) nf (al-len [Field] (load fs)) (mut idx) -1 (mut i) 0]
        (loop (if (icmp-ge (load i) nf) (break)
          (do (if (str-eq (load (field (al-elem [Field] fs (load i)) name)) fname) (store! idx (load i)) 0)
              (store! i (iadd (load i) 1)))))
        (if (icmp-lt (load idx) 0) (cg-bug "codegen: no such field")
          (let [fty (load (field (al-elem [Field] fs (load idx)) ty))
                gep (match-else (load (field sp layout))
                      (LExplicit [offs sz al]
                        (let [(mut ix) (al-new [(ptr i8)] a)]
                          (al-push! (mut ix) (LLVMConstInt (cg-i64t cg) (al-get [i64] (load offs) (load idx)) 0))
                          (LLVMBuildGEP2 b (LLVMInt8TypeInContext (cg-ctx cg)) (tv-val pv) (carr a (load ix)) 1 (cg-bl cg "field"))))
                      (_ (LLVMBuildStructGEP2 b (load (field sp ty)) (tv-val pv) (cast i32 (load idx)) (cg-bl cg "field"))))]
            (mk-tv gep (TPtr (box-type a fty)))))))))
(defn cg-bug-sl [(msg (slice u8))] (-> (slice u8)) (unimplemented msg) "")

(defn emit-index [(cg (ptr Cg)) (pe (ptr Expr)) (idx (ptr Expr)) (scp (ptr Scope))] (-> Tv)
  (let [a (load (field cg a)) b (cg-bld cg)
        pv (emit-expr cg pe scp) iv (emit-expr cg idx scp)
        pointee (match-else (tv-ty pv) (TPtr [pe2] (load pe2)) (_ (do (unimplemented "codegen: index of non-pointer") (TInt 64 true))))]
    (match-else pointee
      (TArray [elem nn]
        (let [(mut ix) (al-new [(ptr i8)] a)]
          (al-push! (mut ix) (cg-zero-i64 cg)) (al-push! (mut ix) (tv-val iv))
          (mk-tv (LLVMBuildGEP2 b (basic-ty cg (box-type a pointee)) (tv-val pv) (carr a (load ix)) 2 (cg-bl cg "idx"))
                 (TPtr elem))))
      (_ (let [(mut ix) (al-new [(ptr i8)] a)]
           (al-push! (mut ix) (tv-val iv))
           (mk-tv (LLVMBuildGEP2 b (basic-ty cg (box-type a pointee)) (tv-val pv) (carr a (load ix)) 1 (cg-bl cg "idx"))
                  (TPtr (box-type a pointee))))))))

(defn emit-cast [(cg (ptr Cg)) (t (ptr Type)) (inner (ptr Expr)) (scp (ptr Scope))] (-> Tv)
  (let [a (load (field cg a)) b (cg-bld cg) ctx (cg-ctx cg)
        iv (emit-expr cg inner scp) v (tv-val iv) vt (tv-ty iv)
        v-is-ptr (match-else vt (TPtr [x] true) (_ false))
        v-is-float (match-else vt (TFloat [x] true) (_ false))
        v-is-int (match-else vt (TInt [x y] true) (_ false))
        v-signed (match-else vt (TInt [x s] s) (_ false))]
    (match-else (load t)
      (TInt [to s]
        (if v-is-ptr (mk-tv (LLVMBuildPtrToInt b v (int-width ctx to) (cg-bl cg "ptrtoint")) (load t))
          (if v-is-float (mk-tv (if s (LLVMBuildFPToSI b v (int-width ctx to) (cg-bl cg "fptosi")) (LLVMBuildFPToUI b v (int-width ctx to) (cg-bl cg "fptoui"))) (load t))
            (let [from (cg-int-bits vt)]
              (mk-tv (if (icmp-gt to from) (if v-signed (LLVMBuildSExt b v (int-width ctx to) (cg-bl cg "sext")) (LLVMBuildZExt b v (int-width ctx to) (cg-bl cg "zext")))
                     (if (icmp-lt to from) (LLVMBuildTrunc b v (int-width ctx to) (cg-bl cg "trunc")) v)) (load t))))))
      (TPtr [inner2]
        (if v-is-int (mk-tv (LLVMBuildIntToPtr b v (LLVMPointerTypeInContext ctx 0) (cg-bl cg "inttoptr")) (load t))
          (mk-tv v (load t))))
      (TFn [c p r] (mk-tv v (load t)))
      (TFloat [to]
        (let [ft (basic-ty cg t)]
          (if v-is-int (mk-tv (if v-signed (LLVMBuildSIToFP b v ft (cg-bl cg "sitofp")) (LLVMBuildUIToFP b v ft (cg-bl cg "uitofp"))) (load t))
            (if v-is-float (let [from (cg-float-bits vt)]
                             (mk-tv (if (icmp-gt to from) (LLVMBuildFPExt b v ft (cg-bl cg "fpext"))
                                    (if (icmp-lt to from) (LLVMBuildFPTrunc b v ft (cg-bl cg "fptrunc")) v)) (load t)))
              (cg-bug "codegen: cannot cast to float")))))
      (_ (cg-bug "codegen: cannot cast to this type")))))
(defn cg-int-bits [(t Type)] (-> i64) (match-else t (TInt [b s] b) (_ 64)))
(defn cg-float-bits [(t Type)] (-> i64) (match-else t (TFloat [b] b) (_ 64)))

; ======================== emit_construct / emit_match ========================
(defn emit-construct [(cg (ptr Cg)) (sum (slice u8)) (variant (slice u8)) (args (ptr (ArrayList Expr))) (scp (ptr Scope))] (-> Tv)
  (let [a (load (field cg a)) b (cg-bld cg) ui (cg-sum-idx cg sum)]
    (if (icmp-lt ui 0) (cg-bug (sconcat a "codegen: unknown sum " sum))
      (let [sp (al-elem [CgSum] (field cg sums) ui) vidx (cg-variant-idx cg sp variant)
            sum-ty (load (field sp ty)) var-struct (al-get [(ptr i8)] (load (field sp vstructs)) vidx)
            tmp (cg-entry-alloca cg sum-ty (cg-bl cg "sum.tmp"))
            tagptr (LLVMBuildStructGEP2 b sum-ty tmp 0 (cg-bl cg "tag"))]
        (LLVMBuildStore b (LLVMConstInt (cg-i32t cg) vidx 0) tagptr)
        (let [payload (LLVMBuildStructGEP2 b sum-ty tmp 1 (cg-bl cg "payload"))
              n (al-len [Expr] (load args)) (mut i) 0]
          (loop (if (icmp-ge (load i) n) (break)
            (do (let [vv (emit-expr cg (al-elem [Expr] args (load i)) scp)
                      fptr (LLVMBuildStructGEP2 b var-struct payload (cast i32 (load i)) (cg-bl cg "vf"))]
                  (LLVMBuildStore b (tv-val vv) fptr))
                (store! i (iadd (load i) 1)))))
          (mk-tv (LLVMBuildLoad2 b sum-ty tmp (cg-bl cg "sum")) (TStruct sum)))))))

(defn emit-match [(cg (ptr Cg)) (scrut (ptr Expr)) (arms (ptr (ArrayList Arm))) (scp (ptr Scope))] (-> Tv)
  (let [a (load (field cg a)) b (cg-bld cg)
        sv (emit-expr cg scrut scp)
        sumname (match-else (tv-ty sv) (TStruct [s] s) (_ (cg-bug-sl "codegen: match on non-sum")))
        ui (cg-sum-idx cg sumname)]
    (if (icmp-lt ui 0) (cg-bug (sconcat a "codegen: match on non-sum " sumname))
      (let [sp (al-elem [CgSum] (field cg sums) ui) sum-ty (load (field sp ty))
            tmp (cg-entry-alloca cg sum-ty (cg-bl cg "match.tmp"))]
        (LLVMBuildStore b (tv-val sv) tmp)
        (let [tagptr (LLVMBuildStructGEP2 b sum-ty tmp 0 (cg-bl cg "tag"))
              tag (LLVMBuildLoad2 b (cg-i32t cg) tagptr (cg-bl cg "tag"))
              payload (LLVMBuildStructGEP2 b sum-ty tmp 1 (cg-bl cg "payload"))
              func (cg-cur-func cg)
              narms (al-len [Arm] (load arms))
              (mut armbbs) (al-new [(ptr i8)] a) (mut k) 0]
          (loop (if (icmp-ge (load k) narms) (break)
            (do (al-push! (mut armbbs) (cg-append cg func (cg-bl cg "arm"))) (store! k (iadd (load k) 1)))))
          (let [default (cg-append cg func (cg-bl cg "match.default"))
                merge (cg-append cg func (cg-bl cg "match.end"))
                sw (LLVMBuildSwitch b tag default (cast i32 narms)) (mut k2) 0]
            (loop (if (icmp-ge (load k2) narms) (break)
              (do (let [ap (al-elem [Arm] arms (load k2)) vidx (cg-variant-idx cg sp (load (field ap variant)))]
                    (LLVMAddCase sw (LLVMConstInt (cg-i32t cg) vidx 0) (al-get [(ptr i8)] (load armbbs) (load k2))))
                  (store! k2 (iadd (load k2) 1)))))
            (cg-pos cg default) (LLVMBuildUnreachable b)
            ; emit arms; collect (value, end-block) for the merge phi.
            (let [(mut inc-vals) (al-new [(ptr i8)] a) (mut inc-bbs) (al-new [(ptr i8)] a)
                  (mut result-ty) (TInt 64 true) (mut k3) 0]
              (loop (if (icmp-ge (load k3) narms) (break)
                (do (cg-pos cg (al-get [(ptr i8)] (load armbbs) (load k3)))
                    (let [ap (al-elem [Arm] arms (load k3)) vidx (cg-variant-idx cg sp (load (field ap variant)))
                          var-struct (al-get [(ptr i8)] (load (field sp vstructs)) vidx)
                          vp (al-elem [Variant] (load (field sp variants)) vidx)
                          vfs (load (field vp fields))
                          binds (load (field ap binds)) nb (al-len [(slice u8)] (load binds))
                          (mut child) scp (mut j) 0]
                      (loop (if (icmp-ge (load j) nb) (break)
                        (do (let [fptr (LLVMBuildStructGEP2 b var-struct payload (cast i32 (load j)) (cg-bl cg "vf"))
                                  fty (load (field (al-elem [Field] vfs (load j)) ty))
                                  bname (al-get [(slice u8)] (load binds) (load j))
                                  fval (LLVMBuildLoad2 b (basic-ty cg (box-type a fty)) fptr (slice->cstr a bname))]
                              (store! child (scope-put a (load child) bname fval fty)))
                            (store! j (iadd (load j) 1)))))
                      (let [bv (emit-expr cg (field ap body) (load child))
                            endbb (cg-cur-block cg)]
                        (if (icmp-eq (cast i64 (LLVMGetBasicBlockTerminator endbb)) 0)
                            (do (store! result-ty (tv-ty bv))
                                (LLVMBuildBr b merge)
                                (al-push! (mut inc-vals) (tv-val bv)) (al-push! (mut inc-bbs) endbb))
                            0)))
                    (store! k3 (iadd (load k3) 1)))))
              (cg-pos cg merge)
              (if (icmp-eq (al-len [(ptr i8)] (load inc-vals)) 0)
                  (do (LLVMBuildUnreachable b) (mk-tv (cg-zero-i64 cg) (load result-ty)))
                (let [phi (LLVMBuildPhi b (basic-ty cg (box-type a (load result-ty))) (cg-bl cg "match.val"))]
                  (LLVMAddIncoming phi (carr a (load inc-vals)) (carr a (load inc-bbs)) (cast i32 (al-len [(ptr i8)] (load inc-vals))))
                  (mk-tv phi (load result-ty)))))))))))

; ======================== emit_alloc / bit access ============================
(defn emit-alloc [(cg (ptr Cg)) (storage i64) (t (ptr Type))] (-> Tv)
  (let [a (load (field cg a)) b (cg-bld cg) bt (basic-ty cg t)]
    (if (icmp-eq storage 0)
        (mk-tv (LLVMBuildAlloca b bt (cg-bl cg "stack.slot")) (TPtr (box-type a (load t))))
      (if (icmp-eq storage 2)
          (mk-tv (LLVMBuildMalloc b bt (cg-bl cg "heap.box")) (TPtr (box-type a (load t))))
        (let [n (cg-next-global cg) g (LLVMAddGlobal (load (field cg module)) bt (cg-gname cg "g." n))]
          (LLVMSetInitializer g (LLVMConstNull bt))
          (mk-tv g (TPtr (box-type a (load t)))))))))

; ======================== emit_if / loop / break / continue ==================
(defn emit-if [(cg (ptr Cg)) (cnd (ptr Expr)) (thn (ptr Expr)) (els (ptr Expr)) (scp (ptr Scope))] (-> Tv)
  (let [a (load (field cg a)) b (cg-bld cg)
        func (cg-cur-func cg)
        cv (emit-expr cg cnd scp) c (tv-val cv)
        cmp (LLVMBuildICmp b 33 c (cg-zero (LLVMTypeOf c)) (cg-bl cg "ifc"))
        then-bb (cg-append cg func (cg-bl cg "then"))
        else-bb (cg-append cg func (cg-bl cg "else"))]
    (LLVMBuildCondBr b cmp then-bb else-bb)
    (cg-pos cg then-bb)
    (let [tv (emit-expr cg thn scp) then-end (cg-cur-block cg)
          then-div (icmp-ne (cast i64 (LLVMGetBasicBlockTerminator then-end)) 0)]
      (cg-pos cg else-bb)
      (let [ev (emit-expr cg els scp) else-end (cg-cur-block cg)
            else-div (icmp-ne (cast i64 (LLVMGetBasicBlockTerminator else-end)) 0)]
        (if (and (not then-div) (not else-div))
            (let [merge-bb (cg-append cg func (cg-bl cg "ifcont"))]
              (cg-pos cg then-end) (LLVMBuildBr b merge-bb)
              (cg-pos cg else-end) (LLVMBuildBr b merge-bb)
              (cg-pos cg merge-bb)
              (let [phi (LLVMBuildPhi b (basic-ty cg (box-type a (tv-ty tv))) (cg-bl cg "ifval"))
                    (mut vs) (al-new [(ptr i8)] a) (mut bs) (al-new [(ptr i8)] a)]
                (al-push! (mut vs) (tv-val tv)) (al-push! (mut vs) (tv-val ev))
                (al-push! (mut bs) then-end) (al-push! (mut bs) else-end)
                (LLVMAddIncoming phi (carr a (load vs)) (carr a (load bs)) 2)
                (mk-tv phi (tv-ty tv))))
          (if (and (not then-div) else-div) (do (cg-pos cg then-end) tv)
            (if (and then-div (not else-div)) (do (cg-pos cg else-end) ev)
              (let [dead-bb (cg-append cg func (cg-bl cg "ifcont.dead"))]
                (cg-pos cg dead-bb) (LLVMBuildUnreachable b)
                (mk-tv (cg-zero-i64 cg) (tv-ty tv))))))))))

(defn emit-loop [(cg (ptr Cg)) (label (Option (slice u8))) (body (ptr (ArrayList Expr))) (scp (ptr Scope))] (-> Tv)
  (let [a (load (field cg a)) b (cg-bld cg) func (cg-cur-func cg)
        body-bb (cg-append cg func (cg-bl cg "loop.body"))
        after-bb (cg-append cg func (cg-bl cg "loop.after"))]
    (LLVMBuildBr b body-bb)
    (cg-pos cg body-bb)
    (let [lc (alloc-stack CgLoop)]
      (store! (field lc label) label) (store! (field lc body_bb) body-bb) (store! (field lc after_bb) after-bb)
      (store! (field lc breaks) (al-new [CgBreak] a)) (store! (field lc break_ty) (None [Type]))
      (al-push! (mut (field cg loops)) (load lc)))
    (let [n (al-len [Expr] (load body)) (mut i) 0]
      (loop (if (or (icmp-ge (load i) n) (cg-terminated cg)) (break)
        (do (emit-expr cg (al-elem [Expr] body (load i)) scp) (store! i (iadd (load i) 1))))))
    (if (not (cg-terminated cg)) (do (LLVMBuildBr b body-bb) 0) 0)
    (let [popped (match (al-pop! [CgLoop] (mut (field cg loops))) (Some [x] x) (None [] (do (unimplemented "loop ctx missing") (zeroed CgLoop))))
          lp (alloc-stack CgLoop)]
      (store! lp popped)
      (cg-pos cg after-bb)
      (let [nb (al-len [CgBreak] (load (field lp breaks)))]
        (if (icmp-eq nb 0)
            (do (LLVMBuildUnreachable b) (mk-tv (cg-zero-i64 cg) (TInt 64 true)))
          (let [ty (match (load (field lp break_ty)) (Some [t] t) (None [] (TInt 64 true)))
                phi (LLVMBuildPhi b (basic-ty cg (box-type a ty)) (cg-bl cg "loop.val"))
                (mut vs) (al-new [(ptr i8)] a) (mut bs) (al-new [(ptr i8)] a) (mut i) 0]
            (loop (if (icmp-ge (load i) nb) (break)
              (do (let [bp (al-elem [CgBreak] (field lp breaks) (load i))]
                    (al-push! (mut vs) (load (field bp val))) (al-push! (mut bs) (load (field bp bb))))
                  (store! i (iadd (load i) 1)))))
            (LLVMAddIncoming phi (carr a (load vs)) (carr a (load bs)) (cast i32 nb))
            (mk-tv phi ty)))))))

(defn cg-loop-index [(cg (ptr Cg)) (label (Option (slice u8)))] (-> i64)
  (let [n (al-len [CgLoop] (load (field cg loops)))]
    (match label
      (Some [l] (let [(mut r) -1 (mut i) 0]
                  (loop (if (icmp-ge (load i) n) (break)
                    (do (match (load (field (al-elem [CgLoop] (field cg loops) (load i)) label))
                          (Some [ll] (if (str-eq ll l) (store! r (load i)) 0))
                          (None [] 0))
                        (store! i (iadd (load i) 1)))))
                  (if (icmp-lt (load r) 0) (do (unimplemented "codegen: break/continue to unknown loop label") -1) (load r))))
      (None [] (if (icmp-eq n 0) (do (unimplemented "codegen: break/continue outside of a loop") -1) (isub n 1))))))

(defn emit-break [(cg (ptr Cg)) (label (Option (slice u8))) (value (Option (ptr Expr))) (scp (ptr Scope))] (-> Tv)
  (let [a (load (field cg a)) b (cg-bld cg)
        vtv (match value (Some [e] (emit-expr cg e scp)) (None [] (mk-tv (cg-zero-i64 cg) (TInt 64 true))))]
    (if (cg-terminated cg) (mk-tv (cg-zero-i64 cg) (TInt 64 true))
      (let [pred (cg-cur-block cg) idx (cg-loop-index cg label)
            lp (al-elem [CgLoop] (field cg loops) idx) site (alloc-stack CgBreak)]
        (store! (field site val) (tv-val vtv)) (store! (field site bb) pred)
        (al-push! (mut (field lp breaks)) (load site))
        (match (load (field lp break_ty)) (Some [x] 0) (None [] (do (store! (field lp break_ty) (Some [Type] (tv-ty vtv))) 0)))
        (LLVMBuildBr b (load (field lp after_bb)))
        (mk-tv (cg-zero-i64 cg) (TInt 64 true))))))

(defn emit-continue [(cg (ptr Cg)) (label (Option (slice u8)))] (-> Tv)
  (let [b (cg-bld cg) idx (cg-loop-index cg label)
        lp (al-elem [CgLoop] (field cg loops) idx)]
    (LLVMBuildBr b (load (field lp body_bb)))
    (mk-tv (cg-zero-i64 cg) (TInt 64 true))))

; ======================== bit access (BitGet/BitSet) =========================
(defstruct BitAcc [(pv (ptr i8)) (off i64) (width i64) (backing i64)])
(defn bit-access [(cg (ptr Cg)) (pe (ptr Expr)) (fname (slice u8)) (scp (ptr Scope))] (-> BitAcc)
  (let [a (load (field cg a)) pv (emit-expr cg pe scp)
        sname (match-else (tv-ty pv) (TPtr [p2] (match-else (load p2) (TStruct [s] s) (_ (cg-bug-sl "bit access on non-struct")))) (_ (cg-bug-sl "bit access on non-pointer")))
        si (cg-struct-idx cg sname) sp (al-elem [CgStruct] (field cg structs) si)
        fs (load (field sp fields)) nf (al-len [Field] (load fs)) (mut idx) -1 (mut i) 0
        r (alloc-stack BitAcc)]
    (loop (if (icmp-ge (load i) nf) (break)
      (do (if (str-eq (load (field (al-elem [Field] fs (load i)) name)) fname) (store! idx (load i)) 0)
          (store! i (iadd (load i) 1)))))
    (store! (field r pv) (tv-val pv))
    (store! (field r width) (match-else (load (field (al-elem [Field] fs (load idx)) ty)) (TInt [w s] w) (_ (do (unimplemented "bitfield not int") 0))))
    (match-else (load (field sp layout))
      (LBits [backing offs] (do (store! (field r backing) backing) (store! (field r off) (al-get [i64] (load offs) (load idx)))))
      (_ (do (unimplemented "codegen: not a bit struct") 0)))
    (load r)))
(defn emit-bitget [(cg (ptr Cg)) (pe (ptr Expr)) (fname (slice u8)) (scp (ptr Scope))] (-> Tv)
  (let [b (cg-bld cg) ctx (cg-ctx cg) ba (alloc-stack BitAcc)]
    (store! ba (bit-access cg pe fname scp))
    (let [backing-ty (int-width ctx (load (field ba backing)))
          loaded (LLVMBuildLoad2 b backing-ty (load (field ba pv)) (cg-bl cg "bits"))
          off (load (field ba off)) width (load (field ba width))
          shifted (if (icmp-gt off 0) (LLVMBuildLShr b loaded (LLVMConstInt backing-ty off 0) (cg-bl cg "shr")) loaded)
          field-ty (int-width ctx width)
          res (if (icmp-lt width (load (field ba backing))) (LLVMBuildTrunc b shifted field-ty (cg-bl cg "bget")) shifted)]
      (mk-tv res (TInt width false)))))
(defn emit-bitset [(cg (ptr Cg)) (pe (ptr Expr)) (fname (slice u8)) (val (ptr Expr)) (scp (ptr Scope))] (-> Tv)
  (let [b (cg-bld cg) ctx (cg-ctx cg) ba (alloc-stack BitAcc)]
    (store! ba (bit-access cg pe fname scp))
    (let [vv (emit-expr cg val scp)
          backing (load (field ba backing)) off (load (field ba off)) width (load (field ba width))
          backing-ty (int-width ctx backing)
          loaded (LLVMBuildLoad2 b backing-ty (load (field ba pv)) (cg-bl cg "bits"))
          field-mask (ishl (isub (ishl 1 width) 1) off)
          clear (LLVMConstInt backing-ty (ixor field-mask -1) 0)
          cleared (LLVMBuildAnd b loaded clear (cg-bl cg "clear"))
          vext (if (icmp-lt width backing) (LLVMBuildZExt b (tv-val vv) backing-ty (cg-bl cg "vext")) (tv-val vv))
          vshift (if (icmp-gt off 0) (LLVMBuildShl b vext (LLVMConstInt backing-ty off 0) (cg-bl cg "vshl")) vext)
          newval (LLVMBuildOr b cleared vshift (cg-bl cg "set"))]
      (LLVMBuildStore b newval (load (field ba pv)))
      (mk-tv (tv-val vv) (TInt width false)))))

; ======================== fnptr-of / call-ptr / llvm-ir ======================
(defn emit-fnptr [(cg (ptr Cg)) (name (slice u8))] (-> Tv)
  (let [a (load (field cg a)) fv (cg-func cg name)]
    (if (icmp-eq (cast i64 fv) 0) (cg-bug (sconcat a "codegen: fnptr-of unknown " name))
      (let [si (cg-sig-idx cg name)]
        (if (icmp-lt si 0) (cg-bug (sconcat a "codegen: no signature for " name))
          (let [sp (al-elem [CgSig] (field cg sigs) si)]
            (mk-tv fv (TFn (load (field sp cc)) (load (field sp params)) (box-type a (load (field sp ret)))))))))))
(defn emit-callptr [(cg (ptr Cg)) (fp (ptr Expr)) (args (ptr (ArrayList Expr))) (scp (ptr Scope))] (-> Tv)
  (let [a (load (field cg a)) b (cg-bld cg)
        fpv (emit-expr cg fp scp)
        cc-params-ret (match-else (tv-ty fpv) (TFn [c p r] (mk-fnsig c p r)) (_ (do (unimplemented "codegen: call-ptr on non-fnptr") (mk-fnsig "" (box-al [Type] a (al-new [Type] a)) (box-type a (TInt 64 true))))))
        fnty (cg-fn-type cg (fnsig-params cc-params-ret) (fnsig-ret cc-params-ret))
        vals (emit-vals cg args scp)
        cs (LLVMBuildCall2 b fnty (tv-val fpv) (carr a vals) (cast i32 (al-len [(ptr i8)] vals)) (cg-bl cg "callptr"))]
    (mk-tv cs (load (fnsig-ret cc-params-ret)))))
(defstruct FnSig [(cc (slice u8)) (params (ptr (ArrayList Type))) (ret (ptr Type))])
(defn mk-fnsig [(c (slice u8)) (p (ptr (ArrayList Type))) (r (ptr Type))] (-> FnSig)
  (let [x (alloc-stack FnSig)] (store! (field x cc) c) (store! (field x params) p) (store! (field x ret) r) (load x)))
(defn fnsig-params [(s FnSig)] (-> (ptr (ArrayList Type))) (let [x (alloc-stack FnSig)] (store! x s) (load (field x params))))
(defn fnsig-ret [(s FnSig)] (-> (ptr Type)) (let [x (alloc-stack FnSig)] (store! x s) (load (field x ret))))

(defn emit-llvm-ir [(cg (ptr Cg)) (result (ptr Type)) (args (ptr (ArrayList Expr))) (body (slice u8)) (scp (ptr Scope))] (-> Tv)
  (let [a (load (field cg a)) b (cg-bld cg)
        argtv (emit-arg-tvs cg args scp)
        nargs (al-len [Tv] (load argtv))
        ret-str (cstr->slice (LLVMPrintTypeToString (basic-ty cg result)))
        ; substitute placeholders, highest index first.
        (mut text) body (mut i) (isub nargs 1)]
    (loop (if (icmp-lt (load i) 0) (break)
      (do (let [argstr (cstr->slice (LLVMPrintTypeToString (basic-ty cg (box-type a (tv-ty (al-get [Tv] (load argtv) (load i)))))))]
            (store! text (str-replace-all a (load text) (sconcat a "$t" (i64->str a (load i))) argstr))
            (store! text (str-replace-all a (load text) (sconcat a "$" (i64->str a (load i))) (sconcat a "%" (i64->str a (load i))))))
          (store! i (isub (load i) 1)))))
    (store! text (str-replace-all a (load text) "$ret" ret-str))
    ; hoist `declare` lines; build the helper module text.
    (let [lines (nz-split-lines a (load text)) nl (al-len [(slice u8)] lines)
          (mut decls) (sb-new a) (mut fnbody) (sb-new a) (mut j) 0]
      (loop (if (icmp-ge (load j) nl) (break)
        (do (let [ln (al-get [(slice u8)] lines (load j))]
              (if (starts-with (str-ltrim ln) "declare")
                  (do (sb-push-str! (mut decls) ln) (sb-push-byte! (mut decls) 10))
                  (do (sb-push-str! (mut fnbody) ln) (sb-push-byte! (mut fnbody) 10))))
            (store! j (iadd (load j) 1)))))
      (let [seq (load (field cg llvm_seq))]
        (store! (field cg llvm_seq) (iadd seq 1))
        (let [name (sconcat a "__coil_llvm_ir_" (i64->str a seq))
              (mut params) (sb-new a) (mut k) 0]
          (loop (if (icmp-ge (load k) nargs) (break)
            (do (if (icmp-gt (load k) 0) (sb-push-str! (mut params) ", ") 0)
                (let [argstr (cstr->slice (LLVMPrintTypeToString (basic-ty cg (box-type a (tv-ty (al-get [Tv] (load argtv) (load k)))))))]
                  (sb-push-str! (mut params) argstr) (sb-push-str! (mut params) " %") (sb-push-str! (mut params) (i64->str a (load k))))
                (store! k (iadd (load k) 1)))))
          (let [(mut mt) (sb-new a)]
            (sb-push-str! (mut mt) (sb-str (load decls)))
            (sb-push-str! (mut mt) "define ") (sb-push-str! (mut mt) ret-str) (sb-push-str! (mut mt) " @")
            (sb-push-str! (mut mt) name) (sb-push-str! (mut mt) "(") (sb-push-str! (mut mt) (sb-str (load params)))
            (sb-push-str! (mut mt) ") alwaysinline {\n") (sb-push-str! (mut mt) (sb-str (load fnbody))) (sb-push-str! (mut mt) "}\n")
            (let [mtext (sb-str (load mt))
                  membuf (LLVMCreateMemoryBufferWithMemoryRangeCopy (cast (ptr i8) (slice-data [u8] mtext)) (slice-len mtext) (cg-bl cg "coil_llvm_ir"))
                  modout (alloc-stack (ptr i8)) errout (alloc-stack (ptr i8))]
              (if (icmp-ne (LLVMParseIRInContext (cg-ctx cg) membuf modout errout) 0)
                  (do (unimplemented "llvm-ir: could not parse IR") (mk-tv (cast (ptr i8) 0) (load result)))
                (let [helper (load modout)]
                  (LLVMSetTarget helper (LLVMGetTarget (load (field cg module))))
                  (LLVMSetDataLayout helper (LLVMGetDataLayoutStr (load (field cg module))))
                  (LLVMLinkModules2 (load (field cg module)) helper)
                  (let [callee (LLVMGetNamedFunction (load (field cg module)) (slice->cstr a name))]
                    (LLVMSetLinkage callee 8)
                    (let [(mut vs) (al-new [(ptr i8)] a) (mut q) 0]
                      (loop (if (icmp-ge (load q) nargs) (break)
                        (do (al-push! (mut vs) (tv-val (al-get [Tv] (load argtv) (load q)))) (store! q (iadd (load q) 1)))))
                      (mk-tv (LLVMBuildCall2 b (LLVMGlobalGetValueType callee) callee (carr a (load vs)) (cast i32 nargs) (cg-bl cg "llvmir")) (load result)))))))))))))
(defn emit-arg-tvs [(cg (ptr Cg)) (es (ptr (ArrayList Expr))) (scp (ptr Scope))] (-> (ArrayList Tv))
  (let [n (al-len [Expr] (load es)) (mut out) (al-new [Tv] (load (field cg a))) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut out) (emit-expr cg (al-elem [Expr] es (load i)) scp)) (store! i (iadd (load i) 1)))))
    (load out)))
(defn str-ltrim [(s (slice u8))] (-> (slice u8))
  (let [n (slice-len s) (mut i) 0]
    (loop (if (or (icmp-ge (load i) n) (icmp-ne (cast i64 (slice-get s (load i))) 32)) (break)
      (store! i (iadd (load i) 1))))
    (substr s (load i) n)))

; ======================== emit_func / emit_tail ==============================
(defn emit-c-return [(cg (ptr Cg)) (ret (ptr Type)) (last Tv)] (-> i64)
  (let [b (cg-bld cg)]
    (if (ty-is-void ret) (do (LLVMBuildRetVoid b) 0) (do (LLVMBuildRet b (tv-val last)) 0))))
(defn tail-call-ok [(cg (ptr Cg)) (func (slice u8)) (function (ptr i8))] (-> bool)
  (and (icmp-eq (cast i64 (cg-func cg func)) (cast i64 function)) (icmp-lt (cg-sig-idx cg func) 999999999)))
(defn emit-tail [(cg (ptr Cg)) (e (ptr Expr)) (function (ptr i8)) (ret (ptr Type)) (scp (ptr Scope))] (-> i64)
  (let [a (load (field cg a)) b (cg-bld cg)]
    (match-else (load (field e kind))
      (EDo [body]
        (let [n (al-len [Expr] (load body))]
          (if (icmp-eq n 0) (emit-c-return cg ret (mk-tv (cg-zero-i64 cg) (TInt 64 true)))
            (let [(mut i) 0]
              (loop (if (or (icmp-ge (load i) (isub n 1)) (cg-terminated cg)) (break)
                (do (emit-expr cg (al-elem [Expr] body (load i)) scp) (store! i (iadd (load i) 1)))))
              (if (not (cg-terminated cg)) (emit-tail cg (al-elem [Expr] body (isub n 1)) function ret scp) 0)))))
      (ELet [binds body]
        (let [child (emit-binds cg binds scp) n (al-len [Expr] (load body))]
          (if (icmp-eq n 0) 0
            (let [(mut i) 0]
              (loop (if (or (icmp-ge (load i) (isub n 1)) (cg-terminated cg)) (break)
                (do (emit-expr cg (al-elem [Expr] body (load i)) child) (store! i (iadd (load i) 1)))))
              (if (not (cg-terminated cg)) (emit-tail cg (al-elem [Expr] body (isub n 1)) function ret child) 0)))))
      (EIf [cnd thn els]
        (let [cv (emit-expr cg cnd scp) c (tv-val cv)
              cmp (LLVMBuildICmp b 33 c (cg-zero (LLVMTypeOf c)) (cg-bl cg "ifc"))
              then-bb (cg-append cg function (cg-bl cg "then")) else-bb (cg-append cg function (cg-bl cg "else"))]
          (LLVMBuildCondBr b cmp then-bb else-bb)
          (cg-pos cg then-bb) (emit-tail cg thn function ret scp)
          (cg-pos cg else-bb) (emit-tail cg els function ret scp)))
      (ECall [func targs args]
        (if (tail-call-ok cg func function)
            (let [vals (emit-vals cg args scp) callee (cg-func cg func)
                  cs (LLVMBuildCall2 b (LLVMGlobalGetValueType callee) callee (carr a vals) (cast i32 (al-len [(ptr i8)] vals)) (cg-bl cg "tailcall"))]
              (LLVMSetInstructionCallConv cs (LLVMGetFunctionCallConv callee))
              (LLVMSetTailCallKind cs 2)
              (if (ty-is-void ret) (do (LLVMBuildRetVoid b) 0) (do (LLVMBuildRet b cs) 0)))
          (let [v (emit-expr cg e scp)] (if (not (cg-terminated cg)) (emit-c-return cg ret v) 0))))
      (EMatch [scrut arms] (emit-tail-match cg scrut arms function ret scp))
      (_ (let [v (emit-expr cg e scp)] (if (not (cg-terminated cg)) (emit-c-return cg ret v) 0))))))
(defn emit-tail-match [(cg (ptr Cg)) (scrut (ptr Expr)) (arms (ptr (ArrayList Arm))) (function (ptr i8)) (ret (ptr Type)) (scp (ptr Scope))] (-> i64)
  (let [a (load (field cg a)) b (cg-bld cg)
        sv (emit-expr cg scrut scp)
        sumname (match-else (tv-ty sv) (TStruct [s] s) (_ (cg-bug-sl "codegen: match on non-sum")))
        ui (cg-sum-idx cg sumname) sp (al-elem [CgSum] (field cg sums) ui) sum-ty (load (field sp ty))
        tmp (cg-entry-alloca cg sum-ty (cg-bl cg "match.tmp"))]
    (LLVMBuildStore b (tv-val sv) tmp)
    (let [tagptr (LLVMBuildStructGEP2 b sum-ty tmp 0 (cg-bl cg "tag"))
          tag (LLVMBuildLoad2 b (cg-i32t cg) tagptr (cg-bl cg "tag"))
          payload (LLVMBuildStructGEP2 b sum-ty tmp 1 (cg-bl cg "payload"))
          narms (al-len [Arm] (load arms)) (mut armbbs) (al-new [(ptr i8)] a) (mut k) 0]
      (loop (if (icmp-ge (load k) narms) (break)
        (do (al-push! (mut armbbs) (cg-append cg function (cg-bl cg "arm"))) (store! k (iadd (load k) 1)))))
      (let [default (cg-append cg function (cg-bl cg "match.default")) (mut k2) 0
            sw (LLVMBuildSwitch b tag default (cast i32 narms))]
        (loop (if (icmp-ge (load k2) narms) (break)
          (do (let [ap (al-elem [Arm] arms (load k2)) vidx (cg-variant-idx cg sp (load (field ap variant)))]
                (LLVMAddCase sw (LLVMConstInt (cg-i32t cg) vidx 0) (al-get [(ptr i8)] (load armbbs) (load k2))))
              (store! k2 (iadd (load k2) 1)))))
        (cg-pos cg default) (LLVMBuildUnreachable b)
        (let [(mut k3) 0]
          (loop (if (icmp-ge (load k3) narms) (break)
            (do (cg-pos cg (al-get [(ptr i8)] (load armbbs) (load k3)))
                (let [ap (al-elem [Arm] arms (load k3)) vidx (cg-variant-idx cg sp (load (field ap variant)))
                      var-struct (al-get [(ptr i8)] (load (field sp vstructs)) vidx)
                      vp (al-elem [Variant] (load (field sp variants)) vidx) vfs (load (field vp fields))
                      binds (load (field ap binds)) nb (al-len [(slice u8)] (load binds)) (mut child) scp (mut j) 0]
                  (loop (if (icmp-ge (load j) nb) (break)
                    (do (let [fptr (LLVMBuildStructGEP2 b var-struct payload (cast i32 (load j)) (cg-bl cg "vf"))
                              fty (load (field (al-elem [Field] vfs (load j)) ty))
                              bname (al-get [(slice u8)] (load binds) (load j))
                              fval (LLVMBuildLoad2 b (basic-ty cg (box-type a fty)) fptr (slice->cstr a bname))]
                          (store! child (scope-put a (load child) bname fval fty)))
                        (store! j (iadd (load j) 1)))))
                  (emit-tail cg (field ap body) function ret (load child)))
                (store! k3 (iadd (load k3) 1)))))
          0)))))

(defn emit-func [(cg (ptr Cg)) (f (ptr Func)) (function (ptr i8))] (-> i64)
  (let [a (load (field cg a)) b (cg-bld cg)
        entry (cg-append cg function (cg-bl cg "entry"))]
    (cg-pos cg entry)
    (let [params (load (field f params)) np (al-len [Param] (load params))
          (mut scp) (scope-nil a) (mut i) 0]
      (loop (if (icmp-ge (load i) np) (break)
        (do (let [pp (al-elem [Param] params (load i)) pname (load (field pp name))
                  v (LLVMGetParam function (cast i32 (load i)))]
              (LLVMSetValueName2 v (slice->cstr a pname) (slice-len pname))
              (store! scp (scope-put a (load scp) pname v (load (field pp ty)))))
            (store! i (iadd (load i) 1)))))
      (let [body (load (field f body)) nb (al-len [Expr] (load body))]
        (if (icmp-eq nb 0)
            (if (not (cg-terminated cg)) (emit-c-return cg (field f ret) (mk-tv (cg-zero-i64 cg) (TInt 64 true))) 0)
          (let [(mut j) 0]
            (loop (if (or (icmp-ge (load j) (isub nb 1)) (cg-terminated cg)) (break)
              (do (emit-expr cg (al-elem [Expr] body (load j)) (load scp)) (store! j (iadd (load j) 1)))))
            (if (not (cg-terminated cg)) (emit-tail cg (al-elem [Expr] body (isub nb 1)) function (field f ret) (load scp)) 0))))))
  0)

; ======================== the module driver (compile_for_dbg, dbg=None) ======
(defn codegen-module [(a (ptr Allocator)) (p (ptr Program))] (-> (ptr i8))
  (let [ctx (LLVMContextCreate)]
    ; init targets so an arbitrary host triple resolves.
    (LLVMInitializeAArch64TargetInfo) (LLVMInitializeAArch64Target) (LLVMInitializeAArch64TargetMC)
    (LLVMInitializeX86TargetInfo) (LLVMInitializeX86Target) (LLVMInitializeX86TargetMC)
    (let [triple (LLVMGetDefaultTargetTriple)
          targetout (alloc-stack (ptr i8)) errout (alloc-stack (ptr i8))]
      (LLVMGetTargetFromTriple triple targetout errout)
      (let [tm (LLVMCreateTargetMachine (load targetout) triple c"generic" c"" 2 2 0)
            td (LLVMCreateTargetDataLayout tm)
            dl (LLVMCopyStringRepOfTargetData td)
            module (LLVMModuleCreateWithNameInContext c"coil" ctx)
            builder (LLVMCreateBuilderInContext ctx)
            cgp (alloc-stack Cg)]
        (LLVMSetTarget module triple)
        (LLVMSetDataLayout module dl)
        (store! (field cgp ctx) ctx) (store! (field cgp module) module) (store! (field cgp builder) builder) (store! (field cgp td) td)
        (store! (field cgp structs) (al-new [CgStruct] a)) (store! (field cgp sums) (al-new [CgSum] a))
        (store! (field cgp funcs) (al-new [CgFunc] a)) (store! (field cgp rets) (al-new [CgRet] a)) (store! (field cgp sigs) (al-new [CgSig] a))
        (store! (field cgp statics) (al-new [CgStatic] a))
        (store! (field cgp globals) 0) (store! (field cgp llvm_seq) 0)
        (store! (field cgp loops) (al-new [CgLoop] a)) (store! (field cgp a) a)
        (cg-register-types cgp p)
        (cg-eval-asserts cgp p)
        (cg-declare-externs cgp p)
        (cg-declare-funcs cgp p)
        (cg-emit-bodies cgp p)
        module))))

; 0a-0d: two-phase type registration.
(defn cg-register-types [(cg (ptr Cg)) (p (ptr Program))] (-> i64)
  (let [ctx (cg-ctx cg)
        ss (load (field p structs)) ns (al-len [StructDef] (load ss))
        us (load (field p sums)) nu (al-len [SumDef] (load us)) (mut i) 0]
    ; 0a. opaque struct names.
    (loop (if (icmp-ge (load i) ns) (break)
      (do (let [sd (al-elem [StructDef] ss (load i)) nm (load (field sd name))
                ty (LLVMStructCreateNamed ctx (slice->cstr (load (field cg a)) nm))
                cs (alloc-stack CgStruct)]
            (store! (field cs name) nm) (store! (field cs fields) (load (field sd fields)))
            (store! (field cs ty) ty) (store! (field cs layout) (load (field sd layout)))
            (al-push! (mut (field cg structs)) (load cs)))
          (store! i (iadd (load i) 1)))))
    ; 0a2. register ALL sum names (opaque) + their variants FIRST, so type sizing
    ;      (sum_words) can size a sum that references a not-yet-bodied sum/struct —
    ;      Rust sizes from the whole-program def maps, independent of build order.
    (store! i 0)
    (loop (if (icmp-ge (load i) nu) (break)
      (do (let [sd (al-elem [SumDef] us (load i)) nm (load (field sd name))
                ty (LLVMStructCreateNamed ctx (slice->cstr (load (field cg a)) nm))
                cs (alloc-stack CgSum)]
            (store! (field cs name) nm) (store! (field cs variants) (load (field sd variants)))
            (store! (field cs ty) ty)
            (store! (field cs vstructs) (let [bp (unwrap-ptr [(ArrayList (ptr i8))] (create [(ArrayList (ptr i8))] (load (field cg a))))] (store! bp (al-new [(ptr i8)] (load (field cg a)))) bp))
            (al-push! (mut (field cg sums)) (load cs)))
          (store! i (iadd (load i) 1)))))
    ; 0b. set each sum's body { i32 tag, [words x i64] payload }.
    (store! i 0)
    (loop (if (icmp-ge (load i) nu) (break)
      (do (let [sd (al-elem [SumDef] us (load i))
                words (cg-sum-words-def cg sd)
                payload (LLVMArrayType2 (cg-i64t cg) words)
                ty (load (field (al-elem [CgSum] (field cg sums) (cg-sum-idx cg (load (field sd name)))) ty))
                (mut bs) (al-new [(ptr i8)] (load (field cg a)))]
            (al-push! (mut bs) (cg-i32t cg)) (al-push! (mut bs) payload)
            (LLVMStructSetBody ty (carr (load (field cg a)) (load bs)) 2 0))
          (store! i (iadd (load i) 1)))))
    ; 0c. struct bodies.
    (store! i 0)
    (loop (if (icmp-ge (load i) ns) (break)
      (do (cg-set-struct-body cg (al-elem [StructDef] ss (load i)))
          (store! i (iadd (load i) 1)))))
    ; 0d. per-variant field structs.
    (store! i 0)
    (loop (if (icmp-ge (load i) nu) (break)
      (do (cg-fill-variant-structs cg (al-elem [SumDef] us (load i)) (load i))
          (store! i (iadd (load i) 1)))))
    0))
(defn cg-set-struct-body [(cg (ptr Cg)) (sd (ptr StructDef))] (-> i64)
  (let [a (load (field cg a)) ctx (cg-ctx cg) si (cg-struct-idx cg (load (field sd name)))
        sp (al-elem [CgStruct] (field cg structs) si) ty (load (field sp ty))
        fs (load (field sd fields)) nf (al-len [Field] (load fs))]
    (match-else (load (field sd layout))
      (LBits [backing offs] (let [(mut bs) (al-new [(ptr i8)] a)] (al-push! (mut bs) (int-width ctx backing)) (LLVMStructSetBody ty (carr a (load bs)) 1 0) 0))
      (LExplicit [offs sz al]
        (let [(mut computed) 0 (mut i) 0]
          (loop (if (icmp-ge (load i) nf) (break)
            (do (let [off (al-get [i64] (load offs) (load i))
                      fsz (LLVMABISizeOfType (load (field cg td)) (basic-ty cg (field (al-elem [Field] fs (load i)) ty)))]
                  (if (icmp-gt (iadd off fsz) (load computed)) (store! computed (iadd off fsz)) 0))
                (store! i (iadd (load i) 1)))))
          (let [size (match sz (Some [s] (if (icmp-gt s (load computed)) s (load computed))) (None [] (load computed)))
                (mut bs) (al-new [(ptr i8)] a)]
            (al-push! (mut bs) (LLVMArrayType2 (LLVMInt8TypeInContext ctx) size))
            (LLVMStructSetBody ty (carr a (load bs)) 1 1) 0)))
      (_ (let [(mut bs) (al-new [(ptr i8)] a) (mut i) 0
               packed (match-else (load (field sd layout)) (LPacked [] 1) (_ 0))]
           (loop (if (icmp-ge (load i) nf) (break)
             (do (al-push! (mut bs) (basic-ty cg (field (al-elem [Field] fs (load i)) ty))) (store! i (iadd (load i) 1)))))
           (LLVMStructSetBody ty (carr a (load bs)) (cast i32 nf) (cast i32 packed)) 0)))))
(defn cg-fill-variant-structs [(cg (ptr Cg)) (sd (ptr SumDef)) (ui i64)] (-> i64)
  (let [a (load (field cg a)) ctx (cg-ctx cg)
        sp (al-elem [CgSum] (field cg sums) (cg-sum-idx cg (load (field sd name))))
        vs (load (field sd variants)) nv (al-len [Variant] (load vs)) (mut i) 0]
    (loop (if (icmp-ge (load i) nv) (break)
      (do (let [vp (al-elem [Variant] vs (load i)) fs (load (field vp fields)) nf (al-len [Field] (load fs))
                (mut bs) (al-new [(ptr i8)] a) (mut j) 0]
            (loop (if (icmp-ge (load j) nf) (break)
              (do (al-push! (mut bs) (basic-ty cg (field (al-elem [Field] fs (load j)) ty))) (store! j (iadd (load j) 1)))))
            (al-push! (mut (load (field sp vstructs))) (LLVMStructTypeInContext ctx (carr a (load bs)) (cast i32 nf) 0)))
          (store! i (iadd (load i) 1)))))
    0))

; 0e: static asserts.
(defn cg-eval-asserts [(cg (ptr Cg)) (p (ptr Program))] (-> i64)
  (let [as (load (field p asserts)) n (al-len [StaticAssert] (load as)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [ap (al-elem [StaticAssert] as (load i))]
            (if (icmp-eq (const-eval cg (field ap cnd)) 0) (do (unimplemented "static assertion failed") 0) 0))
          (store! i (iadd (load i) 1)))))
    0))

; helper: store a (name -> Type) into a CgRet list and (name cc params ret) into sigs.
(defn cg-record-callable [(cg (ptr Cg)) (name (slice u8)) (cc (slice u8)) (params (ptr (ArrayList Type))) (ret Type)] (-> i64)
  (let [r (alloc-stack CgRet)] (store! (field r name) name) (store! (field r ty) ret) (al-push! (mut (field cg rets)) (load r)))
  (let [s (alloc-stack CgSig)] (store! (field s name) name) (store! (field s cc) cc) (store! (field s params) params) (store! (field s ret) ret) (al-push! (mut (field cg sigs)) (load s)))
  0)
(defn cg-add-func [(cg (ptr Cg)) (name (slice u8)) (fv (ptr i8))] (-> i64)
  (let [r (alloc-stack CgFunc)] (store! (field r name) name) (store! (field r val) fv) (al-push! (mut (field cg funcs)) (load r))) 0)

; the last `.`-separated component of a qualified name (the link/C symbol).
(defn last-component [(s (slice u8))] (-> (slice u8))
  (let [n (slice-len s) (mut i) (isub n 1) (mut start) 0]
    (loop (if (icmp-lt (load i) 0) (break)
      (if (icmp-eq (cast i64 (slice-get s (load i))) 46) (do (store! start (iadd (load i) 1)) (store! i -1)) (store! i (isub (load i) 1)))))
    (substr s (load start) n)))
(defn ty-list-has-struct [(cg (ptr Cg)) (l (ptr (ArrayList Type)))] (-> bool)
  (let [n (al-len [Type] (load l)) (mut i) 0 (mut r) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (cg-abi-struct? cg (al-elem [Type] l (load i))) (do (store! r true) 0) 0) (store! i (iadd (load i) 1)))))
    (load r)))
(defn cg-abi-struct? [(cg (ptr Cg)) (t (ptr Type))] (-> bool)
  (match-else (load t)
    (TStruct [nm] (let [si (cg-struct-idx cg nm)] (if (icmp-lt si 0) false (match-else (load (field (al-elem [CgStruct] (field cg structs) si) layout)) (LBits [b o] false) (_ true)))))
    (_ false)))

; 1a: declare externs.
(defn cg-declare-externs [(cg (ptr Cg)) (p (ptr Program))] (-> i64)
  (let [a (load (field cg a)) es (load (field p externs)) n (al-len [Extern] (load es)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [ep (al-elem [Extern] es (load i)) ename (load (field ep name))
                params (load (field ep params)) ret (load (field ep ret))
                csym (last-component ename)]
            (if (or (cg-abi-struct? cg (box-type a ret)) (ty-list-has-struct cg params))
                (do (unimplemented "codegen: struct-by-value C ABI extern (abi.rs deferred)") 0)
              (let [existing (LLVMGetNamedFunction (load (field cg module)) (slice->cstr a csym))
                    fv (if (icmp-ne (cast i64 existing) 0) existing
                         (let [fnty (cg-fn-type cg params (box-type a ret))
                               nf (LLVMAddFunction (load (field cg module)) (slice->cstr a csym) fnty)]
                           (LLVMSetFunctionCallConv nf 0) nf))]
                (cg-add-func cg ename fv)
                (cg-record-callable cg ename (load (field ep cc)) params ret))))
          (store! i (iadd (load i) 1)))))
    0))

; 1b: declare functions (native path only; no shims/exports in corpus).
(defn cg-has-anchor [(p (ptr Program))] (-> bool)
  (let [fs (load (field p funcs)) n (al-len [Func] (load fs)) (mut i) 0 (mut r) false]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [Func] fs (load i)) name)) "main") (do (store! r true) 0) 0) (store! i (iadd (load i) 1)))))
    (or (load r) (icmp-gt (al-len [ExportC] (load (field p exports))) 0))))
(defn cg-declare-funcs [(cg (ptr Cg)) (p (ptr Program))] (-> i64)
  (let [a (load (field cg a)) fs (load (field p funcs)) n (al-len [Func] (load fs))
        anchor (cg-has-anchor p) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [fp (al-elem [Func] fs (load i)) fname (load (field fp name))
                fparams (cg-param-types cg (load (field fp params))) ret (load (field fp ret))]
            (cg-record-callable cg fname (load (field fp cc)) fparams ret)
            (if (or (cg-abi-struct? cg (box-type a ret)) (ty-list-has-struct cg fparams))
                (do (unimplemented "codegen: struct-by-value C ABI function (abi.rs deferred)") 0)
              (let [fnty (cg-fn-type cg fparams (box-type a ret))
                    fv (LLVMAddFunction (load (field cg module)) (slice->cstr a fname) fnty)]
                (LLVMSetFunctionCallConv fv 0)
                (if (not (or (str-eq fname "main") (not anchor))) (do (LLVMSetLinkage fv 8) 0) 0)
                (cg-add-func cg fname fv))))
          (store! i (iadd (load i) 1)))))
    0))
(defn cg-param-types [(cg (ptr Cg)) (params (ptr (ArrayList Param)))] (-> (ptr (ArrayList Type)))
  (let [a (load (field cg a)) n (al-len [Param] (load params)) (mut out) (al-new [Type] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (al-push! (mut out) (load (field (al-elem [Param] params (load i)) ty))) (store! i (iadd (load i) 1)))))
    (box-al [Type] a (load out))))

; 2: emit bodies.
(defn cg-emit-bodies [(cg (ptr Cg)) (p (ptr Program))] (-> i64)
  (let [fs (load (field p funcs)) n (al-len [Func] (load fs)) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
      (do (let [fp (al-elem [Func] fs (load i))]
            (emit-func cg fp (cg-func cg (load (field fp name)))))
          (store! i (iadd (load i) 1)))))
    0))

; ===== Port of src/normalize_ir.rs — cancels codegen's run-to-run nondeterminism
; so the self-host's LLVMPrintModuleToString text matches the normalized reference.
; Faithful, function-for-function port. Families: 0=g 1=str 2=cstr 3=llvmir.
; Categories: 0=type 1=global 2=declare 3=define 4=misc.

(defstruct NumRes  [(val i64) (len i64)])
(defstruct ScanRes [(fam i64) (num i64) (endd i64)])
(defstruct NzBlock [(cat i64) (name (slice u8)) (body (ArrayList (slice u8)))])
(defstruct NzParsed [(header (ArrayList (slice u8))) (blocks (ArrayList NzBlock))])
(defstruct Renum   [(g (ArrayList i64)) (st (ArrayList i64)) (cs (ArrayList i64)) (lv (ArrayList i64))])
(defstruct AttrDef [(old i64) (body (slice u8))])

(defn nz-b [(s (slice u8)) (i i64)] (-> i64) (cast i64 (slice-get s i)))
(defn nz-digit? [(c i64)] (-> bool) (and (icmp-ge c 48) (icmp-le c 57)))
(defn nz-alnum? [(c i64)] (-> bool)
  (or (and (icmp-ge c 48) (icmp-le c 57))
      (or (and (icmp-ge c 65) (icmp-le c 90)) (and (icmp-ge c 97) (icmp-le c 122)))))
(defn nz-ident? [(c i64)] (-> bool) (or (nz-alnum? c) (icmp-eq c 95)))
(defn nz-sym? [(c i64)] (-> bool)
  (or (nz-alnum? c) (or (icmp-eq c 95) (or (icmp-eq c 46) (or (icmp-eq c 36) (icmp-eq c 45))))))

(defn nz-contains? [(hay (slice u8)) (needle (slice u8))] (-> bool)
  (match (str-find hay needle) (Some [_] true) (None [] false)))

(defn nz-find-i64 [(l (ArrayList i64)) (x i64)] (-> i64)
  (let [n (al-len [i64] l) (mut i) 0 (mut res) -1]
    (loop (if (or (icmp-ge (load i) n) (icmp-ge (load res) 0)) (break)
            (if (icmp-eq (al-get [i64] l (load i)) x) (store! res (load i)) (store! i (iadd (load i) 1)))))
    (load res)))

(defn nz-all-digits? [(s (slice u8))] (-> bool)
  (let [n (slice-len s) (mut i) 0 (mut ok) true]
    (loop (if (or (icmp-ge (load i) n) (not (load ok))) (break)
            (if (nz-digit? (nz-b s (load i))) (do (store! i (iadd (load i) 1)) 0) (do (store! ok false) 0))))
    (and (icmp-gt n 0) (load ok))))

(defn nz-leading-number [(s (slice u8)) (start i64)] (-> NumRes)
  (let [n (slice-len s) (mut j) start (mut v) 0]
    (loop (if (or (icmp-ge (load j) n) (not (nz-digit? (nz-b s (load j))))) (break)
            (do (store! v (iadd (imul (load v) 10) (isub (nz-b s (load j)) 48)))
                (store! j (iadd (load j) 1)))))
    (let [r (alloc-stack NumRes)]
      (store! (field r val) (load v))
      (store! (field r len) (isub (load j) start))
      (load r))))

(defn nz-parse-int [(s (slice u8))] (-> i64)
  (let [r (alloc-stack NumRes)] (store! r (nz-leading-number s 0)) (load (field r val))))

(defn nz-split-lines [(a (ptr Allocator)) (text (slice u8))] (-> (ArrayList (slice u8)))
  (let [(mut out) (al-new [(slice u8)] a) n (slice-len text) (mut start) 0 (mut i) 0]
    (loop
      (if (icmp-gt (load i) n) (break)
        (if (icmp-eq (load i) n)
            (do (al-push! (mut out) (subslice text (load start) (load i))) (store! i (iadd (load i) 1)))
            (if (icmp-eq (nz-b text (load i)) 10)
                (do (al-push! (mut out) (subslice text (load start) (load i)))
                    (store! start (iadd (load i) 1)) (store! i (iadd (load i) 1)))
                (store! i (iadd (load i) 1))))))
    (load out)))

(defn nz-first-token [(l (slice u8))] (-> (slice u8))
  (match (str-find l " ") (Some [i] (subslice l 0 i)) (None [] l)))

(defn nz-at-symbol [(l (slice u8))] (-> (slice u8))
  (match (str-find l "@")
    (None [] l)
    (Some [at]
      (let [n (slice-len l) (mut j) (iadd at 1)]
        (if (and (icmp-lt (load j) n) (icmp-eq (nz-b l (load j)) 34))
            (do (store! j (iadd (load j) 1))
                (loop (if (or (icmp-ge (load j) n) (icmp-eq (nz-b l (load j)) 34)) (break)
                        (store! j (iadd (load j) 1))))
                (if (icmp-lt (load j) n) (store! j (iadd (load j) 1)) 0)
                (subslice l at (load j)))
            (do (loop (if (or (icmp-ge (load j) n) (not (nz-sym? (nz-b l (load j))))) (break)
                        (store! j (iadd (load j) 1))))
                (subslice l at (load j))))))))

(defn nz-pos-define-name? [(name (slice u8))] (-> bool)
  (let [pre "@__coil_llvm_ir_" pl (slice-len pre)]
    (if (not (starts-with name pre)) false
        (if (icmp-le (slice-len name) pl) false
            (nz-all-digits? (subslice name pl (slice-len name)))))))

; ---- scan_positional -------------------------------------------------------
(defn nz-mk-scan [(fam i64) (num i64) (endd i64)] (-> ScanRes)
  (let [s (alloc-stack ScanRes)]
    (store! (field s fam) fam) (store! (field s num) num) (store! (field s endd) endd) (load s)))

(defn nz-try-fam [(s (slice u8)) (i i64) (pre (slice u8)) (fam i64)] (-> (Option ScanRes))
  (let [n (slice-len s) pl (slice-len pre) ps (iadd i 1)]
    (if (icmp-gt (iadd ps pl) n) (None [ScanRes])
        (if (not (str-eq (subslice s ps (iadd ps pl)) pre)) (None [ScanRes])
            (let [nr (alloc-stack NumRes)]
              (store! nr (nz-leading-number s (iadd ps pl)))
              (if (icmp-eq (load (field nr len)) 0) (None [ScanRes])
                  (let [endd (iadd (iadd ps pl) (load (field nr len)))]
                    (if (or (icmp-ge endd n) (not (nz-ident? (nz-b s endd))))
                        (Some (nz-mk-scan fam (load (field nr val)) endd))
                        (None [ScanRes])))))))))

(defn nz-scan-positional [(s (slice u8)) (i i64)] (-> (Option ScanRes))
  (if (icmp-ge i (slice-len s)) (None [ScanRes])
      (if (icmp-ne (nz-b s i) 64) (None [ScanRes])
          (match (nz-try-fam s i "g." 0)
            (Some [r] (Some r))
            (None []
              (match (nz-try-fam s i "str." 1)
                (Some [r] (Some r))
                (None []
                  (match (nz-try-fam s i "cstr." 2)
                    (Some [r] (Some r))
                    (None [] (nz-try-fam s i "__coil_llvm_ir_" 3))))))))))

; ---- renumber map (4 first-encounter lists) --------------------------------
(defn nz-renum-assign! [(r (ptr Renum)) (fam i64) (old i64)] (-> i64)
  (if (icmp-eq fam 0)
      (if (icmp-lt (nz-find-i64 (load (field r g)) old) 0) (al-push! (mut (field r g)) old) 0)
   (if (icmp-eq fam 1)
      (if (icmp-lt (nz-find-i64 (load (field r st)) old) 0) (al-push! (mut (field r st)) old) 0)
   (if (icmp-eq fam 2)
      (if (icmp-lt (nz-find-i64 (load (field r cs)) old) 0) (al-push! (mut (field r cs)) old) 0)
      (if (icmp-lt (nz-find-i64 (load (field r lv)) old) 0) (al-push! (mut (field r lv)) old) 0)))))

(defn nz-renum-lookup [(r (ptr Renum)) (fam i64) (old i64)] (-> i64)
  (if (icmp-eq fam 0) (nz-find-i64 (load (field r g)) old)
   (if (icmp-eq fam 1) (nz-find-i64 (load (field r st)) old)
    (if (icmp-eq fam 2) (nz-find-i64 (load (field r cs)) old)
       (nz-find-i64 (load (field r lv)) old)))))

(defn nz-assign-line! [(r (ptr Renum)) (line (slice u8))] (-> i64)
  (let [n (slice-len line) (mut i) 0]
    (loop
      (if (icmp-ge (load i) n) (break)
          (if (icmp-eq (nz-b line (load i)) 64)
              (match (nz-scan-positional line (load i))
                (Some [sr] (let [s (alloc-stack ScanRes)] (store! s sr)
                             (nz-renum-assign! r (load (field s fam)) (load (field s num)))
                             (store! i (load (field s endd)))))
                (None [] (store! i (iadd (load i) 1))))
              (store! i (iadd (load i) 1)))))
    0))

(defn nz-name-of [(blocks (ArrayList NzBlock)) (idx i64)] (-> (slice u8))
  (let [b (alloc-stack NzBlock)] (store! b (al-get [NzBlock] blocks idx)) (load (field b name))))

(defn nz-pnum [(blocks (ArrayList NzBlock)) (idx i64) (r (ptr Renum))] (-> i64)
  (let [name (nz-name-of blocks idx) nr (alloc-stack NumRes)]
    (store! nr (nz-leading-number name (slice-len "@__coil_llvm_ir_")))
    (let [pos (nz-find-i64 (load (field r lv)) (load (field nr val)))]
      (if (icmp-lt pos 0) 9223372036854775807 pos))))

(defn nz-assign-block-bodies [(r (ptr Renum)) (blocks (ArrayList NzBlock)) (idx i64)] (-> i64)
  (let [b (alloc-stack NzBlock)]
    (store! b (al-get [NzBlock] blocks idx))
    (let [body (load (field b body)) n (al-len [(slice u8)] body) (mut i) 0]
      (loop (if (icmp-ge (load i) n) (break)
              (do (nz-assign-line! r (al-get [(slice u8)] body (load i))) (store! i (iadd (load i) 1))))))
    0))

(defn nz-assign-idxs [(r (ptr Renum)) (blocks (ArrayList NzBlock)) (idxs (ArrayList i64))] (-> i64)
  (let [n (al-len [i64] idxs) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
            (do (nz-assign-block-bodies r blocks (al-get [i64] idxs (load i))) (store! i (iadd (load i) 1)))))
    0))

(defn nz-sort-idx-by-name [(a (ptr Allocator)) (blocks (ArrayList NzBlock)) (idxs (ArrayList i64))] (-> (ArrayList i64))
  (let [n (al-len [i64] idxs) (mut used) (al-new [bool] a) (mut out) (al-new [i64] a) (mut k) 0]
    (loop (if (icmp-ge (load k) n) (break) (do (al-push! (mut used) false) (store! k (iadd (load k) 1)))))
    (let [(mut c) 0]
      (loop (if (icmp-ge (load c) n) (break)
        (do (let [(mut best) -1 (mut bi) 0]
              (loop (if (icmp-ge (load bi) n) (break)
                (do (if (not (al-get [bool] (load used) (load bi)))
                        (if (or (icmp-lt (load best) 0)
                                (str-lt (nz-name-of blocks (al-get [i64] idxs (load bi)))
                                        (nz-name-of blocks (al-get [i64] idxs (load best)))))
                            (store! best (load bi)) 0) 0)
                    (store! bi (iadd (load bi) 1)))))
              (al-set! [bool] (mut used) (load best) true)
              (al-push! (mut out) (al-get [i64] idxs (load best))))
            (store! c (iadd (load c) 1))))))
    (load out)))

(defn nz-sort-idx-by-pnum [(a (ptr Allocator)) (blocks (ArrayList NzBlock)) (idxs (ArrayList i64)) (r (ptr Renum))] (-> (ArrayList i64))
  (let [n (al-len [i64] idxs) (mut used) (al-new [bool] a) (mut out) (al-new [i64] a) (mut k) 0]
    (loop (if (icmp-ge (load k) n) (break) (do (al-push! (mut used) false) (store! k (iadd (load k) 1)))))
    (let [(mut c) 0]
      (loop (if (icmp-ge (load c) n) (break)
        (do (let [(mut best) -1 (mut bi) 0]
              (loop (if (icmp-ge (load bi) n) (break)
                (do (if (not (al-get [bool] (load used) (load bi)))
                        (if (or (icmp-lt (load best) 0)
                                (icmp-lt (nz-pnum blocks (al-get [i64] idxs (load bi)) r)
                                         (nz-pnum blocks (al-get [i64] idxs (load best)) r)))
                            (store! best (load bi)) 0) 0)
                    (store! bi (iadd (load bi) 1)))))
              (al-set! [bool] (mut used) (load best) true)
              (al-push! (mut out) (al-get [i64] idxs (load best))))
            (store! c (iadd (load c) 1))))))
    (load out)))

(defn nz-build-renumber [(a (ptr Allocator)) (blocks (ArrayList NzBlock))] (-> Renum)
  (let [rstk (alloc-stack Renum)]
    (store! (field rstk g)  (al-new [i64] a))
    (store! (field rstk st) (al-new [i64] a))
    (store! (field rstk cs) (al-new [i64] a))
    (store! (field rstk lv) (al-new [i64] a))
    (let [nb (al-len [NzBlock] blocks) (mut stable) (al-new [i64] a) (mut pos) (al-new [i64] a) (mut k) 0]
      (loop (if (icmp-ge (load k) nb) (break)
              (do (let [b (alloc-stack NzBlock)]
                    (store! b (al-get [NzBlock] blocks (load k)))
                    (if (icmp-eq (load (field b cat)) 3)
                        (if (nz-pos-define-name? (load (field b name)))
                            (al-push! (mut pos) (load k))
                            (al-push! (mut stable) (load k)))
                        0))
                  (store! k (iadd (load k) 1)))))
      (nz-assign-idxs rstk blocks (nz-sort-idx-by-name a blocks (load stable)))
      (nz-assign-idxs rstk blocks (nz-sort-idx-by-pnum a blocks (load pos) rstk))
      (let [(mut g2) 0]
        (loop (if (icmp-ge (load g2) nb) (break)
                (do (let [b (alloc-stack NzBlock)]
                      (store! b (al-get [NzBlock] blocks (load g2)))
                      (if (icmp-eq (load (field b cat)) 1)
                          (nz-assign-block-bodies rstk blocks (load g2)) 0))
                    (store! g2 (iadd (load g2) 1)))))))
    (load rstk)))

; ---- apply_renumber --------------------------------------------------------
(defn nz-push-str! [(out (mut (ArrayList u8))) (s (slice u8))] (-> i64)
  (let [n (slice-len s) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
            (do (al-push! (mut out) (slice-get s (load i))) (store! i (iadd (load i) 1)))))
    0))

(defn nz-fam-str [(fam i64)] (-> (slice u8))
  (if (icmp-eq fam 0) "g" (if (icmp-eq fam 1) "str" "cstr")))

(defn nz-emit-renamed [(out (mut (ArrayList u8))) (fam i64) (newn i64)] (-> i64)
  (if (icmp-eq fam 3)
      (do (nz-push-str! (mut out) "@__coil_llvm_ir_") (push-mag (mut out) newn))
      (do (al-push! (mut out) (cast u8 64))
          (nz-push-str! (mut out) (nz-fam-str fam))
          (al-push! (mut out) (cast u8 46))
          (push-mag (mut out) newn))))

(defn nz-apply-renumber [(a (ptr Allocator)) (line (slice u8)) (r (ptr Renum))] (-> (slice u8))
  (let [n (slice-len line) (mut out) (al-new [u8] a) (mut i) 0]
    (loop
      (if (icmp-ge (load i) n) (break)
        (if (icmp-eq (nz-b line (load i)) 64)
            (match (nz-scan-positional line (load i))
              (Some [sr] (let [s (alloc-stack ScanRes)] (store! s sr)
                           (let [newn (nz-renum-lookup r (load (field s fam)) (load (field s num)))]
                             (if (icmp-lt newn 0)
                                 (do (al-push! (mut out) (slice-get line (load i))) (store! i (iadd (load i) 1)))
                                 (do (nz-emit-renamed (mut out) (load (field s fam)) newn)
                                     (store! i (load (field s endd))))))))
              (None [] (do (al-push! (mut out) (slice-get line (load i))) (store! i (iadd (load i) 1)))))
            (do (al-push! (mut out) (slice-get line (load i))) (store! i (iadd (load i) 1))))))
    (al-slice [u8] (load out))))

(defn nz-map-apply [(a (ptr Allocator)) (body (ArrayList (slice u8))) (r (ptr Renum))] (-> (ArrayList (slice u8)))
  (let [n (al-len [(slice u8)] body) (mut out) (al-new [(slice u8)] a) (mut i) 0]
    (loop (if (icmp-ge (load i) n) (break)
            (do (al-push! (mut out) (nz-apply-renumber a (al-get [(slice u8)] body (load i)) r))
                (store! i (iadd (load i) 1)))))
    (load out)))

; ---- parse_blocks ----------------------------------------------------------
(defn nz-one-body [(a (ptr Allocator)) (l (slice u8))] (-> (ArrayList (slice u8)))
  (let [(mut b) (al-new [(slice u8)] a)] (al-push! (mut b) l) (load b)))

(defn nz-push-block! [(a (ptr Allocator)) (blocks (mut (ArrayList NzBlock))) (cat i64) (name (slice u8)) (body (ArrayList (slice u8)))] (-> i64)
  (let [b (alloc-stack NzBlock)]
    (store! (field b cat) cat) (store! (field b name) name) (store! (field b body) body)
    (al-push! (mut blocks) (load b)) 0))

(defn nz-parse-define [(a (ptr Allocator)) (blocks (mut (ArrayList NzBlock))) (lines (ArrayList (slice u8))) (nlines i64) (i i64) (l (slice u8))] (-> i64)
  (let [(mut body) (al-new [(slice u8)] a) (mut j) (iadd i 1)]
    (al-push! (mut body) l)
    (loop (if (or (icmp-ge (load j) nlines) (str-eq (al-get [(slice u8)] lines (load j)) "}")) (break)
            (do (al-push! (mut body) (al-get [(slice u8)] lines (load j))) (store! j (iadd (load j) 1)))))
    (if (icmp-lt (load j) nlines)
        (do (al-push! (mut body) (al-get [(slice u8)] lines (load j))) (store! j (iadd (load j) 1)))
        0)
    (nz-push-block! a (mut blocks) 3 (nz-at-symbol l) (load body))
    (load j)))

(defn nz-parse-one-block [(a (ptr Allocator)) (blocks (mut (ArrayList NzBlock))) (lines (ArrayList (slice u8))) (nlines i64) (i i64) (l (slice u8))] (-> i64)
  (if (and (icmp-eq (nz-b l 0) 37) (nz-contains? l "= type"))
      (do (nz-push-block! a (mut blocks) 0 (nz-first-token l) (nz-one-body a l)) (iadd i 1))
   (if (icmp-eq (nz-b l 0) 64)
      (do (nz-push-block! a (mut blocks) 1 (nz-first-token l) (nz-one-body a l)) (iadd i 1))
   (if (starts-with l "declare")
      (do (nz-push-block! a (mut blocks) 2 (nz-at-symbol l) (nz-one-body a l)) (iadd i 1))
   (if (starts-with l "define")
      (nz-parse-define a (mut blocks) lines nlines i l)
      (do (nz-push-block! a (mut blocks) 4 l (nz-one-body a l)) (iadd i 1)))))))

(defn nz-parse-blocks [(a (ptr Allocator)) (text (slice u8))] (-> NzParsed)
  (let [lines (nz-split-lines a text) nlines (al-len [(slice u8)] lines)
        (mut header) (al-new [(slice u8)] a) (mut blocks) (al-new [NzBlock] a) (mut i) 0]
    (loop (if (or (icmp-ge (load i) nlines) (icmp-eq (slice-len (al-get [(slice u8)] lines (load i))) 0)) (break)
            (do (al-push! (mut header) (al-get [(slice u8)] lines (load i))) (store! i (iadd (load i) 1)))))
    (loop (if (icmp-ge (load i) nlines) (break)
            (let [l (al-get [(slice u8)] lines (load i))]
              (if (icmp-eq (slice-len l) 0)
                  (store! i (iadd (load i) 1))
                  (store! i (nz-parse-one-block a (mut blocks) lines nlines (load i) l))))))
    (let [p (alloc-stack NzParsed)]
      (store! (field p header) (load header)) (store! (field p blocks) (load blocks)) (load p))))

; ---- block sort by (cat, name) ---------------------------------------------
(defn nz-block-lt [(blocks (ArrayList NzBlock)) (i i64) (j i64)] (-> bool)
  (let [bi (alloc-stack NzBlock) bj (alloc-stack NzBlock)]
    (store! bi (al-get [NzBlock] blocks i)) (store! bj (al-get [NzBlock] blocks j))
    (let [ci (load (field bi cat)) cj (load (field bj cat))]
      (if (icmp-lt ci cj) true
          (if (icmp-gt ci cj) false
              (str-lt (load (field bi name)) (load (field bj name))))))))

(defn nz-sort-blocks [(a (ptr Allocator)) (blocks (ArrayList NzBlock))] (-> (ArrayList NzBlock))
  (let [n (al-len [NzBlock] blocks) (mut used) (al-new [bool] a) (mut out) (al-new [NzBlock] a) (mut k) 0]
    (loop (if (icmp-ge (load k) n) (break) (do (al-push! (mut used) false) (store! k (iadd (load k) 1)))))
    (let [(mut c) 0]
      (loop (if (icmp-ge (load c) n) (break)
        (do (let [(mut best) -1 (mut bi) 0]
              (loop (if (icmp-ge (load bi) n) (break)
                (do (if (not (al-get [bool] (load used) (load bi)))
                        (if (or (icmp-lt (load best) 0) (nz-block-lt blocks (load bi) (load best)))
                            (store! best (load bi)) 0) 0)
                    (store! bi (iadd (load bi) 1)))))
              (al-set! [bool] (mut used) (load best) true)
              (al-push! (mut out) (al-get [NzBlock] blocks (load best))))
            (store! c (iadd (load c) 1))))))
    (load out)))

; ---- attribute-group renumber ----------------------------------------------
(defn nz-body-of [(defs (ArrayList AttrDef)) (idx i64)] (-> (slice u8))
  (let [d (alloc-stack AttrDef)] (store! d (al-get [AttrDef] defs idx)) (load (field d body))))

(defn nz-sort-attrs [(a (ptr Allocator)) (defs (ArrayList AttrDef))] (-> (ArrayList AttrDef))
  (let [n (al-len [AttrDef] defs) (mut used) (al-new [bool] a) (mut out) (al-new [AttrDef] a) (mut k) 0]
    (loop (if (icmp-ge (load k) n) (break) (do (al-push! (mut used) false) (store! k (iadd (load k) 1)))))
    (let [(mut c) 0]
      (loop (if (icmp-ge (load c) n) (break)
        (do (let [(mut best) -1 (mut bi) 0]
              (loop (if (icmp-ge (load bi) n) (break)
                (do (if (not (al-get [bool] (load used) (load bi)))
                        (if (or (icmp-lt (load best) 0)
                                (str-lt (nz-body-of defs (load bi)) (nz-body-of defs (load best))))
                            (store! best (load bi)) 0) 0)
                    (store! bi (iadd (load bi) 1)))))
              (al-set! [bool] (mut used) (load best) true)
              (al-push! (mut out) (al-get [AttrDef] defs (load best))))
            (store! c (iadd (load c) 1))))))
    (load out)))

(defn nz-attr-newof [(defs (ArrayList AttrDef)) (old i64)] (-> i64)
  (let [n (al-len [AttrDef] defs) (mut i) 0 (mut res) -1]
    (loop (if (or (icmp-ge (load i) n) (icmp-ge (load res) 0)) (break)
            (do (let [d (alloc-stack AttrDef)] (store! d (al-get [AttrDef] defs (load i)))
                  (if (icmp-eq (load (field d old)) old) (store! res (load i)) 0))
                (store! i (iadd (load i) 1)))))
    (load res)))

(defn nz-replace-attr-refs [(a (ptr Allocator)) (text (slice u8)) (sorted (ArrayList AttrDef))] (-> (slice u8))
  (let [n (slice-len text) (mut out) (al-new [u8] a) (mut i) 0]
    (loop
      (if (icmp-ge (load i) n) (break)
        (if (and (icmp-eq (nz-b text (load i)) 35)
                 (and (icmp-lt (iadd (load i) 1) n) (nz-digit? (nz-b text (iadd (load i) 1)))))
            (let [(mut j) (iadd (load i) 1)]
              (loop (if (or (icmp-ge (load j) n) (not (nz-digit? (nz-b text (load j))))) (break)
                      (store! j (iadd (load j) 1))))
              (if (or (icmp-ge (load j) n) (not (nz-ident? (nz-b text (load j)))))
                  (let [newn (nz-attr-newof sorted (nz-parse-int (subslice text (iadd (load i) 1) (load j))))]
                    (if (icmp-ge newn 0)
                        (do (al-push! (mut out) (cast u8 35)) (push-mag (mut out) newn) (store! i (load j)))
                        (do (al-push! (mut out) (slice-get text (load i))) (store! i (iadd (load i) 1)))))
                  (do (al-push! (mut out) (slice-get text (load i))) (store! i (iadd (load i) 1)))))
            (do (al-push! (mut out) (slice-get text (load i))) (store! i (iadd (load i) 1))))))
    (al-slice [u8] (load out))))

(defn nz-renumber-attrs [(a (ptr Allocator)) (text (slice u8))] (-> (slice u8))
  (let [lines (nz-split-lines a text) nl (al-len [(slice u8)] lines)
        (mut defs) (al-new [AttrDef] a) (mut i) 0 pre "attributes #"]
    (loop (if (icmp-ge (load i) nl) (break)
            (do (let [l (al-get [(slice u8)] lines (load i))]
                  (if (starts-with l pre)
                      (let [rest (subslice l (slice-len pre) (slice-len l))]
                        (match (str-find rest " = ")
                          (None [] 0)
                          (Some [eq]
                            (let [numpart (subslice rest 0 eq)]
                              (if (nz-all-digits? numpart)
                                  (let [d (alloc-stack AttrDef)]
                                    (store! (field d old) (nz-parse-int numpart))
                                    (store! (field d body) (subslice rest (iadd eq 3) (slice-len rest)))
                                    (al-push! (mut defs) (load d)) 0)
                                  0)))))
                      0))
                (store! i (iadd (load i) 1)))))
    (if (icmp-eq (al-len [AttrDef] defs) 0)
        text
        (nz-replace-attr-refs a text (nz-sort-attrs a (load defs))))))

; ---- assemble + normalize --------------------------------------------------
(defn nz-assemble [(a (ptr Allocator)) (header (ArrayList (slice u8))) (nblocks (ArrayList NzBlock))] (-> (slice u8))
  (let [(mut out) (al-new [u8] a) nh (al-len [(slice u8)] header) (mut i) 0]
    (loop (if (icmp-ge (load i) nh) (break)
            (do (nz-push-str! (mut out) (al-get [(slice u8)] header (load i)))
                (al-push! (mut out) (cast u8 10)) (store! i (iadd (load i) 1)))))
    (al-push! (mut out) (cast u8 10))
    (let [nb (al-len [NzBlock] nblocks) (mut k) 0]
      (loop (if (icmp-ge (load k) nb) (break)
              (do (let [b (alloc-stack NzBlock)] (store! b (al-get [NzBlock] nblocks (load k)))
                    (let [body (load (field b body)) nbody (al-len [(slice u8)] body) (mut j) 0]
                      (loop (if (icmp-ge (load j) nbody) (break)
                              (do (nz-push-str! (mut out) (al-get [(slice u8)] body (load j)))
                                  (al-push! (mut out) (cast u8 10)) (store! j (iadd (load j) 1)))))
                      (al-push! (mut out) (cast u8 10))))
                  (store! k (iadd (load k) 1))))))
    (loop
      (let [m (al-len [u8] (load out))]
        (if (and (icmp-ge m 2)
                 (and (icmp-eq (nz-b (al-slice [u8] (load out)) (isub m 1)) 10)
                      (icmp-eq (nz-b (al-slice [u8] (load out)) (isub m 2)) 10)))
            (do (al-pop! [u8] (mut out)) 0)
            (break))))
    (al-slice [u8] (load out))))

(defn normalize-ir [(a (ptr Allocator)) (ir (slice u8))] (-> (slice u8))
  (let [text (nz-renumber-attrs a ir)
        parsed (alloc-stack NzParsed)]
    (store! parsed (nz-parse-blocks a text))
    (let [header (load (field parsed header)) blocks0 (load (field parsed blocks))
          rstk (alloc-stack Renum)]
      (store! rstk (nz-build-renumber a blocks0))
      (let [nb (al-len [NzBlock] blocks0) (mut nblocks) (al-new [NzBlock] a) (mut i) 0]
        (loop (if (icmp-ge (load i) nb) (break)
                (do (let [b (alloc-stack NzBlock) nbk (alloc-stack NzBlock)]
                      (store! b (al-get [NzBlock] blocks0 (load i)))
                      (store! (field nbk cat) (load (field b cat)))
                      (store! (field nbk name) (nz-apply-renumber a (load (field b name)) rstk))
                      (store! (field nbk body) (nz-map-apply a (load (field b body)) rstk))
                      (al-push! (mut nblocks) (load nbk)))
                    (store! i (iadd (load i) 1)))))
        (nz-assemble a header (nz-sort-blocks a (load nblocks)))))))

; Tail of the pipeline: mono'd Program -> codegen -> print -> normalize -> stdout.
; Mirrors src/lib.rs::dump_ir (emit_ir then normalize_ir::normalize).
(defn emit-ir-normalized [(a (ptr Allocator)) (w (ptr Writer)) (mp (ptr Program))] (-> i64)
  (let [m       (codegen-module a mp)
        ir-cstr (LLVMPrintModuleToString m)
        ir      (cstr->slice ir-cstr)
        norm    (normalize-ir a ir)]
    (ps w norm)
    (wb w 10)          ; mirror `coil dump-ir`'s println! trailing newline
    0))

(defn dump-ir-program [(a (ptr Allocator)) (src (slice u8)) (cwd (slice u8))] (-> i64)
  (let [w (stdout) s (alloc-stack LS)]
    (store! (field s a) a)
    (store! (field s out)     (al-new [TaggedForm] a))
    (store! (field s loaded)  (al-new [(slice u8)] a))
    (store! (field s imports) (al-new [ImpEntry] a))
    (store! (field s exports) (al-new [ExpEntry] a))
    (match (read-all a src)
      (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
      (Ok [forms]
        (do (load-program (mut s) forms cwd)
            (match (resolve-program a (mut s))
              (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
              (Ok [prog]
                (match (check-program a prog (mut s))
                  (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
                  (Ok [cp]
                    (do (drop-code-funcs a cp)
                        (match (monomorphize a cp)
                          (Err [d] (let [dp (alloc-stack Diag)] (store! dp d) (dump-error w dp)))
                          (Ok [mp] (do (sort-mono-program a mp) (emit-ir-normalized a w mp)))))))))))))
  0)

(defn main [(argc i32) (argv (ptr (ptr i8)))] (-> i64)
  (let [a    (malloc-allocator)
        sub  (cstr->slice (load (index argv 1)))]
    (if (str-eq sub "__smoke")
        (smoke a)
      (if (str-eq sub "__normalize")
          (let [path (load (index argv 2)) src (read-file a path) w (stdout)]
            (ps w (normalize-ir a src)) 0)
          (let [path (load (index argv 2))
                src  (read-file a path)
                cwd  (cwd-slice a)]
            (dump-ir-program a src cwd)))))
  0)