(defn synth-call-general [(a (ptr Allocator)) (func (slice u8)) (call_func (slice u8)) (type_args (ptr (ArrayList Type))) (args (ptr (ArrayList Expr))) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try
   (do
    (let [sig (sig-find cx call_func)]
      (if (icmp-eq (cast i64 sig) 0)
          (return-from :try (err-ep (derr (sconcat3 a (sconcat3 a "in '" fname "': call to undefined function '") func "'")))) 0)
      (let [nparams (al-len [Type] (load (field sig params))) nargs (al-len [Expr] (load args)) variadic (load (field sig variadic))
            arity_ok (if variadic (icmp-ge nargs nparams) (icmp-eq nargs nparams))]
        (if (not arity_ok)
            (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': '" (sconcat a func "' expects ")) (if variadic "at least " "")) (i64->str a nparams)) (sconcat a " args, got " (i64->str a nargs)))))) 0)
        (if (icmp-eq (al-len [(slice u8)] (load (field sig type_params))) 0)
            (do (if (icmp-gt (al-len [Type] (load type_args)) 0)
                    (return-from :try (err-ep (derr (sconcat1 a (sconcat5 a "in '" fname "': '" func "' is not generic but got type arguments"))))) 0)
                (let [new_args (try! (ca-nongeneric a sig args func elo ehi env cx tps fname))]
                  (return-from :try (ok-ep (mk-expr (ECall call_func (box-items-type a) new_args) elo ehi) (load (field sig ret))))))
          (let [defs (box-al [Deferred] a (al-new [Deferred] a))
                argl (ca-build-arglist a args defs env cx tps fname)
                subst (try! (solve-type-args a (load (field sig type_params)) (load (field sig params)) type_args argl (field sig ret) expected cx tps fname func))]
            (try! (ca-check-bounds a sig subst func cx fname))
            (try! (ca-resynth-deferred a defs argl sig subst args env cx tps fname))
            (let [new_args (try! (ca-final-coerce a argl sig subst args func fname))
                  out_targs (subst-targs a (load (field sig type_params)) subst)
                  ret (subst-apply a (field sig ret) subst)]
              (ok-ep (mk-expr (ECall func out_targs new_args) elo ehi) ret)))))))))

(defn synth-call [(a (ptr Allocator)) (func (slice u8)) (type_args (ptr (ArrayList Type))) (args (ptr (ArrayList Expr))) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
  (try
   (do
    (if (icmp-ne (cast i64 (vts-find cx func)) 0)
        (return-from :try (synth-construct a func type_args args expected env cx tps fname elo ehi)) 0)
    (let [(mut call_func) func]
      (if (methods-has cx func)
          (let [me0 (try! (resolve-method a cx func fname)) me (alloc-stack MethodEntry)] (store! me me0)
            (let [trait_name (load (field me trait)) self_idx (load (field me self_idx))
                  td (trait-find cx (load (field me trait))) tm (trait-method-find (trait-find cx (load (field me trait))) func)
                  self_pname (load (field td self_param))]
              (if (not (icmp-eq (al-len [Expr] (load args)) (al-len [Param] (load (field tm params)))))
                  (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': '" (sconcat a func "' expects ")) (i64->str a (al-len [Param] (load (field tm params))))) " args, got ") (i64->str a (al-len [Expr] (load args))))))) 0)
              (let [selfsp (try! (do-synth a (al-elem [Expr] args self_idx) (null-type) env cx tps fname)) ssp (alloc-stack SynPair)] (store! ssp selfsp)
                (let [self_ty (peel-ref-ptr (load (field ssp t)))]
                  (if (not (has-impl-name self_ty))
                      (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat4 a "in '" fname "': trait method '" (sconcat a func "' called on a type that can't carry an impl: ")) (ty-str a self_ty)) "")))) 0)
                  (let [self_name (type-impl-name a self_ty)]
                    (if (icmp-gt (slice-len [u8] (dyn-struct-trait cx self_name)) 0)
                        (return-from :try (synth-dyn-dispatch a cx func self_name self_idx td tm args env tps fname elo ehi)) 0)
                    (if (set-contains tps self_name)
                        (if (not (bounds-has (field cx cur_bounds) self_name trait_name))
                            (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': type parameter '" (sconcat a self_name "' is not bounded by '")) (display-name trait_name)) "' (required to call '") (sconcat a func "')")))))
                          (let [self_as_ty (box-type a (TStruct self_name))
                                new_args (try! (trait-tp-args a tm self_pname self_as_ty args env cx tps fname func))
                                ret (subst-self a (field tm ret) self_pname self_as_ty)]
                            (return-from :try (ok-ep (mk-expr (ETraitCall trait_name func self_name new_args) elo ehi) ret))))
                      (do (if (not (impl-has cx trait_name self_name))
                              (return-from :try (err-ep (derr (sconcat a (sconcat a (sconcat5 a "in '" fname "': '" (display-name self_name) "' does not implement '") (display-name trait_name)) "'")))) 0)
                          (store! call_func (tmfn a trait_name self_name func)) 0)))))))
          0)
      (synth-call-general a func (load call_func) type_args args expected env cx tps fname elo ehi)))))
