(defn process-let-binds [(a (ptr Allocator)) (binds (ptr (ArrayList Bind))) (nbinds (ptr (ArrayList Bind))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result i64 Diag))
