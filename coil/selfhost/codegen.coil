(defn variant-by-name [(variants (ptr (ArrayList Variant))) (name (slice u8))] (-> (ptr Variant))
  (let [n (al-len [Variant] (load variants)) (mut i) 0 (mut r) (cast (ptr Variant) 0)]
    (loop (if (icmp-ge (load i) n) (break)
      (do (if (str-eq (load (field (al-elem [Variant] variants (load i)) name)) name) (do (store! r (al-elem [Variant] variants (load i))) (break)) 0)
          (store! i (iadd (load i) 1)))))
    (load r)))
(defn covered-has [(cov (ptr (ArrayList (slice u8)))) (name (slice u8))] (-> bool) (set-contains cov name))

(defn match-arms-loop [(a (ptr Allocator)) (arms (ptr (ArrayList Arm))) (variants (ptr (ArrayList Variant))) (sumname (slice u8)) (expected (ptr Type)) (covered (ptr (ArrayList (slice u8)))) (checked (ptr (ArrayList Arm))) (synb (ptr (ArrayList Branch))) (metav (ptr (ArrayList (slice u8)))) (metab (ptr (ArrayList (ptr (ArrayList (slice u8)))))) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8))] (-> (Result i64 Diag))
  (let [narms (al-len [Arm] (load arms)) (mut i) 0 (mut err) (zeroed Diag) (mut failed) false]
    (loop (if (icmp-ge (load i) narms) (break)
      (do (let [arm (al-elem [Arm] arms (load i)) av (load (field arm variant)) abinds (load (field arm binds))
                v (variant-by-name variants av)]
            (if (icmp-eq (cast i64 v) 0)
                (do (store! err (derr (sconcat a (sconcat a (sconcat4 a "in '" fname "': sum '" (sconcat a sumname "' has no variant '")) av) "'"))) (store! failed true) (break))
              (if (set-contains covered av)
                  (do (store! err (derr (sconcat a (sconcat a (sconcat4 a "in '" fname "': duplicate match arm for '" av) "'") ""))) (store! failed true) (break))
                (if (not (icmp-eq (al-len [(slice u8)] (load abinds)) (al-len [Field] (load (field v fields)))))
                    (do (store! err (derr (sconcat a (sconcat a (sconcat a (sconcat a (sconcat4 a "in '" fname "': arm '" (sconcat a av "' binds ")) (i64->str a (al-len [(slice u8)] (load abinds)))) " name(s) but the variant has ") (i64->str a (al-len [Field] (load (field v fields))))) " field(s)"))) (store! failed true) (break))
                  (do (al-push! [(slice u8)] covered av)
                      (let [saved (al-len [EnvEntry] (load env)) fs (load (field v fields)) nbn (al-len [(slice u8)] (load abinds)) (mut k) 0]
                        (loop (if (icmp-ge (load k) nbn) (break)
                          (do (env-insert! env (al-get [(slice u8)] (load abinds) (load k)) (field (al-elem [Field] fs (load k)) ty))
                              (store! k (iadd (load k) 1)))))
                        (if (expected-some? expected)
                            (match (check-to a (field arm body) expected env cx tps fname "match arm")
                              (Err [d] (do (env-truncate! env saved) (store! err d) (store! failed true) (break)))
                              (Ok [be] (do (let [na (alloc-stack Arm)] (store! (field na variant) av) (store! (field na binds) abinds) (store! (field na body) be) (al-push! [Arm] checked (load na))) (env-truncate! env saved) 0)))
                          (match (do-synth a (field arm body) (null-type) env cx tps fname)
                            (Err [d] (do (env-truncate! env saved) (store! err d) (store! failed true) (break)))
                            (Ok [sp0] (let [sp (alloc-stack SynPair) br (alloc-stack Branch)] (store! sp sp0)
                                        (store! (field br e) (load (field sp e))) (store! (field br t) (load (field sp t))) (al-push! [Branch] synb (load br))
                                        (al-push! [(slice u8)] metav av) (al-push! [(ptr (ArrayList (slice u8)))] metab abinds)
                                        (env-truncate! env saved) 0)))))))))
          (store! i (iadd (load i) 1))))))
    (if (load failed) (Err [i64 Diag] (load err)) (Ok [i64 Diag] 0))))

(defn build-newarms [(a (ptr Allocator)) (metav (ptr (ArrayList (slice u8)))) (metab (ptr (ArrayList (ptr (ArrayList (slice u8)))))) (outl (ptr (ArrayList Expr)))] (-> (ptr (ArrayList Arm)))
