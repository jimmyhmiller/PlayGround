(defn synth-let [(a (ptr Allocator)) (binds (ptr (ArrayList Bind))) (body (ptr (ArrayList Expr))) (expected (ptr Type)) (env (ptr (ArrayList EnvEntry))) (cx (ptr Cx)) (tps (ptr (ArrayList (slice u8)))) (fname (slice u8)) (elo i64) (ehi i64)] (-> (Result EvalPair Diag))
