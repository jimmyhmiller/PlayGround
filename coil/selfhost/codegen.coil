                    (al-push! (mut initdo) (mk-expr (EVar slot) elo ehi))
                    (al-push! [Bind] nbinds (mk-bind slot false (mk-expr (EAlloc 0 (erase-refs a vt)) elo ehi)))
                    (al-push! [Bind] nbinds (mk-bind name false (mk-expr (EDo (box-al [Expr] a (load initdo))) elo ehi)))
                    (Ok [i64 Diag] 0))
                (do (env-insert! env name (box-type a (load vt)))
