                  ismut (is-mut-borrow (al-elem [Expr] args (load i))) what (sconcat1 a (sconcat3 a "argument to '" func "'"))]
              (match (do-synth a (al-elem [Expr] args (load i)) exp env cx tps fname)
                (Err [d] (do (store! err d) (store! failed true) (break)))
                (Ok [sp0] (let [sp (alloc-stack SynPair)] (store! sp sp0)
