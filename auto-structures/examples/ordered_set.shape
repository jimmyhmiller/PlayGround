# Distinct values, queried for their extremes and printed in order.
#
# `s` does membership (add/has) AND asks for min/max/sorted, so ordering
# matters -> the analyzer upgrades it from a hash set to an ORDERED SET
# (BTreeSet).

let data = [42, 7, 19, 7, 88, 3, 19, 56, 3]

let s = collection()
for x in data {
  add(s, x)
}

print("count:", size(s))
print("min:", min(s))
print("max:", max(s))
print("in order:")
for x in sorted(s) {
  print(x)
}
