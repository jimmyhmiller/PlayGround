# Stable de-duplication.
#
# `seen` is only ever asked "have I seen this?" (add / has) -> a HASH SET.
# `result` is appended to and iterated in order              -> a DYNAMIC ARRAY.

let nums = [3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5]

let seen = collection()
let result = collection()

for n in nums {
  if not has(seen, n) {
    add(seen, n)
    append(result, n)
  }
}

print("unique count:", size(seen))
for x in result {
  print(x)
}
