# Reverse a sequence using a stack.
#
# `stack`    : push/pop          -> a DYNAMIC ARRAY used as a LIFO stack
# `reversed` : append/iterate    -> a DYNAMIC ARRAY

let input = [10, 20, 30, 40, 50]

let stack = collection()
for x in input {
  push(stack, x)
}

let reversed = collection()
while size(stack) > 0 {
  append(reversed, pop(stack))
}

print("reversed:")
for x in reversed {
  print(x)
}
