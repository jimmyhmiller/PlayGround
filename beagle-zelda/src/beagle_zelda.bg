        pos: pos,
        prev: pos,
        vel: v/ZERO,
        half: v/make(12.0, 12.0),
        speed: 120.0,
        detection_range: 300.0,
        attack_reach: 28.0,
        strength: 1.0,
        has_seen: false,
        time_since_los: 0.0,
        notice_acc: 0.0,
        notice_threshold: 0.8,
        wander_dir: v/ZERO,
        wander_timer: 2.0
    }
}

// ============================================================
// Sentinel (searchlight sweep AI)
