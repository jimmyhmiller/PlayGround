namespace beagle_zelda

// beagle-zelda — a port of the Bevy Zelda-like prototype to raylib + raygui.
// Features are being added feature-by-feature; see README.md for status.

use beagle.ffi as ffi
use beagle.async as async
use ray as r
use vec as v

// ============================================================
// Constants
// ============================================================

let MAX_EXTRA_LIGHTS = 8

// Initial window dimensions only — the window is resizable at runtime, so
// never read these constants in render/input paths. Query r/screen_width()
// and r/screen_height() live instead.
let INITIAL_W = 1280
let INITIAL_H = 720
let FIXED_HZ = 60.0
let FIXED_DT = 1.0 / 60.0          // fallback / test dt; gameplay uses real frame time
let MAX_DT = 1.0 / 30.0            // clamp so lag spikes don't teleport entities

// Real seconds since the last frame, clamped to MAX_DT to keep physics stable.
// On frame 0 raylib returns 0, which we replace with FIXED_DT so the first
// tick doesn't advance nothing.
fn current_dt() {
    let raw = r/frame_time()
    if raw <= 0.0 { FIXED_DT }
    else if raw > MAX_DT { MAX_DT }
    else { raw }
}
let WALL_HEIGHT = 48.0             // pseudo-3D front-face height

let MODE_PLAYING = 0
let MODE_EDITING = 1

let TOOL_SELECT = 0
let TOOL_WALL = 1
let TOOL_MONSTER = 2
let TOOL_SENTINEL = 3

// Tuning — mirrors the Bevy `Tuning` resource.
struct Tuning {
    max_speed
    accel
    friction
    light_range
    light_half_angle_deg
    light_intensity
    ambient
    camera_smoothing
    run_multiplier
    sneak_multiplier
}

fn default_tuning() {
    Tuning {
        max_speed: 280.0,
        accel: 3200.0,
        friction: 3600.0,
        light_range: 520.0,
        light_half_angle_deg: 83.0,
        light_intensity: 1.3,
        // 0.15 baseline keeps the scene (and especially the player) visible
        // outside the cone — pure-black ambient makes it look like the
        // character has disappeared whenever the aim points away from their body.
        ambient: 0.15,
        camera_smoothing: 8.0,
        run_multiplier: 1.75,
        sneak_multiplier: 0.4
    }
}

// ============================================================
// Cone-light fragment shader (GLSL 330). Drawn as a full-screen
// darkness overlay — alpha is (1 - lightness), so unlit pixels are black.
// ============================================================

let CONE_LIGHT_FRAGMENT_SHADER = "
#version 330

#define MAX_EXTRA_LIGHTS 8

in vec2 fragTexCoord;
in vec4 fragColor;
out vec4 finalColor;

uniform vec2 player_pos;
uniform vec2 aim_dir;
uniform float cos_half_angle;
uniform float range;
uniform float ambient;
uniform float intensity;
uniform vec2 resolution;

uniform int extra_count;
uniform vec2  extras_pos[MAX_EXTRA_LIGHTS];
uniform vec2  extras_dir[MAX_EXTRA_LIGHTS];
uniform float extras_cos[MAX_EXTRA_LIGHTS];
uniform float extras_range[MAX_EXTRA_LIGHTS];
uniform float extras_intensity[MAX_EXTRA_LIGHTS];

float cone_contribution(vec2 world_pos, vec2 light_pos, vec2 light_dir,
                        float cos_half, float r, float i_intensity) {
    vec2 to_pixel = world_pos - light_pos;
    float dist = length(to_pixel);
    if (dist >= r) { return 0.0; }
    vec2 dir = to_pixel / max(dist, 0.0001);
    vec2 aim = normalize(light_dir);
    float edge = cos_half;
    float angular = smoothstep(edge - 0.004, edge + 0.004, dot(dir, aim));
    float radial = 1.0 - smoothstep(r * 0.15, r, dist);
    return angular * radial * i_intensity;
}

void main() {
    vec2 screen_pos = vec2(gl_FragCoord.x, resolution.y - gl_FragCoord.y);

    float total = cone_contribution(screen_pos, player_pos, aim_dir,
                                    cos_half_angle, range, intensity);

    for (int i = 0; i < extra_count && i < MAX_EXTRA_LIGHTS; i++) {
        total += cone_contribution(screen_pos, extras_pos[i], extras_dir[i],
                                   extras_cos[i], extras_range[i], extras_intensity[i]);
    }

    float light = clamp(ambient + total, 0.0, 1.0);
    float darkness_alpha = 1.0 - light;
    finalColor = vec4(0.0, 0.0, 0.0, darkness_alpha);
}
"

// ============================================================
// Entities
// ============================================================

struct Player {
    pos           // current physical translation (Vec2)
    prev          // previous physical translation (for interpolation)
    vel           // Vec2
    half          // half-extents (Vec2)
    aim           // Vec2 unit vector
    speed_mult    // 1.0 normal, run_multiplier, sneak_multiplier
    hp            // hit points — attacks subtract, respawn on 0
    iframes       // invulnerability timer (seconds) after being hit
}

struct Wall {
    center        // Vec2
    half          // Vec2
}

// Monster + Sentinel are below (ported from the original Rust).

// ============================================================
// Editor state — tool selection, drag target, selected entity
// ============================================================

struct Editor {
    tool              // TOOL_WALL / TOOL_MONSTER / TOOL_SENTINEL
    drag_start        // Vec2 world-space or null if not dragging
    selected_kind     // 0=none, 1=wall, 2=monster, 3=sentinel
    selected_index    // int
    status_text       // short message shown in the editor HUD
    tool_slot         // FFI i32 buffer so raygui toggle_group can read/write it
    lighting_enabled  // F1 toggles the cone shader overlay + shadow mesh
}

fn default_editor() {
    let slot = ffi/allocate(4)
    ffi/set-i32(slot, 0, TOOL_SELECT)
    Editor {
        tool: TOOL_SELECT,
        drag_start: null,
        selected_kind: 0,
        selected_index: 0 - 1,
        status_text: "ready",
        tool_slot: slot,
        lighting_enabled: true
    }
}

// ============================================================
// World state (immutable-style; each tick returns a new World)
// ============================================================

struct World {
    player
    walls         // list<Wall>
    monsters      // list<Monster>
    sentinels     // list<Sentinel>
    camera        // Vec2 center in world space
    tuning
    mode          // MODE_PLAYING or MODE_EDITING
    frame         // int
    editor        // Editor (only relevant in MODE_EDITING)
}

// ============================================================
// Input → desired direction
// ============================================================

fn read_desired_dir() {
    let mut dx = 0.0
    let mut dy = 0.0
    if r/is_key_down(r/KEY_W) || r/is_key_down(r/KEY_UP) { dy = dy + 1.0 }
    if r/is_key_down(r/KEY_S) || r/is_key_down(r/KEY_DOWN) { dy = dy - 1.0 }
    if r/is_key_down(r/KEY_A) || r/is_key_down(r/KEY_LEFT) { dx = dx - 1.0 }
    if r/is_key_down(r/KEY_D) || r/is_key_down(r/KEY_RIGHT) { dx = dx + 1.0 }
    v/normalize_or_zero(v/make(dx, dy))
}

fn read_speed_mult(tuning) {
    let sneak = r/is_key_down(r/KEY_LEFT_CONTROL) || r/is_key_down(r/KEY_RIGHT_CONTROL)
    let run = r/is_key_down(r/KEY_LEFT_SHIFT) || r/is_key_down(r/KEY_RIGHT_SHIFT)
    if sneak { tuning.sneak_multiplier }
    else if run { tuning.run_multiplier }
    else { 1.0 }
}

// ============================================================
// Physics
// ============================================================

// Move one step toward target velocity, clamped by the allowed accel/friction.
fn approach_velocity(cur, target, rate, dt) {
    let delta = v/sub(target, cur)
    let max_step = rate * dt
    let len = v/length(delta)
    if len <= max_step { target }
    else { v/add(cur, v/scale(v/normalize_or_zero(delta), max_step)) }
}

// Resolve AABB collision by axis — returns new position and zeroed velocity components
// via a {pos, vel} struct.
struct Resolve {
    pos
    vel
}

fn resolve_collision(pos, half, delta, walls, vel) {
    let eps = 0.001
    let mut px = pos.x + delta.x
    let mut vx = vel.x
    let mut i = 0
    while i < length(walls) {
        let w = walls[i]
        if v/aabb_overlap(v/make(px, pos.y), half, w.center, w.half) {
            if delta.x > 0.0 {
                px = w.center.x - w.half.x - half.x - eps
            } else if delta.x < 0.0 {
                px = w.center.x + w.half.x + half.x + eps
            }
            vx = 0.0
        }
        i = i + 1
    }
    let mut py = pos.y + delta.y
    let mut vy = vel.y
    let mut j = 0
    while j < length(walls) {
        let w = walls[j]
        if v/aabb_overlap(v/make(px, py), half, w.center, w.half) {
            if delta.y > 0.0 {
                py = w.center.y - w.half.y - half.y - eps
            } else if delta.y < 0.0 {
                py = w.center.y + w.half.y + half.y + eps
            }
            vy = 0.0
        }
        j = j + 1
    }
    Resolve { pos: v/make(px, py), vel: v/make(vx, vy) }
}

fn advance_player(player, tuning, walls, desired, speed_mult, dt) {
    let target = v/scale(desired, tuning.max_speed * speed_mult)
    let rate = if v/length_sq(desired) < 0.0001 { tuning.friction } else { tuning.accel }
    let new_vel = approach_velocity(player.vel, target, rate, dt)
    let move_delta = v/scale(new_vel, dt)
    let res = resolve_collision(player.pos, player.half, move_delta, walls, new_vel)
    Player {
        pos: res.pos,
        prev: player.pos,
        vel: res.vel,
        half: player.half,
        aim: player.aim,
        speed_mult: speed_mult,
        hp: player.hp,
        iframes: if player.iframes > 0.0 { player.iframes - dt } else { 0.0 }
    }
}

// ============================================================
// Camera
// ============================================================

fn update_camera(camera, player_pos, smoothing, dt) {
    // alpha = 1 - exp(-k*dt) — exponential approach
    if smoothing <= 0.0 {
        player_pos
    } else {
        let alpha = 1.0 - exp(0.0 - smoothing * dt)
        v/lerp(camera, player_pos, alpha)
    }
}

// Convert world coordinates to screen coordinates given the camera.
fn world_to_screen(p, camera) {
    v/make(p.x - camera.x + 0.5 * to-float(r/screen_width()),
           0.5 * to-float(r/screen_height()) - (p.y - camera.y))
}

fn screen_to_world(sx, sy, camera) {
    v/make(to-float(sx) - 0.5 * to-float(r/screen_width()) + camera.x,
           camera.y + 0.5 * to-float(r/screen_height()) - to-float(sy))
}

// ============================================================
// Rendering helpers (all take world-space then apply camera)
// ============================================================

fn draw_world_rect(center, half, color, camera) {
    let s = world_to_screen(center, camera)
    let x = to-int(s.x - half.x)
    let y = to-int(s.y - half.y)
    let w = to-int(2.0 * half.x)
    let h = to-int(2.0 * half.y)
    r/draw_rectangle(x, y, w, h, color)
}

fn draw_world_rect_lines(center, half, color, camera) {
    let s = world_to_screen(center, camera)
    let x = to-int(s.x - half.x)
    let y = to-int(s.y - half.y)
    let w = to-int(2.0 * half.x)
    let h = to-int(2.0 * half.y)
    r/draw_rectangle_lines(x, y, w, h, color)
}

fn draw_wall(wall, camera) {
    // Top face (light-gray) and front face (darker) for fake 2.5D depth.
    let top_color = r/rgb(148, 140, 128)
    let front_color = r/rgb(72, 66, 62)
    // Front face sits below the wall top in world coords.
    let front_center = v/make(wall.center.x, wall.center.y - wall.half.y - WALL_HEIGHT * 0.5)
    let front_half = v/make(wall.half.x, WALL_HEIGHT * 0.5)
    draw_world_rect(front_center, front_half, front_color, camera)
    draw_world_rect_lines(front_center, front_half, r/rgb(25, 22, 20), camera)
    draw_world_rect(wall.center, wall.half, top_color, camera)
    draw_world_rect_lines(wall.center, wall.half, r/rgb(25, 22, 20), camera)
}

fn draw_player(player, camera) {
    let body = r/rgb(115, 235, 140)
    draw_world_rect(player.pos, player.half, body, camera)
    draw_world_rect_lines(player.pos, player.half, r/WHITE, camera)
}

// ============================================================
// Monster (LOS + wander AI)
