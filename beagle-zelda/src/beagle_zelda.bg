}

fn default_sentinel(pos) {
    Sentinel {
        pos: pos,
        prev: pos,
        vel: v/ZERO,
        half: v/make(14.0, 14.0),
        light_range: 350.0,
        light_half_angle_deg: 18.0,
        light_intensity: 1.5,
        speed: 60.0,
        attack_reach: 28.0,
        sweep_speed: 40.0,
        aim_angle: 0.0,
        sweep_dir: 1.0,
