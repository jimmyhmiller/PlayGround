}

// ============================================================
// Default level (used until levels/level.txt is saved)
// ============================================================

fn default_walls() {
    [
        Wall { center: v/make(0.0 - 300.0, 150.0), half: v/make(120.0, 20.0) },
        Wall { center: v/make(250.0, 0.0 - 50.0), half: v/make(30.0, 110.0) },
        Wall { center: v/make(0.0 - 150.0, 0.0 - 220.0), half: v/make(160.0, 20.0) },
        Wall { center: v/make(420.0, 220.0), half: v/make(60.0, 60.0) },
        Wall { center: v/make(0.0 - 450.0, 0.0 - 40.0), half: v/make(20.0, 130.0) }
    ]
}

// ============================================================
// Enemy AI helpers (LOS, random)
// ============================================================

// xorshift32 PRNG kept in an atom — module-level mutable globals aren't allowed.
let rng_state = atom(2463534242)

// Current FPS cap. 60 at startup; F2 toggles between 60 and uncapped (0).
// Held in an atom so we don't have to thread it through the World.
let fps_cap = atom(60)

fn next_rand() {
    swap!(rng_state, fn(x) {
        let mut v = x
        v = v ^ (v << 13)
        v = v ^ (v >> 17)
        v = v ^ (v << 5)
        v & 4294967295
    })
    deref(rng_state)
}

fn rand_float_01() {
    to-float(next_rand()) / 4294967296.0
}

fn rand_range(lo, hi) {
    lo + rand_float_01() * (hi - lo)
}

// Segment-blocked test: is there any wall between `from` and `to`?
fn segment_blocked(from, to, walls) {
    let dx = to.x - from.x
    let dy = to.y - from.y
    let len = sqrt(dx * dx + dy * dy)
    if len < 0.0001 {
        false
    } else {
        let dir = v/make(dx / len, dy / len)
        let mut i = 0
        let mut blocked = false
        while i < length(walls) && !blocked {
            let w = walls[i]
            // Build 4 segments for the wall
            let tl = v/make(w.center.x - w.half.x, w.center.y + w.half.y)
            let tr = v/make(w.center.x + w.half.x, w.center.y + w.half.y)
            let br = v/make(w.center.x + w.half.x, w.center.y - w.half.y)
            let bl = v/make(w.center.x - w.half.x, w.center.y - w.half.y)
            let t1 = ray_segment_hit(from, dir, tl, tr)
            let t2 = ray_segment_hit(from, dir, tr, br)
            let t3 = ray_segment_hit(from, dir, br, bl)
            let t4 = ray_segment_hit(from, dir, bl, tl)
            if (t1 > 0.0 && t1 < len) || (t2 > 0.0 && t2 < len) ||
               (t3 > 0.0 && t3 < len) || (t4 > 0.0 && t4 < len) {
                blocked = true
            }
            i = i + 1
        }
        blocked
    }
}

// ============================================================
// Monster AI
// ============================================================

let MONSTER_ALERT_TIMEOUT = 2.5

fn advance_monster(m, player_pos, walls, dt) {
    let to_player = v/sub(player_pos, m.pos)
    let dist = v/length(to_player)
    let in_range = dist < m.detection_range && dist > 0.1
    let has_los = in_range && !segment_blocked(m.pos, player_pos, walls)

    // Update notice accumulator / alert state.
    let mut has_seen = m.has_seen
    let mut time_since_los = m.time_since_los
    let mut notice_acc = m.notice_acc
    let mut notice_threshold = m.notice_threshold
    if has_los {
        if has_seen {
            time_since_los = 0.0
        } else {
            notice_acc = notice_acc + dt
            if notice_acc >= notice_threshold {
                has_seen = true
                time_since_los = 0.0
            }
        }
    } else {
        notice_acc = 0.0
        if has_seen {
            time_since_los = time_since_los + dt
            if (!in_range) || time_since_los > MONSTER_ALERT_TIMEOUT {
                has_seen = false
                notice_threshold = rand_range(0.3, 1.5)
            }
        }
    }

    // Compute desired velocity.
    let mut vx = 0.0
    let mut vy = 0.0
    let mut wander_dir = m.wander_dir
    let mut wander_timer = m.wander_timer
    if has_los && has_seen {
        let dir = v/normalize_or_zero(to_player)
        vx = dir.x * m.speed
        vy = dir.y * m.speed
    } else {
        // Wander when calm.
        wander_timer = wander_timer - dt
        if wander_timer <= 0.0 {
            if rand_float_01() < 0.3 {
                wander_dir = v/ZERO
                wander_timer = rand_range(1.0, 3.0)
            } else {
                let angle = rand_float_01() * 2.0 * 3.14159265
                wander_dir = v/from_angle(angle)
                wander_timer = rand_range(1.5, 4.0)
            }
        }
        vx = wander_dir.x * m.speed * 0.3
        vy = wander_dir.y * m.speed * 0.3
    }

    let vel = v/make(vx, vy)
    let delta = v/scale(vel, dt)
    let res = resolve_collision(m.pos, m.half, delta, walls, vel)

    Monster {
        pos: res.pos,
        prev: m.pos,
        vel: res.vel,
        half: m.half,
        speed: m.speed,
        detection_range: m.detection_range,
        attack_reach: m.attack_reach,
        strength: m.strength,
        has_seen: has_seen,
        time_since_los: time_since_los,
        notice_acc: notice_acc,
        notice_threshold: notice_threshold,
        wander_dir: wander_dir,
        wander_timer: wander_timer
    }
}

fn advance_all_monsters(monsters, player_pos, walls, dt) {
    let mut result = []
    let mut i = 0
    while i < length(monsters) {
        result = push(result, advance_monster(monsters[i], player_pos, walls, dt))
        i = i + 1
    }
    result
}

fn draw_monster(m, camera) {
    let body = if m.has_seen { r/rgb(255, 70, 70) } else { r/rgb(180, 60, 60) }
    draw_world_rect(m.pos, m.half, body, camera)
    draw_world_rect_lines(m.pos, m.half, r/rgb(40, 15, 15), camera)
}

// ============================================================
// Sentinel AI
// ============================================================

fn advance_sentinel(s, player_pos, walls, dt) {
    let deg2rad = 3.14159265 / 180.0
    let to_player = v/sub(player_pos, s.pos)
    let dist = v/length(to_player)
    let aim_dir = v/from_angle(s.aim_angle)

    let in_cone =
        dist < s.light_range &&
        dist > 0.1 &&
        (v/dot(v/scale(to_player, 1.0 / dist), aim_dir) > cos(s.light_half_angle_deg * deg2rad)) &&
        !segment_blocked(s.pos, player_pos, walls)

    let mut vx = 0.0
    let mut vy = 0.0
    let mut new_angle = s.aim_angle
    let mut new_sweep = s.sweep_dir
    let mut new_alerted = s.alerted
    if in_cone {
        new_alerted = true
        new_angle = atan2(to_player.y, to_player.x)
        let dir = v/normalize_or_zero(to_player)
        vx = dir.x * s.speed
        vy = dir.y * s.speed
    } else if s.alerted {
        new_alerted = false
    } else {
        new_angle = s.aim_angle + s.sweep_speed * deg2rad * s.sweep_dir * dt
        if v/abs_f(sin(new_angle)) < 0.01 || rand_float_01() < 0.002 {
            new_sweep = 0.0 - s.sweep_dir
        }
    }

    let vel = v/make(vx, vy)
    let delta = v/scale(vel, dt)
    let res = resolve_collision(s.pos, s.half, delta, walls, vel)

    Sentinel {
        pos: res.pos,
        prev: s.pos,
        vel: res.vel,
        half: s.half,
        light_range: s.light_range,
        light_half_angle_deg: s.light_half_angle_deg,
        light_intensity: s.light_intensity,
        speed: s.speed,
        attack_reach: s.attack_reach,
        sweep_speed: s.sweep_speed,
        aim_angle: new_angle,
        sweep_dir: new_sweep,
        alerted: new_alerted
    }
}

fn advance_all_sentinels(sentinels, player_pos, walls, dt) {
    let mut result = []
    let mut i = 0
    while i < length(sentinels) {
        result = push(result, advance_sentinel(sentinels[i], player_pos, walls, dt))
        i = i + 1
    }
    result
}

fn draw_sentinel(s, camera) {
    let body = if s.alerted { r/rgb(255, 210, 80) } else { r/rgb(210, 170, 50) }
    draw_world_rect(s.pos, s.half, body, camera)
    draw_world_rect_lines(s.pos, s.half, r/rgb(30, 25, 10), camera)
}

// ============================================================
// Shadow geometry — cast rays from light source to wall corners
// (+/- EPS) and 16 filler angles, sort hits by angle, emit black
// quads from each hit outward to `far_dist` pixels away. Those
// quads cover the parts of the light overlay that should remain
// dark even when inside the cone.
// ============================================================

let SHADOW_FAR_DIST = 5000.0
let SHADOW_EPS = 0.0001
let SHADOW_FILLER_RAYS = 16
let SHADOW_TOP_REVEAL = 20.0       // wall-top fudge so shadow starts past corner

struct RaySegHit {
    hit
    t
}

// Ray r(t) = origin + t*dir  vs.  segment a..b. Returns t or -1.0 if no hit.
fn ray_segment_hit(origin, dir, a, b) {
    let sx = b.x - a.x
    let sy = b.y - a.y
    let denom = dir.x * sy - dir.y * sx
    if v/abs_f(denom) < 0.000001 {
        0.0 - 1.0
    } else {
        let diffx = a.x - origin.x
        let diffy = a.y - origin.y
        let t = (diffx * sy - diffy * sx) / denom
        let u = (diffx * dir.y - diffy * dir.x) / denom
        if t >= 0.0 && u >= 0.0 && u <= 1.0 { t } else { 0.0 - 1.0 }
    }
}

// Given a list of wall segments (each is {a: Vec2, b: Vec2}), cast a ray and
// return the nearest positive t, or SHADOW_FAR_DIST if no hit.
struct Segment {
    a
    b
}

fn cast_ray(origin, dir, segments) {
    let mut best = SHADOW_FAR_DIST
    let mut i = 0
    while i < length(segments) {
        let s = segments[i]
        let t = ray_segment_hit(origin, dir, s.a, s.b)
        if t > 0.0 && t < best { best = t }
        i = i + 1
    }
    best
}

struct AngleHit {
    angle
    hit
}

// Insertion-sort a list of AngleHit by .angle (~80 items, trivial cost).
fn sort_angle_hits(hits) {
    let mut result = []
    let mut i = 0
    while i < length(hits) {
        let cur = hits[i]
        let mut j = 0
        let mut inserted = false
        let mut next = []
        while j < length(result) {
            let existing = result[j]
            if (!inserted) && cur.angle < existing.angle {
                next = push(next, cur)
                inserted = true
            }
            next = push(next, existing)
            j = j + 1
        }
        if !inserted { next = push(next, cur) }
        result = next
        i = i + 1
    }
    result
}

// Build segments (4 per wall) and corner points (4 per wall) in screen space.
struct ShadowInput {
    segments
    corners
}

fn build_shadow_input(world) {
    let mut segs = []
    let mut corners = []
    let mut i = 0
    while i < length(world.walls) {
        let w = world.walls[i]
        // Convert the 4 world corners to screen space. World y is up, screen y is down,
        // so top-left/bottom-right in screen space comes from different world corners.
        let cw = world_to_screen(v/make(w.center.x, w.center.y), world.camera)
        let hx = w.half.x
        let hy = w.half.y
        let tl = v/make(cw.x - hx, cw.y - hy)
        let tr = v/make(cw.x + hx, cw.y - hy)
        let br = v/make(cw.x + hx, cw.y + hy)
        let bl = v/make(cw.x - hx, cw.y + hy)
        segs = push(segs, Segment { a: tl, b: tr })
        segs = push(segs, Segment { a: tr, b: br })
        segs = push(segs, Segment { a: br, b: bl })
        segs = push(segs, Segment { a: bl, b: tl })
        corners = push(corners, tl)
        corners = push(corners, tr)
        corners = push(corners, br)
        corners = push(corners, bl)
        i = i + 1
    }
    ShadowInput { segments: segs, corners: corners }
}

fn draw_shadow_geometry(world) {
    if length(world.walls) == 0 {
        0
    } else {
        let input = build_shadow_input(world)
        let segments = input.segments
        let corners = input.corners
        let light = world_to_screen(world.player.pos, world.camera)

        // Collect all the angles: 3 per corner (a-EPS, a, a+EPS) plus filler rays.
        let mut angles = []
        let mut i = 0
        while i < length(corners) {
            let c = corners[i]
            let a = atan2(c.y - light.y, c.x - light.x)
            angles = push(angles, a - SHADOW_EPS)
            angles = push(angles, a)
            angles = push(angles, a + SHADOW_EPS)
            i = i + 1
        }
        let pi = 3.14159265
        let two_pi = 2.0 * pi
        let mut k = 0
        while k < SHADOW_FILLER_RAYS {
            let a = 0.0 - pi + to-float(k) / to-float(SHADOW_FILLER_RAYS) * two_pi
            angles = push(angles, a)
            k = k + 1
        }

        // Cast each ray, collect (angle, hit_point).
        let mut hits = []
        let mut j = 0
        while j < length(angles) {
            let a = angles[j]
            let dir = v/from_angle(a)
            let t = cast_ray(light, dir, segments)
            let hp = v/make(light.x + dir.x * t, light.y + dir.y * t)
            hits = push(hits, AngleHit { angle: a, hit: hp })
            j = j + 1
        }

        let sorted = sort_angle_hits(hits)

        // Emit quads between each adjacent pair of hits.
        let n = length(sorted)
        r/gl_begin(r/RL_TRIANGLES)
        r/gl_color_4ub(0, 0, 0, 255)
        let mut m = 0
        while m < n {
            let ii = sorted[m]
            let next_idx = if m + 1 >= n { 0 } else { m + 1 }
            let jj = sorted[next_idx]
            let di = v/from_angle(ii.angle)
            let dj = v/from_angle(jj.angle)
            // Pull the near edge a little outward so the wall top isn't fully masked.
            let pi_pt = v/make(ii.hit.x + di.x * SHADOW_TOP_REVEAL,
                               ii.hit.y + di.y * SHADOW_TOP_REVEAL)
            let pj_pt = v/make(jj.hit.x + dj.x * SHADOW_TOP_REVEAL,
                               jj.hit.y + dj.y * SHADOW_TOP_REVEAL)
            let fi = v/make(light.x + di.x * SHADOW_FAR_DIST,
                            light.y + di.y * SHADOW_FAR_DIST)
            let fj = v/make(light.x + dj.x * SHADOW_FAR_DIST,
                            light.y + dj.y * SHADOW_FAR_DIST)
            // Two triangles form the quad (pi_pt, pj_pt, fj, fi).
            r/gl_vertex_2f(pi_pt.x, pi_pt.y)
            r/gl_vertex_2f(pj_pt.x, pj_pt.y)
            r/gl_vertex_2f(fj.x, fj.y)

            r/gl_vertex_2f(pi_pt.x, pi_pt.y)
            r/gl_vertex_2f(fj.x, fj.y)
            r/gl_vertex_2f(fi.x, fi.y)
            m = m + 1
        }
        r/gl_end()
        1
    }
}

// ============================================================
// Shader context — owns the shader and pre-allocated uniform buffers
// ============================================================

struct ScreenLight {
    pos_x
    pos_y
    dir_x
    dir_y
    cos_half
    range
    intensity
}

struct ShaderCtx {
    shader
    loc_player_pos
    loc_aim_dir
    loc_cos_half
    loc_range
    loc_ambient
    loc_intensity
    loc_resolution
    loc_extra_count
    loc_extras_pos
    loc_extras_dir
    loc_extras_cos
    loc_extras_range
    loc_extras_intensity
    buf_vec2
    buf_float
    buf_int
    buf_extras_pos
    buf_extras_dir
    buf_extras_cos
    buf_extras_range
    buf_extras_intensity
}

fn load_cone_light_shader() {
    let s = r/load_shader(null, CONE_LIGHT_FRAGMENT_SHADER)
    ShaderCtx {
        shader: s,
        loc_player_pos: r/shader_location(s, "player_pos"),
        loc_aim_dir: r/shader_location(s, "aim_dir"),
        loc_cos_half: r/shader_location(s, "cos_half_angle"),
        loc_range: r/shader_location(s, "range"),
        loc_ambient: r/shader_location(s, "ambient"),
        loc_intensity: r/shader_location(s, "intensity"),
        loc_resolution: r/shader_location(s, "resolution"),
        loc_extra_count: r/shader_location(s, "extra_count"),
        loc_extras_pos: r/shader_location(s, "extras_pos"),
        loc_extras_dir: r/shader_location(s, "extras_dir"),
        loc_extras_cos: r/shader_location(s, "extras_cos"),
        loc_extras_range: r/shader_location(s, "extras_range"),
        loc_extras_intensity: r/shader_location(s, "extras_intensity"),
        buf_vec2: ffi/allocate(8),
        buf_float: ffi/allocate(4),
        buf_int: ffi/allocate(4),
        buf_extras_pos: ffi/allocate(8 * MAX_EXTRA_LIGHTS),
        buf_extras_dir: ffi/allocate(8 * MAX_EXTRA_LIGHTS),
        buf_extras_cos: ffi/allocate(4 * MAX_EXTRA_LIGHTS),
        buf_extras_range: ffi/allocate(4 * MAX_EXTRA_LIGHTS),
        buf_extras_intensity: ffi/allocate(4 * MAX_EXTRA_LIGHTS)
    }
}

fn set_uniform_vec2(ctx, loc, x, y) {
    r/set_f32(ctx.buf_vec2, 0, x)
    r/set_f32(ctx.buf_vec2, 4, y)
    r/set_shader_value(ctx.shader, loc, ctx.buf_vec2, r/SHADER_UNIFORM_VEC2)
}
fn set_uniform_float(ctx, loc, x) {
    r/set_f32(ctx.buf_float, 0, x)
    r/set_shader_value(ctx.shader, loc, ctx.buf_float, r/SHADER_UNIFORM_FLOAT)
}
fn set_uniform_int(ctx, loc, x) {
    ffi/set-i32(ctx.buf_int, 0, x)
    r/set_shader_value(ctx.shader, loc, ctx.buf_int, r/SHADER_UNIFORM_INT)
}

fn upload_cone_uniforms(ctx, world, sentinel_screen_lights) {
    let tuning = world.tuning
    // macOS Retina: the shader's gl_FragCoord is in PHYSICAL framebuffer
    // pixels (e.g. 2560x1440) while our world_to_screen returns LOGICAL
    // window pixels (e.g. 1280x720). Scale everything the shader sees by the
    // render/window ratio so the light origin actually lands on the sprite.
    let rw = to-float(r/render_width())
    let rh = to-float(r/render_height())
    // Ratio between physical (render) and logical (window) pixels.
    let sx = rw / to-float(r/screen_width())
    let sy = rh / to-float(r/screen_height())
    let player_screen = world_to_screen(world.player.pos, world.camera)
    set_uniform_vec2(ctx, ctx.loc_player_pos, player_screen.x * sx, player_screen.y * sy)
    set_uniform_vec2(ctx, ctx.loc_aim_dir,
                     world.player.aim.x, 0.0 - world.player.aim.y)
    let deg2rad = 3.14159265 / 180.0
    set_uniform_float(ctx, ctx.loc_cos_half, cos(tuning.light_half_angle_deg * deg2rad))
    // Ranges are in pixels — scale to physical too.
    set_uniform_float(ctx, ctx.loc_range, tuning.light_range * sx)
    set_uniform_float(ctx, ctx.loc_ambient, tuning.ambient)
    set_uniform_float(ctx, ctx.loc_intensity, tuning.light_intensity)
    set_uniform_vec2(ctx, ctx.loc_resolution, rw, rh)

    let count = length(sentinel_screen_lights)
    let capped = if count > MAX_EXTRA_LIGHTS { MAX_EXTRA_LIGHTS } else { count }
    set_uniform_int(ctx, ctx.loc_extra_count, capped)
    let mut i = 0
    while i < capped {
        let e = sentinel_screen_lights[i]
        r/set_f32(ctx.buf_extras_pos, i * 8, e.pos_x * sx)
        r/set_f32(ctx.buf_extras_pos, i * 8 + 4, e.pos_y * sy)
        r/set_f32(ctx.buf_extras_dir, i * 8, e.dir_x)
        r/set_f32(ctx.buf_extras_dir, i * 8 + 4, e.dir_y)
        r/set_f32(ctx.buf_extras_cos, i * 4, e.cos_half)
        r/set_f32(ctx.buf_extras_range, i * 4, e.range * sx)
        r/set_f32(ctx.buf_extras_intensity, i * 4, e.intensity)
        i = i + 1
    }
    r/set_shader_value_v(ctx.shader, ctx.loc_extras_pos, ctx.buf_extras_pos,
                         r/SHADER_UNIFORM_VEC2, MAX_EXTRA_LIGHTS)
    r/set_shader_value_v(ctx.shader, ctx.loc_extras_dir, ctx.buf_extras_dir,
                         r/SHADER_UNIFORM_VEC2, MAX_EXTRA_LIGHTS)
    r/set_shader_value_v(ctx.shader, ctx.loc_extras_cos, ctx.buf_extras_cos,
                         r/SHADER_UNIFORM_FLOAT, MAX_EXTRA_LIGHTS)
    r/set_shader_value_v(ctx.shader, ctx.loc_extras_range, ctx.buf_extras_range,
                         r/SHADER_UNIFORM_FLOAT, MAX_EXTRA_LIGHTS)
    r/set_shader_value_v(ctx.shader, ctx.loc_extras_intensity, ctx.buf_extras_intensity,
                         r/SHADER_UNIFORM_FLOAT, MAX_EXTRA_LIGHTS)
}

// ============================================================
// Game loop — recursive tail call, no mutable globals
// ============================================================

fn initial_world() {
    let p = Player {
        pos: v/ZERO, prev: v/ZERO, vel: v/ZERO,
        half: v/make(14.0, 14.0),
        aim: v/UNIT_X,
        speed_mult: 1.0,
        hp: 5.0,
        iframes: 0.0
    }
    World {
        player: p,
        walls: default_walls(),
        monsters: [default_monster(v/make(400.0, 120.0)),
                   default_monster(v/make(0.0 - 380.0, 0.0 - 120.0))],
        sentinels: [default_sentinel(v/make(200.0, 0.0 - 340.0)),
                    default_sentinel(v/make(0.0 - 500.0, 240.0))],
        camera: v/ZERO,
        tuning: default_tuning(),
        mode: MODE_PLAYING,
        frame: 0,
        editor: default_editor()
    }
}

// World builder — 10 args is a lot, so a small helper keeps callers tidy.
fn with_world(w, player, walls, monsters, sentinels, camera, tuning, mode, editor) {
    World {
        player: player,
        walls: walls,
        monsters: monsters,
        sentinels: sentinels,
        camera: camera,
        tuning: tuning,
        mode: mode,
        frame: w.frame + 1,
        editor: editor
    }
}

fn update_aim(player, camera) {
    let mouse = screen_to_world(r/mouse_x(), r/mouse_y(), camera)
    let delta = v/sub(mouse, player.pos)
    if v/length_sq(delta) > 1.0 {
        Player {
            pos: player.pos, prev: player.prev, vel: player.vel,
            half: player.half, aim: v/normalize_or_zero(delta),
            speed_mult: player.speed_mult,
            hp: player.hp, iframes: player.iframes
        }
    } else {
        player
    }
}

// Monster attack system: any monster within its attack_reach of the player
// applies damage (if not in iframes). Damaged players respawn at origin.
// Pick a respawn point that is clear of every monster's reach and every
// wall's AABB. Falls back to (0, 0) if nothing better is found (shouldn't
// happen with the default level).
fn pick_respawn(player, monsters, walls) {
    // Spiral outward from origin in 40-px rings until we find a clear spot.
    let candidates = [
        v/make(0.0, 0.0),
        v/make(40.0, 0.0),  v/make(0.0 - 40.0, 0.0),
        v/make(0.0, 40.0),  v/make(0.0, 0.0 - 40.0),
        v/make(80.0, 0.0),  v/make(0.0 - 80.0, 0.0),
        v/make(0.0, 80.0),  v/make(0.0, 0.0 - 80.0),
        v/make(160.0, 0.0), v/make(0.0 - 160.0, 0.0)
    ]
    let mut chosen = v/ZERO
    let mut found = false
    let mut i = 0
    while i < length(candidates) && !found {
        let c = candidates[i]
        let mut clear = true
        let mut j = 0
        while j < length(monsters) && clear {
            if v/length(v/sub(c, monsters[j].pos)) < monsters[j].attack_reach + player.half.x + 8.0 {
                clear = false
            }
            j = j + 1
        }
        let mut k = 0
        while k < length(walls) && clear {
            if v/aabb_overlap(c, player.half, walls[k].center, walls[k].half) {
                clear = false
            }
            k = k + 1
        }
        if clear { chosen = c; found = true }
        i = i + 1
    }
    chosen
}

fn apply_monster_attacks(player, monsters, walls) {
    if player.iframes > 0.0 {
        player
    } else {
        let mut hp = player.hp
        let mut hit = false
        let mut i = 0
        while i < length(monsters) {
            let m = monsters[i]
            let d = v/length(v/sub(player.pos, m.pos))
            if d < m.attack_reach + player.half.x {
                hp = hp - m.strength
                hit = true
            }
            i = i + 1
        }
        if !hit {
            player
        } else if hp <= 0.0 {
            let spawn = pick_respawn(player, monsters, walls)
            Player {
                pos: spawn, prev: spawn, vel: v/ZERO,
                half: player.half, aim: player.aim,
                speed_mult: player.speed_mult,
                hp: 5.0, iframes: 2.0
            }
        } else {
            Player {
                pos: player.pos, prev: player.prev, vel: player.vel,
                half: player.half, aim: player.aim,
                speed_mult: player.speed_mult,
                hp: hp, iframes: 0.75
            }
        }
    }
}

fn playing_tick(world) {
    let tuning = world.tuning
    let dt = current_dt()
    let desired = read_desired_dir()
    let speed_mult = read_speed_mult(tuning)
    let player_a = advance_player(world.player, tuning, world.walls, desired, speed_mult, dt)
    // Update camera first so aim uses the same camera the renderer will use.
    let camera = update_camera(world.camera, player_a.pos, tuning.camera_smoothing, dt)
    let player_b = update_aim(player_a, camera)
    let monsters = advance_all_monsters(world.monsters, player_b.pos, world.walls, dt)
    let sentinels = advance_all_sentinels(world.sentinels, player_b.pos, world.walls, dt)
    let player_c = apply_monster_attacks(player_b, monsters, world.walls)
    with_world(world, player_c, world.walls, monsters, sentinels, camera,
               world.tuning, world.mode, world.editor)
}

// ============================================================
// Y-sort — draw entities in order of their "ground y" so things in
// front properly overlap things behind (fake 2.5D depth).
// ============================================================
//
// Each drawable is tagged (1=wall, 2=monster, 3=sentinel, 4=player)
// and paired with a ground_y key. We insertion-sort by key descending
// (highest world-y drawn first = furthest back) then dispatch by kind.

struct Drawable {
    kind
    ground_y
    index     // index into the corresponding world list
}

fn ysort_drawables(world) {
    let mut items = []
    let mut i = 0
    while i < length(world.walls) {
        let w = world.walls[i]
        // Sort the whole wall (top + front face) by the top face's south edge.
        // Using the front face's south edge instead makes walls sort *in front*
        // of any player standing south of them, so the wall is drawn on top of
        // the player and it looks like collision isn't working.
        let gy = w.center.y - w.half.y
        items = push(items, Drawable { kind: 1, ground_y: gy, index: i })
        i = i + 1
    }
    let mut m = 0
    while m < length(world.monsters) {
        let mm = world.monsters[m]
        items = push(items, Drawable { kind: 2, ground_y: mm.pos.y - mm.half.y, index: m })
        m = m + 1
    }
    let mut s = 0
    while s < length(world.sentinels) {
        let ss = world.sentinels[s]
        items = push(items, Drawable { kind: 3, ground_y: ss.pos.y - ss.half.y, index: s })
        s = s + 1
    }
    let p = world.player
    items = push(items, Drawable { kind: 4, ground_y: p.pos.y - p.half.y, index: 0 })

    // Insertion sort descending by ground_y (small N, fine).
    let mut sorted = []
    let mut j = 0
    while j < length(items) {
        let cur = items[j]
        let mut k = 0
        let mut inserted = false
        let mut next = []
        while k < length(sorted) {
            let ex = sorted[k]
            if (!inserted) && cur.ground_y > ex.ground_y {
                next = push(next, cur)
                inserted = true
            }
            next = push(next, ex)
            k = k + 1
        }
        if !inserted { next = push(next, cur) }
        sorted = next
        j = j + 1
    }
    sorted
}

fn draw_scene_ysorted(world) {
    let items = ysort_drawables(world)
    let mut i = 0
    while i < length(items) {
        let it = items[i]
        if it.kind == 1 { draw_wall(world.walls[it.index], world.camera) }
        else if it.kind == 2 { draw_monster(world.monsters[it.index], world.camera) }
        else if it.kind == 3 { draw_sentinel(world.sentinels[it.index], world.camera) }
        else { draw_player(world.player, world.camera) }
        i = i + 1
    }
}

// Build the per-frame list of sentinel extra lights in screen space.
fn sentinel_screen_lights(world) {
    let deg2rad = 3.14159265 / 180.0
    let mut result = []
    let mut i = 0
    while i < length(world.sentinels) {
        let s = world.sentinels[i]
        let screen = world_to_screen(s.pos, world.camera)
        result = push(result, ScreenLight {
            pos_x: screen.x,
            pos_y: screen.y,
            dir_x: cos(s.aim_angle),
            dir_y: 0.0 - sin(s.aim_angle),  // y-flip for screen coords
            cos_half: cos(s.light_half_angle_deg * deg2rad),
            range: s.light_range,
            intensity: s.light_intensity
        })
        i = i + 1
    }
    result
}

// ============================================================
// Editor rendering — scene view without lighting + raygui sidebar panel.
// ============================================================

fn draw_editor_selection(world) {
    let ed = world.editor
    if ed.selected_kind == 1 && ed.selected_index < length(world.walls) {
        let w = world.walls[ed.selected_index]
        draw_world_rect_lines(w.center,
                              v/make(w.half.x + 3.0, w.half.y + 3.0),
                              r/YELLOW, world.camera)
    } else if ed.selected_kind == 2 && ed.selected_index < length(world.monsters) {
        let m = world.monsters[ed.selected_index]
        draw_world_rect_lines(m.pos,
                              v/make(m.half.x + 4.0, m.half.y + 4.0),
                              r/YELLOW, world.camera)
    } else if ed.selected_kind == 3 && ed.selected_index < length(world.sentinels) {
        let s = world.sentinels[ed.selected_index]
        draw_world_rect_lines(s.pos,
                              v/make(s.half.x + 4.0, s.half.y + 4.0),
                              r/YELLOW, world.camera)
    } else {
        0
    }
}

fn draw_editor_drag_preview(world) {
    let ed = world.editor
    if ed.drag_start != null && ed.tool == TOOL_WALL {
        let mouse = screen_to_world(r/mouse_x(), r/mouse_y(), world.camera)
        let cx = (ed.drag_start.x + mouse.x) * 0.5
        let cy = (ed.drag_start.y + mouse.y) * 0.5
        let hx = v/abs_f(ed.drag_start.x - mouse.x) * 0.5
        let hy = v/abs_f(ed.drag_start.y - mouse.y) * 0.5
        draw_world_rect_lines(v/make(cx, cy), v/make(hx, hy),
                              r/rgb(120, 200, 255), world.camera)
    } else { 0 }
}

fn draw_editor_grid(world) {
    // A 64-pixel grid drawn as faint lines, anchored by the camera.
    let step = 64.0
    let cam = world.camera
    let half_w = 0.5 * to-float(r/screen_width())
    let half_h = 0.5 * to-float(r/screen_height())
    let left = cam.x - half_w
    let right = cam.x + half_w
    let bottom = cam.y - half_h
    let top = cam.y + half_h
    let faint = r/color(255, 255, 255, 20)
    let mut x = floor(left / step) * step
    while x < right {
        let s1 = world_to_screen(v/make(x, bottom), cam)
        let s2 = world_to_screen(v/make(x, top), cam)
        r/draw_line(to-int(s1.x), to-int(s1.y), to-int(s2.x), to-int(s2.y), faint)
        x = x + step
    }
    let mut y = floor(bottom / step) * step
    while y < top {
        let s1 = world_to_screen(v/make(left, y), cam)
        let s2 = world_to_screen(v/make(right, y), cam)
        r/draw_line(to-int(s1.x), to-int(s1.y), to-int(s2.x), to-int(s2.y), faint)
        y = y + step
    }
}

// The right-hand raygui panel. Returns the (possibly updated) Tuning.
fn draw_editor_panel(world, ui_bufs) {
    let panel_x = to-float(r/screen_width()) - 260.0
    r/panel(panel_x, 0.0, 260.0, to-float(r/screen_height()), "Editor")

    // Status.
    r/label(panel_x + 10.0, 30.0, 240.0, 20.0,
            "tool + tune, Tab plays, Del removes")
    r/label(panel_x + 10.0, 52.0, 240.0, 20.0, world.editor.status_text)

    // Tool toggle group — slot is an i32 buffer we persist in the Editor struct.
    // Per-toggle width: 4 toggles must fit in (panel_w - 20) = 240 px, so each
    // toggle is 55 px wide (4*55 = 220 < 240). The label at y=78 cues users.
    r/label(panel_x + 10.0, 78.0, 80.0, 20.0, "Tool:")
    r/toggle_group(panel_x + 10.0, 98.0, 55.0, 26.0,
                   "Select;Wall;Monster;Sentinel", world.editor.tool_slot)

    // Slider helper closures are awkward — do them inline.
    let sx = panel_x + 80.0
    let sw = 150.0
    let mut y = 140.0
    r/slider(sx, y, sw, 18.0, "speed",   "", ui_bufs.max_speed, 0.0, 1000.0); y = y + 24.0
    r/slider(sx, y, sw, 18.0, "accel",   "", ui_bufs.accel, 0.0, 10000.0); y = y + 24.0
    r/slider(sx, y, sw, 18.0, "frict",   "", ui_bufs.friction, 0.0, 10000.0); y = y + 24.0
    r/slider(sx, y, sw, 18.0, "light r", "", ui_bufs.light_range, 50.0, 2000.0); y = y + 24.0
    r/slider(sx, y, sw, 18.0, "cone °",  "", ui_bufs.light_half_angle_deg, 1.0, 180.0); y = y + 24.0
    r/slider(sx, y, sw, 18.0, "lightI",  "", ui_bufs.light_intensity, 0.0, 4.0); y = y + 24.0
    r/slider(sx, y, sw, 18.0, "ambient", "", ui_bufs.ambient, 0.0, 1.0); y = y + 24.0
    r/slider(sx, y, sw, 18.0, "cam smth","", ui_bufs.camera_smoothing, 0.0, 30.0); y = y + 24.0
    r/slider(sx, y, sw, 18.0, "run x",   "", ui_bufs.run_mult, 1.0, 4.0); y = y + 24.0
    r/slider(sx, y, sw, 18.0, "sneak x", "", ui_bufs.sneak_mult, 0.1, 1.0); y = y + 30.0

    // Save / Load.
    let save_pressed = r/button(panel_x + 10.0, y, 110.0, 28.0, "Save") != 0
    let load_pressed = r/button(panel_x + 130.0, y, 110.0, 28.0, "Load") != 0

    SaveLoadResult {
        save: save_pressed,
        load: load_pressed,
        new_tuning: read_tuning_from_ui(ui_bufs)
    }
}

struct SaveLoadResult {
    save
    load
    new_tuning
}

fn render_editor(world, shader_ctx, ui_bufs) {
    r/begin_drawing()
    r/clear_background(r/rgb(25, 30, 38))

    draw_editor_grid(world)

    let mut i = 0
    while i < length(world.walls) {
        draw_wall(world.walls[i], world.camera)
        i = i + 1
    }
    let mut mi = 0
    while mi < length(world.monsters) {
        draw_monster(world.monsters[mi], world.camera)
        mi = mi + 1
    }
    let mut si = 0
    while si < length(world.sentinels) {
        draw_sentinel(world.sentinels[si], world.camera)
        si = si + 1
    }
    draw_player(world.player, world.camera)

    draw_editor_selection(world)
    draw_editor_drag_preview(world)

    r/draw_text("EDITING — Tab=play  WASD=pan  LMB=place  RMB=select  Del=delete",
                10, 10, 18, r/rgb(230, 215, 140))

    let ui = draw_editor_panel(world, ui_bufs)

    r/end_drawing()
    ui
}

fn render_world(world, shader_ctx) {
    r/begin_drawing()
    r/clear_background(r/rgb(18, 20, 28))

    // Scene — all drawables Y-sorted so things in front overlap things behind.
    draw_scene_ysorted(world)

    // Cone-light darkness overlay + shadow mesh. Toggleable via F1 for debugging.
    if world.editor.lighting_enabled {
        let lights = sentinel_screen_lights(world)
        upload_cone_uniforms(shader_ctx, world, lights)
        r/begin_shader_mode(shader_ctx.shader)
        r/draw_rectangle(0, 0, r/screen_width(), r/screen_height(), r/WHITE)
        r/end_shader_mode()
        draw_shadow_geometry(world)
    }

    // Debug overlays — outline boxes + aim lines for player and each sentinel.
    // Only shown when lighting is toggled off via F1; the cone itself is the
    // gameplay cue in normal play.
    if !world.editor.lighting_enabled {
        draw_player_indicator(world)
        draw_sentinel_indicators(world)
    }

    // HUD on top of lighting.
    r/draw_text("WASD/arrows move  Shift=run  Ctrl=sneak  Tab=edit  ESC=quit",
                10, 10, 18, r/LIGHTGRAY)
    r/draw_fps(10, 35)

    // HP bar.
    let hp_w = to-int(world.player.hp * 20.0)
    let hp_y = r/screen_height() - 30
    r/draw_rectangle(10, hp_y, 100, 16, r/rgb(60, 20, 20))
    if hp_w > 0 { r/draw_rectangle(10, hp_y, hp_w, 16, r/rgb(220, 60, 60)) }
    r/draw_rectangle_lines(10, hp_y, 100, 16, r/WHITE)
    r/draw_text("HP", 115, hp_y - 2, 18, r/WHITE)

    r/end_drawing()
}

// Contrast outline + aim-direction line rendered after the shadow overlay
// so the player is always findable regardless of lighting state.
fn draw_player_indicator(world) {
    let p = world.player
    let ps = world_to_screen(p.pos, world.camera)
    let hx = p.half.x
    let hy = p.half.y
    let outline = if p.iframes > 0.0 { r/rgb(255, 220, 120) } else { r/WHITE }
    r/draw_rectangle_lines(to-int(ps.x - hx), to-int(ps.y - hy),
                           to-int(2.0 * hx), to-int(2.0 * hy), outline)
    r/draw_circle(to-int(ps.x), to-int(ps.y), 2.0, outline)
    // Aim direction — world y is up, screen y is down, so negate y.
    let tip_x = ps.x + p.aim.x * 28.0
    let tip_y = ps.y - p.aim.y * 28.0
    r/draw_line(to-int(ps.x), to-int(ps.y), to-int(tip_x), to-int(tip_y), outline)
}

// Aim line + position dot for each sentinel, drawn on top of the overlay.
// Makes it unambiguous where a sentinel is looking and confirms the uploaded
// cone-light origin matches the sprite.
fn draw_sentinel_indicators(world) {
    let mut i = 0
    while i < length(world.sentinels) {
        let s = world.sentinels[i]
        let sp = world_to_screen(s.pos, world.camera)
        let outline = if s.alerted { r/rgb(255, 120, 60) } else { r/rgb(230, 200, 120) }
        r/draw_rectangle_lines(to-int(sp.x - s.half.x), to-int(sp.y - s.half.y),
                               to-int(2.0 * s.half.x), to-int(2.0 * s.half.y), outline)
        // Aim direction. aim_angle is in world coords — flip y for screen.
        let tip_x = sp.x + cos(s.aim_angle) * 40.0
        let tip_y = sp.y - sin(s.aim_angle) * 40.0
        r/draw_line(to-int(sp.x), to-int(sp.y), to-int(tip_x), to-int(tip_y), outline)
        i = i + 1
    }
}

// ============================================================
// Editor UI state — persistent buffers the raygui widgets read/write.
// Created once at startup; mutated in-place each frame.
// ============================================================

struct UiBuffers {
    max_speed
    accel
    friction
    light_range
    light_half_angle_deg
    light_intensity
    ambient
    camera_smoothing
    run_mult
    sneak_mult
}

fn alloc_ui_buffers(t) {
    let a = ffi/allocate(4)
    let b = ffi/allocate(4)
    let c = ffi/allocate(4)
    let d = ffi/allocate(4)
    let e = ffi/allocate(4)
    let f = ffi/allocate(4)
    let g = ffi/allocate(4)
    let h = ffi/allocate(4)
    let i = ffi/allocate(4)
    let j = ffi/allocate(4)
    r/set_f32(a, 0, t.max_speed)
    r/set_f32(b, 0, t.accel)
    r/set_f32(c, 0, t.friction)
    r/set_f32(d, 0, t.light_range)
    r/set_f32(e, 0, t.light_half_angle_deg)
    r/set_f32(f, 0, t.light_intensity)
    r/set_f32(g, 0, t.ambient)
    r/set_f32(h, 0, t.camera_smoothing)
    r/set_f32(i, 0, t.run_multiplier)
    r/set_f32(j, 0, t.sneak_multiplier)
    UiBuffers {
        max_speed: a, accel: b, friction: c,
        light_range: d, light_half_angle_deg: e, light_intensity: f,
        ambient: g, camera_smoothing: h,
        run_mult: i, sneak_mult: j
    }
}

// Read the buffers back into a fresh Tuning.
fn read_tuning_from_ui(bufs) {
    Tuning {
        max_speed: r/get_f32(bufs.max_speed, 0),
        accel: r/get_f32(bufs.accel, 0),
        friction: r/get_f32(bufs.friction, 0),
        light_range: r/get_f32(bufs.light_range, 0),
        light_half_angle_deg: r/get_f32(bufs.light_half_angle_deg, 0),
        light_intensity: r/get_f32(bufs.light_intensity, 0),
        ambient: r/get_f32(bufs.ambient, 0),
        camera_smoothing: r/get_f32(bufs.camera_smoothing, 0),
        run_multiplier: r/get_f32(bufs.run_mult, 0),
        sneak_multiplier: r/get_f32(bufs.sneak_mult, 0)
    }
}

// ============================================================
// Editor logic
// ============================================================

let LEVEL_PATH = "/Users/jimmyhmiller/Documents/Code/PlayGround/beagle-zelda/levels/level.txt"
let EDITOR_CAMERA_SPEED = 600.0
let EDITOR_SELECT_RADIUS = 22.0

// Convert screen mouse → world, respecting editor's free camera.
fn editor_world_mouse(world) {
    screen_to_world(r/mouse_x(), r/mouse_y(), world.camera)
}

// Find an entity under `p` within EDITOR_SELECT_RADIUS.
// Returns {kind, index} — kind 0=none, 1=wall, 2=monster, 3=sentinel.
struct Pick {
    kind
    index
}

fn pick_at(world, p) {
    // Scan walls, then monsters, then sentinels — first hit wins.
    let mut found_kind = 0
    let mut found_index = 0 - 1
    let mut i = 0
    while i < length(world.walls) && found_kind == 0 {
        let w = world.walls[i]
        if v/aabb_overlap(p, v/make(1.0, 1.0), w.center, w.half) {
            found_kind = 1
            found_index = i
        }
        i = i + 1
    }
    let mut m = 0
    while m < length(world.monsters) && found_kind == 0 {
        let mm = world.monsters[m]
        if v/length(v/sub(p, mm.pos)) < EDITOR_SELECT_RADIUS {
            found_kind = 2
            found_index = m
        }
        m = m + 1
    }
    let mut s = 0
    while s < length(world.sentinels) && found_kind == 0 {
        let ss = world.sentinels[s]
        if v/length(v/sub(p, ss.pos)) < EDITOR_SELECT_RADIUS {
            found_kind = 3
            found_index = s
        }
        s = s + 1
    }
    Pick { kind: found_kind, index: found_index }
}

// Remove element at index i from a list; returns a new list.
fn list_remove_at(xs, i) {
    let mut result = []
    let mut k = 0
    while k < length(xs) {
        if k != i { result = push(result, xs[k]) }
        k = k + 1
    }
    result
}

// Serialize a float (we stringify with to-string to preserve precision).
fn ser_f(x) { to-string(x) }

fn serialize_level(world) {
    let mut s = "walls\n"
    let mut i = 0
    while i < length(world.walls) {
        let w = world.walls[i]
        s = s ++ ser_f(w.center.x) ++ " " ++ ser_f(w.center.y) ++ " "
              ++ ser_f(w.half.x) ++ " " ++ ser_f(w.half.y) ++ "\n"
        i = i + 1
    }
    s = s ++ "monsters\n"
    let mut m = 0
    while m < length(world.monsters) {
        let mm = world.monsters[m]
        s = s ++ ser_f(mm.pos.x) ++ " " ++ ser_f(mm.pos.y) ++ " "
              ++ ser_f(mm.speed) ++ " " ++ ser_f(mm.detection_range) ++ " "
              ++ ser_f(mm.attack_reach) ++ " " ++ ser_f(mm.strength) ++ "\n"
        m = m + 1
    }
    s = s ++ "sentinels\n"
    let mut n = 0
    while n < length(world.sentinels) {
        let ss = world.sentinels[n]
        s = s ++ ser_f(ss.pos.x) ++ " " ++ ser_f(ss.pos.y) ++ " "
              ++ ser_f(ss.light_range) ++ " " ++ ser_f(ss.light_half_angle_deg) ++ " "
              ++ ser_f(ss.light_intensity) ++ " " ++ ser_f(ss.speed) ++ " "
              ++ ser_f(ss.attack_reach) ++ " " ++ ser_f(ss.sweep_speed) ++ "\n"
        n = n + 1
    }
    s
}

fn save_level(world) {
    let result = async/blocking-write-file(LEVEL_PATH, serialize_level(world))
    match result {
        Result.Ok { value } => "saved " ++ to-string(value) ++ " bytes",
        Result.Err { error } => "save failed: " ++ to-string(error)
    }
}

// Skip empty strings in a list (split leaves them when the input has
// trailing newlines or double spaces).
fn strip_blanks(items) {
    let mut result = []
    let mut i = 0
    while i < length(items) {
        let s = items[i]
        if length(s) > 0 { result = push(result, s) }
        i = i + 1
    }
    result
}

// Level data (walls + enemies) extracted from a save file. Kept separate
// from World so callers can merge it into an existing world without leaking
// editor/shader state.
struct LevelData {
    walls
    monsters
    sentinels
}

fn deserialize_level(text) {
    let lines = split(text, "\n")
    let mut walls = []
    let mut monsters = []
    let mut sentinels = []
    let mut section = "none"
    let mut i = 0
    while i < length(lines) {
        let line = lines[i]
        if line == "walls" || line == "walls\r" { section = "walls" }
        else if line == "monsters" || line == "monsters\r" { section = "monsters" }
        else if line == "sentinels" || line == "sentinels\r" { section = "sentinels" }
        else if length(line) > 0 {
            let parts = strip_blanks(split(line, " "))
            if section == "walls" && length(parts) >= 4 {
                walls = push(walls, Wall {
                    center: v/make(to-float(parts[0]), to-float(parts[1])),
                    half: v/make(to-float(parts[2]), to-float(parts[3]))
                })
            } else if section == "monsters" && length(parts) >= 6 {
                let m = default_monster(v/make(to-float(parts[0]), to-float(parts[1])))
                let m2 = Monster {
                    pos: m.pos, prev: m.prev, vel: m.vel, half: m.half,
                    speed: to-float(parts[2]),
                    detection_range: to-float(parts[3]),
                    attack_reach: to-float(parts[4]),
                    strength: to-float(parts[5]),
                    has_seen: m.has_seen, time_since_los: m.time_since_los,
                    notice_acc: m.notice_acc, notice_threshold: m.notice_threshold,
                    wander_dir: m.wander_dir, wander_timer: m.wander_timer
                }
                monsters = push(monsters, m2)
            } else if section == "sentinels" && length(parts) >= 8 {
                let s = default_sentinel(v/make(to-float(parts[0]), to-float(parts[1])))
                let s2 = Sentinel {
                    pos: s.pos, prev: s.prev, vel: s.vel, half: s.half,
                    light_range: to-float(parts[2]),
                    light_half_angle_deg: to-float(parts[3]),
                    light_intensity: to-float(parts[4]),
                    speed: to-float(parts[5]),
                    attack_reach: to-float(parts[6]),
                    sweep_speed: to-float(parts[7]),
                    aim_angle: s.aim_angle, sweep_dir: s.sweep_dir, alerted: s.alerted
                }
                sentinels = push(sentinels, s2)
            }
        }
        i = i + 1
    }
    LevelData { walls: walls, monsters: monsters, sentinels: sentinels }
}

fn load_level(world) {
    let exists = async/blocking-file-exists?(LEVEL_PATH)
    let present = match exists {
        Result.Ok { value } => value,
        Result.Err { error } => false
    }
    if !present { world }
    else {
        let result = async/blocking-read-file(LEVEL_PATH)
        match result {
            Result.Ok { value } => {
                let data = deserialize_level(value)
                with_world(world, world.player, data.walls, data.monsters, data.sentinels,
                           world.camera, world.tuning, world.mode, world.editor)
            },
            Result.Err { error } => world
        }
    }
}

// Place a new entity at `p` in the world using the current tool.
fn editor_place(world, tool, p, drag_start) {
    if tool == TOOL_WALL {
        // Wall defined by rect between drag_start and p.
        let cx = (drag_start.x + p.x) * 0.5
        let cy = (drag_start.y + p.y) * 0.5
        let hx = v/abs_f(drag_start.x - p.x) * 0.5
        let hy = v/abs_f(drag_start.y - p.y) * 0.5
        if hx < 5.0 || hy < 5.0 { world }
        else {
            let walls = push(world.walls, Wall {
                center: v/make(cx, cy),
                half: v/make(hx, hy)
            })
            with_world(world, world.player, walls, world.monsters, world.sentinels,
                       world.camera, world.tuning, world.mode, world.editor)
        }
    } else if tool == TOOL_MONSTER {
        let monsters = push(world.monsters, default_monster(p))
        with_world(world, world.player, world.walls, monsters, world.sentinels,
                   world.camera, world.tuning, world.mode, world.editor)
    } else {
        let sentinels = push(world.sentinels, default_sentinel(p))
        with_world(world, world.player, world.walls, world.monsters, sentinels,
                   world.camera, world.tuning, world.mode, world.editor)
    }
}

fn editor_delete_selected(world) {
    let ed = world.editor
    if ed.selected_kind == 1 {
        let walls = list_remove_at(world.walls, ed.selected_index)
        let new_ed = Editor {
            tool: ed.tool, drag_start: ed.drag_start,
            selected_kind: 0, selected_index: 0 - 1,
            lighting_enabled: ed.lighting_enabled, status_text: "deleted wall",
            tool_slot: ed.tool_slot
        }
        with_world(world, world.player, walls, world.monsters, world.sentinels,
                   world.camera, world.tuning, world.mode, new_ed)
    } else if ed.selected_kind == 2 {
        let monsters = list_remove_at(world.monsters, ed.selected_index)
        let new_ed = Editor {
            tool: ed.tool, drag_start: ed.drag_start,
            selected_kind: 0, selected_index: 0 - 1,
            lighting_enabled: ed.lighting_enabled, status_text: "deleted monster",
            tool_slot: ed.tool_slot
        }
        with_world(world, world.player, world.walls, monsters, world.sentinels,
                   world.camera, world.tuning, world.mode, new_ed)
    } else if ed.selected_kind == 3 {
        let sentinels = list_remove_at(world.sentinels, ed.selected_index)
        let new_ed = Editor {
            tool: ed.tool, drag_start: ed.drag_start,
            selected_kind: 0, selected_index: 0 - 1,
            lighting_enabled: ed.lighting_enabled, status_text: "deleted sentinel",
            tool_slot: ed.tool_slot
        }
        with_world(world, world.player, world.walls, world.monsters, sentinels,
                   world.camera, world.tuning, world.mode, new_ed)
    } else {
        world
    }
}

fn editor_tick(world) {
    let dt = current_dt()
    let ed = world.editor
    // Read current tool from the raygui toggle slot.
    let tool = ffi/get-i32(ed.tool_slot, 0)

    // Free-camera panning with WASD / arrows.
    let mut cx = world.camera.x
    let mut cy = world.camera.y
    if r/is_key_down(r/KEY_W) || r/is_key_down(r/KEY_UP) { cy = cy + EDITOR_CAMERA_SPEED * dt }
    if r/is_key_down(r/KEY_S) || r/is_key_down(r/KEY_DOWN) { cy = cy - EDITOR_CAMERA_SPEED * dt }
    if r/is_key_down(r/KEY_A) || r/is_key_down(r/KEY_LEFT) { cx = cx - EDITOR_CAMERA_SPEED * dt }
    if r/is_key_down(r/KEY_D) || r/is_key_down(r/KEY_RIGHT) { cx = cx + EDITOR_CAMERA_SPEED * dt }
    let camera = v/make(cx, cy)

    let mouse_world = screen_to_world(r/mouse_x(), r/mouse_y(), camera)

    // Deletion.
    let mut world1 =
      with_world(world, world.player, world.walls, world.monsters, world.sentinels,
                 camera, world.tuning, world.mode, ed)
    world1 = if r/is_key_pressed(r/KEY_DELETE) || r/is_key_pressed(r/KEY_BACKSPACE) {
        editor_delete_selected(world1)
    } else { world1 }

    // Mouse interactions — skip if mouse is on the UI panel (right 260 px).
    let on_ui = r/mouse_x() > r/screen_width() - 260
    let left_pressed = r/is_mouse_button_pressed(r/MOUSE_LEFT) && !on_ui
    let left_released = r/is_mouse_button_released(r/MOUSE_LEFT) && !on_ui
    let right_pressed = r/is_mouse_button_pressed(r/MOUSE_RIGHT) && !on_ui

    // Select-tool left-click OR right-click-anywhere picks an entity.
    let select_click = (left_pressed && tool == TOOL_SELECT) || right_pressed
    let mut ed2 = world1.editor
    if select_click {
        let pick = pick_at(world1, mouse_world)
        ed2 = Editor {
            tool: tool,
            drag_start: ed2.drag_start,
            selected_kind: pick.kind,
            selected_index: pick.index,
            lighting_enabled: ed2.lighting_enabled,
            status_text: if pick.kind == 0 { "no selection" }
                         else if pick.kind == 1 { "wall selected" }
                         else if pick.kind == 2 { "monster selected" }
                         else { "sentinel selected" },
            tool_slot: ed2.tool_slot
        }
    }

    // Left-click with a placement tool starts placement (wall drags, enemies click).
    let mut world2 = with_world(world1, world1.player, world1.walls,
                                world1.monsters, world1.sentinels,
                                world1.camera, world1.tuning, world1.mode, ed2)
    if left_pressed && tool != TOOL_SELECT {
        let mut new_ed = Editor {
            tool: tool,
            drag_start: mouse_world,
            selected_kind: ed2.selected_kind,
            selected_index: ed2.selected_index,
            lighting_enabled: ed2.lighting_enabled,
            status_text: ed2.status_text,
            tool_slot: ed2.tool_slot
        }
        if tool == TOOL_MONSTER || tool == TOOL_SENTINEL {
            world2 = editor_place(world2, tool, mouse_world, mouse_world)
            new_ed = Editor {
                tool: tool, drag_start: null,
                selected_kind: new_ed.selected_kind, selected_index: new_ed.selected_index,
                lighting_enabled: new_ed.lighting_enabled, status_text: "placed", tool_slot: new_ed.tool_slot
            }
        }
        world2 = with_world(world2, world2.player, world2.walls,
                            world2.monsters, world2.sentinels,
                            world2.camera, world2.tuning, world2.mode, new_ed)
    }
    // Wall tool: drag-release finalises the rect.
    if left_released && world2.editor.drag_start != null && tool == TOOL_WALL {
        world2 = editor_place(world2, TOOL_WALL, mouse_world, world2.editor.drag_start)
        let new_ed = Editor {
            tool: tool, drag_start: null,
            selected_kind: world2.editor.selected_kind, selected_index: world2.editor.selected_index,
            lighting_enabled: world2.editor.lighting_enabled, status_text: "placed wall", tool_slot: world2.editor.tool_slot
        }
        world2 = with_world(world2, world2.player, world2.walls,
                            world2.monsters, world2.sentinels,
                            world2.camera, world2.tuning, world2.mode, new_ed)
    }

    world2
}

// Toggle between playing and editing modes when Tab is pressed this frame.
fn maybe_toggle_mode(world) {
    let mut w = world
    if r/is_key_pressed(r/KEY_TAB) {
        let new_mode = if w.mode == MODE_PLAYING { MODE_EDITING } else { MODE_PLAYING }
        w = with_world(w, w.player, w.walls, w.monsters, w.sentinels,
                       w.camera, w.tuning, new_mode, w.editor)
    }
    // F1 (raylib keycode 290) toggles the cone overlay + shadow mesh so the
    // user can confirm where the player actually is when lighting obscures it.
    let KEY_F1 = 290
    if r/is_key_pressed(KEY_F1) {
        let ed = w.editor
        let new_ed = Editor {
            tool: ed.tool, drag_start: ed.drag_start,
            selected_kind: ed.selected_kind, selected_index: ed.selected_index,
            status_text: if ed.lighting_enabled { "lighting off" } else { "lighting on" },
            tool_slot: ed.tool_slot,
            lighting_enabled: !ed.lighting_enabled
        }
        w = with_world(w, w.player, w.walls, w.monsters, w.sentinels,
                       w.camera, w.tuning, w.mode, new_ed)
    }
    // F2 toggles the FPS cap. 60 (capped) <-> 0 (uncapped in raylib).
    let KEY_F2 = 291
    if r/is_key_pressed(KEY_F2) {
        let new_cap = if deref(fps_cap) == 0 { 60 } else { 0 }
        swap!(fps_cap, fn(x) { new_cap })
        r/set_target_fps(new_cap)
    }
    w
}

fn game_loop(world, shader_ctx, ui_bufs, max_frames) {
    if max_frames >= 0 && world.frame >= max_frames {
        world
    } else if r/window_should_close() {
        world
    } else {
        let after_toggle = maybe_toggle_mode(world)
        let next = if after_toggle.mode == MODE_EDITING {
            editor_tick(after_toggle)
        } else {
            playing_tick(after_toggle)
        }
        let world_after = if next.mode == MODE_EDITING {
            let ui = render_editor(next, shader_ctx, ui_bufs)
            // Apply any save/load/tuning updates the UI produced this frame.
            let w1 = with_world(next, next.player, next.walls, next.monsters, next.sentinels,
                                next.camera, ui.new_tuning, next.mode, next.editor)
            let w2 = if ui.save {
                let msg = save_level(w1)
                let ed = Editor {
                    tool: w1.editor.tool, drag_start: w1.editor.drag_start,
                    selected_kind: w1.editor.selected_kind,
                    selected_index: w1.editor.selected_index,
                    lighting_enabled: w1.editor.lighting_enabled, status_text: msg,
                    tool_slot: w1.editor.tool_slot
                }
                with_world(w1, w1.player, w1.walls, w1.monsters, w1.sentinels,
                           w1.camera, w1.tuning, w1.mode, ed)
            } else { w1 }
            if ui.load { load_level(w2) } else { w2 }
        } else {
            render_world(next, shader_ctx)
            next
        }
        game_loop(world_after, shader_ctx, ui_bufs, max_frames)
    }
}

// Try to load levels/level.txt on startup — fall back to the default layout.
// Check existence first: read-file's Err path currently can't construct its
// SystemError.IOError variant and panics the runtime.
fn startup_world() {
    let base = initial_world()
    let exists = async/blocking-file-exists?(LEVEL_PATH)
    let present = match exists {
        Result.Ok { value } => value,
        Result.Err { error } => false
    }
    if !present {
        base
    } else {
        let result = async/blocking-read-file(LEVEL_PATH)
        match result {
            Result.Ok { value } => {
                let data = deserialize_level(value)
                with_world(base, base.player, data.walls, data.monsters, data.sentinels,
                           v/ZERO, base.tuning, MODE_PLAYING, base.editor)
            },
            Result.Err { error } => base
        }
    }
}

fn main() {
    r/set_config_flags(r/FLAG_WINDOW_RESIZABLE)
    r/init_window(INITIAL_W, INITIAL_H, "beagle-zelda")
    r/set_target_fps(60)

    let shader_ctx = load_cone_light_shader()
    let initial = startup_world()
    let ui_bufs = alloc_ui_buffers(initial.tuning)
    let final_world = game_loop(initial, shader_ctx, ui_bufs, 0 - 1)

    r/close_window()
    println("exited after frame " ++ to-string(final_world.frame))
    0
}
