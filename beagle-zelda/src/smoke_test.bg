namespace smoke_test

// Minimal smoke test: raylib window + raygui button.
// Verifies that HFA-struct params (Rectangle) can be passed as 4 x F32.

use beagle.ffi as ffi

let raylib = ffi/load-library("/opt/homebrew/lib/libraylib.dylib")
let raygui = ffi/load-library("/Users/jimmyhmiller/Documents/Code/PlayGround/beagle-zelda/vendor/libraygui.dylib")

let rl_init_window = ffi/get-function(
    raylib, "InitWindow",
    [ffi/Type.I32, ffi/Type.I32, ffi/Type.String],
    ffi/Type.Void
)
let rl_close_window = ffi/get-function(raylib, "CloseWindow", [], ffi/Type.Void)
let rl_window_should_close = ffi/get-function(raylib, "WindowShouldClose", [], ffi/Type.I32)
let rl_set_target_fps = ffi/get-function(raylib, "SetTargetFPS", [ffi/Type.I32], ffi/Type.Void)
let rl_begin_drawing = ffi/get-function(raylib, "BeginDrawing", [], ffi/Type.Void)
let rl_end_drawing = ffi/get-function(raylib, "EndDrawing", [], ffi/Type.Void)
let rl_clear_background = ffi/get-function(raylib, "ClearBackground", [ffi/Type.U32], ffi/Type.Void)
let rl_draw_text = ffi/get-function(
    raylib, "DrawText",
    [ffi/Type.String, ffi/Type.I32, ffi/Type.I32, ffi/Type.I32, ffi/Type.U32],
    ffi/Type.Void
)

// GuiButton(Rectangle bounds, const char *text) -> int
// Rectangle is HFA of 4 floats: x, y, w, h — passed in v0..v3 on ARM64.
let gui_button = ffi/get-function(
    raygui, "GuiButton",
    [ffi/Type.F32, ffi/Type.F32, ffi/Type.F32, ffi/Type.F32, ffi/Type.String],
    ffi/Type.I32
)

fn rgb(r, g, b) {
    r + (g * 256) + (b * 65536) + (255 * 16777216)
}

fn loop_frame(clicks) {
    if rl_window_should_close() != 0 {
        clicks
    } else {
        rl_begin_drawing()
        rl_clear_background(rgb(30, 30, 40))
        rl_draw_text("smoke test — click the button", 10, 10, 20, rgb(240, 240, 240))
        let click_text = "Clicks: " ++ to-string(clicks)
        rl_draw_text(click_text, 10, 40, 20, rgb(120, 220, 120))
        let pressed = gui_button(40.0, 80.0, 160.0, 40.0, "Press me")
        rl_end_drawing()
        let next = if pressed != 0 { clicks + 1 } else { clicks }
        loop_frame(next)
    }
}

fn main() {
    rl_init_window(480, 240, "beagle-zelda smoke test")
    rl_set_target_fps(60)
    let total = loop_frame(0)
    rl_close_window()
    println("total clicks: " ++ to-string(total))
    total
}
