namespace headless_test

// Runs the main game for a fixed number of frames — lets us smoke-test
// changes without sitting in an interactive window.

use ray as r
use vec as v
use rendering as render
use beagle_zelda as game

fn main() {
    // Honor BEAGLE_ZELDA_NOFOCUS=1 so the test window doesn't steal focus.
    if r/getenv("BEAGLE_ZELDA_NOFOCUS") != null {
        r/set_config_flags(r/FLAG_WINDOW_UNFOCUSED)
    }
    r/init_window(1280, 720, "beagle-zelda (headless test)")
    r/set_target_fps(60)
    let shader_ctx = render/load_cone_light_shader()
    let initial = game/initial_world()
    let ui_bufs = game/alloc_ui_buffers(initial.tuning)
    let final = game/game_loop(initial, shader_ctx, ui_bufs, 60)
    r/close_window()
    println("headless test reached frame " ++ to-string(final.frame))
    0
}
