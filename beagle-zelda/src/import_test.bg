namespace import_test

use ray as r

// Auto-exits after N frames without needing user input.
fn loop_frames(frames_left) {
    if frames_left <= 0 || r/window_should_close() {
        0
    } else {
        r/begin_drawing()
        r/clear_background(r/rgb(20, 25, 30))
        r/draw_text("import test OK", 20, 20, 24, r/WHITE)
        let click_text = "frame " ++ to-string(frames_left)
        r/draw_text(click_text, 20, 60, 20, r/YELLOW)
        // Exercise a raygui call to ensure that loads too.
        r/button(20.0, 100.0, 120.0, 30.0, "noop")
        r/end_drawing()
        loop_frames(frames_left - 1)
    }
}

fn main() {
    r/init_window(320, 200, "import_test")
    r/set_target_fps(60)
    loop_frames(30)
    r/close_window()
    println("import_test: OK")
    0
}
