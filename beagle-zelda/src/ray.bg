// ============================================================
// Color helpers
// ============================================================

fn color(r, g, b, a) {
    r + (g * 256) + (b * 65536) + (a * 16777216)
}

fn rgb(r, g, b) {
    color(r, g, b, 255)
}

let BLACK = rgb(0, 0, 0)
let WHITE = rgb(255, 255, 255)
let LIGHTGRAY = rgb(200, 200, 200)
let GRAY = rgb(130, 130, 130)
let DARKGRAY = rgb(80, 80, 80)
let RED = rgb(230, 41, 55)
let GREEN = rgb(0, 228, 48)
let DARKGREEN = rgb(0, 117, 44)
let BLUE = rgb(0, 121, 241)
let SKYBLUE = rgb(102, 191, 255)
let DARKBLUE = rgb(0, 82, 172)
let YELLOW = rgb(253, 249, 0)
let GOLD = rgb(255, 203, 0)
let ORANGE = rgb(255, 161, 0)
let PINK = rgb(255, 109, 194)
let PURPLE = rgb(200, 122, 255)
let BROWN = rgb(127, 106, 79)
let BEIGE = rgb(211, 176, 131)
let MAROON = rgb(190, 33, 55)

// ============================================================
// Thin helpers (keep call sites readable)
// ============================================================

fn init_window(w, h, title) { rl_init_window(w, h, title) }
fn close_window() { rl_close_window() }
fn window_should_close() { rl_window_should_close() != 0 }
fn set_target_fps(fps) { rl_set_target_fps(fps) }
fn set_config_flags(flags) { rl_set_config_flags(flags) }
fn screen_width() { rl_get_screen_width() }
fn screen_height() { rl_get_screen_height() }
fn render_width() { rl_get_render_width() }
fn render_height() { rl_get_render_height() }
fn frame_time() { rl_get_frame_time() }

fn begin_drawing() { rl_begin_drawing() }
fn end_drawing() { rl_end_drawing() }
fn clear_background(c) { rl_clear_background(c) }

fn draw_rectangle(x, y, w, h, c) { rl_draw_rectangle(x, y, w, h, c) }
fn draw_rectangle_lines(x, y, w, h, c) { rl_draw_rectangle_lines(x, y, w, h, c) }
fn draw_rectangle_lines_ex(x, y, w, h, thick, c) { rl_draw_rectangle_lines_ex(x, y, w, h, thick, c) }
fn draw_circle(x, y, radius, c) { rl_draw_circle(x, y, radius, c) }
fn draw_circle_lines(x, y, radius, c) { rl_draw_circle_lines(x, y, radius, c) }
fn draw_line(x1, y1, x2, y2, c) { rl_draw_line(x1, y1, x2, y2, c) }
fn draw_line_ex(x1, y1, x2, y2, thick, c) { rl_draw_line_ex(x1, y1, x2, y2, thick, c) }
fn draw_text(t, x, y, sz, c) { rl_draw_text(t, x, y, sz, c) }
fn draw_fps(x, y) { rl_draw_fps(x, y) }

fn is_key_down(k) { rl_is_key_down(k) != 0 }
fn is_key_pressed(k) { rl_is_key_pressed(k) != 0 }
fn is_key_released(k) { rl_is_key_released(k) != 0 }
fn mouse_x() { rl_get_mouse_x() }
fn mouse_y() { rl_get_mouse_y() }
fn is_mouse_button_down(b) { rl_is_mouse_button_down(b) != 0 }
fn is_mouse_button_pressed(b) { rl_is_mouse_button_pressed(b) != 0 }
fn is_mouse_button_released(b) { rl_is_mouse_button_released(b) != 0 }
fn mouse_wheel_move() { rl_get_mouse_wheel_move() }

// Shader handle is a {low, high} pair from StructReturn.
fn load_shader(vs, fs) { rl_load_shader_from_memory(vs, fs) }
fn unload_shader(s) { rl_unload_shader(s.low, s.high) }
fn begin_shader_mode(s) { rl_begin_shader_mode(s.low, s.high) }
fn end_shader_mode() { rl_end_shader_mode() }
fn shader_location(s, name) { rl_get_shader_location(s.low, s.high, name) }
fn set_shader_value(s, loc, ptr, uniform_type) {
    rl_set_shader_value(s.low, s.high, loc, ptr, uniform_type)
}
fn set_shader_value_v(s, loc, ptr, uniform_type, count) {
    rl_set_shader_value_v(s.low, s.high, loc, ptr, uniform_type, count)
}

fn gl_begin(mode) { rl_begin(mode) }
fn gl_end() { rl_end() }
fn gl_vertex_2f(x, y) { rl_vertex_2f(x, y) }
fn gl_color_4ub(r, g, b, a) { rl_color_4ub(r, g, b, a) }
fn gl_set_texture(id) { rl_set_texture(id) }

fn begin_scissor_mode(x, y, w, h) { rl_begin_scissor(x, y, w, h) }
fn end_scissor_mode() { rl_end_scissor() }

fn begin_blend_mode(m) { rl_begin_blend_mode(m) }
fn end_blend_mode() { rl_end_blend_mode() }

// raygui helpers — return the int result (for Button: 1 if clicked).
fn button(x, y, w, h, text) { gui_button(x, y, w, h, text) }
fn label(x, y, w, h, text) { gui_label(x, y, w, h, text) }
fn panel(x, y, w, h, title) { gui_panel(x, y, w, h, title) }
fn window_box(x, y, w, h, title) { gui_window_box(x, y, w, h, title) }
fn check_box(x, y, w, h, text, bool_ptr) { gui_check_box(x, y, w, h, text, bool_ptr) }
fn slider(x, y, w, h, left, right, f32_ptr, vmin, vmax) {
    gui_slider(x, y, w, h, left, right, f32_ptr, vmin, vmax)
}
fn slider_bar(x, y, w, h, left, right, f32_ptr, vmin, vmax) {
    gui_slider_bar(x, y, w, h, left, right, f32_ptr, vmin, vmax)
}
fn toggle_group(x, y, w, h, text, int_ptr) {
    gui_toggle_group(x, y, w, h, text, int_ptr)
}
