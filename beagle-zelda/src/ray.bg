// ------------------------------------------------------------
// Blend modes (for additive-lighting style tricks)
// ------------------------------------------------------------
let rl_begin_blend_mode = ffi/get-function(raylib, "BeginBlendMode", [ffi/Type.I32], ffi/Type.Void)
let rl_end_blend_mode = ffi/get-function(raylib, "EndBlendMode", [], ffi/Type.Void)

// ------------------------------------------------------------
// Float buffer helpers — thin wrappers over native Beagle FFI accessors.
// ------------------------------------------------------------
fn set_f32(buf, offset, value) { ffi/set-f32(buf, offset, value) }
fn get_f32(buf, offset) { ffi/get-f32(buf, offset) }
fn set_vec2(buf, offset, x, y) {
    ffi/set-f32(buf, offset, x)
    ffi/set-f32(buf, offset + 4, y)
}
fn set_vec4(buf, offset, x, y, z, w) {
    ffi/set-f32(buf, offset, x)
    ffi/set-f32(buf, offset + 4, y)
    ffi/set-f32(buf, offset + 8, z)
    ffi/set-f32(buf, offset + 12, w)
}

