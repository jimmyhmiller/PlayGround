namespace ray

// ============================================================
// raylib + raygui FFI bindings for beagle-zelda.
//
// Design notes:
//   * All drawing funcs take camera-adjusted screen coordinates as ints.
//     Camera offset is applied in Beagle, not via raylib's Camera2D,
//     which avoids passing Camera2D-as-HFA structs through FFI.
//   * Rectangle (HFA of 4 f32) is always expanded to 4 F32 params —
//     matches the AArch64 calling convention (v0..v3).
//   * Vector2 (HFA of 2 f32) is expanded to 2 F32 params.
//   * Color (4 u8 = 4 bytes) is packed into a single U32.
//   * Shader is a 2-u64 struct — split into (low, high) via StructReturn
//     and always passed as U64, U64 like breakout.bg does.
// ============================================================

use beagle.ffi as ffi

let raylib = ffi/load-library("/opt/homebrew/lib/libraylib.dylib")
let raygui = ffi/load-library("/Users/jimmyhmiller/Documents/Code/PlayGround/beagle-zelda/vendor/libraygui.dylib")
// libc for getenv — used so the caller can launch the window without stealing
// focus from whatever app is frontmost (BEAGLE_ZELDA_NOFOCUS=1).
let libc = ffi/load-library("/usr/lib/libSystem.B.dylib")
let c_getenv = ffi/get-function(libc, "getenv",
                                [ffi/Type.String], ffi/Type.String)

fn getenv(name) { c_getenv(name) }

// ------------------------------------------------------------
// Window / time
// ------------------------------------------------------------
let rl_init_window = ffi/get-function(
    raylib, "InitWindow",
    [ffi/Type.I32, ffi/Type.I32, ffi/Type.String],
    ffi/Type.Void)
let rl_close_window = ffi/get-function(raylib, "CloseWindow", [], ffi/Type.Void)
let rl_window_should_close = ffi/get-function(raylib, "WindowShouldClose", [], ffi/Type.I32)
let rl_set_target_fps = ffi/get-function(raylib, "SetTargetFPS", [ffi/Type.I32], ffi/Type.Void)
let rl_set_config_flags = ffi/get-function(raylib, "SetConfigFlags", [ffi/Type.U32], ffi/Type.Void)
let rl_get_screen_width = ffi/get-function(raylib, "GetScreenWidth", [], ffi/Type.I32)
let rl_get_screen_height = ffi/get-function(raylib, "GetScreenHeight", [], ffi/Type.I32)
let rl_get_render_width = ffi/get-function(raylib, "GetRenderWidth", [], ffi/Type.I32)
let rl_get_render_height = ffi/get-function(raylib, "GetRenderHeight", [], ffi/Type.I32)
let rl_get_time = ffi/get-function(raylib, "GetTime", [], ffi/Type.U64)
let rl_get_frame_time = ffi/get-function(raylib, "GetFrameTime", [], ffi/Type.F32)

