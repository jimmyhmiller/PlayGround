let rl_draw_line_ex = ffi/get-function(
    raylib, "DrawLineEx",
    // Vector2 start (2xF32), Vector2 end (2xF32), F32 thick, U32 color
    [ffi/Type.F32, ffi/Type.F32, ffi/Type.F32, ffi/Type.F32, ffi/Type.F32, ffi/Type.U32],
    ffi/Type.Void)
let rl_draw_text = ffi/get-function(
    raylib, "DrawText",
