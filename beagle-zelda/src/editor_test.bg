namespace editor_test

// Runs the game for 60 frames starting in editor mode, to exercise
// the raygui panel and the editor tick path.

use ray as r
use vec as v
use rendering as render
use beagle_zelda as game

fn main() {
    // Honor BEAGLE_ZELDA_NOFOCUS=1 so the test window doesn't steal focus.
    if r/getenv("BEAGLE_ZELDA_NOFOCUS") != null {
        r/set_config_flags(r/FLAG_WINDOW_UNFOCUSED)
    }
    r/init_window(1280, 720, "beagle-zelda (editor test)")
    r/set_target_fps(60)
    let shader_ctx = render/load_cone_light_shader()
    let initial0 = game/initial_world()
    let ui_bufs = game/alloc_ui_buffers(initial0.tuning)
    // Force-edit mode for this run.
    let initial = game/World { ...initial0, mode: game/MODE_EDITING }
    let final = game/game_loop(initial, shader_ctx, ui_bufs, 60)
    r/close_window()
    println("editor test reached frame ${final.frame}")
    println("walls: ${length(final.walls)}")

    // Round-trip serialization.
    let text = game/serialize_level(final)
    let reload = game/deserialize_level(text)
    println("round-trip walls: ${length(reload.walls)}")
    println("round-trip monsters: ${length(reload.monsters)}")
    println("round-trip sentinels: ${length(reload.sentinels)}")
    0
}
