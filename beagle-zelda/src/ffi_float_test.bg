namespace ffi_float_test

// Verifies that F32 FFI arg passing and round-tripping through
// Beagle's native ffi/set-f32 / ffi/get-f32 actually work.

use beagle.ffi as ffi
use ray as r

fn check(label, actual, expected) {
    let diff = actual - expected
    let ad = if diff < 0.0 { 0.0 - diff } else { diff }
    let tag = if ad < 0.001 { "PASS" } else { "FAIL" }
    println(tag ++ " " ++ label ++ "  actual=" ++ to-string(actual)
               ++ "  expected=" ++ to-string(expected))
}

fn main() {
    let buf = ffi/allocate(32)
    r/set_f32(buf, 0, 640.0)
    r/set_f32(buf, 4, 360.0)
    r/set_f32(buf, 8, 123.456)
    r/set_f32(buf, 12, 0.0 - 42.5)
    check("read slot 0", r/get_f32(buf, 0), 640.0)
    check("read slot 1", r/get_f32(buf, 4), 360.0)
    check("read slot 2", r/get_f32(buf, 8), 123.456)
    check("read slot 3", r/get_f32(buf, 12), 0.0 - 42.5)

    // Make sure slot 1 wasn't clobbered when slot 2 was written
    // (would happen if set-f32 wrote 8 bytes instead of 4).
    check("slot 1 after slot 2 write", r/get_f32(buf, 4), 360.0)

    // Strided writes like we do for vec2 arrays.
    let mut i = 0
    while i < 8 {
        r/set_f32(buf, i * 8, to-float(i) * 10.0)
        r/set_f32(buf, i * 8 + 4, to-float(i) * 10.0 + 5.0)
        i = i + 1
    }
    check("strided slot 0 .x", r/get_f32(buf, 0), 0.0)
    check("strided slot 0 .y", r/get_f32(buf, 4), 5.0)
    check("strided slot 3 .x", r/get_f32(buf, 24), 30.0)
    check("strided slot 3 .y", r/get_f32(buf, 28), 35.0)
    println("done")
    0
}
