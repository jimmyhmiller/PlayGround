# trace via #step_inner — single-step the innermost sub-expression

rule trace_stepper : @meta -> @self {
  trace(?x) => trace(#step_inner(?x))
}

rule trace_print : @meta -> @io {
  reduction(?s, ?old, ?new, ?kind) => println("[", ?s, "] ", ?old, "  =>  ", ?new, "  (", ?kind, ")")
}

fn fact(0) = 1
fn fact(?n) = ?n * fact(?n - 1)

trace(fact(5))
