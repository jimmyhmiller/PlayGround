# Trace propagation via #subst — NO trace_arith rules needed.
# The engine handles arithmetic on wrapped values transparently.

rule trace : @meta -> @self {
  ?f(trace(?x)) => #println(?f(trace(?x)), " => ", #eval(#subst(#step(?f(?x)), ?x, trace(?x))))
}

fn double(?n) = ?n + ?n
fn fact(0) = 1
fn fact(?n) = ?n * fact(?n - 1)

double(trace(3))
fact(trace(5))
