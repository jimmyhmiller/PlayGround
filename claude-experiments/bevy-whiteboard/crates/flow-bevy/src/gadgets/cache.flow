node Cache {
    slots {
        # Probability a request is a hit. A cache "hit" is a
        # Bernoulli draw — we are modeling the behaviour of a
        # read-through cache, not implementing one. No keys, no
        # stored values. Changing `hit_rate` live re-tunes the
        # hit/miss mixture on the next inbound req.
        hit_rate:       Float = 0.8
        # Latency window for a cache hit. Like Worker's `service_ns`
        # this rides on the self-loop edge: `serve_hit` kicks a
        # `done_hit` to self, and the self-loop's latency expression
        # reads this slot at emit time, so live edits of
        # `hit_latency_ns` apply to the next hit.
        hit_latency_ns: Int = 1000000
        hits:           Int = 0
        misses:         Int = 0
        color:          Int = 0
        up:             Int = 1
        # Stashed client return_paths for in-flight misses. Each
        # entry is the original request's return_path (a List of
        # NodeRefs). We push on miss — just before forwarding to
        # the backing store with `pushing self` — and pop when the
        # backing store's resp arrives, so the relayed resp walks
        # back to the original client. Same "stashed reply" shape
        # as 2PC: Samples-of-Lists used as a FIFO of pending
        # return paths, not a keyed lookup.
        pending_rp:     Samples(64)
    }
    probes {
        hit_rate: "{hit_rate * 100}%"
        hits:     "{hits}"
        misses:   "{misses}"
    }
    on_spawn {
        # Self-loop carries the hit-latency window. `done_hit`
        # rides this edge; the latency expr reads `hit_latency_ns`
        # at emit time so live edits propagate to the next hit.
        self -> self : hit_latency_ns
    }
    # Rule ORDER is load-bearing, same discipline as Worker:
    # completion/relay rules (done_hit, relay_resp*) come BEFORE
    # acceptance rules (serve_hit / serve_miss) so a backing-store
    # resp arriving in the same tick as a fresh client req advances
    # pending_rp first. Reject rules (color_mismatch, node_down)
    # come last as fallthroughs.
    #
    # Hit/miss split: `serve_hit`'s guard does the Bernoulli draw
    # (gated on c == color && up == 1 so wrong-colour / down reqs
    # don't consume the RNG). If the draw fails, `serve_miss`
    # catches the same packet with no re-draw — giving a single
    # Bernoulli(hit_rate) decision per req, without a `last_draw`
    # slot and without a keyed data structure.

    # Hit completion: the self-loop `done_hit(nil)` arrived. Reply
    # popping back to the original client (inherited return_path).
    rule finish_hit {
        on done_hit(_)
        when up == 1
        do {
            emit resp(nil) popping to (head(return_path))
        }
    }
    # Crash during the hit window: in-flight reply becomes a
    # resp_error, matching Worker's finish_req_crashed shape.
    rule finish_hit_crashed {
        on done_hit(_)
        when up == 0
        do {
            error "node_down" "cache: crashed mid-hit, reply lost"
            emit resp_error(nil) popping to (head(return_path))
        }
    }
    # Relay resp from the backing store. We pushed ourselves onto
    # return_path when we forwarded the req, so the backing store's
    # popping reply landed here; pop pending_rp to recover the
    # original client's path, then emit resp with return_path
    # replaced by it and popping (head(rp) is the client).
    rule relay_resp {
        on resp(_)
        do {
            pop pending_rp -> rp
            emit resp(nil) return_path rp popping to (head(rp))
        }
    }
    rule relay_resp_error {
        on resp_error(_)
        do {
            pop pending_rp -> rp
            emit resp_error(nil) return_path rp popping to (head(rp))
        }
    }
    # Hit path. Guard uses `if … then Bernoulli(p) else false` so
    # wrong-colour / down reqs don't draw a phantom random bit —
    # expression `&&` evaluates both sides, but `if` short-circuits.
    # `hits` is bumped here; `done_hit` reserves the hit-latency
    # window on the self-loop before replying.
    rule serve_hit {
        on req(c)
        when if c == color && up == 1 then Bernoulli(hit_rate) else false
        do {
            hits := hits + 1
            record hits hits
            emit done_hit(nil) to self
        }
    }
    # Miss path. Same pattern, fires iff serve_hit's guard returned
    # false while `c == color && up == 1` still held. Stash the
    # client's return_path into pending_rp so relay_resp can pop
    # it back when the backing store answers; forward the req
    # pushing self to the first outbound neighbour that isn't the
    # caller (head(return_path)). `to default` would be fragile
    # here — if the reverse edge cache→client was added before
    # cache→store, `default` picks the reverse path and the miss
    # loops back to the client. The filter makes the forward
    # direction explicit.
    rule serve_miss {
        on req(c)
        when c == color && up == 1
        do {
            misses := misses + 1
            record misses misses
            push pending_rp <- return_path
            emit req(c) pushing self to (head(filter(out_neighbors(), "n", n != head(return_path))))
        }
    }
    # Down: any inbound req is failed back to the client, same as
    # Worker.serve_down. `node_down` takes precedence over
    # `color_mismatch` because down-state is the more actionable
    # signal for the operator.
    rule serve_down {
        on req(_)
        when up == 0
        do {
            error "node_down" "cache: request to down cache"
            emit resp_error(nil) popping to (head(return_path))
        }
    }
    rule color_mismatch {
        on req(_)
        do { error "color_mismatch" "cache: wrong-colour req rejected" }
    }
}
