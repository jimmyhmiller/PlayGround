# Single-track service with bounded backlog. A data packet arrival
# either starts servicing immediately (when idle), enqueues (when busy
# and there's room), or overflows out the `overflow` port (when full).
# Service time is the self-loop latency; when the in-flight job
# finishes, the next backlog entry (if any) is dequeued and served.
#
# Equivalent to chaining Buffer → Delay with pull-feedback — bundled
# so the pull loop is implicit. Use as the engine of a Worker-shaped
# gadget (Worker = Lift → Filter → Service → Reply).
#
# Internal protocol uses a `done` kind on the self-loop to mark
# completion. Rules discriminate by `p.kind`. Rule ORDER matters: the
# `done` rules must come BEFORE serve / enqueue so a completion in
# the same tick as a fresh packet advances the queue first.
node Service {
    slots {
        service_ns:  Int = 50000000
        backlog:     Samples(64)
        backlog_cap: Int = 5
        busy:        Int = 0
    }
    probes {
        busy:    "{busy}"
        backlog: "{len(backlog)}"
    }
    on_spawn {
        # Self-loop carries the service window. `done` rides this edge.
        self -> self : service_ns
    }
    rule finish_next {
        on p when p.kind == "done" && len(backlog) > 0
        do {
            pop backlog -> next
            emit packet(p.value) to default
            emit done(next) to self
        }
    }
    rule finish_idle {
        on p when p.kind == "done"
        do {
            busy := 0
            emit packet(p.value) to default
        }
    }
    rule serve {
        on p when busy == 0
        do {
            busy := 1
            emit done(p.value) to self
        }
    }
    rule enqueue {
        on p when len(backlog) < backlog_cap
        do { push backlog <- p.value }
    }
    rule overflow_out {
        on p
        do { emit p to port overflow }
    }
}
