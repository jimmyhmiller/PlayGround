# Single-track service. A data packet arrival starts servicing
# immediately when idle; arrivals while busy queue up in Service's
# own inbox (the engine's natural per-node FIFO), preserving each
# packet's `return_path` and `metadata` end-to-end. When the in-flight
# job finishes (`busy := 0`), the next try_fire round picks the next
# inbox packet via the `serve` rule.
#
# Why inbox queueing instead of an explicit `backlog: Samples`? A
# `Samples` slot stores `Value`s — push/pop loses the originating
# packet's metadata + return_path. That broke request/response
# routing when multiple clients shared the same worker: the dequeued
# packet inherited the wrong RP and replies went to whichever client
# triggered the serve, not the one whose `req` was actually queued.
# Letting the inbox do the queueing is both simpler and correct.
#
# `done` packets ride a self-loop edge whose latency is `service_ns`.
# Live edits to `service_ns` apply to the next service window.
node Service {
    slots {
        service_ns: Int = 50000000
        busy:       Int = 0
    }
    probes {
        busy: "{busy}"
    }
    on_spawn {
        self -> self : service_ns
    }
    rule finish {
        on p when p.kind == "done"
        do {
            busy := 0
            emit packet(p.value) to default
        }
    }
    rule serve {
        on p when busy == 0
        do {
            busy := 1
            emit done(p.value) to self
        }
    }
}
