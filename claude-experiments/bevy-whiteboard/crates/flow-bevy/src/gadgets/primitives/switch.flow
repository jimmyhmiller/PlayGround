# Two-position routing switch. Data packets go out `pass` when
# `passing == 1`, out `divert` when `passing == 0`. Position is flipped
# by `signal` packets on the control input: signal(1) trips
# (passing := 0); signal(0) resets (passing := 1). Wire a Threshold's
# output here to make the Switch close when a measured value crosses a
# limit — the building block for circuit breakers, rate limiters, etc.
#
# Discriminates control from data via `p.kind == "signal"` rather than
# variant matching. Data of any kind passes through with its kind
# preserved.
node Switch {
    slots { passing: Int = 1 }
    probes { state: "{if passing == 1 then 1 else 0}" }
    # Control packets (kind=signal) come first so a signal arriving in
    # the same tick as data flips state before the data is routed.
    rule trip {
        on p when p.kind == "signal" && p.value == 1
        do { passing := 0 }
    }
    rule reset {
        on p when p.kind == "signal" && p.value == 0
        do { passing := 1 }
    }
    rule signal_consume {
        on p when p.kind == "signal"
        do { }
    }
    # Data routes by current state. Bind whole packet so kind is preserved.
    rule pass {
        on p when passing == 1
        do { emit p to port pass }
    }
    rule divert {
        on p when passing == 0
        do { emit p to port divert }
    }
    # Catch-all for unexpected `passing` values.
    rule consume { on p do { } }
}
