# Color filter. Packets whose payload equals `match` go out the `pass`
# port; everything else goes out the `reject` port. The two ports let
# downstream wire matching and non-matching flows independently —
# matches one outbound edge `Filter.pass -> X` and a separate
# `Filter.reject -> Y`. Unwired ports silently drop, matching the
# `to default` contract for missing outputs.
node Filter {
    slots { match: Int = 0 }
    rule pass {
        on packet(c)
        when c == match
        do { emit packet(c) to port pass }
    }
    rule reject {
        on packet(c)
        do { emit packet(c) to port reject }
    }
}
