# Value filter. Packets whose `.value` equals `match` go out the `pass`
# port; everything else goes out the `reject`. The two ports let
# downstream wire matching and non-matching flows independently. Unwired
# ports silently drop, matching the `to default` contract for missing
# outputs.
#
# Pattern-binds the whole packet as `p` and re-emits it on the chosen
# port — kind is preserved verbatim. So a Filter chained after an
# Aggregator sees `total(v)` and routes `total(v)` through, the same
# way it routes `packet(v)` from a generator. One rule pair, every kind.
node Filter {
    slots { match: Int = 0 }
    rule pass {
        on p when p.value == match
        do { emit p to port pass }
    }
    rule reject {
        on p
        do { emit p to port reject }
    }
}
