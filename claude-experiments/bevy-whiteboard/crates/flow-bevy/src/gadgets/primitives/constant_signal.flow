# Emits `signal(value)` on every incoming "trigger" — fires on
# `packet`, `total`, `count`, or `report` so any variant from upstream
# (Filter/Threshold/Aggregator/Window/etc.) can drive a Switch's
# trip/reset rules. Used to convert a discriminator's "decision" into
# a state-machine input.
node ConstantSignal {
    slots { value: Int = 0 }
    rule fire_packet { on packet(_) do { emit signal(value) to default } }
    rule fire_total  { on total(_)  do { emit signal(value) to default } }
    rule fire_count  { on count(_)  do { emit signal(value) to default } }
    rule fire_report { on report(_) do { emit signal(value) to default } }
}
