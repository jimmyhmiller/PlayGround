# Probabilistic two-way split. A Bernoulli(p) draw on each incoming
# packet decides whether it goes out `heads` or `tails`. Use to model
# cache hit/miss, lossy networks, vote outcomes. Preserves the
# incoming packet's kind verbatim by binding and re-emitting `q`.
#
# Note: the slot name is `p`, so we use `q` for the bound packet to
# avoid shadowing.
node Coin {
    slots { p: Float = 0.5 }
    rule heads {
        on q when Bernoulli(p)
        do { emit q to port heads }
    }
    rule tails {
        on q
        do { emit q to port tails }
    }
}
