# Emits `packet(value)` on every incoming packet, regardless of the
# incoming payload. The smallest "value source": every primitive in the
# set transforms or routes its input, but none synthesizes a specific
# numeric value out of nothing. `ConstantPacket` is the one that does —
# letting downstream Aggregator/Filter/Threshold consume a chosen value.
node ConstantPacket {
    slots { value: Int = 0 }
    rule fire {
        on packet(_)
        do { emit packet(value) to default }
    }
}
