# Collects N inputs (any kind), then emits one `total(sum)` packet on
# default. Each arrival contributes its `.value` to a running sum and
# bumps `seen`. When `seen == n` the aggregator fires its output and
# resets — ready for the next batch.
#
# Pattern-binds the whole packet, so this serves both generic "tally N
# packets" (TPC vote tallying with `packet(v)`) and the Conway Game-of-
# Life cell's "tally 8 neighbor `report(v)` packets" without needing a
# variant-specific adapter.
#
# `reset(_)` packets bypass aggregation and clear `seen`/`sum`. The
# rule order is load-bearing here: `reset` must come BEFORE `final` and
# `partial` so a reset arriving in the same tick as data wins.
node Aggregator {
    slots {
        n:    Int = 0
        seen: Int = 0
        sum:  Int = 0
    }
    probes {
        seen: "{seen}/{n}"
        sum:  "{sum}"
    }
    # Reset port: drop accumulated state without firing.
    rule reset {
        on p when p.kind == "reset"
        do {
            seen := 0
            sum  := 0
        }
    }
    # Final input — emit the aggregate and reset for the next batch.
    # `sum + p.value` (the would-be new sum) is emitted BEFORE the
    # reset; otherwise the emit re-reads the new `sum` and double-counts.
    rule final {
        on p when seen + 1 == n && n > 0
        do {
            emit total(sum + p.value) to default
            seen := 0
            sum  := 0
        }
    }
    # Partial — accumulate and wait.
    rule partial {
        on p
        do {
            seen := seen + 1
            sum  := sum + p.value
        }
    }
}
