# Forward request: push self onto return_path, forward downstream.
# Reverse reply: pop self off return_path, relay back to the next hop.
# A request/reply waystation — any downstream that emits popping to
# head(return_path) will land here on the way back, and we relay one
# more hop. Same shape as Router's forward_resp/forward_req pair.
node Stamp {
    rule fwd_packet {
        on packet(p)
        do { emit packet(p) pushing self to default }
    }
    rule fwd_req {
        on req(p)
        do { emit req(p) pushing self to default }
    }
    rule rev_resp {
        on resp(x)
        do { emit resp(x) popping to (head(return_path)) }
    }
    rule rev_resp_error {
        on resp_error(x)
        do { emit resp_error(x) popping to (head(return_path)) }
    }
}
