# Queue — expressed entirely from primitives.
#
# Forward (enqueue) path:
#   input ─▶ R(eply, passthrough=1) ─▶ T(ally) ─▶ F(ilter) ─▶ B(uffer) ─pull─▶ HE ─▶ out output
#
# `R : Reply { passthrough: 1 }` is the accept adapter. On `req(c)`
# arriving with a return_path, it ACKs the client immediately
# (`resp(nil) popping to head`) AND forwards the data popping. On
# plain `packet`, it forwards untouched. Either way, downstream sees
# fresh forward data with the client peeled off the return_path.
#
# `T : Tally` bumps `len` per accepted packet (any kind). Lets the
# inspector show queue depth without hand-wiring a counter inline.
#
# Pull / dispatch path:
#   pull ─▶ B ─pull(items>0)─▶ B.head ─▶ HE ─▶ out output
#
# `pull(_)` packets at the compound's `pull` in-port go straight to
# Buffer. When items are available Buffer pops the head; otherwise the
# pull is parked in Buffer's `waiting` slot so the next data packet
# dispatches without a second pull.
#
# Reverse (response) path:
#   reply ─▶ R ─▶ engine resolves head(rp) back upstream
compound QueueComposite(
    color:    Int = 0,
    capacity: Int = 16,
) {
    in  {
        input: R     # `req(c)` or `packet(c)` to enqueue
        pull:  B     # `pull(_)` to dispatch the head
        reply: R     # responses from a downstream consumer
    }
    out {
        output:   D
        response: R
        overflow: B
    }

    node R  : Reply    { passthrough: 1 }
    node T  : Tally    { }
    node F  : Filter   { match: color }
    node B  : Buffer   { cap: capacity }
    # Round-robin dispatch on the output path: each popped item goes to
    # exactly ONE downstream worker, rotating across them. A broadcast
    # relay here (Egress / `to out output`) duplicated every item to all
    # N workers — each then backed up on N× its share until the engine
    # stalled.
    #
    # The rotation isn't computed here — `to out output rotating` tells
    # the engine to emit to the `output`-port edge used longest ago and
    # mark it used. The rotation state lives on the edges (the graph's
    # send history), so this node holds no counter; it just declares the
    # boundary-crossing mode. Empty / unwired port → silent drop.
    node D {
        rule fwd { on p do { emit p to out output rotating } }
    }

    edges {
        R          -> T  : 1
        T          -> F  : 1
        F.pass     -> B  : 1
        B.head     -> D  : 1
    }
}
