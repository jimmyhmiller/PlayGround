# BackoffClient reimplemented from primitives.
#
# Topology mirrors `ClientComposite` (Endpoint + Egress) but the
# Endpoint owns its own self-tick — the period adapts (`period_ns +
# backoff_ns`) so doubling-on-failure feeds back into the tick rate.
# A plain Tick primitive emits at a fixed cadence, so it can't model
# the backoff-driven cadence shift; the Endpoint absorbs the timing
# role and the rest of the gadget (req emission + resp/resp_error
# state machine) stays as bookkeeping rules.
#
# This is the limit of decomposition for a self-adjusting periodic
# source: any "tick whose own period reads a backoff slot" reduces
# to a node with a self-edge whose latency expression names that
# slot. The composite still proves the primitive set covers the
# *shape* (state machine + variant adapter + egress).
compound BackoffClientComposite(
    period_ns:      Int = 500000000,
    color:          Int = 0,
    max_backoff_ns: Int = 8000000000,
) {
    in  { reply:  Endpoint }
    out { output: E }

    node Endpoint {
        slots {
            color:          Int = color
            emitted:        Int = 0
            completed:      Int = 0
            failed:         Int = 0
            in_flight:      Int = 0
            period_ns:      Int = period_ns
            backoff_ns:     Int = 0
            max_backoff_ns: Int = max_backoff_ns
        }
        probes {
            emitted:   "{emitted}"
            in_flight: "{in_flight}"
            backoff:   "{backoff_ns / 1ms}ms"
        }
        on_spawn {
            self -> self : period_ns + backoff_ns
            inject tick(nil)
        }
        rule fire {
            on tick(_)
            do {
                emitted   := emitted + 1
                in_flight := in_flight + 1
                emit req(color) pushing self to default
                emit tick(nil) to self
            }
        }
        rule on_resp {
            on resp(_) do {
                completed  := completed + 1
                in_flight  := in_flight - 1
                backoff_ns := 0
            }
        }
        rule on_resp_error_seed {
            on resp_error(_)
            when backoff_ns == 0
            do {
                failed     := failed + 1
                in_flight  := in_flight - 1
                backoff_ns := period_ns
            }
        }
        rule on_resp_error_double {
            on resp_error(_)
            when backoff_ns > 0 && backoff_ns * 2 <= max_backoff_ns
            do {
                failed     := failed + 1
                in_flight  := in_flight - 1
                backoff_ns := backoff_ns * 2
            }
        }
        rule on_resp_error_cap {
            on resp_error(_)
            do {
                failed     := failed + 1
                in_flight  := in_flight - 1
                backoff_ns := max_backoff_ns
            }
        }
    }
    node E : Egress { }
    edges { Endpoint -> E : 1 }
}
