# Cache reimplemented from primitives only:
#
#                       ┌─heads─▶ Delay(hit_latency_ns) ──▶ HR (hit-reply) ──▶ L (response port)
#  req(c) ─▶ L (entry)─▶ Coin(p=hit_rate)
#                       └─tails─▶ S (stamp) ──▶ ME (miss-egress; backend wired here)
#                                                 (backend reply pops back: ME → S → L)
#
# - L (formerly Lower): on `req(c)` push self, forward as `packet(c)`;
#   on resp/resp_error pop and emit via the compound's `response` port.
# - Coin does the Bernoulli hit/miss split.
# - Hit path holds the packet in Delay for `hit_latency_ns`, then HR
#   (formerly Reply, now inline) converts it into `resp(nil) popping`.
#   HR's pop pops L off, and L's reverse rule emits via the `response`
#   port.
# - Miss path uses S (formerly Stamp, now inline): pushes self again,
#   forwards as `req`. The external backend's `resp` (popping) pops back
#   to S, which relays it one more hop to L; L's reverse emits via
#   `response` as in the hit case.
compound CacheComposite(
    hit_rate:       Float = 0.8,
    hit_latency_ns: Int   = 1000000,
    color:          Int   = 0,
) {
    in  { request:  L }
    out {
        response: L
        miss:     ME
    }

    # Inline entry adapter (formerly Lower).
    node L {
        rule rev {
            on p when p.kind == "resp" || p.kind == "resp_error"
            do { emit p popping to out response }
        }
        rule fwd {
            on p when p.kind == "req"
            do { emit packet(p.value) pushing self to default }
        }
    }
    node F  : Filter { match: color }
    node C  : Coin   { p: hit_rate }
    node HD : Delay  { ns: hit_latency_ns }
    # Inline hit-reply (formerly Reply).
    node HR {
        rule rev_pass {
            on p when p.kind == "resp" || p.kind == "resp_error"
            do { emit p popping to (head(return_path)) }
        }
        rule on_packet {
            on p
            do { emit resp(nil) popping to (head(return_path)) }
        }
    }
    # Inline stamp waystation (formerly Stamp). Pushes self forward,
    # relays popping resp back one hop.
    node S {
        rule rev {
            on p when p.kind == "resp" || p.kind == "resp_error"
            do { emit p popping to (head(return_path)) }
        }
        rule fwd {
            on p
            do { emit p pushing self to default }
        }
    }
    # Miss-egress: routes both directions of req/resp through the
    # compound's `miss` port. (Egress proper emits via `out output`;
    # this bespoke version routes via `out miss`.)
    node ME {
        rule fwd { on p do { emit p to out miss } }
    }

    edges {
        L      -> F  : 1
        F.pass -> C  : 1
        C.heads -> HD : 1
        HD     -> HR : 1
        HR     -> L  : 1
        # Miss: forward as a stamped req, route out via the `miss` port.
        C.tails -> S  : 1
        S       -> ME : 1
        # When the backend replies, the resp pops back through Stamp to
        # L. The reverse edges mirror the forward chain so popping has
        # somewhere to go.
        ME      -> S  : 1
        S       -> L  : 1
    }
}
