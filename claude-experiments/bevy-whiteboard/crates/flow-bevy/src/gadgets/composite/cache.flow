# Cache reimplemented from primitives:
#
#                  в”Њв”Ђheadsв”Ђв–¶ Delay(hit_latency_ns) в”Ђв”Ђв–¶ Reply в”Ђв”Ђв–¶ Lower (response port)
#  req(c) в”Ђв–¶ Lowerв”Ђв–¶ Coin(p=hit_rate)
#                  в””в”Ђtailsв”Ђв–¶ Stamp в”Ђв”Ђв–¶ MissEgress (miss port; backend wired here)
#                                       (backend reply pops back through Stamp в†’ Lower)
#
# - `Lower` lifts `req(c)` into the inner packet pipeline (push self).
# - `Coin` does the Bernoulli hit/miss split.
# - Hit path holds the packet in `Delay` for `hit_latency_ns`, then
#   `Reply` converts it into a `resp(nil) popping`. Reply's pop pops
#   Lower off, and Lower's reverse rule emits via the `response` port.
# - Miss path uses `Stamp`: pushes self again, forwards as `req`. The
#   external backend's `resp` (popping) pops back to Stamp, which
#   relays it one more hop to Lower; Lower's reverse emits via
#   `response` as in the hit case.
compound CacheComposite(
    hit_rate:       Float = 0.8,
    hit_latency_ns: Int   = 1000000,
    color:          Int   = 0,
) {
    in  { request:  L }
    out {
        response: L
        miss:     ME
    }

    node L  : Lower  { }
    node F  : Filter { match: color }
    node C  : Coin   { p: hit_rate }
    node HD : Delay  { ns: hit_latency_ns }
    node HR : Reply  { }

    node S  : Stamp  { }
    node ME {
        # Egress glue for the `miss` port. (Egress emits via `out output`;
        # this one routes via `out miss`.)
        rule fwd_req         { on req(p)         do { emit req(p)         to out miss } }
        rule fwd_resp        { on resp(x)        do { emit resp(x)        to out miss } }
        rule fwd_resp_error  { on resp_error(x)  do { emit resp_error(x)  to out miss } }
    }

    edges {
        L      -> F  : 1
        F.pass -> C  : 1
        C.heads -> HD : 1
        HD     -> HR : 1
        HR     -> L  : 1
        # Miss: forward as a stamped req, route out via the `miss` port.
        C.tails -> S  : 1
        S       -> ME : 1
        # When the backend replies, the resp pops back through Stamp to
        # Lower. The reverse edges mirror the forward chain so popping
        # has somewhere to go.
        ME      -> S  : 1
        S       -> L  : 1
    }
}
