# Router вЂ” colour demux, built as a visible graph of Filter primitives.
#
#   input в”Ђв–¶ S(tamp) в”Ђв–¶ F0 в”Ђpassв”Ђв–¶ E0 в”Ђв–¶ out lane0   (colour 0)
#                       в”‚reject
#                       в–ј
#                       F1 в”Ђpassв”Ђв–¶ E1 в”Ђв–¶ out lane1   (colour 1)
#                       в”‚reject
#                       в–ј            вЂ¦ one lane per palette colour вЂ¦
#                       F5 в”Ђpassв”Ђв–¶ E5 в”Ђв–¶ out lane5
#                       в”‚reject в”Ђв–¶ (drop)
#
# Each `Filter` peels its own colour off the stream and forwards the
# rest down the chain; the matching packet exits that lane's port. The
# demux is plain graph structure you can see when you drill in вЂ” no
# routing rule, no neighbour introspection, no boundary magic.
#
# The user never picks a port: wiring `Router в†’ Queue` auto-attaches to
# the `lane{c}` port matching the destination's colour (see
# `wire_flow_edge`). So a colour-`c` queue connects to `lane{c}`, and the
# colour-`c` packets that exit there flow straight to it. Lanes with
# nothing wired (and `F5.reject`) drop silently.
#
# `S : Stamp` pushes self onto `return_path` for `req` traffic so a
# downstream Worker's reply walks back through the Router; the reverse
# (`reply`) direction lands on S too.
#
# (One Filter + one tiny boundary-relay `E{c}` per palette colour. The
# relays differ only in which `lane{c}` port they cross вЂ” emit ports
# can't yet be generated by a `for` loop, so the six lanes are spelled
# out.)
compound RouterComposite() {
    in  {
        input: S
        reply: S
    }
    out {
        response: S
        lane0: E0
        lane1: E1
        lane2: E2
        lane3: E3
        lane4: E4
        lane5: E5
    }

    node S  : Stamp  { }
    node F0 : Filter { match: 0 }
    node F1 : Filter { match: 1 }
    node F2 : Filter { match: 2 }
    node F3 : Filter { match: 3 }
    node F4 : Filter { match: 4 }
    node F5 : Filter { match: 5 }
    node E0 { rule fwd { on p do { emit p to out lane0 } } }
    node E1 { rule fwd { on p do { emit p to out lane1 } } }
    node E2 { rule fwd { on p do { emit p to out lane2 } } }
    node E3 { rule fwd { on p do { emit p to out lane3 } } }
    node E4 { rule fwd { on p do { emit p to out lane4 } } }
    node E5 { rule fwd { on p do { emit p to out lane5 } } }

    edges {
        S         -> F0 : 1
        F0.pass   -> E0 : 1
        F0.reject -> F1 : 1
        F1.pass   -> E1 : 1
        F1.reject -> F2 : 1
        F2.pass   -> E2 : 1
        F2.reject -> F3 : 1
        F3.pass   -> E3 : 1
        F3.reject -> F4 : 1
        F4.pass   -> E4 : 1
        F4.reject -> F5 : 1
        F5.pass   -> E5 : 1
    }
}
