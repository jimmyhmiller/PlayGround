# Two-phase commit, coordinator side, reimplemented from primitives.
#
#  req ──▶ Lower ──▶ FanOut(prepare) ──▶ (participants, external)
#                                                │
#                                                ▼  votes (each is `packet(0|1)`)
#                                          Aggregator(n=participants)
#                                                │
#                                                ▼ total(sum)
#                                          DecideReply (compares sum to n)
#                                                │
#                                       ─────────┴──────────
#                                      ▼                    ▼
#                       resp(nil) (commit)      resp_error(nil) (abort)
#                       popping back through Lower
#
# Participant side composite: each participant is a `ParticipantComposite`
# that takes `req` in, draws a Bernoulli for yes/no, and emits the vote
# back through Lower. A whiteboard wires N of those to a single
# `CoordinatorComposite` to model N-participant TPC.
compound TPCCoordinatorComposite(
    participants: Int = 2,
    color:        Int = 0,
) {
    in  { request: L; vote: A }
    out {
        response: L
        prepare:  PE
    }

    node L  : Lower      { }
    node FO : FanOut     { }
    node PE {
        # Prepare-port egress (Egress emits to `out output`; this
        # routes to `out prepare`).
        rule fwd { on packet(p) do { emit packet(p) to out prepare } }
    }
    node A  : Aggregator { n: participants }
    node Decide {
        slots { n: Int = participants }
        # Commit if all voted yes (sum == n); otherwise abort.
        rule decide {
            on total(sum)
            do {
                emit pkt(if sum == n then 1 else 0) to default
            }
        }
    }
    node Resp {
        # Turn the verdict into a resp / resp_error popping back to Lower.
        rule ok {
            on pkt(v) when v == 1
            do { emit resp(nil) popping to (head(return_path)) }
        }
        rule abort {
            on pkt(v) when v == 0
            do { emit resp_error(nil) popping to (head(return_path)) }
        }
    }

    edges {
        L      -> FO : 1
        FO     -> PE : 1   # FanOut to prepare port
        A      -> Decide : 1
        Decide -> Resp   : 1
        Resp   -> L      : 1
    }
}

# Each TPC participant: take an inbound prepare-as-req, flip a coin
# for yes/no, vote back through Lower (which exits via response port).
compound TPCParticipantComposite(
    yes_prob: Float = 1.0,
) {
    in  { request: L }
    out { response: L }

    node L : Lower { }
    node C : Coin  { p: yes_prob }
    node Yes {
        rule on_packet {
            on packet(_)
            do { emit resp(1) popping to (head(return_path)) }
        }
    }
    node No {
        rule on_packet {
            on packet(_)
            do { emit resp(0) popping to (head(return_path)) }
        }
    }

    edges {
        L       -> C   : 1
        C.heads -> Yes : 1
        C.tails -> No  : 1
        Yes     -> L   : 1
        No      -> L   : 1
    }
}
