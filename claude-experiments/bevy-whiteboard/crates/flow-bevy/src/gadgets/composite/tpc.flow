# Two-phase commit, coordinator side, reimplemented from primitives only.
#
#  req ──▶ L (entry) ──▶ FanOut(prepare) ──▶ (participants, external)
#                                                  │
#                                                  ▼  votes (each is `packet(0|1)`)
#                                            Aggregator(n=participants)
#                                                  │
#                                                  ▼ total(sum)
#                                            Decide (compares sum to n)
#                                                  │
#                                         ─────────┴──────────
#                                        ▼                    ▼
#                         resp(nil) (commit)      resp_error(nil) (abort)
#                         popping back through L
#
# Participant side composite: each participant is a `TPCParticipantComposite`
# that takes `req` in, draws a Bernoulli for yes/no, and emits the vote
# back through L. A whiteboard wires N of those to a single
# `TPCCoordinatorComposite` to model N-participant TPC.
compound TPCCoordinatorComposite(
    participants: Int = 2,
    color:        Int = 0,
) {
    in  { request: L; vote: A }
    out {
        response: L
        prepare:  PE
    }

    # Inline entry adapter (formerly Lower).
    node L {
        rule rev {
            on p when p.kind == "resp" || p.kind == "resp_error"
            do { emit p popping to out response }
        }
        rule fwd {
            on p when p.kind == "req"
            do { emit packet(p.value) pushing self to default }
        }
    }
    node FO : FanOut     { }
    node PE {
        # Prepare-port egress (Egress emits to `out output`; this
        # routes to `out prepare`).
        rule fwd { on p do { emit p to out prepare } }
    }
    node A  : Aggregator { n: participants }
    node Decide {
        slots { n: Int = participants }
        # Commit if all voted yes (sum == n); otherwise abort.
        rule decide {
            on p when p.kind == "total"
            do {
                emit pkt(if p.value == n then 1 else 0) to default
            }
        }
    }
    node Resp {
        # Turn the verdict into a resp / resp_error popping back to L.
        rule ok {
            on p when p.kind == "pkt" && p.value == 1
            do { emit resp(nil) popping to (head(return_path)) }
        }
        rule abort {
            on p when p.kind == "pkt" && p.value == 0
            do { emit resp_error(nil) popping to (head(return_path)) }
        }
    }

    edges {
        L      -> FO : 1
        FO     -> PE : 1   # FanOut to prepare port
        A      -> Decide : 1
        Decide -> Resp   : 1
        Resp   -> L      : 1
    }
}

# Each TPC participant: take an inbound prepare-as-req, flip a coin
# for yes/no, vote back through L (which exits via response port).
compound TPCParticipantComposite(
    yes_prob: Float = 1.0,
) {
    in  { request: L }
    out { response: L }

    # Inline entry adapter (formerly Lower).
    node L {
        rule rev {
            on p when p.kind == "resp" || p.kind == "resp_error"
            do { emit p popping to out response }
        }
        rule fwd {
            on p when p.kind == "req"
            do { emit packet(p.value) pushing self to default }
        }
    }
    node C : Coin  { p: yes_prob }
    node Yes {
        rule on_packet {
            on p
            do { emit resp(1) popping to (head(return_path)) }
        }
    }
    node No {
        rule on_packet {
            on p
            do { emit resp(0) popping to (head(return_path)) }
        }
    }

    edges {
        L       -> C   : 1
        C.heads -> Yes : 1
        C.tails -> No  : 1
        Yes     -> L   : 1
        No      -> L   : 1
    }
}
