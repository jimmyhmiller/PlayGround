# Worker — expressed entirely from primitives.
#
#   request ─▶ S(tamp) ─▶ F(ilter) ─▶ Sv(Service) ─▶ R(eply) ─▶ P(ump) ─▶ E(gress) ─▶ out output
#                  ▲                                     │                      └─▶ out pull
#                  └──────────────────────────────────────┘
#                  internal R → S edge so a `resp popping to head` from R
#                  reaches S (which pushed itself on the way in)
#
# Request/response flow:
#   `req(c) pushing` arrives at S. S.fwd_req pushes itself, forwards.
#   F filters by colour. Sv services for `service_ns` (and naturally
#   queues backlog in its own inbox). The serviced `packet(v)` lands
#   at R with `return_path = [S, …]` — R.reply_only fires, emits
#   `resp(nil) popping`, R→S internal edge carries it to S, S pops
#   itself, the engine routes the response out the compound boundary
#   via the auto-wired reverse edge.
#
# Forward pass-through flow (queue → worker → sink):
#   A plain `packet(c)` (return_path empty) arrives at S. S.fwd_packet
#   forwards untouched. F → Sv → R. R.forward fires (return_path
#   empty), `emit p to default` → P. P forwards through E to
#   `out output` AND emits `pull(nil) to out pull` so the upstream
#   Queue dispatches the next item.
#
# `served` lives on R and counts successful replies — tests can read
# `worker.served` via `read_slot_resolved`.
compound WorkerComposite(
    service_ns: Int = 50000000,
    color:      Int = 0,
) {
    in  { request:  S }
    out {
        response: S
        output:   E
        pull:     P
        reject:   F
    }

    node S  : Stamp   { }
    node F  : Filter  { match: color }
    node Sv : Service { service_ns: service_ns }
    node R  : Reply   { }
    node P  : Pump    { }
    node E  : Egress  { }

    edges {
        S      -> F  : 1
        F.pass -> Sv : 1
        Sv     -> R  : 1
        # R.forward emits `to default` — the FIRST outbound carries it.
        # Declare R→P before R→S so the data path wins.
        R      -> P  : 1
        # R.reply_only emits `popping to (head(return_path))` where head
        # is S. The engine finds this direct outbound and uses it.
        R      -> S  : 1
        P      -> E  : 1
    }
}
