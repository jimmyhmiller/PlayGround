# CircuitBreaker from primitives вҖ” req/resp variant.
#
#                                  в”Ңв”Җpassв”Җв”Җв”Җв–¶ Stamp в”Җв”Җв–¶ Server (always fails)
#  Caller в”Җв”Җreqв”Җв”Җв–¶ L в”Җв”Җpacketв”Җв”Җв–¶ SW                            в”Ӯ
#                                  в””в”Җdivertв”Җв”Җв–¶ ErrReply в—Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
#                          в–І                                   в”Ӯ
#                          в”Ӯ signal                     packet (FailTap)
#                          в”Ӯ                                   в–ј
#                         Th в—Җв”Җв”Җв”Җв”Җв”Җв”Җ W (Window)
#
# Failure marks feed the Window; threshold-crossing flips Switch.

node Caller : Client { period_ns: 250000000, color: 0 }

node L {
    rule fwd_req     { on req(p)         do { emit packet(p) pushing self to default } }
    rule rev_resp    { on resp(x)        do { emit resp(x)        popping to (head(return_path)) } }
    rule rev_resp_er { on resp_error(x)  do { emit resp_error(x)  popping to (head(return_path)) } }
}

node SW : Switch { passing: 1 }
# Stamp waystation (was the Stamp primitive). Pushes self forward,
# relays popping resp back one hop.
node S {
    rule rev {
        on p when p.kind == "resp" || p.kind == "resp_error"
        do { emit p popping to (head(return_path)) }
    }
    rule fwd {
        on p
        do { emit p pushing self to default }
    }
}

node Server {
    slots { hits: Int = 0 }
    probes { hits: "{hits}" }
    rule on_packet {
        on packet(_) do {
            hits := hits + 1
            # Tap the failure into the breaker's Window, then reply error.
            emit packet(nil) to FailTap
            emit resp_error(nil) popping to (head(return_path))
        }
    }
}
node FailTap {
    rule fwd { on packet(p) do { emit packet(p) to default } }
}

node W  : Window    { window_ns: 1000000000 }
node Th : Threshold { limit: 3 }

node ErrReply {
    rule on_packet {
        on packet(_) do { emit resp_error(nil) popping to (head(return_path)) }
    }
}

edges {
    Caller -> L  : 5ms
    L      -> SW : 1ms
    SW.pass   -> S : 1ms
    S      -> Server : 5ms
    Server -> S : 5ms
    S      -> L : 1ms
    SW.divert -> ErrReply : 1ms
    ErrReply  -> L : 1ms

    FailTap -> W : 1ms
    W       -> Th : 1ms
    Th      -> SW : 1ms
}
