# 5x5 toroidal Game of Life with a horizontal 3-cell blinker.

compound Cell_0_0 {
in  { report: A }
out { output: BE }
node T     : Tick           { period_ns: 200000000 }
node SW    : Switch         { passing: 0 }
node C1    : Constant { value: 1 }
node C0    : Constant { value: 0 }
node B     : FanOut         { }
node BE    : Egress         { }
node A     : Aggregator     { n: 8 }
node F3    : Filter         { match: 3 }
node F2    : Filter         { match: 2 }
node ToAlv : Constant { value: 0, out_kind: "signal" }
node ToDed : Constant { value: 1, out_kind: "signal" }
edges {
T -> SW : 1ms
SW.pass -> C1 : 1ms
SW.divert -> C0 : 1ms
C1 -> B : 1ms
C0 -> B : 1ms
B -> BE : 1ms
A -> F3 : 1ms
F3.pass -> ToAlv : 1ms
F3.reject -> F2 : 1ms
F2.reject -> ToDed : 1ms
ToAlv -> SW : 1ms
ToDed -> SW : 1ms
}
}

