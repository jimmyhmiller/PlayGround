# Cache from primitives:
#
#                       в”Њв”Ђheadsв”Ђв–¶ HD (Delay) в”Ђв”Ђв–¶ HR (Reply) в”Ђв”Ђв”ђ
#  Client в”Ђв”Ђreqв”Ђв”Ђв–¶ L в”Ђв”Ђв–¶ C (Coin p=0.8)                       в”‚
#                       в””в”Ђtailsв”Ђв–¶ S (Stamp) в”Ђв”Ђв–¶ Backend       в”‚
#                                                  в”‚          в”‚
#                                          (resp pops back via S в†’ L)

node Caller : Client {
    period_ns: 300000000
    color:     0
}

# Boundary adapter (Lower without `out response` since this whiteboard
# has no enclosing compound).
node L {
    rule fwd_req     { on req(p)         do { emit packet(p) pushing self to default } }
    rule rev_resp    { on resp(x)        do { emit resp(x)        popping to (head(return_path)) } }
    rule rev_resp_er { on resp_error(x)  do { emit resp_error(x)  popping to (head(return_path)) } }
}

node C  : Coin   { p: 0.7 }
node HD : Delay  { ns: 5000000 }
# Hit-reply (was the Reply primitive).
node HR {
    rule rev_pass {
        on p when p.kind == "resp" || p.kind == "resp_error"
        do { emit p popping to (head(return_path)) }
    }
    rule on_packet {
        on p
        do { emit resp(nil) popping to (head(return_path)) }
    }
}
# Miss-path stamp waystation (was the Stamp primitive).
node S {
    rule rev {
        on p when p.kind == "resp" || p.kind == "resp_error"
        do { emit p popping to (head(return_path)) }
    }
    rule fwd {
        on p
        do { emit p pushing self to default }
    }
}

# A trivial backend that always replies after a fixed delay.
node Backend {
    slots { dummy: Int = 0 }
    rule on_req {
        on req(_) do { emit resp(nil) popping to (head(return_path)) }
    }
}

edges {
    Caller -> L     : 5ms
    L      -> C     : 1ms
    C.heads -> HD   : 1ms
    HD     -> HR    : 1ms
    HR     -> L     : 1ms
    C.tails -> S    : 1ms
    S      -> Backend : 10ms
    Backend -> S    : 10ms
    S      -> L     : 1ms
}
