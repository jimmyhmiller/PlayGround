# Two-phase commit. Coordinator runs a synchronous prepare round,
# tallies votes, then broadcasts commit or abort and replies to the
# original client. The client's return_path is stashed in pending_rp
# (Samples(1)) across the vote window — that's the "suspended reply"
# pattern.
#
# Drive abort scenarios via the Timeline panel: select any participant
# and drag its `vote_yes_prob` slider down toward 0, or click `+5s` to
# schedule a flip. Coordinator.committed / aborted reflect the round
# outcome each tx.

node Client : Client {
    period_ns: 1000000000   # 1s — gives the prepare/commit fanouts
                            # time to complete before the next req
}

node Coordinator : TPCCoordinator { }

node P0 : TPCParticipant { }
node P1 : TPCParticipant { }
node P2 : TPCParticipant { }

# Each participant has its OWN local "DB" sink — i.e. each replica
# writes to its own backing store once the coordinator has confirmed
# everyone voted yes. On a committed round you see three sinks light
# up in parallel ("every replica applied"). On an aborted round all
# three sinks stay silent — the whole point of TPC.
node DB0 : Sink { }
node DB1 : Sink { }
node DB2 : Sink { }

edges {
    Client      -> Coordinator : 1ms
    Coordinator -> Client      : 1ms

    Coordinator -> P0 : 1ms
    P0          -> Coordinator : 1ms
    Coordinator -> P1 : 1ms
    P1          -> Coordinator : 1ms
    Coordinator -> P2 : 1ms
    P2          -> Coordinator : 1ms

    P0 -> DB0 : 1ms
    P1 -> DB1 : 1ms
    P2 -> DB2 : 1ms
}

scenario {
    # Phase 1 (0–3s): healthy. Coordinator.committed climbs each tx.
    # Phase 2 (3–6s): P1 always votes no. aborted climbs instead.
    at 3s:  set_slot P1.vote_yes_prob := 0.0
    # Phase 3 (6–9s): P1 recovers, P2 takes over as the no-voter.
    # Still aborting, different participant blocking the round.
    at 6s:  set_slot P1.vote_yes_prob := 1.0
    at 6s:  set_slot P2.vote_yes_prob := 0.0
    # Phase 4 (9–12s): all participants healthy. Commits resume.
    at 9s:  set_slot P2.vote_yes_prob := 1.0
    # Phase 5 (12–15s): coordinator down. Reqs hit a down coordinator
    # (no prepare round at all) — distinct from a participant-driven abort.
    at 12s: set_slot Coordinator.up := 0
    # Phase 6 (15s+): coordinator back. Healthy again.
    at 15s: set_slot Coordinator.up := 1
}
