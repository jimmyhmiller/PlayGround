import jrust.JRustAsm;

// ASM opcodes as constants
const ACC_PUBLIC: i32 = 1;
const ACC_STATIC: i32 = 8;
const ACC_SUPER: i32 = 32;
const V21: i32 = 65;
const GETSTATIC: i32 = 178;
const INVOKEVIRTUAL: i32 = 182;
const RETURN_OP: i32 = 177;

fn main() {
    // Test args
    println("args: " + args_len());

    // Test read_file
    let source: String = read_file("sample.jrs");
    println("Read " + source.len() + " chars from sample.jrs");

    // Test JRustAsm: generate a simple Hello World class
    let cw: i32 = JRustAsm::cw_new(3);
    JRustAsm::cw_visit(cw, V21, ACC_PUBLIC | ACC_SUPER, "Hello", "java/lang/Object");

    // Generate: public static void main(String[] args) { System.out.println("Hello from JRust-generated bytecode!"); }
    let mv: i32 = JRustAsm::cw_visit_method(cw, ACC_PUBLIC | ACC_STATIC, "main", "([Ljava/lang/String;)V");
    JRustAsm::mv_code(mv);

    // System.out
    JRustAsm::mv_field_insn(mv, GETSTATIC, "java/lang/System", "out", "Ljava/io/PrintStream;");
    // "Hello from JRust-generated bytecode!"
    JRustAsm::mv_ldc_str(mv, "Hello from JRust-generated bytecode!");
    // println
    JRustAsm::mv_method_insn(mv, INVOKEVIRTUAL, "java/io/PrintStream", "println", "(Ljava/lang/String;)V", 0);
    // return
    JRustAsm::mv_insn(mv, RETURN_OP);

    JRustAsm::mv_maxs(mv, 0, 0);
    JRustAsm::mv_end(mv);
    JRustAsm::cw_end(cw);
    JRustAsm::cw_write(cw, "test_output", "Hello");

    println("Generated Hello.class");

    // Run it
    let rc: i32 = system("java -cp test_output Hello");
    println("Exit code: " + rc);

    println("DONE");
}
