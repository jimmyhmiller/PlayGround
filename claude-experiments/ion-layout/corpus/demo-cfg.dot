digraph G {
  node [shape=box, fontname="Menlo", fontsize=13];
  "entry" [label="Entry\lv0 = param(0)\lv1 = param(1)\lv2 = loadConst(100)\lv3 = loadConst(0)\lif v0 > v2\l", ion_loop_depth=0];
  "hot" [label="HotPath\lv4 = v0 << 2\lv5 = load(v1, v4)\lv6 = typeCheck(v5)\lif v6\l", ion_loop_depth=0];
  "bailout" [label="Bailout\lv99 = deoptimize()\lunreachable\l", ion_loop_depth=0];
  "outer_header" [label="OuterLoop\lv7 = phi(v3, v30)\lv8 = phi(v3, v29)\lv9 = load(v1, v7)\lv10 = bitand(v9, 0xff)\lif v10 != 0\l", ion_loop_depth=1, ion_loop_header=true];
  "inner_header" [label="InnerLoop\lv11 = phi(v3, v22)\lv12 = phi(v8, v21)\lv13 = v7 + v11\lv14 = load(v1, v13)\lv15 = boundsCheck(v13, v2)\lif v14 < v10\l", ion_loop_depth=2, ion_loop_header=true];
  "accumulate" [label="Accumulate\lv16 = v14 * v14\lv17 = v12 + v16\lv18 = overflow(v17)\lif v18\l", ion_loop_depth=2];
  "clamp" [label="Clamp\lv19 = loadConst(0x7fffffff)\lv20 = min(v17, v19)\l", ion_loop_depth=2];
  "inc" [label="InnerInc\lv21 = phi(v17, v20)\lv22 = v11 + 1\l", ion_loop_depth=2];
  "inner_back" [label="InnerBack\lgoto InnerLoop\l", ion_loop_depth=2, ion_backedge=true];
  "inner_exit" [label="InnerExit\lv23 = v12\lv24 = v7 + v10\lv25 = cmp(v24, v2)\lif v25\l", ion_loop_depth=1];
  "outer_inc" [label="OuterInc\lv29 = v23\lv30 = v7 + 1\l", ion_loop_depth=1];
  "outer_back" [label="OuterBack\lgoto OuterLoop\l", ion_loop_depth=1, ion_backedge=true];
  "outer_exit" [label="OuterExit\lv26 = v8\lv27 = store(v1, v3, v26)\l", ion_loop_depth=0];
  "finalize" [label="Finalize\lv28 = phi(v23, v26)\lv31 = hash(v28)\lv32 = logResult(v31)\lreturn v28\l", ion_loop_depth=0];
  "cold" [label="ColdPath\lv40 = call(slowInterp, v0, v1)\lv41 = typeCheck(v40)\lif v41\l", ion_loop_depth=0];
  "cold_ok" [label="ColdOK\lv42 = unbox(v40)\lv43 = store(v1, v3, v42)\l", ion_loop_depth=0];
  "cold_fail" [label="ColdFail\lv44 = newError(\"type\")\lthrow v44\l", ion_loop_depth=0];
  "entry" -> "hot";
  "entry" -> "cold";
  "hot" -> "outer_header";
  "hot" -> "bailout";
  "outer_header" -> "inner_header";
  "outer_header" -> "outer_exit";
  "inner_header" -> "accumulate";
  "inner_header" -> "inner_exit";
  "accumulate" -> "clamp";
  "accumulate" -> "inc";
  "clamp" -> "inc";
  "inc" -> "inner_back";
  "inner_back" -> "inner_header";
  "inner_exit" -> "finalize";
  "inner_exit" -> "outer_inc";
  "outer_inc" -> "outer_back";
  "outer_back" -> "outer_header";
  "outer_exit" -> "finalize";
  "cold" -> "cold_ok";
  "cold" -> "cold_fail";
  "cold_ok" -> "finalize";
}
