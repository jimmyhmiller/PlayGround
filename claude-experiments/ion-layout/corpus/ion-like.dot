digraph IonLike {
  graph [rankdir=TB]
  node [
    shape=box
    style=rounded
    fontname="Menlo"
    fontsize=15
    margin="0.18,0.12"
  ]

  B0 [label="Block 0\n\nv1 = Parameter(0)\nv2 = Parameter(1)\nv3 = Parameter(2)\nv4 = Constant(0)\nGoto B1"]
  B1 [label="Block 1\n\nv5 = Phi(v4, v24)\nv6 = LessThan(v5, v3)\nGotoIf v6 ? B2 : B9"]
  B2 [label="Block 2\n\nv7 = LoadElement(v1, v5)\nv8 = BitAnd(v7, 1)\nv9 = Equal(v8, 0)\nGotoIf v9 ? B3 : B4"]
  B3 [label="Block 3\n\nv10 = Add(v7, v2)\nv11 = Mul(v10, 2)\nv12 = Int32ToDouble(v11)\nGoto B5"]
  B4 [label="Block 4\n\nv13 = Sub(v7, v2)\nv14 = Mul(v13, 3)\nv15 = Int32ToDouble(v14)\nGoto B5"]
  B5 [label="Block 5\n\nv16 = Phi(v12, v15)\nv17 = GreaterThan(v16, 100)\nGotoIf v17 ? B6 : B7"]
  B6 [label="Block 6\n\nv18 = CallRuntime(Clamp, v16)\nv19 = StoreElement(v1, v5, v18)\nGoto B8"]
  B7 [label="Block 7\n\nv20 = Add(v16, 1)\nv21 = StoreElement(v1, v5, v20)\nGoto B8"]
  B8 [label="Block 8\n\nv22 = LoadElement(v1, v5)\nv23 = Add(v22, v5)\nv24 = Add(v5, 1)\nGoto B1"]
  B9 [label="Block 9\n\nv25 = LoadElement(v1, v4)\nv26 = Return(v25)"]

  B0 -> B1
  B1 -> B2
  B1 -> B9
  B2 -> B3
  B2 -> B4
  B3 -> B5
  B4 -> B5
  B5 -> B6
  B5 -> B7
  B6 -> B8
  B7 -> B8
  B8 -> B1
}
