// Array demo: a fixed-size, O(1)-indexable vector of GC-traced slots.
//
//   ai-lang add examples/array_demo.ail
//   ai-lang run main
//
// `Array<T>` stores uniform slots; scalar element types (Int/Float/Bool)
// get an UNBOXED representation when the creation site's type is known
// (here, via the `-> Array<Int>` / `-> Array<Point>` return types).
//
// Indexing is CHECKED: `array_get`/`array_set` return
// `Result<_, IndexError>`, and `?` threads an out-of-bounds error out as
// a value (fused — the happy path never builds a Result). Code that has
// proven its indices can use `array_get_trusted`/`array_set_trusted`,
// which skip nothing but ABORT the process on a violation (a bug).

def make_ints(n: Int) -> Array<Int> = array_new(n)

// a[i] = i*i for every slot.
def fill_squares(a: Array<Int>, i: Int) -> Result<Int, IndexError> =
    if i >= array_len(a) { Result::Ok(0) } else {
        let _s = array_set(a, i, i * i)?;
        fill_squares(a, i + 1)
    }

def sum(a: Array<Int>, i: Int, acc: Int) -> Result<Int, IndexError> =
    if i >= array_len(a) { Result::Ok(acc) } else {
        sum(a, i + 1, acc + array_get(a, i)?)
    }

// Arrays of structs: slots hold real heap pointers, traced + relocated
// by the GC like any other pointer.
struct Point { x: Int, y: Int }
def make_points(n: Int) -> Array<Point> = array_new(n)

def or_zero(r: Result<Int, IndexError>) -> Int =
    match r {
        Result::Ok(v) => v,
        Result::Err(_) => 0 - 1,
    }

def run() -> Result<Int, IndexError> = {
    let a = make_ints(10);
    let _f = fill_squares(a, 0)?;
    // squares of 0..9 sum to 285.
    let total = sum(a, 0, 0)?;
    let _p1 = println(string_concat(
        "sum of squares 0..9 = ", int_to_string(total)));
    let _p2 = println(string_concat("a[7] = ", int_to_string(array_get(a, 7)?)));

    // An out-of-bounds index is an ERROR VALUE, not a crash.
    let _p3 = println(string_concat(
        "a[99] (out of bounds) = ", int_to_string(or_zero(array_get(a, 99)))));

    // Stress the GC, then confirm the array's contents survived.
    let _g = make_ints(0);
    let _c = gc_collect();
    let _p4 = println(string_concat(
        "after GC, a[9] = ", int_to_string(array_get(a, 9)?)));

    // Struct elements.
    let pts = make_points(3);
    let _q = array_set(pts, 0, Point { x: 3, y: 4 })?;
    let p = array_get(pts, 0)?;
    let _p5 = println(string_concat(
        "pts[0].x + pts[0].y = ", int_to_string(p.x + p.y)));

    Result::Ok(total)
}

def main() -> Int = or_zero(run())
