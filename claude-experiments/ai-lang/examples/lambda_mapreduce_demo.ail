// Program A: distributed map-reduce over a GENERIC AWS Lambda worker.
//
// The worker (deploy/ + `ai-lang lambda-worker`) has NO baked-in logic.
// Program A SHIPS the computation as ai-lang source in each invoke payload
// and fans the chunks out across parallel invocations; Lambda auto-scales;
// A reduces the partials. Deploy the worker once, ever — the work is
// chosen here, at call time.
//
//   ai-lang add examples/lambda_mapreduce_demo.ail
//   AWS_ACCESS_KEY_ID=... AWS_SECRET_ACCESS_KEY=... ai-lang run main

def env_or(name: String, fallback: String) -> String = {
    let v = env_get(name);
    if string_is_empty(v) == 1 { fallback } else { v }
}

// The code we hand the worker: sum the half-open range [lo, hi).
def task_source() -> String =
    string_concat(
      "def task(input: String) -> String = int_to_string(sum_range(field_int(input, \"lo\"), field_int(input, \"hi\"), 0)) ",
      string_concat(
        "def sum_range(lo: Int, hi: Int, acc: Int) -> Int = if lo >= hi { acc } else { sum_range(lo + 1, hi, acc + lo) } ",
        "def field_int(s: String, k: String) -> Int = match parse_json(s) { Ok(j) => match json_get(j, k) { Some(v) => match json_int(v) { Some(n) => n, None => 0 }, None => 0 }, Err(e) => 0 }"))

def chunk_input(lo: Int, hi: Int) -> String =
    str4("{\"lo\":", int_to_string(lo), ",\"hi\":", string_concat(int_to_string(hi), "}"))

def chunks(start: Int, total: Int, per: Int, acc: List<String>) -> List<String> =
    if start >= total {
        list_reverse(acc)
    } else {
        let hi = if start + per > total { total } else { start + per };
        chunks(hi, total, per, Cons(ListCell { head: chunk_input(start, hi), tail: acc }))
    }

// Each worker returns its partial sum as a decimal string in the body.
def partial(resp: HttpResponse) -> Int =
    if resp.status == 200 {
        if string_is_int(resp.body) == 1 { string_to_int(resp.body) } else { 0 }
    } else { 0 }

def reduce_sum(resps: List<HttpResponse>, acc: Int) -> Int =
    match resps {
        Nil => acc,
        Cons(cell) => reduce_sum(cell.tail, acc + partial(cell.head))
    }

def main() -> Int = {
    let region = env_or("AWS_REGION", "us-east-1");
    let name = env_or("LAMBDA_FUNCTION", "ai-lang-worker");
    let ak = env_get("AWS_ACCESS_KEY_ID");
    let sk = env_get("AWS_SECRET_ACCESS_KEY");
    let token = env_get("AWS_SESSION_TOKEN");
    let total = 2000;
    let per = 100;                       // 20 chunks -> 20 parallel invocations
    let inputs = chunks(0, total, per, Nil);
    let a = println(str3("shipping code to ", int_to_string(list_length(inputs)), " parallel generic-worker invocations..."));
    let resps = lambda_run_code_many(region, name, task_source(), inputs, ak, sk, token);
    let result = reduce_sum(resps, 0);
    println(str4("sum 0..", int_to_string(total), " = ", int_to_string(result)))
}
