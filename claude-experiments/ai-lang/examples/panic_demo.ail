// Panic demo: `panic(msg)` is the language's hard-error path. It prints
// the message to stderr and aborts the process. Its type is the bottom
// type `Never`, so it can sit in any branch / match arm / function body
// regardless of the surrounding expected type.
//
//   ai-lang add examples/panic_demo.ail
//   ai-lang run main      # aborts with: ai-lang panic: index out of range: -1
//
// Run with a non-negative input by editing `idx` to see the happy path.

// A guarded lookup: negative indices are a programmer error, so we
// panic rather than return a bogus value. The `else` branch is Int; the
// `then` branch diverges. The `if` still typechecks (Never unifies).
def checked_get(idx: Int) -> Int =
    if idx < 0 {
        panic("index out of range")
    } else {
        idx * 10
    }

// `panic` inside a match arm. The reached arm returns Int; the
// unreached arm diverges.
def must_be_positive(x: Int) -> Int =
    match Some(x) {
        Some(_) =>
            if x > 0 { x } else { panic("expected a positive number") },
        None => panic("impossible: Some is always Some")
    }

def main() -> Int = {
    // Happy path first: prints 50.
    let ok = checked_get(5);
    let _p1 = println(string_concat("checked_get(5) = ", int_to_string(ok)));

    let pos = must_be_positive(3);
    let _p2 = println(string_concat("must_be_positive(3) = ", int_to_string(pos)));

    // Now trigger a hard error. This aborts the process; nothing after
    // this line runs.
    let _boom = checked_get(0 - 1);
    _boom
}
