// Transformer model for MIDI sequence generation
// Uses ALiBi (Attention with Linear Biases) instead of position embeddings
// Shape dimensions are symbolic — resolved at compile time

dim B    // batch size
dim T    // sequence length
dim V    // vocabulary size
dim D    // embedding dimension
dim H    // number of attention heads
dim S    // head size (D / H)
dim M    // MLP hidden dimension (4 * D)

// ─── Helper functions ──────────────────────────────────────────────────────

fn layernorm(x, gamma, beta) {
    let mean = mul(sum(x, axis: 2), INV_D)
    let xc = sub(x, mean)
    let var = mul(sum(mul(xc, xc), axis: 2), INV_D)
    let std = sqrt(add(var, 0.00001))
    let normed = mul(xc, recip(std))
    add(mul(normed, gamma), beta)
}

fn clamp(x, lo, hi) {
    let upper = neg(max(neg(x), neg(hi)))
    max(upper, lo)
}

fn gelu(x) {
    let x3 = mul(mul(x, x), x)
    let inner = mul(0.7978845608028654, add(x, mul(0.044715, x3)))
    let clamped = clamp(inner, neg(10.0), 10.0)
    let z2 = mul(clamped, 2.0)
    let ez2 = exp(z2)
    let tanh_val = mul(sub(ez2, 1.0), recip(add(ez2, 1.0)))
    mul(mul(0.5, x), add(1.0, tanh_val))
}

fn linear(x, w, b) {
    add(matmul(x, w), b)
}

fn softmax_attn(x) {
    let m = max(x, axis: 3)
    let e = exp(sub(x, m))
    let s = sum(e, axis: 3)
    mul(recip(s), e)
}

// ─── Inputs ────────────────────────────────────────────────────────────────

let tokens = load([B, T])
let wte = load([V, D])

// ─── Token embedding (no position embedding — ALiBi handles position) ────

let classes = arange(V)
let cls = reshape(classes, [1, 1, V])
let cls_exp = expand(cls, [B, T, V])
let tok_r = reshape(tokens, [B, T, 1])
let tok_exp = expand(tok_r, [B, T, V])
let lo = sub(cls_exp, 0.5)
let hi = add(cls_exp, 0.5)
let one_hot = mul(cmplt(lo, tok_exp), cmplt(tok_exp, hi))
let x = matmul(one_hot, wte)

// ─── Causal mask + ALiBi bias ──────────────────────────────────────────────
// ALiBi: each head gets a slope. Closer tokens get higher attention.
// slope_h = 2^(-8/H * (h+1))  computed via exp2

let head_idx = arange(H)
let head_exp = mul(add(head_idx, 1.0), NEG_EIGHT_OVER_H)
let alibi_slopes = exp2(head_exp)

// Distance matrix: dist[i,j] = j - i (negative for past tokens)
let row = expand(reshape(arange(T), [1, 1, T, 1]), [1, 1, T, T])
let col = expand(reshape(arange(T), [1, 1, 1, T]), [1, 1, T, T])
let dist = sub(col, row)

// Causal mask: -1e6 for future (j > i)
let causal = mul(cmplt(row, col), neg(1000000.0))

// ALiBi bias: slopes[h] * dist[i,j] — penalizes distant past tokens
let slopes_r = expand(reshape(alibi_slopes, [1, H, 1, 1]), [1, H, T, T])
let dist_h = expand(dist, [1, H, T, T])
let alibi = mul(slopes_r, dist_h)

// Combined attention bias (causal mask + ALiBi)
let attn_bias = expand(add(causal, alibi), [B, H, T, T])

// ─── Transformer Layer 0 ──────────────────────────────────────────────────

let ln1_g_0 = load([D])
let ln1_b_0 = load([D])
let qkv_w_0 = load([D, 3 * D])
let qkv_b_0 = load([3 * D])
let proj_w_0 = load([D, D])
let proj_b_0 = load([D])
let ln2_g_0 = load([D])
let ln2_b_0 = load([D])
let fc_w_0 = load([D, M])
let fc_b_0 = load([M])
let mlp_w_0 = load([M, D])
let mlp_b_0 = load([D])

let ln1_0 = layernorm(x, ln1_g_0, ln1_b_0)
let qkv_0 = linear(ln1_0, qkv_w_0, qkv_b_0)
let qkv_r_0 = reshape(qkv_0, [B, T, 3, H, S])
let q_0 = reshape(shrink(qkv_r_0, [[0, B], [0, T], [0, 1], [0, H], [0, S]]), [B, T, H, S])
let k_0 = reshape(shrink(qkv_r_0, [[0, B], [0, T], [1, 2], [0, H], [0, S]]), [B, T, H, S])
let v_0 = reshape(shrink(qkv_r_0, [[0, B], [0, T], [2, 3], [0, H], [0, S]]), [B, T, H, S])
let q_h_0 = permute(q_0, [0, 2, 1, 3])
let k_h_0 = permute(k_0, [0, 2, 1, 3])
let v_h_0 = permute(v_0, [0, 2, 1, 3])
let kt_0 = permute(k_h_0, [0, 1, 3, 2])
let scores_0 = mul(matmul(q_h_0, kt_0), INV_SQRT_S)
let masked_0 = add(scores_0, attn_bias)
let attn_0 = softmax_attn(masked_0)
let attn_out_0 = matmul(attn_0, v_h_0)
let merged_0 = reshape(permute(attn_out_0, [0, 2, 1, 3]), [B, T, D])
let attn_proj_0 = linear(merged_0, proj_w_0, proj_b_0)
let x = add(x, attn_proj_0)

let ln2_0 = layernorm(x, ln2_g_0, ln2_b_0)
let fc_0 = gelu(linear(ln2_0, fc_w_0, fc_b_0))
let mlp_out_0 = linear(fc_0, mlp_w_0, mlp_b_0)
let x = add(x, mlp_out_0)

// ─── Transformer Layer 1 ──────────────────────────────────────────────────

let ln1_g_1 = load([D])
let ln1_b_1 = load([D])
let qkv_w_1 = load([D, 3 * D])
let qkv_b_1 = load([3 * D])
let proj_w_1 = load([D, D])
let proj_b_1 = load([D])
let ln2_g_1 = load([D])
let ln2_b_1 = load([D])
let fc_w_1 = load([D, M])
let fc_b_1 = load([M])
let mlp_w_1 = load([M, D])
let mlp_b_1 = load([D])

let ln1_1 = layernorm(x, ln1_g_1, ln1_b_1)
let qkv_1 = linear(ln1_1, qkv_w_1, qkv_b_1)
let qkv_r_1 = reshape(qkv_1, [B, T, 3, H, S])
let q_1 = reshape(shrink(qkv_r_1, [[0, B], [0, T], [0, 1], [0, H], [0, S]]), [B, T, H, S])
let k_1 = reshape(shrink(qkv_r_1, [[0, B], [0, T], [1, 2], [0, H], [0, S]]), [B, T, H, S])
let v_1 = reshape(shrink(qkv_r_1, [[0, B], [0, T], [2, 3], [0, H], [0, S]]), [B, T, H, S])
let q_h_1 = permute(q_1, [0, 2, 1, 3])
let k_h_1 = permute(k_1, [0, 2, 1, 3])
let v_h_1 = permute(v_1, [0, 2, 1, 3])
let kt_1 = permute(k_h_1, [0, 1, 3, 2])
let scores_1 = mul(matmul(q_h_1, kt_1), INV_SQRT_S)
let masked_1 = add(scores_1, attn_bias)
let attn_1 = softmax_attn(masked_1)
let attn_out_1 = matmul(attn_1, v_h_1)
let merged_1 = reshape(permute(attn_out_1, [0, 2, 1, 3]), [B, T, D])
let attn_proj_1 = linear(merged_1, proj_w_1, proj_b_1)
let x = add(x, attn_proj_1)

let ln2_1 = layernorm(x, ln2_g_1, ln2_b_1)
let fc_1 = gelu(linear(ln2_1, fc_w_1, fc_b_1))
let mlp_out_1 = linear(fc_1, mlp_w_1, mlp_b_1)
let x = add(x, mlp_out_1)

// ─── Output projection (weight-tied with wte) ─────────────────────────────

let ln_f_g = load([D])
let ln_f_b = load([D])
let x_norm = layernorm(x, ln_f_g, ln_f_b)
let wte_t = permute(reshape(wte, [1, V, D]), [0, 2, 1])
let wte_2d = reshape(wte_t, [D, V])
let logits = matmul(x_norm, wte_2d)
