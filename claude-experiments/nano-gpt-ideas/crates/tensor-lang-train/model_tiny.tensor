// Tiny 1-layer transformer for chord grammar learning
// Uses ALiBi (no position embeddings)

dim B    // batch size
dim T    // sequence length
dim V    // vocabulary size
dim D    // embedding dimension
dim H    // number of attention heads
dim S    // head size (D / H)
dim M    // MLP hidden dimension (4 * D)

// ─── Helpers ──────────────────────────────────────────────────────────────

fn layernorm(x, gamma, beta) {
    let mean = mul(sum(x, axis: 2), INV_D)
    let xc = sub(x, mean)
    let var = mul(sum(mul(xc, xc), axis: 2), INV_D)
    let std = sqrt(add(var, 0.00001))
    let normed = mul(xc, recip(std))
    add(mul(normed, gamma), beta)
}

fn clamp(x, lo, hi) {
    let upper = neg(max(neg(x), neg(hi)))
    max(upper, lo)
}

fn gelu(x) {
    let x3 = mul(mul(x, x), x)
    let inner = mul(0.7978845608028654, add(x, mul(0.044715, x3)))
    let clamped = clamp(inner, neg(10.0), 10.0)
    let z2 = mul(clamped, 2.0)
    let ez2 = exp(z2)
    let tanh_val = mul(sub(ez2, 1.0), recip(add(ez2, 1.0)))
    mul(mul(0.5, x), add(1.0, tanh_val))
}

fn linear(x, w, b) {
    add(matmul(x, w), b)
}

fn softmax_attn(x) {
    let m = max(x, axis: 3)
    let e = exp(sub(x, m))
    let s = sum(e, axis: 3)
    mul(recip(s), e)
}

// ─── Inputs ────────────────────────────────────────────────────────────────

let tokens = load([B, T])
let wte = load([V, D])

// ─── Token embedding ──────────────────────────────────────────────────────

let classes = arange(V)
let cls = reshape(classes, [1, 1, V])
let cls_exp = expand(cls, [B, T, V])
let tok_r = reshape(tokens, [B, T, 1])
let tok_exp = expand(tok_r, [B, T, V])
let lo = sub(cls_exp, 0.5)
let hi = add(cls_exp, 0.5)
let one_hot = mul(cmplt(lo, tok_exp), cmplt(tok_exp, hi))
let x = matmul(one_hot, wte)

// ─── Causal mask + ALiBi ──────────────────────────────────────────────────

let head_idx = arange(H)
let head_exp = mul(add(head_idx, 1.0), NEG_EIGHT_OVER_H)
let alibi_slopes = exp2(head_exp)

let row = expand(reshape(arange(T), [1, 1, T, 1]), [1, 1, T, T])
let col = expand(reshape(arange(T), [1, 1, 1, T]), [1, 1, T, T])
let dist = sub(col, row)

let causal = mul(cmplt(row, col), neg(1000000.0))

let slopes_r = expand(reshape(alibi_slopes, [1, H, 1, 1]), [1, H, T, T])
let dist_h = expand(dist, [1, H, T, T])
let alibi = mul(slopes_r, dist_h)

let attn_bias = expand(add(causal, alibi), [B, H, T, T])

// ─── Single Transformer Layer ─────────────────────────────────────────────

let ln1_g = load([D])
let ln1_b = load([D])
let qkv_w = load([D, 3 * D])
let qkv_b = load([3 * D])
let proj_w = load([D, D])
let proj_b = load([D])
let ln2_g = load([D])
let ln2_b = load([D])
let fc_w = load([D, M])
let fc_b = load([M])
let mlp_w = load([M, D])
let mlp_b = load([D])

let ln1 = layernorm(x, ln1_g, ln1_b)
let qkv = linear(ln1, qkv_w, qkv_b)
let qkv_r = reshape(qkv, [B, T, 3, H, S])
let q = reshape(shrink(qkv_r, [[0, B], [0, T], [0, 1], [0, H], [0, S]]), [B, T, H, S])
let k = reshape(shrink(qkv_r, [[0, B], [0, T], [1, 2], [0, H], [0, S]]), [B, T, H, S])
let v = reshape(shrink(qkv_r, [[0, B], [0, T], [2, 3], [0, H], [0, S]]), [B, T, H, S])
let q_h = permute(q, [0, 2, 1, 3])
let k_h = permute(k, [0, 2, 1, 3])
let v_h = permute(v, [0, 2, 1, 3])
let kt = permute(k_h, [0, 1, 3, 2])
let scores = mul(matmul(q_h, kt), INV_SQRT_S)
let masked = add(scores, attn_bias)
let attn = softmax_attn(masked)
let attn_out = matmul(attn, v_h)
let merged = reshape(permute(attn_out, [0, 2, 1, 3]), [B, T, D])
let attn_proj = linear(merged, proj_w, proj_b)
let x = add(x, attn_proj)

let ln2 = layernorm(x, ln2_g, ln2_b)
let fc = gelu(linear(ln2, fc_w, fc_b))
let mlp_out = linear(fc, mlp_w, mlp_b)
let x = add(x, mlp_out)

// ─── Output (weight-tied with wte) ────────────────────────────────────────

let ln_f_g = load([D])
let ln_f_b = load([D])
let x_norm = layernorm(x, ln_f_g, ln_f_b)
let wte_t = permute(reshape(wte, [1, V, D]), [0, 2, 1])
let wte_2d = reshape(wte_t, [D, V])
let logits = matmul(x_norm, wte_2d)
