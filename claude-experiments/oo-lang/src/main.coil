; main.coil — the `scry` CLI (Phase 1: front end only).
;   scry parse-dump <file.scry>   parse and print the AST (stable golden format)
;   scry run <file.scry>          hard-errors: not implemented until Phase 3
(module app)
(import "src/ioutil.coil" :use *)
(import "src/lexer.coil" :use *)
(import "src/ast.coil" :use *)
(import "src/parser.coil" :use *)
(import "src/types.coil" :use *)
(import "src/typecheck.coil" :use *)
(import "src/compile.coil" :use *)
(import "src/server.coil" :use *)

(defn read-file [(path (ptr i8))] (-> (ptr u8))
  (let [file (fopen path c"rb")]
    (if (= (cast i64 file) 0)
      (do (w-cstr 2 c"scry: could not open file: ") (w-cstr 2 path) (w-cstr 2 c"\n")
          (exit (cast i32 74)) (cast (ptr u8) 0))
      (do
        (fseek file 0 (cast i32 2))
        (let [file-size (ftell file)]
          (rewind file)
          (let [buffer (xalloc (+ file-size 1))]
            (let [bytes-read (fread (cast (ptr i8) buffer) 1 file-size file)]
              (store! (index buffer bytes-read) (cast u8 0))
              (fclose file)
              buffer)))))))

(defn cstr-eq [(a (ptr i8)) (b (ptr i8))] (-> bool) (= (cast i64 (strcmp a b)) 0))

(defn usage [] (-> i64)
  (w-cstr 2 c"scry — the Scry compiler (Phase 2: front end + typechecker)\n")
  (w-cstr 2 c"usage:\n")
  (w-cstr 2 c"  scry parse-dump <file.scry>   parse and print the AST\n")
  (w-cstr 2 c"  scry check <file.scry>        typecheck (follows imports)\n")
  (w-cstr 2 c"  scry run <file.scry>          (not implemented until Phase 3)\n")
  0)

(defn cmd-check [(argc i64) (argv (ptr (ptr i8)))] (-> i64)
  (if (< argc 3)
    (do (w-cstr 2 c"scry check: expected a file argument\n") 64)
    (run-check (load (index argv 2)))))

(defn cmd-dump-types [(argc i64) (argv (ptr (ptr i8)))] (-> i64)
  (if (< argc 3)
    (do (w-cstr 2 c"scry dump-types: expected a file argument\n") 64)
    (run-dump-types (load (index argv 2)))))

(defn cmd-parse-dump [(argc i64) (argv (ptr (ptr i8)))] (-> i64)
  (if (< argc 3)
    (do (w-cstr 2 c"scry parse-dump: expected a file argument\n") 64)
    (let [path (load (index argv 2))
          src (read-file path)]
      (if (= (lex-file src path) 1)
        1
        (do
          (parser-init (lexer-tokens) path)
          (dump-program (parse-program))
          0)))))

; resolve the viewer/ asset directory: next to argv[0], else CWD.
(defn resolve-viewer-dir [(argv0 (ptr i8))] (-> (ptr i8))
  (let [cand (join-path (dirname argv0) c"viewer/")
        idx (join-path cand c"index.html")]
    (if (can-open idx) cand (cast (ptr i8) c"viewer/"))))

; scry run [--dump-arenas | --no-viewer | --readonly] <file.scry>
(defn cmd-run [(argc i64) (argv (ptr (ptr i8)))] (-> i64)
  (let [(mut file) (cast (ptr i8) 0) (mut dump) false (mut noview) false (mut ro) false (mut i) 2]
    (loop (if (< (load i) argc)
            (let [a (load (index argv (load i)))]
              (cond
                (cstr-eq a c"--dump-arenas") (do (store! dump true) 0)
                (cstr-eq a c"--no-viewer") (do (store! noview true) 0)
                (cstr-eq a c"--readonly") (do (store! ro true) 0)
                (do (store! file a) 0))
              (store! i (+ (load i) 1)) 0)
            (break)))
    (if (= (cast i64 (load file)) 0) (do (w-cstr 2 c"scry run: expected a file argument\n") 64)
      (if (load dump)
        (scry-run (load file) true)
        (scry-serve (load file) (resolve-viewer-dir (load (index argv 0))) (load noview) (load ro))))))

; scry eval <file.scry> -e "<expr>" [--readonly]
(defn cmd-eval [(argc i64) (argv (ptr (ptr i8)))] (-> i64)
  (let [(mut file) (cast (ptr i8) 0) (mut expr) (cast (ptr i8) 0) (mut ro) false (mut i) 2]
    (loop (if (< (load i) argc)
            (let [a (load (index argv (load i)))]
              (cond
                (cstr-eq a c"-e") (do (store! i (+ (load i) 1)) (if (< (load i) argc) (do (store! expr (load (index argv (load i)))) 0) 0) 0)
                (cstr-eq a c"--readonly") (do (store! ro true) 0)
                (do (store! file a) 0))
              (store! i (+ (load i) 1)) 0)
            (break)))
    (if (or (= (cast i64 (load file)) 0) (= (cast i64 (load expr)) 0))
      (do (w-cstr 2 c"usage: scry eval <file.scry> -e \"<expr>\" [--readonly]\n") 64)
      (scry-eval-cli (load file) (cast (ptr u8) (load expr)) (strlen (load expr)) (load ro)))))

(defn cmd-dump-bytecode [(argc i64) (argv (ptr (ptr i8)))] (-> i64)
  (if (< argc 3)
    (do (w-cstr 2 c"scry dump-bytecode: expected a file argument\n") 64)
    (scry-dump-bytecode (load (index argv 2)))))

(defn main [(argc i32) (argv (ptr (ptr i8)))] (-> i64)
  (let [n (cast i64 argc)]
    (if (< n 2)
      (do (usage) 64)
      (let [sub (load (index argv 1))]
        (cond
          (cstr-eq sub c"parse-dump") (cmd-parse-dump n argv)
          (cstr-eq sub c"check") (cmd-check n argv)
          (cstr-eq sub c"dump-types") (cmd-dump-types n argv)
          (cstr-eq sub c"dump-bytecode") (cmd-dump-bytecode n argv)
          (cstr-eq sub c"run") (cmd-run n argv)
          (cstr-eq sub c"eval") (cmd-eval n argv)
          (do (w-cstr 2 c"scry: unknown command\n") (usage) 64))))))
