; arena.coil — the per-type slab arena allocator (02-runtime.md §3/§4), M0 form.
;
; One TypeArena per entity mono type-id. Slabs are fixed-capacity blocks (~64 KiB)
; with a flat bump frontier and a free-list (Treiber-shaped but single-threaded in
; M0 — magazines + atomics land in M1, see docs/06-implementation.md). Stable
; object identity is (type-id, slot-index, generation), stamped into InstanceHeader.
;
; PHASE 5 ALLOC STRATEGY (as-built — see 06-implementation.md "alloc strategy"):
;  The shared arena is made race-free with an ATOMIC bump frontier + a per-arena spinlock
;  guarding slab growth — the documented "simpler correct thing" (05 M1 lets us pick this
;  at 3-5 threads), NOT yet the per-thread magazines of §4. It is deliberately shaped so
;  magazines slot in on top later: a magazine's refill is exactly one `atomic-add` of
;  bump-cursor by MAGAZINE_CAP instead of by 1, over this same shared layer.
;   - bump-cursor is bumped with `atomic-add` (returns the reserved slot; unique per caller,
;     so two threads never get the same slot — no CAS loop needed, the frontier only grows).
;   - live-count is `atomic-add`/`atomic-sub` (coarse, eventually consistent — §4).
;   - slab growth (malloc a new 64KiB block + publish its base) takes the per-arena
;     `growing` CAS spinlock; the common case (slot already inside a mapped slab) never
;     touches it, just an `atomic-load` of slab-count.
;   - the `slabs` base-pointer array is PRE-SIZED to the type's max at arena-new and NEVER
;     realloc'd, so a concurrent arena-slot-ptr can never read a torn/moved array base.
; DEVIATIONS from §4 still standing: no magazines (above); slot->(slab,local) is div/mod,
; not shift/mask (slab-cap need not be 2^k); InstanceHeader uses i64 fields (not u32).
; The free-list (arena-free) stays present-but-unused until GC lands (no frees in the PoC).
(module arena)
(import "ioutil.coil" :use *)
(import "evalrt.coil" :use *)
(import "atomic.coil" :use *)

; ---- header: every instance begins with this (fixed offset 0) ----
(defstruct InstanceHeader
  [(type-id    i64)     ; which concrete type — recovers TypeInfo for iface dispatch + GC
   (slot-index i64)     ; index within this type's arena (stable id component)
   (generation i64)     ; bumped on free — invalidates viewer handles (Phase 4)
   (flags      i64)])   ; bit0 = live, bit1 = gc-marked (reserved)

(const FLAG_LIVE 1)
(const FLAG_MARKED 2)

(defstruct TypeArena
  [(type-id     i64)
   (name        (ptr u8)) (name-len i64)   ; for --dump-arenas + OutOfArenaSpace
   (slot-size   i64)      ; sizeof(InstanceHeader)+fields, padded to 8
   (slab-cap    i64)      ; slots per slab
   (slabs       (ptr (ptr u8)))   ; growable array of slab base pointers
   (slab-count  i64)
   (slab-arrcap i64)
   (bump-cursor i64)      ; ATOMIC flat frontier of ever-reserved slots (high-water mark)
   (free-head   i64)      ; index of first free slot, or -1 (unused until GC)
   (growing     i64)      ; ATOMIC 0/1 spinlock — held only while mapping a new slab
   (live-count  i64)      ; ATOMIC coarse live counter
   (max-slots   i64)])    ; budget; exceeding it => OutOfArenaSpace hard error

(defn align8 [(n i64)] (-> i64) (iand (+ n 7) (ixor -1 7)))

(defn arena-new [(type-id i64) (name (ptr u8)) (name-len i64) (fields-size i64) (max-slots i64)] (-> (ptr TypeArena))
  (let [a (cast (ptr TypeArena) (xalloc (sizeof TypeArena)))
        slot (align8 (+ (sizeof InstanceHeader) fields-size))
        cap0 (idiv 65536 slot)
        cap (if (< cap0 8) 8 cap0)
        ; pre-size the slab base-pointer array to the type's whole budget + slack, once,
        ; so it is NEVER realloc'd — a concurrent arena-slot-ptr reads a stable array base.
        max-slabs (+ (idiv max-slots cap) 2)]
    (store! (field a type-id) type-id)
    (store! (field a name) name) (store! (field a name-len) name-len)
    (store! (field a slot-size) slot)
    (store! (field a slab-cap) cap)
    (store! (field a slabs) (cast (ptr (ptr u8)) (xalloc (* (sizeof (ptr u8)) max-slabs))))
    (store! (field a slab-count) 0)
    (store! (field a slab-arrcap) max-slabs)
    (store! (field a bump-cursor) 0)
    (store! (field a free-head) -1)
    (store! (field a growing) 0)
    (store! (field a live-count) 0)
    (store! (field a max-slots) max-slots)
    a))

; slot-index -> raw byte pointer
(defn arena-slot-ptr [(a (ptr TypeArena)) (idx i64)] (-> (ptr u8))
  (let [cap (load (field a slab-cap))
        slabno (idiv idx cap)
        local (irem idx cap)
        base (load (index (load (field a slabs)) slabno))]
    (index base (* local (load (field a slot-size))))))

; malloc+zero a fresh slab and publish it. MUST be called holding the `growing` lock.
; The slabs array is pre-sized (arena-new), so this never realloc's it; it writes the base
; pointer then advances slab-count with an atomic-store, so a reader that atomic-loads
; slab-count >= slab#+1 is guaranteed to see the fully-written base (seq_cst publish).
(defn arena-add-slab [(a (ptr TypeArena))] (-> i64)
  (let [bytes (* (load (field a slab-cap)) (load (field a slot-size)))
        blk (xalloc bytes)]
    (memset (cast (ptr i8) blk) (cast i32 0) bytes)
    (store! (index (load (field a slabs)) (load (field a slab-count))) blk)
    (atomic-store (field a slab-count) (+ (load (field a slab-count)) 1))
    0))

; ensure the slab containing `idx` is mapped. Common case: already mapped, one atomic-load,
; no lock. Otherwise CAS-acquire `growing`, map slabs up to `need` under it, release.
(defn arena-ensure-slab [(a (ptr TypeArena)) (idx i64)] (-> i64)
  (let [need (+ (idiv idx (load (field a slab-cap))) 1) (mut done) false]
    (loop
      (if (load done) (break)
        (if (>= (atomic-load (field a slab-count)) need) (do (store! done true) 0)
          (if (= (atomic-cas (field a growing) 0 1) 0)
            (do
              (loop (if (< (atomic-load (field a slab-count)) need) (do (arena-add-slab a) 0) (break)))
              (atomic-store (field a growing) 0)
              (store! done true) 0)
            (do (usleep (cast i32 20)) 0))))))
  0)

; hard error: budget exceeded before GC exists (05 "What we fake" #1)
(defn arena-oom [(a (ptr TypeArena))] (-> i64)
  (w-cstr 2 c"OutOfArenaSpace: ")
  (w-bytes 2 (load (field a name)) (load (field a name-len)))
  (w-cstr 2 c" arena full at ") (w-int 2 (load (field a max-slots)))
  (w-cstr 2 c" slots (") (w-int 2 (load (field a live-count)))
  (w-cstr 2 c" live) — GC not implemented in this build, restart the process.\n")
  (if (eval-active?) (eval-panic0 EK_RUNTIME c"OutOfArenaSpace: arena full (GC not implemented)") (do (exit (cast i32 70)) 0)) 0)

; allocate one slot; stamps the header (type-id, slot-index, flags=live). Returns ptr.
; THREAD-SAFE: `atomic-add` reserves a unique slot index (no two callers collide, no CAS
; loop — the frontier only grows). The caller then maps its slab (locked only if unmapped)
; and writes ITS OWN slot's header — no other thread touches that slot, so no race there.
; The header's type-id is fully written before OP_NEW ever publishes the pointer to another
; thread (05 M1 risk note: construction-visibility ordering), because publication is a
; later store on the mutator's own stack/field.
(defn arena-alloc [(a (ptr TypeArena))] (-> (ptr u8))
  (let [idx (atomic-add (field a bump-cursor) 1)]   ; returns the OLD frontier = our reserved slot
    (if (>= idx (load (field a max-slots))) (do (arena-oom a) 0) 0)
    (arena-ensure-slab a idx)
    (let [p (cast (ptr InstanceHeader) (arena-slot-ptr a idx))]
      (store! (field p type-id) (load (field a type-id)))
      (store! (field p slot-index) idx)
      (store! (field p flags) FLAG_LIVE)
      (atomic-add (field a live-count) 1)
      (cast (ptr u8) p))))

; free-list push (structure present; unused until GC lands)
(defn arena-free [(a (ptr TypeArena)) (idx i64)] (-> i64)
  (let [p (cast (ptr InstanceHeader) (arena-slot-ptr a idx))]
    (store! (field p generation) (+ (load (field p generation)) 1))
    (store! (field p flags) 0)
    (let [link (cast (ptr i64) p)] (store! link (load (field a free-head))))
    (store! (field a free-head) idx)
    (store! (field a live-count) (- (load (field a live-count)) 1))
    0))

; enumeration — "list every live instance of this type" (the viewer's foundation)
(defn arena-for-each-live [(a (ptr TypeArena)) (f (fnptr c [(ptr u8)] i64))] (-> i64)
  (let [hwm (load (field a bump-cursor)) (mut i) 0]
    (loop
      (if (< (load i) hwm)
        (let [p (cast (ptr InstanceHeader) (arena-slot-ptr a (load i)))]
          (if (= (iand (load (field p flags)) FLAG_LIVE) FLAG_LIVE) (do (call-ptr f (cast (ptr u8) p)) 0) 0)
          (store! i (+ (load i) 1)) 0)
        (break))))
  0)

(defn arena-live-count [(a (ptr TypeArena))] (-> i64) (load (field a live-count)))
(defn arena-hwm [(a (ptr TypeArena))] (-> i64) (load (field a bump-cursor)))
