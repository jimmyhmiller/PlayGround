; gcstate.coil — process-global GC allocation accounting + trigger threshold (02-runtime.md §6).
;
; The whole program is one heap (arenas + non-arena objects). GC's trigger is a single
; `bytes-allocated`/`next-gc` pair summed across every allocation site, exactly clox's
; heuristic. This is a LEAF (imports only atomic) so both the allocator (arena.coil) and the
; non-arena object layer (builtins.coil) can bump the counter without an import cycle, and
; the collector (gc.coil) / VM can read it. `enabled` stays 0 until vm-run arms GC, so the
; static-inspect / typecheck paths that build a Program without running never collect.
(module gcstate)
(import "atomic.coil" :use *)
(import "ioutil.coil" :use *)

(defn gc-bytes-cell  [] (-> (ptr i64)) (alloc-static i64))
(defn gc-nextgc-cell [] (-> (ptr i64)) (alloc-static i64))
(defn gc-enabled-cell [] (-> (ptr i64)) (alloc-static i64))

; ============================ generational state (02 §6, generational) =======
; YOUNG LIST — every fresh object's pointer, appended lock-free (`atomic-add` reserves a unique
; slot, pre-sized so it never reallocs mid-epoch). A MINOR collection sweeps THIS list, not the
; whole heap, so its cost is O(objects-allocated-since-last-minor). Overflow (more objects in one
; epoch than the cap) => the pusher is told (-1) and marks that object OLD, so it's simply
; collected at the next major instead — safe, never lost.
(const GC_YOUNG_CAP 262144)   ; 2 MiB of pointers; the minor byte-threshold fires long before this
(defn gc-young-arr-cell   [] (-> (ptr i64)) (alloc-static i64))
(defn gc-young-count-cell [] (-> (ptr i64)) (alloc-static i64))
(defn gc-young-init [] (-> i64)
  (if (= (load (gc-young-arr-cell)) 0) (do (store! (gc-young-arr-cell) (cast i64 (xalloc (* 8 GC_YOUNG_CAP)))) 0) 0)
  (atomic-store (gc-young-count-cell) 0) 0)
(defn gc-young-push [(p i64)] (-> i64)
  (let [i (atomic-add (gc-young-count-cell) 1)]
    (if (>= i GC_YOUNG_CAP) -1 (do (store! (index (cast (ptr i64) (load (gc-young-arr-cell))) i) p) i))))
(defn gc-young-count [] (-> i64) (let [c (atomic-load (gc-young-count-cell))] (if (> c GC_YOUNG_CAP) GC_YOUNG_CAP c)))
(defn gc-young-at [(i i64)] (-> i64) (load (index (cast (ptr i64) (load (gc-young-arr-cell))) i)))
(defn gc-young-reset [] (-> i64) (atomic-store (gc-young-count-cell) 0) 0)

; REMEMBERED SET — old objects a write barrier caught storing a reference (potential old->young
; edges). A minor treats these as extra roots. Overflow just forces the next collection to be a
; major (which scans everything, needing no remembered set).
(const GC_REM_CAP 65536)
(defn gc-rem-arr-cell   [] (-> (ptr i64)) (alloc-static i64))
(defn gc-rem-count-cell [] (-> (ptr i64)) (alloc-static i64))
(defn gc-rem-overflow-cell [] (-> (ptr i64)) (alloc-static i64))
(defn gc-rem-init [] (-> i64)
  (if (= (load (gc-rem-arr-cell)) 0) (do (store! (gc-rem-arr-cell) (cast i64 (xalloc (* 8 GC_REM_CAP)))) 0) 0)
  (atomic-store (gc-rem-count-cell) 0) (store! (gc-rem-overflow-cell) 0) 0)
(defn gc-rem-push [(p i64)] (-> i64)
  (let [i (atomic-add (gc-rem-count-cell) 1)]
    (if (>= i GC_REM_CAP) (do (store! (gc-rem-overflow-cell) 1) -1) (do (store! (index (cast (ptr i64) (load (gc-rem-arr-cell))) i) p) i))))
(defn gc-rem-count [] (-> i64) (let [c (atomic-load (gc-rem-count-cell))] (if (> c GC_REM_CAP) GC_REM_CAP c)))
(defn gc-rem-at [(i i64)] (-> i64) (load (index (cast (ptr i64) (load (gc-rem-arr-cell))) i)))
(defn gc-rem-reset [] (-> i64) (atomic-store (gc-rem-count-cell) 0) (store! (gc-rem-overflow-cell) 0) 0)
(defn gc-rem-overflow? [] (-> i64) (load (gc-rem-overflow-cell)))

; which collection kind is currently running (mark-object skips OLD objects during a minor).
(defn gc-minor-mode-cell [] (-> (ptr i64)) (alloc-static i64))
(defn gc-in-minor? [] (-> i64) (load (gc-minor-mode-cell)))
(defn gc-set-minor [] (-> i64) (store! (gc-minor-mode-cell) 1) 0)
(defn gc-set-major [] (-> i64) (store! (gc-minor-mode-cell) 0) 0)

; minors since the last major — a major runs every GC_MAJOR_EVERY minors (bounds old-gen floating garbage).
(const GC_MAJOR_EVERY 8)
(defn gc-minors-cell [] (-> (ptr i64)) (alloc-static i64))
(defn gc-minors [] (-> i64) (load (gc-minors-cell)))
(defn gc-minors-inc [] (-> i64) (store! (gc-minors-cell) (+ (load (gc-minors-cell)) 1)) 0)
(defn gc-minors-reset [] (-> i64) (store! (gc-minors-cell) 0) 0)

; force the NEXT collection to be a major (set when an arena genuinely fills — only a major
; reclaims the old generation).
(defn gc-force-major-cell [] (-> (ptr i64)) (alloc-static i64))
(defn gc-force-major? [] (-> i64) (load (gc-force-major-cell)))
(defn gc-request-major [] (-> i64) (store! (gc-force-major-cell) 1) 0)
(defn gc-clear-force-major [] (-> i64) (store! (gc-force-major-cell) 0) 0)

; gc-bytes is MONOTONIC (total allocated); re-arm the trigger GC_MINOR_THRESHOLD bytes ahead after
; every collection, so a (minor) collection fires roughly every threshold of fresh allocation.
(const GC_MINOR_THRESHOLD 2097152)   ; 2 MiB of young allocation between minors
(defn gc-rearm [] (-> i64) (gc-set-nextgc (+ (gc-bytes) GC_MINOR_THRESHOLD)) 0)

; add `n` bytes to the live-allocation estimate (called from every alloc site).
(defn gc-account [(n i64)] (-> i64) (atomic-add (gc-bytes-cell) n) 0)
(defn gc-bytes [] (-> i64) (atomic-load (gc-bytes-cell)))
(defn gc-set-bytes [(v i64)] (-> i64) (atomic-store (gc-bytes-cell) v) 0)

(defn gc-nextgc [] (-> i64) (load (gc-nextgc-cell)))
(defn gc-set-nextgc [(v i64)] (-> i64) (store! (gc-nextgc-cell) v) 0)

(defn gc-enabled? [] (-> i64) (load (gc-enabled-cell)))
(defn gc-enable [] (-> i64) (store! (gc-enabled-cell) 1) 0)
(defn gc-disable [] (-> i64) (store! (gc-enabled-cell) 0) 0)

; should the VM stop the world and collect at its next trigger point? Cheap: one load + cmp.
(defn gc-should? [] (-> i64)
  (if (= (gc-enabled?) 1) (if (> (gc-bytes) (gc-nextgc)) 1 0) 0))
