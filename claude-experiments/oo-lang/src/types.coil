; types.coil — Scry Phase 2 type universe: resolved Types, the symbol/Decl table,
; the monomorphization table (per DECISIONS.md #6 — each distinct generic
; instantiation is its own concrete type identity), built-in types, type
; resolution from AST TYPE nodes, nominal equality/assignability, and the
; diagnostics buffer. typecheck.coil drives the actual body checking on top.
(module types)
(import "ioutil.coil" :use *)
(import "evalrt.coil" :use *)
(import "lexer.coil" :use *)
(import "ast.coil" :use *)
(import "arraylist.coil" :use *)
(import "alloc.coil" :use *)

; ======================================================================
; Type kinds
; ======================================================================
(const TY_ERROR 0)     ; propagates; suppresses cascade errors
(const TY_INT 1)
(const TY_FLOAT 2)
(const TY_BOOL 3)
(const TY_STRING 4)
(const TY_VOID 5)
(const TY_UNIT 6)      ; the '()' type — Ok(()) etc.
(const TY_NAMED 7)     ; class/interface/enum/object/builtin-generic; decl + type args
(const TY_VAR 8)       ; an unsubstituted type parameter (name only)

; Decl kinds (symbol-table entries)
(const DK_CLASS 0)
(const DK_INTERFACE 1)
(const DK_ENUM 2)
(const DK_OBJECT 3)
(const DK_FN 4)             ; top-level function
(const DK_BUILTIN_GEN 5)    ; List / Map / Mutex — generic, class-like, value (no arena)
(const DK_BUILTIN_OBJ 6)    ; Clock / Console / Thread
(const DK_BUILTIN_CLASS 7)  ; ThreadHandle
(const DK_BUILTIN_IFACE 8)  ; Runnable

; ======================================================================
; Structs
; ======================================================================
(defstruct Type
  [(kind i64)
   (name (ptr u8)) (name-len i64)   ; TY_NAMED base name / TY_VAR name
   (decl (ptr Decl))                ; TY_NAMED: the declaring Decl
   (args (ArrayList (ptr Type)))])  ; TY_NAMED: type arguments

(defstruct Decl
  [(kind i64)
   (name (ptr u8)) (name-len i64)
   (node (ptr Node))               ; AST node (CLASS/INTERFACE/ENUM/OBJECT/FN); null for builtins
   (tparams (ArrayList (ptr Node))); type-param name nodes (TYPEPARAM or synthetic TYPE)
   (members (ArrayList (ptr Node)));  fields + methods (for builtins: synthetic FN/FIELD nodes)
   (file (ptr i8))                 ; source filename for diagnostics
   (deep bool)                     ; body deep-checked? (target module only)
   (qmod (ptr u8)) (qmod-len i64)  ; owning module's dotted name; empty (len 0) = builtin prelude
   (impl-decls (ArrayList (ptr Decl)))]) ; resolved `implements` clause targets (class only),
                                          ; cached at check-conformance time so later passes
                                          ; (assignable/codegen) never re-resolve names from
                                          ; ambient module context.

(defstruct MonoField [(name (ptr u8)) (name-len i64) (ty (ptr Type))])

(defstruct MonoType
  [(id i64)
   (name (ptr u8)) (name-len i64)  ; BARE display mangled name, e.g. "Inventory<Tool>" —
                                    ; reflection JSON / dump-types read this; unchanged in Phase 1.
   (qkey (ptr u8)) (qkey-len i64)  ; QUALIFIED identity key, e.g. "a.b.Inventory<a.b.Tool>" —
                                    ; find-mono/intern-mono dedup on THIS, never on `name`
                                    ; (07-modules.md §4: "display names shorten to bare").
   (base (ptr Decl))
   (args (ArrayList (ptr Type)))
   (fields (ArrayList (ptr MonoField)))  ; class/object field layout in decl order
   (is-entity bool)])              ; class/object => arena-backed entity; else value

(defstruct VariantRef
  [(name (ptr u8)) (name-len i64)
   (enum-decl (ptr Decl))
   (vnode (ptr Node))])            ; the VARIANT node

; ---- module bookkeeping (07-modules.md Phase 1) ----------------------------
; a loaded file's derived module name, recorded once at load time.
(defstruct FileMod [(file (ptr i8)) (mod (ptr u8)) (mod-len i64)])
; a registered module name (one per loaded file) — answers "is X a known module?"
; for qualified-reference resolution (07-modules.md §4/§6).
(defstruct ModEntry [(name (ptr u8)) (name-len i64)])
; one `import` binding: bare-name-in-scope (alias if `as`, else the imported symbol)
; -> the resolved target Decl, scoped to the importing file.
(defstruct ImportEntry [(file (ptr i8)) (bare (ptr u8)) (bare-len i64) (target (ptr Decl))])

(defstruct Ctx
  [(decls (ArrayList (ptr Decl)))
   (monos (ArrayList (ptr MonoType)))
   (variants (ArrayList (ptr VariantRef)))
   (views (ArrayList (ptr Node)))    ; program-declared views (NK_VIEW), in source order
   (actions (ArrayList (ptr Node)))  ; program-declared actions (NK_ACTION), in source order
   (cur-file (ptr i8))
   (cur-module (ptr u8)) (cur-module-len i64)   ; ambient module context, tracks cur-file
   (file-mods (ArrayList (ptr FileMod)))
   (modules (ArrayList (ptr ModEntry)))
   (imports (ArrayList (ptr ImportEntry)))
   (entry-file (ptr i8))            ; the very first file passed to load-file
   (proj-root (ptr i8))             ; nearest scry.toml ancestor, else entry file's dir
   (std-root (ptr i8))              ; SCRY_STD env, else dir(argv0)+"std/"
   (argv0 (ptr i8))
   (eval-mod-file (ptr i8))         ; 07-modules.md §6 Phase 2: the file whose module context
                                     ; the CURRENT eval resolves "<eval>" against — entry-file
                                     ; by default, re-pointed per-eval by a `module a.b.c`
                                     ; source header (server.coil eval-module-header). Read by
                                     ; set-cur-file/effective-import-file's "<eval>" fallback.
   (nerr i64)
   (inited bool)])

(defn ctx [] (-> (ptr Ctx)) (alloc-static Ctx))
(defn ctx-init [] (-> i64)
  (if (load (field (ctx) inited)) 0
    (do
      (store! (field (ctx) decls) (al-new [(ptr Decl)] (alc-global)))
      (store! (field (ctx) monos) (al-new [(ptr MonoType)] (alc-global)))
      (store! (field (ctx) variants) (al-new [(ptr VariantRef)] (alc-global)))
      (store! (field (ctx) views) (al-new [(ptr Node)] (alc-global)))
      (store! (field (ctx) actions) (al-new [(ptr Node)] (alc-global)))
      (store! (field (ctx) file-mods) (al-new [(ptr FileMod)] (alc-global)))
      (store! (field (ctx) modules) (al-new [(ptr ModEntry)] (alc-global)))
      (store! (field (ctx) imports) (al-new [(ptr ImportEntry)] (alc-global)))
      (store! (field (ctx) cur-module) (cast (ptr u8) c""))
      (store! (field (ctx) cur-module-len) 0)
      (store! (field (ctx) entry-file) (cast (ptr i8) 0))
      (store! (field (ctx) proj-root) (cast (ptr i8) 0))
      (store! (field (ctx) std-root) (cast (ptr i8) 0))
      (store! (field (ctx) argv0) (cast (ptr i8) 0))
      (store! (field (ctx) eval-mod-file) (cast (ptr i8) 0))
      (store! (field (ctx) nerr) 0)
      (store! (field (ctx) inited) true)
      0)))
(defn set-argv0 [(a (ptr i8))] (-> i64) (store! (field (ctx) argv0) a) 0)

; find this file's registered module (or null if never registered — e.g. the "<eval>"
; pseudo-file, which keeps whatever cur-module was already ambient).
(defn find-file-mod [(f (ptr i8))] (-> (ptr FileMod))
  (let [fs (load (field (ctx) file-mods)) n (al-len fs) (mut i) 0 (mut r) (cast (ptr FileMod) 0)]
    (loop (if (and (= (cast i64 (load r)) 0) (< (load i) n))
            (let [fm (al-get fs (load i))]
              (if (= (cast i64 (strcmp (load (field fm file)) f)) 0) (do (store! r fm) 0) 0)
              (store! i (+ (load i) 1)) 0)
            (break)))
    (load r)))
(defn register-module-for-file [(f (ptr i8)) (mod (ptr u8)) (mod-len i64)] (-> i64)
  (let [fm (cast (ptr FileMod) (xalloc (sizeof FileMod)))]
    (store! (field fm file) f) (store! (field fm mod) mod) (store! (field fm mod-len) mod-len)
    (al-push! (mut (field (ctx) file-mods)) fm)
    (let [me (cast (ptr ModEntry) (xalloc (sizeof ModEntry)))]
      (store! (field me name) mod) (store! (field me name-len) mod-len)
      (al-push! (mut (field (ctx) modules)) me))
    0))
(defn is-known-module [(name (ptr u8)) (len i64)] (-> bool)
  (let [ms (load (field (ctx) modules)) n (al-len ms) (mut i) 0 (mut ok) false]
    (loop (if (and (not (load ok)) (< (load i) n))
            (do (if (name-eq (load (field (al-get ms (load i)) name)) (load (field (al-get ms (load i)) name-len)) name len) (do (store! ok true) 0) 0)
                (store! i (+ (load i) 1)) 0)
            (break)))
    (load ok)))
; reverse of register-module-for-file: the loaded file whose derived module is exactly
; `name` (07-modules.md §6 Phase 2 — resolving an eval `module a.b.c` header to the real
; file whose scope the eval should borrow). Null if `name` names no loaded module.
(defn find-file-for-module [(name (ptr u8)) (len i64)] (-> (ptr i8))
  (let [fs (load (field (ctx) file-mods)) n (al-len fs) (mut i) 0 (mut r) (cast (ptr i8) 0)]
    (loop (if (and (= (cast i64 (load r)) 0) (< (load i) n))
            (let [fm (al-get fs (load i))]
              (if (name-eq (load (field fm mod)) (load (field fm mod-len)) name len) (do (store! r (load (field fm file))) 0) 0)
              (store! i (+ (load i) 1)) 0)
            (break)))
    (load r)))
; the file whose scope "<eval>" should borrow when it has no registered FileMod of its
; own: the CURRENT eval's module context if one has been set (a `module a.b.c` header —
; server.coil eval-module-header sets eval-mod-file), else the entry file (07-modules.md
; §6: "with no [module] header, context defaults to the entry module"). Both set-cur-file
; and effective-import-file read this so the header's effect reaches decl lookup AND
; import-table lookup identically.
(defn eval-fallback-file [] (-> (ptr i8))
  (let [emf (load (field (ctx) eval-mod-file))]
    (if (!= (cast i64 emf) 0) emf (load (field (ctx) entry-file)))))
(defn set-eval-mod-file [(f (ptr i8))] (-> i64) (store! (field (ctx) eval-mod-file) f) 0)
(defn reset-eval-mod-file [] (-> i64) (store! (field (ctx) eval-mod-file) (load (field (ctx) entry-file))) 0)
; cur-file drives ALL ambient name resolution (find-decl); every existing call site
; already calls this before checking/compiling a decl's body, so hooking cur-module
; here — rather than threading a module parameter through 20+ call sites — keeps
; every one of them correct for free. A file with no registered module (the "<eval>"
; pseudo-file used throughout server.coil for live-eval typechecking) falls back to
; eval-fallback-file's scope — the entry module by default, or the eval's `module`
; header target when one was set for this eval (07-modules.md §6).
(defn set-cur-file [(f (ptr i8))] (-> i64)
  (store! (field (ctx) cur-file) f)
  (let [fm (find-file-mod f)]
    (if (!= (cast i64 fm) 0)
      (do (store! (field (ctx) cur-module) (load (field fm mod))) (store! (field (ctx) cur-module-len) (load (field fm mod-len))) 0)
      (let [ef (eval-fallback-file)]
        (if (= (cast i64 ef) 0) 0
          (let [efm (find-file-mod ef)]
            (if (!= (cast i64 efm) 0)
              (do (store! (field (ctx) cur-module) (load (field efm mod))) (store! (field (ctx) cur-module-len) (load (field efm mod-len))) 0)
              0))))))
  0)

; ======================================================================
; name helpers
; ======================================================================
(defn name-eq [(a (ptr u8)) (an i64) (b (ptr u8)) (bn i64)] (-> bool)
  (if (!= an bn)
    false
    (let [(mut i) 0 (mut ok) true]
      (loop
        (if (and (load ok) (< (load i) an))
          (do
            (if (!= (cast i64 (load (index a (load i)))) (cast i64 (load (index b (load i))))) (do (store! ok false) 0) 0)
            (store! i (+ (load i) 1)) 0)
          (break)))
      (load ok))))
(defn nm [(n (ptr Node))] (-> (ptr u8)) (load (field n s-name)))
(defn nlen [(n (ptr Node))] (-> i64) (load (field n s-len)))
(defn node-name-eq [(n (ptr Node)) (s (ptr i8))] (-> bool) (tok-eq (nm n) (nlen n) s))

; ======================================================================
; Type constructors
; ======================================================================
(defn prim-cell [] (-> (ptr (array (ptr Type) 8))) (alloc-static (array (ptr Type) 8)))
(defn raw-type [(k i64)] (-> (ptr Type))
  (let [p (cast (ptr Type) (xalloc (sizeof Type)))]
    (store! p (zeroed Type))
    (store! (field p kind) k)
    (store! (field p args) (al-new [(ptr Type)] (alc-global)))
    p))
(defn ty-of [(k i64)] (-> (ptr Type))
  (let [cell (prim-cell) slot (index cell k)]
    (if (= (cast i64 (load slot)) 0) (do (store! slot (raw-type k)) 0) 0)
    (load slot)))
(defn ty-error [] (-> (ptr Type)) (ty-of TY_ERROR))
(defn ty-int [] (-> (ptr Type)) (ty-of TY_INT))
(defn ty-float [] (-> (ptr Type)) (ty-of TY_FLOAT))
(defn ty-bool [] (-> (ptr Type)) (ty-of TY_BOOL))
(defn ty-string [] (-> (ptr Type)) (ty-of TY_STRING))
(defn ty-void [] (-> (ptr Type)) (ty-of TY_VOID))
(defn ty-unit [] (-> (ptr Type)) (ty-of TY_UNIT))

(defn ty-var [(name (ptr u8)) (len i64)] (-> (ptr Type))
  (let [p (raw-type TY_VAR)] (store! (field p name) name) (store! (field p name-len) len) p))

(defn is-err [(t (ptr Type))] (-> bool) (= (load (field t kind)) TY_ERROR))
(defn ty-kind [(t (ptr Type))] (-> i64) (load (field t kind)))

; ======================================================================
; Decl table
; ======================================================================
; module-scoped lookup: exact (module, bare-name) match. Empty module (len 0) means
; "the builtin prelude" (07-modules.md §4 step 4).
(defn decl-in-module [(d (ptr Decl)) (mod (ptr u8)) (mlen i64)] (-> bool)
  (name-eq (load (field d qmod)) (load (field d qmod-len)) mod mlen))
(defn find-decl-in-module [(mod (ptr u8)) (mlen i64) (name (ptr u8)) (len i64)] (-> (ptr Decl))
  (let [ds (load (field (ctx) decls)) n (al-len ds) (mut i) 0 (mut found) (cast (ptr Decl) 0)]
    (loop
      (if (and (= (cast i64 (load found)) 0) (< (load i) n))
        (let [d (al-get ds (load i))]
          (if (and (decl-in-module d mod mlen) (name-eq (load (field d name)) (load (field d name-len)) name len))
            (do (store! found d) 0) 0)
          (store! i (+ (load i) 1)) 0)
        (break)))
    (load found)))
(defn find-decl-builtin [(name (ptr u8)) (len i64)] (-> (ptr Decl)) (find-decl-in-module (cast (ptr u8) c"") 0 name len))

; this file's import table entry for a bare name (07-modules.md §4 step 3)
(defn find-import [(file (ptr i8)) (name (ptr u8)) (len i64)] (-> (ptr Decl))
  (let [is0 (load (field (ctx) imports)) n (al-len is0) (mut i) 0 (mut found) (cast (ptr Decl) 0)]
    (loop
      (if (and (= (cast i64 (load found)) 0) (< (load i) n))
        (let [e (al-get is0 (load i))]
          (if (and (= (cast i64 (strcmp (load (field e file)) file)) 0)
                   (name-eq (load (field e bare)) (load (field e bare-len)) name len))
            (do (store! found (load (field e target))) 0) 0)
          (store! i (+ (load i) 1)) 0)
        (break)))
    (load found)))
(defn register-import [(file (ptr i8)) (bare (ptr u8)) (bare-len i64) (target (ptr Decl))] (-> i64)
  (let [e (cast (ptr ImportEntry) (xalloc (sizeof ImportEntry)))]
    (store! (field e file) file) (store! (field e bare) bare) (store! (field e bare-len) bare-len) (store! (field e target) target)
    (al-push! (mut (field (ctx) imports)) e) 0))

; the file whose import TABLE is in scope: cur-file normally, but the synthetic "<eval>"
; pseudo-file (server.coil, every live-eval typecheck) has no import table of its own —
; it borrows eval-fallback-file's imports instead (the entry file by default, or the
; eval's `module` header target — see set-cur-file's comment and 07-modules.md §6:
; "bare names resolve as if the source were appended to that module's file").
(defn effective-import-file [] (-> (ptr i8))
  (let [f (load (field (ctx) cur-file))]
    (if (= (cast i64 (strcmp f c"<eval>")) 0) (eval-fallback-file) f)))

; Bare-identifier resolution order (07-modules.md §4): own module -> this file's
; imports -> builtin prelude. Locals/params/self-fields are handled by the caller
; (Env) before this is ever consulted. Ambient cur-file/cur-module (set-cur-file)
; supply the scope — see its comment for why that's safe everywhere it's called.
(defn find-decl [(name (ptr u8)) (len i64)] (-> (ptr Decl))
  (let [own (find-decl-in-module (load (field (ctx) cur-module)) (load (field (ctx) cur-module-len)) name len)]
    (if (!= (cast i64 own) 0) own
      (let [imp (find-import (effective-import-file) name len)]
        (if (!= (cast i64 imp) 0) imp
          (find-decl-builtin name len))))))
(defn find-decl-c [(s (ptr i8))] (-> (ptr Decl)) (find-decl (cast (ptr u8) s) (strlen s)))

; unscoped, first-match lookup — ONLY for building "name exists elsewhere, add an
; import" diagnostics. Never use this to actually resolve a reference.
(defn find-decl-anywhere [(name (ptr u8)) (len i64)] (-> (ptr Decl))
  (let [ds (load (field (ctx) decls)) n (al-len ds) (mut i) 0 (mut found) (cast (ptr Decl) 0)]
    (loop
      (if (and (= (cast i64 (load found)) 0) (< (load i) n))
        (let [d (al-get ds (load i))]
          (if (name-eq (load (field d name)) (load (field d name-len)) name len)
            (do (store! found d) 0) 0)
          (store! i (+ (load i) 1)) 0)
        (break)))
    (load found)))

(defn new-decl [(kind i64) (name (ptr u8)) (len i64) (node (ptr Node)) (file (ptr i8))] (-> (ptr Decl))
  (let [d (cast (ptr Decl) (xalloc (sizeof Decl)))]
    (store! d (zeroed Decl))
    (store! (field d kind) kind)
    (store! (field d name) name) (store! (field d name-len) len)
    (store! (field d node) node) (store! (field d file) file)
    (store! (field d tparams) (al-new [(ptr Node)] (alc-global)))
    (store! (field d members) (al-new [(ptr Node)] (alc-global)))
    (store! (field d impl-decls) (al-new [(ptr Decl)] (alc-global)))
    (store! (field d qmod) (load (field (ctx) cur-module))) (store! (field d qmod-len) (load (field (ctx) cur-module-len)))
    d))
(defn register-decl [(d (ptr Decl))] (-> i64) (al-push! (mut (field (ctx) decls)) d) 0)
(defn register-view [(v (ptr Node))] (-> i64) (al-push! (mut (field (ctx) views)) v) 0)
(defn view-count [] (-> i64) (al-len (load (field (ctx) views))))
(defn view-at [(i i64)] (-> (ptr Node)) (al-get (load (field (ctx) views)) i))
(defn register-action [(v (ptr Node))] (-> i64) (al-push! (mut (field (ctx) actions)) v) 0)
(defn action-count [] (-> i64) (al-len (load (field (ctx) actions))))
(defn action-at [(i i64)] (-> (ptr Node)) (al-get (load (field (ctx) actions)) i))

(defn decl-tparam-count [(d (ptr Decl))] (-> i64) (al-len (load (field d tparams))))
(defn decl-is-generic [(d (ptr Decl))] (-> bool) (> (decl-tparam-count d) 0))
(defn decl-tparam-at [(d (ptr Decl)) (i i64)] (-> (ptr Node)) (al-get (load (field d tparams)) i))
(defn is-tparam-of [(d (ptr Decl)) (name (ptr u8)) (len i64)] (-> bool)
  (let [n (decl-tparam-count d) (mut i) 0 (mut ok) false]
    (loop
      (if (and (not (load ok)) (< (load i) n))
        (let [tp (decl-tparam-at d (load i))]
          (if (name-eq (nm tp) (nlen tp) name len) (do (store! ok true) 0) 0)
          (store! i (+ (load i) 1)) 0)
        (break)))
    (load ok)))

; find a member (FIELD/FN) node by name inside a decl
(defn decl-member [(d (ptr Decl)) (name (ptr u8)) (len i64)] (-> (ptr Node))
  (let [ms (load (field d members)) n (al-len ms) (mut i) 0 (mut found) (cast (ptr Node) 0)]
    (loop
      (if (and (= (cast i64 (load found)) 0) (< (load i) n))
        (let [m (al-get ms (load i))]
          (if (name-eq (nm m) (nlen m) name len) (do (store! found m) 0) 0)
          (store! i (+ (load i) 1)) 0)
        (break)))
    (load found)))
(defn decl-member-c [(d (ptr Decl)) (s (ptr i8))] (-> (ptr Node)) (decl-member d (cast (ptr u8) s) (strlen s)))

; ======================================================================
; Variant index (unqualified enum variant lookup: None/Some/Ok/Err/Circle/...)
; ======================================================================
(defn register-variant [(name (ptr u8)) (len i64) (ed (ptr Decl)) (vn (ptr Node))] (-> i64)
  (let [v (cast (ptr VariantRef) (xalloc (sizeof VariantRef)))]
    (store! (field v name) name) (store! (field v name-len) len)
    (store! (field v enum-decl) ed) (store! (field v vnode) vn)
    (al-push! (mut (field (ctx) variants)) v) 0))
; prefer a variant whose enum matches `pref` (may be null)
(defn find-variant [(name (ptr u8)) (len i64) (pref (ptr Decl))] (-> (ptr VariantRef))
  (let [vs (load (field (ctx) variants)) n (al-len vs)
        (mut i) 0 (mut any) (cast (ptr VariantRef) 0) (mut hit) (cast (ptr VariantRef) 0)]
    (loop
      (if (< (load i) n)
        (let [v (al-get vs (load i))]
          (if (name-eq (load (field v name)) (load (field v name-len)) name len)
            (do
              (if (= (cast i64 (load any)) 0) (do (store! any v) 0) 0)
              (if (and (!= (cast i64 pref) 0) (= (cast i64 (load (field v enum-decl))) (cast i64 pref))) (do (store! hit v) 0) 0) 0)
            0)
          (store! i (+ (load i) 1)) 0)
        (break)))
    (if (!= (cast i64 (load hit)) 0) (load hit) (load any))))

; a VARIANT node's payload arity + i-th payload TYPE node
(defn variant-arity [(vn (ptr Node))] (-> i64) (kid-count vn))
(defn variant-payload-at [(vn (ptr Node)) (i i64)] (-> (ptr Node)) (kid-at vn i))

; ======================================================================
; Type equality (strict, nominal) and assignability
; ======================================================================
(defn type-eq [(a (ptr Type)) (b (ptr Type))] (-> bool)
  (let [ka (ty-kind a) kb (ty-kind b)]
    (cond
      (!= ka kb) false
      (= ka TY_NAMED)
        (if (!= (cast i64 (load (field a decl))) (cast i64 (load (field b decl))))
          false
          (let [aa (load (field a args)) ba (load (field b args)) na (al-len aa)]
            (if (!= na (al-len ba))
              false
              (let [(mut i) 0 (mut ok) true]
                (loop
                  (if (and (load ok) (< (load i) na))
                    (do (if (not (type-eq (al-get aa (load i)) (al-get ba (load i)))) (do (store! ok false) 0) 0)
                        (store! i (+ (load i) 1)) 0)
                    (break)))
                (load ok)))))
      (= ka TY_VAR) (name-eq (load (field a name)) (load (field a name-len)) (load (field b name)) (load (field b name-len)))
      true)))

; does classDecl implement interfaceDecl (nominal)? Reads the CACHED impl-decls list
; (populated once by check-conformance, when cur-file/cur-module correctly reflect cd's
; own declaring scope) instead of re-resolving the implements-clause names from
; whatever module happens to be ambient at the call site — assignable() is invoked from
; deep inside body-checking/codegen of ARBITRARY other modules, so ambient cur-module
; would otherwise be the wrong scope for cd's own `implements` names.
(defn class-implements [(cd (ptr Decl)) (id (ptr Decl))] (-> bool)
  (let [ids (load (field cd impl-decls)) n (al-len ids) (mut i) 0 (mut ok) false]
    (loop
      (if (and (not (load ok)) (< (load i) n))
        (do (if (= (cast i64 (al-get ids (load i))) (cast i64 id)) (do (store! ok true) 0) 0)
            (store! i (+ (load i) 1)) 0)
        (break)))
    (load ok)))

; is `from` assignable to `to`?
(defn assignable [(from (ptr Type)) (to (ptr Type))] (-> bool)
  (cond
    (or (is-err from) (is-err to)) true
    (type-eq from to) true
    ; class instance -> interface it implements
    (and (= (ty-kind to) TY_NAMED) (= (ty-kind from) TY_NAMED))
      (let [td (load (field to decl)) fd (load (field from decl))]
        (if (and (or (= (load (field td kind)) DK_INTERFACE) (= (load (field td kind)) DK_BUILTIN_IFACE))
                 (or (= (load (field fd kind)) DK_CLASS) (= (load (field fd kind)) DK_OBJECT)))
          (class-implements fd td)
          false))
    false))

; ======================================================================
; Type display (to a fd) and canonical mangled name (to an ArrayList u8)
; ======================================================================
(defn type-write [(fd i64) (t (ptr Type))] (-> i64)
  (let [k (ty-kind t)]
    (cond
      (= k TY_ERROR) (w-cstr fd c"<error>")
      (= k TY_INT) (w-cstr fd c"Int")
      (= k TY_FLOAT) (w-cstr fd c"Float")
      (= k TY_BOOL) (w-cstr fd c"Bool")
      (= k TY_STRING) (w-cstr fd c"String")
      (= k TY_VOID) (w-cstr fd c"Void")
      (= k TY_UNIT) (w-cstr fd c"()")
      (= k TY_VAR) (w-bytes fd (load (field t name)) (load (field t name-len)))
      (= k TY_NAMED)
        (do (w-bytes fd (load (field t name)) (load (field t name-len)))
            (let [aa (load (field t args)) n (al-len aa)]
              (if (> n 0)
                (do (w-cstr fd c"<")
                    (let [(mut i) 0]
                      (loop (if (< (load i) n)
                              (do (if (> (load i) 0) (w-cstr fd c", ") 0)
                                  (type-write fd (al-get aa (load i))) (store! i (+ (load i) 1)) 0)
                              (break))))
                    (w-cstr fd c">") 0)
                0)))
      (w-cstr fd c"?"))))

; ---- StrBuf: a plain growable byte buffer (avoids ArrayList mut-ref friction) ----
(defstruct StrBuf [(data (ptr u8)) (len i64) (cap i64)])
(defn sb-new [] (-> (ptr StrBuf))
  (let [sb (cast (ptr StrBuf) (xalloc (sizeof StrBuf)))]
    (store! (field sb data) (xalloc 4096)) (store! (field sb len) 0) (store! (field sb cap) 4096) sb))
(defn sb-byte [(sb (ptr StrBuf)) (b i64)] (-> i64)
  (if (>= (load (field sb len)) (load (field sb cap)))
    (fatal-or-panic EK_RUNTIME c"scry: internal: type name too long" 70)
    (do (store! (index (load (field sb data)) (load (field sb len))) (cast u8 b))
        (store! (field sb len) (+ (load (field sb len)) 1)) 0)))
(defn sb-push-str [(sb (ptr StrBuf)) (s (ptr i8))] (-> i64)
  (let [n (strlen s) (mut i) 0]
    (loop (if (< (load i) n) (do (sb-byte sb (cast i64 (load (index (cast (ptr u8) s) (load i))))) (store! i (+ (load i) 1)) 0) (break))))
  0)
(defn sb-push-bytes [(sb (ptr StrBuf)) (p (ptr u8)) (n i64)] (-> i64)
  (let [(mut i) 0]
    (loop (if (< (load i) n) (do (sb-byte sb (cast i64 (load (index p (load i))))) (store! i (+ (load i) 1)) 0) (break))))
  0)
; "module.Name", or bare "Name" for a builtin (qmod-len 0) — the qualified IDENTITY
; string used as the mono-table interning key (07-modules.md §4/§6). Display (type-write,
; reflection JSON) stays bare everywhere else — this is the ONLY consumer of qmod for names.
(defn decl-qname-sb [(sb (ptr StrBuf)) (d (ptr Decl))] (-> i64)
  (if (> (load (field d qmod-len)) 0)
    (do (sb-push-bytes sb (load (field d qmod)) (load (field d qmod-len))) (sb-push-str sb c".") 0)
    0)
  (sb-push-bytes sb (load (field d name)) (load (field d name-len))))

; BARE display canon, e.g. "Inventory<Tool>" — reflection JSON / dump-types / error
; messages read this (07-modules.md §4: "display names shorten to bare"). NEVER used for
; interning/dedup identity — see type-canon-qual below for that.
(defn type-canon [(sb (ptr StrBuf)) (t (ptr Type))] (-> i64)
  (let [k (ty-kind t)]
    (cond
      (= k TY_ERROR) (sb-push-str sb c"<error>")
      (= k TY_INT) (sb-push-str sb c"Int")
      (= k TY_FLOAT) (sb-push-str sb c"Float")
      (= k TY_BOOL) (sb-push-str sb c"Bool")
      (= k TY_STRING) (sb-push-str sb c"String")
      (= k TY_VOID) (sb-push-str sb c"Void")
      (= k TY_UNIT) (sb-push-str sb c"()")
      (= k TY_VAR) (sb-push-bytes sb (load (field t name)) (load (field t name-len)))
      (= k TY_NAMED)
        (do (sb-push-bytes sb (load (field t name)) (load (field t name-len)))
            (let [aa (load (field t args)) n (al-len aa)]
              (if (> n 0)
                (do (sb-push-str sb c"<")
                    (let [(mut i) 0]
                      (loop (if (< (load i) n)
                              (do (if (> (load i) 0) (sb-push-str sb c",") 0)
                                  (type-canon sb (al-get aa (load i))) (store! i (+ (load i) 1)) 0)
                              (break))))
                    (sb-push-str sb c">") 0)
                0)))
      0)))

; QUALIFIED identity canon, e.g. "a.b.Inventory<a.b.Tool>" — mono-table interning key ONLY
; (07-modules.md §4/§6: generic args fully qualified in keys). Never displayed.
(defn type-canon-qual [(sb (ptr StrBuf)) (t (ptr Type))] (-> i64)
  (let [k (ty-kind t)]
    (cond
      (= k TY_NAMED)
        (do (decl-qname-sb sb (load (field t decl)))
            (let [aa (load (field t args)) n (al-len aa)]
              (if (> n 0)
                (do (sb-push-str sb c"<")
                    (let [(mut i) 0]
                      (loop (if (< (load i) n)
                              (do (if (> (load i) 0) (sb-push-str sb c",") 0)
                                  (type-canon-qual sb (al-get aa (load i))) (store! i (+ (load i) 1)) 0)
                              (break))))
                    (sb-push-str sb c">") 0)
                0)))
      (type-canon sb t))))

; ======================================================================
; Monomorphization table
; ======================================================================
(defn type-concrete [(t (ptr Type))] (-> bool)
  (let [k (ty-kind t)]
    (cond
      (= k TY_VAR) false
      (= k TY_NAMED)
        (let [aa (load (field t args)) n (al-len aa) (mut i) 0 (mut ok) true]
          (loop (if (and (load ok) (< (load i) n))
                  (do (if (not (type-concrete (al-get aa (load i)))) (do (store! ok false) 0) 0) (store! i (+ (load i) 1)) 0)
                  (break)))
          (load ok))
      true)))

; keyed on the QUALIFIED identity (m.qkey), never the bare display name (m.name) — two
; modules' same-named classes must intern as DISTINCT monos (07-modules.md §4).
(defn find-mono [(cn (ptr u8)) (cnl i64)] (-> (ptr MonoType))
  (let [ms (load (field (ctx) monos)) n (al-len ms) (mut i) 0 (mut f) (cast (ptr MonoType) 0)]
    (loop
      (if (and (= (cast i64 (load f)) 0) (< (load i) n))
        (let [m (al-get ms (load i))]
          (if (name-eq (load (field m qkey)) (load (field m qkey-len)) cn cnl) (do (store! f m) 0) 0)
          (store! i (+ (load i) 1)) 0)
        (break)))
    (load f)))

; forward decls (mutual recursion within file resolves)
(defn subst-type [(t (ptr Type)) (d (ptr Decl)) (args (ArrayList (ptr Type)))] (-> (ptr Type))
  (let [k (ty-kind t)]
    (cond
      (= k TY_VAR)
        (let [n (decl-tparam-count d) (mut i) 0 (mut r) (cast (ptr Type) 0)]
          (loop
            (if (and (= (cast i64 (load r)) 0) (< (load i) n))
              (let [tp (decl-tparam-at d (load i))]
                (if (name-eq (nm tp) (nlen tp) (load (field t name)) (load (field t name-len))) (do (store! r (al-get args (load i))) 0) 0)
                (store! i (+ (load i) 1)) 0)
              (break)))
          (if (= (cast i64 (load r)) 0) t (load r)))
      (= k TY_NAMED)
        (let [aa (load (field t args)) na (al-len aa)]
          (if (= na 0)
            t
            (let [(mut nargs) (al-new [(ptr Type)] (alc-global)) (mut i) 0]
              (loop (if (< (load i) na) (do (al-push! (mut nargs) (subst-type (al-get aa (load i)) d args)) (store! i (+ (load i) 1)) 0) (break)))
              (mk-named (load (field t decl)) (load nargs)))))
      t)))

; build a TY_NAMED and intern its monomorphization if concrete
(defn mk-named [(d (ptr Decl)) (args (ArrayList (ptr Type)))] (-> (ptr Type))
  (let [t (raw-type TY_NAMED)]
    (store! (field t name) (load (field d name))) (store! (field t name-len) (load (field d name-len)))
    (store! (field t decl) d) (store! (field t args) args)
    (if (type-concrete t) (do (intern-mono t) 0) 0)
    t))

(defn intern-mono [(t (ptr Type))] (-> i64)
  (let [qsb (sb-new)]
    (type-canon-qual qsb t)
    (let [qcn (load (field qsb data)) qcnl (load (field qsb len))
          existing (find-mono qcn qcnl)]
      (if (!= (cast i64 existing) 0)
        (load (field existing id))
        (let [d (load (field t decl))
              m (cast (ptr MonoType) (xalloc (sizeof MonoType)))
              id (al-len (load (field (ctx) monos)))
              sb (sb-new)]
          (type-canon sb t)
          (store! m (zeroed MonoType))
          (store! (field m id) id)
          (store! (field m name) (load (field sb data))) (store! (field m name-len) (load (field sb len)))
          (store! (field m qkey) qcn) (store! (field m qkey-len) qcnl)
          (store! (field m base) d) (store! (field m args) (load (field t args)))
          (store! (field m fields) (al-new [(ptr MonoField)] (alc-global)))
          (store! (field m is-entity) (or (= (load (field d kind)) DK_CLASS) (= (load (field d kind)) DK_OBJECT)))
          (al-push! (mut (field (ctx) monos)) m)   ; register BEFORE populating fields (cycle-safe)
          (if (load (field m is-entity)) (populate-mono-fields m t) 0)
          id)))))

(defn populate-mono-fields [(m (ptr MonoType)) (t (ptr Type))] (-> i64)
  (let [d (load (field t decl)) args (load (field t args)) ms (load (field d members)) n (al-len ms) (mut i) 0]
    (loop
      (if (< (load i) n)
        (let [mem (al-get ms (load i))]
          (if (= (load (field mem kind)) NK_FIELD)
            (let [ft (subst-type (resolve-type (load (field mem a)) d) d args)
                  mf (cast (ptr MonoField) (xalloc (sizeof MonoField)))]
              (store! (field mf name) (nm mem)) (store! (field mf name-len) (nlen mem))
              (store! (field mf ty) ft)
              (al-push! (mut (field m fields)) mf) 0)
            0)
          (store! i (+ (load i) 1)) 0)
        (break)))
    0))

; ======================================================================
; Type resolution from AST TYPE nodes
;   ctxt-decl provides in-scope type params (may be null)
; ======================================================================
(defn resolve-type [(tn (ptr Node)) (ctxt-decl (ptr Decl))] (-> (ptr Type))
  (if (= (cast i64 tn) 0)
    (ty-void)   ; absent return type => Void
    (if (= (load (field tn ival)) 1)
      (ty-unit)
      (let [name (nm tn) len (nlen tn)]
        (cond
          (name-eq name len (cast (ptr u8) c"Int") 3) (ty-int)
          (name-eq name len (cast (ptr u8) c"Float") 5) (ty-float)
          (name-eq name len (cast (ptr u8) c"Bool") 4) (ty-bool)
          (name-eq name len (cast (ptr u8) c"String") 6) (ty-string)
          (name-eq name len (cast (ptr u8) c"Void") 4) (ty-void)
          (and (!= (cast i64 ctxt-decl) 0) (is-tparam-of ctxt-decl name len)) (ty-var name len)
          (resolve-named tn ctxt-decl))))))

; last '.' index in [0,len), or -1 (07-modules.md §6: fully-qualified type names —
; TypeName never itself contains a dot, so the LAST dot unambiguously splits
; "<module>.<TypeName>", however deeply the module path nests).
(defn qname-last-dot [(s (ptr u8)) (len i64)] (-> i64)
  (let [(mut last) -1 (mut i) 0]
    (loop (if (< (load i) len) (do (if (= (cast i64 (load (index s (load i)))) \.) (do (store! last (load i)) 0) 0) (store! i (+ (load i) 1)) 0) (break)))
    (load last)))
; a fully-qualified type reference with no import (07-modules.md §4/§6): try the whole
; text as a bare name first (own module/imports/builtins); on failure, if it contains a
; dot, split at the LAST dot and resolve <name-after-dot> inside module <prefix-before-dot>.
(defn resolve-named-decl [(name (ptr u8)) (len i64)] (-> (ptr Decl))
  (let [d (find-decl name len)]
    (if (!= (cast i64 d) 0) d
      (let [ld (qname-last-dot name len)]
        (if (< ld 0) (cast (ptr Decl) 0)
          (find-decl-in-module name ld (index name (+ ld 1)) (- len (+ ld 1))))))))

(defn resolve-named [(tn (ptr Node)) (ctxt-decl (ptr Decl))] (-> (ptr Type))
  (let [d (resolve-named-decl (nm tn) (nlen tn))]
    (if (= (cast i64 d) 0)
      (do (err-unknown-type tn) (ty-error))
      (let [want (decl-tparam-count d) got (kid-count tn)]
        (if (!= want got)
          (do (err-type-arity tn (nm tn) (nlen tn) want got) (ty-error))
          (let [(mut args) (al-new [(ptr Type)] (alc-global)) (mut i) 0]
            (loop (if (< (load i) got) (do (al-push! (mut args) (resolve-type (kid-at tn (load i)) ctxt-decl)) (store! i (+ (load i) 1)) 0) (break)))
            (mk-named d (load args))))))))

; ======================================================================
; Diagnostics
; ======================================================================
(defn bump-err [] (-> i64) (store! (field (ctx) nerr) (+ (load (field (ctx) nerr)) 1)) 0)
(defn err-count [] (-> i64) (load (field (ctx) nerr)))
(defn err-head [(line i64) (col i64)] (-> i64)
  (bump-err)
  (w-cstr 2 (load (field (ctx) cur-file)))
  (w-cstr 2 c":") (w-int 2 line) (w-cstr 2 c":") (w-int 2 col) (w-cstr 2 c": error: ")
  0)
(defn err-head-n [(n (ptr Node))] (-> i64) (err-head (load (field n line)) (load (field n col))))
(defn err-end [] (-> i64) (w-cstr 2 c"\n") 0)

(defn err-msg [(n (ptr Node)) (msg (ptr i8))] (-> i64) (err-head-n n) (w-cstr 2 msg) (err-end))
(defn err-msg-name [(n (ptr Node)) (pre (ptr i8)) (name (ptr u8)) (len i64) (post (ptr i8))] (-> i64)
  (err-head-n n) (w-cstr 2 pre) (w-bytes 2 name len) (w-cstr 2 post) (err-end))
; if `name` (a plain, undotted bare name) is declared in some OTHER already-loaded
; module, print "(add `import <mod>.{<name>}` [or ...] to use it)" — else nothing.
; 07-modules.md §4 step 5: "the error must say so and print the exact import line".
(defn write-import-suggestion [(fd i64) (name (ptr u8)) (len i64)] (-> i64)
  (if (>= (qname-last-dot name len) 0) 0    ; already dotted/qualified — no import would help
    (let [ds (load (field (ctx) decls)) n (al-len ds) (mut i) 0 (mut any) false]
      (loop (if (< (load i) n)
              (let [d (al-get ds (load i))]
                (if (and (name-eq (load (field d name)) (load (field d name-len)) name len) (> (load (field d qmod-len)) 0))
                  (do (w-cstr fd (if (load any) c" or `import " c" (add `import "))
                      (w-bytes fd (load (field d qmod)) (load (field d qmod-len))) (w-cstr fd c".{")
                      (w-bytes fd name len) (w-cstr fd c"}`") (store! any true) 0)
                  0)
                (store! i (+ (load i) 1)) 0)
              (break)))
      (if (load any) (w-cstr fd c" to use it)") 0)
      0)))
(defn err-unknown-type [(tn (ptr Node))] (-> i64)
  (err-head-n tn) (w-cstr 2 c"unknown type: ") (w-bytes 2 (nm tn) (nlen tn))
  (write-import-suggestion 2 (nm tn) (nlen tn)) (err-end))
(defn err-type-arity [(tn (ptr Node)) (name (ptr u8)) (len i64) (want i64) (got i64)] (-> i64)
  (err-head-n tn) (w-cstr 2 c"type ") (w-bytes 2 name len)
  (w-cstr 2 c" expects ") (w-int 2 want) (w-cstr 2 c" type argument(s), found ") (w-int 2 got) (err-end))
(defn err-exp-found [(n (ptr Node)) (pre (ptr i8)) (exp (ptr Type)) (found (ptr Type))] (-> i64)
  (err-head-n n) (w-cstr 2 pre) (w-cstr 2 c"expected ") (type-write 2 exp)
  (w-cstr 2 c", found ") (type-write 2 found) (err-end))
