; safepoint.coil — the generalized N-thread safepoint protocol (02-runtime.md §7).
;
; ONE global stop-flag every interpreter thread polls at the top of its dispatch loop
; (and inside Clock.sleep / Mutex.lock spins). When a coordinator (the eval server
; thread) requests a global stop, every OTHER registered thread parks itself at its next
; poll and spins until the flag clears; the coordinator proceeds only once every one of
; them has reported parked, does its work with the whole object graph quiescent, then
; releases. This is the mechanism a future GC and shape-migration reuse verbatim.
;
; This module stays a LEAF (imports only ioutil + atomic): it never learns the VMThread
; struct. Each thread registers just the address of its own `parked` word (a (ptr i64)),
; and polls by passing that same address back in. That decoupling is what lets `vm.coil`
; call the hook with no import cycle, exactly as in Phase 4.
;
; DESIGN NOTES (as-built, 06-implementation.md):
;  - Spin-wait, not futex/condvar: Coil's concurrency surface is pthread + atomics only
;    (02 §7 makes the same call). Fine at PoC scale (a handful of human-paced threads).
;  - A single coordinator at a time (no nested/reentrant stops): a second requester spins
;    on the CAS until the first releases (02 §7's honest gap).
;  - A DEAD thread (its dispatch loop returned) leaves `parked`=1 permanently (set at
;    thread exit), so request-global-stop never waits forever on a finished agent.
(module safepoint)
(import "ioutil.coil" :use *)
(import "atomic.coil" :use *)

(const SP_MAX_THREADS 64)

(defn sp-flag [] (-> (ptr i64)) (alloc-static i64))            ; 0 = run, 1 = global stop requested
(defn sp-parked-ptrs [] (-> (ptr (array i64 64))) (alloc-static (array i64 64)))  ; each = a (ptr i64) parked word
(defn sp-nthreads [] (-> (ptr i64)) (alloc-static i64))
(defn sp-coord [] (-> (ptr i64)) (alloc-static i64))          ; parked-ptr of the current coordinator, 0 if none

; register THIS thread's parked-word address so a global stop can wait on it. Called once
; per thread, at spawn (and for main/eval at startup). Registrations in the PoC are
; serialized (main spawns the agents one at a time), so a plain publish is sufficient; the
; ptr is stored before the count advances (seq_cst) so a concurrent reader never sees a
; slot before it is written.
(defn sp-register [(parked (ptr i64))] (-> i64)
  (let [idx (atomic-load (sp-nthreads))]
    (store! (index (sp-parked-ptrs) idx) (cast i64 parked))
    (atomic-store (sp-nthreads) (+ idx 1))
    idx))

; true iff a global stop is currently in force.
(defn safepoint-stopped? [] (-> i64) (atomic-load (sp-flag)))

; true iff `parked` is the current coordinator's own parked-word (so it must NOT park).
(defn safepoint-is-coordinator? [(parked (ptr i64))] (-> i64)
  (if (= (load (sp-coord)) (cast i64 parked)) 1 0))

; called at the TOP of the dispatch loop, once per instruction (and from sleep/lock spins).
; Almost always the flag is 0 and this is a single atomic load + branch. When a stop is in
; force, this thread parks (publishes parked=1) and spins until the flag clears — unless it
; IS the coordinator, in which case it returns immediately so the coordinator can run.
(defn safepoint-poll [(parked (ptr i64))] (-> i64)
  (if (= (atomic-load (sp-flag)) 1)
    (if (= (safepoint-is-coordinator? parked) 1)
      0
      (do
        (atomic-store parked 1)
        (loop (if (= (atomic-load (sp-flag)) 0) (break) (do (usleep (cast i32 50)) (continue))))
        (atomic-store parked 0)
        0))
    0))

; coordinator side: acquire the global stop and wait until every OTHER registered thread
; has parked. `coord` is the coordinator's own parked-word (excluded from the wait, and
; recorded so its own polls don't self-park).
(defn request-global-stop [(coord (ptr i64))] (-> i64)
  (loop (if (= (atomic-cas (sp-flag) 0 1) 0) (break) (do (usleep (cast i32 50)) (continue))))
  (store! (sp-coord) (cast i64 coord))
  (let [n (atomic-load (sp-nthreads)) (mut i) 0]
    (loop
      (if (< (load i) n)
        (let [p (cast (ptr i64) (load (index (sp-parked-ptrs) (load i))))]
          (if (!= (cast i64 p) (cast i64 coord))
            (loop (if (= (atomic-load p) 1) (break) (do (usleep (cast i32 50)) (continue)))) 0)
          (store! i (+ (load i) 1)) 0)
        (break))))
  0)

; coordinator side: release — every parked thread resumes together.
(defn release-global-stop [] (-> i64)
  (store! (sp-coord) 0)
  (atomic-store (sp-flag) 0)
  0)
