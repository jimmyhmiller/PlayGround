class Task {
  title: String
  done: Bool
  fn complete() { self.done = true }
}

class Project {
  name: String
  tasks: List<Task>
  fn add(t: Task) { self.tasks.push(t) }
  fn openCount() -> Int {
    var n = 0
    for t in self.tasks { if !t.done { n = n + 1 } }
    n
  }
}

fn main() {
  let p = Project(name: "Scry in the browser", tasks: List<Task>())
  p.add(Task(title: "compile the VM to wasm", done: true))
  p.add(Task(title: "run the viewer in-page", done: true))
  p.add(Task(title: "wire up the terminal", done: false))
  Console.log("demo booted: " + p.name)
}
