// Workers build an enum via a typed helper and branch on it via match, accumulating under a
// mutex. Even->2, Odd->1; per thread 100 iters -> 50*2 + 50*1 = 150; x2 threads = 300.
enum Parity {
  Even
  Odd
}
class M implements Runnable {
  box: Mutex<Int>
  fn classify(i: Int) -> Parity {
    if i % 2 == 0 {
      return Even
    }
    Odd
  }
  fn run() -> Void {
    var i = 0
    while i < 100 {
      let w = match self.classify(i) {
        Even -> 2
        Odd -> 1
      }
      self.box.lock()
      self.box.set(self.box.get() + w)
      self.box.unlock()
      i = i + 1
    }
  }
}
fn main() {
  let box = Mutex<Int>(0)
  let a = Thread.spawn(M(box: box))
  let b = Thread.spawn(M(box: box))
  a.join()
  b.join()
  print(box.get())
}
