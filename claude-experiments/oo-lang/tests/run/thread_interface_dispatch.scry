// Concurrent virtual dispatch: workers call tool.tag() through a Tool interface (itable)
// while accumulating under a mutex. A()=1 x2 threads x40 + B()=2 x1 thread x40 = 80+80 = 160.
interface Tool {
  fn tag() -> Int
}
class A implements Tool {
  fn tag() -> Int { 1 }
}
class B implements Tool {
  fn tag() -> Int { 2 }
}
class Caller implements Runnable {
  box: Mutex<Int>
  tool: Tool
  fn run() -> Void {
    var i = 0
    while i < 40 {
      let g = self.tool.tag()
      self.box.lock()
      self.box.set(self.box.get() + g)
      self.box.unlock()
      i = i + 1
    }
  }
}
fn main() {
  let box = Mutex<Int>(0)
  let hs = List<ThreadHandle>()
  hs.push(Thread.spawn(Caller(box: box, tool: A())))
  hs.push(Thread.spawn(Caller(box: box, tool: B())))
  hs.push(Thread.spawn(Caller(box: box, tool: A())))
  var j = 0
  while j < 3 {
    hs.get(j).join()
    j = j + 1
  }
  print(box.get())
}
