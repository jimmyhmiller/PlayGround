// Concurrent virtual dispatch: workers call tool.run() through a Tool interface (itable)
// while counting successes under a mutex. 3 threads x 40 calls = 120.
interface Tool { fn tag() -> Int }
class A implements Tool { fn tag() -> Int { 1 } }
class B implements Tool { fn tag() -> Int { 2 } }
class Caller implements Runnable {
  box: Mutex<Int>
  tool: Tool
  fn run() -> Void {
    var i = 0
    while i < 40 {
      let g = self.tool.tag()
      self.box.lock()
      self.box.set(self.box.get() + g)
      self.box.unlock()
      i = i + 1
    }
  }
}
fn main() {
  let box = Mutex<Int>(0)
  let hs = List<ThreadHandle>()
  hs.push(Thread.spawn(Caller(box: box, tool: A())))
  hs.push(Thread.spawn(Caller(box: box, tool: B())))
  hs.push(Thread.spawn(Caller(box: box, tool: A())))
  var j = 0
  while j < 3 { hs.get(j).join(); j = j + 1 }
  print(box.get())
}
