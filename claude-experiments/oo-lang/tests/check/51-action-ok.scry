enum AgentStatus { Idle Running Done }
class Agent {
  name: String
  status: AgentStatus
  paused: Bool
  fn init() { self.name = "x" self.status = AgentStatus.Idle self.paused = false }
  fn pause() { self.paused = true }
  fn ask(question: String) -> String { self.name }
}
interface Runnable { fn run() -> Void }
fn main() { let a = Agent() }
action "Pause" for Agent { self.pause() }
action "Toggle" for Agent { self.paused = false }
action "Ask" for Agent (question: String) { self.ask(question) }
