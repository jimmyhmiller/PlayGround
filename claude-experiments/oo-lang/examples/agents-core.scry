// file: agents/core.scry — a self-contained multi-agent demo core (module `agents.core`).
//
// This is deliberately separate from the real `agent` library (agent.scry): it illustrates the
// "N agents, each on its own OS thread, browsable live in the viewer" pattern from the design
// docs (§5), using only REAL runtime primitives — the built-in Clock, Process.run, Mutex<T>,
// Thread.spawn/Runnable. There is no network and no LLM: the brain is a deterministic offline
// `Brain` that does honest work, so the demo runs reproducibly. main.scry wires three of these
// agents up; ui/tui.scry renders them.

enum AgentStatus {
  Waiting
  Running
  Paused
  Done
}

class Message {
  role: String
  content: String
  createdAt: Int

  fn init(role: String, content: String) {
    self.role = role
    self.content = content
    self.createdAt = Clock.now()   // built-in Clock: wall-clock milliseconds
  }
}

class Conversation {
  messages: List<Message>

  fn init() { self.messages = List<Message>() }

  fn append(m: Message) { self.messages.push(m) }

  fn tokenEstimate() -> Int {
    var total = 0
    for m in self.messages { total = total + m.content.len() / 4 }
    total
  }
}

enum ToolError {
  NotFound(String)
  Failed(String)
}

// Tool heterogeneity via real interfaces (§2.3): any class that implements Tool can live in
// Agent.tools below, with no enum to edit when a new tool kind is added.
interface Tool {
  fn name() -> String
  fn call(args: Map<String, String>) -> Result<String, ToolError>
}

class ShellTool implements Tool {
  command: String

  fn name() -> String { "shell" }

  fn call(args: Map<String, String>) -> Result<String, ToolError> {
    match args.get("cmd") {
      Some(cmd) -> Ok(Process.run(cmd))   // real shell via the Process builtin
      None -> Err(ToolError.Failed("missing cmd arg"))
    }
  }
}

class SearchTool implements Tool {
  index: String

  fn name() -> String { "search" }

  fn call(args: Map<String, String>) -> Result<String, ToolError> {
    match args.get("q") {
      Some(q) -> Ok("results for " + q + " in " + self.index)
      None -> Err(ToolError.Failed("missing q arg"))
    }
  }
}

// The turn can fail; a real error type (not a fake stub) so runTurn's `?` propagates honestly.
enum AgentError {
  EmptyConversation
  Failed(String)
}

// A deterministic, offline "brain": no network, no LLM. It produces a real reply from the
// conversation so the multi-agent demo does honest work and runs reproducibly. A live LLM would
// slot in here by implementing the same Result-returning shape.
object Brain {
  fn respond(convo: Conversation) -> Result<String, AgentError> {
    if convo.messages.len() == 0 { return Err(AgentError.EmptyConversation) }
    let last = convo.messages.get(convo.messages.len() - 1)
    Ok("ack: " + last.content)
  }
}

class Agent {
  name: String
  // Wrapped in Mutex<T> because the main thread's TUI render loop and the viewer's eval channel
  // both read these fields while this agent's own worker thread (below) mutates them (§5.2).
  // `tools` is not wrapped: only this agent's own thread ever touches it, by convention (§5.3).
  status: Mutex<AgentStatus>
  conversation: Mutex<Conversation>
  tools: List<Tool>

  fn init(name: String, tools: List<Tool>) {
    self.name = name
    self.status = Mutex<AgentStatus>(AgentStatus.Waiting)
    self.conversation = Mutex<Conversation>(Conversation())
    self.tools = tools
  }

  fn pause() {
    self.status.lock()
    self.status.set(AgentStatus.Paused)
    self.status.unlock()
  }

  fn resume() {
    self.status.lock()
    self.status.set(AgentStatus.Waiting)
    self.status.unlock()
  }

  fn findTool(name: String) -> Option<Tool> {
    for t in self.tools {
      if t.name() == name { return Some(t) }
    }
    None
  }

  // Runs on this agent's own worker thread (§5.1), driven by AgentWorker below. Brain.respond
  // returns synchronously in the offline demo, so this never blocks — but note for when a real
  // model is slotted in: a blocking call parks this thread where it can't reach a safepoint, so
  // per 02-runtime.md §7 request-global-stop would then wait on it, delaying every GC / shape
  // migration / viewer eval process-wide until it returns (other agents' threads keep running).
  fn runTurn() -> Result<(), AgentError> {
    self.status.lock()
    if self.status.get() != AgentStatus.Waiting {
      self.status.unlock()
      return Ok(())
    }
    self.status.set(AgentStatus.Running)
    self.status.unlock()

    self.conversation.lock()
    self.conversation.get().append(Message(role: "user", content: "continue"))
    let reply = Brain.respond(self.conversation.get())?
    self.conversation.get().append(Message(role: "assistant", content: reply))
    self.conversation.unlock()

    self.status.lock()
    self.status.set(AgentStatus.Waiting)
    self.status.unlock()
    Ok(())
  }
}

// The thread this agent runs on (§5.1): implements Runnable rather than taking a bare function
// value, since the PoC has no closures — the agent to drive is just a field.
class AgentWorker implements Runnable {
  agent: Agent

  fn run() -> Void {
    while true {
      match self.agent.runTurn() {
        Ok(_) -> {}
        Err(e) -> Console.log("agent " + self.agent.name + " turn failed")
      }
      Clock.sleep(400)   // pace the demo: turns stay watchable, not instantaneous (§1.7)
    }
  }
}
