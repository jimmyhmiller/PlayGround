// Glaze styling challenges — each `style` is one gallery tile.
// Rendered by `glaze_gallery`. uv ∈ 0..1 per tile; `size`/`resolution` = tile px.

token ink   = vec4(0.10, 0.12, 0.18, 1.0)
token gold  = vec4(0.82, 0.64, 0.36, 1.0)
token slate = vec4(0.22, 0.24, 0.32, 1.0)

// 1 — linear gradient
style linear_gradient {
  overlay shader {
    emit mix(ink, gold, uv.x)
  }
}

// 2 — radial gradient
style radial_gradient {
  overlay shader {
    let d = length(uv - vec2(0.5, 0.5)) * 2.0
    emit mix(gold, ink, clamp(d, 0.0, 1.0))
  }
}

// 3 — conic hue wheel (atan2 + scalar hue→rgb)
style conic_hue {
  overlay shader {
    let a = atan2(uv.y - 0.5, uv.x - 0.5)
    let h = a / 6.2831853 + 0.5
    let r = clamp(abs(h * 6.0 - 3.0) - 1.0, 0.0, 1.0)
    let g = clamp(2.0 - abs(h * 6.0 - 2.0), 0.0, 1.0)
    let b = clamp(2.0 - abs(h * 6.0 - 4.0), 0.0, 1.0)
    emit vec4(r, g, b, 1.0)
  }
}

// 4 — rounded-rect SDF with border (Inigo Quilez box SDF)
style rounded_rect {
  overlay shader {
    let p    = (uv - vec2(0.5, 0.5)) * size
    let half = size * 0.5 - vec2(10.0, 10.0)
    let q    = abs(p) - half + vec2(16.0, 16.0)
    let d    = length(max(q, vec2(0.0, 0.0))) + min(max(q.x, q.y), 0.0) - 16.0
    let fill = smoothstep(1.0, -1.0, d)
    let edge = smoothstep(2.0, 0.0, abs(d))
    emit vec4(mix(slate.x, gold.x, edge), mix(slate.y, gold.y, edge), mix(slate.z, gold.z, edge), fill)
  }
}

// 5 — neon ring with exponential glow
style neon_ring {
  overlay shader {
    let d    = abs(length(uv - vec2(0.5, 0.5)) - 0.30)
    let glow = exp(-d * 16.0)
    emit vec4(0.30 * glow, 0.85 * glow, 1.0 * glow, glow)
  }
}

// 6 — diagonal stripes
style stripes {
  overlay shader {
    let s = fract((uv.x + uv.y) * 7.0)
    emit mix(ink, gold, step(0.5, s))
  }
}

// 7 — checkerboard
style checkerboard {
  overlay shader {
    let cx = floor(uv.x * 8.0)
    let cy = floor(uv.y * 8.0)
    let parity = fract((cx + cy) * 0.5) * 2.0
    emit mix(ink, slate, parity)
  }
}

// 8 — dot grid
style dot_grid {
  overlay shader {
    let g = fract(uv * 9.0) - vec2(0.5, 0.5)
    let d = length(g)
    let dot = smoothstep(0.42, 0.30, d)
    emit mix(ink, gold, dot)
  }
}

// 9 — vignette
style vignette {
  overlay shader {
    let d = length(uv - vec2(0.5, 0.5))
    let v = smoothstep(0.85, 0.25, d)
    emit vec4(0.82 * v + 0.05, 0.66 * v + 0.05, 0.42 * v + 0.07, 1.0)
  }
}

// 10 — value noise (hash + bilinear interpolation)
style value_noise {
  overlay shader {
    let st = uv * 6.0
    let i  = floor(st)
    let f  = fract(st)
    let a  = fract(sin(dot(i,                  vec2(127.1, 311.7))) * 43758.5453)
    let b  = fract(sin(dot(i + vec2(1.0, 0.0), vec2(127.1, 311.7))) * 43758.5453)
    let c  = fract(sin(dot(i + vec2(0.0, 1.0), vec2(127.1, 311.7))) * 43758.5453)
    let e  = fract(sin(dot(i + vec2(1.0, 1.0), vec2(127.1, 311.7))) * 43758.5453)
    let u  = f * f * (vec2(3.0, 3.0) - 2.0 * f)
    let n  = mix(mix(a, b, u.x), mix(c, e, u.x), u.y)
    emit vec4(n * 0.82, n * 0.66, n * 0.45, 1.0)
  }
}

// 11 — bevel / fake-3D shading
style bevel {
  overlay shader {
    let shade = mix(1.18, 0.78, uv.y)
    emit vec4(0.80 * shade, 0.62 * shade, 0.35 * shade, 1.0)
  }
}

// 12 — plasma
style plasma {
  overlay shader {
    let v = sin(uv.x * 9.0) + sin(uv.y * 9.0) + sin((uv.x + uv.y) * 7.0)
    let h = v / 3.0 * 0.5 + 0.5
    let r = clamp(abs(h * 6.0 - 3.0) - 1.0, 0.0, 1.0)
    let g = clamp(2.0 - abs(h * 6.0 - 2.0), 0.0, 1.0)
    let b = clamp(2.0 - abs(h * 6.0 - 4.0), 0.0, 1.0)
    emit vec4(r, g, b, 1.0)
  }
}
