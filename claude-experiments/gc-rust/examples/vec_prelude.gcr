// The prelude provides a growable, generic `Vec<T>` — no declaration needed.
// Construction needs a type annotation so `T` is known; everything else is
// inferred. The backing array is GC-managed and reallocates on growth.

fn sum_squares(n: i64) -> i64 {
    let mut v: Vec<i64> = vec_new();
    let mut i = 0;
    while i < n {
        v = vec_push(v, i * i);
        i = i + 1;
    }
    let mut total = 0;
    let mut j = 0;
    while j < vec_len(v) {
        total = total + vec_get_unchecked(v, j);
        j = j + 1;
    }
    total
}

fn main() -> i64 {
    // sum of i*i for i in 0..10 = 0+1+4+9+16+25+36+49+64+81 = 285
    sum_squares(10)
}
