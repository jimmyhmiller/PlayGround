// Falling-Blocks Dodge — a real raylib game written in gc-rust, proving the FFI.
//
// NO C SHIM. gc-rust calls raylib's actual C API directly, including the
// functions that take a `Color` struct BY VALUE — `ClearBackground(Color)`,
// `DrawCircle(int,int,float,Color)`, etc. gc-rust's FFI implements the platform
// C ABI (AAPCS64): a 4-byte `Color` is coerced into a general register, an HFA
// like `Vector2 {f32,f32}` into SIMD registers, matching exactly what clang
// emits. See docs/ffi.md and src/codegen.rs (`abi_coerce`).
//
// The game state is a `Vec<Block>` of GC-heap structs rebuilt every frame, so a
// moving generational GC runs continuously alongside native rendering. Safe
// because only scalars / by-value PODs cross the boundary — GC pointers never do.
//
// Build + run: examples/raylib/build.sh

// raylib's Color: { unsigned char r, g, b, a } — 4 bytes, passed by value.
#[value] struct Color { r: u8, g: u8, b: u8, a: u8 }

extern "C" fn InitWindow(width: i32, height: i32, title: RawPtr);
extern "C" fn SetTargetFPS(fps: i32);
extern "C" fn BeginDrawing();
extern "C" fn EndDrawing();
extern "C" fn CloseWindow();
extern "C" fn ClearBackground(color: Color);
extern "C" fn DrawCircle(centerX: i32, centerY: i32, radius: f32, color: Color);
extern "C" fn DrawRectangle(posX: i32, posY: i32, width: i32, height: i32, color: Color);
extern "C" fn DrawText(text: RawPtr, posX: i32, posY: i32, fontSize: i32, color: Color);
extern "C" fn WindowShouldClose() -> bool;
extern "C" fn IsKeyDown(key: i32) -> bool;
extern "C" fn GetMouseX() -> i32;

fn rgb(r: i64, g: i64, b: i64) -> Color {
  Color { r: r as u8, g: g as u8, b: b as u8, a: 255 as u8 }
}

// A GC-heap game object: one falling block.
struct Block { x: f64, y: f64, w: f64, speed: f64 }

// Overflow-safe LCG (state stays < 2^31, so state*1103515245 < 2^61 < i64::MAX).
fn rand_next(s: i64) -> i64 { (s * 1103515245 + 12345) % 2147483648 }

fn clampf(v: f64, lo: f64, hi: f64) -> f64 { max_f64(lo, min_f64(v, hi)) }

// Circle (cx,cy,r) vs axis-aligned rect (bx,by,bw,bh).
fn hits(cx: f64, cy: f64, r: f64, bx: f64, by: f64, bw: f64, bh: f64) -> bool {
  let nx = clampf(cx, bx, bx + bw);
  let ny = clampf(cy, by, by + bh);
  let dx = cx - nx;
  let dy = cy - ny;
  dx * dx + dy * dy < r * r
}

fn main() -> i64 {
  let width = 800;
  let height = 640;
  InitWindow(width as i32, height as i32, as_c_bytes("gc-rust + raylib — Falling Blocks Dodge"));
  SetTargetFPS(60);

  let player_y = 600.0;
  let player_r = 18.0;

  let mut blocks: Vec<Block> = vec_new();
  let mut score = 0;
  let mut best = 0;
  let mut rng = 987654321;
  let mut spawn_timer = 0;
  let mut alive = true;
  let mut px = 400.0;

  while WindowShouldClose() == false {
    px = clampf(GetMouseX() as f64, 0.0, width as f64);

    if alive {
      // Spawn a new block every ~22 frames at a random x with a random speed.
      spawn_timer = spawn_timer + 1;
      if spawn_timer >= 22 {
        spawn_timer = 0;
        rng = rand_next(rng);
        let bx = (rng % 760) as f64;
        rng = rand_next(rng);
        let spd = 3.0 + ((rng % 400) as f64) / 100.0;
        blocks = vec_push(blocks, Block { x: bx, y: 0.0 - 40.0, w: 40.0, speed: spd });
      }

      // Advance every block; keep on-screen ones (rebuild the Vec — off-screen
      // blocks become GC garbage). Score a point per block dodged off the bottom.
      let mut next: Vec<Block> = vec_new();
      let n = vec_len(blocks);
      let mut i = 0;
      let mut hit = false;
      while i < n {
        let mut b = vec_get(blocks, i);
        b.y = b.y + b.speed;
        if hits(px, player_y, player_r, b.x, b.y, b.w, b.w) {
          hit = true;
        }
        if b.y < height as f64 {
          next = vec_push(next, b);
        } else {
          score = score + 1;
        }
        i = i + 1;
      }
      blocks = next;
      if hit {
        alive = false;
        if score > best { best = score; }
      }
    } else {
      // Game over: press R (key 82) to restart.
      if IsKeyDown(82) {
        blocks = vec_new();
        score = 0;
        spawn_timer = 0;
        alive = true;
      }
    }

    // ---- draw (all direct raylib calls; Color crosses by value) ----
    BeginDrawing();
    ClearBackground(rgb(18, 18, 28));

    let n2 = vec_len(blocks);
    let mut j = 0;
    while j < n2 {
      let b = vec_get(blocks, j);
      DrawRectangle(b.x as i32, b.y as i32, b.w as i32, b.w as i32, rgb(90, 170, 240));
      j = j + 1;
    }

    DrawCircle(px as i32, player_y as i32, player_r as f32, rgb(245, 205, 80));

    DrawText(as_c_bytes(str_concat("Score: ", to_string(score))), 12, 12, 26, rgb(235, 235, 235));
    DrawText(as_c_bytes(str_concat("Best: ", to_string(best))), 12, 44, 20, rgb(150, 150, 160));

    if alive == false {
      DrawText(as_c_bytes("GAME OVER"), 300, 280, 44, rgb(245, 90, 90));
      DrawText(as_c_bytes("press R to restart"), 300, 336, 24, rgb(220, 220, 220));
    }

    EndDrawing();
  }

  CloseWindow();
  best
}
