// binary_trees — the GC allocation/tracing benchmark. Builds many complete
// binary trees on the GC heap and checksums them. This is the one benchmark
// that stresses the garbage collector directly (allocation + tracing throughput
// vs malloc/free). Returns a checksum.

enum Tree { Leaf, Node(Tree, Tree) }

fn make(depth: i64) -> Tree {
    if depth == 0 {
        Tree::Leaf
    } else {
        Tree::Node(make(depth - 1), make(depth - 1))
    }
}

fn check(t: Tree) -> i64 {
    match t {
        Tree::Leaf => 1,
        Tree::Node(l, r) => 1 + check(l) + check(r),
    }
}

fn main() -> i64 {
    let max_depth = 16;
    let mut total = 0;
    let mut iter = 0;
    // Build 40 trees of the max depth and sum their node counts.
    while iter < 40 {
        let t = make(max_depth);
        total = total + check(t);
        iter = iter + 1;
    }
    total
}
