struct IntVec { data: Array<i64>, len: i64, cap: i64 }

fn ivec_new() -> IntVec {
    IntVec { data: array_new(4), len: 0, cap: 4 }
}

fn ivec_get(v: IntVec, i: i64) -> i64 {
    array_get_unchecked(v.data, i)
}

fn ivec_push(mut v: IntVec, x: i64) -> IntVec {
    if v.len < v.cap {
        let _u = array_set(v.data, v.len, x);
        IntVec { data: v.data, len: v.len + 1, cap: v.cap }
    } else {
        let new_cap = v.cap * 2;
        let mut new_data: Array<i64> = array_new(new_cap);
        let mut i = 0;
        while i < v.len {
            let _u = array_set(new_data, i, array_get_unchecked(v.data, i));
            i = i + 1;
        }
        let _u2 = array_set(new_data, v.len, x);
        IntVec { data: new_data, len: v.len + 1, cap: new_cap }
    }
}

fn main() -> i64 {
    let mut v = ivec_new();
    let mut i = 0;
    while i < 20 {
        v = ivec_push(v, i * i);
        i = i + 1;
    }
    print_int(v.len);
    ivec_get(v, 5) + ivec_get(v, 19)
}
