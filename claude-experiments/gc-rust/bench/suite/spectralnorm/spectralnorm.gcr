// spectral-norm — gc-rust port of the Computer Language Benchmarks Game
// algorithm (single-threaded reference). Faithful line-for-line translation of
// the same algorithm as spectralnorm.go / .rs / .java in this directory, so the
// result is directly comparable. N is hardcoded to match the CLI arg passed to
// the other languages by the harness.
//
// Algorithm origin: The Computer Language Benchmarks Game (BSD-3-Clause); this
// gc-rust translation written for the gc-rust benchmark comparison.

fn evala(i: i64, j: i64) -> i64 {
    (i + j) * (i + j + 1) / 2 + i + 1
}

fn times(mut v: Array<f64>, u: Array<f64>, n: i64) -> i64 {
    let mut i = 0;
    while i < n {
        let mut a = 0.0;
        let mut j = 0;
        while j < n {
            a = a + array_get_unchecked(u, j) / (evala(i, j) as f64);
            j = j + 1;
        }
        let _u = array_set(v, i, a);
        i = i + 1;
    }
    0
}

fn times_trans(mut v: Array<f64>, u: Array<f64>, n: i64) -> i64 {
    let mut i = 0;
    while i < n {
        let mut a = 0.0;
        let mut j = 0;
        while j < n {
            a = a + array_get_unchecked(u, j) / (evala(j, i) as f64);
            j = j + 1;
        }
        let _u = array_set(v, i, a);
        i = i + 1;
    }
    0
}

fn a_times_transp(v: Array<f64>, u: Array<f64>, x: Array<f64>, n: i64) -> i64 {
    let _a = times(x, u, n);
    let _b = times_trans(v, x, n);
    0
}

fn main() -> i64 {
    let n = 3000;
    let mut u: Array<f64> = array_new(n);
    let mut v: Array<f64> = array_new(n);
    let mut x: Array<f64> = array_new(n);
    let mut i = 0;
    while i < n {
        let _a = array_set(u, i, 1.0);
        let _b = array_set(v, i, 1.0);
        i = i + 1;
    }
    let mut it = 0;
    while it < 10 {
        let _a = a_times_transp(v, u, x, n);
        let _b = a_times_transp(u, v, x, n);
        it = it + 1;
    }
    let mut vBv = 0.0;
    let mut vv = 0.0;
    let mut k = 0;
    while k < n {
        let vi = array_get_unchecked(v, k);
        vBv = vBv + array_get_unchecked(u, k) * vi;
        vv = vv + vi * vi;
        k = k + 1;
    }
    print_float(sqrt(vBv / vv));
    0
}
