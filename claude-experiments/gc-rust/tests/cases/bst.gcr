enum Tree { Leaf, Node(Tree, i64, Tree) }
fn insert(t: Tree, v: i64) -> Tree {
    match t {
        Tree::Leaf => Tree::Node(Tree::Leaf, v, Tree::Leaf),
        Tree::Node(l, x, r) => if v < x { Tree::Node(insert(l, v), x, r) } else { Tree::Node(l, x, insert(r, v)) },
    }
}
fn sum(t: Tree) -> i64 { match t { Tree::Leaf => 0, Tree::Node(l, x, r) => sum(l) + x + sum(r) } }
fn main() -> i64 {
    let mut t = Tree::Leaf;
    t = insert(t, 10); t = insert(t, 5); t = insert(t, 15); t = insert(t, 12);
    sum(t)
}
