fn main() -> i64 {
    let words = str_split_byte("the cat the dog the cat the", 32);
    let mut counts: MapStr<i64> = mapstr_new();
    let mut i = 0;
    while i < vec_len(words) {
        let w = vec_get_unchecked(words, i);
        let c = match mapstr_get(counts, w) { Option::Some(n) => n, Option::None => 0 };
        counts = mapstr_insert(counts, w, c + 1);
        i = i + 1;
    }
    let the = match mapstr_get(counts, "the") { Option::Some(n) => n, Option::None => 0 };
    let cat = match mapstr_get(counts, "cat") { Option::Some(n) => n, Option::None => 0 };
    let dog = match mapstr_get(counts, "dog") { Option::Some(n) => n, Option::None => 0 };
    the * 10 + cat - dog + 1
}
