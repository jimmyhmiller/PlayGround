fn ieq(a: String, b: String) -> bool { string_eq(str_to_lower(a), str_to_lower(b)) }
fn main() -> i64 {
  let lo = str_to_lower("MixedCase123");        // "mixedcase123"
  let up = str_to_upper("MixedCase123");        // "MIXEDCASE123"
  let a = if string_eq(lo, "mixedcase123") { 1 } else { 0 };
  let b = if string_eq(up, "MIXEDCASE123") { 1 } else { 0 };
  let c = if ieq("Hello", "HELLO") { 1 } else { 0 };
  let d = if ieq("x", "y") { 0 } else { 1 };
  a * 10 + b * 10 + c * 10 + d * 10 + 2          // 1*10*4 + 2 = 42
}
