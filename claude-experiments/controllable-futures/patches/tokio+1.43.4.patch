 unsafe fn poll<T: Future, S: Schedule>(ptr: NonNull<Header>) {
-    let harness = Harness::<T, S>::from_raw(ptr);
-    harness.poll();
+    // cf-runtime hook: single chokepoint for every poll. Sets a
+    // thread-local "currently polling task" so wakes fired from inside
+    // the poll body can attribute their source — that's what makes the
+    // wake graph readable instead of every edge starting from the left.
+    let __cf_id = Header::get_id(ptr).0.get();
+    let __cf_worker = cf_runtime::hooks::current_worker().unwrap_or(usize::MAX);
+    let __cf_proceed = cf_runtime::hooks::on_poll_begin(__cf_id, __cf_worker);
+    let __cf_prev_polling = cf_runtime::hooks::polling_tokio_id();
+    cf_runtime::hooks::set_polling_tokio_id(__cf_id);
+    let __cf_start = std::time::Instant::now();
+    if __cf_proceed {
+        let harness = Harness::<T, S>::from_raw(ptr);
+        harness.poll();
+    }
+    let __cf_dur = __cf_start.elapsed().as_nanos() as u64;
+    // Restore previous polling id (handles re-entrant raw::poll calls).
+    match __cf_prev_polling {
+        Some(prev) => cf_runtime::hooks::set_polling_tokio_id(prev),
+        None => cf_runtime::hooks::clear_polling_tokio_id(),
+    }
+    cf_runtime::hooks::on_poll_end(__cf_id, __cf_worker, __cf_dur, false);
 }
 
