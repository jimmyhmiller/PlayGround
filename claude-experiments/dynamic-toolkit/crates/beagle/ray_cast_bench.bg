namespace ray_cast_bench

use beagle.core as core

// Isolated benchmark for the inner loop that dominates beagle-zelda:
// `ray_segment_hit` (gameplay.bg) and `cast_ray` (rendering.bg).
//
// One "frame" of work casts N rays against M segments. With 8 walls
// surviving the light cull (32 segments) and ~64 rays per frame
// (corners×3 + filler), this is representative of the hot loop seen
// while playing.

struct Vec2 { x, y }
struct Segment { a, b }

fn make_v(x, y) { Vec2 { x: x, y: y } }
fn make_seg(a, b) { Segment { a: a, b: b } }

fn abs_f(x) { if x < 0.0 { 0.0 - x } else { x } }

let SHADOW_FAR = 5000.0

// Identical to gameplay.ray_segment_hit.
fn ray_segment_hit(origin, dir, a, b) {
    let sx = b.x - a.x
    let sy = b.y - a.y
    let denom = dir.x * sy - dir.y * sx
    if abs_f(denom) < 0.000001 {
        0.0 - 1.0
    } else {
        let diffx = a.x - origin.x
        let diffy = a.y - origin.y
        let t = (diffx * sy - diffy * sx) / denom
        let u = (diffx * dir.y - diffy * dir.x) / denom
        if t >= 0.0 && u >= 0.0 && u <= 1.0 { t } else { 0.0 - 1.0 }
    }
}

// Identical to rendering.cast_ray.
fn cast_ray(origin, dir, segments) {
    let mut best = SHADOW_FAR
    let mut i = 0
    while i < length(segments) {
        let s = segments[i]
        let t = ray_segment_hit(origin, dir, s.a, s.b)
        if t > 0.0 && t < best { best = t }
        i = i + 1
    }
    best
}

// 8 walls (center.x, center.y, half.x, half.y) → 32 segments.
fn build_segments() {
    let walls = [
        [100.0, 100.0, 60.0, 40.0],
        [0.0 - 150.0, 80.0, 50.0, 50.0],
        [200.0, 0.0 - 120.0, 40.0, 60.0],
        [0.0 - 80.0, 0.0 - 200.0, 70.0, 30.0],
        [300.0, 50.0, 50.0, 100.0],
        [0.0 - 250.0, 0.0 - 50.0, 80.0, 40.0],
        [50.0, 250.0, 100.0, 30.0],
        [0.0, 0.0 - 300.0, 90.0, 50.0]
    ]
    let mut segs = []
    let mut i = 0
    while i < length(walls) {
        let w = walls[i]
        let cx = w[0]
        let cy = w[1]
        let hx = w[2]
        let hy = w[3]
        let tl = make_v(cx - hx, cy - hy)
        let tr = make_v(cx + hx, cy - hy)
        let br = make_v(cx + hx, cy + hy)
        let bl = make_v(cx - hx, cy + hy)
        segs = push(segs, make_seg(tl, tr))
        segs = push(segs, make_seg(tr, br))
        segs = push(segs, make_seg(br, bl))
        segs = push(segs, make_seg(bl, tl))
        i = i + 1
    }
    segs
}

let PI = 3.14159265358979

fn build_angles(n) {
    let two_pi = 2.0 * PI
    let mut angles = []
    let mut i = 0
    while i < n {
        let a = 0.0 - PI + to-float(i) / to-float(n) * two_pi
        angles = push(angles, a)
        i = i + 1
    }
    angles
}

// One frame's worth of cast_ray calls. Returns a checksum so the
// optimizer can't elide the work.
fn do_pass(origin, angles, segments) {
    let mut sum = 0.0
    let mut i = 0
    while i < length(angles) {
        let a = angles[i]
        let dir = make_v(cos(a), sin(a))
        sum = sum + cast_ray(origin, dir, segments)
        i = i + 1
    }
    sum
}

fn run_bench(frames, origin, angles, segments) {
    let mut total = 0.0
    let mut frame = 0
    while frame < frames {
        total = total + do_pass(origin, angles, segments)
        frame = frame + 1
    }
    total
}

fn main() {
    let segments = build_segments()
    let angles = build_angles(64)
    let origin = make_v(0.0, 0.0)

    let n_segs = length(segments)
    let n_angles = length(angles)

    // Warm-up so JIT/inline-cache paths don't show up in the timed run.
    let warm = run_bench(200, origin, angles, segments)
    print("warm checksum: ")
    println(warm)

    let frames = 10000
    let start = core/time-now()
    let total = run_bench(frames, origin, angles, segments)
    let end = core/time-now()

    let elapsed_ms = (end - start) / 1000000
    let calls = frames * n_angles * n_segs

    print("frames: ")
    println(frames)
    print("segments/frame: ")
    println(n_segs)
    print("rays/frame: ")
    println(n_angles)
    print("ray_segment_hit calls: ")
    println(calls)
    print("checksum: ")
    println(total)
    print("elapsed_ms: ")
    println(elapsed_ms)
}
