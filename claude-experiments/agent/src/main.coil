(module app)
(import "raylib.coil" :as raylib)
(import "workflow.coil" :as workflow)
(import "workflow.coil" :use [RUN_RUNNING RUN_DONE RUN_WAITING RUN_FAILED
                              STATUS_PENDING STATUS_READY STATUS_RUNNING STATUS_DONE
                              STATUS_WAITING STATUS_FAILED KIND_AGENT KIND_APPROVAL])
(import "native.coil" :as native)

(extern sin :cc c [f64] (-> f64))
(extern fmod :cc c [f64 f64] (-> f64))
(extern printf :cc c [(ptr i8) ...] (-> i32))
(extern snprintf :cc c [(ptr i8) i64 (ptr i8) ...] (-> i32))

(const WINDOW_FLAGS 8292)
(const LEFT_WIDTH 236)
(const RIGHT_WIDTH 476)
(const HEADER_HEIGHT 64)

;; The seven workspace views. `view` in AppState is the single source of truth for
;; which one is on screen; nothing else gates visibility.
(const VIEW_DASHBOARD 0)
(const VIEW_RUNS 1)
(const VIEW_APPROVALS 2)
(const VIEW_TEMPLATES 3)
(const VIEW_SETTINGS 4)
(const VIEW_CREATE 5)
(const VIEW_RUN 6)

;; Sidebar vertical rhythm, top down. Derived once here so hit-testing and drawing
;; cannot drift apart.
(const SIDEBAR_HEADER_HEIGHT 50)
(const SIDEBAR_NAV_TOP 79)
(const SIDEBAR_NAV_ROW_HEIGHT 33)
(const SIDEBAR_NAV_COUNT 5)
(const SIDEBAR_PROJECTS_LABEL_TOP 259)
(const SIDEBAR_PROJECTS_TOP 279)
(const SIDEBAR_PROJECT_ROW_HEIGHT 46)
(const SIDEBAR_FOOTER_HEIGHT 40)
(const KEY_ENTER 257)
(const KEY_BACKSPACE 259)
(const KEY_DELETE 261)
(const KEY_RIGHT 262)
(const KEY_LEFT 263)
(const KEY_HOME 268)
(const KEY_END 269)
(const KEY_A 65)
(const KEY_C 67)
(const KEY_V 86)
(const KEY_X 88)
(const KEY_LEFT_SHIFT 340)
(const KEY_LEFT_CONTROL 341)
(const KEY_LEFT_ALT 342)
(const KEY_LEFT_SUPER 343)
(const KEY_RIGHT_SHIFT 344)
(const KEY_RIGHT_CONTROL 345)
(const KEY_RIGHT_ALT 346)
(const KEY_RIGHT_SUPER 347)
(const CREATION_CAPACITY 2048)
(const INPUT_CHARACTER_CAPACITY 16)

(defstruct AppState
  [(view i64)
   (selectedProject i64)
   (selectedNode i64)
   (approvalGranted i64)
   (runRequested i64)
   (approvalRequested i64)
   (catalog (ptr workflow.Catalog))
   (runLog (ptr workflow.RunLog))
   (activeRunEntry i64)
   (runFilter i64)
   (scrollOffsets (array f64 8))
   (runtime (ptr workflow.Runtime))
   (activeRuntime (ptr workflow.Runtime))
   (creationRequested i64)
   (creationState i64)
   (creationLength i64)
   (creationText (ptr i8))
   (creationAnchor i64)
   (creationFocus i64)
   (creationFocused i64)
   (creationDragging i64)
   (creationTruncated i64)
   (clipboardRequested i64)
   (clipboardText (ptr i8))
   (designRequested i64)
   (designState i64)
   (designTurn i64)
   (designResponse (ptr i8))
   (designRequest (ptr i8))
   (designPreview (ptr workflow.Runtime))
   (designPreviewValid i64)
   (wrappedOutput (ptr i8))
   (wrappedOutputLength i64)
   (selectionRegion i64)
   (selectionAnchor i64)
   (selectionFocus i64)
   (selectionDragging i64)
   (selectionPressHandled i64)
   (hoverSelectableText i64)
   (measureText (ptr i8))
   (integrations (array Integration 8))
   (mono raylib.Font)
   (monoMedium raylib.Font)
   (sans raylib.Font)])

(const INTEGRATION_COUNT 7)

;; A settings row. `connected` is the result of a real check against this machine
;; (env var set, binary on PATH, file present) run once at startup — never a
;; hardcoded status, and never re-run inside a draw call.
(defstruct Integration
  [(name (ptr i8))
   (glyph (ptr i8))
   (detail (ptr i8))
   (connected i64)])

(defstruct InputFrame
  [(mouseHorizontal f64)
   (mouseVertical f64)
   (wheel f64)
   (pressed i64)
   (down i64)
   (typedCount i64)
   (typedCharacters (array i64 16))
   (backspacePressed i64)
   (deletePressed i64)
   (leftPressed i64)
   (rightPressed i64)
   (homePressed i64)
   (endPressed i64)
   (enterPressed i64)
   (shiftDown i64)
   (commandDown i64)
   (wordDown i64)
   (selectAllPressed i64)
   (copyPressed i64)
   (cutPressed i64)
   (pastePressed i64)
   (pasteText (ptr i8))])

(defn color-alpha [(red i64) (green i64) (blue i64) (alpha i64)] (-> raylib.Color)
  (let [value (alloc-stack raylib.Color)]
    (do
      (store! (field value r) (cast u8 red))
      (store! (field value g) (cast u8 green))
      (store! (field value b) (cast u8 blue))
      (store! (field value a) (cast u8 alpha))
      (load value))))

(defn color [(red i64) (green i64) (blue i64)] (-> raylib.Color)
  (color-alpha red green blue 255))

(defn vector [(horizontal f64) (vertical f64)] (-> raylib.Vector2)
  (let [value (alloc-stack raylib.Vector2)]
    (do
      (store! (field value x) (cast f32 horizontal))
      (store! (field value y) (cast f32 vertical))
      (load value))))

(defn rectangle [(left f64) (top f64) (width f64) (height f64)] (-> raylib.Rectangle)
  (let [value (alloc-stack raylib.Rectangle)]
    (do
      (store! (field value x) (cast f32 left))
      (store! (field value y) (cast f32 top))
      (store! (field value width) (cast f32 width))
      (store! (field value height) (cast f32 height))
      (load value))))

(defn ui-scale [] (-> f64) 1.25)

(defn draw-text [(font raylib.Font) (text (ptr i8)) (left f64) (top f64) (size f64) (tint raylib.Color)] (-> i64)
  (do
    (raylib.DrawTextEx (load font) text (vector left top) (cast f32 (* size 1.16)) (cast f32 0.18) tint)
    0))

;; Scissor rectangles are in physical window coordinates, so they must be scaled
;; by hand while everything else inherits the camera zoom.
(defn begin-scissor [(left f64) (top f64) (width f64) (height f64)] (-> i64)
  (do
    (raylib.BeginScissorMode (cast i32 (* left (ui-scale)))
                             (cast i32 (* top (ui-scale)))
                             (cast i32 (* width (ui-scale)))
                             (cast i32 (* height (ui-scale))))
    0))

(defn fill-rectangle [(left f64) (top f64) (width f64) (height f64) (tint raylib.Color)] (-> i64)
  (do (raylib.DrawRectangleRec (rectangle left top width height) tint) 0))

(defn stroke-rectangle [(left f64) (top f64) (width f64) (height f64) (thickness f64) (tint raylib.Color)] (-> i64)
  (do (raylib.DrawRectangleLinesEx (rectangle left top width height) (cast f32 thickness) tint) 0))

(defn line [(fromHorizontal f64)
            (fromVertical f64)
            (toHorizontal f64)
            (toVertical f64)
            (thickness f64)
            (tint raylib.Color)] (-> i64)
  (do
    (raylib.DrawLineEx (vector fromHorizontal fromVertical) (vector toHorizontal toVertical) (cast f32 thickness) tint)
    0))

(defn text-width [(font raylib.Font) (text (ptr i8)) (size f64)] (-> f64)
  (let [measured (raylib.MeasureTextEx (load font) text (cast f32 (* size 1.16)) (cast f32 0.18))]
    (cast f64 (load (field measured x)))))

(defn draw-text-right [(font raylib.Font)
                       (text (ptr i8))
                       (right f64)
                       (top f64)
                       (size f64)
                       (tint raylib.Color)] (-> i64)
  (draw-text font text (- right (text-width font text size)) top size tint))

(defn project-name [(project i64)] (-> (ptr i8))
  (case project 0
        c"Refund Resolver" 1
        c"Contract Analyzer" 2
        c"Support Triage" 3
        c"Data Migration" c"Release Notes"))

(defn project-subtitle [(project i64)] (-> (ptr i8))
  (case project 0
        c"billing / duplicate charge" 1
        c"legal / MSA review" 2
        c"support / iOS session bug" 3
        c"infra / orders table" c"eng / shipping v2.14"))

(defn project-path [(project i64)] (-> (ptr i8))
  (case project 0
        c"refund-resolver" 1
        c"contract-analyzer" 2
        c"support-triage" 3
        c"data-migration" c"release-notes"))

(defn display-project-name [(state AppState) (project i64)] (-> (ptr i8))
  (workflow.catalog-name (load (field state catalog)) project))

(defn display-project-path [(state AppState) (project i64)] (-> (ptr i8))
  (workflow.catalog-path (load (field state catalog)) project))

(defn display-project-subtitle [(state AppState) (project i64)] (-> (ptr i8))
  c"project workflow / codex")

(defn accent [(project i64)] (-> raylib.Color)
  (case project 0
        (color 224 165 58) 1
        (color 191 135 223) 2
        (color 104 207 167) 3
        (color 102 158 229) (color 224 113 98)))

(defn accent-alpha [(project i64) (alpha i64)] (-> raylib.Color)
  (let [value (alloc-stack raylib.Color)]
    (do
      (store! value (accent project))
      (store! (field value a) (cast u8 alpha))
      (load value))))

;; Mixes a colour toward the page background, standing in for the design's
;; color-mix(... , #070a0e) fills.
(defn accent-blend [(tint raylib.Color) (amount i64)] (-> raylib.Color)
  (let [value (alloc-stack raylib.Color)]
    (do
      (store! value tint)
      (store! (field value r) (cast u8 (/ (* (cast i64 (load (field value r))) amount) 255)))
      (store! (field value g) (cast u8 (/ (* (cast i64 (load (field value g))) amount) 255)))
      (store! (field value b) (cast u8 (/ (* (cast i64 (load (field value b))) amount) 255)))
      (load value))))

