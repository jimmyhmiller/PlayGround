(defn configure-font [(font raylib.Font)] (-> i64)
  (do
    (raylib.SetTextureFilter (load (field font texture)) (cast i32 TEXTURE_FILTER_BILINEAR))
    0))

(defn in-bounds [(horizontal f64) (vertical f64) (left f64) (top f64) (width f64) (height f64)] (-> bool)
  (and (>= horizontal left)
       (and (< horizontal (+ left width)) (and (>= vertical top) (< vertical (+ top height))))))

;; Layered DAG layout: a node's row is its longest dependency chain, and
;; nodes sharing a row spread into columns around the center line.
(defn compute-flow-layout [(runtime workflow.Runtime)
                           (depths (ptr i64))
                           (columns (ptr i64))
                           (rowCounts (ptr i64))] (-> i64)
  (let [(mut maxDepth) 0]
    (do
      (for [row 0
            7]
        (store! (index rowCounts row) 0))
      (for [node 0
            7]
        (if (< node (workflow.node-count runtime))
          (let [dependencyA (workflow.node-dependency runtime node 0)
                dependencyB (workflow.node-dependency runtime node 1)
                (mut depth) 0]
            (do
              (if (and (>= dependencyA 0) (> (+ (load (index depths dependencyA)) 1) (load depth)))
                (store! depth (+ (load (index depths dependencyA)) 1))
                0)
              (if (and (>= dependencyB 0) (> (+ (load (index depths dependencyB)) 1) (load depth)))
                (store! depth (+ (load (index depths dependencyB)) 1))
                0)
              (store! (index depths node) (load depth))
              (store! (index columns node) (load (index rowCounts (load depth))))
              (store! (index rowCounts (load depth)) (+ (load (index rowCounts (load depth))) 1))
              (if (> (load depth) (load maxDepth)) (store! maxDepth (load depth)) 0)
              0))
          0))
      (load maxDepth))))

(defn layout-horizontal [(column i64) (rowCount i64) (center f64)] (-> f64)
  (+ center (* (- (cast f64 column) (/ (cast f64 (- rowCount 1)) 2.0)) 320.0)))

(defn layout-vertical [(depth i64) (maxDepth i64) (height i64)] (-> f64)
  (let [divisor (cast f64 (if (> maxDepth 5) maxDepth 5))
        raw (/ (- (cast f64 height) 205.0) divisor)
        step (cond (< raw 100.0) 100.0
                   (> raw 139.0) 139.0
                   raw)]
    (+ 144.0 (* (cast f64 depth) step))))

;; Text editing behavior in this section is adapted from Vercel Labs Native SDK's
;; text interaction engine, modified for Coil, Raylib, and Flowline's fixed state.
;; See licenses/native-sdk-Apache-2.0.txt and THIRD_PARTY_NOTICES.md.
(defn selection-start [(state AppState)] (-> i64)
  (let [anchor (load (field state creationAnchor))
        focus (load (field state creationFocus))]
    (if (< anchor focus) anchor focus)))

(defn selection-end [(state AppState)] (-> i64)
  (let [anchor (load (field state creationAnchor))
        focus (load (field state creationFocus))]
    (if (> anchor focus) anchor focus)))

(defn is-utf8-continuation [(byte i64)] (-> bool)
  (= (iand byte 192) 128))

(defn previous-text-offset [(text (ptr i8)) (offset i64)] (-> i64)
  (if (<= offset 0)
    0
    (let [(mut cursor) (- offset 1)]
      (do
        (while (and (> (load cursor) 0)
                    (is-utf8-continuation (cast i64 (cast u8 (load (index text (load cursor)))))))
          (store! cursor (- (load cursor) 1)))
        (load cursor)))))

(defn next-text-offset [(text (ptr i8)) (length i64) (offset i64)] (-> i64)
  (if (>= offset length)
    length
    (let [(mut cursor) (+ offset 1)]
      (do
        (while (and (< (load cursor) length)
                    (is-utf8-continuation (cast i64 (cast u8 (load (index text (load cursor)))))))
          (store! cursor (+ (load cursor) 1)))
        (load cursor)))))

(defn word-byte [(byte i64)] (-> bool)
  (or (and (>= byte 48) (<= byte 57))
      (or (and (>= byte 65) (<= byte 90))
          (or (and (>= byte 97) (<= byte 122)) (or (= byte 95) (>= byte 128))))))

(defn word-at [(text (ptr i8)) (offset i64)] (-> bool)
  (word-byte (cast i64 (cast u8 (load (index text offset))))))

(defn previous-word-offset [(text (ptr i8)) (offset i64)] (-> i64)
  (let [(mut cursor) offset]
    (do
      (while (and (> (load cursor) 0) (= (word-at text (previous-text-offset text (load cursor))) false))
        (store! cursor (previous-text-offset text (load cursor))))
      (while (and (> (load cursor) 0) (word-at text (previous-text-offset text (load cursor))))
        (store! cursor (previous-text-offset text (load cursor))))
      (load cursor))))

(defn next-word-offset [(text (ptr i8)) (length i64) (offset i64)] (-> i64)
  (let [(mut cursor) offset]
    (do
      (while (and (< (load cursor) length) (= (word-at text (load cursor)) false))
        (store! cursor (next-text-offset text length (load cursor))))
      (while (and (< (load cursor) length) (word-at text (load cursor)))
        (store! cursor (next-text-offset text length (load cursor))))
      (load cursor))))

(defn delete-text-range [(state (mut AppState)) (start i64) (end i64)] (-> i64)
  (let [text (load (field state creationText))
        length (load (field state creationLength))
        removed (- end start)
        (mut source) end]
    (do
      (while (<= (load source) length)
        (do
          (store! (index text (- (load source) removed)) (load (index text (load source))))
          (store! source (+ (load source) 1))))
      (store! (field state creationLength) (- length removed))
      (store! (field state creationAnchor) start)
      (store! (field state creationFocus) start)
      0)))

(defn delete-selection [(state (mut AppState))] (-> i64)
  (let [start (selection-start state)
        end (selection-end state)]
    (if (< start end) (delete-text-range (mut state) start end) 0)))

(defn insert-codepoint [(state (mut AppState)) (codepoint i64)] (-> i64)
  (let [byteCount (cond (<= codepoint 127) 1 (<= codepoint 2047) 2 (<= codepoint 65535) 3 4)]
    (do
      (delete-selection (mut state))
      (let [text (load (field state creationText))
            length (load (field state creationLength))
            cursor (load (field state creationFocus))]
        (if (> (+ length byteCount) (- CREATION_CAPACITY 1))
          (do (store! (field state creationTruncated) 1) 0)
          (let [(mut source) length]
            (do
              (while (>= (load source) cursor)
                (do
                  (store! (index text (+ (load source) byteCount)) (load (index text (load source))))
                  (store! source (- (load source) 1))))
              (cond (= byteCount 1) (store! (index text cursor) (cast i8 codepoint))
                    (= byteCount 2)
                      (do
                        (store! (index text cursor) (cast i8 (ior 192 (ishr codepoint 6))))
                        (store! (index text (+ cursor 1)) (cast i8 (ior 128 (iand codepoint 63))))
                        0)
                    (= byteCount 3)
                      (do
                        (store! (index text cursor) (cast i8 (ior 224 (ishr codepoint 12))))
                        (store! (index text (+ cursor 1))
                                (cast i8 (ior 128 (iand (ishr codepoint 6) 63))))
                        (store! (index text (+ cursor 2)) (cast i8 (ior 128 (iand codepoint 63))))
                        0)
                    (do
                      (store! (index text cursor) (cast i8 (ior 240 (ishr codepoint 18))))
                      (store! (index text (+ cursor 1))
                              (cast i8 (ior 128 (iand (ishr codepoint 12) 63))))
                      (store! (index text (+ cursor 2))
                              (cast i8 (ior 128 (iand (ishr codepoint 6) 63))))
                      (store! (index text (+ cursor 3)) (cast i8 (ior 128 (iand codepoint 63))))
                      0))
              (store! (field state creationLength) (+ length byteCount))
              (store! (field state creationAnchor) (+ cursor byteCount))
              (store! (field state creationFocus) (+ cursor byteCount))
              (store! (field state creationTruncated) 0)
              0))))
      0)))

(defn copy-string [(destination (ptr i8)) (source (ptr i8)) (capacity i64)] (-> i64)
  (let [(mut position) 0]
    (do
      (while (and (< (load position) (- capacity 1))
                  (icmp-ne (load (index source (load position))) (cast i8 0)))
        (do
          (store! (index destination (load position)) (load (index source (load position))))
          (store! position (+ (load position) 1))))
      (store! (index destination (load position)) (cast i8 0))
      0)))

(defn byte-text-length [(text (ptr i8))] (-> i64)
  (let [(mut length) 0]
    (loop (if (icmp-eq (load (index text (load length))) (cast i8 0))
            (break (load length))
            (store! length (+ (load length) 1))))))

(defn insert-text [(state (mut AppState)) (sourceText (ptr i8))] (-> i64)
  (do
    (delete-selection (mut state))
    (let [text (load (field state creationText))
          length (load (field state creationLength))
          cursor (load (field state creationFocus))
          requested (byte-text-length sourceText)
          available (- (- CREATION_CAPACITY 1) length)
          (mut insertLength) (if (< requested available) requested available)]
      (do
        (while (and (> (load insertLength) 0)
                    (is-utf8-continuation (cast i64 (cast u8 (load (index sourceText (load insertLength)))))))
          (store! insertLength (- (load insertLength) 1)))
        (let [(mut source) length]
          (do
            (while (>= (load source) cursor)
              (do
                (store! (index text (+ (load source) (load insertLength))) (load (index text (load source))))
                (store! source (- (load source) 1))))
            (for [position 0
                  2048]
              (if (< position (load insertLength))
                (store! (index text (+ cursor position)) (load (index sourceText position)))
                0))
            (store! (field state creationLength) (+ length (load insertLength)))
            (store! (field state creationAnchor) (+ cursor (load insertLength)))
            (store! (field state creationFocus) (+ cursor (load insertLength)))
            (store! (field state creationTruncated) (if (< (load insertLength) requested) 1 0))
            0))
        0))))

(defn copy-creation-selection [(state (mut AppState))] (-> i64)
  (let [start (selection-start state)
        end (selection-end state)
        source (load (field state creationText))
        destination (load (field state clipboardText))]
    (if (= start end)
      0
      (do
        (for [position 0
              2048]
          (if (< position (- end start))
            (store! (index destination position) (load (index source (+ start position))))
            0))
        (store! (index destination (- end start)) (cast i8 0))
        (store! (field state clipboardRequested) 1)
        0))))

(defn move-creation-caret [(state (mut AppState)) (direction i64) (extend i64)] (-> i64)
  (let [text (load (field state creationText))
        length (load (field state creationLength))
        anchor (load (field state creationAnchor))
        focus (load (field state creationFocus))
        start (selection-start state)
        end (selection-end state)
        target
          (cond (= direction 0) (if (and (= extend 0) (!= anchor focus)) start (previous-text-offset text focus))
                (= direction 1) (if (and (= extend 0) (!= anchor focus)) end (next-text-offset text length focus))
                (= direction 2) 0
                (= direction 3) length
                (= direction 4) (previous-word-offset text focus)
                (next-word-offset text length focus))]
    (do
      (store! (field state creationFocus) target)
      (if (= extend 0) (store! (field state creationAnchor) target) 0)
      0)))

(defn edit-creation-text [(state (mut AppState)) (input InputFrame)] (-> i64)
  (if (or (= (load (field state creationFocused)) 0) (= (load (field state designState)) 1))
    0
    (do
      (if (= (load (field input selectAllPressed)) 1)
        (do
          (store! (field state creationAnchor) 0)
          (store! (field state creationFocus) (load (field state creationLength)))
          0)
        0)
      (if (= (load (field input copyPressed)) 1) (copy-creation-selection (mut state)) 0)
      (if (= (load (field input cutPressed)) 1)
        (do
          (copy-creation-selection (mut state))
          (delete-selection (mut state))
          0)
        0)
      (if (= (load (field input pastePressed)) 1)
        (let [pasteText (load (field input pasteText))]
          (if (!= (cast i64 pasteText) 0) (insert-text (mut state) pasteText) 0))
        0)
      (if (= (load (field input leftPressed)) 1)
        (move-creation-caret (mut state)
                             (if (= (load (field input commandDown)) 1)
                               2
                               (if (= (load (field input wordDown)) 1) 4 0))
                             (load (field input shiftDown)))
        0)
      (if (= (load (field input rightPressed)) 1)
        (move-creation-caret (mut state)
                             (if (= (load (field input commandDown)) 1)
                               3
                               (if (= (load (field input wordDown)) 1) 5 1))
                             (load (field input shiftDown)))
        0)
      (if (= (load (field input homePressed)) 1)
        (move-creation-caret (mut state) 2 (load (field input shiftDown)))
        0)
      (if (= (load (field input endPressed)) 1)
        (move-creation-caret (mut state) 3 (load (field input shiftDown)))
        0)
      (if (= (load (field input backspacePressed)) 1)
        (let [start (selection-start state)
              end (selection-end state)
              focus (load (field state creationFocus))]
          (if (< start end)
            (delete-text-range (mut state) start end)
            (if (> focus 0)
              (delete-text-range (mut state) (previous-text-offset (load (field state creationText)) focus) focus)
              0)))
        0)
      (if (= (load (field input deletePressed)) 1)
        (let [start (selection-start state)
              end (selection-end state)
              focus (load (field state creationFocus))
              length (load (field state creationLength))]
          (if (< start end)
            (delete-text-range (mut state) start end)
            (if (< focus length)
              (delete-text-range (mut state) focus (next-text-offset (load (field state creationText)) length focus))
              0)))
        0)
      (for [characterIndex 0
            16]
        (if (< characterIndex (load (field input typedCount)))
          (let [codepoint (load (index (field input typedCharacters) characterIndex))]
            (if (>= codepoint 32) (insert-codepoint (mut state) codepoint) 0))
          0))
      0)))

(defn text-width-through [(font raylib.Font) (text (ptr i8)) (offset i64) (size f64)] (-> f64)
  (let [saved (load (index text offset))]
    (do
      (store! (index text offset) (cast i8 0))
      (let [measured (raylib.MeasureTextEx (load font) text (cast f32 (* size 1.16)) (cast f32 0.18))]
        (do
          (store! (index text offset) saved)
          (cast f64 (load (field measured x))))))))

(defn creation-text-scroll [(state AppState) (visibleWidth f64)] (-> f64)
  (let [caretWidth
          (text-width-through (field state sans)
                              (load (field state creationText))
                              (load (field state creationFocus))
                              11.5)]
    (if (> caretWidth (- visibleWidth 8.0)) (- caretWidth (- visibleWidth 8.0)) 0.0)))

(defn creation-offset-at [(state AppState) (horizontal f64) (textLeft f64) (visibleWidth f64)] (-> i64)
  (let [text (load (field state creationText))
        length (load (field state creationLength))
        target (+ (- horizontal textLeft) (creation-text-scroll state visibleWidth))
        (mut offset) 0]
    (loop (if (>= (load offset) length)
            (break length)
            (let [next (next-text-offset text length (load offset))
                  leftWidth (text-width-through (field state sans) text (load offset) 11.5)
                  rightWidth (text-width-through (field state sans) text next 11.5)]
              (if (< target (/ (+ leftWidth rightWidth) 2.0))
                (break (load offset))
                (store! offset next)))))))

;; Read-only text selection for content blocks (agent output, designer replies).
;; A block registers itself at draw time with a stable region id; the selection
;; lives in AppState and survives frames until a press lands outside every block.
(defn text-line-advance [(size f64)] (-> f64)
  (+ (* size 1.16) 2.0))

(defn line-end-offset [(text (ptr i8)) (length i64) (lineStart i64)] (-> i64)
  (let [(mut offset) lineStart]
    (loop (if (or (>= (load offset) length)
                  (= (cast i64 (load (index text (load offset)))) 10))
            (break (load offset))
            (store! offset (+ (load offset) 1))))))

(defn count-text-lines [(text (ptr i8)) (length i64)] (-> i64)
  (let [(mut count) 1
        (mut position) 0]
    (do
      (while (< (load position) length)
        (do
          (if (= (cast i64 (load (index text (load position)))) 10)
            (store! count (+ (load count) 1))
            0)
          (store! position (+ (load position) 1))))
      (load count))))

(defn segment-width [(state AppState)
                     (font raylib.Font)
                     (text (ptr i8))
                     (segmentStart i64)
                     (segmentEnd i64)
                     (size f64)] (-> f64)
  (let [buffer (load (field state measureText))
        span (- segmentEnd segmentStart)
        count (if (> span 4095) 4095 span)
        (mut position) 0]
    (do
      (while (< (load position) count)
        (do
          (store! (index buffer (load position)) (load (index text (+ segmentStart (load position)))))
          (store! position (+ (load position) 1))))
      (store! (index buffer count) (cast i8 0))
      (let [measured (raylib.MeasureTextEx (load font) buffer (cast f32 (* size 1.16)) (cast f32 0.18))]
        (cast f64 (load (field measured x)))))))

;; Greedy word wrap, in place: spaces become newlines where the measured line
;; would overflow, so text length and selection offsets stay stable.
(defn wrap-text-in-place [(state AppState)
                          (text (ptr i8))
                          (font raylib.Font)
                          (size f64)
                          (maxWidth f64)] (-> i64)
  (let [(mut lineStart) 0
        (mut lastSpace) -1
        (mut position) 0]
    (do
      (loop
        (let [byte (cast i64 (load (index text (load position))))]
          (if (= byte 0)
            (break 0)
            (do
              (cond (= byte 10)
                      (do
                        (store! lineStart (+ (load position) 1))
                        (store! lastSpace -1)
                        0)
                    (= byte 32)
                      (do
                        (if (and (>= (load lastSpace) 0)
                                 (> (segment-width state font text (load lineStart) (load position) size)
                                    maxWidth))
                          (do
                            (store! (index text (load lastSpace)) (cast i8 10))
                            (store! lineStart (+ (load lastSpace) 1))
                            0)
                          0)
                        (store! lastSpace (load position))
                        0)
                    0)
              (store! position (+ (load position) 1))))))
      (if (and (>= (load lastSpace) 0)
               (> (segment-width state font text (load lineStart) (load position) size) maxWidth))
        (do (store! (index text (load lastSpace)) (cast i8 10)) 0)
        0)
      0)))

(defn region-offset-at [(state AppState)
                        (font raylib.Font)
                        (text (ptr i8))
                        (length i64)
                        (left f64)
                        (top f64)
                        (size f64)
                        (horizontal f64)
                        (vertical f64)] (-> i64)
  (let [advance (text-line-advance size)
        targetLine
          (let [raw (cast i64 (/ (- vertical top) advance))]
            (if (< raw 0) 0 raw))
        (mut lineStart) 0
        (mut remaining) targetLine
        (mut pastEnd) 0]
    (do
      (while (> (load remaining) 0)
        (let [lineEnd (line-end-offset text length (load lineStart))]
          (if (>= lineEnd length)
            (do
              (store! pastEnd 1)
              (store! remaining 0)
              0)
            (do
              (store! lineStart (+ lineEnd 1))
              (store! remaining (- (load remaining) 1))
              0))))
      (if (= (load pastEnd) 1)
        length
        (let [lineEnd (line-end-offset text length (load lineStart))
              target (- horizontal left)
              (mut offset) (load lineStart)]
          (if (<= target 0.0)
            (load lineStart)
            (loop (if (>= (load offset) lineEnd)
                    (break lineEnd)
                    (let [next (next-text-offset text lineEnd (load offset))
                          leftWidth (segment-width state font text (load lineStart) (load offset) size)
                          rightWidth (segment-width state font text (load lineStart) next size)]
                      (if (< target (/ (+ leftWidth rightWidth) 2.0))
                        (break (load offset))
                        (store! offset next)))))))))))

(defn draw-region-highlight [(state AppState)
                             (font raylib.Font)
                             (text (ptr i8))
                             (length i64)
                             (left f64)
                             (top f64)
                             (size f64)
                             (start i64)
                             (end i64)] (-> i64)
  (let [advance (text-line-advance size)
        (mut lineStart) 0
        (mut lineIndex) 0]
    (loop
      (let [lineEnd (line-end-offset text length (load lineStart))
            segmentStart (if (> start (load lineStart)) start (load lineStart))
            segmentEnd (if (< end lineEnd) end lineEnd)]
        (do
          (if (< segmentStart segmentEnd)
            (let [leftEdge (segment-width state font text (load lineStart) segmentStart size)
                  rightEdge (segment-width state font text (load lineStart) segmentEnd size)
                  newlineTail (if (and (< lineEnd length) (> end lineEnd)) 5.0 0.0)]
              (fill-rectangle (+ left leftEdge)
                              (+ top (- (* (cast f64 (load lineIndex)) advance) 2.0))
                              (+ (- rightEdge leftEdge) newlineTail)
                              (+ (* size 1.16) 5.0)
                              (color-alpha 74 121 178 110)))
            0)
          (if (>= lineEnd length)
            (break 0)
            (do
              (store! lineStart (+ lineEnd 1))
              (store! lineIndex (+ (load lineIndex) 1))
              0)))))))

(defn copy-region-text [(state (mut AppState)) (text (ptr i8)) (start i64) (end i64)] (-> i64)
  (let [destination (load (field state clipboardText))
        span (- end start)
        count (if (> span 4095) 4095 span)
        (mut position) 0]
    (do
      (while (< (load position) count)
        (do
          (store! (index destination (load position)) (load (index text (+ start (load position)))))
          (store! position (+ (load position) 1))))
      (store! (index destination count) (cast i8 0))
      (store! (field state clipboardRequested) 1)
      0)))

(defn selectable-text [(state (mut AppState))
                       (input InputFrame)
                       (region i64)
                       (font raylib.Font)
                       (text (ptr i8))
                       (left f64)
                       (top f64)
                       (size f64)
                       (tint raylib.Color)] (-> i64)
  (let [length (byte-text-length text)]
    (if (= length 0)
      (draw-text font text left top size tint)
      (let [advance (text-line-advance size)
            measured (raylib.MeasureTextEx (load font) text (cast f32 (* size 1.16)) (cast f32 0.18))
            width (cast f64 (load (field measured x)))
            height (* (cast f64 (count-text-lines text length)) advance)
            mouseHorizontal (load (field input mouseHorizontal))
            mouseVertical (load (field input mouseVertical))
            hovering (in-bounds mouseHorizontal mouseVertical (- left 2.0) (- top 2.0) (+ width 4.0) (+ height 4.0))
            editing
              (if (and (= (load (field state view)) VIEW_CREATE) (= (load (field state creationFocused)) 1)) 1 0)]
        (do
          (if hovering (store! (field state hoverSelectableText) 1) 0)
          (if (and hovering (= (load (field input pressed)) 1))
            (let [offset (region-offset-at state font text length left top size mouseHorizontal mouseVertical)]
              (do
                (store! (field state selectionRegion) region)
                (store! (field state selectionAnchor) offset)
                (store! (field state selectionFocus) offset)
                (store! (field state selectionDragging) 1)
                (store! (field state selectionPressHandled) 1)
                0))
            0)
          (if (= (load (field state selectionRegion)) region)
            (do
              (if (> (load (field state selectionAnchor)) length) (store! (field state selectionAnchor) length) 0)
              (if (> (load (field state selectionFocus)) length) (store! (field state selectionFocus) length) 0)
              (if (and (= (load (field state selectionDragging)) 1) (= (load (field input down)) 1))
                (store! (field state selectionFocus)
                        (region-offset-at state font text length left top size mouseHorizontal mouseVertical))
                0)
              (if (= (load (field input down)) 0) (store! (field state selectionDragging) 0) 0)
              (if (and (= (load (field input selectAllPressed)) 1) (= editing 0))
                (do
                  (store! (field state selectionAnchor) 0)
                  (store! (field state selectionFocus) length)
                  0)
                0)
              (let [anchor (load (field state selectionAnchor))
                    focus (load (field state selectionFocus))
                    start (if (< anchor focus) anchor focus)
                    end (if (> anchor focus) anchor focus)]
                (do
                  (if (< start end)
                    (draw-region-highlight state font text length left top size start end)
                    0)
                  (if (and (= (load (field input copyPressed)) 1)
                           (and (= editing 0) (< start end)))
                    (copy-region-text (mut state) text start end)
                    0)
                  0)))
            0)
          (draw-text font text left top size tint)
          0)))))

(defn set-integration [(state (mut AppState))
                       (slot i64)
                       (name (ptr i8))
                       (glyph (ptr i8))
                       (detail (ptr i8))
                       (connected bool)] (-> i64)
  (do
    (store! (field (index (field state integrations) slot) name) name)
    (store! (field (index (field state integrations) slot) glyph) glyph)
    (store! (field (index (field state integrations) slot) detail) detail)
    (store! (field (index (field state integrations) slot) connected) (if connected 1 0))
    0))

;; Probes the machine once at startup. `command-available` shells out, so this
;; must never be called from a draw path.
(defn detect-integrations [(state (mut AppState))] (-> i64)
  (do
    (set-integration (mut state)
                     0
                     c"DeepSeek API"
                     c"ds"
                     c"chat completions / runs every agent turn"
                     (or (workflow.environment-set c"DEEPSEEK_KEY")
                         (workflow.environment-set c"DEEPSEEK_API_KEY")))
    (set-integration (mut state)
                     1
                     c"Agent adapter"
                     c"ag"
                     c"tools/deepseek-agent.sh / composes and sends turns"
                     (workflow.file-exists c"tools/deepseek-agent.sh"))
    (set-integration (mut state) 2 c"curl" c"cu" c"transport used to reach the API" (workflow.command-available c"curl"))
    (set-integration (mut state)
                     3
                     c"jq"
                     c"jq"
                     c"builds request payloads and reads responses"
                     (workflow.command-available c"jq"))
    (set-integration (mut state)
                     4
                     c"Codex CLI"
                     c"cx"
                     c"alternate runner named by a workflow's runner line"
                     (workflow.command-available c"codex"))
    (set-integration (mut state)
                     5
                     c"Workflow catalog"
                     c"wf"
                     c"workflows/*.flow / discovered at startup"
                     (> (workflow.catalog-count (load (field state catalog))) 0))
    (set-integration (mut state)
                     6
                     c"Run state"
                     c"rs"
                     c".flowline/ / prompts, outputs and run history"
                     (workflow.file-exists c".flowline/runs.log"))
    0))

;; Starting a run is one transition: begin the runtime, make it the active one,
;; and open its record in the log. Extracted from the frame loop so the harness
;; can drive it — a run that never gets recorded is invisible everywhere else.
(defn apply-run-request [(state (mut AppState))] (-> i64)
  (if (!= (load (field state runRequested)) 1)
    0
    (let [selectedRuntime (load (field state runtime))
          activeRuntime (load (field state activeRuntime))]
      (do
        (if (or (= (cast i64 activeRuntime) 0) (workflow.is-finished activeRuntime))
          (do
            (workflow.start (mut selectedRuntime))
            (store! (field state activeRuntime) selectedRuntime)
            (store! (field state activeRunEntry)
                    (workflow.begin-run (load (field state runLog))
                                        (workflow.program-name selectedRuntime)
                                        (workflow.program-path selectedRuntime)
                                        c"manual"))
            0)
          0)
        (store! (field state runRequested) 0)
        0))))

;; The run record for the in-flight runtime follows that runtime's collapsed
;; status. Writes only happen on an actual change, so a long run does not rewrite
;; the log every frame.
(defn sync-active-run [(state (mut AppState)) (runtime (ptr workflow.Runtime))] (-> i64)
  (let [entry (load (field state activeRunEntry))
        log (load (field state runLog))]
    (if (< entry 0)
      0
      (let [record (workflow.run-log-record log entry)
            status (workflow.runtime-run-status runtime)]
        (do
          (if (!= status (load (field record status)))
            (workflow.update-run log entry status)
            0)
          (if (workflow.is-finished runtime)
            (store! (field state activeRunEntry) -1)
            0)
          0)))))

;; Clearing everything the create view accumulates. Entering `create` from anywhere
;; always starts from a blank slate rather than a half-finished previous attempt.
(defn reset-creation [(state (mut AppState))] (-> i64)
  (do
    (store! (field state view) VIEW_CREATE)
    (store! (field state creationState) 0)
    (store! (field state creationLength) 0)
    (store! (field state creationAnchor) 0)
    (store! (field state creationFocus) 0)
    (store! (field state creationFocused) 1)
    (store! (field state creationDragging) 0)
    (store! (field state creationTruncated) 0)
    (store! (field state designState) 0)
    (store! (field state designTurn) 0)
    (store! (load (field state creationText)) (cast i8 0))
    (store! (load (field state designResponse)) (cast i8 0))
    (store! (load (field state designRequest)) (cast i8 0))
    (store! (field state designPreviewValid) 0)
    0))

;; The sidebar is live in every view, so its hit-testing runs before any view's own.
(defn apply-sidebar-input [(state (mut AppState)) (input InputFrame) (screenHeight i64)] (-> i64)
  (let [mouseHorizontal (load (field input mouseHorizontal))
        mouseVertical (load (field input mouseVertical))
        catalog (load (field state catalog))]
    (if (= (load (field input pressed)) 0)
      0
      (do
        (for [slot 0
              SIDEBAR_NAV_COUNT]
          (if (in-bounds mouseHorizontal mouseVertical 8.0 (nav-row-top slot) 220.0 32.0)
            (store! (field state view)
                    (case slot 0
                          VIEW_DASHBOARD 1
                          VIEW_RUNS 2
                          VIEW_APPROVALS 3
                          VIEW_TEMPLATES
                          VIEW_SETTINGS))
            0))
        (if (in-bounds mouseHorizontal mouseVertical 176.0 (cast f64 (- SIDEBAR_PROJECTS_LABEL_TOP 4)) 44.0 18.0)
          (reset-creation (mut state))
          0)
        (for [project 0
              8]
          (if (and (< project (workflow.catalog-count catalog))
                   (in-bounds mouseHorizontal mouseVertical 8.0 (project-row-top project) 220.0 45.0))
            (do
              (store! (field state selectedProject) project)
              (store! (field state runtime) (workflow.catalog-runtime catalog project))
              (store! (field state selectedNode) 0)
              (store! (field state approvalGranted) 0)
              (store! (field state view) VIEW_DASHBOARD)
              0)
            0))
        0))))

;; How tall a view's body is if nothing were clipped. Scrolling is clamped
;; against this, and the same number tells each view whether to bother at all.
(defn view-content-height [(state AppState) (view i64) (screenWidth i64)] (-> f64)
  (let [catalog (load (field state catalog))]
    (cond (= view VIEW_RUNS)
            (cast f64 (* (run-log-tally state (cast (ptr i8) 0) (run-filter-status (load (field state runFilter)))) 40))
          (= view VIEW_APPROVALS) (cast f64 (* (catalog-waiting-node-count catalog) 124))
          (= view VIEW_TEMPLATES)
            (cast f64 (* (/ (+ (workflow.catalog-count catalog) 2) 3) 190))
          (= view VIEW_SETTINGS) (cast f64 (* INTEGRATION_COUNT 62))
          0.0)))

(defn view-scroll [(state AppState) (view i64)] (-> f64)
  (if (or (< view 0) (>= view 8)) 0.0 (load (index (field state scrollOffsets) view))))

;; Wheel input scrolls the active view, clamped so a list can never be pushed
;; past its own end or above its start.
(defn apply-scroll-input [(state (mut AppState)) (input InputFrame) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [view (load (field state view))
        wheel (load (field input wheel))]
    (if (or (fcmp-eq wheel 0.0) (or (< view 0) (>= view 8)))
      0
      (let [viewport (cast f64 (- screenHeight (+ VIEW_HEADER_HEIGHT 30)))
            content (view-content-height state view screenWidth)
            maximum (if (> content viewport) (- content viewport) 0.0)
            proposed (- (view-scroll state view) (* wheel 42.0))]
        (do
          (store! (index (field state scrollOffsets) view)
                  (if (< proposed 0.0) 0.0 (if (> proposed maximum) maximum proposed)))
          0)))))

(defn runs-row-top [(row i64) (scroll f64)] (-> f64)
  (- (+ (cast f64 (+ VIEW_HEADER_HEIGHT 34)) (cast f64 (* row 40))) scroll))

(defn approval-card-top [(card i64) (scroll f64)] (-> f64)
  (- (+ (cast f64 (+ VIEW_HEADER_HEIGHT 20)) (cast f64 (* card 124))) scroll))

;; A row is drawn only when it is actually inside the body. Culling per row keeps
;; the lists correct without an enclosing scissor, which would be dropped by the
;; per-cell text clipping inside each row.
(defn row-visible [(top f64) (height f64) (screenHeight i64)] (-> bool)
  (and (> (+ top height) (cast f64 VIEW_HEADER_HEIGHT)) (< top (cast f64 screenHeight))))

;; Which catalog entry a recorded run belongs to, or -1 when its program is no
;; longer in the catalog.
(defn project-for-path [(state AppState) (path (ptr i8))] (-> i64)
  (let [catalog (load (field state catalog))
        (mut found) -1]
    (do
      (for [project 0
            8]
        (if (and (< project (workflow.catalog-count catalog))
                 (workflow.strings-equal (workflow.program-path (workflow.catalog-runtime catalog project)) path))
          (store! found project)
          0))
      (load found))))

(defn open-project-run [(state (mut AppState)) (project i64) (node i64)] (-> i64)
  (if (< project 0)
    0
    (do
      (store! (field state selectedProject) project)
      (store! (field state runtime) (workflow.catalog-runtime (load (field state catalog)) project))
      (store! (field state selectedNode) node)
      (store! (field state view) VIEW_RUN)
      0)))

;; Input for the five list-style views. Each block mirrors its view's own row
;; geometry through the shared *-top helpers so the two cannot drift apart.
(defn apply-view-input [(state (mut AppState)) (input InputFrame) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [mouseHorizontal (load (field input mouseHorizontal))
        mouseVertical (load (field input mouseVertical))
        view (load (field state view))
        left (cast f64 (+ LEFT_WIDTH VIEW_PADDING))
        right (cast f64 (- screenWidth VIEW_PADDING))
        catalog (load (field state catalog))
        log (load (field state runLog))]
    (if (= (load (field input pressed)) 0)
      0
      (do
        (if (= view VIEW_DASHBOARD)
          (do
            (if (in-bounds mouseHorizontal mouseVertical (- (+ (cast f64 LEFT_WIDTH) (- right (cast f64 LEFT_WIDTH))) 128.0) 22.0 128.0 30.0)
              (reset-creation (mut state))
              0)
            (if (in-bounds mouseHorizontal mouseVertical (- right 400.0) (cast f64 (+ VIEW_HEADER_HEIGHT 128)) 92.0 20.0)
              (store! (field state view) VIEW_RUNS)
              0)
            0)
          0)
        (if (= view VIEW_RUNS)
          (do
            (for [slot 0
                  4]
              (if (in-bounds mouseHorizontal mouseVertical (run-filter-left slot screenWidth) 24.0 62.0 26.0)
                (store! (field state runFilter) slot)
                0))
            (let [wanted (run-filter-status (load (field state runFilter)))
                  (mut row) 0]
              (for [step 0
                    64]
                (let [entry (- (- (workflow.run-log-count log) 1) step)]
                  (if (>= entry 0)
                    (let [record (workflow.run-log-record log entry)]
                      (if (or (< wanted 0) (= (load (field record status)) wanted))
                        (do
                          (if (in-bounds mouseHorizontal
                                         mouseVertical
                                         (cast f64 LEFT_WIDTH)
                                         (runs-row-top (load row) (view-scroll state VIEW_RUNS))
                                         (- (cast f64 screenWidth) (cast f64 LEFT_WIDTH))
                                         40.0)
                            (open-project-run (mut state)
                                              (project-for-path state (workflow.record-path record))
                                              0)
                            0)
                          (store! row (+ (load row) 1))
                          0)
                        0))
                    0))))
            0)
          0)
        (if (= view VIEW_RUN)
          (if (in-bounds mouseHorizontal mouseVertical (cast f64 (+ LEFT_WIDTH 24)) 14.0 46.0 22.0)
            (store! (field state view) VIEW_RUNS)
            0)
          0)
        (if (= view VIEW_APPROVALS)
          (let [(mut card) 0]
            (for [project 0
                  8]
              (if (< project (workflow.catalog-count catalog))
                (let [runtime (workflow.catalog-runtime catalog project)]
                  (for [node 0
                        7]
                    (if (and (< node (workflow.node-count runtime))
                             (= (workflow.node-status runtime node) STATUS_WAITING))
                      (let [cardTop (approval-card-top (load card) (view-scroll state VIEW_APPROVALS))]
                        (do
                          (if (in-bounds mouseHorizontal mouseVertical (+ left 18.0) (+ cardTop 78.0) 92.0 26.0)
                            (do
                              (store! (field state selectedProject) project)
                              (store! (field state runtime) runtime)
                              (store! (field state selectedNode) node)
                              (store! (field state approvalRequested) 1)
                              0)
                            0)
                          (if (in-bounds mouseHorizontal mouseVertical (- right 90.0) (+ cardTop 80.0) 90.0 22.0)
                            (open-project-run (mut state) project node)
                            0)
                          (store! card (+ (load card) 1))
                          0))
                      0)))
                0))
            0)
          0)
        0))))

(defn apply-input [(state (mut AppState)) (input InputFrame) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [mouseHorizontal (load (field input mouseHorizontal))
        mouseVertical (load (field input mouseVertical))
        rightStart (- screenWidth RIGHT_WIDTH)
        center (/ (cast f64 (+ LEFT_WIDTH rightStart)) 2.0)
        catalog (load (field state catalog))
        catalogCount (workflow.catalog-count catalog)]
    (do
    (apply-sidebar-input (mut state) input screenHeight)
    (apply-scroll-input (mut state) input screenWidth screenHeight)
    (apply-view-input (mut state) input screenWidth screenHeight)
    (if (= (load (field state view)) VIEW_CREATE)
      (do
        (let [textLeft (cast f64 (+ rightStart 54))
              textTop (cast f64 (- screenHeight 58))
              textWidth (cast f64 (- RIGHT_WIDTH 102))]
          (do
            (if (= (load (field input pressed)) 1)
              (if (in-bounds mouseHorizontal mouseVertical textLeft textTop textWidth 40.0)
                (let [offset (creation-offset-at state mouseHorizontal textLeft textWidth)]
                  (do
                    (store! (field state creationFocused) 1)
                    (store! (field state creationDragging) 1)
                    (store! (field state creationAnchor) offset)
                    (store! (field state creationFocus) offset)
                    0))
                (if (!= (load (field input enterPressed)) 1)
                  (do (store! (field state creationFocused) 0) 0)
                  0))
              0)
            (if (and (= (load (field input down)) 1) (= (load (field state creationDragging)) 1))
              (store! (field state creationFocus) (creation-offset-at state mouseHorizontal textLeft textWidth))
              0)
            (if (= (load (field input down)) 0) (store! (field state creationDragging) 0) 0)
            0))
        (edit-creation-text (mut state) input)
        (if (and (!= (load (field state designState)) 1)
                 (or (and (= (load (field state creationFocused)) 1)
                          (= (load (field input enterPressed)) 1))
                     (and (= (load (field input pressed)) 1)
                          (in-bounds mouseHorizontal
                                     mouseVertical
                                     (cast f64 (- screenWidth 48))
                                     (cast f64 (- screenHeight 41))
                                     28.0
                                     28.0))))
          (if (> (load (field state creationLength)) 0)
            (do
              (store! (field state designRequested) 1)
              (store! (field state designState) 1)
              0)
            0)
          0)
        (if (and (= (load (field input pressed)) 1)
                 (and (> (load (field state designTurn)) 0)
                      (in-bounds mouseHorizontal
                                 mouseVertical
                                 (cast f64 (- rightStart 214))
                                 14.0
                                 184.0
                                 34.0)))
          (do
            (store! (field state creationRequested) 1)
            (store! (field state view) VIEW_DASHBOARD)
            0)
          0)
        0)
      (if (or (= (load (field input pressed)) 0) (!= (load (field state view)) VIEW_RUN))
        0
        (do
          (if (and (= catalogCount 0)
                   (in-bounds mouseHorizontal
                              mouseVertical
                              (- (/ (cast f64 (+ LEFT_WIDTH screenWidth)) 2.0) 116.0)
                              477.0
                              232.0
                              42.0))
            (reset-creation (mut state))
            0)
          (if (> catalogCount 0)
            (let [runtime (load (field state runtime))
                  depths (cast (ptr i64) (cast i64 (alloc-stack (array i64 7))))
                  columns (cast (ptr i64) (cast i64 (alloc-stack (array i64 7))))
                  rowCounts (cast (ptr i64) (cast i64 (alloc-stack (array i64 7))))
                  maxDepth (compute-flow-layout runtime depths columns rowCounts)]
              (for [node 0
                    7]
                (if (and (< node (workflow.node-count runtime))
                         (in-bounds mouseHorizontal
                                    mouseVertical
                                    (- (layout-horizontal (load (index columns node))
                                                          (load (index rowCounts (load (index depths node))))
                                                          center)
                                       20.0)
                                    (- (layout-vertical (load (index depths node)) maxDepth screenHeight) 20.0)
                                    40.0
                                    40.0))
                  (do (store! (field state selectedNode) node) 0)
                  0)))
            0)
          (if (and (> catalogCount 0)
                   (and (= (workflow.node-status (load (field state runtime)) (load (field state selectedNode))) 4)
                        (in-bounds mouseHorizontal
                                   mouseVertical
                                   (cast f64 (+ rightStart 20))
                                   (cast f64 (- screenHeight 174))
                                   112.0
                                   34.0)))
            (do (store! (field state approvalRequested) 1) 0)
            0)
          (if (and (> catalogCount 0)
                   (in-bounds mouseHorizontal mouseVertical (cast f64 (- rightStart 132)) 14.0 116.0 34.0))
            (do (store! (field state runRequested) 1) 0)
            0)
          0))))))

(defn draw-grid [(left i64) (right i64) (height i64)] (-> i64)
  (let [gridHorizontal (alloc-stack i64)
        gridVertical (alloc-stack i64)]
    (do
      (store! gridHorizontal left)
      (store! gridVertical HEADER_HEIGHT)
      (while (< (load gridHorizontal) right)
        (do
          (line (cast f64 (load gridHorizontal))
                (cast f64 HEADER_HEIGHT)
                (cast f64 (load gridHorizontal))
                (cast f64 height)
                1.0
                (color-alpha 14 20 27 150))
          (store! gridHorizontal (+ (load gridHorizontal) 32))))
      (while (< (load gridVertical) height)
        (do
          (line (cast f64 left)
                (cast f64 (load gridVertical))
                (cast f64 right)
                (cast f64 (load gridVertical))
                1.0
                (color-alpha 14 20 27 150))
          (store! gridVertical (+ (load gridVertical) 32))))
      0)))

;; How many runtimes in the catalog currently have a node in the given status.
;; Both counts the sidebar shows are derived from live runtime state, never stored.
(defn runtime-has-status [(runtime (ptr workflow.Runtime)) (status i64)] (-> bool)
  (let [(mut matched) 0]
    (do
      (for [node 0
            7]
        (if (and (< node (workflow.node-count runtime))
                 (= (workflow.node-status runtime node) status))
          (store! matched 1)
          0))
      (= (load matched) 1))))

;; Nodes, not workflows: one waiting node is one thing a human has to act on, and
;; a workflow can hold several.
(defn catalog-waiting-node-count [(catalog (ptr workflow.Catalog))] (-> i64)
  (let [(mut total) 0]
    (do
      (for [project 0
            8]
        (if (< project (workflow.catalog-count catalog))
          (let [runtime (workflow.catalog-runtime catalog project)]
            (for [node 0
                  7]
              (if (and (< node (workflow.node-count runtime))
                       (= (workflow.node-status runtime node) STATUS_WAITING))
                (store! total (+ (load total) 1))
                0)))
          0))
      (load total))))

(defn catalog-status-count [(catalog (ptr workflow.Catalog)) (status i64)] (-> i64)
  (let [(mut total) 0]
    (do
      (for [project 0
            8]
        (if (and (< project (workflow.catalog-count catalog))
                 (runtime-has-status (workflow.catalog-runtime catalog project) status))
          (store! total (+ (load total) 1))
          0))
      (load total))))

(defn draw-icon-dashboard [(left f64) (top f64) (tint raylib.Color)] (-> i64)
  (do
    (stroke-rectangle (+ left 1.0) (+ top 1.0) 5.0 5.0 1.4 tint)
    (stroke-rectangle (+ left 8.0) (+ top 1.0) 5.0 5.0 1.4 tint)
    (stroke-rectangle (+ left 1.0) (+ top 8.0) 5.0 5.0 1.4 tint)
    (stroke-rectangle (+ left 8.0) (+ top 8.0) 5.0 5.0 1.4 tint)
    0))

(defn draw-icon-runs [(left f64) (top f64) (tint raylib.Color)] (-> i64)
  (do
    (for [row 0
          3]
      (let [rowTop (+ top (+ 3.0 (* (cast f64 row) 4.0)))]
        (do
          (fill-rectangle (+ left 0.6) (- rowTop 0.7) 1.4 1.4 tint)
          (line (+ left 4.0) rowTop (+ left 13.0) rowTop 1.4 tint)
          0)))
    0))

(defn draw-icon-approvals [(left f64) (top f64) (tint raylib.Color)] (-> i64)
  (do
    (stroke-rectangle (+ left 1.0) (+ top 1.0) 12.0 12.0 1.4 tint)
    (line (+ left 4.0) (+ top 7.0) (+ left 6.2) (+ top 9.2) 1.4 tint)
    (line (+ left 6.2) (+ top 9.2) (+ left 10.0) (+ top 4.8) 1.4 tint)
    0))

(defn draw-icon-templates [(left f64) (top f64) (tint raylib.Color)] (-> i64)
  (do
    (line (+ left 7.0) (+ top 1.0) (+ left 13.0) (+ top 4.0) 1.4 tint)
    (line (+ left 13.0) (+ top 4.0) (+ left 7.0) (+ top 7.0) 1.4 tint)
    (line (+ left 7.0) (+ top 7.0) (+ left 1.0) (+ top 4.0) 1.4 tint)
    (line (+ left 1.0) (+ top 4.0) (+ left 7.0) (+ top 1.0) 1.4 tint)
    (line (+ left 1.0) (+ top 7.6) (+ left 7.0) (+ top 10.6) 1.4 tint)
    (line (+ left 13.0) (+ top 7.6) (+ left 7.0) (+ top 10.6) 1.4 tint)
    (line (+ left 1.0) (+ top 10.4) (+ left 7.0) (+ top 13.4) 1.4 tint)
    (line (+ left 13.0) (+ top 10.4) (+ left 7.0) (+ top 13.4) 1.4 tint)
    0))

(defn draw-icon-settings [(left f64) (top f64) (tint raylib.Color)] (-> i64)
  (do
    (raylib.DrawCircleLines (cast i32 (+ left 7.0)) (cast i32 (+ top 7.0)) (cast f32 2.6) tint)
    (line (+ left 7.0) (+ top 1.0) (+ left 7.0) (+ top 2.6) 1.4 tint)
    (line (+ left 7.0) (+ top 11.4) (+ left 7.0) (+ top 13.0) 1.4 tint)
    (line (+ left 1.0) (+ top 7.0) (+ left 2.6) (+ top 7.0) 1.4 tint)
    (line (+ left 11.4) (+ top 7.0) (+ left 13.0) (+ top 7.0) 1.4 tint)
    (line (+ left 2.8) (+ top 2.8) (+ left 3.9) (+ top 3.9) 1.4 tint)
    (line (+ left 10.1) (+ top 10.1) (+ left 11.2) (+ top 11.2) 1.4 tint)
    (line (+ left 11.2) (+ top 2.8) (+ left 10.1) (+ top 3.9) 1.4 tint)
    (line (+ left 3.9) (+ top 10.1) (+ left 2.8) (+ top 11.2) 1.4 tint)
    0))

(defn nav-row-top [(slot i64)] (-> f64)
  (cast f64 (+ SIDEBAR_NAV_TOP (* slot SIDEBAR_NAV_ROW_HEIGHT))))

(defn project-row-top [(project i64)] (-> f64)
  (cast f64 (+ SIDEBAR_PROJECTS_TOP (* project SIDEBAR_PROJECT_ROW_HEIGHT))))

;; A nav row draws itself from its slot; `active` is true when `view` routes here.
;; The trailing badge is optional — pass a null label to omit it.
(defn draw-nav-row [(state AppState)
                    (slot i64)
                    (label (ptr i8))
                    (active bool)
                    (badge (ptr i8))
                    (badgeBoxed bool)] (-> i64)
  (let [selected (load (field state selectedProject))
        top (nav-row-top slot)
        foreground (if active (color 238 242 246) (color 107 116 128))
        iconTint (if active (color 238 242 246) (color 107 116 128))
        iconTop (+ top 9.0)]
    (do
      (if active (fill-rectangle 8.0 top 220.0 32.0 (accent-alpha selected 36)) 0)
      (case slot 0
            (draw-icon-dashboard 19.0 iconTop iconTint) 1
            (draw-icon-runs 19.0 iconTop iconTint) 2
            (draw-icon-approvals 19.0 iconTop iconTint) 3
            (draw-icon-templates 19.0 iconTop iconTint)
            (draw-icon-settings 19.0 iconTop iconTint))
      (draw-text (field state monoMedium) label 44.0 (+ top 9.0) 12.0 foreground)
      (if (= (cast i64 badge) 0)
        0
        (if badgeBoxed
          (let [width (+ (text-width (field state monoMedium) badge 9.0) 10.0)]
            (do
              (fill-rectangle (- 220.0 width) (+ top 10.0) width 13.0 (color 74 58 26))
              (draw-text (field state monoMedium) badge (- 220.0 (- width 5.0)) (+ top 11.0) 9.0 (color 224 165 58))
              0))
          (draw-text-right (field state monoMedium) badge 220.0 (+ top 11.0) 9.0 (accent selected))))
      0)))

(defn draw-sidebar [(state AppState) (height i64)] (-> i64)
  (let [view (load (field state view))
        selected (load (field state selectedProject))
        catalog (load (field state catalog))
        runningBuffer (cast (ptr i8) (cast i64 (alloc-stack (array i8 16))))
        approvalBuffer (cast (ptr i8) (cast i64 (alloc-stack (array i8 16))))
        runningCount (catalog-status-count catalog STATUS_RUNNING)
        approvalCount (catalog-waiting-node-count catalog)
        footerTop (cast f64 (- height SIDEBAR_FOOTER_HEIGHT))]
    (do
      (fill-rectangle 0.0 0.0 (cast f64 LEFT_WIDTH) (cast f64 height) (color 9 12 17))
      (line (cast f64 (- LEFT_WIDTH 1)) 0.0 (cast f64 (- LEFT_WIDTH 1)) (cast f64 height) 1.0 (color 23 30 39))

      ;; Header
      (line 0.0 (cast f64 SIDEBAR_HEADER_HEIGHT) (cast f64 LEFT_WIDTH) (cast f64 SIDEBAR_HEADER_HEIGHT) 1.0 (color 20 26 34))
      (stroke-rectangle 18.0 17.0 15.0 15.0 1.0 (accent selected))
      (fill-rectangle 23.0 22.0 5.0 5.0 (accent selected))
      (draw-text (field state monoMedium) c"flowline" 43.0 16.0 13.0 (color 223 229 236))
      (draw-text-right (field state monoMedium) c"v0.4" 218.0 19.0 9.0 (color 69 78 90))

      ;; Workspace navigation
      (draw-text (field state monoMedium) c"WORKSPACE" 16.0 64.0 9.0 (color 61 69 79))
      (snprintf runningBuffer 16 c"%lld" runningCount)
      (snprintf approvalBuffer 16 c"%lld" approvalCount)
      (draw-nav-row state 0 c"Dashboard" (= view VIEW_DASHBOARD) (cast (ptr i8) 0) false)
      (draw-nav-row state
                    1
                    c"Runs"
                    (or (= view VIEW_RUNS) (= view VIEW_RUN))
                    (if (> runningCount 0) runningBuffer (cast (ptr i8) 0))
                    false)
      (draw-nav-row state
                    2
                    c"Approvals"
                    (= view VIEW_APPROVALS)
                    (if (> approvalCount 0) approvalBuffer (cast (ptr i8) 0))
                    true)
      (draw-nav-row state 3 c"Templates" (= view VIEW_TEMPLATES) (cast (ptr i8) 0) false)
      (draw-nav-row state 4 c"Settings" (= view VIEW_SETTINGS) (cast (ptr i8) 0) false)

      ;; Projects
      (draw-text (field state monoMedium) c"PROJECTS" 16.0 (cast f64 SIDEBAR_PROJECTS_LABEL_TOP) 9.0 (color 61 69 79))
      (let [newTop (cast f64 (- SIDEBAR_PROJECTS_LABEL_TOP 4))]
        (do
          (stroke-rectangle 176.0 newTop 44.0 18.0 1.0 (accent-alpha selected 102))
          (if (= view VIEW_CREATE)
            (fill-rectangle 176.0 newTop 44.0 18.0 (accent-alpha selected 51))
            0)
          (draw-text (field state monoMedium) c"+ new" 182.0 (+ newTop 3.0) 11.0 (accent selected))
          0))
      (for [project 0
            8]
        (if (< project (workflow.catalog-count catalog))
          (let [rowTop (project-row-top project)
                active (and (= project selected) (or (= view VIEW_DASHBOARD) (= view VIEW_RUN)))]
            (do
              (if active
                (do
                  (fill-rectangle 8.0 rowTop 220.0 45.0 (accent-alpha project 33))
                  (fill-rectangle 8.0 (+ rowTop 8.0) 2.0 29.0 (accent project))
                  0)
                0)
              (if active
                (fill-rectangle 21.0 (+ rowTop 18.0) 8.0 8.0 (accent project))
                (stroke-rectangle 21.0 (+ rowTop 18.0) 8.0 8.0 1.0 (accent project)))
              (begin-scissor 40.0 rowTop 168.0 45.0)
              (draw-text (field state monoMedium)
                         (display-project-name state project)
                         40.0
                         (+ rowTop 9.0)
                         12.0
                         (if active (color 238 242 246) (color 107 116 128)))
              (draw-text (field state mono)
                         (display-project-subtitle state project)
                         40.0
                         (+ rowTop 26.0)
                         9.5
                         (color 76 85 97))
              (raylib.EndScissorMode)
              (if (runtime-has-status (workflow.catalog-runtime catalog project) STATUS_RUNNING)
                (do
                  (raylib.DrawCircle (cast i32 216) (cast i32 (+ rowTop 22.0)) (cast f32 3.0) (accent project))
                  0)
                (do
                  (raylib.DrawCircleLines (cast i32 216) (cast i32 (+ rowTop 22.0)) (cast f32 3.0) (color 42 51 63))
                  0))
              0))
          0))

      ;; Footer — the workspace this catalog was loaded from.
      (line 0.0 footerTop (cast f64 LEFT_WIDTH) footerTop 1.0 (color 20 26 34))
      (stroke-rectangle 16.0 (+ footerTop 11.0) 18.0 18.0 1.0 (color 42 51 63))
      (draw-text (field state mono) c"f" 22.0 (+ footerTop 14.0) 10.0 (color 107 116 128))
      (draw-text (field state mono) c"workflows / catalog" 42.0 (+ footerTop 15.0) 9.5 (color 61 69 79))
      0)))

(defn draw-edge [(fromHorizontal f64)
                 (fromVertical f64)
                 (toHorizontal f64)
                 (toVertical f64)
                 (active bool)
                 (tint raylib.Color)] (-> i64)
  (let [middleVertical (/ (+ fromVertical toVertical) 2.0)
        edgeColor (if active (load tint) (color-alpha 87 97 113 125))
        thickness (if active 1.8 1.2)]
    (do
      (if (fcmp-eq fromHorizontal toHorizontal)
        (line fromHorizontal fromVertical toHorizontal toVertical thickness edgeColor)
        (do
          (line fromHorizontal fromVertical fromHorizontal middleVertical thickness edgeColor)
          (line fromHorizontal middleVertical toHorizontal middleVertical thickness edgeColor)
          (line toHorizontal middleVertical toHorizontal toVertical thickness edgeColor)
          0))
      (if active
        (let [travel (fmod (* (raylib.GetTime) 72.0) 34.0)]
          (fill-rectangle (- toHorizontal 2.5) (- toVertical travel) 5.0 5.0 tint))
        0)
      0)))

(defn draw-node-symbol [(horizontal f64) (vertical f64) (node i64) (status i64) (pulse f64) (tint raylib.Color)] (-> i64)
  (cond (= status 2)
          (do
            (stroke-rectangle (- horizontal (+ 12.0 (* pulse 5.0)))
                              (- vertical (+ 12.0 (* pulse 5.0)))
                              (* 2.0 (+ 12.0 (* pulse 5.0)))
                              (* 2.0 (+ 12.0 (* pulse 5.0)))
                              1.0
                              (color-alpha 224 165 58 (cast i64 (+ 55.0 (* pulse 55.0)))))
            (fill-rectangle (- horizontal 7.5) (- vertical 7.5) 15.0 15.0 tint)
            0)
        (= status 3) (fill-rectangle (- horizontal 7.0) (- vertical 7.0) 14.0 14.0 (color-alpha 224 165 58 155))
        (= status 4) (stroke-rectangle (- horizontal 7.0) (- vertical 7.0) 14.0 14.0 1.5 tint)
        (= status 5) (stroke-rectangle (- horizontal 7.0) (- vertical 7.0) 14.0 14.0 1.5 (color 211 91 85))
        (= node 1)
          (do
            (for [square 0
                  3]
              (fill-rectangle (+ (- horizontal 12.0) (cast f64 (* square 10)))
                              (- vertical 2.5)
                              5.0
                              5.0
                              (color-alpha 224 165 58 110)))
            0)
        (stroke-rectangle (- horizontal 6.5) (- vertical 6.5) 13.0 13.0 1.5 (color 61 69 79))))

(defn draw-flow [(state AppState)
                 (runtime workflow.Runtime)
                 (selected i64)
                 (rightStart i64)
                 (screenHeight i64)
                 (tint raylib.Color)] (-> i64)
  (let [center (/ (cast f64 (+ LEFT_WIDTH rightStart)) 2.0)
        time (raylib.GetTime)
        pulse (+ 1.0 (* 0.5 (sin (* time 4.0))))
        depths (cast (ptr i64) (cast i64 (alloc-stack (array i64 7))))
        columns (cast (ptr i64) (cast i64 (alloc-stack (array i64 7))))
        rowCounts (cast (ptr i64) (cast i64 (alloc-stack (array i64 7))))
        maxDepth (compute-flow-layout runtime depths columns rowCounts)]
    (do
      (for [node 0
            7]
        (if (< node (workflow.node-count runtime))
          (do
            (for [dependencySlot 0
                  2]
              (let [dependency (workflow.node-dependency runtime node dependencySlot)]
                (if (>= dependency 0)
                  (draw-edge (layout-horizontal (load (index columns dependency))
                                                (load (index rowCounts (load (index depths dependency))))
                                                center)
                             (+ (layout-vertical (load (index depths dependency)) maxDepth screenHeight) 20.0)
                             (layout-horizontal (load (index columns node))
                                                (load (index rowCounts (load (index depths node))))
                                                center)
                             (- (layout-vertical (load (index depths node)) maxDepth screenHeight) 20.0)
                             (or (= (workflow.node-status runtime node) 2)
                                 (= (workflow.node-status runtime node) 4))
                             tint)
                  0)))
            0)
          0))
      (if (= (load (index rowCounts 0)) 1)
        (line center 68.0 center (- (layout-vertical 0 maxDepth screenHeight) 20.0) 1.0 (color-alpha 224 165 58 80))
        0)
      (if (= (load (index rowCounts maxDepth)) 1)
        (let [bottom (layout-vertical maxDepth maxDepth screenHeight)]
          (line center (+ bottom 20.0) center (+ bottom 53.0) 1.0 (color-alpha 224 165 58 80)))
        0)
      (for [node 0
            7]
        (if (< node (workflow.node-count runtime))
          (let [horizontal
                  (layout-horizontal (load (index columns node))
                                     (load (index rowCounts (load (index depths node))))
                                     center)
                vertical (layout-vertical (load (index depths node)) maxDepth screenHeight)
                chosen (= node selected)
                numberLabel (case node 0 c"[1]" 1 c"[2]" 2 c"[3]" 3 c"[4]" 4 c"[5]" 5 c"[6]" c"[7]")]
            (do
              (if chosen (stroke-rectangle (- horizontal 16.0) (- vertical 16.0) 32.0 32.0 1.0 tint) 0)
              (draw-node-symbol horizontal vertical node (workflow.node-status runtime node) pulse tint)
              ;; Titles are full sentences and the column is narrow, so every label
              ;; sits to the right of its node and is clipped at the column edge.
              ;; A left-hand label would have almost no room to grow into.
              (line (+ horizontal 10.0) vertical (+ horizontal 34.0) vertical 1.0 (color-alpha 224 165 58 100))
              (draw-text (field state monoMedium)
                         numberLabel
                         (+ horizontal 42.0)
                         (- vertical 6.0)
                         10.0
                         (if chosen (load tint) (color 127 136 148)))
              ;; A label stops before its next sibling on the same row, so parallel
              ;; branches never write over each other.
              (let [rowCount (load (index rowCounts (load (index depths node))))
                    nextColumn (+ (load (index columns node)) 1)
                    labelEnd (if (< nextColumn rowCount)
                               (- (layout-horizontal nextColumn rowCount center) 26.0)
                               (cast f64 (- rightStart 10)))]
                (do
                  (begin-scissor (+ horizontal 70.0)
                                 (- vertical 12.0)
                                 (- labelEnd (+ horizontal 70.0))
                                 24.0)
                  (draw-text (field state mono)
                             (workflow.node-title runtime node)
                             (+ horizontal 70.0)
                             (- vertical 6.0)
                             10.5
                             (if chosen (load tint) (color 88 97 113)))
                  (raylib.EndScissorMode)
                  0))
              0))
          0))
      0)))

(defn draw-center [(state AppState) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [rightStart (- screenWidth RIGHT_WIDTH)
        centerWidth (- rightStart LEFT_WIDTH)
        project (load (field state selectedProject))
        tint (accent project)]
    (do
      (fill-rectangle (cast f64 LEFT_WIDTH) 0.0 (cast f64 centerWidth) (cast f64 screenHeight) (color 7 10 14))
      (draw-grid LEFT_WIDTH rightStart screenHeight)
      (fill-rectangle (cast f64 LEFT_WIDTH) 0.0 (cast f64 centerWidth) (cast f64 HEADER_HEIGHT) (color 7 10 14))
      (line (cast f64 LEFT_WIDTH) 63.0 (cast f64 rightStart) 63.0 1.0 (color 20 26 34))
      (let [runtime (load (field state runtime))
            nodeCount (workflow.node-count runtime)
            statusBuffer (cast (ptr i8) (cast i64 (alloc-stack (array i8 64))))
            badgeLeft (cast f64 (- rightStart 232))
            (mut doneCount) 0
            (mut anyFailed) 0]
        (do
          (for [node 0
                7]
            (if (< node nodeCount)
              (do
                (if (= (workflow.node-status runtime node) 3) (store! doneCount (+ (load doneCount) 1)) 0)
                (if (= (workflow.node-status runtime node) 5) (store! anyFailed 1) 0)
                0)
              0))
          (snprintf statusBuffer
                    64
                    c"%lld/%lld / %s"
                    (load doneCount)
                    nodeCount
                    (if (workflow.is-started runtime)
                      (workflow.run-status-label (workflow.runtime-run-status runtime))
                      c"idle"))
          ;; Breadcrumb back to the runs list, then the program and its progress.
          ;; The badge follows the measured title, but never crosses into the run
          ;; button's space on the right.
          (let [left (cast f64 (+ LEFT_WIDTH 24))
                titleLeft (+ left 62.0)
                titleWidth (text-width (field state monoMedium) (display-project-name state project) 15.0)
                limit (cast f64 (- rightStart 240))
                badgeAt (if (> (+ titleLeft (+ titleWidth 12.0)) limit) limit (+ titleLeft (+ titleWidth 12.0)))]
            (do
              (draw-text (field state mono) c"< runs" left 18.0 11.0 (color 76 85 97))
              (draw-text (field state mono) c"/" (+ left 48.0) 18.0 11.0 (color 42 51 63))
              (begin-scissor titleLeft 10.0 (- badgeAt (+ titleLeft 10.0)) 28.0)
              (draw-text (field state monoMedium)
                         (display-project-name state project)
                         titleLeft
                         14.0
                         15.0
                         (color 223 229 236))
              (raylib.EndScissorMode)
              (stroke-rectangle badgeAt 13.0 88.0 20.0 1.0 (color-alpha 224 165 58 100))
              (draw-text (field state monoMedium) statusBuffer (+ badgeAt 7.0) 18.0 9.0 tint)
              0))
          0))
      (let [left (cast f64 (+ LEFT_WIDTH 24))]
        (do
          (draw-text (field state mono) c"~/" left 39.0 10.5 (color 76 85 97))
          (begin-scissor (+ left 21.0) 34.0 (cast f64 (- (- rightStart 236) LEFT_WIDTH)) 20.0)
          (draw-text (field state mono) (display-project-path state project) (+ left 21.0) 39.0 10.5 (color 76 85 97))
          (raylib.EndScissorMode)
          0))
      (stroke-rectangle (cast f64 (- rightStart 132)) 14.0 116.0 34.0 1.0 (color-alpha 224 165 58 130))
      (draw-text (field state monoMedium)
                 (if (workflow.is-started (load (field state runtime))) c"RUN AGAIN" c"RUN WORKFLOW")
                 (cast f64 (- rightStart 117))
                 24.0
                 9.5
                 tint)
      ;; LIVE claims the run is moving right now, so it only appears when a node
      ;; is genuinely running.
      (if (runtime-has-status (load (field state runtime)) STATUS_RUNNING)
        (do
          (fill-rectangle (cast f64 (- rightStart 208)) 23.0 7.0 7.0 tint)
          (draw-text (field state monoMedium) c"LIVE" (cast f64 (- rightStart 190)) 21.0 10.0 tint)
          0)
        0)
      ;; draw-flow clips each node label individually, so no enclosing scissor is
      ;; used here — raylib's scissor does not nest, and an inner EndScissorMode
      ;; would silently drop an outer one.
      (draw-flow state
                 (load (field state runtime))
                 (load (field state selectedNode))
                 rightStart
                 screenHeight
                 tint)
      0)))

(defn draw-card-background [(left f64) (top f64) (width f64) (height f64) (leftAccent bool) (tint raylib.Color)] (-> i64)
  (do
    (fill-rectangle left top width height (color 13 18 25))
    (stroke-rectangle left top width height 1.0 (color 27 35 46))
    (if leftAccent (fill-rectangle left top 2.0 height tint) 0)
    0))

(defn draw-approval [(state (mut AppState))
                     (input InputFrame)
                     (left f64)
                     (width f64)
                     (height i64)
                     (node i64)
                     (tint raylib.Color)] (-> i64)
  (let [approved (load (field state approvalGranted))
        runtime (load (field state runtime))
        upstream (workflow.node-dependency runtime node 0)
        cardY (cast f64 (- height 244))]
    (do
      (draw-card-background left 148.0 width 82.0 true tint)
      (fill-rectangle (+ left 13.0) 161.0 6.0 6.0 tint)
      (draw-text (field state monoMedium) c"UPSTREAM OUTPUT" (+ left 27.0) 157.0 9.0 (color 127 136 148))
      (begin-scissor (+ left 13.0) 176.0 (- width 26.0) 48.0)
      (selectable-text (mut state)
                       input
                       3
                       (field state sans)
                       (if (< upstream 0)
                         c"This gate has no upstream step - it is waiting on you directly."
                         (workflow.node-output runtime upstream))
                       (+ left 13.0)
                       182.0
                       12.5
                       (color 200 207 216))
      (raylib.EndScissorMode)
      (fill-rectangle left cardY width 122.0 (color 20 16 10))
      (stroke-rectangle left cardY width 122.0 1.0 (color 74 58 26))
      (stroke-rectangle (+ left 13.0) (+ cardY 14.0) 9.0 9.0 1.5 tint)
      (draw-text (field state monoMedium)
                 (if (= approved 1) c"APPROVAL RECORDED" c"HUMAN APPROVAL REQUIRED")
                 (+ left 31.0)
                 (+ cardY 11.0)
                 9.0
                 tint)
      (begin-scissor (+ left 13.0) (+ cardY 34.0) (- width 26.0) 44.0)
      (selectable-text (mut state)
                       input
                       4
                       (field state sans)
                       (if (= approved 1)
                         c"Approved. The dependent steps are free to continue."
                         (workflow.node-title runtime node))
                       (+ left 13.0)
                       (+ cardY 40.0)
                       12.5
                       (color 185 172 147))
      (raylib.EndScissorMode)
      (fill-rectangle left (cast f64 (- height 174)) 112.0 34.0 (if (= approved 1) (color 58 82 67) (load tint)))
      (draw-text (field state monoMedium)
                 (if (= approved 1) c"APPROVED" c"APPROVE  >")
                 (+ left 15.0)
                 (cast f64 (- height 164))
                 10.5
                 (color 10 14 19))
      0)))

(defn draw-generic-feed [(state (mut AppState)) (input InputFrame) (left f64) (width f64) (project i64) (node i64) (tint raylib.Color)] (-> i64)
  (let [runtime (load (field state runtime))
        status (workflow.node-status runtime node)
        output (workflow.node-output runtime node)]
    (do
      ;; The instruction this step actually carries, straight off the parsed
      ;; program - an approval node has none, so it says so rather than
      ;; inventing narration.
      (draw-card-background left 148.0 width 84.0 true tint)
      (fill-rectangle (+ left 13.0) 161.0 6.0 6.0 tint)
      (draw-text (field state monoMedium) c"PROMPT" (+ left 27.0) 157.0 9.0 (color 127 136 148))
      (begin-scissor (+ left 13.0) 176.0 (- width 26.0) 50.0)
      (selectable-text (mut state)
                       input
                       1
                       (field state sans)
                       (let [prompt (workflow.node-prompt runtime node)]
                         (if (icmp-eq (load prompt) (cast i8 0))
                           c"This step carries no prompt."
                           prompt))
                       (+ left 13.0)
                       182.0
                       12.5
                       (color 200 207 216))
      (raylib.EndScissorMode)
      (line (+ left 3.0) 258.0 (+ left 3.0) 326.0 1.0 (color 35 44 56))
      (draw-text (field state monoMedium) c"// STATE" (+ left 15.0) 258.0 9.0 (color 76 85 97))
      (draw-text (field state mono) (display-project-name state project) (+ left 15.0) 281.0 11.0 tint)
      (draw-text (field state mono)
                 (display-node-title state project node)
                 (+ left 15.0)
                 303.0
                 11.0
                 (color 127 136 148))
      (draw-card-background left 349.0 width 73.0 false tint)
      (draw-text (field state monoMedium) c"> workflow.inspect" (+ left 13.0) 362.0 11.0 (color 207 214 222))
      (if (= status 2)
        (let [statusBuffer (cast (ptr i8) (cast i64 (alloc-stack (array i8 48))))
              time (raylib.GetTime)
              elapsed
                (let [raw (cast i64 (- time (workflow.node-started-at runtime node)))]
                  (if (or (< raw 0) (> raw 359999)) 0 raw))]
          (do
            (snprintf statusBuffer 48 c"agent working - %llds" elapsed)
            (draw-text (field state mono) statusBuffer (+ left 13.0) 393.0 10.5 (color 167 176 187))
            (for [dot 0
                  3]
              (let [wave (sin (- (* time 6.0) (* (cast f64 dot) 1.1)))
                    alpha (cast i64 (+ 90.0 (* 65.0 (+ 1.0 wave))))]
                (fill-rectangle (+ left (+ (- width 58.0) (* (cast f64 dot) 14.0)))
                                397.0
                                5.0
                                5.0
                                (color-alpha (cast i64 (load (field tint r)))
                                             (cast i64 (load (field tint g)))
                                             (cast i64 (load (field tint b)))
                                             alpha))))
            0))
        (draw-text (field state mono)
                   (workflow.status-label status)
                   (+ left 13.0)
                   393.0
                   10.5
                   (color 167 176 187)))
      (if (icmp-ne (load output) (cast i8 0))
        (do
          (if (or (!= (load (field state wrappedOutput)) output)
                  (!= (load (field state wrappedOutputLength)) (byte-text-length output)))
            (do
              (wrap-text-in-place state output (field state sans) 11.0 432.0)
              (store! (field state wrappedOutput) output)
              (store! (field state wrappedOutputLength) (byte-text-length output))
              0)
            0)
          (draw-text (field state monoMedium) c"// AGENT OUTPUT" left 453.0 9.0 (color 76 85 97))
          (selectable-text (mut state) input 2 (field state sans) output left 478.0 11.0 (color 184 193 204))
          0)
        0)
      0)))

(defn draw-right [(state (mut AppState)) (input InputFrame) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [rightStart (- screenWidth RIGHT_WIDTH)
        contentLeft (cast f64 (+ rightStart 20))
        width (cast f64 (- RIGHT_WIDTH 40))
        project (load (field state selectedProject))
        node (load (field state selectedNode))
        tint (accent project)]
    (do
      (fill-rectangle (cast f64 rightStart) 0.0 (cast f64 RIGHT_WIDTH) (cast f64 screenHeight) (color 9 12 17))
      (line (cast f64 rightStart) 0.0 (cast f64 rightStart) (cast f64 screenHeight) 1.0 (color 23 30 39))
      (line (cast f64 rightStart) 112.0 (cast f64 screenWidth) 112.0 1.0 (color 20 26 34))
      (begin-scissor contentLeft 11.0 126.0 18.0)
      (draw-text (field state mono) (display-project-path state project) contentLeft 15.0 9.5 (color 61 69 79))
      (raylib.EndScissorMode)
      (draw-text (field state mono) c"/" (+ contentLeft 132.0) 15.0 9.5 tint)
      (begin-scissor (+ contentLeft 146.0) 11.0 (- (cast f64 screenWidth) (+ contentLeft 166.0)) 18.0)
      (draw-text (field state mono)
                 (display-node-title state project node)
                 (+ contentLeft 146.0)
                 15.0
                 9.5
                 (color 107 116 128))
      (raylib.EndScissorMode)
      (draw-text (field state monoMedium)
                 (case node 0 c"[1]" 1 c"[2]" 2 c"[3]" 3 c"[4]" 4 c"[5]" 5 c"[6]" c"[7]")
                 contentLeft
                 50.0
                 15.0
                 tint)
      (begin-scissor (+ contentLeft 38.0) 44.0 (- (cast f64 (- screenWidth 129)) (+ contentLeft 38.0)) 28.0)
      (draw-text (field state monoMedium)
                 (display-node-title state project node)
                 (+ contentLeft 38.0)
                 50.0
                 15.0
                 (color 223 229 236))
      (raylib.EndScissorMode)
      (stroke-rectangle (cast f64 (- screenWidth 117))
                        45.0
                        97.0
                        23.0
                        1.0
                        (if (= node 4) (color-alpha 224 165 58 120) (color 38 49 61)))
      (draw-text (field state monoMedium)
                 (workflow.status-label (workflow.node-status (load (field state runtime)) node))
                 (cast f64 (- screenWidth 104))
                 51.0
                 9.5
                 (if (>= node 4) (load tint) (color 111 154 126)))
      (if (= (workflow.node-kind (load (field state runtime)) node) 1)
        (draw-approval (mut state) input contentLeft width screenHeight node tint)
        (draw-generic-feed (mut state) input contentLeft width project node tint))
      (fill-rectangle (cast f64 rightStart) (cast f64 (- screenHeight 49)) (cast f64 RIGHT_WIDTH) 49.0 (color 9 12 17))
      (line (cast f64 rightStart)
            (cast f64 (- screenHeight 49))
            (cast f64 screenWidth)
            (cast f64 (- screenHeight 49))
            1.0
            (color 20 26 34))
      (draw-text (field state monoMedium) c">" (cast f64 (+ rightStart 16)) (cast f64 (- screenHeight 31)) 12.0 tint)
      (draw-text (field state mono)
                 c"add a note to this step"
                 (cast f64 (+ rightStart 38))
                 (cast f64 (- screenHeight 31))
                 12.0
                 (color 69 78 90))
      (fill-rectangle (cast f64 (- screenWidth 29)) (cast f64 (- screenHeight 33)) 8.0 15.0 tint)
      0)))

(defn capture-input [(input (mut InputFrame))] (-> i64)
  (let [mouse (raylib.GetMousePosition)
        wheel (cast f64 (raylib.GetMouseWheelMove))
        (mut typedCount) 0
        (mut typedCharacter) (cast i64 (raylib.GetCharPressed))
        shiftDown
          (if (or (icmp-ne (raylib.IsKeyDown (cast i32 KEY_LEFT_SHIFT)) (cast u8 0))
                  (icmp-ne (raylib.IsKeyDown (cast i32 KEY_RIGHT_SHIFT)) (cast u8 0)))
            1
            0)
        controlDown
          (if (or (icmp-ne (raylib.IsKeyDown (cast i32 KEY_LEFT_CONTROL)) (cast u8 0))
                  (icmp-ne (raylib.IsKeyDown (cast i32 KEY_RIGHT_CONTROL)) (cast u8 0)))
            1
            0)
        altDown
          (if (or (icmp-ne (raylib.IsKeyDown (cast i32 KEY_LEFT_ALT)) (cast u8 0))
                  (icmp-ne (raylib.IsKeyDown (cast i32 KEY_RIGHT_ALT)) (cast u8 0)))
            1
            0)
        superDown
          (if (or (icmp-ne (raylib.IsKeyDown (cast i32 KEY_LEFT_SUPER)) (cast u8 0))
                  (icmp-ne (raylib.IsKeyDown (cast i32 KEY_RIGHT_SUPER)) (cast u8 0)))
            1
            0)]
    (do
      (store! (field input mouseHorizontal) (/ (cast f64 (load (field mouse x))) (ui-scale)))
      (store! (field input mouseVertical) (/ (cast f64 (load (field mouse y))) (ui-scale)))
      (store! (field input wheel) wheel)
      (store! (field input pressed)
              (if (icmp-ne (raylib.IsMouseButtonPressed (cast i32 0)) (cast u8 0)) 1 0))
      (store! (field input down) (if (icmp-ne (raylib.IsMouseButtonDown (cast i32 0)) (cast u8 0)) 1 0))
      (while (and (> (load typedCharacter) 0) (< (load typedCount) INPUT_CHARACTER_CAPACITY))
        (do
          (store! (index (field input typedCharacters) (load typedCount)) (load typedCharacter))
          (store! typedCount (+ (load typedCount) 1))
          (store! typedCharacter (cast i64 (raylib.GetCharPressed)))))
      (store! (field input typedCount) (load typedCount))
      (store! (field input backspacePressed)
              (if (or (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_BACKSPACE)) (cast u8 0))
                      (icmp-ne (raylib.IsKeyPressedRepeat (cast i32 KEY_BACKSPACE)) (cast u8 0)))
                1
                0))
      (store! (field input deletePressed)
              (if (or (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_DELETE)) (cast u8 0))
                      (icmp-ne (raylib.IsKeyPressedRepeat (cast i32 KEY_DELETE)) (cast u8 0)))
                1
                0))
      (store! (field input leftPressed)
              (if (or (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_LEFT)) (cast u8 0))
                      (icmp-ne (raylib.IsKeyPressedRepeat (cast i32 KEY_LEFT)) (cast u8 0)))
                1
                0))
      (store! (field input rightPressed)
              (if (or (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_RIGHT)) (cast u8 0))
                      (icmp-ne (raylib.IsKeyPressedRepeat (cast i32 KEY_RIGHT)) (cast u8 0)))
                1
                0))
      (store! (field input homePressed)
              (if (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_HOME)) (cast u8 0)) 1 0))
      (store! (field input endPressed)
              (if (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_END)) (cast u8 0)) 1 0))
      (store! (field input enterPressed)
              (if (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_ENTER)) (cast u8 0)) 1 0))
      (store! (field input shiftDown) shiftDown)
      (store! (field input commandDown) (if (or (= superDown 1) (= controlDown 1)) 1 0))
      (store! (field input wordDown) (if (or (= altDown 1) (= controlDown 1)) 1 0))
      (store! (field input selectAllPressed)
              (if (and (or (= superDown 1) (= controlDown 1))
                       (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_A)) (cast u8 0)))
                1
                0))
      (store! (field input copyPressed)
              (if (and (or (= superDown 1) (= controlDown 1))
                       (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_C)) (cast u8 0)))
                1
                0))
      (store! (field input cutPressed)
              (if (and (or (= superDown 1) (= controlDown 1))
                       (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_X)) (cast u8 0)))
                1
                0))
      (store! (field input pastePressed)
              (if (and (or (= superDown 1) (= controlDown 1))
                       (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_V)) (cast u8 0)))
                1
                0))
      (store! (field input pasteText)
              (if (= (load (field input pastePressed)) 1)
                (raylib.GetClipboardText)
                (cast (ptr i8) 0)))
      0)))

(defn draw-creation-editor [(state AppState) (left f64) (top f64) (width f64) (tint raylib.Color)] (-> i64)
  (let [text (load (field state creationText))
        length (load (field state creationLength))
        focused (= (load (field state creationFocused)) 1)
        sending (= (load (field state designState)) 1)
        textLeft (+ left 34.0)
        textWidth (- width 62.0)
        scroll (creation-text-scroll state textWidth)
        origin (- textLeft scroll)
        start (selection-start state)
        end (selection-end state)
        startWidth (text-width-through (field state sans) text start 11.5)
        endWidth (text-width-through (field state sans) text end 11.5)
        caretWidth (text-width-through (field state sans) text (load (field state creationFocus)) 11.5)
        border
          (cond (= (load (field state creationTruncated)) 1) (color 211 91 85)
                focused (load tint)
                (color 35 44 56))
        sendColor (if (or sending (= length 0)) (color 35 44 56) (load tint))]
    (do
      (fill-rectangle left top width 40.0 (if focused (color 11 16 23) (color 7 10 14)))
      (stroke-rectangle left top width 40.0 (if focused 1.5 1.0) border)
      (draw-text (field state monoMedium)
                 c">"
                 (+ left 12.0)
                 (+ top 11.0)
                 12.0
                 (if focused (load tint) (color 76 85 97)))
      (begin-scissor textLeft (+ top 4.0) textWidth 32.0)
      (if (< start end)
        (fill-rectangle (+ origin startWidth) (+ top 8.0) (- endWidth startWidth) 23.0 (color-alpha 74 121 178 110))
        0)
      (draw-text (field state sans)
                 (if (= length 0) c"Describe the outcome or ask a question..." text)
                 origin
                 (+ top 11.0)
                 11.5
                 (if (= length 0) (color 69 78 90) (if sending (color 107 116 128) (color 220 226 233))))
      (if (and focused
               (and (= start end) (< (fmod (raylib.GetTime) 1.0) 0.55)))
        (fill-rectangle (+ origin caretWidth) (+ top 8.0) 1.5 23.0 tint)
        0)
      (raylib.EndScissorMode)
      (fill-rectangle (+ left (- width 28.0)) (+ top 12.0) 28.0 28.0 sendColor)
      ;; The font atlas only rasterizes ASCII, so the busy glyph must be ASCII.
      (draw-text (field state monoMedium)
                 (if sending c"." c">")
                 (+ left (- width 19.0))
                 (+ top 18.0)
                 12.0
                 (if (or sending (= length 0)) (color 76 85 97) (color 10 14 19)))
      0)))

(defn draw-typing-bubble [(left f64) (top f64) (tint raylib.Color)] (-> i64)
  (let [time (raylib.GetTime)]
    (do
      (draw-card-background left top 84.0 40.0 true tint)
      (for [dot 0
            3]
        (let [wave (sin (- (* time 6.0) (* (cast f64 dot) 1.1)))
              alpha (cast i64 (+ 90.0 (* 65.0 (+ 1.0 wave))))]
          (fill-rectangle (+ left (+ 16.0 (* (cast f64 dot) 20.0)))
                          (+ top 17.0)
                          6.0
                          6.0
                          (color-alpha (cast i64 (load (field tint r)))
                                       (cast i64 (load (field tint g)))
                                       (cast i64 (load (field tint b)))
                                       alpha))))
      0)))

(defn draw-design-workspace [(state (mut AppState)) (input InputFrame) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [rightStart (- screenWidth RIGHT_WIDTH)
        center (/ (cast f64 (+ LEFT_WIDTH rightStart)) 2.0)
        contentLeft (cast f64 (+ rightStart 20))
        tint (accent 0)]
    (do
      (fill-rectangle (cast f64 LEFT_WIDTH)
                      0.0
                      (cast f64 (- rightStart LEFT_WIDTH))
                      (cast f64 screenHeight)
                      (color 7 10 14))
      (draw-grid LEFT_WIDTH rightStart screenHeight)
      (fill-rectangle (cast f64 LEFT_WIDTH) 0.0 (cast f64 (- rightStart LEFT_WIDTH)) 64.0 (color 7 10 14))
      (line (cast f64 LEFT_WIDTH) 63.0 (cast f64 rightStart) 63.0 1.0 (color 20 26 34))
      (begin-scissor 268.0 10.0 (cast f64 (- rightStart 494)) 28.0)
      (draw-text (field state monoMedium)
                 (if (= (load (field state designPreviewValid)) 1)
                   (workflow.program-name (load (field state designPreview)))
                   c"UNTITLED WORKFLOW")
                 268.0
                 14.0
                 15.0
                 (color 223 229 236))
      (raylib.EndScissorMode)
      (draw-text (field state mono) c"DRAFT / NOT SAVED" 268.0 39.0 9.5 (color 76 85 97))
      (if (> (load (field state designTurn)) 0)
        (do
          (stroke-rectangle (cast f64 (- rightStart 214)) 14.0 184.0 34.0 1.0 tint)
          (draw-text (field state monoMedium) c"BUILD THIS WORKFLOW  >" (cast f64 (- rightStart 198)) 24.0 9.5 tint)
          0)
        0)
      (if (= (load (field state designPreviewValid)) 1)
        (draw-flow state (load (field state designPreview)) -1 rightStart screenHeight tint)
        (do
          (stroke-rectangle (- center 28.0) 214.0 56.0 56.0 1.5 (color 42 51 63))
          (fill-rectangle (- center 4.0) 238.0 8.0 8.0 tint)
          (draw-text (field state monoMedium)
                     c"YOUR WORKFLOW WILL TAKE SHAPE HERE"
                     (- center 208.0)
                     310.0
                     16.0
                     (color 207 214 222))
          (draw-text (field state sans)
                     c"Talk through the outcome, constraints, and unknowns. The designer can\ninspect this repository and recommend useful steps as you iterate."
                     (- center 255.0)
                     351.0
                     13.0
                     (color 127 136 148))
          (draw-text (field state mono) c"NO NODES YET" (- center 53.0) 421.0 10.0 (color 61 69 79))
          0))
      (fill-rectangle (cast f64 rightStart) 0.0 (cast f64 RIGHT_WIDTH) (cast f64 screenHeight) (color 9 12 17))
      (line (cast f64 rightStart) 0.0 (cast f64 rightStart) (cast f64 screenHeight) 1.0 (color 23 30 39))
      (line (cast f64 rightStart) 78.0 (cast f64 screenWidth) 78.0 1.0 (color 20 26 34))
      (draw-text (field state monoMedium) c"WORKFLOW DESIGNER" contentLeft 18.0 14.0 (color 223 229 236))
      (fill-rectangle contentLeft
                      49.0
                      6.0
                      6.0
                      (cond (= (load (field state designState)) 1) (load tint)
                            (= (load (field state designState)) 3) (color 211 91 85)
                            (color 104 207 167)))
      (draw-text (field state mono)
                 (cond (= (load (field state designState)) 1) c"INSPECTING REPOSITORY..."
                       (= (load (field state designState)) 3) c"DESIGNER FAILED - SEE .flowline/design.events"
                       c"READY TO DISCOVER")
                 (+ contentLeft 16.0)
                 43.0
                 9.0
                 (if (= (load (field state designState)) 3) (color 211 91 85) (color 76 85 97)))
      (draw-card-background contentLeft 104.0 (cast f64 (- RIGHT_WIDTH 40)) 116.0 true tint)
      (draw-text (field state monoMedium) c"DESIGNER" (+ contentLeft 14.0) 118.0 9.0 tint)
      (selectable-text (mut state)
                       input
                       5
                       (field state sans)
                       c"What are you hoping this workflow will accomplish?\nYou can start with a rough idea. I'll inspect the project,\nidentify what matters, and suggest concrete next steps."
                       (+ contentLeft 14.0)
                       145.0
                       12.0
                       (color 190 198 208))
      (let [requestText (load (field state designRequest))
            haveRequest
              (if (and (!= (cast i64 requestText) 0) (icmp-ne (load requestText) (cast i8 0))) 1 0)
            requestLines
              (if (= haveRequest 1)
                (let [lines (count-text-lines requestText (byte-text-length requestText))]
                  (if (> lines 6) 6 lines))
                0)
            requestCardHeight (+ 42.0 (* (cast f64 requestLines) (text-line-advance 11.5)))
            responseTop (if (= haveRequest 1) (+ 260.0 requestCardHeight) 244.0)
            responseBottom (cast f64 (- screenHeight 100))]
        (do
          (if (= haveRequest 1)
            (do
              (draw-card-background contentLeft 244.0 (cast f64 (- RIGHT_WIDTH 40)) requestCardHeight false tint)
              (draw-text (field state monoMedium) c"YOU" (+ contentLeft 14.0) 256.0 9.0 tint)
              (begin-scissor (+ contentLeft 14.0) 270.0 (cast f64 (- RIGHT_WIDTH 68)) (- requestCardHeight 32.0))
              (selectable-text (mut state)
                               input
                               7
                               (field state sans)
                               requestText
                               (+ contentLeft 14.0)
                               274.0
                               11.5
                               (color 220 226 233))
              (raylib.EndScissorMode)
              0)
            0)
          (if (= (load (field state designState)) 1)
            (draw-typing-bubble contentLeft responseTop tint)
            (if (> (load (field state designTurn)) 0)
              (do
                (draw-card-background contentLeft
                                      responseTop
                                      (cast f64 (- RIGHT_WIDTH 40))
                                      (- responseBottom responseTop)
                                      true
                                      tint)
                (draw-text (field state monoMedium)
                           c"DESIGNER / RECOMMENDATION"
                           (+ contentLeft 14.0)
                           (+ responseTop 14.0)
                           9.0
                           tint)
                (begin-scissor (+ contentLeft 14.0)
                               (+ responseTop 42.0)
                               (cast f64 (- RIGHT_WIDTH 68))
                               (- responseBottom (+ responseTop 56.0)))
                (selectable-text (mut state)
                                 input
                                 6
                                 (field state sans)
                                 (load (field state designResponse))
                                 (+ contentLeft 14.0)
                                 (+ responseTop 42.0)
                                 11.5
                                 (color 190 198 208))
                (raylib.EndScissorMode)
                0)
              0))
          0))
      (fill-rectangle (cast f64 rightStart) (cast f64 (- screenHeight 76)) (cast f64 RIGHT_WIDTH) 76.0 (color 9 12 17))
      (line (cast f64 rightStart)
            (cast f64 (- screenHeight 76))
            (cast f64 screenWidth)
            (cast f64 (- screenHeight 76))
            1.0
            (color 20 26 34))
      (draw-creation-editor state contentLeft (cast f64 (- screenHeight 58)) (cast f64 (- RIGHT_WIDTH 40)) tint)
      0)))

(defn draw-empty-workspace [(state AppState) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [left (cast f64 LEFT_WIDTH)
        width (cast f64 (- screenWidth LEFT_WIDTH))
        center (/ (cast f64 (+ LEFT_WIDTH screenWidth)) 2.0)
        tint (accent 0)]
    (do
      (fill-rectangle left 0.0 width (cast f64 screenHeight) (color 7 10 14))
      (draw-grid LEFT_WIDTH screenWidth screenHeight)
      (fill-rectangle left 0.0 width (cast f64 HEADER_HEIGHT) (color 7 10 14))
      (line left 63.0 (cast f64 screenWidth) 63.0 1.0 (color 20 26 34))
      (draw-text (field state monoMedium) c"WORKFLOW CATALOG" (+ left 24.0) 18.0 14.0 (color 223 229 236))
      (stroke-rectangle (- center 31.0) 178.0 62.0 62.0 1.5 tint)
      (line (- center 13.0) 209.0 (+ center 13.0) 209.0 2.0 tint)
      (line center 196.0 center 222.0 2.0 tint)
      (draw-text (field state monoMedium) c"CREATE YOUR FIRST WORKFLOW" (- center 174.0) 281.0 19.0 (color 230 235 241))
      (draw-text (field state sans)
                 c"Describe an outcome for this project. A creator agent will inspect the\nrepository, design an executable DAG, and add it to this catalog."
                 (- center 274.0)
                 330.0
                 14.0
                 (color 142 153 166))
      (draw-text (field state mono) c"1  CLICK + NEW WORKFLOW" (- center 168.0) 406.0 11.0 tint)
      (draw-text (field state mono) c"2  DESCRIBE THE OUTCOME" (- center 168.0) 433.0 11.0 (color 107 116 128))
      (draw-text (field state mono) c"3  PRESS ENTER TO CREATE" (- center 168.0) 460.0 11.0 (color 107 116 128))
      (fill-rectangle (- center 116.0) 477.0 232.0 42.0 tint)
      (draw-text (field state monoMedium) c"+  NEW WORKFLOW" (- center 78.0) 490.0 12.0 (color 10 14 19))
      (draw-text (field state mono)
                 c"No templates or demo workflows are loaded."
                 (- center 156.0)
                 550.0
                 10.0
                 (color 61 69 79))
      0)))

(defn draw-creation-banner [(state AppState) (screenWidth i64)] (-> i64)
  (let [failed (= (load (field state creationState)) 3)
        center (/ (cast f64 (+ LEFT_WIDTH screenWidth)) 2.0)
        width 420.0
        left (- center (/ width 2.0))
        pulse (+ 0.5 (* 0.5 (sin (* (raylib.GetTime) 5.0))))
        tint (if failed (color 211 91 85) (color 224 165 58))]
    (do
      (fill-rectangle left 76.0 width 38.0 (if failed (color 26 12 12) (color 20 16 10)))
      (stroke-rectangle left 76.0 width 38.0 1.0 tint)
      (fill-rectangle (+ left 14.0)
                      90.0
                      8.0
                      8.0
                      (color-alpha (if failed 211 224)
                                   (if failed 91 165)
                                   (if failed 85 58)
                                   (+ 80 (cast i64 (* 175.0 pulse)))))
      (draw-text (field state monoMedium)
                 (if failed
                   c"WORKFLOW CREATION FAILED - SEE .flowline/create.events"
                   c"CREATING WORKFLOW - THE CREATOR AGENT IS WORKING...")
                 (+ left 32.0)
                 88.0
                 9.5
                 tint)
      0)))

(const VIEW_HEADER_HEIGHT 72)
(const VIEW_PADDING 26)

(defn format-duration [(seconds i64) (buffer (ptr i8))] (-> (ptr i8))
  (do
    (snprintf buffer 32 c"%lldm %02llds" (/ seconds 60) (% seconds 60))
    buffer))

;; Wall-clock age rendered the way the runs table reads it: coarse, and never
;; more precise than the underlying second-granularity timestamp.
(defn format-relative [(seconds i64) (buffer (ptr i8))] (-> (ptr i8))
  (do
    (cond (< seconds 45) (snprintf buffer 32 c"just now")
          (< seconds 5400) (snprintf buffer 32 c"%lldm ago" (/ seconds 60))
          (< seconds 86400) (snprintf buffer 32 c"%lldh ago" (/ seconds 3600))
          (snprintf buffer 32 c"%lldd ago" (/ seconds 86400)))
    buffer))

(defn run-status-color [(status i64) (tint raylib.Color)] (-> raylib.Color)
  (cond (= status RUN_RUNNING) tint
        (= status RUN_DONE) (color 111 154 126)
        (= status RUN_WAITING) (color 224 165 58)
        (color 201 106 90)))

(defn draw-card [(left f64) (top f64) (width f64) (height f64)] (-> i64)
  (do
    (fill-rectangle left top width height (color 11 15 21))
    (stroke-rectangle left top width height 1.0 (color 23 30 39))
    0))

(defn draw-label [(state AppState) (text (ptr i8)) (left f64) (top f64) (tint raylib.Color)] (-> i64)
  (draw-text (field state monoMedium) text left top 9.0 tint))

;; A status pill: a small filled square in the status colour followed by its label.
(defn draw-status-chip [(state AppState)
                        (status i64)
                        (left f64)
                        (top f64)
                        (tint raylib.Color)] (-> i64)
  (let [statusTint (run-status-color status tint)]
    (do
      (fill-rectangle left (+ top 3.0) 6.0 6.0 statusTint)
      (draw-text (field state monoMedium) (workflow.run-status-label status) (+ left 12.0) top 9.5 statusTint)
      0)))

;; Counts over the whole run log, used by both the dashboard tiles and the runs
;; header. `projectPath` narrows to one workflow; a null pointer counts everything.
(defn run-log-tally [(state AppState) (projectPath (ptr i8)) (status i64)] (-> i64)
  (let [log (load (field state runLog))
        (mut total) 0]
    (do
      (for [entry 0
            64]
        (if (< entry (workflow.run-log-count log))
          (let [record (workflow.run-log-record log entry)]
            (if (and (or (= (cast i64 projectPath) 0)
                         (workflow.strings-equal (workflow.record-path record) projectPath))
                     (or (< status 0) (= (load (field record status)) status)))
              (store! total (+ (load total) 1))
              0))
          0))
      (load total))))

;; How many nodes of each shape a program has. These drive the template cards and
;; are read straight off the parsed program, never stored alongside it.
(defn program-approval-count [(runtime (ptr workflow.Runtime))] (-> i64)
  (let [(mut total) 0]
    (do
      (for [node 0
            7]
        (if (and (< node (workflow.node-count runtime))
                 (= (workflow.node-kind runtime node) KIND_APPROVAL))
          (store! total (+ (load total) 1))
          0))
      (load total))))

;; A join is a node that waits on two dependencies, so it is also the point where
;; one fanned-out branch reconverges.
(defn program-join-count [(runtime (ptr workflow.Runtime))] (-> i64)
  (let [(mut total) 0]
    (do
      (for [node 0
            7]
        (if (and (< node (workflow.node-count runtime))
                 (>= (workflow.node-dependency runtime node 1) 0))
          (store! total (+ (load total) 1))
          0))
      (load total))))

;; Every workspace view shares one header: title over a dimmer subtitle, with a rule
;; underneath. Returns the y the body content starts at.
(defn draw-view-header [(state AppState)
                        (screenWidth i64)
                        (title (ptr i8))
                        (subtitle (ptr i8))] (-> f64)
  (let [left (cast f64 (+ LEFT_WIDTH VIEW_PADDING))]
    (do
      (draw-text (field state monoMedium) title left 16.0 16.0 (color 223 229 236))
      (draw-text (field state mono) subtitle left 42.0 10.5 (color 76 85 97))
      (line (cast f64 LEFT_WIDTH)
            (cast f64 VIEW_HEADER_HEIGHT)
            (cast f64 screenWidth)
            (cast f64 VIEW_HEADER_HEIGHT)
            1.0
            (color 20 26 34))
      (cast f64 VIEW_HEADER_HEIGHT))))

(defn draw-stat-tile [(state AppState)
                      (left f64)
                      (top f64)
                      (width f64)
                      (label (ptr i8))
                      (value (ptr i8))
                      (sub (ptr i8))
                      (valueTint raylib.Color)] (-> i64)
  (do
    (draw-card left top width 88.0)
    (draw-label state label (+ left 16.0) (+ top 15.0) (color 76 85 97))
    (draw-text (field state monoMedium) value (+ left 16.0) (+ top 32.0) 26.0 valueTint)
    (draw-text (field state mono) sub (+ left 16.0) (+ top 67.0) 9.5 (color 76 85 97))
    0))

(defn draw-dashboard-view [(state AppState) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [project (load (field state selectedProject))
        runtime (workflow.catalog-runtime (load (field state catalog)) project)
        left (cast f64 (+ LEFT_WIDTH VIEW_PADDING))
        contentWidth (- (cast f64 screenWidth) (cast f64 (+ LEFT_WIDTH (* VIEW_PADDING 2))))
        tint (accent project)
        projectPath (display-project-path state project)
        scratch (cast (ptr i8) (cast i64 (alloc-stack (array i8 64))))
        second (cast (ptr i8) (cast i64 (alloc-stack (array i8 64))))
        doneTotal (run-log-tally state projectPath RUN_DONE)
        failedTotal (run-log-tally state projectPath RUN_FAILED)
        projectTotal (run-log-tally state projectPath -1)]
    (do
      ;; Header
      (fill-rectangle left 20.0 10.0 10.0 tint)
      (draw-text (field state monoMedium)
                 (display-project-name state project)
                 (+ left 21.0)
                 16.0
                 16.0
                 (color 223 229 236))
      (let [badgeLeft (+ (+ left 33.0) (text-width (field state monoMedium) (display-project-name state project) 16.0))
            label (if (runtime-has-status runtime STATUS_RUNNING)
                    c"running"
                    (if (runtime-has-status runtime STATUS_WAITING) c"waiting" c"idle"))]
        (do
          (stroke-rectangle badgeLeft 19.0 (+ (text-width (field state monoMedium) label 9.5) 14.0) 17.0 1.0 (accent-alpha project 102))
          (draw-text (field state monoMedium) label (+ badgeLeft 7.0) 22.0 9.5 tint)
          0))
      (draw-text (field state mono) c"~/" left 42.0 10.5 (color 76 85 97))
      (draw-text (field state mono) projectPath (+ left 21.0) 42.0 10.5 (color 76 85 97))
      (let [buttonWidth 128.0
            buttonLeft (- (+ (cast f64 LEFT_WIDTH) (+ contentWidth (cast f64 VIEW_PADDING))) buttonWidth)]
        (do
          (fill-rectangle buttonLeft 22.0 buttonWidth 30.0 (accent-alpha project 31))
          (stroke-rectangle buttonLeft 22.0 buttonWidth 30.0 1.0 (accent-alpha project 115))
          (draw-text (field state monoMedium) c"+ new workflow" (+ buttonLeft 15.0) 31.0 11.0 tint)
          0))
      (line (cast f64 LEFT_WIDTH)
            (cast f64 VIEW_HEADER_HEIGHT)
            (cast f64 screenWidth)
            (cast f64 VIEW_HEADER_HEIGHT)
            1.0
            (color 20 26 34))

      ;; Stat tiles, all four counted off the run log and the live runtime.
      (let [tileWidth (/ (- contentWidth 36.0) 4.0)
            tileTop (cast f64 (+ VIEW_HEADER_HEIGHT 22))]
        (do
          (snprintf scratch 64 c"%lld" (run-log-tally state projectPath RUN_RUNNING))
          (draw-stat-tile state left tileTop tileWidth c"ACTIVE RUNS" scratch c"in progress now" tint)
          (snprintf second 64 c"%lld" (run-log-tally state projectPath RUN_WAITING))
          (draw-stat-tile state
                          (+ left (+ tileWidth 12.0))
                          tileTop
                          tileWidth
                          c"AWAITING APPROVAL"
                          second
                          c"paused on humans"
                          (color 224 165 58))
          (let [completed (cast (ptr i8) (cast i64 (alloc-stack (array i8 32))))
                rate (cast (ptr i8) (cast i64 (alloc-stack (array i8 32))))]
            (do
              (snprintf completed 32 c"%lld" doneTotal)
              (draw-stat-tile state
                              (+ left (* (+ tileWidth 12.0) 2.0))
                              tileTop
                              tileWidth
                              c"COMPLETED"
                              completed
                              c"finished runs"
                              (color 223 229 236))
              (if (> (+ doneTotal failedTotal) 0)
                (snprintf rate 32 c"%lld%%" (/ (* doneTotal 100) (+ doneTotal failedTotal)))
                (snprintf rate 32 c"--"))
              (draw-stat-tile state
                              (+ left (* (+ tileWidth 12.0) 3.0))
                              tileTop
                              tileWidth
                              c"SUCCESS RATE"
                              rate
                              c"across recorded runs"
                              (color 111 154 126))
              0))
          0))

      ;; Recent runs for this workflow, and the workflow's own shape.
      (let [panelTop (cast f64 (+ VIEW_HEADER_HEIGHT 132))
            sideWidth 320.0
            listWidth (- contentWidth (+ sideWidth 22.0))
            sideLeft (+ left (+ listWidth 22.0))]
        (do
          (draw-label state c"RECENT RUNS" left panelTop (color 107 116 128))
          (draw-text-right (field state mono) c"view all >" (+ left listWidth) panelTop 10.0 tint)
          (if (= projectTotal 0)
            (do
              (draw-card left (+ panelTop 19.0) listWidth 56.0)
              (draw-text (field state mono)
                         c"no runs recorded yet - start one from the run view"
                         (+ left 14.0)
                         (+ panelTop 39.0)
                         10.5
                         (color 76 85 97))
              0)
            (let [log (load (field state runLog))
                  (mut drawn) 0]
              (do
                (draw-card left (+ panelTop 19.0) listWidth (cast f64 (* (if (> projectTotal 5) 5 projectTotal) 38)))
                (for [step 0
                      64]
                  (let [entry (- (- (workflow.run-log-count log) 1) step)]
                    (if (and (>= entry 0) (< (load drawn) 5))
                      (let [record (workflow.run-log-record log entry)]
                        (if (workflow.strings-equal (workflow.record-path record) projectPath)
                          (let [rowTop (+ (+ panelTop 19.0) (cast f64 (* (load drawn) 38)))]
                            (do
                              (if (> (load drawn) 0)
                                (line left rowTop (+ left listWidth) rowTop 1.0 (color 19 25 34))
                                0)
                              (draw-text (field state monoMedium)
                                         (workflow.record-id record)
                                         (+ left 14.0)
                                         (+ rowTop 13.0)
                                         11.0
                                         (color 199 205 214))
                              (begin-scissor (+ left 106.0) rowTop (- listWidth 300.0) 38.0)
                              (draw-text (field state mono)
                                         (workflow.record-name record)
                                         (+ left 106.0)
                                         (+ rowTop 13.0)
                                         11.0
                                         (color 107 116 128))
                              (raylib.EndScissorMode)
                              (draw-status-chip state
                                                (load (field record status))
                                                (- (+ left listWidth) 168.0)
                                                (+ rowTop 14.0)
                                                tint)
                              (draw-text-right (field state mono)
                                               (format-duration (load (field record duration)) scratch)
                                               (- (+ left listWidth) 14.0)
                                               (+ rowTop 14.0)
                                               10.0
                                               (color 76 85 97))
                              (store! drawn (+ (load drawn) 1))
                              0))
                          0))
                      0)))
                0)))

          (draw-label state c"WORKFLOW" sideLeft panelTop (color 107 116 128))
          (draw-card sideLeft (+ panelTop 19.0) sideWidth 92.0)
          (begin-scissor (+ sideLeft 14.0) (+ panelTop 19.0) (- sideWidth 100.0) 92.0)
          (draw-text (field state monoMedium)
                     (workflow.program-name runtime)
                     (+ sideLeft 14.0)
                     (+ panelTop 31.0)
                     12.0
                     (color 207 214 222))
          (raylib.EndScissorMode)
          (snprintf scratch 64 c"%lld steps" (workflow.node-count runtime))
          (draw-text-right (field state mono) scratch (- (+ sideLeft sideWidth) 14.0) (+ panelTop 33.0) 9.0 (color 76 85 97))
          (draw-text (field state mono) c"runner" (+ sideLeft 14.0) (+ panelTop 54.0) 9.5 (color 76 85 97))
          (draw-text (field state mono)
                     (workflow.program-runner runtime)
                     (+ sideLeft 62.0)
                     (+ panelTop 54.0)
                     9.5
                     tint)
          (snprintf second
                    64
                    c"%lld runs / %lld approval steps"
                    projectTotal
                    (program-approval-count runtime))
          (draw-text (field state mono) second (+ sideLeft 14.0) (+ panelTop 74.0) 9.5 (color 76 85 97))
          0))
      0)))

;; Filter slots 0-3 map onto "everything" plus the three run statuses worth
;; singling out. Slot 0 is the only one that does not correspond to a status.
(defn run-filter-status [(slot i64)] (-> i64)
  (case slot 0
        -1 1
        RUN_RUNNING 2
        RUN_WAITING RUN_DONE))

(defn run-filter-label [(slot i64)] (-> (ptr i8))
  (case slot 0
        c"all" 1
        c"running" 2
        c"waiting" c"done"))

(defn run-filter-left [(slot i64) (screenWidth i64)] (-> f64)
  (- (cast f64 (- screenWidth VIEW_PADDING)) (- 268.0 (cast f64 (* slot 68)))))

(defn draw-runs-view [(state AppState) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [left (cast f64 (+ LEFT_WIDTH VIEW_PADDING))
        right (cast f64 (- screenWidth VIEW_PADDING))
        tint (accent (load (field state selectedProject)))
        log (load (field state runLog))
        filter (load (field state runFilter))
        wanted (run-filter-status filter)
        scratch (cast (ptr i8) (cast i64 (alloc-stack (array i8 64))))
        subtitle (cast (ptr i8) (cast i64 (alloc-stack (array i8 96))))
        now (workflow.now-seconds)]
    (do
      (snprintf subtitle 96 c"every recorded execution / %lld total" (workflow.run-log-count log))
      (draw-view-header state screenWidth c"Runs" subtitle)
      (for [slot 0
            4]
        (let [buttonLeft (run-filter-left slot screenWidth)
              active (= slot filter)]
          (do
            (if active (fill-rectangle buttonLeft 24.0 62.0 26.0 (accent-alpha (load (field state selectedProject)) 36)) 0)
            (stroke-rectangle buttonLeft 24.0 62.0 26.0 1.0 (if active (accent-alpha (load (field state selectedProject)) 128) (color 27 35 46)))
            (draw-text (field state monoMedium)
                       (run-filter-label slot)
                       (+ buttonLeft 11.0)
                       32.0
                       10.0
                       (if active tint (color 107 116 128)))
            0)))

      ;; Column rule
      (let [top (cast f64 (+ VIEW_HEADER_HEIGHT 1))]
        (do
          (draw-label state c"RUN" left (+ top 11.0) (color 61 69 79))
          (draw-label state c"WORKFLOW" (+ left 96.0) (+ top 11.0) (color 61 69 79))
          (draw-label state c"PROGRAM" (+ left 300.0) (+ top 11.0) (color 61 69 79))
          (draw-label state c"TRIGGER" (- right 300.0) (+ top 11.0) (color 61 69 79))
          (draw-label state c"STATUS" (- right 210.0) (+ top 11.0) (color 61 69 79))
          (draw-label state c"STARTED" (- right 130.0) (+ top 11.0) (color 61 69 79))
          (draw-text-right (field state monoMedium) c"DURATION" right (+ top 11.0) 9.0 (color 61 69 79))
          (line (cast f64 LEFT_WIDTH) (+ top 33.0) (cast f64 screenWidth) (+ top 33.0) 1.0 (color 23 30 39))
          0))

      (if (= (workflow.run-log-count log) 0)
        (draw-text (field state mono)
                   c"no runs recorded yet - every run you start from a workflow lands here"
                   left
                   (cast f64 (+ VIEW_HEADER_HEIGHT 60))
                   11.0
                   (color 76 85 97))
        (let [(mut drawn) 0]
          (do
            (for [step 0
                  64]
              (let [entry (- (- (workflow.run-log-count log) 1) step)]
                (if (>= entry 0)
                  (let [record (workflow.run-log-record log entry)
                        status (load (field record status))]
                    (if (or (< wanted 0) (= status wanted))
                      (let [rowTop (runs-row-top (load drawn) (view-scroll state VIEW_RUNS))]
                        (if (not (row-visible rowTop 40.0 screenHeight))
                          (store! drawn (+ (load drawn) 1))
                        (do
                          (line (cast f64 LEFT_WIDTH)
                                (+ rowTop 40.0)
                                (cast f64 screenWidth)
                                (+ rowTop 40.0)
                                1.0
                                (color 19 25 34))
                          (draw-text (field state monoMedium)
                                     (workflow.record-id record)
                                     left
                                     (+ rowTop 14.0)
                                     11.0
                                     (color 199 205 214))
                          (begin-scissor (+ left 96.0) rowTop 196.0 40.0)
                          (draw-text (field state mono)
                                     (workflow.record-name record)
                                     (+ left 96.0)
                                     (+ rowTop 14.0)
                                     11.0
                                     (color 207 214 222))
                          (raylib.EndScissorMode)
                          (begin-scissor (+ left 300.0) rowTop (- (- right 300.0) (+ left 312.0)) 40.0)
                          (draw-text (field state mono)
                                     (workflow.record-path record)
                                     (+ left 300.0)
                                     (+ rowTop 14.0)
                                     10.0
                                     (color 92 102 114))
                          (raylib.EndScissorMode)
                          (draw-text (field state mono)
                                     (workflow.record-trigger record)
                                     (- right 300.0)
                                     (+ rowTop 14.0)
                                     10.0
                                     (color 92 102 114))
                          (draw-status-chip state status (- right 210.0) (+ rowTop 15.0) tint)
                          (draw-text (field state mono)
                                     (format-relative (- now (load (field record startedAt))) scratch)
                                     (- right 130.0)
                                     (+ rowTop 15.0)
                                     10.0
                                     (color 76 85 97))
                          (draw-text-right (field state mono)
                                           (format-duration (load (field record duration)) scratch)
                                           right
                                           (+ rowTop 15.0)
                                           10.0
                                           (color 76 85 97))
                          (store! drawn (+ (load drawn) 1))
                          0)))
                      0))
                  0)))
            (if (= (load drawn) 0)
              (draw-text (field state mono)
                         c"no runs match this filter"
                         left
                         (cast f64 (+ VIEW_HEADER_HEIGHT 60))
                         11.0
                         (color 76 85 97))
              0)
            0)))
      0)))

;; One card per node actually sitting in STATUS_WAITING. The list is derived from
;; the live runtimes every frame — there is no separate approvals store to drift.
(defn draw-approvals-view [(state AppState) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [left (cast f64 (+ LEFT_WIDTH VIEW_PADDING))
        right (cast f64 (- screenWidth VIEW_PADDING))
        catalog (load (field state catalog))
        subtitle (cast (ptr i8) (cast i64 (alloc-stack (array i8 96))))
        pending (catalog-waiting-node-count catalog)
        (mut drawn) 0]
    (do
      (snprintf subtitle 96 c"%lld step(s) paused, waiting on a human" pending)
      (draw-view-header state screenWidth c"Approvals" subtitle)
      (for [project 0
            8]
        (if (< project (workflow.catalog-count catalog))
          (let [runtime (workflow.catalog-runtime catalog project)
                tint (accent project)]
            (for [node 0
                  7]
              (if (and (< node (workflow.node-count runtime))
                       (= (workflow.node-status runtime node) STATUS_WAITING))
                (let [cardTop (approval-card-top (load drawn) (view-scroll state VIEW_APPROVALS))
                      width (- right left)]
                  (if (not (row-visible cardTop 112.0 screenHeight))
                    (store! drawn (+ (load drawn) 1))
                  (do
                    (draw-card left cardTop width 112.0)
                    (fill-rectangle left cardTop 2.0 112.0 tint)
                    (fill-rectangle (+ left 18.0) (+ cardTop 18.0) 8.0 8.0 tint)
                    (draw-text (field state monoMedium)
                               (workflow.program-name runtime)
                               (+ left 34.0)
                               (+ cardTop 14.0)
                               12.0
                               (color 223 229 236))
                    (draw-text (field state mono)
                               (workflow.program-path runtime)
                               (+ left 34.0)
                               (+ cardTop 34.0)
                               10.0
                               (color 76 85 97))
                    (draw-text-right (field state mono) c"awaiting approval" (- right 18.0) (+ cardTop 16.0) 10.0 (color 224 165 58))
                    (draw-text (field state sans)
                               (workflow.node-title runtime node)
                               (+ left 18.0)
                               (+ cardTop 54.0)
                               12.5
                               (color 185 192 202))
                    (fill-rectangle (+ left 18.0) (+ cardTop 78.0) 92.0 26.0 tint)
                    (draw-text (field state monoMedium) c"APPROVE" (+ left 34.0) (+ cardTop 85.0) 10.5 (color 10 14 19))
                    (stroke-rectangle (+ left 118.0) (+ cardTop 78.0) 142.0 26.0 1.0 (color 42 51 63))
                    (draw-text (field state monoMedium) c"REQUEST CHANGES" (+ left 130.0) (+ cardTop 85.0) 10.5 (color 136 146 160))
                    (draw-text-right (field state mono) c"open run >" (- right 18.0) (+ cardTop 86.0) 10.0 (color 92 102 114))
                    (store! drawn (+ (load drawn) 1))
                    0)))
                0)))
          0))
      (if (= (load drawn) 0)
        (draw-text (field state mono)
                   c"nothing is waiting on you - approval steps appear here when a run reaches one"
                   left
                   (cast f64 (+ VIEW_HEADER_HEIGHT 30))
                   11.0
                   (color 76 85 97))
        0)
      0)))

;; A step pip, shaded by what the step actually is: approvals read as an outline
;; because they are the steps that stop and wait, agents as filled.
(defn draw-step-pip [(left f64) (top f64) (kind i64) (tint raylib.Color)] (-> i64)
  (if (= kind KIND_APPROVAL)
    (stroke-rectangle left top 9.0 9.0 1.0 (color 224 165 58))
    (do
      (fill-rectangle left top 9.0 9.0 (accent-blend tint 150))
      (stroke-rectangle left top 9.0 9.0 1.0 tint)
      0)))

;; Every card is one real .flow program in the catalog. Step, join and approval
;; counts are read off the parsed program each frame.
(defn draw-template-card [(state AppState)
                          (project i64)
                          (left f64)
                          (top f64)
                          (width f64)] (-> i64)
  (let [runtime (workflow.catalog-runtime (load (field state catalog)) project)
        tint (accent project)
        steps (workflow.node-count runtime)
        scratch (cast (ptr i8) (cast i64 (alloc-stack (array i8 96))))]
    (do
      (draw-card left top width 176.0)
      (let [runner (workflow.program-runner runtime)
            chipWidth (+ (text-width (field state monoMedium) runner 9.0) 14.0)]
        (do
          (stroke-rectangle (+ left 16.0) (+ top 16.0) chipWidth 16.0 1.0 (accent-alpha project 89))
          (draw-text (field state monoMedium) runner (+ left 23.0) (+ top 19.0) 9.0 tint)
          0))
      (snprintf scratch 96 c"%lld runs" (run-log-tally state (workflow.program-path runtime) -1))
      (draw-text-right (field state mono) scratch (- (+ left width) 16.0) (+ top 19.0) 9.0 (color 76 85 97))
      (begin-scissor (+ left 16.0) (+ top 40.0) (- width 32.0) 24.0)
      (draw-text (field state monoMedium)
                 (workflow.program-name runtime)
                 (+ left 16.0)
                 (+ top 44.0)
                 14.0
                 (color 223 229 236))
      (raylib.EndScissorMode)
      (begin-scissor (+ left 16.0) (+ top 66.0) (- width 32.0) 20.0)
      (draw-text (field state mono)
                 (workflow.program-path runtime)
                 (+ left 16.0)
                 (+ top 68.0)
                 11.0
                 (color 107 116 128))
      (raylib.EndScissorMode)

      ;; The program's shape, one pip per step with a rule between them.
      (for [node 0
            7]
        (if (< node steps)
          (let [pipLeft (+ (+ left 16.0) (cast f64 (* node 22)))]
            (do
              (draw-step-pip pipLeft (+ top 96.0) (workflow.node-kind runtime node) tint)
              (if (< node (- steps 1))
                (line (+ pipLeft 11.0) (+ top 100.5) (+ pipLeft 20.0) (+ top 100.5) 1.0 (color 42 51 63))
                0)
              0))
          0))
      (snprintf scratch
                96
                c"%lld steps    %lld joins    %lld approvals"
                steps
                (program-join-count runtime)
                (program-approval-count runtime))
      (draw-text (field state mono) scratch (+ left 16.0) (+ top 120.0) 9.5 (color 76 85 97))
      (fill-rectangle (+ left 16.0) (+ top 140.0) 96.0 24.0 (accent-alpha project 31))
      (stroke-rectangle (+ left 16.0) (+ top 140.0) 96.0 24.0 1.0 (accent-alpha project 115))
      (draw-text (field state monoMedium) c"open run" (+ left 30.0) (+ top 146.0) 10.5 tint)
      (stroke-rectangle (+ left 120.0) (+ top 140.0) 88.0 24.0 1.0 (color 42 51 63))
      (draw-text (field state monoMedium) c"view DSL" (+ left 133.0) (+ top 146.0) 10.5 (color 107 116 128))
      0)))

(defn draw-templates-view [(state AppState) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [catalog (load (field state catalog))
        left (cast f64 (+ LEFT_WIDTH VIEW_PADDING))
        contentWidth (- (cast f64 screenWidth) (cast f64 (+ LEFT_WIDTH (* VIEW_PADDING 2))))
        columns 3
        cardWidth (/ (- contentWidth (cast f64 (* (- columns 1) 14))) (cast f64 columns))]
    (do
      (draw-view-header state
                        screenWidth
                        c"Template library"
                        c"every workflow program in the catalog, with the shape it compiles to")
      (for [project 0
            8]
        (if (< project (workflow.catalog-count catalog))
          (let [cardTop (- (+ (cast f64 (+ VIEW_HEADER_HEIGHT 22)) (cast f64 (* (/ project columns) 190)))
                           (view-scroll state VIEW_TEMPLATES))]
            (if (row-visible cardTop 176.0 screenHeight)
              (draw-template-card state
                                  project
                                  (+ left (* (cast f64 (% project columns)) (+ cardWidth 14.0)))
                                  cardTop
                                  cardWidth)
              0))
          0))
      (if (= (workflow.catalog-count catalog) 0)
        (draw-text (field state mono)
                   c"no workflow programs found in workflows/"
                   left
                   (cast f64 (+ VIEW_HEADER_HEIGHT 30))
                   11.0
                   (color 76 85 97))
        0)
      0)))

(defn draw-settings-view [(state AppState) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [left (cast f64 (+ LEFT_WIDTH VIEW_PADDING))
        project (load (field state selectedProject))
        rowWidth 780.0]
    (do
      (draw-view-header state
                        screenWidth
                        c"Settings / Integrations"
                        c"what flowline detected on this machine - checked once at startup")
      (for [slot 0
            INTEGRATION_COUNT]
        (let [row (index (field state integrations) slot)
              connected (= (load (field row connected)) 1)
              top (- (+ (cast f64 (+ VIEW_HEADER_HEIGHT 22)) (cast f64 (* slot 62)))
                     (view-scroll state VIEW_SETTINGS))
              glyphTint (if connected (accent project) (color 76 85 97))
              statusTint (if connected (color 111 154 126) (color 76 85 97))]
          (if (not (row-visible top 52.0 screenHeight))
            0
          (do
            (draw-card left top rowWidth 52.0)
            (stroke-rectangle (+ left 16.0) (+ top 11.0) 30.0 30.0 1.0 (color 42 51 63))
            (draw-text (field state monoMedium) (load (field row glyph)) (+ left 25.0) (+ top 19.0) 12.0 glyphTint)
            (draw-text (field state monoMedium) (load (field row name)) (+ left 60.0) (+ top 13.0) 12.0 (color 223 229 236))
            (draw-text (field state mono) (load (field row detail)) (+ left 60.0) (+ top 31.0) 9.5 (color 76 85 97))
            (draw-text-right (field state mono)
                             (if connected c"detected" c"not found")
                             (+ left (- rowWidth 62.0))
                             (+ top 21.0)
                             9.5
                             statusTint)
            (let [switchLeft (+ left (- rowWidth 50.0))]
              (do
                (stroke-rectangle switchLeft (+ top 17.0) 34.0 18.0 1.0 (if connected (accent-alpha project 153) (color 42 51 63)))
                (if connected
                  (fill-rectangle switchLeft (+ top 17.0) 34.0 18.0 (accent-alpha project 28))
                  0)
                (fill-rectangle (if connected (+ switchLeft 20.0) (+ switchLeft 2.0))
                                (+ top 19.0)
                                12.0
                                12.0
                                (if connected (accent project) (color 61 69 79)))
                0))
            0))))
      0)))

(defn draw-app [(state (mut AppState)) (input InputFrame) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [view (load (field state view))]
    (do
      (raylib.ClearBackground (color 7 10 14))
      (draw-sidebar state screenHeight)
      (cond
        (= view VIEW_CREATE) (draw-design-workspace (mut state) input screenWidth screenHeight)
        (= view VIEW_RUNS) (draw-runs-view state screenWidth screenHeight)
        (= view VIEW_APPROVALS) (draw-approvals-view state screenWidth screenHeight)
        (= view VIEW_TEMPLATES) (draw-templates-view state screenWidth screenHeight)
        (= view VIEW_SETTINGS) (draw-settings-view state screenWidth screenHeight)
        (= view VIEW_RUN)
          (if (= (workflow.catalog-count (load (field state catalog))) 0)
            (draw-empty-workspace state screenWidth screenHeight)
            (do
              (draw-center state screenWidth screenHeight)
              (draw-right (mut state) input screenWidth screenHeight)
              0))
        (if (= (workflow.catalog-count (load (field state catalog))) 0)
          (draw-empty-workspace state screenWidth screenHeight)
          (draw-dashboard-view state screenWidth screenHeight)))
      (if (and (!= view VIEW_CREATE)
               (or (= (load (field state creationState)) 1) (= (load (field state creationState)) 3)))
        (draw-creation-banner state screenWidth)
        0)
      0)))

(defn run-interface [] (-> i64)
  (do
    (raylib.SetConfigFlags (cast u32 WINDOW_FLAGS))
    (raylib.InitWindow (cast i32 1440) (cast i32 900) c"flowline - agent workflow designer")
    (raylib.MaximizeWindow)
    (raylib.SetTargetFPS (cast i32 60))
    (let [mono (raylib.LoadFontEx c"assets/fonts/IBMPlexMono-Regular.ttf" (cast i32 64) (cast (ptr i32) 0) (cast i32 0))
          monoMedium
            (raylib.LoadFontEx c"assets/fonts/IBMPlexMono-Medium.ttf" (cast i32 64) (cast (ptr i32) 0) (cast i32 0))
          sans (raylib.LoadFontEx c"assets/fonts/IBMPlexSans-Regular.ttf" (cast i32 64) (cast (ptr i32) 0) (cast i32 0))
          catalogValue (workflow.load-catalog)
          catalog (alloc-stack workflow.Catalog)
          state (alloc-stack AppState)
          input (alloc-stack InputFrame)
          camera (alloc-stack raylib.Camera2D)
          creationText (workflow.allocate-buffer CREATION_CAPACITY)
          clipboardText (workflow.allocate-buffer 4096)
          measureText (workflow.allocate-buffer 4096)
          designResponse (workflow.allocate-buffer 4096)
          designRequest (workflow.allocate-buffer CREATION_CAPACITY)
          designPreview (workflow.allocate-runtime)
          runLog (cast (ptr workflow.RunLog) (workflow.allocate-buffer (sizeof workflow.RunLog)))]
      (store! catalog catalogValue)
      (workflow.load-run-log runLog)
      (store! creationText (cast i8 0))
      (store! clipboardText (cast i8 0))
      (store! designResponse (cast i8 0))
      (store! designRequest (cast i8 0))
      (store! (field state selectedProject) 0)
      (store! (field state selectedNode) 0)
      (store! (field state approvalGranted) 0)
      (store! (field state runRequested) 0)
      (store! (field state approvalRequested) 0)
      (store! (field state catalog) catalog)
      (store! (field state runLog) runLog)
      (store! (field state activeRunEntry) -1)
      (detect-integrations (mut state))
      (store! (field state runtime) (workflow.catalog-runtime catalog 0))
      (store! (field state activeRuntime) (cast (ptr workflow.Runtime) 0))
      (store! (field state view) VIEW_DASHBOARD)
      (store! (field state creationRequested) 0)
      (store! (field state creationState) 0)
      (store! (field state creationLength) 0)
      (store! (field state creationText) creationText)
      (store! (field state creationAnchor) 0)
      (store! (field state creationFocus) 0)
      (store! (field state creationFocused) 0)
      (store! (field state creationDragging) 0)
      (store! (field state creationTruncated) 0)
      (store! (field state clipboardRequested) 0)
      (store! (field state clipboardText) clipboardText)
      (store! (field state designRequested) 0)
      (store! (field state designState) 0)
      (store! (field state designTurn) 0)
      (store! (field state designResponse) designResponse)
      (store! (field state designRequest) designRequest)
      (store! (field state designPreview) designPreview)
      (store! (field state designPreviewValid) 0)
      (store! (field state wrappedOutput) (cast (ptr i8) 0))
      (store! (field state wrappedOutputLength) 0)
      (store! (field state selectionRegion) 0)
      (store! (field state selectionAnchor) 0)
      (store! (field state selectionFocus) 0)
      (store! (field state selectionDragging) 0)
      (store! (field state selectionPressHandled) 0)
      (store! (field state hoverSelectableText) 0)
      (store! (field state measureText) measureText)
      (store! (field camera offset) (vector 0.0 0.0))
      (store! (field camera target) (vector 0.0 0.0))
      (store! (field camera rotation) (cast f32 0.0))
      (store! (field camera zoom) (cast f32 (ui-scale)))
      (store! (field state mono) mono)
      (store! (field state monoMedium) monoMedium)
      (store! (field state sans) sans)
      (configure-font (field state mono))
      (configure-font (field state monoMedium))
      (configure-font (field state sans))
      (loop (if (icmp-ne (raylib.WindowShouldClose) (cast u8 0))
              (break)
              (let [screenWidth (cast i64 (/ (cast f64 (raylib.GetScreenWidth)) (ui-scale)))
                    screenHeight (cast i64 (/ (cast f64 (raylib.GetScreenHeight)) (ui-scale)))]
                (do
                  (capture-input (mut input))
                  (apply-input (mut state) input screenWidth screenHeight)
                  (if (= (load (field state clipboardRequested)) 1)
                    (do
                      (raylib.SetClipboardText (load (field state clipboardText)))
                      (store! (field state clipboardRequested) 0)
                      0)
                    0)
                  (apply-run-request (mut state))
                  (if (= (load (field state approvalRequested)) 1)
                    (let [selectedRuntime (load (field state runtime))]
                      (do
                        (workflow.approve (mut selectedRuntime) (load (field state selectedNode)))
                        (if (= (workflow.node-status selectedRuntime (load (field state selectedNode))) 3)
                          (store! (field state approvalGranted) 1)
                          0)
                        (store! (field state approvalRequested) 0)
                        0))
                    0)
                  (if (= (load (field state creationRequested)) 1)
                    (do
                      (if (and (= (load (field state designPreviewValid)) 1)
                               (= (workflow.install-draft-workflow) 1))
                        (do
                          (workflow.refresh-catalog (mut catalog))
                          (let [createdWorkflowIndex (workflow.created-workflow-index catalog)]
                            (store! (field state selectedProject)
                                    (if (>= createdWorkflowIndex 0)
                                      createdWorkflowIndex
                                      (- (workflow.catalog-count catalog) 1))))
                          (store! (field state runtime)
                                  (workflow.catalog-runtime catalog (load (field state selectedProject))))
                          (store! (field state selectedNode) 0)
                          (store! (field state creationState) 2)
                          0)
                        (do
                          (workflow.start-creation-from-design)
                          (store! (field state creationState) 1)
                          0))
                      (store! (field state creationRequested) 0)
                      0)
                    0)
                  (if (= (load (field state designRequested)) 1)
                    (do
                      (copy-string (load (field state designRequest))
                                   (load (field state creationText))
                                   CREATION_CAPACITY)
                      (wrap-text-in-place state
                                          (load (field state designRequest))
                                          (field state sans)
                                          11.5
                                          404.0)
                      (workflow.start-design-turn (load (field state creationText)) (load (field state designTurn)))
                      (store! (field state designRequested) 0)
                      (store! (field state creationLength) 0)
                      (store! (field state creationAnchor) 0)
                      (store! (field state creationFocus) 0)
                      (store! creationText (cast i8 0))
                      0)
                    0)
                  (if (= (load (field state designState)) 1)
                    (let [designState (workflow.design-state)]
                      (if (= designState 2)
                        (do
                          (workflow.finish-design-turn designResponse)
                          (wrap-text-in-place state designResponse (field state sans) 11.5 404.0)
                          (store! designPreview (workflow.load-runtime c".flowline/design.draft.flow"))
                          (store! (field state designPreviewValid)
                                  (if (> (workflow.node-count designPreview) 0) 1 0))
                          (store! (field state designTurn) (+ (load (field state designTurn)) 1))
                          (store! (field state designState) 2)
                          0)
                        (if (= designState 3)
                          (do (store! (field state designState) 3) 0)
                          0)))
                    0)
                  (if (= (load (field state creationState)) 1)
                    (let [creationState (workflow.creation-state)]
                      (if (= creationState 2)
                        (do
                          (workflow.refresh-catalog (mut catalog))
                          (let [createdWorkflowIndex (workflow.created-workflow-index catalog)]
                            (store! (field state selectedProject)
                                    (if (>= createdWorkflowIndex 0)
                                      createdWorkflowIndex
                                      (- (workflow.catalog-count catalog) 1))))
                          (store! (field state runtime)
                                  (workflow.catalog-runtime catalog (load (field state selectedProject))))
                          (store! (field state selectedNode) 0)
                          (store! (field state creationState) 2)
                          (store! (field state creationLength) 0)
                          (store! (field state creationAnchor) 0)
                          (store! (field state creationFocus) 0)
                          (store! creationText (cast i8 0))
                          0)
                        (if (= creationState 3)
                          (do (store! (field state creationState) 3) 0)
                          0)))
                    0)
                  (let [activeRuntime (load (field state activeRuntime))]
                    (if (!= (cast i64 activeRuntime) 0)
                      (do
                        (workflow.tick (mut activeRuntime) (raylib.GetTime))
                        (sync-active-run (mut state) activeRuntime)
                        0)
                      0))
                  (store! (field state selectionPressHandled) 0)
                  (store! (field state hoverSelectableText) 0)
                  (raylib.BeginDrawing)
                  (raylib.BeginMode2D (load camera))
                  (draw-app (mut state) input screenWidth screenHeight)
                  (raylib.EndMode2D)
                  (raylib.EndDrawing)
                  (if (and (= (load (field input pressed)) 1)
                           (= (load (field state selectionPressHandled)) 0))
                    (do
                      (store! (field state selectionRegion) 0)
                      (store! (field state selectionAnchor) 0)
                      (store! (field state selectionFocus) 0)
                      (store! (field state selectionDragging) 0)
                      0)
                    0)
                  (raylib.SetMouseCursor
                    (cast i32
                          (if (= (load (field state hoverSelectableText)) 1)
                            MOUSE_CURSOR_IBEAM
                            MOUSE_CURSOR_DEFAULT)))
                  (continue)))))
      (raylib.UnloadFont (load (field state mono)))
      (raylib.UnloadFont (load (field state monoMedium)))
      (raylib.UnloadFont (load (field state sans))))
    (raylib.CloseWindow)
    0))

(defn render-interface-snapshot [] (-> i64)
  (do
    (raylib.SetConfigFlags (cast u32 WINDOW_FLAGS))
    (raylib.InitWindow (cast i32 1440) (cast i32 900) c"flowline - interface snapshot")
    (let [state (alloc-stack AppState)
          input (alloc-stack InputFrame)
          camera (alloc-stack raylib.Camera2D)
          catalogValue (workflow.load-catalog)
          catalog (alloc-stack workflow.Catalog)
          creationText (workflow.allocate-buffer CREATION_CAPACITY)
          clipboardText (workflow.allocate-buffer 4096)
          measureText (workflow.allocate-buffer 4096)
          designResponse (workflow.allocate-buffer 4096)
          designRequest (workflow.allocate-buffer CREATION_CAPACITY)
          designPreview (workflow.allocate-runtime)
          snapshotRunLog (cast (ptr workflow.RunLog) (workflow.allocate-buffer (sizeof workflow.RunLog)))
          response
            c"Recommended workflow: start with a repository inspection step, then\nfan out into build verification and a documentation pass. Both feed a\nfinal human approval before anything lands on the main branch."
          screenWidth (cast i64 (/ (cast f64 (raylib.GetScreenWidth)) (ui-scale)))
          screenHeight (cast i64 (/ (cast f64 (raylib.GetScreenHeight)) (ui-scale)))]
      (store! state (zeroed AppState))
      (store! input (zeroed InputFrame))
      (store! catalog catalogValue)
      (store! creationText (cast i8 0))
      (store! clipboardText (cast i8 0))
      (let [(mut position) 0]
        (do
          (while (icmp-ne (load (index response (load position))) (cast i8 0))
            (do
              (store! (index designResponse (load position)) (load (index response (load position))))
              (store! position (+ (load position) 1))))
          (store! (index designResponse (load position)) (cast i8 0))))
      (copy-string designRequest
                   c"Help me design a review workflow for the flowline UI. It should check the renderer, the text selection code, and the deepseek adapter, then let me approve the final report before anything gets written."
                   CREATION_CAPACITY)
      (store! (field state catalog) catalog)
      (workflow.load-run-log snapshotRunLog)
      (store! (field state runLog) snapshotRunLog)
      (store! (field state activeRunEntry) -1)
      (detect-integrations (mut state))
      (store! (field state runtime) (workflow.catalog-runtime catalog 0))
      (store! (field state creationText) creationText)
      (store! (field state clipboardText) clipboardText)
      (store! (field state measureText) measureText)
      (store! (field state designResponse) designResponse)
      (store! (field state designRequest) designRequest)
      (workflow.write-text-file c".flowline/snapshot.draft.flow"
                                c"workflow Draft Review Pipeline\nrunner deepseek\n\nagent inspect-repo\ntitle Inspect repository\nprompt Summarize the structure of src/main.coil.\nafter none\n\nagent review-ui\ntitle Review UI changes\nprompt Review src/main.coil for UI regressions.\nafter inspect-repo\n\napproval human-signoff\ntitle Human signoff\nafter review-ui\n")
      (store! designPreview (workflow.load-runtime c".flowline/snapshot.draft.flow"))
      (store! (field state designPreview) designPreview)
      (store! (field state designPreviewValid)
              (if (> (workflow.node-count designPreview) 0) 1 0))
      (store! (field state view) VIEW_CREATE)
      (store! (field state designTurn) 1)
      (store! (field state designState) 2)
      (store! (field state selectionRegion) 6)
      (store! (field state selectionAnchor) 21)
      (store! (field state selectionFocus) 108)
      (store! (field state mono)
              (raylib.LoadFontEx c"assets/fonts/IBMPlexMono-Regular.ttf" (cast i32 64) (cast (ptr i32) 0) (cast i32 0)))
      (store! (field state monoMedium)
              (raylib.LoadFontEx c"assets/fonts/IBMPlexMono-Medium.ttf" (cast i32 64) (cast (ptr i32) 0) (cast i32 0)))
      (store! (field state sans)
              (raylib.LoadFontEx c"assets/fonts/IBMPlexSans-Regular.ttf" (cast i32 64) (cast (ptr i32) 0) (cast i32 0)))
      (configure-font (field state mono))
      (configure-font (field state monoMedium))
      (configure-font (field state sans))
      (wrap-text-in-place state designRequest (field state sans) 11.5 404.0)
      (wrap-text-in-place state designResponse (field state sans) 11.5 404.0)
      (store! (field camera offset) (vector 0.0 0.0))
      (store! (field camera target) (vector 0.0 0.0))
      (store! (field camera rotation) (cast f32 0.0))
      (store! (field camera zoom) (cast f32 (ui-scale)))
      (raylib.BeginDrawing)
      (raylib.BeginMode2D (load camera))
      (draw-app (mut state) input screenWidth screenHeight)
      (raylib.EndMode2D)
      (raylib.TakeScreenshot c"interface-design.png")
      (raylib.EndDrawing)
      (store! (field state designState) 1)
      (raylib.BeginDrawing)
      (raylib.BeginMode2D (load camera))
      (draw-app (mut state) input screenWidth screenHeight)
      (raylib.EndMode2D)
      (raylib.TakeScreenshot c"interface-pending.png")
      (raylib.EndDrawing)
      (store! (field state designState) 2)
      (store! (field state view) VIEW_RUN)
      (raylib.BeginDrawing)
      (raylib.BeginMode2D (load camera))
      (draw-app (mut state) input screenWidth screenHeight)
      (raylib.EndMode2D)
      (raylib.TakeScreenshot c"interface-empty.png")
      (raylib.EndDrawing)
      (store! (field state creationState) 1)
      (raylib.BeginDrawing)
      (raylib.BeginMode2D (load camera))
      (draw-app (mut state) input screenWidth screenHeight)
      (raylib.EndMode2D)
      (raylib.TakeScreenshot c"interface-creating.png")
      (raylib.EndDrawing)
      (store! (field state creationState) 0)
      (raylib.UnloadFont (load (field state mono)))
      (raylib.UnloadFont (load (field state monoMedium)))
      (raylib.UnloadFont (load (field state sans))))
    (raylib.CloseWindow)
    0))

;; An approval node reaches STATUS_WAITING purely from its dependencies, with no
;; agent launched, so a workflow made only of approvals can be driven to its
;; waiting state for free. The snapshot tool primes exactly those runtimes and
;; leaves every other workflow untouched — it never spends an agent turn.
(defn prime-approval-only-runtimes [(catalog (ptr workflow.Catalog))] (-> i64)
  (do
    (for [project 0
          8]
      (if (< project (workflow.catalog-count catalog))
        (let [runtime (workflow.catalog-runtime catalog project)
              (mut onlyApprovals) 1]
          (do
            (for [node 0
                  7]
              (if (and (< node (workflow.node-count runtime))
                       (!= (workflow.node-kind runtime node) KIND_APPROVAL))
                (store! onlyApprovals 0)
                0))
            (if (and (= (load onlyApprovals) 1) (> (workflow.node-count runtime) 0))
              (do
                (workflow.start (mut runtime))
                (workflow.tick (mut runtime) 0.0)
                0)
              0)
            0))
        0))
    0))

;; One screenshot per workspace view, so every screen can be eyeballed without
;; clicking through the running app.
(defn render-view-snapshots [] (-> i64)
  (do
    (raylib.SetConfigFlags (cast u32 WINDOW_FLAGS))
    (raylib.InitWindow (cast i32 1440) (cast i32 900) c"flowline - view snapshots")
    (let [state (alloc-stack AppState)
          input (alloc-stack InputFrame)
          camera (alloc-stack raylib.Camera2D)
          catalogValue (workflow.load-catalog)
          catalog (alloc-stack workflow.Catalog)
          creationText (workflow.allocate-buffer CREATION_CAPACITY)
          clipboardText (workflow.allocate-buffer 4096)
          measureText (workflow.allocate-buffer 4096)
          designResponse (workflow.allocate-buffer 4096)
          designRequest (workflow.allocate-buffer CREATION_CAPACITY)
          screenWidth (cast i64 (/ (cast f64 (raylib.GetScreenWidth)) (ui-scale)))
          screenHeight (cast i64 (/ (cast f64 (raylib.GetScreenHeight)) (ui-scale)))
          runLog (cast (ptr workflow.RunLog) (workflow.allocate-buffer (sizeof workflow.RunLog)))
          names (alloc-stack (array (ptr i8) 6))]
      (do
        (store! state (zeroed AppState))
        (workflow.load-run-log runLog)
        (store! (field state runLog) runLog)
        (store! (field state activeRunEntry) -1)
        (store! input (zeroed InputFrame))
        (store! catalog catalogValue)
        (store! creationText (cast i8 0))
        (store! clipboardText (cast i8 0))
        (store! designResponse (cast i8 0))
        (store! designRequest (cast i8 0))
        (store! (field state catalog) catalog)
        (prime-approval-only-runtimes catalog)
        (detect-integrations (mut state))
        (store! (field state runtime) (workflow.catalog-runtime catalog 0))
        (store! (field state creationText) creationText)
        (store! (field state clipboardText) clipboardText)
        (store! (field state measureText) measureText)
        (store! (field state designResponse) designResponse)
        (store! (field state designRequest) designRequest)
        (store! (field state mono)
                (raylib.LoadFontEx c"assets/fonts/IBMPlexMono-Regular.ttf" (cast i32 64) (cast (ptr i32) 0) (cast i32 0)))
        (store! (field state monoMedium)
                (raylib.LoadFontEx c"assets/fonts/IBMPlexMono-Medium.ttf" (cast i32 64) (cast (ptr i32) 0) (cast i32 0)))
        (store! (field state sans)
                (raylib.LoadFontEx c"assets/fonts/IBMPlexSans-Regular.ttf" (cast i32 64) (cast (ptr i32) 0) (cast i32 0)))
        (configure-font (field state mono))
        (configure-font (field state monoMedium))
        (configure-font (field state sans))
        (store! (field camera offset) (vector 0.0 0.0))
        (store! (field camera target) (vector 0.0 0.0))
        (store! (field camera rotation) (cast f32 0.0))
        (store! (field camera zoom) (cast f32 (ui-scale)))
        (store! (index names 0) c"view-dashboard.png")
        (store! (index names 1) c"view-runs.png")
        (store! (index names 2) c"view-approvals.png")
        (store! (index names 3) c"view-templates.png")
        (store! (index names 4) c"view-settings.png")
        (store! (index names 5) c"view-run.png")
        (for [slot 0
              6]
          (do
            (store! (field state view) (if (= slot 5) VIEW_RUN slot))
            ;; The run shot uses an agent workflow so the step panel shows a real
            ;; prompt rather than an approval gate.
            (if (= slot 5)
              (let [target (if (> (workflow.catalog-count catalog) 1) 1 0)]
                (do
                  (store! (field state selectedProject) target)
                  (store! (field state runtime) (workflow.catalog-runtime catalog target))
                  (store! (field state selectedNode) 0)
                  0))
              0)
            (raylib.BeginDrawing)
            (raylib.BeginMode2D (load camera))
            (draw-app (mut state) (load input) screenWidth screenHeight)
            (raylib.EndMode2D)
            (raylib.TakeScreenshot (load (index names slot)))
            (raylib.EndDrawing)
            0))
        (raylib.UnloadFont (load (field state mono)))
        (raylib.UnloadFont (load (field state monoMedium)))
        (raylib.UnloadFont (load (field state sans)))))
    (raylib.CloseWindow)
    0))

;; Round-trips the run log through disk so the persistence path can be exercised
;; without launching the interface.
(defn check-run-log [] (-> i64)
  (let [log (cast (ptr workflow.RunLog) (workflow.allocate-buffer (sizeof workflow.RunLog)))
        reloaded (cast (ptr workflow.RunLog) (workflow.allocate-buffer (sizeof workflow.RunLog)))]
    (do
      (workflow.load-run-log log)
      (let [before (workflow.run-log-count log)
            entry (workflow.begin-run log c"Round Trip Check" c"workflows/check.flow" c"manual")]
        (do
          (workflow.update-run log entry RUN_DONE)
          (workflow.load-run-log reloaded)
          (let [record (workflow.run-log-record reloaded entry)
                valid (and (= (workflow.run-log-count reloaded) (+ before 1))
                           (and (= (load (field record status)) RUN_DONE)
                                (workflow.strings-equal (workflow.record-name record) c"Round Trip Check")))]
            (do
              (printf c"{\"before\":%lld,\"after\":%lld,\"id\":\"%s\",\"name\":\"%s\",\"path\":\"%s\",\"trigger\":\"%s\",\"status\":\"%s\",\"valid\":%s}\n"
                      before
                      (workflow.run-log-count reloaded)
                      (workflow.record-id record)
                      (workflow.record-name record)
                      (workflow.record-path record)
                      (workflow.record-trigger record)
                      (workflow.run-status-label (load (field record status)))
                      (if valid c"true" c"false"))
              (if valid 0 1))))))))

(defn dump-runs [] (-> i64)
  (let [log (cast (ptr workflow.RunLog) (workflow.allocate-buffer (sizeof workflow.RunLog)))]
    (do
      (workflow.load-run-log log)
      (printf c"{\"count\":%lld,\"runs\":[" (workflow.run-log-count log))
      (for [entry 0
            64]
        (if (< entry (workflow.run-log-count log))
          (let [record (workflow.run-log-record log entry)]
            (do
              (if (> entry 0) (do (printf c",") 0) 0)
              (printf c"{\"id\":\"%s\",\"workflow\":\"%s\",\"path\":\"%s\",\"trigger\":\"%s\",\"status\":\"%s\",\"started\":%lld,\"duration\":%lld}"
                      (workflow.record-id record)
                      (workflow.record-name record)
                      (workflow.record-path record)
                      (workflow.record-trigger record)
                      (workflow.run-status-label (load (field record status)))
                      (load (field record startedAt))
                      (load (field record duration)))
              0))
          0))
      (printf c"]}\n")
      0)))

;; ---------------------------------------------------------------------------
;; Interaction harness
;;
;; Drives apply-input with synthesized clicks at the same coordinates the views
;; draw at, and asserts the state transition each one is supposed to cause. This
;; is the only thing that proves a hit box actually lands where its control is
;; drawn — rendering a button and hit-testing it are separate code paths.
;; ---------------------------------------------------------------------------

(defn expect-equal [(failures (ptr i64)) (label (ptr i8)) (actual i64) (expected i64)] (-> i64)
  (if (= actual expected)
    0
    (do
      (printf c"  FAIL %s: expected %lld, got %lld\n" label expected actual)
      (store! failures (+ (load failures) 1))
      0)))

(defn synthesize-click [(state (mut AppState))
                        (horizontal f64)
                        (vertical f64)
                        (screenWidth i64)
                        (screenHeight i64)] (-> i64)
  (let [input (alloc-stack InputFrame)]
    (do
      (store! input (zeroed InputFrame))
      (store! (field input mouseHorizontal) horizontal)
      (store! (field input mouseVertical) vertical)
      (store! (field input pressed) 1)
      (apply-input (mut state) (load input) screenWidth screenHeight)
      0)))

(defn synthesize-wheel [(state (mut AppState))
                        (amount f64)
                        (screenWidth i64)
                        (screenHeight i64)] (-> i64)
  (let [input (alloc-stack InputFrame)]
    (do
      (store! input (zeroed InputFrame))
      (store! (field input wheel) amount)
      (apply-input (mut state) (load input) screenWidth screenHeight)
      0)))

(defn check-interactions [] (-> i64)
  (let [state (alloc-stack AppState)
        catalogValue (workflow.load-catalog)
        catalog (alloc-stack workflow.Catalog)
        runLog (cast (ptr workflow.RunLog) (workflow.allocate-buffer (sizeof workflow.RunLog)))
        creationText (workflow.allocate-buffer CREATION_CAPACITY)
        clipboardText (workflow.allocate-buffer 4096)
        measureText (workflow.allocate-buffer 4096)
        designResponse (workflow.allocate-buffer 4096)
        designRequest (workflow.allocate-buffer CREATION_CAPACITY)
        screenWidth 1152
        screenHeight 720
        right (cast f64 (- screenWidth VIEW_PADDING))
        left (cast f64 (+ LEFT_WIDTH VIEW_PADDING))
        failures (alloc-stack i64)]
    (do
      (store! failures 0)
      (store! state (zeroed AppState))
      (store! catalog catalogValue)
      (store! creationText (cast i8 0))
      (store! clipboardText (cast i8 0))
      (store! designResponse (cast i8 0))
      (store! designRequest (cast i8 0))
      (store! (field state catalog) catalog)
      (workflow.load-run-log runLog)
      (store! (field state runLog) runLog)
      (store! (field state activeRunEntry) -1)
      (store! (field state runtime) (workflow.catalog-runtime catalog 0))
      (store! (field state creationText) creationText)
      (store! (field state clipboardText) clipboardText)
      (store! (field state measureText) measureText)
      (store! (field state designResponse) designResponse)
      (store! (field state designRequest) designRequest)
      (prime-approval-only-runtimes catalog)

      ;; Sidebar navigation: every nav row reaches its view.
      (for [slot 0
            SIDEBAR_NAV_COUNT]
        (do
          (synthesize-click (mut state) 100.0 (+ (nav-row-top slot) 16.0) screenWidth screenHeight)
          (expect-equal failures
                        c"nav row reaches its view"
                        (load (field state view))
                        (case slot 0
                              VIEW_DASHBOARD 1
                              VIEW_RUNS 2
                              VIEW_APPROVALS 3
                              VIEW_TEMPLATES
                              VIEW_SETTINGS))
          0))

      ;; The projects list selects a project and lands on its dashboard.
      (if (> (workflow.catalog-count catalog) 1)
        (do
          (synthesize-click (mut state) 100.0 (+ (project-row-top 1) 20.0) screenWidth screenHeight)
          (expect-equal failures c"project row selects project" (load (field state selectedProject)) 1)
          (expect-equal failures c"project row opens dashboard" (load (field state view)) VIEW_DASHBOARD)
          0)
        0)

      ;; "+ new" enters the create view from a blank slate.
      (synthesize-click (mut state) 198.0 (cast f64 (+ SIDEBAR_PROJECTS_LABEL_TOP 5)) screenWidth screenHeight)
      (expect-equal failures c"+ new opens create" (load (field state view)) VIEW_CREATE)
      (expect-equal failures c"+ new resets the draft" (load (field state designTurn)) 0)

      ;; Dashboard header button also reaches create.
      (store! (field state view) VIEW_DASHBOARD)
      (synthesize-click (mut state) (cast f64 (- screenWidth 100)) 36.0 screenWidth screenHeight)
      (expect-equal failures c"+ new workflow opens create" (load (field state view)) VIEW_CREATE)

      ;; Dashboard "view all" reaches the runs list.
      (store! (field state view) VIEW_DASHBOARD)
      (synthesize-click (mut state) (- right 380.0) (cast f64 (+ VIEW_HEADER_HEIGHT 136)) screenWidth screenHeight)
      (expect-equal failures c"view all opens runs" (load (field state view)) VIEW_RUNS)

      ;; Run filters.
      (for [slot 0
            4]
        (do
          (store! (field state view) VIEW_RUNS)
          (synthesize-click (mut state) (+ (run-filter-left slot screenWidth) 20.0) 34.0 screenWidth screenHeight)
          (expect-equal failures c"run filter selects slot" (load (field state runFilter)) slot)
          0))
      (store! (field state runFilter) 0)

      ;; A run row opens that run's workflow, when there is one recorded.
      (if (> (workflow.run-log-count runLog) 0)
        (let [newest (workflow.run-log-record runLog (- (workflow.run-log-count runLog) 1))
              expected (project-for-path state (workflow.record-path newest))]
          (if (>= expected 0)
            (do
              (store! (field state view) VIEW_RUNS)
              (synthesize-click (mut state)
                                (+ left 40.0)
                                (+ (runs-row-top 0 0.0) 20.0)
                                screenWidth
                                screenHeight)
              (expect-equal failures c"run row opens the run view" (load (field state view)) VIEW_RUN)
              (expect-equal failures c"run row selects its workflow" (load (field state selectedProject)) expected)
              0)
            0))
        0)

      ;; The run view's breadcrumb goes back to the runs list.
      (store! (field state view) VIEW_RUN)
      (synthesize-click (mut state) (cast f64 (+ LEFT_WIDTH 40)) 24.0 screenWidth screenHeight)
      (expect-equal failures c"run breadcrumb returns to runs" (load (field state view)) VIEW_RUNS)

      ;; APPROVE on the first approvals card requests approval for that exact node.
      (if (> (catalog-waiting-node-count catalog) 0)
        (do
          (store! (field state view) VIEW_APPROVALS)
          (store! (field state approvalRequested) 0)
          (synthesize-click (mut state)
                            (+ left 40.0)
                            (+ (approval-card-top 0 0.0) 90.0)
                            screenWidth
                            screenHeight)
          (expect-equal failures c"approve requests approval" (load (field state approvalRequested)) 1)
          (expect-equal failures
                        c"approve targets a waiting node"
                        (workflow.node-status (load (field state runtime)) (load (field state selectedNode)))
                        STATUS_WAITING)
          0)
        0)

      ;; A full run lifecycle against a real runtime. An approval-only workflow
      ;; reaches its waiting state without launching an agent, so this exercises
      ;; the live path — request, start, record, sync — for free.
      (let [(mut approvalOnly) -1]
        (do
          (for [project 0
                8]
            (if (< project (workflow.catalog-count catalog))
              (let [runtime (workflow.catalog-runtime catalog project)
                    (mut allApprovals) 1]
                (do
                  (for [node 0
                        7]
                    (if (and (< node (workflow.node-count runtime))
                             (!= (workflow.node-kind runtime node) KIND_APPROVAL))
                      (store! allApprovals 0)
                      0))
                  (if (and (= (load allApprovals) 1)
                           (and (> (workflow.node-count runtime) 0) (< (load approvalOnly) 0)))
                    (store! approvalOnly project)
                    0)
                  0))
              0))
          (if (< (load approvalOnly) 0)
            (printf c"  SKIP run lifecycle: no approval-only workflow in the catalog\n")
            (let [runtime (workflow.catalog-runtime catalog (load approvalOnly))
                  before (workflow.run-log-count runLog)]
              (do
                (store! (field state selectedProject) (load approvalOnly))
                (store! (field state runtime) runtime)
                (store! (field state activeRuntime) (cast (ptr workflow.Runtime) 0))
                (store! (field state runRequested) 1)
                (apply-run-request (mut state))
                (expect-equal failures c"run request clears its flag" (load (field state runRequested)) 0)
                (expect-equal failures
                              c"run request opens a log record"
                              (workflow.run-log-count runLog)
                              (+ before 1))
                (expect-equal failures
                              c"run request tracks the new record"
                              (load (field state activeRunEntry))
                              before)
                (let [record (workflow.run-log-record runLog before)]
                  (do
                    (expect-equal failures
                                  c"record names the workflow it started"
                                  (if (workflow.strings-equal (workflow.record-name record)
                                                              (workflow.program-name runtime))
                                    1
                                    0)
                                  1)
                    (expect-equal failures
                                  c"a new record starts as running"
                                  (load (field record status))
                                  RUN_RUNNING)
                    ;; Tick to the waiting state, then let the sync write it back.
                    (workflow.tick (mut runtime) 0.0)
                    (sync-active-run (mut state) runtime)
                    (expect-equal failures
                                  c"sync writes the waiting status through"
                                  (load (field record status))
                                  RUN_WAITING)
                    (let [reloaded (cast (ptr workflow.RunLog)
                                         (workflow.allocate-buffer (sizeof workflow.RunLog)))]
                      (do
                        (workflow.load-run-log reloaded)
                        (expect-equal failures
                                      c"the run survives a reload from disk"
                                      (load (field (workflow.run-log-record reloaded before) status))
                                      RUN_WAITING)
                        0))
                    0))
                0)))
          0))

      ;; Scrolling clamps at both ends.
      (store! (field state view) VIEW_SETTINGS)
      (store! (index (field state scrollOffsets) VIEW_SETTINGS) 0.0)
      (synthesize-wheel (mut state) 5.0 screenWidth screenHeight)
      (expect-equal failures
                    c"scroll cannot go above the start"
                    (cast i64 (view-scroll state VIEW_SETTINGS))
                    0)
      (synthesize-wheel (mut state) -500.0 screenWidth screenHeight)
      (let [content (view-content-height state VIEW_SETTINGS screenWidth)
            viewport (cast f64 (- screenHeight (+ VIEW_HEADER_HEIGHT 30)))
            maximum (if (> content viewport) (- content viewport) 0.0)]
        (expect-equal failures
                      c"scroll clamps at the end"
                      (cast i64 (view-scroll state VIEW_SETTINGS))
                      (cast i64 maximum)))

      (printf c"{\"failures\":%lld,\"valid\":%s}\n"
              (load failures)
              (if (= (load failures) 0) c"true" c"false"))
      (if (= (load failures) 0) 0 1))))

(defn check-text-editor [] (-> i64)
  (let [state (alloc-stack AppState)
        input (alloc-stack InputFrame)
        text (workflow.allocate-buffer CREATION_CAPACITY)
        clipboardText (workflow.allocate-buffer CREATION_CAPACITY)]
    (do
      (store! state (zeroed AppState))
      (store! input (zeroed InputFrame))
      (store! text (cast i8 0))
      (store! clipboardText (cast i8 0))
      (store! (field state creationText) text)
      (store! (field state clipboardText) clipboardText)
      (store! (field state creationFocused) 1)
      (store! (field input typedCount) 3)
      (store! (index (field input typedCharacters) 0) 65)
      (store! (index (field input typedCharacters) 1) 233)
      (store! (index (field input typedCharacters) 2) 128640)
      (edit-creation-text (mut state) (load input))
      (store! input (zeroed InputFrame))
      (store! (field input backspacePressed) 1)
      (edit-creation-text (mut state) (load input))
      (store! input (zeroed InputFrame))
      (store! (field input homePressed) 1)
      (edit-creation-text (mut state) (load input))
      (store! input (zeroed InputFrame))
      (store! (field input typedCount) 1)
      (store! (index (field input typedCharacters) 0) 90)
      (edit-creation-text (mut state) (load input))
      (printf c"{\"text\":\"%s\",\"bytes\":%lld,\"anchor\":%lld,\"focus\":%lld,\"valid\":%s}\n"
              text
              (load (field state creationLength))
              (load (field state creationAnchor))
              (load (field state creationFocus))
              (if (and (= (load (field state creationLength)) 4)
                       (and (= (load (field state creationAnchor)) 1) (= (load (field state creationFocus)) 1)))
                c"true"
                c"false"))
      0)))

(defn main [(argumentCount i32) (arguments (ptr (ptr i8)))] (-> i64)
  (if (and (> (cast i64 argumentCount) 1)
           (workflow.strings-equal (load (index arguments 1)) c"--native-catalog"))
    (native.run-catalog)
    (if (and (> (cast i64 argumentCount) 1)
             (workflow.strings-equal (load (index arguments 1)) c"--check-interactions"))
      (check-interactions)
    (if (and (> (cast i64 argumentCount) 1)
             (workflow.strings-equal (load (index arguments 1)) c"--check-run-log"))
      (check-run-log)
    (if (and (> (cast i64 argumentCount) 1)
             (workflow.strings-equal (load (index arguments 1)) c"--dump-runs"))
      (dump-runs)
    (if (and (> (cast i64 argumentCount) 1)
             (workflow.strings-equal (load (index arguments 1)) c"--render-views"))
      (render-view-snapshots)
    (if (and (> (cast i64 argumentCount) 1)
             (workflow.strings-equal (load (index arguments 1)) c"--render-interface"))
      (render-interface-snapshot)
    (if (and (> (cast i64 argumentCount) 1)
             (workflow.strings-equal (load (index arguments 1)) c"--render-native-catalog"))
      (native.render-catalog-snapshot)
      (if (and (> (cast i64 argumentCount) 1)
             (workflow.strings-equal (load (index arguments 1)) c"--check-native-controls"))
        (let [valid (native.check-catalog-interactions)]
          (do
            (printf c"{\"button\":true,\"checkbox\":true,\"switch\":true,\"slider\":true,\"toggle\":true,\"radioGroup\":true,\"valid\":%s}\n"
                    (if (= valid 1) c"true" c"false"))
            (if (= valid 1) 0 1)))
        (if (and (> (cast i64 argumentCount) 1)
             (workflow.strings-equal (load (index arguments 1)) c"--check-text-editor"))
          (check-text-editor)
          (if (and (> (cast i64 argumentCount) 2)
                   (workflow.strings-equal (load (index arguments 1)) c"--check-workflow"))
            (let [runtime (workflow.load-runtime (load (index arguments 2)))]
              (workflow.dump runtime))
            (if (and (> (cast i64 argumentCount) 1)
                     (workflow.strings-equal (load (index arguments 1)) c"--check-catalog"))
              (let [catalog (workflow.load-catalog)]
                (workflow.dump-catalog catalog))
              (run-interface)))))))))))))
