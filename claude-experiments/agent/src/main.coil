(defn configure-font [(font raylib.Font)] (-> i64)
  (do
    (raylib.SetTextureFilter (load (field font texture)) (cast i32 TEXTURE_FILTER_BILINEAR))
    0))

(defn in-bounds [(horizontal f64) (vertical f64) (left f64) (top f64) (width f64) (height f64)] (-> bool)
  (and (>= horizontal left)
       (and (< horizontal (+ left width)) (and (>= vertical top) (< vertical (+ top height))))))

;; Layered DAG layout: a node's row is its longest dependency chain, and
;; nodes sharing a row spread into columns around the center line.
(defn compute-flow-layout [(runtime workflow.Runtime)
                           (depths (ptr i64))
                           (columns (ptr i64))
                           (rowCounts (ptr i64))] (-> i64)
  (let [(mut maxDepth) 0]
    (do
      (for [row 0
            7]
        (store! (index rowCounts row) 0))
      (for [node 0
            7]
        (if (< node (workflow.node-count runtime))
          (let [dependencyA (workflow.node-dependency runtime node 0)
                dependencyB (workflow.node-dependency runtime node 1)
                (mut depth) 0]
            (do
              (if (and (>= dependencyA 0) (> (+ (load (index depths dependencyA)) 1) (load depth)))
                (store! depth (+ (load (index depths dependencyA)) 1))
                0)
              (if (and (>= dependencyB 0) (> (+ (load (index depths dependencyB)) 1) (load depth)))
                (store! depth (+ (load (index depths dependencyB)) 1))
                0)
              (store! (index depths node) (load depth))
              (store! (index columns node) (load (index rowCounts (load depth))))
              (store! (index rowCounts (load depth)) (+ (load (index rowCounts (load depth))) 1))
              (if (> (load depth) (load maxDepth)) (store! maxDepth (load depth)) 0)
              0))
          0))
      (load maxDepth))))

(defn layout-horizontal [(column i64) (rowCount i64) (center f64)] (-> f64)
  (+ center (* (- (cast f64 column) (/ (cast f64 (- rowCount 1)) 2.0)) 320.0)))

(defn layout-vertical [(depth i64) (maxDepth i64) (height i64)] (-> f64)
  (let [divisor (cast f64 (if (> maxDepth 5) maxDepth 5))
        raw (/ (- (cast f64 height) 205.0) divisor)
        step (cond (< raw 100.0) 100.0
                   (> raw 139.0) 139.0
                   raw)]
    (+ 144.0 (* (cast f64 depth) step))))

;; Text editing behavior in this section is adapted from Vercel Labs Native SDK's
;; text interaction engine, modified for Coil, Raylib, and Flowline's fixed state.
;; See licenses/native-sdk-Apache-2.0.txt and THIRD_PARTY_NOTICES.md.
(defn selection-start [(state AppState)] (-> i64)
  (let [anchor (load (field state creationAnchor))
        focus (load (field state creationFocus))]
    (if (< anchor focus) anchor focus)))

(defn selection-end [(state AppState)] (-> i64)
  (let [anchor (load (field state creationAnchor))
        focus (load (field state creationFocus))]
    (if (> anchor focus) anchor focus)))

(defn is-utf8-continuation [(byte i64)] (-> bool)
  (= (iand byte 192) 128))

(defn previous-text-offset [(text (ptr i8)) (offset i64)] (-> i64)
  (if (<= offset 0)
    0
    (let [(mut cursor) (- offset 1)]
      (do
        (while (and (> (load cursor) 0)
                    (is-utf8-continuation (cast i64 (cast u8 (load (index text (load cursor)))))))
          (store! cursor (- (load cursor) 1)))
        (load cursor)))))

(defn next-text-offset [(text (ptr i8)) (length i64) (offset i64)] (-> i64)
  (if (>= offset length)
    length
    (let [(mut cursor) (+ offset 1)]
      (do
        (while (and (< (load cursor) length)
                    (is-utf8-continuation (cast i64 (cast u8 (load (index text (load cursor)))))))
          (store! cursor (+ (load cursor) 1)))
        (load cursor)))))

(defn word-byte [(byte i64)] (-> bool)
  (or (and (>= byte 48) (<= byte 57))
      (or (and (>= byte 65) (<= byte 90))
          (or (and (>= byte 97) (<= byte 122)) (or (= byte 95) (>= byte 128))))))

(defn word-at [(text (ptr i8)) (offset i64)] (-> bool)
  (word-byte (cast i64 (cast u8 (load (index text offset))))))

(defn previous-word-offset [(text (ptr i8)) (offset i64)] (-> i64)
  (let [(mut cursor) offset]
    (do
      (while (and (> (load cursor) 0) (= (word-at text (previous-text-offset text (load cursor))) false))
        (store! cursor (previous-text-offset text (load cursor))))
      (while (and (> (load cursor) 0) (word-at text (previous-text-offset text (load cursor))))
        (store! cursor (previous-text-offset text (load cursor))))
      (load cursor))))

(defn next-word-offset [(text (ptr i8)) (length i64) (offset i64)] (-> i64)
  (let [(mut cursor) offset]
    (do
      (while (and (< (load cursor) length) (= (word-at text (load cursor)) false))
        (store! cursor (next-text-offset text length (load cursor))))
      (while (and (< (load cursor) length) (word-at text (load cursor)))
        (store! cursor (next-text-offset text length (load cursor))))
      (load cursor))))

(defn delete-text-range [(state (mut AppState)) (start i64) (end i64)] (-> i64)
  (let [text (load (field state creationText))
        length (load (field state creationLength))
        removed (- end start)
        (mut source) end]
    (do
      (while (<= (load source) length)
        (do
          (store! (index text (- (load source) removed)) (load (index text (load source))))
          (store! source (+ (load source) 1))))
      (store! (field state creationLength) (- length removed))
      (store! (field state creationAnchor) start)
      (store! (field state creationFocus) start)
      0)))

(defn delete-selection [(state (mut AppState))] (-> i64)
  (let [start (selection-start state)
        end (selection-end state)]
    (if (< start end) (delete-text-range (mut state) start end) 0)))

(defn insert-codepoint [(state (mut AppState)) (codepoint i64)] (-> i64)
  (let [byteCount (cond (<= codepoint 127) 1 (<= codepoint 2047) 2 (<= codepoint 65535) 3 4)]
    (do
      (delete-selection (mut state))
      (let [text (load (field state creationText))
            length (load (field state creationLength))
            cursor (load (field state creationFocus))]
        (if (> (+ length byteCount) (- CREATION_CAPACITY 1))
          (do (store! (field state creationTruncated) 1) 0)
          (let [(mut source) length]
            (do
              (while (>= (load source) cursor)
                (do
                  (store! (index text (+ (load source) byteCount)) (load (index text (load source))))
                  (store! source (- (load source) 1))))
              (cond (= byteCount 1) (store! (index text cursor) (cast i8 codepoint))
                    (= byteCount 2)
                      (do
                        (store! (index text cursor) (cast i8 (ior 192 (ishr codepoint 6))))
                        (store! (index text (+ cursor 1)) (cast i8 (ior 128 (iand codepoint 63))))
                        0)
                    (= byteCount 3)
                      (do
                        (store! (index text cursor) (cast i8 (ior 224 (ishr codepoint 12))))
                        (store! (index text (+ cursor 1))
                                (cast i8 (ior 128 (iand (ishr codepoint 6) 63))))
                        (store! (index text (+ cursor 2)) (cast i8 (ior 128 (iand codepoint 63))))
                        0)
                    (do
                      (store! (index text cursor) (cast i8 (ior 240 (ishr codepoint 18))))
                      (store! (index text (+ cursor 1))
                              (cast i8 (ior 128 (iand (ishr codepoint 12) 63))))
                      (store! (index text (+ cursor 2))
                              (cast i8 (ior 128 (iand (ishr codepoint 6) 63))))
                      (store! (index text (+ cursor 3)) (cast i8 (ior 128 (iand codepoint 63))))
                      0))
              (store! (field state creationLength) (+ length byteCount))
              (store! (field state creationAnchor) (+ cursor byteCount))
              (store! (field state creationFocus) (+ cursor byteCount))
              (store! (field state creationTruncated) 0)
              0))))
      0)))

(defn copy-string [(destination (ptr i8)) (source (ptr i8)) (capacity i64)] (-> i64)
  (let [(mut position) 0]
    (do
      (while (and (< (load position) (- capacity 1))
                  (icmp-ne (load (index source (load position))) (cast i8 0)))
        (do
          (store! (index destination (load position)) (load (index source (load position))))
          (store! position (+ (load position) 1))))
      (store! (index destination (load position)) (cast i8 0))
      0)))

(defn byte-text-length [(text (ptr i8))] (-> i64)
  (let [(mut length) 0]
    (loop (if (icmp-eq (load (index text (load length))) (cast i8 0))
            (break (load length))
            (store! length (+ (load length) 1))))))

(defn insert-text [(state (mut AppState)) (sourceText (ptr i8))] (-> i64)
  (do
    (delete-selection (mut state))
    (let [text (load (field state creationText))
          length (load (field state creationLength))
          cursor (load (field state creationFocus))
          requested (byte-text-length sourceText)
          available (- (- CREATION_CAPACITY 1) length)
          (mut insertLength) (if (< requested available) requested available)]
      (do
        (while (and (> (load insertLength) 0)
                    (is-utf8-continuation (cast i64 (cast u8 (load (index sourceText (load insertLength)))))))
          (store! insertLength (- (load insertLength) 1)))
        (let [(mut source) length]
          (do
            (while (>= (load source) cursor)
              (do
                (store! (index text (+ (load source) (load insertLength))) (load (index text (load source))))
                (store! source (- (load source) 1))))
            (for [position 0
                  2048]
              (if (< position (load insertLength))
                (store! (index text (+ cursor position)) (load (index sourceText position)))
                0))
            (store! (field state creationLength) (+ length (load insertLength)))
            (store! (field state creationAnchor) (+ cursor (load insertLength)))
            (store! (field state creationFocus) (+ cursor (load insertLength)))
            (store! (field state creationTruncated) (if (< (load insertLength) requested) 1 0))
            0))
        0))))

(defn copy-creation-selection [(state (mut AppState))] (-> i64)
  (let [start (selection-start state)
        end (selection-end state)
        source (load (field state creationText))
        destination (load (field state clipboardText))]
    (if (= start end)
      0
      (do
        (for [position 0
              2048]
          (if (< position (- end start))
            (store! (index destination position) (load (index source (+ start position))))
            0))
        (store! (index destination (- end start)) (cast i8 0))
        (store! (field state clipboardRequested) 1)
        0))))

(defn move-creation-caret [(state (mut AppState)) (direction i64) (extend i64)] (-> i64)
  (let [text (load (field state creationText))
        length (load (field state creationLength))
        anchor (load (field state creationAnchor))
        focus (load (field state creationFocus))
        start (selection-start state)
        end (selection-end state)
        target
          (cond (= direction 0) (if (and (= extend 0) (!= anchor focus)) start (previous-text-offset text focus))
                (= direction 1) (if (and (= extend 0) (!= anchor focus)) end (next-text-offset text length focus))
                (= direction 2) 0
                (= direction 3) length
                (= direction 4) (previous-word-offset text focus)
                (next-word-offset text length focus))]
    (do
      (store! (field state creationFocus) target)
      (if (= extend 0) (store! (field state creationAnchor) target) 0)
      0)))

(defn edit-creation-text [(state (mut AppState)) (input InputFrame)] (-> i64)
  (if (or (= (load (field state creationFocused)) 0) (= (load (field state designState)) 1))
    0
    (do
      (if (= (load (field input selectAllPressed)) 1)
        (do
          (store! (field state creationAnchor) 0)
          (store! (field state creationFocus) (load (field state creationLength)))
          0)
        0)
      (if (= (load (field input copyPressed)) 1) (copy-creation-selection (mut state)) 0)
      (if (= (load (field input cutPressed)) 1)
        (do
          (copy-creation-selection (mut state))
          (delete-selection (mut state))
          0)
        0)
      (if (= (load (field input pastePressed)) 1)
        (let [pasteText (load (field input pasteText))]
          (if (!= (cast i64 pasteText) 0) (insert-text (mut state) pasteText) 0))
        0)
      (if (= (load (field input leftPressed)) 1)
        (move-creation-caret (mut state)
                             (if (= (load (field input commandDown)) 1)
                               2
                               (if (= (load (field input wordDown)) 1) 4 0))
                             (load (field input shiftDown)))
        0)
      (if (= (load (field input rightPressed)) 1)
        (move-creation-caret (mut state)
                             (if (= (load (field input commandDown)) 1)
                               3
                               (if (= (load (field input wordDown)) 1) 5 1))
                             (load (field input shiftDown)))
        0)
      (if (= (load (field input homePressed)) 1)
        (move-creation-caret (mut state) 2 (load (field input shiftDown)))
        0)
      (if (= (load (field input endPressed)) 1)
        (move-creation-caret (mut state) 3 (load (field input shiftDown)))
        0)
      (if (= (load (field input backspacePressed)) 1)
        (let [start (selection-start state)
              end (selection-end state)
              focus (load (field state creationFocus))]
          (if (< start end)
            (delete-text-range (mut state) start end)
            (if (> focus 0)
              (delete-text-range (mut state) (previous-text-offset (load (field state creationText)) focus) focus)
              0)))
        0)
      (if (= (load (field input deletePressed)) 1)
        (let [start (selection-start state)
              end (selection-end state)
              focus (load (field state creationFocus))
              length (load (field state creationLength))]
          (if (< start end)
            (delete-text-range (mut state) start end)
            (if (< focus length)
              (delete-text-range (mut state) focus (next-text-offset (load (field state creationText)) length focus))
              0)))
        0)
      (for [characterIndex 0
            16]
        (if (< characterIndex (load (field input typedCount)))
          (let [codepoint (load (index (field input typedCharacters) characterIndex))]
            (if (>= codepoint 32) (insert-codepoint (mut state) codepoint) 0))
          0))
      0)))

(defn text-width-through [(font raylib.Font) (text (ptr i8)) (offset i64) (size f64)] (-> f64)
  (let [saved (load (index text offset))]
    (do
      (store! (index text offset) (cast i8 0))
      (let [measured (raylib.MeasureTextEx (load font) text (cast f32 (* size 1.16)) (cast f32 0.18))]
        (do
          (store! (index text offset) saved)
          (cast f64 (load (field measured x))))))))

(defn creation-text-scroll [(state AppState) (visibleWidth f64)] (-> f64)
  (let [caretWidth
          (text-width-through (field state sans)
                              (load (field state creationText))
                              (load (field state creationFocus))
                              11.5)]
    (if (> caretWidth (- visibleWidth 8.0)) (- caretWidth (- visibleWidth 8.0)) 0.0)))

(defn creation-offset-at [(state AppState) (horizontal f64) (textLeft f64) (visibleWidth f64)] (-> i64)
  (let [text (load (field state creationText))
        length (load (field state creationLength))
        target (+ (- horizontal textLeft) (creation-text-scroll state visibleWidth))
        (mut offset) 0]
    (loop (if (>= (load offset) length)
            (break length)
            (let [next (next-text-offset text length (load offset))
                  leftWidth (text-width-through (field state sans) text (load offset) 11.5)
                  rightWidth (text-width-through (field state sans) text next 11.5)]
              (if (< target (/ (+ leftWidth rightWidth) 2.0))
                (break (load offset))
                (store! offset next)))))))

;; Read-only text selection for content blocks (agent output, designer replies).
;; A block registers itself at draw time with a stable region id; the selection
;; lives in AppState and survives frames until a press lands outside every block.
(defn text-line-advance [(size f64)] (-> f64)
  (+ (* size 1.16) 2.0))

(defn line-end-offset [(text (ptr i8)) (length i64) (lineStart i64)] (-> i64)
  (let [(mut offset) lineStart]
    (loop (if (or (>= (load offset) length)
                  (= (cast i64 (load (index text (load offset)))) 10))
            (break (load offset))
            (store! offset (+ (load offset) 1))))))

(defn count-text-lines [(text (ptr i8)) (length i64)] (-> i64)
  (let [(mut count) 1
        (mut position) 0]
    (do
      (while (< (load position) length)
        (do
          (if (= (cast i64 (load (index text (load position)))) 10)
            (store! count (+ (load count) 1))
            0)
          (store! position (+ (load position) 1))))
      (load count))))

(defn segment-width [(state AppState)
                     (font raylib.Font)
                     (text (ptr i8))
                     (segmentStart i64)
                     (segmentEnd i64)
                     (size f64)] (-> f64)
  (let [buffer (load (field state measureText))
        span (- segmentEnd segmentStart)
        count (if (> span 4095) 4095 span)
        (mut position) 0]
    (do
      (while (< (load position) count)
        (do
          (store! (index buffer (load position)) (load (index text (+ segmentStart (load position)))))
          (store! position (+ (load position) 1))))
      (store! (index buffer count) (cast i8 0))
      (let [measured (raylib.MeasureTextEx (load font) buffer (cast f32 (* size 1.16)) (cast f32 0.18))]
        (cast f64 (load (field measured x)))))))

;; Greedy word wrap, in place: spaces become newlines where the measured line
;; would overflow, so text length and selection offsets stay stable.
(defn wrap-text-in-place [(state AppState)
                          (text (ptr i8))
                          (font raylib.Font)
                          (size f64)
                          (maxWidth f64)] (-> i64)
  (let [(mut lineStart) 0
        (mut lastSpace) -1
        (mut position) 0]
    (do
      (loop
        (let [byte (cast i64 (load (index text (load position))))]
          (if (= byte 0)
            (break 0)
            (do
              (cond (= byte 10)
                      (do
                        (store! lineStart (+ (load position) 1))
                        (store! lastSpace -1)
                        0)
                    (= byte 32)
                      (do
                        (if (and (>= (load lastSpace) 0)
                                 (> (segment-width state font text (load lineStart) (load position) size)
                                    maxWidth))
                          (do
                            (store! (index text (load lastSpace)) (cast i8 10))
                            (store! lineStart (+ (load lastSpace) 1))
                            0)
                          0)
                        (store! lastSpace (load position))
                        0)
                    0)
              (store! position (+ (load position) 1))))))
      (if (and (>= (load lastSpace) 0)
               (> (segment-width state font text (load lineStart) (load position) size) maxWidth))
        (do (store! (index text (load lastSpace)) (cast i8 10)) 0)
        0)
      0)))

(defn region-offset-at [(state AppState)
                        (font raylib.Font)
                        (text (ptr i8))
                        (length i64)
                        (left f64)
                        (top f64)
                        (size f64)
                        (horizontal f64)
                        (vertical f64)] (-> i64)
  (let [advance (text-line-advance size)
        targetLine
          (let [raw (cast i64 (/ (- vertical top) advance))]
            (if (< raw 0) 0 raw))
        (mut lineStart) 0
        (mut remaining) targetLine
        (mut pastEnd) 0]
    (do
      (while (> (load remaining) 0)
        (let [lineEnd (line-end-offset text length (load lineStart))]
          (if (>= lineEnd length)
            (do
              (store! pastEnd 1)
              (store! remaining 0)
              0)
            (do
              (store! lineStart (+ lineEnd 1))
              (store! remaining (- (load remaining) 1))
              0))))
      (if (= (load pastEnd) 1)
        length
        (let [lineEnd (line-end-offset text length (load lineStart))
              target (- horizontal left)
              (mut offset) (load lineStart)]
          (if (<= target 0.0)
            (load lineStart)
            (loop (if (>= (load offset) lineEnd)
                    (break lineEnd)
                    (let [next (next-text-offset text lineEnd (load offset))
                          leftWidth (segment-width state font text (load lineStart) (load offset) size)
                          rightWidth (segment-width state font text (load lineStart) next size)]
                      (if (< target (/ (+ leftWidth rightWidth) 2.0))
                        (break (load offset))
                        (store! offset next)))))))))))

(defn draw-region-highlight [(state AppState)
                             (font raylib.Font)
                             (text (ptr i8))
                             (length i64)
                             (left f64)
                             (top f64)
                             (size f64)
                             (start i64)
                             (end i64)] (-> i64)
  (let [advance (text-line-advance size)
        (mut lineStart) 0
        (mut lineIndex) 0]
    (loop
      (let [lineEnd (line-end-offset text length (load lineStart))
            segmentStart (if (> start (load lineStart)) start (load lineStart))
            segmentEnd (if (< end lineEnd) end lineEnd)]
        (do
          (if (< segmentStart segmentEnd)
            (let [leftEdge (segment-width state font text (load lineStart) segmentStart size)
                  rightEdge (segment-width state font text (load lineStart) segmentEnd size)
                  newlineTail (if (and (< lineEnd length) (> end lineEnd)) 5.0 0.0)]
              (fill-rectangle (+ left leftEdge)
                              (+ top (- (* (cast f64 (load lineIndex)) advance) 2.0))
                              (+ (- rightEdge leftEdge) newlineTail)
                              (+ (* size 1.16) 5.0)
                              (color-alpha 74 121 178 110)))
            0)
          (if (>= lineEnd length)
            (break 0)
            (do
              (store! lineStart (+ lineEnd 1))
              (store! lineIndex (+ (load lineIndex) 1))
              0)))))))

(defn copy-region-text [(state (mut AppState)) (text (ptr i8)) (start i64) (end i64)] (-> i64)
  (let [destination (load (field state clipboardText))
        span (- end start)
        count (if (> span 4095) 4095 span)
        (mut position) 0]
    (do
      (while (< (load position) count)
        (do
          (store! (index destination (load position)) (load (index text (+ start (load position)))))
          (store! position (+ (load position) 1))))
      (store! (index destination count) (cast i8 0))
      (store! (field state clipboardRequested) 1)
      0)))

(defn selectable-text [(state (mut AppState))
                       (input InputFrame)
                       (region i64)
                       (font raylib.Font)
                       (text (ptr i8))
                       (left f64)
                       (top f64)
                       (size f64)
                       (tint raylib.Color)] (-> i64)
  (let [length (byte-text-length text)]
    (if (= length 0)
      (draw-text font text left top size tint)
      (let [advance (text-line-advance size)
            measured (raylib.MeasureTextEx (load font) text (cast f32 (* size 1.16)) (cast f32 0.18))
            width (cast f64 (load (field measured x)))
            height (* (cast f64 (count-text-lines text length)) advance)
            mouseHorizontal (load (field input mouseHorizontal))
            mouseVertical (load (field input mouseVertical))
            hovering (in-bounds mouseHorizontal mouseVertical (- left 2.0) (- top 2.0) (+ width 4.0) (+ height 4.0))
            editing
              (if (and (= (load (field state creationOpen)) 1) (= (load (field state creationFocused)) 1)) 1 0)]
        (do
          (if hovering (store! (field state hoverSelectableText) 1) 0)
          (if (and hovering (= (load (field input pressed)) 1))
            (let [offset (region-offset-at state font text length left top size mouseHorizontal mouseVertical)]
              (do
                (store! (field state selectionRegion) region)
                (store! (field state selectionAnchor) offset)
                (store! (field state selectionFocus) offset)
                (store! (field state selectionDragging) 1)
                (store! (field state selectionPressHandled) 1)
                0))
            0)
          (if (= (load (field state selectionRegion)) region)
            (do
              (if (> (load (field state selectionAnchor)) length) (store! (field state selectionAnchor) length) 0)
              (if (> (load (field state selectionFocus)) length) (store! (field state selectionFocus) length) 0)
              (if (and (= (load (field state selectionDragging)) 1) (= (load (field input down)) 1))
                (store! (field state selectionFocus)
                        (region-offset-at state font text length left top size mouseHorizontal mouseVertical))
                0)
              (if (= (load (field input down)) 0) (store! (field state selectionDragging) 0) 0)
              (if (and (= (load (field input selectAllPressed)) 1) (= editing 0))
                (do
                  (store! (field state selectionAnchor) 0)
                  (store! (field state selectionFocus) length)
                  0)
                0)
              (let [anchor (load (field state selectionAnchor))
                    focus (load (field state selectionFocus))
                    start (if (< anchor focus) anchor focus)
                    end (if (> anchor focus) anchor focus)]
                (do
                  (if (< start end)
                    (draw-region-highlight state font text length left top size start end)
                    0)
                  (if (and (= (load (field input copyPressed)) 1)
                           (and (= editing 0) (< start end)))
                    (copy-region-text (mut state) text start end)
                    0)
                  0)))
            0)
          (draw-text font text left top size tint)
          0)))))

(defn apply-input [(state (mut AppState)) (input InputFrame) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [mouseHorizontal (load (field input mouseHorizontal))
        mouseVertical (load (field input mouseVertical))
        rightStart (- screenWidth RIGHT_WIDTH)
        center (/ (cast f64 (+ LEFT_WIDTH rightStart)) 2.0)
        catalog (load (field state catalog))
        catalogCount (workflow.catalog-count catalog)]
    (if (= (load (field state creationOpen)) 1)
      (do
        (let [textLeft (cast f64 (+ rightStart 54))
              textTop (cast f64 (- screenHeight 58))
              textWidth (cast f64 (- RIGHT_WIDTH 102))]
          (do
            (if (= (load (field input pressed)) 1)
              (if (in-bounds mouseHorizontal mouseVertical textLeft textTop textWidth 40.0)
                (let [offset (creation-offset-at state mouseHorizontal textLeft textWidth)]
                  (do
                    (store! (field state creationFocused) 1)
                    (store! (field state creationDragging) 1)
                    (store! (field state creationAnchor) offset)
                    (store! (field state creationFocus) offset)
                    0))
                (if (!= (load (field input enterPressed)) 1)
                  (do (store! (field state creationFocused) 0) 0)
                  0))
              0)
            (if (and (= (load (field input down)) 1) (= (load (field state creationDragging)) 1))
              (store! (field state creationFocus) (creation-offset-at state mouseHorizontal textLeft textWidth))
              0)
            (if (= (load (field input down)) 0) (store! (field state creationDragging) 0) 0)
            0))
        (edit-creation-text (mut state) input)
        (if (and (!= (load (field state designState)) 1)
                 (or (and (= (load (field state creationFocused)) 1)
                          (= (load (field input enterPressed)) 1))
                     (and (= (load (field input pressed)) 1)
                          (in-bounds mouseHorizontal
                                     mouseVertical
                                     (cast f64 (- screenWidth 48))
                                     (cast f64 (- screenHeight 41))
                                     28.0
                                     28.0))))
          (if (> (load (field state creationLength)) 0)
            (do
              (store! (field state designRequested) 1)
              (store! (field state designState) 1)
              0)
            0)
          0)
        (if (and (= (load (field input pressed)) 1)
                 (and (> (load (field state designTurn)) 0)
                      (in-bounds mouseHorizontal
                                 mouseVertical
                                 (cast f64 (- rightStart 214))
                                 14.0
                                 184.0
                                 34.0)))
          (do
            (store! (field state creationRequested) 1)
            (store! (field state creationOpen) 0)
            0)
          0)
        0)
      (if (= (load (field input pressed)) 0)
        0
        (do
          (if (or (in-bounds mouseHorizontal mouseVertical 8.0 (cast f64 (- screenHeight 86)) 228.0 34.0)
                  (and (= catalogCount 0)
                       (in-bounds mouseHorizontal
                                  mouseVertical
                                  (- (/ (cast f64 (+ LEFT_WIDTH screenWidth)) 2.0) 116.0)
                                  477.0
                                  232.0
                                  42.0)))
            (do
              (store! (field state creationOpen) 1)
              (store! (field state creationState) 0)
              (store! (field state creationLength) 0)
              (store! (field state creationAnchor) 0)
              (store! (field state creationFocus) 0)
              (store! (field state creationFocused) 1)
              (store! (field state creationDragging) 0)
              (store! (field state creationTruncated) 0)
              (store! (field state designState) 0)
              (store! (field state designTurn) 0)
              (store! (load (field state creationText)) (cast i8 0))
              (store! (load (field state designResponse)) (cast i8 0))
              (store! (load (field state designRequest)) (cast i8 0))
              (store! (field state designPreviewValid) 0)
              0)
            0)
          (for [project 0
                8]
            (if (and (< project (workflow.catalog-count catalog))
                     (in-bounds mouseHorizontal mouseVertical 8.0 (cast f64 (+ 76 (* project 58))) 228.0 51.0))
              (do
                (store! (field state selectedProject) project)
                (store! (field state runtime) (workflow.catalog-runtime catalog project))
                (store! (field state selectedNode) 0)
                (store! (field state approvalGranted) 0)
                (store! (field state creationOpen) 0)
                0)
              0))
          (if (> catalogCount 0)
            (let [runtime (load (field state runtime))
                  depths (cast (ptr i64) (cast i64 (alloc-stack (array i64 7))))
                  columns (cast (ptr i64) (cast i64 (alloc-stack (array i64 7))))
                  rowCounts (cast (ptr i64) (cast i64 (alloc-stack (array i64 7))))
                  maxDepth (compute-flow-layout runtime depths columns rowCounts)]
              (for [node 0
                    7]
                (if (and (< node (workflow.node-count runtime))
                         (in-bounds mouseHorizontal
                                    mouseVertical
                                    (- (layout-horizontal (load (index columns node))
                                                          (load (index rowCounts (load (index depths node))))
                                                          center)
                                       20.0)
                                    (- (layout-vertical (load (index depths node)) maxDepth screenHeight) 20.0)
                                    40.0
                                    40.0))
                  (do (store! (field state selectedNode) node) 0)
                  0)))
            0)
          (if (and (> catalogCount 0)
                   (and (= (workflow.node-status (load (field state runtime)) (load (field state selectedNode))) 4)
                        (in-bounds mouseHorizontal
                                   mouseVertical
                                   (cast f64 (+ rightStart 20))
                                   (cast f64 (- screenHeight 174))
                                   112.0
                                   34.0)))
            (do (store! (field state approvalRequested) 1) 0)
            0)
          (if (and (> catalogCount 0)
                   (in-bounds mouseHorizontal mouseVertical (cast f64 (- rightStart 214)) 14.0 116.0 34.0))
            (do (store! (field state runRequested) 1) 0)
            0)
          0)))))

(defn draw-grid [(left i64) (right i64) (height i64)] (-> i64)
  (let [gridHorizontal (alloc-stack i64)
        gridVertical (alloc-stack i64)]
    (do
      (store! gridHorizontal left)
      (store! gridVertical HEADER_HEIGHT)
      (while (< (load gridHorizontal) right)
        (do
          (line (cast f64 (load gridHorizontal))
                (cast f64 HEADER_HEIGHT)
                (cast f64 (load gridHorizontal))
                (cast f64 height)
                1.0
                (color-alpha 14 20 27 150))
          (store! gridHorizontal (+ (load gridHorizontal) 32))))
      (while (< (load gridVertical) height)
        (do
          (line (cast f64 left)
                (cast f64 (load gridVertical))
                (cast f64 right)
                (cast f64 (load gridVertical))
                1.0
                (color-alpha 14 20 27 150))
          (store! gridVertical (+ (load gridVertical) 32))))
      0)))

(defn draw-projects [(state AppState) (height i64)] (-> i64)
  (let [selected (load (field state selectedProject))
        catalog (load (field state catalog))]
    (do
      (fill-rectangle 0.0 0.0 (cast f64 LEFT_WIDTH) (cast f64 height) (color 9 12 17))
      (line (cast f64 (- LEFT_WIDTH 1)) 0.0 (cast f64 (- LEFT_WIDTH 1)) (cast f64 height) 1.0 (color 23 30 39))
      (line 0.0 55.0 (cast f64 LEFT_WIDTH) 55.0 1.0 (color 20 26 34))
      (stroke-rectangle 18.0 19.0 15.0 15.0 1.0 (accent selected))
      (fill-rectangle 23.0 24.0 5.0 5.0 (accent selected))
      (draw-text (field state monoMedium) c"flowline" 43.0 18.0 13.0 (color 223 229 236))
      (draw-text (field state mono) c"v0.4" 198.0 21.0 9.0 (color 69 78 90))
      (draw-text (field state monoMedium) c"PROJECTS" 16.0 64.0 9.0 (color 61 69 79))
      (for [project 0
            8]
        (if (< project (workflow.catalog-count catalog))
          (let [rowTop (+ 76 (* project 58))
                active (= project selected)]
            (do
              (if active
                (do
                  (fill-rectangle 8.0 (cast f64 rowTop) 228.0 51.0 (color-alpha 224 165 58 17))
                  (fill-rectangle 8.0 (cast f64 (+ rowTop 8)) 2.0 35.0 (accent project))
                  0)
                0)
              (if active
                (fill-rectangle 20.0 (cast f64 (+ rowTop 17)) 8.0 8.0 (accent project))
                (stroke-rectangle 20.0 (cast f64 (+ rowTop 17)) 8.0 8.0 1.0 (accent project)))
              (draw-text (field state monoMedium)
                         (display-project-name state project)
                         39.0
                         (cast f64 (+ rowTop 10))
                         12.0
                         (if active (color 238 242 246) (color 107 116 128)))
              (draw-text (field state mono)
                         (display-project-subtitle state project)
                         39.0
                         (cast f64 (+ rowTop 29))
                         9.5
                         (color 76 85 97))
              (if active
                (do
                  (raylib.DrawCircle (cast i32 220) (cast i32 (+ rowTop 22)) (cast f32 3.0) (accent project))
                  0)
                (do
                  (raylib.DrawCircleLines (cast i32 220) (cast i32 (+ rowTop 22)) (cast f32 3.0) (color 42 51 63))
                  0))
              0))
          0))
      (stroke-rectangle 8.0 (cast f64 (- height 86)) 228.0 34.0 1.0 (color 35 44 56))
      (draw-text (field state monoMedium)
                 (case (load (field state creationState)) 1
                       c"... CREATING WORKFLOW" 2
                       c"+  WORKFLOW CREATED" 3
                       c"!  CREATION FAILED" c"+  NEW WORKFLOW")
                 20.0
                 (cast f64 (- height 76))
                 10.0
                 (accent selected))
      (line 0.0 (cast f64 (- height 41)) (cast f64 LEFT_WIDTH) (cast f64 (- height 41)) 1.0 (color 20 26 34))
      (fill-rectangle 16.0 (cast f64 (- height 22)) 6.0 6.0 (color 42 51 63))
      (draw-text (field state mono) c"DISK-BACKED WORKFLOW CATALOG" 30.0 (cast f64 (- height 26)) 8.5 (color 61 69 79))
      0)))

(defn draw-edge [(fromHorizontal f64)
                 (fromVertical f64)
                 (toHorizontal f64)
                 (toVertical f64)
                 (active bool)
                 (tint raylib.Color)] (-> i64)
  (let [middleVertical (/ (+ fromVertical toVertical) 2.0)
        edgeColor (if active (load tint) (color-alpha 87 97 113 125))
        thickness (if active 1.8 1.2)]
    (do
      (if (fcmp-eq fromHorizontal toHorizontal)
        (line fromHorizontal fromVertical toHorizontal toVertical thickness edgeColor)
        (do
          (line fromHorizontal fromVertical fromHorizontal middleVertical thickness edgeColor)
          (line fromHorizontal middleVertical toHorizontal middleVertical thickness edgeColor)
          (line toHorizontal middleVertical toHorizontal toVertical thickness edgeColor)
          0))
      (if active
        (let [travel (fmod (* (raylib.GetTime) 72.0) 34.0)]
          (fill-rectangle (- toHorizontal 2.5) (- toVertical travel) 5.0 5.0 tint))
        0)
      0)))

(defn draw-node-symbol [(horizontal f64) (vertical f64) (node i64) (status i64) (pulse f64) (tint raylib.Color)] (-> i64)
  (cond (= status 2)
          (do
            (stroke-rectangle (- horizontal (+ 12.0 (* pulse 5.0)))
                              (- vertical (+ 12.0 (* pulse 5.0)))
                              (* 2.0 (+ 12.0 (* pulse 5.0)))
                              (* 2.0 (+ 12.0 (* pulse 5.0)))
                              1.0
                              (color-alpha 224 165 58 (cast i64 (+ 55.0 (* pulse 55.0)))))
            (fill-rectangle (- horizontal 7.5) (- vertical 7.5) 15.0 15.0 tint)
            0)
        (= status 3) (fill-rectangle (- horizontal 7.0) (- vertical 7.0) 14.0 14.0 (color-alpha 224 165 58 155))
        (= status 4) (stroke-rectangle (- horizontal 7.0) (- vertical 7.0) 14.0 14.0 1.5 tint)
        (= status 5) (stroke-rectangle (- horizontal 7.0) (- vertical 7.0) 14.0 14.0 1.5 (color 211 91 85))
        (= node 1)
          (do
            (for [square 0
                  3]
              (fill-rectangle (+ (- horizontal 12.0) (cast f64 (* square 10)))
                              (- vertical 2.5)
                              5.0
                              5.0
                              (color-alpha 224 165 58 110)))
            0)
        (stroke-rectangle (- horizontal 6.5) (- vertical 6.5) 13.0 13.0 1.5 (color 61 69 79))))

(defn draw-flow [(state AppState)
                 (runtime workflow.Runtime)
                 (selected i64)
                 (rightStart i64)
                 (screenHeight i64)
                 (tint raylib.Color)] (-> i64)
  (let [center (/ (cast f64 (+ LEFT_WIDTH rightStart)) 2.0)
        time (raylib.GetTime)
        pulse (+ 1.0 (* 0.5 (sin (* time 4.0))))
        depths (cast (ptr i64) (cast i64 (alloc-stack (array i64 7))))
        columns (cast (ptr i64) (cast i64 (alloc-stack (array i64 7))))
        rowCounts (cast (ptr i64) (cast i64 (alloc-stack (array i64 7))))
        maxDepth (compute-flow-layout runtime depths columns rowCounts)]
    (do
      (for [node 0
            7]
        (if (< node (workflow.node-count runtime))
          (do
            (for [dependencySlot 0
                  2]
              (let [dependency (workflow.node-dependency runtime node dependencySlot)]
                (if (>= dependency 0)
                  (draw-edge (layout-horizontal (load (index columns dependency))
                                                (load (index rowCounts (load (index depths dependency))))
                                                center)
                             (+ (layout-vertical (load (index depths dependency)) maxDepth screenHeight) 20.0)
                             (layout-horizontal (load (index columns node))
                                                (load (index rowCounts (load (index depths node))))
                                                center)
                             (- (layout-vertical (load (index depths node)) maxDepth screenHeight) 20.0)
                             (or (= (workflow.node-status runtime node) 2)
                                 (= (workflow.node-status runtime node) 4))
                             tint)
                  0)))
            0)
          0))
      (if (= (load (index rowCounts 0)) 1)
        (line center 68.0 center (- (layout-vertical 0 maxDepth screenHeight) 20.0) 1.0 (color-alpha 224 165 58 80))
        0)
      (if (= (load (index rowCounts maxDepth)) 1)
        (let [bottom (layout-vertical maxDepth maxDepth screenHeight)]
          (line center (+ bottom 20.0) center (+ bottom 53.0) 1.0 (color-alpha 224 165 58 80)))
        0)
      (for [node 0
            7]
        (if (< node (workflow.node-count runtime))
          (let [horizontal
                  (layout-horizontal (load (index columns node))
                                     (load (index rowCounts (load (index depths node))))
                                     center)
                vertical (layout-vertical (load (index depths node)) maxDepth screenHeight)
                chosen (= node selected)
                numberLabel (case node 0 c"[1]" 1 c"[2]" 2 c"[3]" 3 c"[4]" 4 c"[5]" 5 c"[6]" c"[7]")]
            (do
              (if chosen (stroke-rectangle (- horizontal 16.0) (- vertical 16.0) 32.0 32.0 1.0 tint) 0)
              (draw-node-symbol horizontal vertical node (workflow.node-status runtime node) pulse tint)
              (if (< horizontal center)
                (do
                  (draw-text (field state mono)
                             (workflow.node-title runtime node)
                             (- horizontal 175.0)
                             (- vertical 6.0)
                             10.5
                             (if chosen (load tint) (color 88 97 113)))
                  (draw-text (field state monoMedium)
                             numberLabel
                             (- horizontal 62.0)
                             (- vertical 6.0)
                             10.0
                             (if chosen (load tint) (color 127 136 148)))
                  (line (- horizontal 34.0) vertical (- horizontal 10.0) vertical 1.0 (color-alpha 224 165 58 100))
                  0)
                (do
                  (line (+ horizontal 10.0) vertical (+ horizontal 34.0) vertical 1.0 (color-alpha 224 165 58 100))
                  (draw-text (field state monoMedium)
                             numberLabel
                             (+ horizontal 42.0)
                             (- vertical 6.0)
                             10.0
                             (if chosen (load tint) (color 127 136 148)))
                  (draw-text (field state mono)
                             (workflow.node-title runtime node)
                             (+ horizontal 70.0)
                             (- vertical 6.0)
                             10.5
                             (if chosen (load tint) (color 88 97 113)))
                  0))
              0))
          0))
      0)))

(defn draw-center [(state AppState) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [rightStart (- screenWidth RIGHT_WIDTH)
        centerWidth (- rightStart LEFT_WIDTH)
        project (load (field state selectedProject))
        tint (accent project)]
    (do
      (fill-rectangle (cast f64 LEFT_WIDTH) 0.0 (cast f64 centerWidth) (cast f64 screenHeight) (color 7 10 14))
      (draw-grid LEFT_WIDTH rightStart screenHeight)
      (fill-rectangle (cast f64 LEFT_WIDTH) 0.0 (cast f64 centerWidth) (cast f64 HEADER_HEIGHT) (color 7 10 14))
      (line (cast f64 LEFT_WIDTH) 63.0 (cast f64 rightStart) 63.0 1.0 (color 20 26 34))
      (let [runtime (load (field state runtime))
            nodeCount (workflow.node-count runtime)
            statusBuffer (cast (ptr i8) (cast i64 (alloc-stack (array i8 64))))
            badgeLeft (cast f64 (- rightStart 318))
            (mut doneCount) 0
            (mut anyFailed) 0]
        (do
          (for [node 0
                7]
            (if (< node nodeCount)
              (do
                (if (= (workflow.node-status runtime node) 3) (store! doneCount (+ (load doneCount) 1)) 0)
                (if (= (workflow.node-status runtime node) 5) (store! anyFailed 1) 0)
                0)
              0))
          (snprintf statusBuffer
                    64
                    c"%lld/%lld / %s"
                    (load doneCount)
                    nodeCount
                    (cond (= (load anyFailed) 1) c"failed"
                          (= (load doneCount) nodeCount) c"done"
                          (workflow.is-started runtime) c"running"
                          c"idle"))
          (begin-scissor 268.0 10.0 (- badgeLeft 280.0) 28.0)
          (draw-text (field state monoMedium) (display-project-name state project) 268.0 14.0 15.0 (color 223 229 236))
          (raylib.EndScissorMode)
          (stroke-rectangle badgeLeft 13.0 88.0 20.0 1.0 (color-alpha 224 165 58 100))
          (draw-text (field state monoMedium) statusBuffer (+ badgeLeft 7.0) 18.0 9.0 tint)
          0))
      (draw-text (field state mono) c"~/" 268.0 39.0 10.5 (color 76 85 97))
      (begin-scissor 289.0 34.0 123.0 20.0)
      (draw-text (field state mono) (display-project-path state project) 289.0 39.0 10.5 (color 76 85 97))
      (raylib.EndScissorMode)
      (draw-text (field state mono) c">" 420.0 39.0 10.5 tint)
      (draw-text (field state mono) (display-project-subtitle state project) 436.0 39.0 10.5 (color 76 85 97))
      (stroke-rectangle (cast f64 (- rightStart 214)) 14.0 116.0 34.0 1.0 (color-alpha 224 165 58 130))
      (draw-text (field state monoMedium)
                 (if (workflow.is-started (load (field state runtime))) c"RUN AGAIN" c"RUN WORKFLOW")
                 (cast f64 (- rightStart 199))
                 24.0
                 9.5
                 tint)
      (fill-rectangle (cast f64 (- rightStart 76)) 23.0 7.0 7.0 tint)
      (draw-text (field state monoMedium) c"LIVE" (cast f64 (- rightStart 58)) 21.0 10.0 tint)
      (draw-flow state
                 (load (field state runtime))
                 (load (field state selectedNode))
                 rightStart
                 screenHeight
                 tint)
      0)))

(defn draw-card-background [(left f64) (top f64) (width f64) (height f64) (leftAccent bool) (tint raylib.Color)] (-> i64)
  (do
    (fill-rectangle left top width height (color 13 18 25))
    (stroke-rectangle left top width height 1.0 (color 27 35 46))
    (if leftAccent (fill-rectangle left top 2.0 height tint) 0)
    0))

(defn draw-refund-composition [(state AppState) (left f64) (width f64) (tint raylib.Color)] (-> i64)
  (do
    (line (+ left 3.0) 145.0 (+ left 3.0) 213.0 1.0 (color 35 44 56))
    (draw-text (field state monoMedium) c"// REASONING" (+ left 15.0) 145.0 9.0 (color 76 85 97))
    (draw-text (field state sans)
               c"Both sub-agents returned: eligible and confirmed\nduplicate. Composing a $48.00 refund to the original\ncard plus a customer reply with an apology."
               (+ left 15.0)
               166.0
               12.0
               (color 107 116 128))
    (draw-card-background left 232.0 width 99.0 false tint)
    (fill-rectangle left 232.0 width 34.0 (color 13 18 25))
    (line left 266.0 (+ left width) 266.0 1.0 (color 20 26 34))
    (draw-text (field state monoMedium) c">" (+ left 12.0) 243.0 11.0 tint)
    (draw-text (field state monoMedium) c"draft_reply" (+ left 31.0) 242.0 11.0 (color 207 214 222))
    (draw-text (field state mono) c"TOOL" (+ left (- width 42.0)) 243.0 9.0 (color 61 69 79))
    (draw-text (field state mono)
               c"in   { amount: 48.00, tone: apologetic }"
               (+ left 12.0)
               276.0
               10.5
               (color 127 136 148))
    (draw-text (field state mono) c"out  Draft generated." (+ left 12.0) 305.0 10.5 (color 167 176 187))
    (draw-card-background left 347.0 width 82.0 true tint)
    (fill-rectangle (+ left 13.0) 360.0 6.0 6.0 tint)
    (draw-text (field state monoMedium) c"ORCHESTRATOR" (+ left 27.0) 356.0 9.0 (color 127 136 148))
    (draw-text (field state sans)
               c"Draft ready: refund $48.00 to the original card,\n5-7 business day ETA, with an apology."
               (+ left 13.0)
               381.0
               12.5
               (color 200 207 216))
    (draw-card-background left 445.0 190.0 47.0 false tint)
    (stroke-rectangle (+ left 11.0) 455.0 22.0 27.0 1.0 (color 42 51 63))
    (draw-text (field state monoMedium) c"draft_reply.md" (+ left 45.0) 453.0 11.5 tint)
    (draw-text (field state mono) c"1.2 KB / markdown" (+ left 45.0) 473.0 9.5 (color 76 85 97))
    (draw-text (field state mono) c"tokens  2,481" left 511.0 9.5 (color 127 136 148))
    (draw-text (field state mono) c"time  1.8s" (+ left 118.0) 511.0 9.5 (color 127 136 148))
    (draw-text (field state mono) c"cost  $0.011" (+ left 222.0) 511.0 9.5 (color 127 136 148))
    0))

(defn draw-approval [(state (mut AppState)) (input InputFrame) (left f64) (width f64) (height i64) (tint raylib.Color)] (-> i64)
  (let [approved (load (field state approvalGranted))
        cardY (cast f64 (- height 244))]
    (do
      (draw-card-background left 148.0 width 82.0 true tint)
      (fill-rectangle (+ left 13.0) 161.0 6.0 6.0 tint)
      (draw-text (field state monoMedium) c"ORCHESTRATOR" (+ left 27.0) 157.0 9.0 (color 127 136 148))
      (selectable-text (mut state)
                       input
                       3
                       (field state sans)
                       c"Refund is under threshold, but this account was flagged\nfor a billing spot-check before payout."
                       (+ left 13.0)
                       182.0
                       12.5
                       (color 200 207 216))
      (fill-rectangle left cardY width 122.0 (color 20 16 10))
      (stroke-rectangle left cardY width 122.0 1.0 (color 74 58 26))
      (stroke-rectangle (+ left 13.0) (+ cardY 14.0) 9.0 9.0 1.5 tint)
      (draw-text (field state monoMedium)
                 (if (= approved 1) c"APPROVAL RECORDED" c"HUMAN APPROVAL REQUIRED")
                 (+ left 31.0)
                 (+ cardY 11.0)
                 9.0
                 tint)
      (selectable-text (mut state)
                       input
                       4
                       (field state sans)
                       (if (= approved 1)
                         c"Approved. The payout step is ready to continue."
                         c"Issue a $48.00 refund to card ending 4821 and send\nthe drafted reply?")
                       (+ left 13.0)
                       (+ cardY 40.0)
                       12.5
                       (color 185 172 147))
      (fill-rectangle left (cast f64 (- height 174)) 112.0 34.0 (if (= approved 1) (color 58 82 67) (load tint)))
      (draw-text (field state monoMedium)
                 (if (= approved 1) c"APPROVED" c"APPROVE  >")
                 (+ left 15.0)
                 (cast f64 (- height 164))
                 10.5
                 (color 10 14 19))
      0)))

(defn draw-generic-feed [(state (mut AppState)) (input InputFrame) (left f64) (width f64) (project i64) (node i64) (tint raylib.Color)] (-> i64)
  (let [runtime (load (field state runtime))
        status (workflow.node-status runtime node)
        output (workflow.node-output runtime node)]
    (do
      (draw-card-background left 148.0 width 84.0 true tint)
      (fill-rectangle (+ left 13.0) 161.0 6.0 6.0 tint)
      (draw-text (field state monoMedium) c"ORCHESTRATOR" (+ left 27.0) 157.0 9.0 (color 127 136 148))
      (selectable-text (mut state)
                       input
                       1
                       (field state sans)
                       c"This step is backed by the loaded workflow program. Its\nstate changes only when dependencies and agents complete."
                       (+ left 13.0)
                       182.0
                       12.5
                       (color 200 207 216))
      (line (+ left 3.0) 258.0 (+ left 3.0) 326.0 1.0 (color 35 44 56))
      (draw-text (field state monoMedium) c"// STATE" (+ left 15.0) 258.0 9.0 (color 76 85 97))
      (draw-text (field state mono) (display-project-name state project) (+ left 15.0) 281.0 11.0 tint)
      (draw-text (field state mono)
                 (display-node-title state project node)
                 (+ left 15.0)
                 303.0
                 11.0
                 (color 127 136 148))
      (draw-card-background left 349.0 width 73.0 false tint)
      (draw-text (field state monoMedium) c"> workflow.inspect" (+ left 13.0) 362.0 11.0 (color 207 214 222))
      (draw-text (field state mono)
                 (workflow.status-label status)
                 (+ left 13.0)
                 393.0
                 10.5
                 (color 167 176 187))
      (if (icmp-ne (load output) (cast i8 0))
        (do
          (if (or (!= (load (field state wrappedOutput)) output)
                  (!= (load (field state wrappedOutputLength)) (byte-text-length output)))
            (do
              (wrap-text-in-place state output (field state sans) 11.0 432.0)
              (store! (field state wrappedOutput) output)
              (store! (field state wrappedOutputLength) (byte-text-length output))
              0)
            0)
          (draw-text (field state monoMedium) c"// AGENT OUTPUT" left 453.0 9.0 (color 76 85 97))
          (selectable-text (mut state) input 2 (field state sans) output left 478.0 11.0 (color 184 193 204))
          0)
        0)
      0)))

(defn draw-right [(state (mut AppState)) (input InputFrame) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [rightStart (- screenWidth RIGHT_WIDTH)
        contentLeft (cast f64 (+ rightStart 20))
        width (cast f64 (- RIGHT_WIDTH 40))
        project (load (field state selectedProject))
        node (load (field state selectedNode))
        tint (accent project)]
    (do
      (fill-rectangle (cast f64 rightStart) 0.0 (cast f64 RIGHT_WIDTH) (cast f64 screenHeight) (color 9 12 17))
      (line (cast f64 rightStart) 0.0 (cast f64 rightStart) (cast f64 screenHeight) 1.0 (color 23 30 39))
      (line (cast f64 rightStart) 112.0 (cast f64 screenWidth) 112.0 1.0 (color 20 26 34))
      (begin-scissor contentLeft 11.0 126.0 18.0)
      (draw-text (field state mono) (display-project-path state project) contentLeft 15.0 9.5 (color 61 69 79))
      (raylib.EndScissorMode)
      (draw-text (field state mono) c"/" (+ contentLeft 132.0) 15.0 9.5 tint)
      (begin-scissor (+ contentLeft 146.0) 11.0 (- (cast f64 screenWidth) (+ contentLeft 166.0)) 18.0)
      (draw-text (field state mono)
                 (display-node-title state project node)
                 (+ contentLeft 146.0)
                 15.0
                 9.5
                 (color 107 116 128))
      (raylib.EndScissorMode)
      (draw-text (field state monoMedium)
                 (case node 0 c"[1]" 1 c"[2]" 2 c"[3]" 3 c"[4]" 4 c"[5]" 5 c"[6]" c"[7]")
                 contentLeft
                 50.0
                 15.0
                 tint)
      (begin-scissor (+ contentLeft 38.0) 44.0 (- (cast f64 (- screenWidth 129)) (+ contentLeft 38.0)) 28.0)
      (draw-text (field state monoMedium)
                 (display-node-title state project node)
                 (+ contentLeft 38.0)
                 50.0
                 15.0
                 (color 223 229 236))
      (raylib.EndScissorMode)
      (stroke-rectangle (cast f64 (- screenWidth 117))
                        45.0
                        97.0
                        23.0
                        1.0
                        (if (= node 4) (color-alpha 224 165 58 120) (color 38 49 61)))
      (draw-text (field state monoMedium)
                 (workflow.status-label (workflow.node-status (load (field state runtime)) node))
                 (cast f64 (- screenWidth 104))
                 51.0
                 9.5
                 (if (>= node 4) (load tint) (color 111 154 126)))
      (if (= (workflow.node-kind (load (field state runtime)) node) 1)
        (draw-approval (mut state) input contentLeft width screenHeight tint)
        (draw-generic-feed (mut state) input contentLeft width project node tint))
      (fill-rectangle (cast f64 rightStart) (cast f64 (- screenHeight 49)) (cast f64 RIGHT_WIDTH) 49.0 (color 9 12 17))
      (line (cast f64 rightStart)
            (cast f64 (- screenHeight 49))
            (cast f64 screenWidth)
            (cast f64 (- screenHeight 49))
            1.0
            (color 20 26 34))
      (draw-text (field state monoMedium) c">" (cast f64 (+ rightStart 16)) (cast f64 (- screenHeight 31)) 12.0 tint)
      (draw-text (field state mono)
                 c"add a note to this step"
                 (cast f64 (+ rightStart 38))
                 (cast f64 (- screenHeight 31))
                 12.0
                 (color 69 78 90))
      (fill-rectangle (cast f64 (- screenWidth 29)) (cast f64 (- screenHeight 33)) 8.0 15.0 tint)
      0)))

(defn capture-input [(input (mut InputFrame))] (-> i64)
  (let [mouse (raylib.GetMousePosition)
        (mut typedCount) 0
        (mut typedCharacter) (cast i64 (raylib.GetCharPressed))
        shiftDown
          (if (or (icmp-ne (raylib.IsKeyDown (cast i32 KEY_LEFT_SHIFT)) (cast u8 0))
                  (icmp-ne (raylib.IsKeyDown (cast i32 KEY_RIGHT_SHIFT)) (cast u8 0)))
            1
            0)
        controlDown
          (if (or (icmp-ne (raylib.IsKeyDown (cast i32 KEY_LEFT_CONTROL)) (cast u8 0))
                  (icmp-ne (raylib.IsKeyDown (cast i32 KEY_RIGHT_CONTROL)) (cast u8 0)))
            1
            0)
        altDown
          (if (or (icmp-ne (raylib.IsKeyDown (cast i32 KEY_LEFT_ALT)) (cast u8 0))
                  (icmp-ne (raylib.IsKeyDown (cast i32 KEY_RIGHT_ALT)) (cast u8 0)))
            1
            0)
        superDown
          (if (or (icmp-ne (raylib.IsKeyDown (cast i32 KEY_LEFT_SUPER)) (cast u8 0))
                  (icmp-ne (raylib.IsKeyDown (cast i32 KEY_RIGHT_SUPER)) (cast u8 0)))
            1
            0)]
    (do
      (store! (field input mouseHorizontal) (/ (cast f64 (load (field mouse x))) (ui-scale)))
      (store! (field input mouseVertical) (/ (cast f64 (load (field mouse y))) (ui-scale)))
      (store! (field input pressed)
              (if (icmp-ne (raylib.IsMouseButtonPressed (cast i32 0)) (cast u8 0)) 1 0))
      (store! (field input down) (if (icmp-ne (raylib.IsMouseButtonDown (cast i32 0)) (cast u8 0)) 1 0))
      (while (and (> (load typedCharacter) 0) (< (load typedCount) INPUT_CHARACTER_CAPACITY))
        (do
          (store! (index (field input typedCharacters) (load typedCount)) (load typedCharacter))
          (store! typedCount (+ (load typedCount) 1))
          (store! typedCharacter (cast i64 (raylib.GetCharPressed)))))
      (store! (field input typedCount) (load typedCount))
      (store! (field input backspacePressed)
              (if (or (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_BACKSPACE)) (cast u8 0))
                      (icmp-ne (raylib.IsKeyPressedRepeat (cast i32 KEY_BACKSPACE)) (cast u8 0)))
                1
                0))
      (store! (field input deletePressed)
              (if (or (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_DELETE)) (cast u8 0))
                      (icmp-ne (raylib.IsKeyPressedRepeat (cast i32 KEY_DELETE)) (cast u8 0)))
                1
                0))
      (store! (field input leftPressed)
              (if (or (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_LEFT)) (cast u8 0))
                      (icmp-ne (raylib.IsKeyPressedRepeat (cast i32 KEY_LEFT)) (cast u8 0)))
                1
                0))
      (store! (field input rightPressed)
              (if (or (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_RIGHT)) (cast u8 0))
                      (icmp-ne (raylib.IsKeyPressedRepeat (cast i32 KEY_RIGHT)) (cast u8 0)))
                1
                0))
      (store! (field input homePressed)
              (if (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_HOME)) (cast u8 0)) 1 0))
      (store! (field input endPressed)
              (if (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_END)) (cast u8 0)) 1 0))
      (store! (field input enterPressed)
              (if (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_ENTER)) (cast u8 0)) 1 0))
      (store! (field input shiftDown) shiftDown)
      (store! (field input commandDown) (if (or (= superDown 1) (= controlDown 1)) 1 0))
      (store! (field input wordDown) (if (or (= altDown 1) (= controlDown 1)) 1 0))
      (store! (field input selectAllPressed)
              (if (and (or (= superDown 1) (= controlDown 1))
                       (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_A)) (cast u8 0)))
                1
                0))
      (store! (field input copyPressed)
              (if (and (or (= superDown 1) (= controlDown 1))
                       (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_C)) (cast u8 0)))
                1
                0))
      (store! (field input cutPressed)
              (if (and (or (= superDown 1) (= controlDown 1))
                       (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_X)) (cast u8 0)))
                1
                0))
      (store! (field input pastePressed)
              (if (and (or (= superDown 1) (= controlDown 1))
                       (icmp-ne (raylib.IsKeyPressed (cast i32 KEY_V)) (cast u8 0)))
                1
                0))
      (store! (field input pasteText)
              (if (= (load (field input pastePressed)) 1)
                (raylib.GetClipboardText)
                (cast (ptr i8) 0)))
      0)))

(defn draw-creation-editor [(state AppState) (left f64) (top f64) (width f64) (tint raylib.Color)] (-> i64)
  (let [text (load (field state creationText))
        length (load (field state creationLength))
        focused (= (load (field state creationFocused)) 1)
        sending (= (load (field state designState)) 1)
        textLeft (+ left 34.0)
        textWidth (- width 62.0)
        scroll (creation-text-scroll state textWidth)
        origin (- textLeft scroll)
        start (selection-start state)
        end (selection-end state)
        startWidth (text-width-through (field state sans) text start 11.5)
        endWidth (text-width-through (field state sans) text end 11.5)
        caretWidth (text-width-through (field state sans) text (load (field state creationFocus)) 11.5)
        border
          (cond (= (load (field state creationTruncated)) 1) (color 211 91 85)
                focused (load tint)
                (color 35 44 56))
        sendColor (if (or sending (= length 0)) (color 35 44 56) (load tint))]
    (do
      (fill-rectangle left top width 40.0 (if focused (color 11 16 23) (color 7 10 14)))
      (stroke-rectangle left top width 40.0 (if focused 1.5 1.0) border)
      (draw-text (field state monoMedium)
                 c">"
                 (+ left 12.0)
                 (+ top 11.0)
                 12.0
                 (if focused (load tint) (color 76 85 97)))
      (begin-scissor textLeft (+ top 4.0) textWidth 32.0)
      (if (< start end)
        (fill-rectangle (+ origin startWidth) (+ top 8.0) (- endWidth startWidth) 23.0 (color-alpha 74 121 178 110))
        0)
      (draw-text (field state sans)
                 (if (= length 0) c"Describe the outcome or ask a question..." text)
                 origin
                 (+ top 11.0)
                 11.5
                 (if (= length 0) (color 69 78 90) (if sending (color 107 116 128) (color 220 226 233))))
      (if (and focused
               (and (= start end) (< (fmod (raylib.GetTime) 1.0) 0.55)))
        (fill-rectangle (+ origin caretWidth) (+ top 8.0) 1.5 23.0 tint)
        0)
      (raylib.EndScissorMode)
      (fill-rectangle (+ left (- width 28.0)) (+ top 12.0) 28.0 28.0 sendColor)
      ;; The font atlas only rasterizes ASCII, so the busy glyph must be ASCII.
      (draw-text (field state monoMedium)
                 (if sending c"." c">")
                 (+ left (- width 19.0))
                 (+ top 18.0)
                 12.0
                 (if (or sending (= length 0)) (color 76 85 97) (color 10 14 19)))
      0)))

(defn draw-typing-bubble [(left f64) (top f64) (tint raylib.Color)] (-> i64)
  (let [time (raylib.GetTime)]
    (do
      (draw-card-background left top 84.0 40.0 true tint)
      (for [dot 0
            3]
        (let [wave (sin (- (* time 6.0) (* (cast f64 dot) 1.1)))
              alpha (cast i64 (+ 90.0 (* 65.0 (+ 1.0 wave))))]
          (fill-rectangle (+ left (+ 16.0 (* (cast f64 dot) 20.0)))
                          (+ top 17.0)
                          6.0
                          6.0
                          (color-alpha (cast i64 (load (field tint r)))
                                       (cast i64 (load (field tint g)))
                                       (cast i64 (load (field tint b)))
                                       alpha))))
      0)))

(defn draw-design-workspace [(state (mut AppState)) (input InputFrame) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [rightStart (- screenWidth RIGHT_WIDTH)
        center (/ (cast f64 (+ LEFT_WIDTH rightStart)) 2.0)
        contentLeft (cast f64 (+ rightStart 20))
        tint (accent 0)]
    (do
      (fill-rectangle (cast f64 LEFT_WIDTH)
                      0.0
                      (cast f64 (- rightStart LEFT_WIDTH))
                      (cast f64 screenHeight)
                      (color 7 10 14))
      (draw-grid LEFT_WIDTH rightStart screenHeight)
      (fill-rectangle (cast f64 LEFT_WIDTH) 0.0 (cast f64 (- rightStart LEFT_WIDTH)) 64.0 (color 7 10 14))
      (line (cast f64 LEFT_WIDTH) 63.0 (cast f64 rightStart) 63.0 1.0 (color 20 26 34))
      (begin-scissor 268.0 10.0 (cast f64 (- rightStart 494)) 28.0)
      (draw-text (field state monoMedium)
                 (if (= (load (field state designPreviewValid)) 1)
                   (workflow.program-name (load (field state designPreview)))
                   c"UNTITLED WORKFLOW")
                 268.0
                 14.0
                 15.0
                 (color 223 229 236))
      (raylib.EndScissorMode)
      (draw-text (field state mono) c"DRAFT / NOT SAVED" 268.0 39.0 9.5 (color 76 85 97))
      (if (> (load (field state designTurn)) 0)
        (do
          (stroke-rectangle (cast f64 (- rightStart 214)) 14.0 184.0 34.0 1.0 tint)
          (draw-text (field state monoMedium) c"BUILD THIS WORKFLOW  >" (cast f64 (- rightStart 198)) 24.0 9.5 tint)
          0)
        0)
      (if (= (load (field state designPreviewValid)) 1)
        (draw-flow state (load (field state designPreview)) -1 rightStart screenHeight tint)
        (do
          (stroke-rectangle (- center 28.0) 214.0 56.0 56.0 1.5 (color 42 51 63))
          (fill-rectangle (- center 4.0) 238.0 8.0 8.0 tint)
          (draw-text (field state monoMedium)
                     c"YOUR WORKFLOW WILL TAKE SHAPE HERE"
                     (- center 208.0)
                     310.0
                     16.0
                     (color 207 214 222))
          (draw-text (field state sans)
                     c"Talk through the outcome, constraints, and unknowns. The designer can\ninspect this repository and recommend useful steps as you iterate."
                     (- center 255.0)
                     351.0
                     13.0
                     (color 127 136 148))
          (draw-text (field state mono) c"NO NODES YET" (- center 53.0) 421.0 10.0 (color 61 69 79))
          0))
      (fill-rectangle (cast f64 rightStart) 0.0 (cast f64 RIGHT_WIDTH) (cast f64 screenHeight) (color 9 12 17))
      (line (cast f64 rightStart) 0.0 (cast f64 rightStart) (cast f64 screenHeight) 1.0 (color 23 30 39))
      (line (cast f64 rightStart) 78.0 (cast f64 screenWidth) 78.0 1.0 (color 20 26 34))
      (draw-text (field state monoMedium) c"WORKFLOW DESIGNER" contentLeft 18.0 14.0 (color 223 229 236))
      (fill-rectangle contentLeft
                      49.0
                      6.0
                      6.0
                      (cond (= (load (field state designState)) 1) (load tint)
                            (= (load (field state designState)) 3) (color 211 91 85)
                            (color 104 207 167)))
      (draw-text (field state mono)
                 (cond (= (load (field state designState)) 1) c"INSPECTING REPOSITORY..."
                       (= (load (field state designState)) 3) c"DESIGNER FAILED - SEE .flowline/design.events"
                       c"READY TO DISCOVER")
                 (+ contentLeft 16.0)
                 43.0
                 9.0
                 (if (= (load (field state designState)) 3) (color 211 91 85) (color 76 85 97)))
      (draw-card-background contentLeft 104.0 (cast f64 (- RIGHT_WIDTH 40)) 116.0 true tint)
      (draw-text (field state monoMedium) c"DESIGNER" (+ contentLeft 14.0) 118.0 9.0 tint)
      (selectable-text (mut state)
                       input
                       5
                       (field state sans)
                       c"What are you hoping this workflow will accomplish?\nYou can start with a rough idea. I'll inspect the project,\nidentify what matters, and suggest concrete next steps."
                       (+ contentLeft 14.0)
                       145.0
                       12.0
                       (color 190 198 208))
      (let [requestText (load (field state designRequest))
            haveRequest
              (if (and (!= (cast i64 requestText) 0) (icmp-ne (load requestText) (cast i8 0))) 1 0)
            requestLines
              (if (= haveRequest 1)
                (let [lines (count-text-lines requestText (byte-text-length requestText))]
                  (if (> lines 6) 6 lines))
                0)
            requestCardHeight (+ 42.0 (* (cast f64 requestLines) (text-line-advance 11.5)))
            responseTop (if (= haveRequest 1) (+ 260.0 requestCardHeight) 244.0)
            responseBottom (cast f64 (- screenHeight 100))]
        (do
          (if (= haveRequest 1)
            (do
              (draw-card-background contentLeft 244.0 (cast f64 (- RIGHT_WIDTH 40)) requestCardHeight false tint)
              (draw-text (field state monoMedium) c"YOU" (+ contentLeft 14.0) 256.0 9.0 tint)
              (begin-scissor (+ contentLeft 14.0) 270.0 (cast f64 (- RIGHT_WIDTH 68)) (- requestCardHeight 32.0))
              (selectable-text (mut state)
                               input
                               7
                               (field state sans)
                               requestText
                               (+ contentLeft 14.0)
                               274.0
                               11.5
                               (color 220 226 233))
              (raylib.EndScissorMode)
              0)
            0)
          (if (= (load (field state designState)) 1)
            (draw-typing-bubble contentLeft responseTop tint)
            (if (> (load (field state designTurn)) 0)
              (do
                (draw-card-background contentLeft
                                      responseTop
                                      (cast f64 (- RIGHT_WIDTH 40))
                                      (- responseBottom responseTop)
                                      true
                                      tint)
                (draw-text (field state monoMedium)
                           c"DESIGNER / RECOMMENDATION"
                           (+ contentLeft 14.0)
                           (+ responseTop 14.0)
                           9.0
                           tint)
                (begin-scissor (+ contentLeft 14.0)
                               (+ responseTop 42.0)
                               (cast f64 (- RIGHT_WIDTH 68))
                               (- responseBottom (+ responseTop 56.0)))
                (selectable-text (mut state)
                                 input
                                 6
                                 (field state sans)
                                 (load (field state designResponse))
                                 (+ contentLeft 14.0)
                                 (+ responseTop 42.0)
                                 11.5
                                 (color 190 198 208))
                (raylib.EndScissorMode)
                0)
              0))
          0))
      (fill-rectangle (cast f64 rightStart) (cast f64 (- screenHeight 76)) (cast f64 RIGHT_WIDTH) 76.0 (color 9 12 17))
      (line (cast f64 rightStart)
            (cast f64 (- screenHeight 76))
            (cast f64 screenWidth)
            (cast f64 (- screenHeight 76))
            1.0
            (color 20 26 34))
      (draw-creation-editor state contentLeft (cast f64 (- screenHeight 58)) (cast f64 (- RIGHT_WIDTH 40)) tint)
      0)))

(defn draw-empty-workspace [(state AppState) (screenWidth i64) (screenHeight i64)] (-> i64)
  (let [left (cast f64 LEFT_WIDTH)
        width (cast f64 (- screenWidth LEFT_WIDTH))
        center (/ (cast f64 (+ LEFT_WIDTH screenWidth)) 2.0)
        tint (accent 0)]
    (do
      (fill-rectangle left 0.0 width (cast f64 screenHeight) (color 7 10 14))
      (draw-grid LEFT_WIDTH screenWidth screenHeight)
      (fill-rectangle left 0.0 width (cast f64 HEADER_HEIGHT) (color 7 10 14))
      (line left 63.0 (cast f64 screenWidth) 63.0 1.0 (color 20 26 34))
      (draw-text (field state monoMedium) c"WORKFLOW CATALOG" (+ left 24.0) 18.0 14.0 (color 223 229 236))
      (stroke-rectangle (- center 31.0) 178.0 62.0 62.0 1.5 tint)
      (line (- center 13.0) 209.0 (+ center 13.0) 209.0 2.0 tint)
      (line center 196.0 center 222.0 2.0 tint)
      (draw-text (field state monoMedium) c"CREATE YOUR FIRST WORKFLOW" (- center 174.0) 281.0 19.0 (color 230 235 241))
      (draw-text (field state sans)
                 c"Describe an outcome for this project. A creator agent will inspect the\nrepository, design an executable DAG, and add it to this catalog."
                 (- center 274.0)
                 330.0
                 14.0
                 (color 142 153 166))
      (draw-text (field state mono) c"1  CLICK + NEW WORKFLOW" (- center 168.0) 406.0 11.0 tint)
      (draw-text (field state mono) c"2  DESCRIBE THE OUTCOME" (- center 168.0) 433.0 11.0 (color 107 116 128))
      (draw-text (field state mono) c"3  PRESS ENTER TO CREATE" (- center 168.0) 460.0 11.0 (color 107 116 128))
      (fill-rectangle (- center 116.0) 477.0 232.0 42.0 tint)
      (draw-text (field state monoMedium) c"+  NEW WORKFLOW" (- center 78.0) 490.0 12.0 (color 10 14 19))
      (draw-text (field state mono)
                 c"No templates or demo workflows are loaded."
                 (- center 156.0)
                 550.0
                 10.0
                 (color 61 69 79))
      0)))

(defn draw-creation-banner [(state AppState) (screenWidth i64)] (-> i64)
  (let [failed (= (load (field state creationState)) 3)
        center (/ (cast f64 (+ LEFT_WIDTH screenWidth)) 2.0)
        width 420.0
        left (- center (/ width 2.0))
        pulse (+ 0.5 (* 0.5 (sin (* (raylib.GetTime) 5.0))))
        tint (if failed (color 211 91 85) (color 224 165 58))]
    (do
      (fill-rectangle left 76.0 width 38.0 (if failed (color 26 12 12) (color 20 16 10)))
      (stroke-rectangle left 76.0 width 38.0 1.0 tint)
      (fill-rectangle (+ left 14.0)
                      90.0
                      8.0
                      8.0
                      (color-alpha (if failed 211 224)
                                   (if failed 91 165)
                                   (if failed 85 58)
                                   (+ 80 (cast i64 (* 175.0 pulse)))))
      (draw-text (field state monoMedium)
                 (if failed
                   c"WORKFLOW CREATION FAILED - SEE .flowline/create.events"
                   c"CREATING WORKFLOW - THE CREATOR AGENT IS WORKING...")
                 (+ left 32.0)
                 88.0
                 9.5
                 tint)
      0)))

(defn draw-app [(state (mut AppState)) (input InputFrame) (screenWidth i64) (screenHeight i64)] (-> i64)
  (do
    (raylib.ClearBackground (color 7 10 14))
    (draw-projects state screenHeight)
    (if (= (load (field state creationOpen)) 1)
      (draw-design-workspace (mut state) input screenWidth screenHeight)
      (if (= (workflow.catalog-count (load (field state catalog))) 0)
        (draw-empty-workspace state screenWidth screenHeight)
        (do
          (draw-center state screenWidth screenHeight)
          (draw-right (mut state) input screenWidth screenHeight)
          0)))
    (if (and (= (load (field state creationOpen)) 0)
             (or (= (load (field state creationState)) 1) (= (load (field state creationState)) 3)))
      (draw-creation-banner state screenWidth)
      0)
    0))

(defn run-interface [] (-> i64)
  (do
    (raylib.SetConfigFlags (cast u32 WINDOW_FLAGS))
    (raylib.InitWindow (cast i32 1440) (cast i32 900) c"flowline - agent workflow designer")
    (raylib.MaximizeWindow)
    (raylib.SetTargetFPS (cast i32 60))
    (let [mono (raylib.LoadFontEx c"assets/fonts/IBMPlexMono-Regular.ttf" (cast i32 64) (cast (ptr i32) 0) (cast i32 0))
          monoMedium
            (raylib.LoadFontEx c"assets/fonts/IBMPlexMono-Medium.ttf" (cast i32 64) (cast (ptr i32) 0) (cast i32 0))
          sans (raylib.LoadFontEx c"assets/fonts/IBMPlexSans-Regular.ttf" (cast i32 64) (cast (ptr i32) 0) (cast i32 0))
          catalogValue (workflow.load-catalog)
          catalog (alloc-stack workflow.Catalog)
          state (alloc-stack AppState)
          input (alloc-stack InputFrame)
          camera (alloc-stack raylib.Camera2D)
          creationText (workflow.allocate-buffer CREATION_CAPACITY)
          clipboardText (workflow.allocate-buffer 4096)
          measureText (workflow.allocate-buffer 4096)
          designResponse (workflow.allocate-buffer 4096)
          designRequest (workflow.allocate-buffer CREATION_CAPACITY)
          designPreview (workflow.allocate-runtime)]
      (store! catalog catalogValue)
      (store! creationText (cast i8 0))
      (store! clipboardText (cast i8 0))
      (store! designResponse (cast i8 0))
      (store! designRequest (cast i8 0))
      (store! (field state selectedProject) 0)
      (store! (field state selectedNode) 0)
      (store! (field state approvalGranted) 0)
      (store! (field state runRequested) 0)
      (store! (field state approvalRequested) 0)
      (store! (field state catalog) catalog)
      (store! (field state runtime) (workflow.catalog-runtime catalog 0))
      (store! (field state activeRuntime) (cast (ptr workflow.Runtime) 0))
      (store! (field state creationOpen) 0)
      (store! (field state creationRequested) 0)
      (store! (field state creationState) 0)
      (store! (field state creationLength) 0)
      (store! (field state creationText) creationText)
      (store! (field state creationAnchor) 0)
      (store! (field state creationFocus) 0)
      (store! (field state creationFocused) 0)
      (store! (field state creationDragging) 0)
      (store! (field state creationTruncated) 0)
      (store! (field state clipboardRequested) 0)
      (store! (field state clipboardText) clipboardText)
      (store! (field state designRequested) 0)
      (store! (field state designState) 0)
      (store! (field state designTurn) 0)
      (store! (field state designResponse) designResponse)
      (store! (field state designRequest) designRequest)
      (store! (field state designPreview) designPreview)
      (store! (field state designPreviewValid) 0)
      (store! (field state wrappedOutput) (cast (ptr i8) 0))
      (store! (field state wrappedOutputLength) 0)
      (store! (field state selectionRegion) 0)
      (store! (field state selectionAnchor) 0)
      (store! (field state selectionFocus) 0)
      (store! (field state selectionDragging) 0)
      (store! (field state selectionPressHandled) 0)
      (store! (field state hoverSelectableText) 0)
      (store! (field state measureText) measureText)
      (store! (field camera offset) (vector 0.0 0.0))
      (store! (field camera target) (vector 0.0 0.0))
      (store! (field camera rotation) (cast f32 0.0))
      (store! (field camera zoom) (cast f32 (ui-scale)))
      (store! (field state mono) mono)
      (store! (field state monoMedium) monoMedium)
      (store! (field state sans) sans)
      (configure-font (field state mono))
      (configure-font (field state monoMedium))
      (configure-font (field state sans))
      (loop (if (icmp-ne (raylib.WindowShouldClose) (cast u8 0))
              (break)
              (let [screenWidth (cast i64 (/ (cast f64 (raylib.GetScreenWidth)) (ui-scale)))
                    screenHeight (cast i64 (/ (cast f64 (raylib.GetScreenHeight)) (ui-scale)))]
                (do
                  (capture-input (mut input))
                  (apply-input (mut state) input screenWidth screenHeight)
                  (if (= (load (field state clipboardRequested)) 1)
                    (do
                      (raylib.SetClipboardText (load (field state clipboardText)))
                      (store! (field state clipboardRequested) 0)
                      0)
                    0)
                  (if (= (load (field state runRequested)) 1)
                    (let [selectedRuntime (load (field state runtime))
                          activeRuntime (load (field state activeRuntime))]
                      (do
                        (if (or (= (cast i64 activeRuntime) 0) (workflow.is-finished activeRuntime))
                          (do
                            (workflow.start (mut selectedRuntime))
                            (store! (field state activeRuntime) selectedRuntime)
                            0)
                          0)
                        (store! (field state runRequested) 0)
                        0))
                    0)
                  (if (= (load (field state approvalRequested)) 1)
                    (let [selectedRuntime (load (field state runtime))]
                      (do
                        (workflow.approve (mut selectedRuntime) (load (field state selectedNode)))
                        (if (= (workflow.node-status selectedRuntime (load (field state selectedNode))) 3)
                          (store! (field state approvalGranted) 1)
                          0)
                        (store! (field state approvalRequested) 0)
                        0))
                    0)
                  (if (= (load (field state creationRequested)) 1)
                    (do
                      (if (and (= (load (field state designPreviewValid)) 1)
                               (= (workflow.install-draft-workflow) 1))
                        (do
                          (workflow.refresh-catalog (mut catalog))
                          (let [createdWorkflowIndex (workflow.created-workflow-index catalog)]
                            (store! (field state selectedProject)
                                    (if (>= createdWorkflowIndex 0)
                                      createdWorkflowIndex
                                      (- (workflow.catalog-count catalog) 1))))
                          (store! (field state runtime)
                                  (workflow.catalog-runtime catalog (load (field state selectedProject))))
                          (store! (field state selectedNode) 0)
                          (store! (field state creationState) 2)
                          0)
                        (do
                          (workflow.start-creation-from-design)
                          (store! (field state creationState) 1)
                          0))
                      (store! (field state creationRequested) 0)
                      0)
                    0)
                  (if (= (load (field state designRequested)) 1)
                    (do
                      (copy-string (load (field state designRequest))
                                   (load (field state creationText))
                                   CREATION_CAPACITY)
                      (wrap-text-in-place state
                                          (load (field state designRequest))
                                          (field state sans)
                                          11.5
                                          404.0)
                      (workflow.start-design-turn (load (field state creationText)) (load (field state designTurn)))
                      (store! (field state designRequested) 0)
                      (store! (field state creationLength) 0)
                      (store! (field state creationAnchor) 0)
                      (store! (field state creationFocus) 0)
                      (store! creationText (cast i8 0))
                      0)
                    0)
                  (if (= (load (field state designState)) 1)
                    (let [designState (workflow.design-state)]
                      (if (= designState 2)
                        (do
                          (workflow.finish-design-turn designResponse)
                          (wrap-text-in-place state designResponse (field state sans) 11.5 404.0)
                          (store! designPreview (workflow.load-runtime c".flowline/design.draft.flow"))
                          (store! (field state designPreviewValid)
                                  (if (> (workflow.node-count designPreview) 0) 1 0))
                          (store! (field state designTurn) (+ (load (field state designTurn)) 1))
                          (store! (field state designState) 2)
                          0)
                        (if (= designState 3)
                          (do (store! (field state designState) 3) 0)
                          0)))
                    0)
                  (if (= (load (field state creationState)) 1)
                    (let [creationState (workflow.creation-state)]
                      (if (= creationState 2)
                        (do
                          (workflow.refresh-catalog (mut catalog))
                          (let [createdWorkflowIndex (workflow.created-workflow-index catalog)]
                            (store! (field state selectedProject)
                                    (if (>= createdWorkflowIndex 0)
                                      createdWorkflowIndex
                                      (- (workflow.catalog-count catalog) 1))))
                          (store! (field state runtime)
                                  (workflow.catalog-runtime catalog (load (field state selectedProject))))
                          (store! (field state selectedNode) 0)
                          (store! (field state creationState) 2)
                          (store! (field state creationLength) 0)
                          (store! (field state creationAnchor) 0)
                          (store! (field state creationFocus) 0)
                          (store! creationText (cast i8 0))
                          0)
                        (if (= creationState 3)
                          (do (store! (field state creationState) 3) 0)
                          0)))
                    0)
                  (let [activeRuntime (load (field state activeRuntime))]
                    (if (!= (cast i64 activeRuntime) 0)
                      (workflow.tick (mut activeRuntime))
                      0))
                  (store! (field state selectionPressHandled) 0)
                  (store! (field state hoverSelectableText) 0)
                  (raylib.BeginDrawing)
                  (raylib.BeginMode2D (load camera))
                  (draw-app (mut state) input screenWidth screenHeight)
                  (raylib.EndMode2D)
                  (raylib.EndDrawing)
                  (if (and (= (load (field input pressed)) 1)
                           (= (load (field state selectionPressHandled)) 0))
                    (do
                      (store! (field state selectionRegion) 0)
                      (store! (field state selectionAnchor) 0)
                      (store! (field state selectionFocus) 0)
                      (store! (field state selectionDragging) 0)
                      0)
                    0)
                  (raylib.SetMouseCursor
                    (cast i32
                          (if (= (load (field state hoverSelectableText)) 1)
                            MOUSE_CURSOR_IBEAM
                            MOUSE_CURSOR_DEFAULT)))
                  (continue)))))
      (raylib.UnloadFont (load (field state mono)))
      (raylib.UnloadFont (load (field state monoMedium)))
      (raylib.UnloadFont (load (field state sans))))
    (raylib.CloseWindow)
    0))

(defn render-interface-snapshot [] (-> i64)
  (do
    (raylib.SetConfigFlags (cast u32 WINDOW_FLAGS))
    (raylib.InitWindow (cast i32 1440) (cast i32 900) c"flowline - interface snapshot")
    (let [state (alloc-stack AppState)
          input (alloc-stack InputFrame)
          camera (alloc-stack raylib.Camera2D)
          catalogValue (workflow.load-catalog)
          catalog (alloc-stack workflow.Catalog)
          creationText (workflow.allocate-buffer CREATION_CAPACITY)
          clipboardText (workflow.allocate-buffer 4096)
          measureText (workflow.allocate-buffer 4096)
          designResponse (workflow.allocate-buffer 4096)
          designRequest (workflow.allocate-buffer CREATION_CAPACITY)
          designPreview (workflow.allocate-runtime)
          response
            c"Recommended workflow: start with a repository inspection step, then\nfan out into build verification and a documentation pass. Both feed a\nfinal human approval before anything lands on the main branch."
          screenWidth (cast i64 (/ (cast f64 (raylib.GetScreenWidth)) (ui-scale)))
          screenHeight (cast i64 (/ (cast f64 (raylib.GetScreenHeight)) (ui-scale)))]
      (store! state (zeroed AppState))
      (store! input (zeroed InputFrame))
      (store! catalog catalogValue)
      (store! creationText (cast i8 0))
      (store! clipboardText (cast i8 0))
      (let [(mut position) 0]
        (do
          (while (icmp-ne (load (index response (load position))) (cast i8 0))
            (do
              (store! (index designResponse (load position)) (load (index response (load position))))
              (store! position (+ (load position) 1))))
          (store! (index designResponse (load position)) (cast i8 0))))
      (copy-string designRequest
                   c"Help me design a review workflow for the flowline UI. It should check the renderer, the text selection code, and the deepseek adapter, then let me approve the final report before anything gets written."
                   CREATION_CAPACITY)
      (store! (field state catalog) catalog)
      (store! (field state runtime) (workflow.catalog-runtime catalog 0))
      (store! (field state creationText) creationText)
      (store! (field state clipboardText) clipboardText)
      (store! (field state measureText) measureText)
      (store! (field state designResponse) designResponse)
      (store! (field state designRequest) designRequest)
      (workflow.write-text-file c".flowline/snapshot.draft.flow"
                                c"workflow Draft Review Pipeline\nrunner deepseek\n\nagent inspect-repo\ntitle Inspect repository\nprompt Summarize the structure of src/main.coil.\nafter none\n\nagent review-ui\ntitle Review UI changes\nprompt Review src/main.coil for UI regressions.\nafter inspect-repo\n\napproval human-signoff\ntitle Human signoff\nafter review-ui\n")
      (store! designPreview (workflow.load-runtime c".flowline/snapshot.draft.flow"))
      (store! (field state designPreview) designPreview)
      (store! (field state designPreviewValid)
              (if (> (workflow.node-count designPreview) 0) 1 0))
      (store! (field state creationOpen) 1)
      (store! (field state designTurn) 1)
      (store! (field state designState) 2)
      (store! (field state selectionRegion) 6)
      (store! (field state selectionAnchor) 21)
      (store! (field state selectionFocus) 108)
      (store! (field state mono)
              (raylib.LoadFontEx c"assets/fonts/IBMPlexMono-Regular.ttf" (cast i32 64) (cast (ptr i32) 0) (cast i32 0)))
      (store! (field state monoMedium)
              (raylib.LoadFontEx c"assets/fonts/IBMPlexMono-Medium.ttf" (cast i32 64) (cast (ptr i32) 0) (cast i32 0)))
      (store! (field state sans)
              (raylib.LoadFontEx c"assets/fonts/IBMPlexSans-Regular.ttf" (cast i32 64) (cast (ptr i32) 0) (cast i32 0)))
      (configure-font (field state mono))
      (configure-font (field state monoMedium))
      (configure-font (field state sans))
      (wrap-text-in-place state designRequest (field state sans) 11.5 404.0)
      (wrap-text-in-place state designResponse (field state sans) 11.5 404.0)
      (store! (field camera offset) (vector 0.0 0.0))
      (store! (field camera target) (vector 0.0 0.0))
      (store! (field camera rotation) (cast f32 0.0))
      (store! (field camera zoom) (cast f32 (ui-scale)))
      (raylib.BeginDrawing)
      (raylib.BeginMode2D (load camera))
      (draw-app (mut state) input screenWidth screenHeight)
      (raylib.EndMode2D)
      (raylib.TakeScreenshot c"interface-design.png")
      (raylib.EndDrawing)
      (store! (field state designState) 1)
      (raylib.BeginDrawing)
      (raylib.BeginMode2D (load camera))
      (draw-app (mut state) input screenWidth screenHeight)
      (raylib.EndMode2D)
      (raylib.TakeScreenshot c"interface-pending.png")
      (raylib.EndDrawing)
      (store! (field state designState) 2)
      (store! (field state creationOpen) 0)
      (raylib.BeginDrawing)
      (raylib.BeginMode2D (load camera))
      (draw-app (mut state) input screenWidth screenHeight)
      (raylib.EndMode2D)
      (raylib.TakeScreenshot c"interface-empty.png")
      (raylib.EndDrawing)
      (store! (field state creationState) 1)
      (raylib.BeginDrawing)
      (raylib.BeginMode2D (load camera))
      (draw-app (mut state) input screenWidth screenHeight)
      (raylib.EndMode2D)
      (raylib.TakeScreenshot c"interface-creating.png")
      (raylib.EndDrawing)
      (store! (field state creationState) 0)
      (raylib.UnloadFont (load (field state mono)))
      (raylib.UnloadFont (load (field state monoMedium)))
      (raylib.UnloadFont (load (field state sans))))
    (raylib.CloseWindow)
    0))

(defn check-text-editor [] (-> i64)
  (let [state (alloc-stack AppState)
        input (alloc-stack InputFrame)
        text (workflow.allocate-buffer CREATION_CAPACITY)
        clipboardText (workflow.allocate-buffer CREATION_CAPACITY)]
    (do
      (store! state (zeroed AppState))
      (store! input (zeroed InputFrame))
      (store! text (cast i8 0))
      (store! clipboardText (cast i8 0))
      (store! (field state creationText) text)
      (store! (field state clipboardText) clipboardText)
      (store! (field state creationFocused) 1)
      (store! (field input typedCount) 3)
      (store! (index (field input typedCharacters) 0) 65)
      (store! (index (field input typedCharacters) 1) 233)
      (store! (index (field input typedCharacters) 2) 128640)
      (edit-creation-text (mut state) (load input))
      (store! input (zeroed InputFrame))
      (store! (field input backspacePressed) 1)
      (edit-creation-text (mut state) (load input))
      (store! input (zeroed InputFrame))
      (store! (field input homePressed) 1)
      (edit-creation-text (mut state) (load input))
      (store! input (zeroed InputFrame))
      (store! (field input typedCount) 1)
      (store! (index (field input typedCharacters) 0) 90)
      (edit-creation-text (mut state) (load input))
      (printf c"{\"text\":\"%s\",\"bytes\":%lld,\"anchor\":%lld,\"focus\":%lld,\"valid\":%s}\n"
              text
              (load (field state creationLength))
              (load (field state creationAnchor))
              (load (field state creationFocus))
              (if (and (= (load (field state creationLength)) 4)
                       (and (= (load (field state creationAnchor)) 1) (= (load (field state creationFocus)) 1)))
                c"true"
                c"false"))
      0)))

(defn main [(argumentCount i32) (arguments (ptr (ptr i8)))] (-> i64)
  (if (and (> (cast i64 argumentCount) 1)
           (workflow.strings-equal (load (index arguments 1)) c"--native-catalog"))
    (native.run-catalog)
    (if (and (> (cast i64 argumentCount) 1)
             (workflow.strings-equal (load (index arguments 1)) c"--render-interface"))
      (render-interface-snapshot)
    (if (and (> (cast i64 argumentCount) 1)
             (workflow.strings-equal (load (index arguments 1)) c"--render-native-catalog"))
      (native.render-catalog-snapshot)
      (if (and (> (cast i64 argumentCount) 1)
             (workflow.strings-equal (load (index arguments 1)) c"--check-native-controls"))
        (let [valid (native.check-catalog-interactions)]
          (do
            (printf c"{\"button\":true,\"checkbox\":true,\"switch\":true,\"slider\":true,\"toggle\":true,\"radioGroup\":true,\"valid\":%s}\n"
                    (if (= valid 1) c"true" c"false"))
            (if (= valid 1) 0 1)))
        (if (and (> (cast i64 argumentCount) 1)
             (workflow.strings-equal (load (index arguments 1)) c"--check-text-editor"))
          (check-text-editor)
          (if (and (> (cast i64 argumentCount) 2)
                   (workflow.strings-equal (load (index arguments 1)) c"--check-workflow"))
            (let [runtime (workflow.load-runtime (load (index arguments 2)))]
              (workflow.dump runtime))
            (if (and (> (cast i64 argumentCount) 1)
                     (workflow.strings-equal (load (index arguments 1)) c"--check-catalog"))
              (let [catalog (workflow.load-catalog)]
                (workflow.dump-catalog catalog))
              (run-interface)))))))))
