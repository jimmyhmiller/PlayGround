(module native)
(import "raylib.coil" :as raylib)

(const NATIVE_KEY_SPACE 32)
(const NATIVE_KEY_RIGHT 262)
(const NATIVE_KEY_LEFT 263)
(const NATIVE_KEY_TAB 258)
(const NATIVE_WINDOW_FLAGS 8292)

(defstruct Frame
  [(left f64) (top f64) (width f64) (height f64)])

(defstruct Interaction
  [(hovered i64) (pressed i64) (focused i64) (disabled i64)])

(defstruct CatalogInput
  [(mouseHorizontal f64)
   (mouseVertical f64)
   (mousePressed i64)
   (mouseDown i64)
   (tabPressed i64)
   (spacePressed i64)
   (leftPressed i64)
   (rightPressed i64)])

(defstruct CatalogState
  [(page i64)
   (focusedControl i64)
   (buttonCount i64)
   (checkboxChecked i64)
   (switchChecked i64)
   (sliderValue f64)
   (sliderDragging i64)
   (toggleChecked i64)
   (radioValue i64)
   (inputFocused i64)
   (textareaFocused i64)
   (accordionOpen i64)
   (tabValue i64)
   (groupValue i64)
   (paginationValue i64)
   (selectOpen i64)
   (comboboxOpen i64)
   (overlay i64)
   (resizableSplit f64)
   (mono raylib.Font)
   (sans raylib.Font)])

(defn color-alpha [(red i64) (green i64) (blue i64) (alpha i64)] (-> raylib.Color)
  (let [value (alloc-stack raylib.Color)]
    (do
      (store! (field value r) (cast u8 red))
      (store! (field value g) (cast u8 green))
      (store! (field value b) (cast u8 blue))
      (store! (field value a) (cast u8 alpha))
      (load value))))

(defn color [(red i64) (green i64) (blue i64)] (-> raylib.Color)
  (color-alpha red green blue 255))

(defn smaller [(left f64) (right f64)] (-> f64)
  (if (< left right) left right))

(defn larger [(left f64) (right f64)] (-> f64)
  (if (> left right) left right))

(defn vector [(horizontal f64) (vertical f64)] (-> raylib.Vector2)
  (let [value (alloc-stack raylib.Vector2)]
    (do
      (store! (field value x) (cast f32 horizontal))
      (store! (field value y) (cast f32 vertical))
      (load value))))

(defn rectangle [(frame Frame)] (-> raylib.Rectangle)
  (let [value (alloc-stack raylib.Rectangle)]
    (do
      (store! (field value x) (cast f32 (load (field frame left))))
      (store! (field value y) (cast f32 (load (field frame top))))
      (store! (field value width) (cast f32 (load (field frame width))))
      (store! (field value height) (cast f32 (load (field frame height))))
      (load value))))

(defn frame [(left f64) (top f64) (width f64) (height f64)] (-> Frame)
  (let [value (alloc-stack Frame)]
    (do
      (store! (field value left) left)
      (store! (field value top) top)
      (store! (field value width) width)
      (store! (field value height) height)
      (load value))))

(defn interaction [(hovered i64) (pressed i64) (focused i64) (disabled i64)] (-> Interaction)
  (let [value (alloc-stack Interaction)]
    (do
      (store! (field value hovered) hovered)
      (store! (field value pressed) pressed)
      (store! (field value focused) focused)
      (store! (field value disabled) disabled)
      (load value))))

(defn contains [(bounds Frame) (horizontal f64) (vertical f64)] (-> bool)
  (and (>= horizontal (load (field bounds left)))
       (and (<= horizontal (+ (load (field bounds left)) (load (field bounds width))))
            (and (>= vertical (load (field bounds top)))
                 (<= vertical (+ (load (field bounds top)) (load (field bounds height))))))))

(defn background [] (-> raylib.Color) (color 10 10 10))
(defn surface [] (-> raylib.Color) (color 23 23 23))
(defn surface-subtle [] (-> raylib.Color) (color 38 38 38))
(defn surface-pressed [] (-> raylib.Color) (color-alpha 255 255 255 38))
(defn text [] (-> raylib.Color) (color 250 250 250))
(defn text-muted [] (-> raylib.Color) (color 161 161 161))
(defn border [] (-> raylib.Color) (color-alpha 255 255 255 26))
(defn accent [] (-> raylib.Color) (color 229 229 229))
(defn accent-text [] (-> raylib.Color) (color 23 23 23))
(defn focus-ring [] (-> raylib.Color) (color 115 115 115))

(defn rounded-fill [(bounds Frame) (radius f64) (tint raylib.Color)] (-> i64)
  (do
    (raylib.DrawRectangleRounded (rectangle bounds) (cast f32 (/ radius (smaller (load (field bounds width)) (load (field bounds height))))) (cast i32 8) tint)
    0))

(defn rounded-stroke [(bounds Frame) (radius f64) (thickness f64) (tint raylib.Color)] (-> i64)
  (do
    (raylib.DrawRectangleRoundedLinesEx (rectangle bounds)
                                         (cast f32 (/ radius (smaller (load (field bounds width)) (load (field bounds height)))))
                                         (cast i32 8)
                                         (cast f32 thickness)
                                         tint)
    0))

(defn draw-label [(font raylib.Font) (label (ptr i8)) (left f64) (top f64) (size f64) (tint raylib.Color)] (-> i64)
  (do
    (raylib.DrawTextEx (load font) label (vector left top) (cast f32 size) (cast f32 0.0) tint)
    0))

(defn draw-centered-label [(font raylib.Font) (label (ptr i8)) (bounds Frame) (size f64) (tint raylib.Color)] (-> i64)
  (let [measured (raylib.MeasureTextEx (load font) label (cast f32 size) (cast f32 0.0))]
    (draw-label font
                label
                (+ (load (field bounds left)) (/ (- (load (field bounds width)) (cast f64 (load (field measured x)))) 2.0))
                (+ (load (field bounds top)) (/ (- (load (field bounds height)) size) 2.0))
                size
                tint)))

(defn draw-focus [(bounds Frame) (radius f64) (focused i64)] (-> i64)
  (if (= focused 1)
    (rounded-stroke (frame (- (load (field bounds left)) 3.0)
                           (- (load (field bounds top)) 3.0)
                           (+ (load (field bounds width)) 6.0)
                           (+ (load (field bounds height)) 6.0))
                    (+ radius 3.0)
                    2.0
                    (focus-ring))
    0))

(defn draw-button [(font raylib.Font) (label (ptr i8)) (bounds Frame) (state Interaction)] (-> i64)
  (let [disabled (= (load (field state disabled)) 1)
        fill (if disabled
               (color 70 70 70)
               (if (= (load (field state pressed)) 1) (color 199 199 199) (accent)))
        ink (if disabled (text-muted) (accent-text))]
    (do
      (rounded-fill bounds 6.0 fill)
      (draw-focus bounds 6.0 (load (field state focused)))
      (draw-centered-label font label bounds 14.0 ink)
      0)))

(defn draw-input [(font raylib.Font) (value (ptr i8)) (placeholder (ptr i8)) (bounds Frame) (state Interaction)] (-> i64)
  (let [hasValue (icmp-ne (load value) (cast i8 0))]
    (do
      (rounded-fill bounds 6.0 (surface))
      (rounded-stroke bounds 6.0 1.0 (border))
      (draw-focus bounds 6.0 (load (field state focused)))
      (draw-label font
                  (if hasValue value placeholder)
                  (+ (load (field bounds left)) 10.0)
                  (+ (load (field bounds top)) 8.0)
                  14.0
                  (if hasValue (text) (text-muted)))
      0)))

(defn draw-textarea [(font raylib.Font) (value (ptr i8)) (placeholder (ptr i8)) (bounds Frame) (state Interaction)] (-> i64)
  (let [hasValue (icmp-ne (load value) (cast i8 0))]
    (do
      (rounded-fill bounds 6.0 (surface))
      (rounded-stroke bounds 6.0 1.0 (border))
      (draw-focus bounds 6.0 (load (field state focused)))
      (draw-label font
                  (if hasValue value placeholder)
                  (+ (load (field bounds left)) 10.0)
                  (+ (load (field bounds top)) 9.0)
                  14.0
                  (if hasValue (text) (text-muted)))
      0)))

(defn draw-checkbox [(font raylib.Font) (label (ptr i8)) (bounds Frame) (checked i64) (state Interaction)] (-> i64)
  (let [box (frame (load (field bounds left))
                   (+ (load (field bounds top)) (/ (- (load (field bounds height)) 16.0) 2.0))
                   16.0
                   16.0)]
    (do
      (rounded-fill box 4.0 (if (= checked 1) (accent) (surface)))
      (rounded-stroke box 4.0 1.0 (border))
      (draw-focus box 4.0 (load (field state focused)))
      (if (= checked 1)
        (do
          (raylib.DrawLineEx (vector (+ (load (field box left)) 4.0) (+ (load (field box top)) 8.5))
                             (vector (+ (load (field box left)) 7.0) (+ (load (field box top)) 11.0))
                             (cast f32 2.0)
                             (accent-text))
          (raylib.DrawLineEx (vector (+ (load (field box left)) 7.0) (+ (load (field box top)) 11.0))
                             (vector (+ (load (field box left)) 12.0) (+ (load (field box top)) 5.0))
                             (cast f32 2.0)
                             (accent-text))
          0)
        0)
      (draw-label font label (+ (load (field bounds left)) 24.0) (+ (load (field bounds top)) 5.0) 14.0 (text))
      0)))

(defn draw-switch [(font raylib.Font) (label (ptr i8)) (bounds Frame) (checked i64) (state Interaction)] (-> i64)
  (let [track (frame (load (field bounds left))
                     (+ (load (field bounds top)) (/ (- (load (field bounds height)) 24.0) 2.0))
                     44.0
                     24.0)
        knobLeft (if (= checked 1) (+ (load (field track left)) 22.0) (+ (load (field track left)) 2.0))]
    (do
      (rounded-fill track 12.0 (if (= checked 1) (accent) (surface-pressed)))
      (raylib.DrawCircle (cast i32 (+ knobLeft 10.0))
                         (cast i32 (+ (load (field track top)) 12.0))
                         (cast f32 10.0)
                         (if (= checked 1) (accent-text) (text)))
      (draw-focus track 12.0 (load (field state focused)))
      (draw-label font label (+ (load (field bounds left)) 54.0) (+ (load (field bounds top)) 5.0) 14.0 (text))
      0)))

(defn draw-slider [(bounds Frame) (value f64) (state Interaction)] (-> i64)
  (let [clamped (larger 0.0 (smaller 1.0 value))
        trackTop (+ (load (field bounds top)) (/ (- (load (field bounds height)) 4.0) 2.0))
        activeWidth (* (load (field bounds width)) clamped)
        knobHorizontal (+ (load (field bounds left)) (* (load (field bounds width)) clamped))]
    (do
      (rounded-fill (frame (load (field bounds left)) trackTop (load (field bounds width)) 4.0) 2.0 (surface-subtle))
      (if (> activeWidth 0.0)
        (rounded-fill (frame (load (field bounds left)) trackTop activeWidth 4.0) 2.0 (accent))
        0)
      (raylib.DrawCircle (cast i32 knobHorizontal)
                         (cast i32 (+ (load (field bounds top)) (/ (load (field bounds height)) 2.0)))
                         (cast f32 6.0)
                         (color 255 255 255))
      (raylib.DrawCircleLines (cast i32 knobHorizontal)
                              (cast i32 (+ (load (field bounds top)) (/ (load (field bounds height)) 2.0)))
                              (cast f32 6.0)
                              (focus-ring))
      (if (= (load (field state focused)) 1)
        (do
          (raylib.DrawCircleLines (cast i32 knobHorizontal)
                                  (cast i32 (+ (load (field bounds top)) (/ (load (field bounds height)) 2.0)))
                                  (cast f32 9.0)
                                  (focus-ring))
          0)
        0)
      0)))

(defn draw-toggle [(font raylib.Font) (label (ptr i8)) (bounds Frame) (checked i64) (state Interaction)] (-> i64)
  (do
    (rounded-fill bounds 6.0 (if (= checked 1) (surface-pressed) (surface)))
    (if (= checked 1) 0 (rounded-stroke bounds 6.0 1.0 (border)))
    (draw-focus bounds 6.0 (load (field state focused)))
    (draw-centered-label font label bounds 14.0 (text))
    0))

(defn draw-radio [(font raylib.Font) (label (ptr i8)) (bounds Frame) (selected i64) (state Interaction)] (-> i64)
  (let [centerHorizontal (+ (load (field bounds left)) 8.0)
        centerVertical (+ (load (field bounds top)) (/ (load (field bounds height)) 2.0))]
    (do
      (raylib.DrawCircle (cast i32 centerHorizontal) (cast i32 centerVertical) (cast f32 8.0) (surface))
      (raylib.DrawCircleLines (cast i32 centerHorizontal) (cast i32 centerVertical) (cast f32 8.0) (border))
      (if (= selected 1)
        (do
          (raylib.DrawCircle (cast i32 centerHorizontal) (cast i32 centerVertical) (cast f32 4.0) (accent))
          0)
        0)
      (if (= (load (field state focused)) 1)
        (do
          (raylib.DrawCircleLines (cast i32 centerHorizontal) (cast i32 centerVertical) (cast f32 11.0) (focus-ring))
          0)
        0)
      (draw-label font label (+ (load (field bounds left)) 24.0) (+ (load (field bounds top)) 5.0) 14.0 (text))
      0)))

(defn draw-alert [(font raylib.Font)
                  (title (ptr i8))
                  (description (ptr i8))
                  (bounds Frame)
                  (destructive i64)] (-> i64)
  (do
    (rounded-fill bounds 8.0 (surface))
    (rounded-stroke bounds 8.0 1.0 (if (= destructive 1) (color 255 100 103) (border)))
    (draw-label font (if (= destructive 1) c"!" c"i") (+ (load (field bounds left)) 14.0) (+ (load (field bounds top)) 14.0) 14.0 (if (= destructive 1) (color 255 100 103) (text)))
    (draw-label font title (+ (load (field bounds left)) 40.0) (+ (load (field bounds top)) 12.0) 14.0 (text))
    (draw-label font description (+ (load (field bounds left)) 40.0) (+ (load (field bounds top)) 36.0) 13.0 (text-muted))
    0))

(defn draw-avatar [(font raylib.Font) (initials (ptr i8)) (bounds Frame)] (-> i64)
  (do
    (rounded-fill bounds (/ (load (field bounds height)) 2.0) (surface-subtle))
    (draw-centered-label font initials bounds 14.0 (text))
    0))

(defn draw-badge [(font raylib.Font) (label (ptr i8)) (bounds Frame) (strong i64)] (-> i64)
  (do
    (rounded-fill bounds (/ (load (field bounds height)) 2.0) (if (= strong 1) (accent) (surface-subtle)))
    (if (= strong 1) 0 (rounded-stroke bounds (/ (load (field bounds height)) 2.0) 1.0 (border)))
    (draw-centered-label font label bounds 12.0 (if (= strong 1) (accent-text) (text)))
    0))

(defn draw-breadcrumb [(font raylib.Font) (left f64) (top f64) (active (ptr i8))] (-> i64)
  (do
    (draw-label font c"Workflows" left top 13.0 (text-muted))
    (draw-label font c"/" (+ left 76.0) top 13.0 (text-muted))
    (draw-label font c"Design" (+ left 94.0) top 13.0 (text-muted))
    (draw-label font c"/" (+ left 142.0) top 13.0 (text-muted))
    (draw-label font active (+ left 160.0) top 13.0 (text))
    0))

(defn draw-bubble [(font raylib.Font) (message (ptr i8)) (bounds Frame) (agent i64)] (-> i64)
  (do
    (rounded-fill bounds 10.0 (if (= agent 1) (surface) (surface-subtle)))
    (if (= agent 1) (rounded-stroke bounds 10.0 1.0 (border)) 0)
    (draw-label font message (+ (load (field bounds left)) 14.0) (+ (load (field bounds top)) 12.0) 13.0 (text))
    0))

(defn draw-card [(font raylib.Font)
                 (title (ptr i8))
                 (description (ptr i8))
                 (bounds Frame)] (-> i64)
  (do
    (rounded-fill bounds 10.0 (surface))
    (rounded-stroke bounds 10.0 1.0 (border))
    (draw-label font title (+ (load (field bounds left)) 18.0) (+ (load (field bounds top)) 18.0) 16.0 (text))
    (draw-label font description (+ (load (field bounds left)) 18.0) (+ (load (field bounds top)) 48.0) 13.0 (text-muted))
    0))

(defn draw-separator [(bounds Frame)] (-> i64)
  (do
    (raylib.DrawRectangleRec (rectangle bounds) (border))
    0))

(defn draw-skeleton [(bounds Frame)] (-> i64)
  (rounded-fill bounds 6.0 (surface-subtle)))

(defn draw-progress [(bounds Frame) (value f64)] (-> i64)
  (let [clamped (larger 0.0 (smaller 1.0 value))]
    (do
      (rounded-fill bounds (/ (load (field bounds height)) 2.0) (surface-subtle))
      (if (> clamped 0.0)
        (rounded-fill (frame (load (field bounds left))
                             (load (field bounds top))
                             (* (load (field bounds width)) clamped)
                             (load (field bounds height)))
                      (/ (load (field bounds height)) 2.0)
                      (accent))
        0)
      0)))

(defn draw-spinner [(bounds Frame) (time f64)] (-> i64)
  (let [start (* time 210.0)]
    (do
      (raylib.DrawRing (vector (+ (load (field bounds left)) (/ (load (field bounds width)) 2.0))
                                  (+ (load (field bounds top)) (/ (load (field bounds height)) 2.0)))
                       (cast f32 6.0)
                       (cast f32 8.0)
                       (cast f32 start)
                       (cast f32 (+ start 275.0))
                       (cast i32 24)
                       (accent))
      0)))

(defn draw-table [(font raylib.Font) (bounds Frame)] (-> i64)
  (let [rowHeight (/ (load (field bounds height)) 4.0)
        firstColumn (+ (load (field bounds left)) (* (load (field bounds width)) 0.58))]
    (do
      (rounded-fill bounds 8.0 (surface))
      (rounded-stroke bounds 8.0 1.0 (border))
      (raylib.DrawLineEx (vector firstColumn (load (field bounds top)))
                         (vector firstColumn (+ (load (field bounds top)) (load (field bounds height))))
                         (cast f32 1.0)
                         (border))
      (for [row 1 4]
        (raylib.DrawLineEx (vector (load (field bounds left)) (+ (load (field bounds top)) (* (cast f64 row) rowHeight)))
                           (vector (+ (load (field bounds left)) (load (field bounds width))) (+ (load (field bounds top)) (* (cast f64 row) rowHeight)))
                           (cast f32 1.0)
                           (border)))
      (draw-label font c"Workflow" (+ (load (field bounds left)) 12.0) (+ (load (field bounds top)) 9.0) 12.0 (text-muted))
      (draw-label font c"State" (+ firstColumn 12.0) (+ (load (field bounds top)) 9.0) 12.0 (text-muted))
      (draw-label font c"Release readiness" (+ (load (field bounds left)) 12.0) (+ (+ (load (field bounds top)) rowHeight) 9.0) 13.0 (text))
      (draw-label font c"Ready" (+ firstColumn 12.0) (+ (+ (load (field bounds top)) rowHeight) 9.0) 13.0 (text))
      (draw-label font c"Support triage" (+ (load (field bounds left)) 12.0) (+ (+ (load (field bounds top)) (* rowHeight 2.0)) 9.0) 13.0 (text))
      (draw-label font c"Paused" (+ firstColumn 12.0) (+ (+ (load (field bounds top)) (* rowHeight 2.0)) 9.0) 13.0 (text))
      (draw-label font c"Contract review" (+ (load (field bounds left)) 12.0) (+ (+ (load (field bounds top)) (* rowHeight 3.0)) 9.0) 13.0 (text))
      (draw-label font c"Draft" (+ firstColumn 12.0) (+ (+ (load (field bounds top)) (* rowHeight 3.0)) 9.0) 13.0 (text))
      0)))

(defn draw-accordion [(font raylib.Font) (title (ptr i8)) (body (ptr i8)) (bounds Frame) (open i64) (state Interaction)] (-> i64)
  (do
    (rounded-fill bounds 8.0 (surface))
    (rounded-stroke bounds 8.0 1.0 (border))
    (draw-label font title (+ (load (field bounds left)) 14.0) (+ (load (field bounds top)) 13.0) 14.0 (text))
    (draw-label font (if (= open 1) c"-" c"+") (- (+ (load (field bounds left)) (load (field bounds width))) 26.0) (+ (load (field bounds top)) 12.0) 16.0 (text-muted))
    (if (= open 1)
      (do
        (draw-separator (frame (+ (load (field bounds left)) 14.0) (+ (load (field bounds top)) 43.0) (- (load (field bounds width)) 28.0) 1.0))
        (draw-label font body (+ (load (field bounds left)) 14.0) (+ (load (field bounds top)) 57.0) 13.0 (text-muted))
        0)
      0)
    (draw-focus bounds 8.0 (load (field state focused)))
    0))

(defn draw-tabs [(font raylib.Font) (bounds Frame) (selected i64)] (-> i64)
  (let [segmentWidth (/ (load (field bounds width)) 3.0)]
    (do
      (rounded-fill bounds 8.0 (surface-subtle))
      (rounded-fill (frame (+ (load (field bounds left)) (* segmentWidth (cast f64 selected)))
                           (+ (load (field bounds top)) 3.0)
                           segmentWidth
                           (- (load (field bounds height)) 6.0))
                    6.0
                    (surface))
      (draw-centered-label font c"Design" (frame (load (field bounds left)) (load (field bounds top)) segmentWidth (load (field bounds height))) 13.0 (if (= selected 0) (text) (text-muted)))
      (draw-centered-label font c"Runs" (frame (+ (load (field bounds left)) segmentWidth) (load (field bounds top)) segmentWidth (load (field bounds height))) 13.0 (if (= selected 1) (text) (text-muted)))
      (draw-centered-label font c"Settings" (frame (+ (load (field bounds left)) (* segmentWidth 2.0)) (load (field bounds top)) segmentWidth (load (field bounds height))) 13.0 (if (= selected 2) (text) (text-muted)))
      0)))

(defn draw-button-group [(font raylib.Font) (bounds Frame) (selected i64)] (-> i64)
  (let [segmentWidth (/ (load (field bounds width)) 3.0)]
    (do
      (for [segment 0 3]
        (do
          (rounded-fill (frame (+ (load (field bounds left)) (* segmentWidth (cast f64 segment)))
                               (load (field bounds top))
                               segmentWidth
                               (load (field bounds height)))
                        (if (or (= segment 0) (= segment 2)) 6.0 0.1)
                        (if (= selected segment) (accent) (surface)))
          (rounded-stroke (frame (+ (load (field bounds left)) (* segmentWidth (cast f64 segment)))
                                  (load (field bounds top))
                                  segmentWidth
                                  (load (field bounds height)))
                           (if (or (= segment 0) (= segment 2)) 6.0 0.1)
                           1.0
                           (border))))
      (draw-centered-label font c"Back" (frame (load (field bounds left)) (load (field bounds top)) segmentWidth (load (field bounds height))) 13.0 (if (= selected 0) (accent-text) (text)))
      (draw-centered-label font c"Pause" (frame (+ (load (field bounds left)) segmentWidth) (load (field bounds top)) segmentWidth (load (field bounds height))) 13.0 (if (= selected 1) (accent-text) (text)))
      (draw-centered-label font c"Next" (frame (+ (load (field bounds left)) (* segmentWidth 2.0)) (load (field bounds top)) segmentWidth (load (field bounds height))) 13.0 (if (= selected 2) (accent-text) (text)))
      0)))

(defn draw-toggle-group [(font raylib.Font) (bounds Frame) (selected i64)] (-> i64)
  (draw-button-group font bounds selected))

(defn draw-pagination [(font raylib.Font) (bounds Frame) (page i64)] (-> i64)
  (let [cell (load (field bounds height))]
    (do
      (for [item 0 5]
        (do
          (if (= item page)
            (rounded-fill (frame (+ (load (field bounds left)) (* cell (cast f64 item)))
                                 (load (field bounds top))
                                 cell
                                 cell)
                          6.0
                          (surface-subtle))
            0)
          (draw-centered-label font
                               (case item 0 c"<" 1 c"1" 2 c"2" 3 c"3" c">")
                               (frame (+ (load (field bounds left)) (* cell (cast f64 item))) (load (field bounds top)) cell cell)
                               13.0
                               (if (= item page) (text) (text-muted)))))
      0)))

(defn draw-select [(font raylib.Font) (label (ptr i8)) (bounds Frame) (open i64) (state Interaction)] (-> i64)
  (do
    (draw-input font label c"Select..." bounds state)
    (draw-label font (if (= open 1) c"^" c"v") (- (+ (load (field bounds left)) (load (field bounds width))) 24.0) (+ (load (field bounds top)) 8.0) 13.0 (text-muted))
    (if (= open 1)
      (do
        (rounded-fill (frame (load (field bounds left)) (+ (+ (load (field bounds top)) (load (field bounds height))) 6.0) (load (field bounds width)) 92.0) 8.0 (surface))
        (rounded-stroke (frame (load (field bounds left)) (+ (+ (load (field bounds top)) (load (field bounds height))) 6.0) (load (field bounds width)) 92.0) 8.0 1.0 (border))
        (draw-label font c"Ask before running" (+ (load (field bounds left)) 12.0) (+ (load (field bounds top)) 49.0) 13.0 (text))
        (draw-label font c"Run immediately" (+ (load (field bounds left)) 12.0) (+ (load (field bounds top)) 77.0) 13.0 (text-muted))
        (draw-label font c"Save as draft" (+ (load (field bounds left)) 12.0) (+ (load (field bounds top)) 105.0) 13.0 (text-muted))
        0)
      0)
    0))

(defn draw-combobox [(font raylib.Font) (query (ptr i8)) (bounds Frame) (open i64) (state Interaction)] (-> i64)
  (do
    (draw-input font query c"Search workflows..." bounds state)
    (if (= open 1)
      (do
        (rounded-fill (frame (load (field bounds left)) (+ (+ (load (field bounds top)) (load (field bounds height))) 6.0) (load (field bounds width)) 70.0) 8.0 (surface))
        (rounded-stroke (frame (load (field bounds left)) (+ (+ (load (field bounds top)) (load (field bounds height))) 6.0) (load (field bounds width)) 70.0) 8.0 1.0 (border))
        (rounded-fill (frame (+ (load (field bounds left)) 5.0) (+ (load (field bounds top)) 43.0) (- (load (field bounds width)) 10.0) 28.0) 5.0 (surface-subtle))
        (draw-label font c"Release readiness" (+ (load (field bounds left)) 12.0) (+ (load (field bounds top)) 49.0) 13.0 (text))
        (draw-label font c"Support triage" (+ (load (field bounds left)) 12.0) (+ (load (field bounds top)) 78.0) 13.0 (text-muted))
        0)
      0)
    0))

(defn draw-dropdown-menu [(font raylib.Font) (bounds Frame)] (-> i64)
  (do
    (rounded-fill bounds 8.0 (surface))
    (rounded-stroke bounds 8.0 1.0 (border))
    (draw-label font c"Run workflow" (+ (load (field bounds left)) 12.0) (+ (load (field bounds top)) 10.0) 13.0 (text))
    (draw-label font c"Duplicate" (+ (load (field bounds left)) 12.0) (+ (load (field bounds top)) 38.0) 13.0 (text))
    (draw-separator (frame (+ (load (field bounds left)) 8.0) (+ (load (field bounds top)) 66.0) (- (load (field bounds width)) 16.0) 1.0))
    (draw-label font c"Delete" (+ (load (field bounds left)) 12.0) (+ (load (field bounds top)) 78.0) 13.0 (color 255 100 103))
    0))

(defn draw-tooltip [(font raylib.Font) (label (ptr i8)) (bounds Frame)] (-> i64)
  (do
    (rounded-fill bounds 6.0 (text))
    (draw-centered-label font label bounds 12.0 (accent-text))
    0))

(defn draw-dialog [(font raylib.Font) (screenWidth f64) (screenHeight f64)] (-> i64)
  (let [bounds (frame (/ (- screenWidth 420.0) 2.0) (/ (- screenHeight 210.0) 2.0) 420.0 210.0)]
    (do
      (raylib.DrawRectangleRec (rectangle (frame 0.0 0.0 screenWidth screenHeight)) (color-alpha 0 0 0 166))
      (draw-card font c"Build this workflow?" c"The creator agent will write an executable workflow." bounds)
      (draw-button font c"Build workflow" (frame (+ (load (field bounds left)) 252.0) (+ (load (field bounds top)) 154.0) 150.0 36.0) (interaction 0 0 1 0))
      0)))

(defn draw-drawer [(font raylib.Font) (screenWidth f64) (screenHeight f64)] (-> i64)
  (let [bounds (frame 0.0 (- screenHeight 250.0) screenWidth 250.0)]
    (do
      (raylib.DrawRectangleRec (rectangle (frame 0.0 0.0 screenWidth screenHeight)) (color-alpha 0 0 0 120))
      (rounded-fill bounds 14.0 (surface))
      (draw-label font c"Run history" 28.0 (+ (load (field bounds top)) 28.0) 18.0 (text))
      (draw-label font c"Inspect events and agent output from the latest run." 28.0 (+ (load (field bounds top)) 60.0) 13.0 (text-muted))
      0)))

(defn draw-sheet [(font raylib.Font) (screenWidth f64) (screenHeight f64)] (-> i64)
  (let [bounds (frame (- screenWidth 420.0) 0.0 420.0 screenHeight)]
    (do
      (raylib.DrawRectangleRec (rectangle (frame 0.0 0.0 screenWidth screenHeight)) (color-alpha 0 0 0 120))
      (raylib.DrawRectangleRec (rectangle bounds) (surface))
      (draw-label font c"Workflow settings" (+ (load (field bounds left)) 28.0) 32.0 18.0 (text))
      (draw-label font c"Configure approvals and execution." (+ (load (field bounds left)) 28.0) 64.0 13.0 (text-muted))
      0)))

(defn draw-resizable [(font raylib.Font) (bounds Frame) (split f64)] (-> i64)
  (let [divider (+ (load (field bounds left)) (* (load (field bounds width)) split))]
    (do
      (rounded-fill bounds 8.0 (surface))
      (rounded-stroke bounds 8.0 1.0 (border))
      (raylib.DrawLineEx (vector divider (load (field bounds top)))
                         (vector divider (+ (load (field bounds top)) (load (field bounds height))))
                         (cast f32 2.0)
                         (border))
      (draw-label font c"Workflow graph" (+ (load (field bounds left)) 14.0) (+ (load (field bounds top)) 14.0) 13.0 (text))
      (draw-label font c"Inspector" (+ divider 14.0) (+ (load (field bounds top)) 14.0) 13.0 (text))
      0)))

(defn button-frame [] (-> Frame) (frame 100.0 166.0 220.0 32.0))
(defn input-frame [] (-> Frame) (frame 100.0 264.0 320.0 32.0))
(defn textarea-frame [] (-> Frame) (frame 100.0 364.0 320.0 92.0))
(defn checkbox-frame [] (-> Frame) (frame 560.0 166.0 260.0 28.0))
(defn switch-frame [] (-> Frame) (frame 560.0 250.0 260.0 28.0))
(defn slider-frame [] (-> Frame) (frame 560.0 348.0 280.0 28.0))
(defn toggle-frame [] (-> Frame) (frame 560.0 442.0 112.0 32.0))
(defn radio-first-frame [] (-> Frame) (frame 560.0 548.0 180.0 28.0))
(defn radio-second-frame [] (-> Frame) (frame 560.0 584.0 180.0 28.0))

(defn catalog-state [] (-> CatalogState)
  (let [state (alloc-stack CatalogState)]
    (do
      (store! state (zeroed CatalogState))
      (store! (field state page) 0)
      (store! (field state focusedControl) 0)
      (store! (field state sliderValue) 0.42)
      (store! (field state accordionOpen) 1)
      (store! (field state tabValue) 0)
      (store! (field state groupValue) 1)
      (store! (field state paginationValue) 2)
      (store! (field state selectOpen) 1)
      (store! (field state comboboxOpen) 1)
      (store! (field state resizableSplit) 0.58)
      (load state))))

(defn input-at [(horizontal f64) (vertical f64) (pressed i64) (down i64)] (-> CatalogInput)
  (let [input (alloc-stack CatalogInput)]
    (do
      (store! input (zeroed CatalogInput))
      (store! (field input mouseHorizontal) horizontal)
      (store! (field input mouseVertical) vertical)
      (store! (field input mousePressed) pressed)
      (store! (field input mouseDown) down)
      (load input))))

(defn activate-focused [(state (mut CatalogState))] (-> i64)
  (case (load (field state focusedControl))
        0 (store! (field state buttonCount) (+ (load (field state buttonCount)) 1))
        3 (store! (field state checkboxChecked) (- 1 (load (field state checkboxChecked))))
        4 (store! (field state switchChecked) (- 1 (load (field state switchChecked))))
        6 (store! (field state toggleChecked) (- 1 (load (field state toggleChecked))))
        7 (store! (field state radioValue) 0)
        8 (store! (field state radioValue) 1)
        0))

(defn apply-catalog-input [(state (mut CatalogState)) (input CatalogInput)] (-> i64)
  (let [horizontal (load (field input mouseHorizontal))
        vertical (load (field input mouseVertical))
        pressed (= (load (field input mousePressed)) 1)]
    (do
      (if pressed
        (cond (contains (frame 64.0 650.0 150.0 32.0) horizontal vertical)
                (do (store! (field state page) 0) 0)
              (contains (frame 224.0 650.0 150.0 32.0) horizontal vertical)
                (do (store! (field state page) 1) 0)
              (contains (frame 384.0 650.0 150.0 32.0) horizontal vertical)
                (do (store! (field state page) 2) 0)
              (contains (frame 544.0 650.0 150.0 32.0) horizontal vertical)
                (do (store! (field state page) 3) 0)
              true 0)
        0)
      (if (= (load (field input tabPressed)) 1)
        (store! (field state focusedControl) (% (+ (load (field state focusedControl)) 1) 9))
        0)
      (if (= (load (field input spacePressed)) 1) (activate-focused (mut state)) 0)
      (if (and (= (load (field state focusedControl)) 5)
               (= (load (field input leftPressed)) 1))
        (do
          (store! (field state sliderValue) (larger 0.0 (- (load (field state sliderValue)) 0.05)))
          0)
        0)
      (if (and (= (load (field state focusedControl)) 5)
               (= (load (field input rightPressed)) 1))
        (do
          (store! (field state sliderValue) (smaller 1.0 (+ (load (field state sliderValue)) 0.05)))
          0)
        0)
      (if (and pressed (= (load (field state page)) 0))
        (cond (contains (button-frame) horizontal vertical)
                (do
                  (store! (field state focusedControl) 0)
                  (store! (field state buttonCount) (+ (load (field state buttonCount)) 1))
                  0)
              (contains (input-frame) horizontal vertical)
                (do (store! (field state focusedControl) 1) (store! (field state inputFocused) 1) 0)
              (contains (textarea-frame) horizontal vertical)
                (do (store! (field state focusedControl) 2) (store! (field state textareaFocused) 1) 0)
              (contains (checkbox-frame) horizontal vertical)
                (do
                  (store! (field state focusedControl) 3)
                  (store! (field state checkboxChecked) (- 1 (load (field state checkboxChecked))))
                  0)
              (contains (switch-frame) horizontal vertical)
                (do
                  (store! (field state focusedControl) 4)
                  (store! (field state switchChecked) (- 1 (load (field state switchChecked))))
                  0)
              (contains (slider-frame) horizontal vertical)
                (do
                  (store! (field state focusedControl) 5)
                  (store! (field state sliderDragging) 1)
                  0)
              (contains (toggle-frame) horizontal vertical)
                (do
                  (store! (field state focusedControl) 6)
                  (store! (field state toggleChecked) (- 1 (load (field state toggleChecked))))
                  0)
              (contains (radio-first-frame) horizontal vertical)
                (do (store! (field state focusedControl) 7) (store! (field state radioValue) 0) 0)
              (contains (radio-second-frame) horizontal vertical)
                (do (store! (field state focusedControl) 8) (store! (field state radioValue) 1) 0)
              true (do
                     (store! (field state inputFocused) 0)
                     (store! (field state textareaFocused) 0)
                     0))
        0)
      (if (and pressed (= (load (field state page)) 2))
        (cond (contains (frame 64.0 142.0 400.0 100.0) horizontal vertical)
                (do (store! (field state accordionOpen) (- 1 (load (field state accordionOpen)))) 0)
              (contains (frame 64.0 300.0 360.0 40.0) horizontal vertical)
                (do
                  (store! (field state tabValue)
                          (cast i64 (larger 0.0 (smaller 2.0 (/ (- horizontal 64.0) 120.0)))))
                  0)
              (contains (frame 64.0 404.0 360.0 36.0) horizontal vertical)
                (do
                  (store! (field state groupValue)
                          (cast i64 (larger 0.0 (smaller 2.0 (/ (- horizontal 64.0) 120.0)))))
                  0)
              (contains (frame 540.0 142.0 330.0 32.0) horizontal vertical)
                (do (store! (field state selectOpen) (- 1 (load (field state selectOpen)))) 0)
              (contains (frame 540.0 310.0 330.0 32.0) horizontal vertical)
                (do (store! (field state comboboxOpen) (- 1 (load (field state comboboxOpen)))) 0)
              true 0)
        0)
      (if (and pressed (= (load (field state page)) 3))
        (cond (contains (frame 64.0 142.0 160.0 34.0) horizontal vertical)
                (do (store! (field state overlay) 1) 0)
              (contains (frame 238.0 142.0 160.0 34.0) horizontal vertical)
                (do (store! (field state overlay) 2) 0)
              (contains (frame 412.0 142.0 160.0 34.0) horizontal vertical)
                (do (store! (field state overlay) 3) 0)
              (= (load (field state overlay)) 0) 0
              true (do (store! (field state overlay) 0) 0))
        0)
      (if (and (= (load (field input mouseDown)) 1)
               (= (load (field state sliderDragging)) 1))
        (do
          (store! (field state sliderValue)
                  (larger 0.0 (smaller 1.0 (/ (- horizontal 560.0) 280.0))))
          0)
        0)
      (if (= (load (field input mouseDown)) 0) (store! (field state sliderDragging) 0) 0)
      0)))

(defn capture-catalog-input [] (-> CatalogInput)
  (let [mouse (raylib.GetMousePosition)
        input (alloc-stack CatalogInput)]
    (do
      (store! input (zeroed CatalogInput))
      (store! (field input mouseHorizontal) (cast f64 (load (field mouse x))))
      (store! (field input mouseVertical) (cast f64 (load (field mouse y))))
      (store! (field input mousePressed)
              (if (icmp-ne (raylib.IsMouseButtonPressed (cast i32 0)) (cast u8 0)) 1 0))
      (store! (field input mouseDown)
              (if (icmp-ne (raylib.IsMouseButtonDown (cast i32 0)) (cast u8 0)) 1 0))
      (store! (field input tabPressed)
              (if (icmp-ne (raylib.IsKeyPressed (cast i32 NATIVE_KEY_TAB)) (cast u8 0)) 1 0))
      (store! (field input spacePressed)
              (if (icmp-ne (raylib.IsKeyPressed (cast i32 NATIVE_KEY_SPACE)) (cast u8 0)) 1 0))
      (store! (field input leftPressed)
              (if (icmp-ne (raylib.IsKeyPressed (cast i32 NATIVE_KEY_LEFT)) (cast u8 0)) 1 0))
      (store! (field input rightPressed)
              (if (icmp-ne (raylib.IsKeyPressed (cast i32 NATIVE_KEY_RIGHT)) (cast u8 0)) 1 0))
      (load input))))

(defn control-interaction [(state CatalogState) (input CatalogInput) (identifier i64) (bounds Frame)] (-> Interaction)
  (interaction (if (contains bounds
                             (load (field input mouseHorizontal))
                             (load (field input mouseVertical)))
                 1
                 0)
               (if (and (= (load (field input mouseDown)) 1)
                        (contains bounds
                                  (load (field input mouseHorizontal))
                                  (load (field input mouseVertical))))
                 1
                 0)
               (if (= (load (field state focusedControl)) identifier) 1 0)
               0))

(defn draw-catalog-left [(state CatalogState) (input CatalogInput)] (-> i64)
  (do
    (draw-label (field state mono) c"BUTTON" 100.0 132.0 11.0 (text-muted))
    (draw-button (field state sans)
                 (if (= (load (field state buttonCount)) 0) c"Create workflow" c"Created")
                 (button-frame)
                 (control-interaction state input 0 (button-frame)))
    (draw-label (field state mono) c"INPUT" 100.0 230.0 11.0 (text-muted))
    (draw-input (field state sans)
                c""
                c"Describe an outcome..."
                (input-frame)
                (control-interaction state input 1 (input-frame)))
    (draw-label (field state mono) c"TEXTAREA" 100.0 330.0 11.0 (text-muted))
    (draw-textarea (field state sans)
                   c""
                   c"Add context for the workflow agent..."
                   (textarea-frame)
                   (control-interaction state input 2 (textarea-frame)))
    0))

(defn draw-catalog-right [(state CatalogState) (input CatalogInput)] (-> i64)
  (do
    (draw-label (field state mono) c"CHECKBOX" 560.0 132.0 11.0 (text-muted))
    (draw-checkbox (field state sans)
                   c"Require human approval"
                   (checkbox-frame)
                   (load (field state checkboxChecked))
                   (control-interaction state input 3 (checkbox-frame)))
    (draw-label (field state mono) c"SWITCH" 560.0 216.0 11.0 (text-muted))
    (draw-switch (field state sans)
                 c"Run automatically"
                 (switch-frame)
                 (load (field state switchChecked))
                 (control-interaction state input 4 (switch-frame)))
    (draw-label (field state mono) c"SLIDER" 560.0 314.0 11.0 (text-muted))
    (draw-slider (slider-frame)
                 (load (field state sliderValue))
                 (control-interaction state input 5 (slider-frame)))
    (draw-label (field state mono) c"TOGGLE" 560.0 408.0 11.0 (text-muted))
    (draw-toggle (field state sans)
                 c"Inspect"
                 (toggle-frame)
                 (load (field state toggleChecked))
                 (control-interaction state input 6 (toggle-frame)))
    (draw-label (field state mono) c"RADIO GROUP" 560.0 514.0 11.0 (text-muted))
    (draw-radio (field state sans)
                c"Ask before running"
                (radio-first-frame)
                (if (= (load (field state radioValue)) 0) 1 0)
                (control-interaction state input 7 (radio-first-frame)))
    (draw-radio (field state sans)
                c"Run immediately"
                (radio-second-frame)
                (if (= (load (field state radioValue)) 1) 1 0)
                (control-interaction state input 8 (radio-second-frame)))
    0))

(defn draw-catalog-surfaces [(state CatalogState)] (-> i64)
  (do
    (draw-alert (field state sans) c"Workflow paused" c"Human approval is required before the next step." (frame 64.0 138.0 400.0 82.0) 0)
    (draw-card (field state sans) c"Release readiness" c"7 steps / approval required" (frame 64.0 252.0 400.0 112.0))
    (draw-bubble (field state sans) c"Inspect the repository and recommend a plan." (frame 64.0 398.0 400.0 46.0) 0)
    (draw-breadcrumb (field state sans) 64.0 486.0 c"Release readiness")
    (draw-label (field state mono) c"AVATAR + BADGE" 64.0 538.0 11.0 (text-muted))
    (draw-avatar (field state sans) c"AG" (frame 64.0 566.0 40.0 40.0))
    (draw-badge (field state sans) c"Running" (frame 118.0 572.0 82.0 26.0) 1)
    (draw-badge (field state sans) c"Approval" (frame 212.0 572.0 88.0 26.0) 0)
    (draw-label (field state mono) c"TABLE" 520.0 104.0 11.0 (text-muted))
    (draw-table (field state sans) (frame 520.0 138.0 372.0 164.0))
    (draw-label (field state mono) c"PROGRESS" 520.0 336.0 11.0 (text-muted))
    (draw-progress (frame 520.0 368.0 260.0 8.0) 0.62)
    (draw-label (field state mono) c"SKELETON + SPINNER" 520.0 420.0 11.0 (text-muted))
    (draw-skeleton (frame 520.0 454.0 280.0 16.0))
    (draw-skeleton (frame 520.0 480.0 220.0 16.0))
    (draw-spinner (frame 824.0 458.0 28.0 28.0) (raylib.GetTime))
    (draw-separator (frame 520.0 536.0 372.0 1.0))
    (draw-alert (field state sans) c"Creation failed" c"The workflow file could not be parsed." (frame 520.0 562.0 372.0 64.0) 1)
    0))

(defn draw-catalog-navigation [(state CatalogState)] (-> i64)
  (do
    (draw-label (field state mono) c"ACCORDION" 64.0 108.0 11.0 (text-muted))
    (draw-accordion (field state sans)
                    c"What will the agent inspect?"
                    c"Repository structure, tooling, and existing workflows."
                    (frame 64.0 142.0 400.0 (if (= (load (field state accordionOpen)) 1) 100.0 48.0))
                    (load (field state accordionOpen))
                    (interaction 0 0 0 0))
    (draw-label (field state mono) c"TABS" 64.0 268.0 11.0 (text-muted))
    (draw-tabs (field state sans) (frame 64.0 300.0 360.0 40.0) (load (field state tabValue)))
    (draw-label (field state mono) c"BUTTON GROUP" 64.0 372.0 11.0 (text-muted))
    (draw-button-group (field state sans) (frame 64.0 404.0 360.0 36.0) (load (field state groupValue)))
    (draw-label (field state mono) c"TOGGLE GROUP" 64.0 472.0 11.0 (text-muted))
    (draw-toggle-group (field state sans) (frame 64.0 504.0 360.0 36.0) 0)
    (draw-label (field state mono) c"PAGINATION" 64.0 570.0 11.0 (text-muted))
    (draw-pagination (field state sans) (frame 64.0 600.0 180.0 32.0) (load (field state paginationValue)))
    (draw-label (field state mono) c"SELECT" 540.0 108.0 11.0 (text-muted))
    (draw-select (field state sans)
                 c"Ask before running"
                 (frame 540.0 142.0 330.0 32.0)
                 (load (field state selectOpen))
                 (interaction 0 0 0 0))
    (draw-label (field state mono) c"COMBOBOX" 540.0 276.0 11.0 (text-muted))
    (draw-combobox (field state sans)
                   c"Release"
                   (frame 540.0 310.0 330.0 32.0)
                   (load (field state comboboxOpen))
                   (interaction 0 0 1 0))
    (draw-label (field state mono) c"DROPDOWN MENU" 540.0 430.0 11.0 (text-muted))
    (draw-dropdown-menu (field state sans) (frame 540.0 462.0 220.0 112.0))
    (draw-tooltip (field state sans) c"Open workflow actions" (frame 678.0 592.0 174.0 30.0))
    0))

(defn draw-catalog-overlays [(state CatalogState)] (-> i64)
  (do
    (draw-label (field state mono) c"OVERLAY SURFACES" 64.0 106.0 11.0 (text-muted))
    (draw-button (field state sans) c"Open dialog" (frame 64.0 142.0 160.0 34.0) (interaction 0 0 0 0))
    (draw-button (field state sans) c"Open drawer" (frame 238.0 142.0 160.0 34.0) (interaction 0 0 0 0))
    (draw-button (field state sans) c"Open sheet" (frame 412.0 142.0 160.0 34.0) (interaction 0 0 0 0))
    (draw-label (field state mono) c"RESIZABLE" 64.0 228.0 11.0 (text-muted))
    (draw-resizable (field state sans) (frame 64.0 262.0 828.0 280.0) (load (field state resizableSplit)))
    (draw-label (field state sans) c"Click outside an open overlay to close it." 64.0 584.0 13.0 (text-muted))
    (case (load (field state overlay))
          1 (draw-dialog (field state sans) 960.0 700.0)
          2 (draw-drawer (field state sans) 960.0 700.0)
          3 (draw-sheet (field state sans) 960.0 700.0)
          0)))

(defn draw-catalog-navigation-bar [(state CatalogState)] (-> i64)
  (do
    (draw-toggle (field state sans) c"Controls" (frame 64.0 650.0 150.0 32.0) (if (= (load (field state page)) 0) 1 0) (interaction 0 0 0 0))
    (draw-toggle (field state sans) c"Surfaces" (frame 224.0 650.0 150.0 32.0) (if (= (load (field state page)) 1) 1 0) (interaction 0 0 0 0))
    (draw-toggle (field state sans) c"Navigation" (frame 384.0 650.0 150.0 32.0) (if (= (load (field state page)) 2) 1 0) (interaction 0 0 0 0))
    (draw-toggle (field state sans) c"Overlays" (frame 544.0 650.0 150.0 32.0) (if (= (load (field state page)) 3) 1 0) (interaction 0 0 0 0))
    0))

(defn draw-catalog [(state CatalogState) (input CatalogInput)] (-> i64)
  (do
    (raylib.ClearBackground (background))
    (draw-label (field state sans)
                (case (load (field state page)) 0 c"Native controls" 1 c"Native surfaces" 2 c"Native navigation" c"Native overlays")
                64.0
                38.0
                28.0
                (text))
    (draw-label (field state mono)
                c"HOUSE DARK / APACHE-2.0 ADAPTATION / POINTER + KEYBOARD"
                64.0
                78.0
                11.0
                (text-muted))
    (case (load (field state page))
          0 (do (draw-catalog-left state input) (draw-catalog-right state input) 0)
          1 (draw-catalog-surfaces state)
          2 (draw-catalog-navigation state)
          3 (draw-catalog-overlays state)
          0)
    (if (= (load (field state overlay)) 0) (draw-catalog-navigation-bar state) 0)
    0))

(defn run-catalog [] (-> i64)
  (do
    (raylib.SetConfigFlags (cast u32 NATIVE_WINDOW_FLAGS))
    (raylib.InitWindow (cast i32 960) (cast i32 700) c"flowline - native controls")
    (raylib.SetTargetFPS (cast i32 60))
    (let [state (alloc-stack CatalogState)
          initial (catalog-state)]
      (store! state initial)
      (store! (field state mono)
              (raylib.LoadFontEx c"assets/fonts/IBMPlexMono-Regular.ttf" (cast i32 42) (cast (ptr i32) 0) (cast i32 0)))
      (store! (field state sans)
              (raylib.LoadFontEx c"assets/fonts/IBMPlexSans-Regular.ttf" (cast i32 42) (cast (ptr i32) 0) (cast i32 0)))
      (raylib.SetTextureFilter (load (field (field state mono) texture)) (cast i32 1))
      (raylib.SetTextureFilter (load (field (field state sans) texture)) (cast i32 1))
      (loop (if (icmp-ne (raylib.WindowShouldClose) (cast u8 0))
              (break)
              (let [input (capture-catalog-input)]
                (do
                  (apply-catalog-input (mut state) input)
                  (raylib.BeginDrawing)
                  (draw-catalog (load state) input)
                  (raylib.EndDrawing)
                  (continue)))))
      (raylib.UnloadFont (load (field state mono)))
      (raylib.UnloadFont (load (field state sans))))
    (raylib.CloseWindow)
    0))

(defn render-catalog-snapshot [] (-> i64)
  (do
    (raylib.SetConfigFlags (cast u32 NATIVE_WINDOW_FLAGS))
    (raylib.InitWindow (cast i32 960) (cast i32 700) c"flowline - native controls snapshot")
    (let [state (alloc-stack CatalogState)
          initial (catalog-state)
          input (input-at 0.0 0.0 0 0)]
      (store! state initial)
      (store! (field state mono)
              (raylib.LoadFontEx c"assets/fonts/IBMPlexMono-Regular.ttf" (cast i32 42) (cast (ptr i32) 0) (cast i32 0)))
      (store! (field state sans)
              (raylib.LoadFontEx c"assets/fonts/IBMPlexSans-Regular.ttf" (cast i32 42) (cast (ptr i32) 0) (cast i32 0)))
      (raylib.SetTextureFilter (load (field (field state mono) texture)) (cast i32 1))
      (raylib.SetTextureFilter (load (field (field state sans) texture)) (cast i32 1))
      (raylib.BeginDrawing)
      (draw-catalog (load state) input)
      (raylib.TakeScreenshot c"native-controls.png")
      (raylib.EndDrawing)
      (raylib.UnloadFont (load (field state mono)))
      (raylib.UnloadFont (load (field state sans))))
    (raylib.CloseWindow)
    0))

(defn check-catalog-interactions [] (-> i64)
  (let [state (alloc-stack CatalogState)
        (mut input) (input-at 0.0 0.0 0 0)]
    (do
      (store! state (catalog-state))
      (store! input (input-at 200.0 182.0 1 0))
      (apply-catalog-input (mut state) (load input))
      (store! input (input-at 600.0 180.0 1 0))
      (apply-catalog-input (mut state) (load input))
      (store! input (input-at 600.0 264.0 1 0))
      (apply-catalog-input (mut state) (load input))
      (store! input (input-at 700.0 360.0 1 1))
      (apply-catalog-input (mut state) (load input))
      (store! input (input-at 700.0 360.0 0 0))
      (apply-catalog-input (mut state) (load input))
      (store! input (input-at 600.0 456.0 1 0))
      (apply-catalog-input (mut state) (load input))
      (store! input (input-at 600.0 598.0 1 0))
      (apply-catalog-input (mut state) (load input))
      (if (and (= (load (field state buttonCount)) 1)
               (and (= (load (field state checkboxChecked)) 1)
                    (and (= (load (field state switchChecked)) 1)
                         (and (> (load (field state sliderValue)) 0.49)
                              (and (= (load (field state toggleChecked)) 1)
                                   (= (load (field state radioValue)) 1))))))
        1
        0))))

(export Frame
        Interaction
        CatalogInput
        CatalogState
        frame
