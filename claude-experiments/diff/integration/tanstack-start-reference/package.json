    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.3",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "nitro": "3.0.260610-beta",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "vite": "8.1.5"
  }
