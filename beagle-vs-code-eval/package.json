{
  "name": "beagle-vs-code-eval",
  "displayName": "beagle-vs-code-eval",
  "description": "Live evaluation of Beagle code via socket REPL",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "beagle-vs-code-eval.sendFile",
        "title": "Beagle: Eval File"
      },
      {
        "command": "beagle-vs-code-eval.evalSelection",
        "title": "Beagle: Eval Selection/Line"
      },
      {
        "command": "beagle-vs-code-eval.run",
        "title": "Beagle: Run File with REPL"
      },
      {
        "command": "beagle-vs-code-eval.connect",
        "title": "Beagle: Connect to REPL"
      },
      {
        "command": "beagle-vs-code-eval.disconnect",
        "title": "Beagle: Disconnect from REPL"
      }
    ],
    "keybindings": [
      {
        "command": "beagle-vs-code-eval.evalSelection",
        "key": "ctrl+enter",
        "mac": "ctrl+enter"
      },
      {
        "command": "beagle-vs-code-eval.sendFile",
        "key": "ctrl+shift+enter",
        "mac": "ctrl+shift+enter"
      }
    ],
    "configuration": {
      "title": "Beagle",
      "properties": {
        "beagle.repl.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Beagle REPL server host"
        },
        "beagle.repl.port": {
          "type": "number",
          "default": 7888,
          "description": "Beagle REPL server port"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.96.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1"
  }
}
